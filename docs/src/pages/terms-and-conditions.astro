---
const lastUpdated = 'June 18, 2026';
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Terms and Conditions | PMP Recipes</title>
		<meta
			name="description"
			content="Terms and conditions for PMP Recipes, a recipe browsing app and website."
		/>
	</head>
	<body>
		<main class="terms-shell">
			<a class="back-link" href={base}>← Back to home</a>
			<h1>Terms and Conditions</h1>
			<p class="updated">Last updated: {lastUpdated}</p>

			<section>
				<h2>Use of the service</h2>
				<p>
					PMP Recipes provides recipe browsing and related content for personal, non-commercial
					use unless otherwise stated.
				</p>
			</section>

			<section>
				<h2>Content</h2>
				<p>
					Recipe names, descriptions, and related catalog information are provided as-is. We may
					update, remove, or reorganize content at any time.
				</p>
			</section>

			<section>
				<h2>No warranty</h2>
				<p>
					The service is provided without warranties of any kind, express or implied. We do not
					guarantee that the app or website will always be available or error-free.
				</p>
			</section>

			<section>
				<h2>Limitation of liability</h2>
				<p>
					To the maximum extent permitted by law, we are not liable for damages arising from use of
					the service or reliance on its content.
				</p>
			</section>

			<section>
				<h2>Changes to these terms</h2>
				<p>
					We may update these terms from time to time. Continued use of the service means you accept
					the updated terms.
				</p>
			</section>
		</main>
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		background: linear-gradient(180deg, #fffaf4 0%, #fff 100%);
		color: #221813;
	}

	body {
		margin: 0;
		min-height: 100vh;
	}

	.terms-shell {
		max-width: 760px;
		margin: 0 auto;
		padding: 2rem 1.25rem 3rem;
		line-height: 1.7;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 1rem;
		color: #a4551d;
		text-decoration: none;
		font-weight: 700;
	}

	h1,
	h2,
	p {
		margin-top: 0;
	}

	h1 {
		font-size: clamp(2.25rem, 6vw, 3.5rem);
		line-height: 1;
		margin-bottom: 0.5rem;
	}

	.updated {
		color: #6b5446;
		font-weight: 600;
		margin-bottom: 2rem;
	}

	section + section {
		margin-top: 1.5rem;
	}

	h2 {
		font-size: 1.15rem;
		margin-bottom: 0.4rem;
	}

	p {
		color: #4f4036;
	}
</style>
