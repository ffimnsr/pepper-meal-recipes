{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pmp.vastorigins.com/schemas/recipe.schema.json",
  "title": "Pepper Meal Planner Recipe",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "slug",
    "name",
    "instructions",
    "ingredients",
    "categories",
    "tags",
    "related_recipe_ids",
    "recipe_notes",
    "storage_notes",
    "public",
    "updated_at",
    "revision"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "recipe_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "brief_description": {
      "type": [
        "string",
        "null"
      ]
    },
    "cuisine": {
      "type": [
        "string",
        "null"
      ]
    },
    "instructions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/instructionStep"
      }
    },
    "servings": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "cooking_time_minutes": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "preparation_time_minutes": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "rest_time_minutes": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "difficulty": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "easy",
        "medium",
        "hard",
        "expert",
        null
      ]
    },
    "image_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "video_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "additional_media": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "nutritional_information": {
      "type": [
        "object",
        "null"
      ]
    },
    "dietary_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allergens": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "equipment": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ingredients": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ingredient"
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/category"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tag"
      }
    },
    "related_recipe_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "recipe_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "storage_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "public": {
      "type": "boolean"
    },
    "updated_at": {
      "type": "integer",
      "minimum": 0
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    }
  },
  "$defs": {
    "instructionStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "position",
        "text"
      ],
      "properties": {
        "position": {
          "type": "integer",
          "minimum": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ingredient": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ingredient_id",
        "name",
        "normalized_name",
        "position"
      ],
      "properties": {
        "ingredient_id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "normalized_name": {
          "type": "string",
          "minLength": 1
        },
        "quantity": {
          "type": [
            "string",
            "null"
          ]
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "preparation": {
          "type": [
            "string",
            "null"
          ]
        },
        "position": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slug",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "slug": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "tag": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slug",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "slug": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "color": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        }
      }
    }
  }
}
