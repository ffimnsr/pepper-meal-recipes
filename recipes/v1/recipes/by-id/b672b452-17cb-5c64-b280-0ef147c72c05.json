  "id": "b672b452-17cb-5c64-b280-0ef147c72c05",
  "slug": "slow-cooked-beef-brisket-recipe",
  "name": "Slow Cooked Beef Brisket Recipe",
  "recipe_type": null,
  "brief_description": "Slow Cooked Beef Brisket sounds like a nice idea for dinner during a busy day. It is full of flavor and also very tender. You can have this with bread as beef brisket sandwich, with tortillas and make some beef brisket taco burrito, or simply with white steamed rice \u2013 which I prefer.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the beef consomme, Worcestershire sauce, salt, and pepper in a bowl. Stir."
    },
    {
      "position": 2,
      "text": "Arrange the beef brisket in a crock pot (slow cooker). Add the minced onions and garlic on top."
    },
    {
      "position": 3,
      "text": "Pour-in the sauce mixture."
    },
    {
      "position": 4,
      "text": "Cover and slow cook the beef brisket for 5 to 6 hours."
    },
    {
      "position": 5,
      "text": "Gently remove the beef brisket from the crock pot."
    },
    {
      "position": 6,
      "text": "Pour the remaining liquid in a sauce pan and heat over the stove top. Let the sauce reduce to half."
    },
    {
      "position": 7,
      "text": "Pour the sauce over the beef brisket."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 360,
  "preparation_time_minutes": 5,
