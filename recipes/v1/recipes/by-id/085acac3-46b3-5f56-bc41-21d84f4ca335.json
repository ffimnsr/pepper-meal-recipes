  "id": "085acac3-46b3-5f56-bc41-21d84f4ca335",
  "slug": "spicy-bopis-recipe",
  "name": "Spicy Bopis Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for bopis. It is a Filipino dish that makes use of pig innards. It is eaten as pulutan or main dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute garlic, onion, and ginger."
    },
    {
      "position": 3,
      "text": "Put-in the pig's heart and cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Add the crushed pepper and annatto water. Stir."
    },
    {
      "position": 5,
      "text": "Add the dried bay leaves and pour-in water. Let boil and simmer for 5 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in vinegar and allow to reboil. Stir."
    },
    {
      "position": 7,
      "text": "Add carrots,red bell pepper, salt, and pepper. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
