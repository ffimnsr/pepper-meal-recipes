{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "3b5ce42c-55de-5b32-846c-8e7f61f92407",
  "slug": "sticky-crispy-chicken",
  "name": "Sticky Crispy Chicken",
  "recipe_type": "main",
  "brief_description": "Crispy chicken fingers tossed in a tangy sticky sauce with sesame seeds",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt, garlic powder, and ground white pepper on the chicken breasts. Rub it all over. Let it stand for at least 10 minutes."
    },
    {
      "position": 2,
      "text": "Combine all-purpose flour and cornstarch in a bowl. Mix it well."
    },
    {
      "position": 3,
      "text": "Dredge the chicken in the flour mixture, dip in beaten eggs, and roll it on the breadcrumbs. Make sure that the chicken gets completely coated. Arrange the coated chicken on a plate. Let it stay for 5 minutes. Note: This provides enough time for the breadcrumbs to absorb moisture which helps it to stick better."
    },
    {
      "position": 4,
      "text": "Heat oil in a wok or a deep pan. Deep-fry the coated chicken at 335F (168 Celsius) until golden brown. Remove from the wok and put it on a clean plate."
    },
    {
      "position": 5,
      "text": "Start making the sauce by combining all the sauce ingredients in a bowl. Mix it well."
    },
    {
      "position": 6,
      "text": "Pour the sauce mixture on a clean wok or pan. Let it boil. Adjust the heat to a simmer. Continue cooking while stirring occasionally until the mixture thickens."
    },
    {
      "position": 7,
      "text": "Add the crispy fried chicken pieces into the wok. Gently toss until the chicken gets completely coated with the sauce."
    },
    {
      "position": 8,
      "text": "Arrange the sticky crispy fried chicken on a serving plate. Sprinkle sesame seeds on top and garnish with chopped green onions. Serve with warm white rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 15,
