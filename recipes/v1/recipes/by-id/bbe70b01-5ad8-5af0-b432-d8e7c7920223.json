  "id": "bbe70b01-5ad8-5af0-b432-d8e7c7920223",
  "slug": "pata-at-hipon-sa-gata-na-may-monggo-at-langka",
  "name": "Pata at Hipon sa Gata na May Monggo at Langka",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pata at Hipon sa Gata na May Monggo at Langka",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour 4 quarts water in a pressure cooker. Add the pork hock. Boil for 15 minutes. Remove the pork hock and place in a bowl. Discard the water."
    },
    {
      "position": 2,
      "text": "Pour clean water on the same pressure cooker. Let boil."
    },
    {
      "position": 3,
      "text": "Add whole peppercorn, dried bay leaves, and put the pork hock back into the pressure cooker."
    },
    {
      "position": 4,
      "text": "Cover and pressure cook for 25 minutes."
    },
    {
      "position": 5,
      "text": "Remove the pressure and open the pressure cooker. Take the tender pork hocks out and set aside."
    },
    {
      "position": 6,
      "text": "Heat a cooking pot. Pour oil into it."
    },
    {
      "position": 7,
      "text": "Once the oil gets hot, pan-fry the shrimp for 1 minute per side.Remove the shrimp from the pot. Set aside."
    },
    {
      "position": 8,
      "text": "Add more oil if needed. Saute onion for 30 seconds."
    },
    {
      "position": 9,
      "text": "Add garlic. Continue to saute until onion becomes soft."
    },
    {
      "position": 10,
      "text": "Pour coconut milk into the pot. Let boil."
    },
    {
      "position": 11,
      "text": "Add Knorr Pork Cube. Stir."
    },
    {
      "position": 12,
      "text": "Put the mung beans into the pot. Cover and cook for 15 to 18 minutes."
    },
    {
      "position": 13,
      "text": "Add unripe jackfruit. Cover and cook for 10 to 12 minutes."
    },
    {
      "position": 14,
      "text": "Add chili pepper, shrimp paste, and ground black pepper. Stir."
    },
    {
      "position": 15,
      "text": "Put the pork hock into the pan. Cover and cook for 10 minutes."
    },
    {
      "position": 16,
      "text": "Add hot pepper leaves. Stir."
    },
    {
      "position": 17,
      "text": "Add the shrimp back into the pot. Cook for 3 minutes."
    },
    {
      "position": 18,
      "text": "Tranfer to a serving bowl. Serve."
    },
    {
      "position": 19,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
