  "id": "57d31c89-0a8a-5827-a761-b061ee3f0e8d",
  "slug": "fresh-basil-and-sun-dried-tomato-spaghetti-pasta",
  "name": "Fresh Basil and Sun Dried Tomato Spaghetti Pasta",
  "recipe_type": "main",
  "brief_description": "Fresh Basil and Sun Dried Tomato Spaghetti is a simple yet tasty pasta dish that anyone can prepare with ease. I like it because it is fresh",
  "cuisine": "italian",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the Spaghetti according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Heat olive oil in a wide pan."
    },
    {
      "position": 3,
      "text": "Once the oil starts to get hot, add garlic. Cook until garlic turns light brown."
    },
    {
      "position": 4,
      "text": "Stir-in the grape tomato and cook for 20 to 30 seconds."
    },
    {
      "position": 5,
      "text": "Add the sun-dried tomato and basil. Cook for 10 to 15 seconds."
    },
    {
      "position": 6,
      "text": "Quickly add the cooked spaghetti. Toss until all ingredients are well blended."
    },
    {
      "position": 7,
      "text": "Sprinkle the Parmesan cheese on top. Toss one more time. Turn the heat off and transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy your simple yet delicious pasta."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
