  "id": "8929b78e-4eac-5e5f-8376-c1eb3d1bac77",
  "slug": "how-to-make-longganisa",
  "name": "Longanisa Recipe (Filipino Sausage)",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for longanisa. It is a type of Filipino sweet sausage.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large container mix the salt, Prague powder, phosphate, Anise liquor, and water"
    },
    {
      "position": 2,
      "text": "Add the Textured Vegetable Protein, Isolate, and Carrageenan"
    },
    {
      "position": 3,
      "text": "Add the ground pork followed by the sugar, garlic, paprika, ground black pepper, pineapple juice, and meat enhancer then mix thoroughly."
    },
    {
      "position": 4,
      "text": "Place inside the refrigerator for 12 hours. (Note: Take note of the time. The mixture will smell sour if left for more than 12 hours)"
    },
    {
      "position": 5,
      "text": "Shape and wrap the longanisa individually. You can use sausage casings or you can simply shape the mixture over a wax or parchment paper. At this point, the finished product is ready to be cooked."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 18,
