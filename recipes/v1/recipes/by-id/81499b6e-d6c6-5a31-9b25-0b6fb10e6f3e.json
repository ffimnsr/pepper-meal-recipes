  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "81499b6e-d6c6-5a31-9b25-0b6fb10e6f3e",
  "slug": "pinoy-style-carbonara",
  "name": "Pinoy Style Carbonara",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pinoy Style Carbonara",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the spaghetti according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Heat a cooking pot. Sear the bacon. Continue to cook until the fat comes out and the bacon becomes crispy."
    },
    {
      "position": 3,
      "text": "Remove the bacon from the pot including half of the bacon fat. Set the bacon aside. We will add it later. As for the bacon fat, you can keep it in a sealed container for later use or you may discard it."
    },
    {
      "position": 4,
      "text": "Heat the remaining bacon fat in the pot. Add the ground beef and cook until it browns."
    },
    {
      "position": 5,
      "text": "Add the onion and garlic. Stir and cook until the onion becomes tender."
    },
    {
      "position": 6,
      "text": "Pour the beef broth. Let boil. Continue to cook until the liquid evaporates completely."
    },
    {
      "position": 7,
      "text": "Add the mushrooms. Stir."
    },
    {
      "position": 8,
      "text": "Slide-in the butter and then continue to cook until it melts."
    },
    {
      "position": 9,
      "text": "Pour 2 \u00bc cups of heavy whipping cream. Stir and let boil. Set the heat to medium."
    },
    {
      "position": 10,
      "text": "Add Parmesan cheese, salt and ground black pepper."
    },
    {
      "position": 11,
      "text": "In a bowl, beat the egg yolks and then add the remaining \u00bc cup heavy whipping cream. Continue to beat until all the ingredients are well blended."
    },
    {
      "position": 12,
      "text": "Pour the egg yolk mixture on the pot. Continuously stir until the texture of the white sauce becomes thick."
    },
    {
      "position": 13,
      "text": "Arrange a serving of spaghetti in a bowl and pour-in some carbonara sauce. Mix well."
    },
    {
      "position": 14,
      "text": "Twirl the spaghetti carbonara using a fork and then transfer to a pasta bowl. Top with bacon and Parmesan cheese."
    },
    {
      "position": 15,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
