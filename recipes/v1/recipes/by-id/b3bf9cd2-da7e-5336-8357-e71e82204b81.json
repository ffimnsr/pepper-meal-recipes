  "slug": "delicious-seafood-appetizer-dish-marinated-shrimp-with-lemon-dill-sauce-recipe",
  "name": "Marinated Shrimp with Lemon Dill Sauce",
  "recipe_type": "appetizer",
  "brief_description": "Marinated Shrimp with Lemon Dill Sauce is an appetizer dish that makes use of peeled semi-cooked shrimps. The preparation of this dish is a bit similar to how we make our \u201ckilawin\u201d although some of the ingredients are not common in a typical Filipino pantry.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, combine the mayonnaise, sour cream, sugar, lemon juice, salt, dill, and red onions then mix thoroughly."
    },
    {
      "position": 2,
      "text": "Add the shrimps then muddle up until the mixture covers the shrimps."
    },
    {
      "position": 3,
      "text": "Cover the top of the bowl with cling wrap then refrigerate overnight."
    },
    {
      "position": 4,
      "text": "Serve cold as an appetizer. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 10,
