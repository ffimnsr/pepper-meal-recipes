  "id": "713a4dd6-5f33-5d7d-a33c-59b926f31ef9",
  "slug": "easy-chicken-ala-king-recipe",
  "name": "Easy Chicken Ala King",
  "recipe_type": "main",
  "brief_description": "Chicken Katsu with creamy chicken ala king sauce",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the chicken katsu. Flatten the chicken breast by slightly pounding with the flat part of the meat tenderizer tool. Season salt, ground black pepper, and garlic powder all over the chicken."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan."
    },
    {
      "position": 3,
      "text": "While the oil is heating up, bread the chicken. Dredge it in all-purpose flour. Dip in the beaten egg mixture, dredge in flour again and then dip one more time in beaten egg. Now, roll it over the Panko breadcrumbs making sure that it gets completely coated."
    },
    {
      "position": 4,
      "text": "Deep fry the chicken katsu until the color of the breading turns golden brown. Note: if the oil is not enough, you can turn the chicken over to fully cook the opposite side."
    },
    {
      "position": 5,
      "text": "Remove the chicken from the pan and arrange in a serving plate. Set aside."
    },
    {
      "position": 6,
      "text": "Make the easy chicken ala king sauce by melting the butter in a saucepan. Add the cooking oil."
    },
    {
      "position": 7,
      "text": "Once the butter mixture gets hot, add the bell peppers. Saute for 1 \u00bd minutes."
    },
    {
      "position": 8,
      "text": "Combine Knorr Cream of Chicken and Corn and water. Stir until well blended. Pour the mixture into the saucepan. Continue cooking while stirring until the sauce thickens to your desired consistency."
    },
    {
      "position": 9,
      "text": "Pour the sauce over the chicken katsu. Serve with rice and Knorr Cream of mushroom soup on the side."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
