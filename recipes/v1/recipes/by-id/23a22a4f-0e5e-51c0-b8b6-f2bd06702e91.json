  "id": "23a22a4f-0e5e-51c0-b8b6-f2bd06702e91",
  "slug": "dark-chocolate-banana-bread",
  "name": "Dark Chocolate Banana Bread",
  "recipe_type": null,
  "brief_description": "This is a recipe for dark chocolate banana bread.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350F."
    },
    {
      "position": 2,
      "text": "Mash the bananas using a fork. Set aside."
    },
    {
      "position": 3,
      "text": "Combine flour, sugar, salt, baking soda, and dark chocolate powder in a bowl. Mix well using a wire whisk."
    },
    {
      "position": 4,
      "text": "Crack the eggs in and then pour the cooking oil. Also add the mashed banana. Fold the mixture until well blended."
    },
    {
      "position": 5,
      "text": "Grease a loaf pan and pour the banana bread mixture into it."
    },
    {
      "position": 6,
      "text": "Bake for 50 to 55 minutes."
    },
    {
      "position": 7,
      "text": "Remove from the oven and let the dark chocolate banana bread cool down. Slice and serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
