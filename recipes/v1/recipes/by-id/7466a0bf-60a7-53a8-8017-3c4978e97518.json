  "slug": "delicious-reuben-sandwich",
  "name": "Delicious Reuben Sandwich",
  "recipe_type": null,
  "brief_description": "Delicious Reuben Sandwich is a type of hot sandwich that makes use of corned beef brisket, sauerkraut, and cheese. It's simply out of this world.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Spread mayonnaise on one side of both bread slices."
    },
    {
      "position": 2,
      "text": "Arrange the cheese on top of one slice of bread with mayo."
    },
    {
      "position": 3,
      "text": "Generously top with corned beef brisket."
    },
    {
      "position": 4,
      "text": "Add Sauerkraut on top and then finish by placing the other bread slice over the Sauerkraut mayo side down."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
