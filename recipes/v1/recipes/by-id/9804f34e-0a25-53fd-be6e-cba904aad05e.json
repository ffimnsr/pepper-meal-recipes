  "id": "9804f34e-0a25-53fd-be6e-cba904aad05e",
  "slug": "corned-beef-guisado-recipe",
  "name": "Corned Beef Guisado Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for sauteed corned beef with potatoes using canned corned beef or carne norte.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 crushed garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the corned beef and then cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Put-in potatoes, garlic powder, and beef stock. Stir and let boil. Cover and Cook for 6 to 8 minutes."
    },
    {
      "position": 5,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
