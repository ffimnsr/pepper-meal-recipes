  "id": "4d78a6b0-528b-521c-83ca-5fe43dbc0747",
  "slug": "ginisang-baguio-beans-pork",
  "name": "Ginisang Baguio Beans with Pork",
  "recipe_type": null,
  "brief_description": "Ginisang Baguio Beans with Pork is a simple dish consisting of fresh green beans, tomato, and ground pork. Green beans are known as Baguio beans in the Philippines; this has something to do with the place where green beans are commonly grown.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the onion, garlic, and tomato."
    },
    {
      "position": 3,
      "text": "Add the ground pork when the tomato becomes soft. Continue to saute until the pork turns light to medium brown. Make sure that the pork is fully cooked."
    },
    {
      "position": 4,
      "text": "Add the fish sauce and ground black pepper. Stir."
    },
    {
      "position": 5,
      "text": "Put-in the sliced beans. Toss and continue to saute for 5 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
