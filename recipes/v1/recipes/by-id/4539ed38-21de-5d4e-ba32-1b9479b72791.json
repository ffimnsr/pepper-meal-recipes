  "id": "4539ed38-21de-5d4e-ba32-1b9479b72791",
  "slug": "killer-chicken-adobo",
  "name": "Killer Chicken Adobo",
  "recipe_type": "main",
  "brief_description": "Insanely delicious Filipino Chicken Adobo cooked with lemon lime soda.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken, soy sauce, and 1 cup lemon lime soda. Mix. Marinate for at least 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Pan-fry marinated chicken for 1 minute per side. Remove from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil, saut\u00e9 garlic until it browns. Put the pan-fried chicken back into the pan. Add remaining marinade, lemon lime soda, whole peppercorn, and dried bay leaves. Let boil."
    },
    {
      "position": 4,
      "text": "Pour-in vinegar. Let the mixture boil. Stir."
    },
    {
      "position": 5,
      "text": "Add Knorr Chicken Cube. Cover and reduce heat between low to medium. Cook for 20 minutes."
    },
    {
      "position": 6,
      "text": "Remove the cover of the pan. Adjust heat to medium. Continue cooking while stirring every few minutes until the sauce evaporates."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
