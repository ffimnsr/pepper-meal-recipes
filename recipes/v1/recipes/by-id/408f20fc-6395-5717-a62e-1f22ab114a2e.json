  "id": "408f20fc-6395-5717-a62e-1f22ab114a2e",
  "slug": "chickpea-salad-recipe",
  "name": "Chickpea Salad",
  "recipe_type": "salad",
  "brief_description": "Chickpea Salad is a delicious dish that I always enjoy during lunchtime. It can be considered as a meal by itself because it is satisfying",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine chickpeas, tomato, basil, parsley, lemon juice, and onion in a bowl. Toss gently until the ingredients are well incorporated."
    },
    {
      "position": 2,
      "text": "Meanwhile, make the dressing by combining the extra virgin olive oil, red wine vinegar, salt, and pepper in a bowl. Whisk well for 30 seconds."
    },
    {
      "position": 3,
      "text": "Pour the dressing over the chickpeas and other ingredients. Gently toss one more time. cover the bowl with a cling wrap. Refrigerate for 3 hours."
    },
    {
      "position": 4,
      "text": "Serve for lunch. Share and enjoy!"
    }
  ],
  "servings": 5,
