  "id": "48c7de9a-505f-531b-8d6f-e90e6380166f",
  "slug": "pork-asado-recipe",
  "name": "Pork Asado Recipe",
  "recipe_type": "main",
  "brief_description": "Pork Asado or Asadong Baboy is a sweet pork dish that was introduced by the Chinese. Unlike Chicken Asado, which is its name counterpart, this dish is prepared with pork simmered in a sweet and savory sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine soy sauce, five spice powder, garlic, cooking rice wine, and salt then mix well."
    },
    {
      "position": 2,
      "text": "Marinate the pork in the combined mixture for at least 1 hour."
    },
    {
      "position": 3,
      "text": "Heat a cooking pot then put-in the pork along with the marinade and water then let boil."
    },
    {
      "position": 4,
      "text": "Add brown sugar and stir to distribute evenly."
    },
    {
      "position": 5,
      "text": "Simmer for about 40 minutes flipping the meat after 20 minutes or so to tenderize the other side."
    },
    {
      "position": 6,
      "text": "Turn off the heat and remove the meat from the cooking pot."
    },
    {
      "position": 7,
      "text": "Allow the meat to rest for about 10 minutes then slice."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate and top with the thick sauce then serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 10,
  "difficulty": "medium",
