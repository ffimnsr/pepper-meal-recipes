  "id": "b4b65901-1c24-5835-ab12-6d33cf8692aa",
  "slug": "chicken-barbecue-recipe",
  "name": "Chicken Barbecue",
  "recipe_type": "dessert",
  "brief_description": "Easy chicken barbecue using sweet banana sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make the marinade by combining the soy sauce, juice of 1 lemon, banana ketchup, salt, and ground black pepper in a bowl. Stir to mix."
    },
    {
      "position": 2,
      "text": "Put the chicken leg quarters inside a large freezer bag, and then pour-in the marinade."
    },
    {
      "position": 3,
      "text": "Shake the bag gently to coat the chicken with marinade then remove the air inside the bag. Seal the bag then refrigerate overnight."
    },
    {
      "position": 4,
      "text": "Remove the chicken from the bag and transfer the remaining marinade to a bowl."
    },
    {
      "position": 5,
      "text": "Heat-up your grill and start grilling the chicken under medium heat for 12 to 15 minutes per side or until the chicken is completely cooked. Do not forget to baste the chicken with the remaining marinade mixture."
    },
    {
      "position": 6,
      "text": "Note: Chicken takes a long time to cook. Grilling it in high heat will cause the outer part of the chicken to cook earlier leaving the inside raw."
    },
    {
      "position": 7,
      "text": "Remove from the grill and transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with steamed rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 24,
  "preparation_time_minutes": 60,
  "rest_time_minutes": null,
  "difficulty": "hard",
