  "slug": "cabbage-soup-recipe",
  "name": "Cabbage Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "This tried and tested Cabbage Soup Recipe does not only taste great, it is also low in calories. This makes this recipe good for weight loss.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the olive oil in a cooking pot, and then saute onion and garlic."
    },
    {
      "position": 2,
      "text": "Add the cabbage, and then cook for a minute."
    },
    {
      "position": 3,
      "text": "Pour-in the organic tomato sauce and low sodium chicken broth. Stir and let boil."
    },
    {
      "position": 4,
      "text": "Simmer for 5 to 7 minutes."
    },
    {
      "position": 5,
      "text": "Turn the heat off. Transfer to a serving bowl."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
