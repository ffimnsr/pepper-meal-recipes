  "id": "6ab9b02b-89de-5f52-873e-5394eb0832b0",
  "slug": "how-to-cook-tuna-pasta-alfredo",
  "name": "Tuna Pasta Alfredo",
  "recipe_type": null,
  "brief_description": "Tuna Pasta Alfredo is a good dish to make at this time. It is quick and easy to cook, and the ingredients are easy to source.",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a pan. Add garlic. Cook while stirring until garlic starts to brown."
    },
    {
      "position": 2,
      "text": "Add all-purpose cream. Cook for 30 seconds."
    },
    {
      "position": 3,
      "text": "Pour-in fresh milk. Stir. Let boil."
    },
    {
      "position": 4,
      "text": "Add tuna. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Put the Parmesan cheese into the pan. Cook for 30 to 40 seconds."
    },
    {
      "position": 6,
      "text": "Season with salt and ground black pepper. Stir until all ingredients are well blended."
    },
    {
      "position": 7,
      "text": "Add the cooked linguine. Toss until pasta is coated with sauce. Add chopped parsley if desired."
    },
    {
      "position": 8,
      "text": "Transfer to a pasta bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
