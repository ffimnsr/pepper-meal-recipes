  "id": "5e1d3622-6873-5939-9f09-733087b001dc",
  "slug": "chicken-and-ham-sopas",
  "name": "Chicken and Ham Sopas Recipe",
  "recipe_type": null,
  "brief_description": "Chicken and Ham Sopas is perfect during cold weather. This version of the popular chicken sopas will excite your taste buds.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a deep cooking pot."
    },
    {
      "position": 2,
      "text": "Put-in the butter to melt."
    },
    {
      "position": 3,
      "text": "Add-in the onions once the butter becomes hot.Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the celery ribs. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "add the ground chicken and ham. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the chicken broth and water. Let boil. Simmer for 30 minutes."
    },
    {
      "position": 7,
      "text": "Add the carrots and potato. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Pour-in the evaporated milk. Allow to boil, and then simmer for 10 minutes."
    },
    {
      "position": 9,
      "text": "Put-in the noodles and thyme. Cook for 12 to 15 minutes."
    },
    {
      "position": 10,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 12,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
