  "id": "5eb235b4-c825-5ce6-aba9-2e80352bc6db",
  "slug": "adobong-bulalo",
  "name": "Adobong Bulalo",
  "recipe_type": "side",
  "brief_description": "Adobong Bulalo is a delicious beef dish that can be considered as a hybrid of pork adobo and bulalo. This can also be referred to as beef shank adobo. This is a perfect dish to serve for lunch during the weekend -- don't forget the warm white rice to make it complete.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Add in the garlic when the oil becomes hot. Cook until the color turns light brown."
    },
    {
      "position": 3,
      "text": "Put-in the beef shank. Pan-fry each side for 1 minute or until it browns."
    },
    {
      "position": 4,
      "text": "Pour-in the soy sauce and water. Add the whole peppercorn and bay leaves. Bring to a boil."
    },
    {
      "position": 5,
      "text": "Reduce the heat to simmer. Cover and simmer for 60 to 90 minutes or until the beef is tender."
    },
    {
      "position": 6,
      "text": "Remove the cover. Add the vinegar and sugar. Let it boil and then stir. Cook for 3 to 5 minutes more."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with warm white rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
