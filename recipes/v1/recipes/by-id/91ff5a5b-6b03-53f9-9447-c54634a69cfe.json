  "id": "91ff5a5b-6b03-53f9-9447-c54634a69cfe",
  "slug": "deep-fried-mussels",
  "name": "Deep Fried Mussels",
  "recipe_type": "appetizer",
  "brief_description": "Deep Fried Mussels are mussel meats removed from the shell, coated in batter, and deep fried until crispy. This makes a good appetizer.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle 2 teaspoons of salt and 1/2 teaspoon of ground black pepper on the mussel meat. Mix well and then let it stand for 30 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, make the batter by combining 3/4 cup flour, cornstarch, eggs, water, garlic powder, and remaining salt and pepper in a medium bowl. Mix well until the texture becomes smooth."
    },
    {
      "position": 3,
      "text": "Heat the oil in a deep cooking pot."
    },
    {
      "position": 4,
      "text": "Dip the mussel meat in the batter and then dredge in the remaining flour. This will prevent the mussel meat from sticking to each other."
    },
    {
      "position": 5,
      "text": "Deep fry the coated mussel meat in medium heat until the color of the coating turns golden brown."
    },
    {
      "position": 6,
      "text": "Serve with garlic sauce. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 10,
