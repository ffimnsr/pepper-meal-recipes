  "id": "44edbc60-b19a-52cb-a5d0-53f252298a68",
  "slug": "mini-banana-cake-with-walnuts-for-kids",
  "name": "Mini Banana Cake with Walnuts for Kids",
  "recipe_type": "dessert",
  "brief_description": "This is a Recipe for Mini Banana Cake with walnuts for Kids",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350F."
    },
    {
      "position": 2,
      "text": "In a mixing bowl, combine flour, baking soda, and salt. Stir using a wire whisk until well blended. Set aside."
    },
    {
      "position": 3,
      "text": "Combine softened butter, vanilla extract, and sour cream in another bowl. Start to cream the mixture; use a blended, if possible for better results. The beater blade of your stand mixer needs to be used in this process."
    },
    {
      "position": 4,
      "text": "Add the mashed bananas and walnuts while beating and then gradually add the flour mixture. Continue to beat until the texture becomes smooth."
    },
    {
      "position": 5,
      "text": "Scoop the mixture and arrange in small rectangular cups or cupcake cups. Put the rectangular cups over a baking tray. If using cupcake cups, use a muffin pan."
    },
    {
      "position": 6,
      "text": "Bake in the oven for 20 to 30 minutes or until it turns golden brown"
    },
    {
      "position": 7,
      "text": "Remove from oven. Serve. You can also top with whip cream so that kids will like it more."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 12,
