  "id": "21bb69ee-8549-53c5-90f0-5f4e154beac2",
  "slug": "beef-broccoli-recipe-with-carrots",
  "name": "Beef Broccoli Recipe with Carrots",
  "recipe_type": "main",
  "brief_description": "Beef with broccoli and carrot stew. This is best served over warm rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saut\u00e9 onion and garlic."
    },
    {
      "position": 2,
      "text": "Add beef once the onion softens. Continue cooking until the beef turns light brown."
    },
    {
      "position": 3,
      "text": "Pour the soy sauce into the pan along with the oyster sauce and sesame oil. Stir."
    },
    {
      "position": 4,
      "text": "Add Knorr Beef Cube. Pour water into the pan. Cover and then cook in low heat for 25 minutes."
    },
    {
      "position": 5,
      "text": "Add brown sugar, carrots, and broccoli. Cover the pan and continue cooking for 5 minutes."
    },
    {
      "position": 6,
      "text": "Combine cornstarch with 3 tablespoons water. Mix well. Pour the mixture into the pan. Stir and cook until the sauce thickens to your desired consistency."
    },
    {
      "position": 7,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 8,
      "text": "Finish by adding toasted sesame seeds."
    },
    {
      "position": 9,
      "text": "Serve over rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
