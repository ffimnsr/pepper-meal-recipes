  "id": "09a78a5e-0b32-57e0-be60-9979b41399e7",
  "slug": "healthy-vegetable-soup-recipe",
  "name": "Healthy Vegetable Soup",
  "recipe_type": "appetizer",
  "brief_description": "A light and colorful clear broth soup made with broccoli, zucchini, yellow squash, green beans, and red bell pepper simmered in vegetable broth. No cream, no butter, and ready in under 15 minutes.",
  "cuisine": "American healthy Mediterranean",
  "instructions": [
    {
      "position": 1,
      "text": "Pour the vegetable broth into a large cooking pot. Bring it to a boil over high heat. Using a well-seasoned broth helps limit the amount of added salt."
    },
    {
      "position": 2,
      "text": "Add the sliced onion to the boiling broth and cook for about 1 minute until it starts to soften."
    },
    {
      "position": 3,
      "text": "Add the broccoli, yellow squash, zucchini, green beans, and red bell pepper. Let the soup return to a boil, then lower the heat and cook for 5 to 7 minutes. Avoid overcooking so the vegetables stay tender and vibrant."
    },
    {
      "position": 4,
      "text": "Taste the soup and season with salt and ground black pepper only if needed."
    },
    {
      "position": 5,
      "text": "Transfer to individual serving bowls."
    },
    {
      "position": 6,
      "text": "Serve warm. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
