  "id": "0837ca23-95cb-5a19-9019-28ed45ef74cc",
  "slug": "grilled-tuna-belly",
  "name": "Grilled Tuna Belly",
  "recipe_type": "main",
  "brief_description": "Tuna belly is perfect for grilling. This grilled tuna belly recipe is easy to follow and the result is great. Enjoy it with warm rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the marinade by combine soy sauce, calamansi, ground black pepper, and sugar in a bowl. Stir until well blended."
    },
    {
      "position": 2,
      "text": "Place the tuna in a Ziploc bag. Pour the soy sauce marinade.Let the air out of the bag. Seal. Marinate inside the fridge for at least 3 hours."
    },
    {
      "position": 3,
      "text": "Heat-up the grill. Arrange the tuna belly on the grate of the grill. Brush a generous amount marinade mixture on the tuna. Grill for 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Turn the tuna belly over and grill the opposite side. Baste the top and sides. Continue to grill for another 5 minutes. Continue performing the process until the tuna is completely cooked."
    },
    {
      "position": 5,
      "text": "Serve with a dipping sauce composed of soy sauce, calamansi, and chili pepper. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 3,
