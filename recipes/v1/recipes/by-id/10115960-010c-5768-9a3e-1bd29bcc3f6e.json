  "id": "10115960-010c-5768-9a3e-1bd29bcc3f6e",
  "slug": "how-to-make-pata-kare-kare",
  "name": "Pata Kare Kare Recipe",
  "recipe_type": "main",
  "brief_description": "Pork hocks and leg stewed until tender and cooked in a rich peanut sauce with a variety of healthy vegetables. This Filipino dish is best served with bagoong alamang (shrimp paste) and eaten with warm white rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil pork pata in 4 cups of water for 15 minutes. Discard the water. Let the pata cool down. Wash pata to remove impurities. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot. Saut\u00e9 garlic until it starts to brown. Add onion. Continue cooking until the onion softens."
    },
    {
      "position": 3,
      "text": "Put the boiled pata into the pot. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour 4 cups of water. Cover the pot. Let the water boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork Cube. Stir. Set heat between low to medium. Cover and continue boiling for 1 \u00bd hours or until the pork gets tender."
    },
    {
      "position": 6,
      "text": "Prepare the peanut paste by blending using a food processor until a paste-like consistency is achieved."
    },
    {
      "position": 7,
      "text": "Add peanut paste into the cooking pot once the pata tenderizes. Stir."
    },
    {
      "position": 8,
      "text": "Add annatto water and glutinous rice and water mixture. Stir and continue cooking until sauce reaches desired consistency."
    },
    {
      "position": 9,
      "text": "Add eggplant, banana blossom, and string beans. Cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Season with ground black pepper and \u00bd teaspoon of shrimp paste. Stir."
    },
    {
      "position": 11,
      "text": "Add bok choy. Cover and cook for 1 \u00bd minutes."
    },
    {
      "position": 12,
      "text": "Serve with warm rice and bagoong alamang. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
