  "id": "8a0f0f48-63de-5f0e-82d1-22b2778dbb85",
  "slug": "curried-potato-salad",
  "name": "Curried Potato Salad",
  "recipe_type": "salad",
  "brief_description": "Curried Potato Salad makes a nice side dish to fried chicken; it can even be your lunch meal by itself. This recipe makes the regular potato salad stand out by adding a dose of curry powder.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water on a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add the potatoes and a teaspoon of salt. Boil for 18 to 23 minutes. Remove from the cooking pot, Let cool and then cube."
    },
    {
      "position": 3,
      "text": "Meanwhile, combine mayonnaise, sour cream, sweet pickle relish, curry powder, salt, and ground black pepper in a mixing bowl. Mix well."
    },
    {
      "position": 4,
      "text": "Add the onion, celery and potatoes. Gently mix until the ingredients are well incorporated."
    },
    {
      "position": 5,
      "text": "Chill in the fridge for 3 hours."
    },
    {
      "position": 6,
      "text": "Top with almonds and sunflower seeds."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
