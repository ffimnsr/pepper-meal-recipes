  "id": "e0f6b27a-ad1d-5435-aedc-6ba5005c6ac7",
  "slug": "quick-and-easy-beef-and-pepper-stir-fry",
  "name": "Quick and Easy Beef and Pepper Stir Fry",
  "recipe_type": "main",
  "brief_description": "Quick and Easy Beef and Pepper Stir Fry is something that like to cook when I want to enjoy a delicious Asian steak stir fry dinner. This dish is one of my favorite stir fry dishes because it is tasty and easy to prepare.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In large bowl, combine beef, soy sauce oyster sauce, salt, and pepper. Mix well. Let is stand for 10 minutes."
    },
    {
      "position": 2,
      "text": "Add the cornstarch. Continue to mix until all the ingredients are well blended. Set aside."
    },
    {
      "position": 3,
      "text": "Meanwhile, heat a pan. Spray or pour cooking oil. Once the oil becomes hot, add the onion and peppers. Stir fry for 2 to 3 minutes."
    },
    {
      "position": 4,
      "text": "Transfer the cooked onion and peppers on a plate. Set aside."
    },
    {
      "position": 5,
      "text": "Add oil to the same pan. Put-in the beef. Stir fry until the beef turns medium brown (around 7 to 8 minutes). Make sure that you are cooking in very high heat. Add more cooking time if needed."
    },
    {
      "position": 6,
      "text": "Add the cooked onion and peppers. Continue to stir fry for 1 minute."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 12,
