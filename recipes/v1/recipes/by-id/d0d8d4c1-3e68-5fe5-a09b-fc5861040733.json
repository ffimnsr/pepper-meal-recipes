  "id": "d0d8d4c1-3e68-5fe5-a09b-fc5861040733",
  "slug": "special-longanisa-fried-rice-recipe",
  "name": "Special Longanisa Fried Rice Recipe",
  "recipe_type": "breakfast",
  "brief_description": "This is a recipe for Special Longanisa Fried Rice",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Crack the eggs in a bowl. Beat until smooth."
    },
    {
      "position": 2,
      "text": "Heat a pan and pour 3 tablespoons cooking oil."
    },
    {
      "position": 3,
      "text": "When the oil gets hot, pour the beaten egg into the pan. Cook one side until done and then flip to cook the other side. Remove the egg from the pan. Set aside."
    },
    {
      "position": 4,
      "text": "Add the remaining oil in the same pan. Once the oil heats-up, add the longanisa. Continue to cook for 5 to 7 minutes (or until the meat is fully cooked) in medium heat while stirring once in a while."
    },
    {
      "position": 5,
      "text": "Add the butter and let it melt."
    },
    {
      "position": 6,
      "text": "Slide the rice into the pan. Fold until all the ingredients are well blended. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Press the tip of the spatula towards the egg on the plate to slice it initially. Add the egg into the pan. Continue to stir fry for 1 minute."
    },
    {
      "position": 8,
      "text": "Put the green peas and carrots in. Cook for 3 to 5 minutes"
    },
    {
      "position": 9,
      "text": "Add salt and pepper to taste. Stir and make sure that all ingredients are well incorporated."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
