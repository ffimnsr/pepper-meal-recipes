  "id": "11d1835f-ed61-56ec-8e17-81c384873940",
  "slug": "beef-with-ampalaya",
  "name": "Beef with Ampalaya Recipe",
  "recipe_type": "main",
  "brief_description": "Bitter gourd sauteed with beef sirloin",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine beef with all the marinade ingredients. Mix well. Marinade for 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat 2 tablespoons of cooking oil in a pan. Add the marinated beef slices. Stir fry for 2 minutes. Transfer to a plate. Set aside."
    },
    {
      "position": 3,
      "text": "Heat the remaining cooking oil on the same pan used to cook the beef. Saute the onion until it softens."
    },
    {
      "position": 4,
      "text": "Add the bitter gourd. Continue to stir-fry for 1 minute. (see notes below)"
    },
    {
      "position": 5,
      "text": "Add the beef back into the pan. Pour water. Cover and let boil."
    },
    {
      "position": 6,
      "text": "Remove the cover and simmer while stirring occasionally until the sauce thickens. (see notes below)"
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 20,
