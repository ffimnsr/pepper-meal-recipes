  "id": "03fd1bb0-4618-58e8-8786-1e4e6fd1207c",
  "slug": "stir-fry-tofu-with-vegetables",
  "name": "Stir Fry Tofu with Vegetables",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Stir Fry Tofu",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Deep fry the tofu until medium brown (about 5 to 8 minutes). Set aside."
    },
    {
      "position": 2,
      "text": "Heat a pan and pour-in 1 tablespoon cooking oil."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 onion."
    },
    {
      "position": 4,
      "text": "Add the fried tofu and stir-fry for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add all the vegetables and stir fry for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Put-in soy sauce, salt, and pepper."
    },
    {
      "position": 7,
      "text": "Pour-in vegetable broth with cornstarch. Cook until the sauce thickens."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
