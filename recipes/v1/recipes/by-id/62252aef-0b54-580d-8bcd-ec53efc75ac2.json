{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "62252aef-0b54-580d-8bcd-ec53efc75ac2",
  "slug": "braised-pork-belly-in-soy-sauce-tau-yew-bak",
  "name": "Braised Pork Belly in Soy Sauce (Tau Yew Bak)",
  "recipe_type": "main",
  "brief_description": "Tender pork belly braised in soy sauce with sweet roasted garlic, tofu, and hard-boiled eggs. A comforting dish perfect over steamed rice.",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork and soy sauce in a bowl. Mix well. Let it stand for at least 30 minutes."
    },
    {
      "position": 2,
      "text": "Prepare the roasted garlic pulp by first slicing the top part of the garlic crosswise to expose the cloves. Boil 2 cups water and then put the garlic head into the pot. Continue to boil over low to medium heat for 8 minutes."
    },
    {
      "position": 3,
      "text": "Preheat oven to 200F. Remove the garlic from the pot. Let it cool down and then rub vegetable oil all over it. Arrange in a baking tray and bake for 30 minutes. Remove from the oven, let cool, and squeeze out the roasted garlic pulp. Set aside."
    },
    {
      "position": 4,
      "text": "Place the marinated pork along with the soy sauce in a cooking pot. Heat the pot and cook the pork until light to medium brown."
    },
    {
      "position": 5,
      "text": "Pour the beef broth into the pot (or you can also use water with \u00bd beef or pork cube/bouillon). Let boil. Add the roasted garlic pulp. Cover and cook over low to medium heat until the pork gets tender. You can add more broth or water if needed."
    },
    {
      "position": 6,
      "text": "Add the sugar. Stir until dissolved."
    },
    {
      "position": 7,
      "text": "Add salt to taste (only if necessary) and then put the tofu and hard-boiled egg into the pot. Cook for 2 to 3 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 50,
