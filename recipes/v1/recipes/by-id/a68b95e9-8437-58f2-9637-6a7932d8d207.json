  "id": "a68b95e9-8437-58f2-9637-6a7932d8d207",
  "slug": "pinoy-pork-and-chicken-curry",
  "name": "Pinoy Style Pork and Chicken Curry",
  "recipe_type": "main",
  "brief_description": "Curried pork belly and chicken with potato, peas, and bell pepper.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a coking pot."
    },
    {
      "position": 2,
      "text": "Pan-fry potato for 1 minute per side. Remove from the pot and place in a clean plate."
    },
    {
      "position": 3,
      "text": "Pan-fry chicken for 1 to 1 \u00bd minute per side. Remove and set aside."
    },
    {
      "position": 4,
      "text": "Using the remaining oil, saute onion, garlic, and ginger."
    },
    {
      "position": 5,
      "text": "Once the onion softens, add pork. Cook until outer part turns light brown."
    },
    {
      "position": 6,
      "text": "Pour-in coconut milk. Let boil."
    },
    {
      "position": 7,
      "text": "Add Knorr Pork Cube. Stir. Cover the pot and boil pork using low to medium heat until tender. Add water as needed."
    },
    {
      "position": 8,
      "text": "Put the pan-fried chicken into the pot. Cook for 15 to 18 minutes."
    },
    {
      "position": 9,
      "text": "Add pan-fried potato, bell peppers, and green peas. Cook for 5 minutes."
    },
    {
      "position": 10,
      "text": "Season with patis and ground black pepper. Transfer to a serving plate. Serve."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
