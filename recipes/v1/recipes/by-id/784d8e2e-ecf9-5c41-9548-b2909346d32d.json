  "id": "784d8e2e-ecf9-5c41-9548-b2909346d32d",
  "slug": "filipino-style-chicken-curry-knr-mm",
  "name": "Filipino Style Chicken Curry Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pinoy Style Chicken Curry.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot. Pan fry the chicken pieces for 1 \u00bd to 2 minutes per side. Remove the chicken from the cooking pot. Set aside."
    },
    {
      "position": 2,
      "text": "Combine Knorr Ginataang Gulay recipe Mix with 2 cups water. Stir until well blended. Set aside."
    },
    {
      "position": 3,
      "text": "Heat remaining oil on the pot. Saute onion and garlic. Add the celery. Continue to cook until onion and celery softens."
    },
    {
      "position": 4,
      "text": "Pour the gata mixture into the pot. Let boil."
    },
    {
      "position": 5,
      "text": "Add curry powder. Stir until the powder totally dilutes in coconut milk."
    },
    {
      "position": 6,
      "text": "Put the pan-fried chicken into the pan. Cover and cook in medium heat for 30 to 35 minutes or until tender."
    },
    {
      "position": 7,
      "text": "Add red bell pepper, long green pepper, and potato. Cover the pot and cook for 5 to 8 minutes."
    },
    {
      "position": 8,
      "text": "Add fish sauce and ground black pepper. Stir."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
