  "id": "3900169d-1a6d-541b-a2f4-dc73da232bce",
  "slug": "ginisang-upo-with-sardinas",
  "name": "Ginisang Upo with Sardinas",
  "recipe_type": null,
  "brief_description": "This is a recipe for sauteed bottle gourd with canned sardines in tomato sauce.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute onion and garlic."
    },
    {
      "position": 3,
      "text": "Add tomato. Continue to cook until soft."
    },
    {
      "position": 4,
      "text": "Put the sliced upo (bottle gourd) into the pan. Saute for 3 minutes."
    },
    {
      "position": 5,
      "text": "Pour canned sardines. Stir."
    },
    {
      "position": 6,
      "text": "Add water. Let boil. Continue to for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
