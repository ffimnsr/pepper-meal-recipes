  "name": "Lobster Pasta in Creamy Alfredo Sauce Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Lobster Pasta in Creamy Alfredo Sauce.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the creamy lobster Alfredo sauce by Melting butter in a pot."
    },
    {
      "position": 2,
      "text": "Add chopped lobsters and garlic powder. Cook for 2 minutes."
    },
    {
      "position": 3,
      "text": "Pour heavy whipping cream into the pot. Stir. Cook while stirring until it starts to boil."
    },
    {
      "position": 4,
      "text": "Add Parmesan cheese. Stir until all ingredients are well blended. Set aside."
    },
    {
      "position": 5,
      "text": "Arrange a serving of spaghetti in a bowl. Pour the creamy lobster Alfredo sauce over the spaghetti and sprinkle some ground black pepper, if desired. Toss."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
