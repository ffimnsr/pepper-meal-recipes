  "id": "c1004fd0-44a7-51fd-8763-b4483b900f6e",
  "slug": "stir-fry-eggplant-recipe",
  "name": "Stir Fry Eggplant Recipe",
  "recipe_type": "main",
  "brief_description": "Easy stir-fried eggplant Chinese style",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Combine 2 cups water, 1 tablespoon salt, and 2 tablespoons vinegar in a large mixing bowl. Stir and then add the sliced eggplants. Soak it for 20 minutes."
    },
    {
      "position": 2,
      "text": "Make the sauce by combining all the sauce ingredients as listed above the ingredient section in a bowl. Mix well and then set aside."
    },
    {
      "position": 3,
      "text": "Remove the eggplants from the bowl and place it in a colander. Gently squeeze until enough water has been extracted from the eggplants. Sprinkle the cornstarch over it and then toss the eggplants until it gets evenly coated. Set this aside."
    },
    {
      "position": 4,
      "text": "Heat 1 tablespoon of cooking oil in a pan. Add the ground pork. Saut\u00e9 this until the color turns light to medium brown."
    },
    {
      "position": 5,
      "text": "Add the eggplants. Continue saut\u00e9ing for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour the sauce into the pan. Stir and continue cooking using medium heat until the sauce thickens."
    },
    {
      "position": 7,
      "text": "Garnish with chopped green onions and then transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve! Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
