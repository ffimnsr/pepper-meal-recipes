  "id": "f14ea447-cc55-5228-b3c8-2e8827dc4e7e",
  "slug": "cheesy-ham-steak-with-bacon-and-mushrooms",
  "name": "Cheesy Ham Steak with Bacon and Mushroom",
  "recipe_type": "dessert",
  "brief_description": "There is just something so uniquely delicious about a perfectly seasoned, sweet and juicy ham steak. It is simply good!",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a pan. Saut\u00e9 onion and garlic. Add mushrooms once the onion softens. Continue saut\u00e9ing for 2 minutes. Season with salt and ground black pepper. Set aside."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a clean pan. Fry the ham steak for 3 minutes."
    },
    {
      "position": 3,
      "text": "Flip the ham over and top with 2 to 3 slices of cheddar cheese. Cover the pan. Continue cooking for 2 \u00bd minutes."
    },
    {
      "position": 4,
      "text": "Arrange the ham steak on a serving plate. Top it with crumbled bacon and serve with sauteed mushrooms."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
