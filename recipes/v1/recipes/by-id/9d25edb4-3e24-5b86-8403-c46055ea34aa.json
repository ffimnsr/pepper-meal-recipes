  "id": "9d25edb4-3e24-5b86-8403-c46055ea34aa",
  "slug": "pork-nilaga-with-kalabasa-recipe",
  "name": "Pork Nilaga with Kalabasa",
  "recipe_type": "soup",
  "brief_description": "Pork Nilaga with Kalabasa is an easy Filipino Pork Soup. It is composed of pork shoulder, potato, Calabaza squash, cabbage, and green onions. It is simply delicious.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the onion and whole peppercorn. Cover and boil for 10 minutes."
    },
    {
      "position": 3,
      "text": "Add the pork. Stir, cover, and simmer for 45 to 60 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the beef cube, calabaza squash and potato. Cook for 7 minutes."
    },
    {
      "position": 5,
      "text": "Add the cabbage and green onions. Continue to cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add the fish sauce. Stir. Cook for 1 to 3 minutes more."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
