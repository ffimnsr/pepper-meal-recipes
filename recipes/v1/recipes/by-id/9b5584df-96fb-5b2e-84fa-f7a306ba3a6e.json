  "id": "9b5584df-96fb-5b2e-84fa-f7a306ba3a6e",
  "slug": "bacon-and-caramelized-onion-cornbread-stuffing",
  "name": "Bacon and Caramelized Onion Cornbread Stuffing",
  "recipe_type": "side",
  "brief_description": "Cornbread stuffing with bacon and caramelized onion",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt the butter in a pan."
    },
    {
      "position": 2,
      "text": "Put-in the onions. Cook for 12 minutes or until caramelized"
    },
    {
      "position": 3,
      "text": "Add-in garlic powder, chopped bacon, and rosemary. Cook until the bacon browns."
    },
    {
      "position": 4,
      "text": "Pour-in chicken stock and wait until it boils."
    },
    {
      "position": 5,
      "text": "Turn off the heat and then add the corn bread. Gently mix until all the ingredients are incorporated."
    },
    {
      "position": 6,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 7,
      "text": "Transfer the stuffing to a oven safe dish."
    },
    {
      "position": 8,
      "text": "Bake for 20 to 30 minutes."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 45,
