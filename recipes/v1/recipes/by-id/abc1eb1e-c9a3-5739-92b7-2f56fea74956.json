  "id": "abc1eb1e-c9a3-5739-92b7-2f56fea74956",
  "slug": "lugaw-recipe",
  "name": "Lugaw Recipe",
  "recipe_type": null,
  "brief_description": "Lugaw or plain congee is the most basic congee recipe that only requires rice, water, and salt. This is an upgraded version",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Put-in the rice. Continue cooking for 30 minutes or until the texture becomes thick, while stirring once in awhile."
    },
    {
      "position": 3,
      "text": "Add the salt, stir and then cook for 2 minutes more."
    },
    {
      "position": 4,
      "text": "Transfer to a serving bowl. Top with a tablespoon of rousing."
    },
    {
      "position": 5,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
