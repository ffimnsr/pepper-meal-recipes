  "id": "ddf24eb0-fa41-5b81-8d12-b0b808c94005",
  "slug": "beef-kaldereta",
  "name": "Beef Kaldereta",
  "recipe_type": "main",
  "brief_description": "Beef Kaldereta is a rich and hearty Filipino tomato-based stew made with tender beef, potatoes, carrots, bell peppers, and green olives, thickened with liver spread for a deep, savory flavor. This comforting dish is best served hot over steamed white rice.",
  "cuisine": "Asian Filipino Southeast Asian",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the beef and soy sauce in a bowl. Mix well and marinate for 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a large pot or pressure cooker. Saut\u00e9 the garlic and onion until fragrant, about 1 to 2 minutes."
    },
    {
      "position": 3,
      "text": "Add the marinated beef. Cook while stirring for 3 to 5 minutes, or until the meat turns light brown on all sides."
    },
    {
      "position": 4,
      "text": "Pour in the tomato sauce and beef broth. Add the dried bay leaves. Bring to a boil, then lower the heat. Cover and cook until the beef becomes tender."
    },
    {
      "position": 5,
      "text": "Add the carrots, potatoes, and green olives. Stir to combine."
    },
    {
      "position": 6,
      "text": "Add the liver spread and chili flakes. Continue cooking for 8 to 10 minutes, stirring occasionally, until the sauce thickens."
    },
    {
      "position": 7,
      "text": "Add the red and green bell peppers. Cook for about 3 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper to taste."
    },
    {
      "position": 9,
      "text": "Serve hot with steamed white rice."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 40,
  "rest_time_minutes": 30,
  "difficulty": "hard",
