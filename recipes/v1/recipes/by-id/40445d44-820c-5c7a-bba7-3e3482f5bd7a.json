  "id": "40445d44-820c-5c7a-bba7-3e3482f5bd7a",
  "slug": "ham-and-egg-fried-rice-with-sweet-peas",
  "name": "Ham and Egg Fried Rice with Sweet Peas",
  "recipe_type": "main",
  "brief_description": "Ham and Egg Fried Rice with Sweet Peas is a tasty dish that's perfect for a quick meal\u2013egg fried rice recipe with ham and peas!",
  "cuisine": "filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Chop the ham into small pieces. Set aside."
    },
    {
      "position": 2,
      "text": "Crack eggs in a bowl. Beat until smooth."
    },
    {
      "position": 3,
      "text": "Heat 2 tablespoons oil in a pot or pan. Pour-in beaten egg mixture. Cook both sides until done. Remove from the pot and chop into pieces. Set aside."
    },
    {
      "position": 4,
      "text": "Pour remaining oil on the same pot. Add the ham. Cook for 30 seconds to 1 minute."
    },
    {
      "position": 5,
      "text": "Add leftover rice. Toss until well blended. Continue to cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Season with salt, onion powder, and garlic powder. Mix well."
    },
    {
      "position": 7,
      "text": "Put the peas into the pot. Cook for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "easy",
