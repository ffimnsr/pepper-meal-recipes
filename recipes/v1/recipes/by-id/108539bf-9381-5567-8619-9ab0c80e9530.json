  "id": "108539bf-9381-5567-8619-9ab0c80e9530",
  "slug": "air-fried-fish-sinigang-sa-miso",
  "name": "Air Fried Fish Sinigang sa Miso",
  "recipe_type": "soup",
  "brief_description": "Fish singang using air fried fish.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Create slits on both sides of the fish. Rub salt all over and then rub the cooking oil."
    },
    {
      "position": 2,
      "text": "Use an air fryer to cook the fish. Air fry each side in 350F for 10 minutes. Remove and let it cool down."
    },
    {
      "position": 3,
      "text": "Pour water in a cooking pot. Let it boil."
    },
    {
      "position": 4,
      "text": "Add onion, tomato, daikon radish, and miso. Let the water- re-boil."
    },
    {
      "position": 5,
      "text": "Put the fish into the pot. Let it cook for 2 minutes after the water re-boils."
    },
    {
      "position": 6,
      "text": "Add Knorr Sinigang Recipe Mix. Stir."
    },
    {
      "position": 7,
      "text": "Put the okra and long green peppers into the pot. Cover and cook in medium heat for 5 minutes."
    },
    {
      "position": 8,
      "text": "Add the mustard leaves and then season with fish sauce and ground black pepper. Cover and cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
