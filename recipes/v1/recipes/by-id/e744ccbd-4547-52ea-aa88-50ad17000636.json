  "slug": "seafood-sinigang",
  "name": "Seafood Sinigang",
  "recipe_type": null,
  "brief_description": "This is a recipe for Seafood Sinigang.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour rice wash in a soup pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add tomato and onion. Cook for 5 minutes."
    },
    {
      "position": 3,
      "text": "Add fish and shrimp."
    },
    {
      "position": 4,
      "text": "Add Knorr Sinigang na May Miso Recipe Mix. Stir."
    },
    {
      "position": 5,
      "text": "Put all the vegetables into the pot. Cover and cook for 6 to 8 minutes."
    },
    {
      "position": 6,
      "text": "Pour fish sauce and add the mustard leaves. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve with rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
