  "id": "a2c91536-329e-552f-ae34-edcd8777f6b6",
  "slug": "excursion-chicken-and-pork-adobo",
  "name": "Excursion Chicken and Pork Adobo",
  "recipe_type": null,
  "brief_description": "Chicken and pork adobo is a perfect dish to bring with you during family picnics and excursions. Get to know how to cook this dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine soy sauce, garlic, whole peppercorn, and bay leaves in a large bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Add the pork and chicken slices. Toss until the ingredients are well blended."
    },
    {
      "position": 3,
      "text": "Cover and place inside the fridge to marinate for at least 3 hours. You can also marinate overnight."
    },
    {
      "position": 4,
      "text": "Heat oil in a large and wide pan."
    },
    {
      "position": 5,
      "text": "Once the oil gets hot, add the marinated pork and chicken including the remaining marinade. Cook for 10 to 12 minutes or until the meat browns."
    },
    {
      "position": 6,
      "text": "Pour water and let boil."
    },
    {
      "position": 7,
      "text": "Add the beef cube. Stir. Cover and cook in low heat for 60 minutes or until the meat gets very tender."
    },
    {
      "position": 8,
      "text": "Pour-in the vinegar. Let boil. Cook until the the liquid almost evaporates."
    },
    {
      "position": 9,
      "text": "Add salt and pepper if needed."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    },
    {
      "position": 11,
      "text": "Add salt and more pepper if needed."
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
