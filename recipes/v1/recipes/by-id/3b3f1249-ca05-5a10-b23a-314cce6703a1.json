  "slug": "salmon-patty-recipe",
  "name": "Salmon Patty Recipe",
  "recipe_type": null,
  "brief_description": "Salmon fillets mixed with carrots, breadcrumbs, and spices and made into patties",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a bowl, combine beaten egg, soy sauce and salt."
    },
    {
      "position": 2,
      "text": "Add onion, carrots, salmon and bread crumbs."
    },
    {
      "position": 3,
      "text": "Toss gently to combine."
    },
    {
      "position": 4,
      "text": "Form mixture into patties."
    },
    {
      "position": 5,
      "text": "Heat a frying pan or skillet and fry both sides of the patties in low to medium heat for 4 to 6 minutes or until it turns medium brown."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 10,
