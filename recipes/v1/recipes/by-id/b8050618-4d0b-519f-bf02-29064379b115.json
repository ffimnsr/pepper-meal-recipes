  "id": "b8050618-4d0b-519f-bf02-29064379b115",
  "slug": "how-to-make-home-made-beef-tapa",
  "name": "Homemade Beef Tapa",
  "recipe_type": null,
  "brief_description": "The procedure below requires combining water and oil. The beef is boiled until the water evaporates - this makes it more tender. The remaining oil fries the beef. You can skip this process by directly frying the beef in oil.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a container, combine soy sauce, garlic, salt, pepper, and sugar and mix well. Set aside"
    },
    {
      "position": 2,
      "text": "Place the beef in the clear plastic bag"
    },
    {
      "position": 3,
      "text": "Pour-in the the mixed seasonings in the clear plastic bag with meat and mix well"
    },
    {
      "position": 4,
      "text": "Place inside the refrigerator and marinate for a minimum of 12 hours"
    },
    {
      "position": 5,
      "text": "In a pan, place 1 cup water and bring to a boil"
    },
    {
      "position": 6,
      "text": "Add 3 tbsp of cooking oil"
    },
    {
      "position": 7,
      "text": "Put-in the marinated beef tapa and cook until the water evaporates."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 720,
