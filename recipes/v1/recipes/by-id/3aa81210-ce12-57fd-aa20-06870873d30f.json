  "id": "3aa81210-ce12-57fd-aa20-06870873d30f",
  "slug": "asian-chicken-vermicelli-soup",
  "name": "Asian Chicken Soup",
  "recipe_type": "soup",
  "brief_description": "Asian Chicken Soup is similar to chicken sotanghon soup, but this recipe has some features that makes it unique and still delicous.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a casserole or soup pot."
    },
    {
      "position": 2,
      "text": "Once the oil is hot, saute the garlic and onion until the onion is soft."
    },
    {
      "position": 3,
      "text": "Add the ground chicken. Cook for 5 minutes while stirring once in awhile."
    },
    {
      "position": 4,
      "text": "Pour-in the chicken broth and water. Let boil and simmer for 45 minutes."
    },
    {
      "position": 5,
      "text": "Add the rice noodles. Stir and cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add salt and pepper. Stir."
    },
    {
      "position": 7,
      "text": "Pit-in the chopped scallions. Turn the heat off and then cover the pot for 3 minutes."
    },
    {
      "position": 8,
      "text": "Transfer the soup to a serving bowl. Top with toasted garlic."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
