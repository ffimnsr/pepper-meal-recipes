  "id": "df67b725-d638-5512-ae28-8ab032026e8d",
  "slug": "turkey-chicken-pot-pie-recipe",
  "name": "Turkey Pot Pie",
  "recipe_type": null,
  "brief_description": "Looking for delicious turkey recipes? How about trying this Turkey Pot Pie Recipe. This will definitely keep your taste buds happy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then put-in 1/8 cup butter. Allow to melt."
    },
    {
      "position": 2,
      "text": "Add-in the onion, celery, and carrots then stir."
    },
    {
      "position": 3,
      "text": "Put-in the dried parsley, oregano, salt, and ground black pepper. Stir and cook for 3 minutes or until the vegetables are soft."
    },
    {
      "position": 4,
      "text": "Add the chicken bouillon and water. Let boil. Simmer for 5 minutes."
    },
    {
      "position": 5,
      "text": "Put the potatoes in and simmer."
    },
    {
      "position": 6,
      "text": "While simmering the potatoes, melt the remaining butter in a separate pan."
    },
    {
      "position": 7,
      "text": "Put-in the turkey and cook for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Sprinkle flour and stir."
    },
    {
      "position": 9,
      "text": "Add milk, stir, and simmer for a minute."
    },
    {
      "position": 10,
      "text": "Combine the turkey mixture with the vegetables then stir. Simmer until the desired thickness is achieved."
    },
    {
      "position": 11,
      "text": "Turn-off heat and allow the mixture to cool."
    },
    {
      "position": 12,
      "text": "Preheat oven to 400 degrees Fahrenheit."
    },
    {
      "position": 13,
      "text": "Transfer the mixture on the pie crust. Cover with the second crust."
    },
    {
      "position": 14,
      "text": "Bake for 30 to 35 minutes."
    },
    {
      "position": 15,
      "text": "Remove from the oven and allow to cool."
    },
    {
      "position": 16,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
