{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "31986a50-fbff-5c8c-8e1b-4f7bc8adcac1",
  "slug": "cheese-puffs-recipe",
  "name": "Cheese Puff",
  "recipe_type": "appetizer",
  "brief_description": "These golden cheese puffs are made from a simple choux dough loaded with grated cheddar cheese. Light and airy on the inside with a crispy exterior, they make a perfect snack or appetizer for any occasion.",
  "cuisine": "American Filipino French",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pot and pour in the water."
    },
    {
      "position": 2,
      "text": "Add the butter and salt. Let the mixture boil, then stir well."
    },
    {
      "position": 3,
      "text": "Gradually add the flour while stirring continuously until a dough forms."
    },
    {
      "position": 4,
      "text": "Add 3 eggs one at a time, stirring well after each addition."
    },
    {
      "position": 5,
      "text": "Add the grated cheddar cheese and mix until well combined."
    },
    {
      "position": 6,
      "text": "Turn off the heat and transfer the dough to a container. Let it cool to room temperature."
    },
    {
      "position": 7,
      "text": "Make the egg wash by combining the remaining egg yolk with 1 tablespoon of butter in a bowl. Mix well."
    },
    {
      "position": 8,
      "text": "Preheat the oven to 375 degrees Fahrenheit."
    },
    {
      "position": 9,
      "text": "Scoop the dough and arrange on a baking tray lined with parchment paper."
    },
    {
      "position": 10,
      "text": "Brush the top of each piece with the egg wash."
    },
    {
      "position": 11,
      "text": "Bake for 20 to 30 minutes. To check for doneness, cut one piece in half. The center should be dry. Bake longer if there is still moisture inside."
    },
    {
      "position": 12,
      "text": "Remove from the oven and transfer to a serving plate or bread basket."
    },
    {
      "position": 13,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 15,
