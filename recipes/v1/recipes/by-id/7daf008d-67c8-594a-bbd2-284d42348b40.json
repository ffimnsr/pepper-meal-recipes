  "slug": "ginisang-pusit-recipe",
  "name": "Ginisang Pusit",
  "recipe_type": null,
  "brief_description": "Ginisang Pusit is a quick and simple saut\u00e9ed squid recipe that anyone can easily make. The secret to a good ginisang pusit is in the quality of the ingredients: using fresh squid is highly recommended, along with the use of fresh vegetables.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a wok or saut\u00e9 pan."
    },
    {
      "position": 2,
      "text": "Saute the onion, garlic, and tomato."
    },
    {
      "position": 3,
      "text": "Once the onion gets soft, add the squid. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the fish sauce and water. Stir. Continue to cook for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Add the ground black pepper and adjust the taste by adding more fish sauce, only if needed."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
