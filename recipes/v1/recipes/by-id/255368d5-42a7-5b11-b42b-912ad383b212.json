  "id": "255368d5-42a7-5b11-b42b-912ad383b212",
  "slug": "cheese-puto-recipe",
  "name": "Cheese Puto Recipe",
  "recipe_type": "dessert",
  "brief_description": "This is a Recipe for a Filipino rice cake called Puto Cheese or Cheesy Puto",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water into a steamer or cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Sift flour, sugar, and baking powder. Combine in a bowl. Mix well."
    },
    {
      "position": 3,
      "text": "Gradually add the milk and egg while stirring. Continue to stir until the texture of the mixture becomes smooth."
    },
    {
      "position": 4,
      "text": "Stir-in the vanilla extract, butter, and half of the cheese."
    },
    {
      "position": 5,
      "text": "Pour the mixture into small to medium sized molds. Arrange in a steamer. Cover and steam for 25 minutes. Top each puto with the remaining cheese. Steam for 5 minutes more."
    },
    {
      "position": 6,
      "text": "Take the steamed cheese puto out of the steamer. Let it cool down."
    },
    {
      "position": 7,
      "text": "Gently remove the puto from the mold with the help of a spatula."
    },
    {
      "position": 8,
      "text": "Arrange in serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
