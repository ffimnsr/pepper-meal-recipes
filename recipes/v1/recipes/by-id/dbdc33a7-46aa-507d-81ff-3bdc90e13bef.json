  "id": "dbdc33a7-46aa-507d-81ff-3bdc90e13bef",
  "slug": "pork-ginataan-recipe",
  "name": "Pork Ginataan",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pork Ginataan.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute, onion, garlic, and ginger."
    },
    {
      "position": 3,
      "text": "Once the onion becomes translucent and soft, add pork. Saute until light brown."
    },
    {
      "position": 4,
      "text": "Pour coconut milk and coconut cream. Let boil."
    },
    {
      "position": 5,
      "text": "Add chili pepper (Thai chili). Cover the cooking pot. Cook for 45 to 60 minutes, or until the pork becomes tender."
    },
    {
      "position": 6,
      "text": "Add spinach. Cover and cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and fish sauce."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
