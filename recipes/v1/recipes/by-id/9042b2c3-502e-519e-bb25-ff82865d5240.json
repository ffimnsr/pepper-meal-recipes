  "id": "9042b2c3-502e-519e-bb25-ff82865d5240",
  "slug": "chicken-gizzard-bicol-express",
  "name": "Chicken Gizzard Bicol Express",
  "recipe_type": "main",
  "brief_description": "Chicken gizzard and winged beans cooked in coconut milk",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil the chicken gizzard until tender. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Saut\u00e9 the garlic until it starts to brown. Add onion. Cook until it softens."
    },
    {
      "position": 3,
      "text": "Put the boiled gizzards into the pan and saut\u00e9 for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add shrimp paste and chili pepper. Stir."
    },
    {
      "position": 5,
      "text": "Pour the water into the pan. Let it boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Ginataang Gulay Mix. Stir until well blended. Cover the pan and reduce the heat to low setting. Cook for 8 to 10 minutes."
    },
    {
      "position": 7,
      "text": "Add winged beans. Stir and cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve hot."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
