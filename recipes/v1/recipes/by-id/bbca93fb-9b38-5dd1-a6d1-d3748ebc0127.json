  "id": "bbca93fb-9b38-5dd1-a6d1-d3748ebc0127",
  "slug": "hototay-soup",
  "name": "Hototay Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "A hearty Chinese-inspired soup, enriched with a variety of meats and vegetables.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "When the onion becomes soft, add the pork and cook until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Put-in the chicken and liver, and cook for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the chicken stock or chicken broth. Let boil and simmer for 7 to 10 minutes."
    },
    {
      "position": 6,
      "text": "Add carrots and mushroom. Stir and cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the Napa cabbage, salt, and ground black pepper. Stir and cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Turn off heat, and then transfer to individual serving bowls."
    },
    {
      "position": 9,
      "text": "Crack and place one egg per bowl. Sprinkle green onions on top to garnish."
    },
    {
      "position": 10,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
