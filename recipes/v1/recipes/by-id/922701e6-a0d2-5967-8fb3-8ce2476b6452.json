  "id": "922701e6-a0d2-5967-8fb3-8ce2476b6452",
  "slug": "ginisang-sitaw-with-bell-pepper",
  "name": "Ginisang Sitaw with Carrot and Bell Pepper",
  "recipe_type": "dessert",
  "brief_description": "Sitaw stir-fried with pork belly and red bell peppers in a savory soy and oyster sauce blend, simmered with a touch of sweetness. Served with steamed rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a wok over medium heat. Add the pork belly and cook until the fat renders and the meat starts to brown."
    },
    {
      "position": 2,
      "text": "Add the chopped garlic and saut\u00e9 for about 1 minute until fragrant."
    },
    {
      "position": 3,
      "text": "Pour in the soy sauce and \u00be cup of water, and coca cola. Cover the wok and let the pork simmer until tender."
    },
    {
      "position": 4,
      "text": "Remove the lid and allow the remaining liquid to evaporate completely."
    },
    {
      "position": 5,
      "text": "Stir in the onions and tomatoes. Cook until softened."
    },
    {
      "position": 6,
      "text": "Add the string beans and saut\u00e9 for 1 minute."
    },
    {
      "position": 7,
      "text": "Pour in the oyster sauce and remaining \u00bc cup of water. Stir well, cover, and cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Add the bell pepper and cook for another 2 minutes."
    },
    {
      "position": 9,
      "text": "Add sugar, salt, and ground black pepper to taste. Stir to combine."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl and enjoy with steamed rice."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
