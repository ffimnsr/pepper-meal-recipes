{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "d9a42085-b650-50d7-badd-ba33c423172f",
  "slug": "longevity-noodles-chicken-mushroom-knr-cc",
  "name": "Longevity Noodles with Chicken and Mushroom",
  "recipe_type": "soup",
  "brief_description": "Thick fresh noodles cooked with chicken broth and stir-fried with sliced chicken breast and Shiitake mushroom. This delicious noodle dish will bring smiles on your taste buds.",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a wok. Put the chicken. Boil for 8 minutes."
    },
    {
      "position": 2,
      "text": "Add Knorr Chicken Cube in boiling water. Stir. Continue to boil chicken for 7 to 10 minutes more. Remove the chicken and let it cool down. Slice into thin pieces. Set aside."
    },
    {
      "position": 3,
      "text": "Add fresh noodles in the boiling broth that was used to tenderize the chicken. Cook in medium heat for 8 minutes or until broth is consumed. Arrange noodle in a colander and quickly wash with cold water to prevent it from sticking with each other. Set aside."
    },
    {
      "position": 4,
      "text": "Heat oil in a wok. Stir-fry the boiled chicken breast for 1 minute once the oil gets hot."
    },
    {
      "position": 5,
      "text": "Add scallions and mushroom. Continue to stir-fry for 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour cooking wine into the wok. Cook for 2 minutes while stirring."
    },
    {
      "position": 7,
      "text": "Add Chinese chives and carrots. Stir-fry for 2 minutes more."
    },
    {
      "position": 8,
      "text": "Add the oyster sauce and \u00bd cup water. Stir."
    },
    {
      "position": 9,
      "text": "Put the fresh noodles back into the wok. Toss."
    },
    {
      "position": 10,
      "text": "Season with ground black pepper. Toss until all ingredients are well distributed."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
