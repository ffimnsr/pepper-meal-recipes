  "id": "89ebbe30-26c9-5ea6-9965-9b0e797bef79",
  "slug": "asian-filipino-soup-beef-mami-recipe",
  "name": "Beef Mami Recipe",
  "recipe_type": "soup",
  "brief_description": "Beef Mami is a type of Beef Noodle soup of Filipino-Chinese origin. This is simply composed of tender beef brisket and egg noodles, boiled eggs, and other toppings which are soaked in a hot and flavorful beef stock.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Put the oil in a cooking pot and apply heat"
    },
    {
      "position": 2,
      "text": "Saute the garlic and onions"
    },
    {
      "position": 3,
      "text": "Put-in the beef brisket and cook until the color of the outer part turns light brown"
    },
    {
      "position": 4,
      "text": "Add the beef cube and star anise"
    },
    {
      "position": 5,
      "text": "Pour-in the water and bring to a boil. Allow to boil until beef becomes tender"
    },
    {
      "position": 6,
      "text": "Add salt and pepper to taste"
    },
    {
      "position": 7,
      "text": "Place the cooked egg noodles and Chinese cabbage in a serving bowl"
    },
    {
      "position": 8,
      "text": "Pour the soup and beef brisket on the bowl with noodles then garnish with sliced boiled egg and green onions"
    },
    {
      "position": 9,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
