  "recipe_notes": [
    "For best results, choose center-cut salmon fillets of even thickness.",
    "If using skinless fillets, reduce cooking time by 2-3 minutes.",
    "The salmon is done when it reaches an internal temperature of 145\u00b0F (63\u00b0C) and flakes easily with a fork."
  ],
  "storage_notes": [
    "Store leftover grilled salmon in an airtight container in the refrigerator for up to 3 days.",
    "Reheat gently in a 275\u00b0F oven for about 15 minutes to prevent drying out."
  ],
