  "id": "3e93c893-d82b-5c33-b05c-60c005a5e52d",
  "slug": "laswa-recipe",
  "name": "Laswa Recipe",
  "recipe_type": "soup",
  "brief_description": "Similar to bulanglang and dinengdeng, Laswa is a healthy vegetable soup that makes use of any available vegetables from the backyard.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Add onion and tomato. Cover and boil for 5 minutes using medium heat."
    },
    {
      "position": 3,
      "text": "Add kalabasa and bagoong alamang. Boil for 5 minutes."
    },
    {
      "position": 4,
      "text": "Add eggplant, string beans, and okra. Cook for 4 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Put shrimp into the pot. Cover and cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Add saluyot, amaranth leaves (kulitis), and alugbati. Stir."
    },
    {
      "position": 7,
      "text": "Season with salt and ground black pepper. Serve with fried fish on the side. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
