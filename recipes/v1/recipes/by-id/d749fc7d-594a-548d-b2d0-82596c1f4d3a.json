  "slug": "spanish-sardines-pasta-with-sun-dried-tomato-and-chopped-olives",
  "name": "Spanish Sardines Pasta with Sun Dried Tomato and Chopped Olives",
  "recipe_type": null,
  "brief_description": "This is a recipe for Spanish Sardines Pasta with Sun Dried Tomato and Chopped Olives",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook fettuccine according to package instructions. Place in a large mixing bowl."
    },
    {
      "position": 2,
      "text": "Add Spanish sardines, chopped sun-dried tomato, chopped olives, crushed red pepper, parsley, and extra virgin olive oil."
    },
    {
      "position": 3,
      "text": "Place the pasta and other ingredients in a pan. Heat the pan and toss. Continue to cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add salt and ground black pepper to taste."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
