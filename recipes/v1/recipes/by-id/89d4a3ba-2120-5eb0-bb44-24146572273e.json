  "id": "89d4a3ba-2120-5eb0-bb44-24146572273e",
  "slug": "pineapple-chicken-casserole-pininyahang-manok-recipe",
  "name": "Pininyahang Manok",
  "recipe_type": "main",
  "brief_description": "Pininyahang Manok or Pineapple Chicken Recipe is a delicious chicken dish that is best served with steamed rice. Try cooking this today.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Marinate the chicken in pineapple juice/concentrate (derived from the can of pineapple chunks) for 20 to 30 minutes"
    },
    {
      "position": 2,
      "text": "Pour the cooking oil in a cooking pot / casserole then apply heat"
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the garlic, onion, and tomatoes"
    },
    {
      "position": 4,
      "text": "Put-in the chicken and cook until color of the outer part turns light brown"
    },
    {
      "position": 5,
      "text": "Add the pineapple juice/concentrate marinade and fresh milk then bring to a boil"
    },
    {
      "position": 6,
      "text": "Add the pineapple chunks and simmer until the chicken is tender and half of the liquid evaporates (about 20 to 30 minutes)."
    },
    {
      "position": 7,
      "text": "Put-in the carrots and simmer for 5 minutes"
    },
    {
      "position": 8,
      "text": "Add the bell pepper and fish sauce then simmer for 3 minutes"
    },
    {
      "position": 9,
      "text": "Remove from the cooking pot / casserole and transfer to a serving dish."
    },
    {
      "position": 10,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
