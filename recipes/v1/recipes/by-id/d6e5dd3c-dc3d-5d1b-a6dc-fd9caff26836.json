  "id": "d6e5dd3c-dc3d-5d1b-a6dc-fd9caff26836",
  "slug": "pineapple-fried-chicken-recipe",
  "name": "Pineapple Fried Chicken Recipe",
  "recipe_type": null,
  "brief_description": "Fried chicken marinated in pineapple and lemon soda",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large container, combine crushed pineapple, lemon soda, soy sauce, 3 tsp. salt, 1 tsp. ground black pepper. Stir."
    },
    {
      "position": 2,
      "text": "Add the chicken pieces in the mixture. Marinate overnight. Make sure to place the container in the fridge while marinating."
    },
    {
      "position": 3,
      "text": "Combine the flour and garlic powder. Set aside."
    },
    {
      "position": 4,
      "text": "Separate the chicken from the marinade. Let excess liquid drip."
    },
    {
      "position": 5,
      "text": "Heat the cooking oil in a frying pan."
    },
    {
      "position": 6,
      "text": "Rub some salt and pepper over the chicken pieces and then dip each piece in the egg mixture. Dredge the egg coated chicken in the flour mixture."
    },
    {
      "position": 7,
      "text": "Fry each chicken piece in low to medium heat for about 8 to 12 minutes per side. You can add more time depending on the thickness of the chicken."
    },
    {
      "position": 8,
      "text": "Remove the cooked chicken pieces from the pan. Arrange in a plate lined with paper towels."
    },
    {
      "position": 9,
      "text": "Serve with your favorite dip. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
