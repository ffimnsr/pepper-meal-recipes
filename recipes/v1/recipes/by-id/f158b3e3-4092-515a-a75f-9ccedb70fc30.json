  "id": "f158b3e3-4092-515a-a75f-9ccedb70fc30",
  "slug": "sirloin-beef-steak-tagalog",
  "name": "Sirloin Beef Steak Tagalog",
  "recipe_type": "soup",
  "brief_description": "Sirloin beef steak tagalog recipe with thin-sliced sirloin, beef broth, and a 30-minute marinade. The weeknight bistek I cook most often.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine soy sauce, lime, and beef in a bowl, Mix well and let it stay for at least 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan and start to pan fry the beef sirloin in medium heat for 1 to 2 minutes per side."
    },
    {
      "position": 3,
      "text": "Pour-in the remaining marinade and the beef broth. Add garlic powder and ground black pepper. Stir. Cover and simmer for 20 to 35 minutes. Add more beef broth if necessary."
    },
    {
      "position": 4,
      "text": "Remove the cover and add the onion and scallion. Cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate and serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 35,
