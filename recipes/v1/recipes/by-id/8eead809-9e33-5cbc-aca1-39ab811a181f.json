  "id": "8eead809-9e33-5cbc-aca1-39ab811a181f",
  "slug": "pasta-puttanesca",
  "name": "Pasta Puttanesca Recipe",
  "recipe_type": "main",
  "brief_description": "A flavorful linguine dish tossed in a sauce of anchovies, olives, capers, and sun-dried tomatoes, simmered in rich tomato base and finished with basil and Parmesan.",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the linguine pasta in a large pot of boiling salted water according to package instructions. Drain and set aside."
    },
    {
      "position": 2,
      "text": "Heat extra virgin olive oil in a saut\u00e9 pan over medium heat."
    },
    {
      "position": 3,
      "text": "Add minced carrots and anchovy fillets. Cook for about 2 minutes while mashing the anchovies into the oil until they dissolve."
    },
    {
      "position": 4,
      "text": "Add garlic, sun-dried tomatoes, kalamata olives, capers, diced tomatoes, dried oregano, red pepper flakes, and tomato paste. Stir and bring to a boil. Cover and simmer for 12 to 17 minutes to let the flavors blend."
    },
    {
      "position": 5,
      "text": "Add the cooked pasta and chopped fresh basil leaves. Toss well to coat the noodles evenly with the sauce."
    },
    {
      "position": 6,
      "text": "Sprinkle with Parmesan cheese and season with salt and pepper to taste."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate and serve immediately. Enjoy this flavorful pasta puttanesca with your favorite drink or a side of garlic bread."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
