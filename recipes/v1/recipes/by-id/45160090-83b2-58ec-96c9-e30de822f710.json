  "id": "45160090-83b2-58ec-96c9-e30de822f710",
  "slug": "tinolang-bangus-recipe",
  "name": "Tinolang Bangus Recipe",
  "recipe_type": "soup",
  "brief_description": "Tinolang Bangus is a delicious Filipino soup recipe; it is a hearty ginger soup composed of bangus (milkfish) and vegetables such as chayote, hot pepper leaves, and malunggay leaves. This is best eaten with white rice along with a spicy fish sauce dip.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute the onion and ginger."
    },
    {
      "position": 3,
      "text": "Add the ground black pepper and pour-in water. Let boil."
    },
    {
      "position": 4,
      "text": "Put-in the sliced bangus. Let the water boil once more and then adjust the heat to low. Continue to cook covered for 20 minutes."
    },
    {
      "position": 5,
      "text": "Add the fish sauce and chayote. Cook for 8 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the malunggay and hot pepper leaves. Stir and cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
