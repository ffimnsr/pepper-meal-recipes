  "id": "dba7c14b-ebc7-53ef-8754-46df6b2779b0",
  "slug": "filipino-street-food-homemade-taho-recipe",
  "name": "Homemade Taho",
  "recipe_type": "dessert",
  "brief_description": "Soft silken tofu topped with a sweet brown syrup and sago pearls.&nbsp;",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour 5 cups of water in a cooking pot and bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the sago pearls. Boil for 3 to 6 minutes. Reduce the heat to low setting, continue boiling for 5 to 10 minutes."
    },
    {
      "position": 3,
      "text": "Drain the hot water by filtering the sago using a kitchen strainer. Put the sago pearls in a bowl with warm water and let it stay until needed."
    },
    {
      "position": 4,
      "text": "Make the arnibal by boiling 3/4 cup water in a saucepan. Add the brown sugar. Stir. Add the vanilla extract. Turn the heat off. Set aside."
    },
    {
      "position": 5,
      "text": "Transfer the extra soft tofu in a bowl. Microwave it for 2 1/2 minutes."
    },
    {
      "position": 6,
      "text": "Arrange the soft tofu in individual cups. Top with sago pearls and pour arnibal (syrup) on top."
    },
    {
      "position": 7,
      "text": "Serve warm. Share and Enjoy"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
