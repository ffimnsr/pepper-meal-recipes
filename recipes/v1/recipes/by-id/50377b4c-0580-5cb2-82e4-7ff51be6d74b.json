{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "50377b4c-0580-5cb2-82e4-7ff51be6d74b",
  "slug": "chicken-liver-and-gizzard-in-oyster-sauce",
  "name": "Chicken Liver and Gizzard in Oyster Sauce",
  "recipe_type": null,
  "brief_description": "Chicken innard stewed in oyster sauce",
  "cuisine": "Chinese Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 4 cups of water and then add 3 to 5 dried bay leaves, 1 teaspoon salt, and \u00bd teaspoon ground black pepper. Add the chicken gizzard. Continue boiling for 45 minutes or until the gizzards tenderize. Discard the water and wash the gizzards. Set aside."
    },
    {
      "position": 2,
      "text": "Combine chicken liver and 2 tablespoons of cornstarch. Mix well."
    },
    {
      "position": 3,
      "text": "Heat 4 tablespoons of cooking oil. Fry the chicken liver for around 1 \u00bd minutes per side. Set aside."
    },
    {
      "position": 4,
      "text": "Using the remaining oil (note: add more as needed), saut\u00e9 the onion, garlic, and ginger until the onion softens."
    },
    {
      "position": 5,
      "text": "Add the boiled gizzard. Saut\u00e9 for 1 \u00bd minutes."
    },
    {
      "position": 6,
      "text": "Add the heart. Saut\u00e9 until it turns light brown in color."
    },
    {
      "position": 7,
      "text": "Pour the oyster sauce and lemon lime soda. Let boil."
    },
    {
      "position": 8,
      "text": "Add Maggi Magic Chicken Cube. Stir and then add the carrots. Cook for 1 minute."
    },
    {
      "position": 9,
      "text": "Pour 1 cup of water and let it boil."
    },
    {
      "position": 10,
      "text": "Thicken the sauce by pouring the slurry (mix 1 \u00bd tablespoons of cornstarch with 3 tablespoons of water). Stir and cook until the sauce thickens."
    },
    {
      "position": 11,
      "text": "Add the bell peppers. Cook for 1 \u00bd minutes."
    },
    {
      "position": 12,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 13,
      "text": "Transfer to a serving bowl. Serve with rice."
    },
    {
      "position": 14,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 20,
