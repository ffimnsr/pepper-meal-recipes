  "id": "c481e40d-f7e7-55c9-9c50-27cafeba1b2e",
  "slug": "pork-adobo-with-sitaw-recipe",
  "name": "Pork Adobo with Sitaw",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pork Adobo with Sitaw",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork, soy sauce, ground black pepper, and garlic. Mix well. Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the onion until it gets soft."
    },
    {
      "position": 4,
      "text": "Add the marinated pork including the remaining soy sauce and garlic. Cook for 5 minutes in medium heat."
    },
    {
      "position": 5,
      "text": "Pour the beef broth in the pot. Let boil. Cook in low heat for 45 minutes or until the pork gets tender. Note: add more beef broth or water if the liquid starts to dry out."
    },
    {
      "position": 6,
      "text": "Add the vinegar. Allow the liquid to re-boil. Stir."
    },
    {
      "position": 7,
      "text": "Put the string beans in the pot. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Add brown sugar. Stir. Continue to cook for 5 to 8 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve!"
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
