  "id": "9af4e52c-e943-5986-920a-c58773d0b748",
  "slug": "deep-fried-seasoned-pork-chop",
  "name": "Deep Fried Seasoned Pork Chop",
  "recipe_type": null,
  "brief_description": "This deep fried seasoned pork chop recipe is awesome. It results in a nice dish that makes a good food for lunch or dinner",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine salt, seasoned salt, garlic powder, and ground black pepper. Mix well and then rub all over the pork chop.Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Pour the buttermilk over the pork chop. Let it stay for another 15 minutes."
    },
    {
      "position": 3,
      "text": "Heat oil in a deep cooking pot. Set the heat to around 350 degrees Fahrenheit."
    },
    {
      "position": 4,
      "text": "Dust flour all over the pork chop. shake of excess flour."
    },
    {
      "position": 5,
      "text": "Dip the dusted pork chops in beaten egg and then roll over the bread crumbs. Make sure that all sides of the pork are coated with crumbs."
    },
    {
      "position": 6,
      "text": "Deep fry for 12 to 15 minutes or until the outer part turns golden brown"
    },
    {
      "position": 7,
      "text": "Serve with your favorite side dish."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
