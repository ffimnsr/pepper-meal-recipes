  "id": "e4147329-b453-577f-bc66-448e195c2ce8",
  "slug": "potato-salad-with-carrots-and-pineapple",
  "name": "Potato Salad with Carrots and Pineapple",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for Potato Salad with pineapple chunks, carrots, and mayo.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Peel potato and carrot. Put potato in boiling water. Boil for 2 minutes. Add carrot. Boil for 10 minutes."
    },
    {
      "position": 3,
      "text": "Pour cold water and 2 cups ice on a large bowl. Take the potato and carrots out of the cooking pot and submerge in cold water. Let it stay for 6 minutes. Remove from water, pat dry with paper towels. Cut into cubes. Set aside."
    },
    {
      "position": 4,
      "text": "Prepare the salad dressing by placing Lady's Choice Mayonnaise in a large bowl. Add onion, ground black pepper, sugar, and salt. Mix well."
    },
    {
      "position": 5,
      "text": "Add pineapple chunks, carrot, and potato. Fold until all ingredients are well distributed."
    },
    {
      "position": 6,
      "text": "Add minced parsley. Fold. Cover the bowl and refrigerate for at least 1 hour."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
