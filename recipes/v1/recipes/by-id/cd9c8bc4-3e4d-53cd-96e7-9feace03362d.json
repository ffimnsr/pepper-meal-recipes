  "id": "cd9c8bc4-3e4d-53cd-96e7-9feace03362d",
  "slug": "no-oven-baked-macaroni-filipino-style",
  "name": "No Oven Baked Macaroni Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Filipino Style Baked Macaroni.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the elbow macaroni based on package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Prepare the sauce by heating oil in a cooking pot. Add ground beef. Continue to brown the beef until enough oil gets extracted. (note: scoop off the oil)."
    },
    {
      "position": 3,
      "text": "Add onion and garlic. Continue sauteing until the onion softens."
    },
    {
      "position": 4,
      "text": "Add hotdogs and ham."
    },
    {
      "position": 5,
      "text": "Pour tomato sauce and water. Stir. Cover the pot and let the liquid boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Beef Cube. Continue cooking uncovered using low to medium heat until the liquid reduces to half."
    },
    {
      "position": 7,
      "text": "Add banana ketchup and half of the chopped red bell pepper. Stir."
    },
    {
      "position": 8,
      "text": "Add \u00bd cup shredded cheese and all-purpose cream. Season with sugar, salt, and ground black pepper. Stir and continue cooking until the sauce becomes thick."
    },
    {
      "position": 9,
      "text": "Combine the cooked macaroni and sauce. Gently fold until well blended."
    },
    {
      "position": 10,
      "text": "Arrange the macaroni with sauce on a baking tray. Top with remaining cheese and bell pepper."
    },
    {
      "position": 11,
      "text": "Broil in 350F for 20 minutes using a turbo broiler. Serve warm. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
