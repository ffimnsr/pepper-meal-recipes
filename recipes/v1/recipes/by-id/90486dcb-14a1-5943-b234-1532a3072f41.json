  "slug": "sipo-eggs-recipe",
  "name": "Sipo Eggs Recipe",
  "recipe_type": null,
  "brief_description": "Have you had Sipo Eggs? If you have not, then now is the best time to know more about Sipo Eggs and learn how to cook it at the comfort of your own home. Sipo Egg is a Filipino quail egg and shrimp recipe that originated in Pampanga.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt the butter in a cooking pan."
    },
    {
      "position": 2,
      "text": "Add the cooking oil."
    },
    {
      "position": 3,
      "text": "Once the mixture becomes hot, saute the shrimp for a minute per side."
    },
    {
      "position": 4,
      "text": "Remove the shrimp and set aside."
    },
    {
      "position": 5,
      "text": "Meanwhile, saute the onion and garlic."
    },
    {
      "position": 6,
      "text": "Put-in the carrot and green peas. Add the ham (this is an optional ingredient).Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Pour-in the water (I used water with shrimp juice in the video).Let it boil. Cook for 1 minute."
    },
    {
      "position": 8,
      "text": "Add the quail eggs and shrimp.Stir."
    },
    {
      "position": 9,
      "text": "Pour-in the cream of mushroom and table cream. Stir once more until the ingredients are well distributed."
    },
    {
      "position": 10,
      "text": "Add water chestnuts, salt and pepper."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 12,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
  "difficulty": "hard",
