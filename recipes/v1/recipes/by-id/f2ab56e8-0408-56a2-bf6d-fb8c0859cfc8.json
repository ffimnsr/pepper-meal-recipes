  "id": "f2ab56e8-0408-56a2-bf6d-fb8c0859cfc8",
  "slug": "beef-broccoli-stir-fry",
  "name": "Beef and Broccoli Stir Fry",
  "recipe_type": "main",
  "brief_description": "Stir fried version of beef and broccoli. This is perfect for people on the go.",
  "cuisine": "American Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the ginger, brown sugar, corn starch, ground black pepper, and garlic powder in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Add the soy sauce and Sherry cooking wine. Stir."
    },
    {
      "position": 3,
      "text": "Arrange the beef in a bowl. Pour half of the soy sauce mixture on the flank beef. Mix well. Marinate for 10 minutes."
    },
    {
      "position": 4,
      "text": "Heat 2 tablespoons of cooking oil in a pan. Once the oil is hot, pan fry both sides of the marinated beef for 30 secs to 1 minute per side. Remove the pan fried beef and place it in a bowl. Set aside."
    },
    {
      "position": 5,
      "text": "Meanwhile, add the remaining oil to the pan. Add the onion and broccoli. Stir-fry for 3 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the pan-fried beef. Continue to stir-fry for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Pour-in the remaining soy sauce mixture. Stir an cook for 1 minute."
    },
    {
      "position": 8,
      "text": "Add the oyster sauce. Stir and cook for a minute more."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
