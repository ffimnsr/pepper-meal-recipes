  "id": "42dacace-7f97-5ec8-bb4b-036f6bf88a10",
  "slug": "spicy-chicken-feet",
  "name": "Spicy Chicken Feet",
  "recipe_type": "appetizer",
  "brief_description": "This Chicken Feet Recipe makes a good appetizer. Learn how to cook this dish by following our cooking video.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "In a pan, heat the cooking oil and put-in the chicken feet. Continue frying until color turns golden brown. Set aside when done"
    },
    {
      "position": 2,
      "text": "On the same pan, saut\u00e9 the garlic and ginger"
    },
    {
      "position": 3,
      "text": "Put-in the fried chicken feet, oyster sauce, soy sauce, and Chinese black beans"
    },
    {
      "position": 4,
      "text": "Add the water and let boil. Simmer until chicken feet is tender"
    },
    {
      "position": 5,
      "text": "Add the sugar, chili, and green onions and mix well"
    },
    {
      "position": 6,
      "text": "Add the cornstarch and mix thoroughly for 3 minutes"
    },
    {
      "position": 7,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
