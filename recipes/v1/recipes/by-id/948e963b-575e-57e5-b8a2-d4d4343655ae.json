  "id": "948e963b-575e-57e5-b8a2-d4d4343655ae",
  "slug": "pork-giniling-kaldereta-recipe",
  "name": "Pork Giniling Kaldereta Recipe",
  "recipe_type": null,
  "brief_description": "Pork Giniling Kaldereta is a simple dish that you can make for lunch or dinner. If you like pork giniling and if you are a fan of kaldereta at the same time, this recipe is perfect for you.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan or cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil turns hot, saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Let the onion get soft then add the ground pork. Cook while stirring once in a while until the pork turns light to medium brown."
    },
    {
      "position": 4,
      "text": "Add the pork cube and liver spread. Stir and cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the tomato sauce. Stir. Add water and cover. Simmer for 15 to 20 minutes."
    },
    {
      "position": 6,
      "text": "Add crushed red peppers, carrots and olives. Cook for 7 minutes."
    },
    {
      "position": 7,
      "text": "Stir-in the bell peppers. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Add salt and pepper to taste. Stir and continue to cook until the liquid evaporates."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve with white rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
