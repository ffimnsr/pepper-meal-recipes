  "id": "1d6b4c29-d3c2-5a93-9af6-81f303106848",
  "slug": "bacon-and-avocado-sandwich",
  "name": "Bacon and Avocado Sandwich",
  "recipe_type": "breakfast",
  "brief_description": "Bacon and Avocado Sandwich is a quick and easy meal that you can enjoy for breakfast or lunch. I thought that the bacon and avocado are a good combination",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the mustard and mayonnaise. Mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Toast the bread slices in the way that you prefer."
    },
    {
      "position": 3,
      "text": "Spread the mayonnaise mixture equally on both bread slices."
    },
    {
      "position": 4,
      "text": "Assemble the sandwich by placing a slice of bread on a flat surface (side with mayo facing up). Top with lettuce leaf, tomato slices, bacon, and avocado slices. You can even add cheese if preferred."
    },
    {
      "position": 5,
      "text": "Top the avocado with the other slice of bread. The side with mayo spread should be facing down."
    },
    {
      "position": 6,
      "text": "Serve with your favorite drink."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 1,
