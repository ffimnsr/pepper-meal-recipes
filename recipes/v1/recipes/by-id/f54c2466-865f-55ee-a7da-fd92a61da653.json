  "id": "f54c2466-865f-55ee-a7da-fd92a61da653",
  "slug": "sago-at-gulaman",
  "name": "Sago at Gulaman Recipe",
  "recipe_type": "drink",
  "brief_description": "A favorite local beverage in the Philippines is Sago at Gulaman. This sugar based refreshment tastes great. Get the recipe here.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the tapioca by boiling 4 cups of water in a pot. Add the tapioca pearls. Boil for 8 minutes in medium heat setting. Reduce the heat to the lowest setting and then continue boiling until the pearls turn translucent and chewy. Set it aside."
    },
    {
      "position": 2,
      "text": "Cook the gelatin by boiling 2 cups of water in a pot. Add white sugar and ge;atin powder. Turn the heat off and stir. Transfer the mixture to a glass container. Let it cool down. Refrigerate until the gelatin sets."
    },
    {
      "position": 3,
      "text": "Make the syrup by combining all the syrup ingredients in a cooking pot. Let it boil. Cook for 1 minute while stirring. Set aside."
    },
    {
      "position": 4,
      "text": "In a glass, combine some tapioca pearls, sliced gelatin, 3 tablespoons of syrup , and a cup of cold water. Stir."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
