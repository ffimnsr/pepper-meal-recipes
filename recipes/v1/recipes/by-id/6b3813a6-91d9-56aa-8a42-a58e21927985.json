  "id": "6b3813a6-91d9-56aa-8a42-a58e21927985",
  "slug": "filipino-food-appetizer-pulutan-sisig",
  "name": "Sisig Recipe",
  "recipe_type": null,
  "brief_description": "This Sisig Recipe is simple yet delicious. Discover how easy it is to cook your own meal or pulutan by checking this page.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water in a pan and bring to a boil"
    },
    {
      "position": 2,
      "text": "Add salt and pepper"
    },
    {
      "position": 3,
      "text": "Put-in the pig\u2019s ears and pork belly then simmer for 40 minutes to 1 hour (or until tender)."
    },
    {
      "position": 4,
      "text": "Remove the boiled ingredients from the pot then drain excess water"
    },
    {
      "position": 5,
      "text": "Grill the boiled pig ears and pork belly until done"
    },
    {
      "position": 6,
      "text": "Chop the pig ears and pork belly into fine pieces"
    },
    {
      "position": 7,
      "text": "In a pan, melt the butter then add the onions. Cook until onions are soft."
    },
    {
      "position": 8,
      "text": "Put-in the ginger and cook for a few minutes"
    },
    {
      "position": 9,
      "text": "Add the chicken liver and cook until well done."
    },
    {
      "position": 10,
      "text": "Crush the chicken liver while being cooked in the pan"
    },
    {
      "position": 11,
      "text": "Add the chopped pig ears and pork belly then cook for 10 minutes"
    },
    {
      "position": 12,
      "text": "Put-in the soy sauce and chili then mix well"
    },
    {
      "position": 13,
      "text": "Add salt and pepper to taste"
    },
    {
      "position": 14,
      "text": "Put-in the mayonnaise and mix with the other ingredients"
    },
    {
      "position": 15,
      "text": "Serve hot. Share and Enjoy (add the lemon or calamansi before eating)"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
