  "id": "156e83e4-e2cb-52f9-ab50-68ead6ee1e9c",
  "slug": "creamy-macaroni-salad",
  "name": "Creamy Macaroni Salad Recipe",
  "recipe_type": "salad",
  "brief_description": "Creamy macaroni salad with chicken and ham.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the macaroni based on package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Make the dressing by combining all the dressing ingredients in a large mixing bowl. Mix well."
    },
    {
      "position": 3,
      "text": "Add the cooked macaroni. Toss until the macaroni is coated with the dressing."
    },
    {
      "position": 4,
      "text": "Chill by placing the bowl inside the refrigerator for at least 1 hour."
    },
    {
      "position": 5,
      "text": "Serve and enjoy with your family."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 10,
