  "id": "34d2df2c-b224-5986-b287-5d39a8a7c59b",
  "slug": "kalabasa-and-corned-beef-nuggets",
  "name": "Homemade Kalabasa and Corned Beef Nuggets",
  "recipe_type": "appetizer",
  "brief_description": "How to make homemade nuggets using Butternut squash and corned beef.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Grate the kalabasa or butternut squash using a cheese grater. You can also use a food processor."
    },
    {
      "position": 2,
      "text": "Combine grated kalabasa nd corned beef in a bowl. Mix the ingredients together."
    },
    {
      "position": 3,
      "text": "Add garlic powder, pepper, salt, egg, and breadcrumbs. Continue to mix until all ingredients are well blended. Note: If the texture of the mixture is still sticky, you can add more breadcrumbs."
    },
    {
      "position": 4,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 5,
      "text": "Scoop around 2 tablespoons of mixture and mold it into nuggets. Dredge in breadcrumbs."
    },
    {
      "position": 6,
      "text": "Fry one side until golden brown. Turn over and continue to fry the opposite side until the same color is achieved. Remove from the cooking pot and let excess oil drip."
    },
    {
      "position": 7,
      "text": "Tranfer to a serving plate. Serve with your favorite dipping sauce."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
