  "slug": "filipino-food-network-pork-recipe-paksiw-na-pata-ng-baboy",
  "name": "Paksiw na Pata Recipe",
  "recipe_type": null,
  "brief_description": "Paksiw na Pata is pork hock cooked in vinegar and soy sauce. It is a delicious Filipino dish that is best eaten with warm white rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil 6 cups water in a pot. Add the pork hock. Continue to boil for 15 minutes. Discard water and wash the pork with running water until all impurities are cleaned."
    },
    {
      "position": 2,
      "text": "Pour the water in a pot and bring to a boil. Add the whole pepper corn and dried bay leaves"
    },
    {
      "position": 3,
      "text": "Pour soy sauce into the pot and add the garlic."
    },
    {
      "position": 4,
      "text": "Put-in the sliced pork hock and simmer for 1 to 1.5 hours (or cook in pressure cooker for 30 minutes)"
    },
    {
      "position": 5,
      "text": "Add the vinegar and simmer for 10 minutes"
    },
    {
      "position": 6,
      "text": "Place the banana blossoms in and simmer for 5 to 7 minutes"
    },
    {
      "position": 7,
      "text": "Add the brown sugar and salt and simmer for 2 minutes"
    },
    {
      "position": 8,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
