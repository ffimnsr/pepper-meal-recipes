  "id": "d180b26b-e793-502a-9728-e578f4b95ccf",
  "slug": "jollibee-style-burger-steak-recipe",
  "name": "Burger Steak",
  "recipe_type": "main",
  "brief_description": "Salisbury steak Filipino style.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make the beef patties by combining ground beef, onion powder, garlic powder, ground black pepper, and egg. Grate 1 piece of Knorr beef cube. Mix everything together."
    },
    {
      "position": 2,
      "text": "Make the patties by scooping around \u00bc cup of the meat mixture. Mold it into ball shaped figures and then flatten."
    },
    {
      "position": 3,
      "text": "Heat 2 tablespoons cooking oil in a pan. Fry one side of the patties in medium heat until it browns. Turn it over and do the same procedure to the opposite side. Remove from the pan. Set it aside."
    },
    {
      "position": 4,
      "text": "Make the gravy by melting butter in a saucepan."
    },
    {
      "position": 5,
      "text": "Add all-purpose flour. Cook in medium heat while stirring for 8 minutes to make a brown roux."
    },
    {
      "position": 6,
      "text": "Add Knorr Beef Cube. Stir until melted."
    },
    {
      "position": 7,
      "text": "Pour water into the saucepan. Stir until well blended. Note: you will notice that the mixture slowly gets thicker in time."
    },
    {
      "position": 8,
      "text": "Add onion powder, garlic powder, ground black pepper, and Knorr Liquid Seasoning. Cook for 30 seconds."
    },
    {
      "position": 9,
      "text": "Add sliced mushrooms. Cook for 1 minute. Set aside."
    },
    {
      "position": 10,
      "text": "Arrange beef patties over a cup of steamed rice and then pour beef gravy all over."
    },
    {
      "position": 11,
      "text": "Top with chopped parsley, Serve warm. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
