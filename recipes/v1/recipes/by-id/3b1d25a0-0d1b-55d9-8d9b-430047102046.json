  "id": "3b1d25a0-0d1b-55d9-8d9b-430047102046",
  "slug": "nilagang-pata-recipe",
  "name": "Nilagang Pata Recipe",
  "recipe_type": "soup",
  "brief_description": "Nilagang Pata is a simple Filipino soup dish involving pata or pork hocks. This is also known as Pig legs. Unlike crispy pata, this soup recipe requires the leg to be sliced crosswise \u2013 similar to that of paksiw na pata.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine water and beef stock. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the onion, peppercorns, and pork hock. Simmer for 60 minutes or until the pork hock becomes tender. Add more water if needed."
    },
    {
      "position": 3,
      "text": "Put-in the potato and saba banana. Cook for 10 minutes."
    },
    {
      "position": 4,
      "text": "Add the fish sauce and baby bok choy. Stir. Turn the heat off and cover the cooking pot. Let is stay for 10 minutes."
    },
    {
      "position": 5,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
