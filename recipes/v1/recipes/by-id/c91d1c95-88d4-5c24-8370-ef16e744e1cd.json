  "id": "c91d1c95-88d4-5c24-8370-ef16e744e1cd",
  "slug": "filipino-style-escabeche",
  "name": "Escabeche",
  "recipe_type": "appetizer",
  "brief_description": "Crispy fried whole fish topped with a sweet and sour sauce made from banana ketchup, vinegar, and julienned vegetables. Serve warm with steamed rice.",
  "cuisine": "Asian Filipino Mediterranean",
  "instructions": [
    {
      "position": 1,
      "text": "Rub the Maggi Magic Sarap all over the fish, including the cavity and the scored sides. Let it stand for 5 minutes."
    },
    {
      "position": 2,
      "text": "Heat 3/4 cup of cooking oil in a large pan over medium-high heat. Fry both sides of the fish until golden brown and crispy. Remove the fish from the pan and arrange on a serving plate."
    },
    {
      "position": 3,
      "text": "In a separate pan, heat 2 tablespoons of cooking oil over medium heat. Saute the garlic, ginger, and onion until the onion softens."
    },
    {
      "position": 4,
      "text": "Add the banana ketchup, white vinegar, white sugar, and water. Stir and let the mixture come to a boil."
    },
    {
      "position": 5,
      "text": "Toss in the bell peppers and carrots. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Season the sauce with salt and ground black pepper to taste."
    },
    {
      "position": 7,
      "text": "In a small bowl, combine the cornstarch with 2 tablespoons of water. Mix until smooth. Pour the slurry into the pan and stir until the sauce thickens."
    },
    {
      "position": 8,
      "text": "Add the fried fish back into the pan. Pour the sauce over it and cook for 1 minute. Transfer to a serving plate. Serve warm with steamed rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
