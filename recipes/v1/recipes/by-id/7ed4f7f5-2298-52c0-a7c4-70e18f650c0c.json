  "id": "7ed4f7f5-2298-52c0-a7c4-70e18f650c0c",
  "slug": "breaded-fried-salmon-recipe",
  "name": "Breaded Fried Salmon Recipe",
  "recipe_type": null,
  "brief_description": "Breaded Fried Salmon is a very simple fried fish recipe. Salmon fillets are marinated and breaded with flour before being fried.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine soy sauce, Worcestershire sauce, sugar, salt, and pepper. Stir."
    },
    {
      "position": 2,
      "text": "Rub the mixture all over the salmon. Marinate for at least 1 hour."
    },
    {
      "position": 3,
      "text": "Heat the oil in a frying pan."
    },
    {
      "position": 4,
      "text": "Dredge the salmon in flour and then fry each side for about 5 minutes or until golden brown."
    },
    {
      "position": 5,
      "text": "Transfer to individual serving plates."
    },
    {
      "position": 6,
      "text": "Serve with Ampalaya Salad and rice."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 60,
