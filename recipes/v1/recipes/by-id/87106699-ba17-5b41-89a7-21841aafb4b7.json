  "id": "87106699-ba17-5b41-89a7-21841aafb4b7",
  "slug": "chicken-hinalang-halang-halang-na-manok",
  "name": "Chicken Hinalang (Halang-halang na Manok)",
  "recipe_type": "soup",
  "brief_description": "Spicy chicken soup with chayote and bell peppers.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken, soy sauce, and vinegar. Mix well. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic, onion, and ginger."
    },
    {
      "position": 3,
      "text": "Add marinated chicken once onion softens. Continue saut\u00e9ing until chicken for 5 minutes."
    },
    {
      "position": 4,
      "text": "Pour 1 \u00bd quarts water into the cooking pot. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Chicken Cube and lemongrass. Cover and cook in low heat for 30 minutes."
    },
    {
      "position": 6,
      "text": "Remove lemongrass. Add chili pepper and sayote. Cook for 7 minutes."
    },
    {
      "position": 7,
      "text": "Put-in bell pepper, hot pepper leaves, and green onions. Continue cooking for 5 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 9,
      "text": "Serve hot with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
