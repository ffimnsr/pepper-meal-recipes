{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "83195bbb-a70a-5ac3-a389-de0fc97041f2",
  "slug": "corned-beef-silog",
  "name": "Corned Beef Silog",
  "recipe_type": "breakfast",
  "brief_description": "A Filipino breakfast meal composed of sauteed corned beef, fried egg, and garlic fried rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil on a pan. Once the oil gets hot, crack an egg and fry sunny-side-up. Remove the fried egg and place in a plate. Do this step until all 3 eggs are cooked."
    },
    {
      "position": 2,
      "text": "Using the remaining oil, saut\u00e9 the garlic until it turns medium brown. Add the onion and saut\u00e9 until it softens."
    },
    {
      "position": 3,
      "text": "Add the corned beef. Saut\u00e9 for 2 minutes"
    },
    {
      "position": 4,
      "text": "Pour the beef broth in the pan. Continue to cook for 2 to 3 minutes or until the liquid evaporate. Add salt and pepper to taste."
    },
    {
      "position": 5,
      "text": "Arrange a cup of sinangag (garlic fried rice) and a piece of egg on a plate. Put 1/3 of the cooked corned beef. Do this step on all 3 plates. Serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
