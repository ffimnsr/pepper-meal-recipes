  "id": "e10ac3d4-ed3b-504f-9777-3c64c7439ea9",
  "slug": "sinigang-na-liempo-sa-sampaloc-with-taro",
  "name": "Sinigang na Liempo sa Sampaloc",
  "recipe_type": null,
  "brief_description": "Sinigang na Liempo sa Sampaloc with Gabi is a version of Pork Sinigang made using the traditional method. It is simply delicious.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil the water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Put-in the tamarind and continue to boil for 45 minutes. Once done, remove the tamarind from the water. Set both aside."
    },
    {
      "position": 3,
      "text": "Meanwhile, heat the oil on another deep cooking pot."
    },
    {
      "position": 4,
      "text": "Once the oil is hot, sear the pork belly until the color turns light brown."
    },
    {
      "position": 5,
      "text": "Stir-in the tomatoes and onion. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Gently pour-in the water (used to boil the tamarind), but do not include the tamarind yet. Add the beef broth and gabi afterwards."
    },
    {
      "position": 7,
      "text": "Place the tamarind on a strainer and let the remaining juice out by pushing a spoon against it. Add the tamarind juice to the cooking pot where the meat is. Simmer for 60 minutes. Add more water if necessary."
    },
    {
      "position": 8,
      "text": "Put-in the okra and long green chili. Cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Add the kangkong (onchoy) and fish sauce. Stir. Cover and turn the heat off. Let it stay covered for 5 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 11,
      "text": "Serve with warm rice."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
