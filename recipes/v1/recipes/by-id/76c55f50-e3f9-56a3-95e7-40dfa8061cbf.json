  "id": "76c55f50-e3f9-56a3-95e7-40dfa8061cbf",
  "slug": "chicken-sotanghon-soup-with-malunggay-and-sayote",
  "name": "Chicken Sotanghon Soup with Malunggay at Sayote",
  "recipe_type": "soup",
  "brief_description": "Chicken noodle soup using vermicelli with moringa leaves and sliced chayote. This healthy soup dish can be enjoyed as it is or as a main dish with rice. 1 lb. Chicken breast",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add chicken. Cover and continue boiling for 18 minutes. Remove chicken from the pot and let it cool down. Save the chicken stock for later."
    },
    {
      "position": 2,
      "text": "Separate the bone from the meat and then shred. Set shredded chicken aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a cooking pot. Add crushed garlic right away. Continue cooking the garlic until it turns light brown."
    },
    {
      "position": 4,
      "text": "Add onion. Saut\u00e9 until it softens."
    },
    {
      "position": 5,
      "text": "Add sayote. Cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Put shredded chicken into the pot and pour-in chicken stock. Cover the pot and let the liquid boil."
    },
    {
      "position": 7,
      "text": "Add Knorr Chicken Cube. Stir and add the sotanghon noodles. Cook until noodles are soft."
    },
    {
      "position": 8,
      "text": "Add malunggay leaves. Cook for 1 minute."
    },
    {
      "position": 9,
      "text": "Season with patis and ground black pepper. Transfer to a serving bowl. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
