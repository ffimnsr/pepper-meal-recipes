  "id": "8d00e049-028e-5e85-83ce-a86e874bcc3d",
  "slug": "peach-pie-recipe",
  "name": "Peach Pie Recipe",
  "recipe_type": "dessert",
  "brief_description": "This quick and easy Peach Pie Recipe will give you the quickest and most delicious peach pie that you ever tasted. Try this recipe today.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Separate the liquid concentrate from the sliced peaches."
    },
    {
      "position": 2,
      "text": "Combine the flour, sugar, nutmeg, salt, and cinnamon in a small bowl. Mix well."
    },
    {
      "position": 3,
      "text": "On a large bowl, combine the sliced peaches and lime juice. Gently toss to mix."
    },
    {
      "position": 4,
      "text": "Preheat oven to 400 degrees Fahrenheit."
    },
    {
      "position": 5,
      "text": "Gradually add the flour mixture to the peaches while gradually tossing. Continue to toss until all the ingredients are well incorporated."
    },
    {
      "position": 6,
      "text": "Arrange the pastry dough in a 9\u201d round pie pan."
    },
    {
      "position": 7,
      "text": "Brush some egg whites over the pie pan."
    },
    {
      "position": 8,
      "text": "Blind bake the pastry dough by placing it in the oven for 10 minutes."
    },
    {
      "position": 9,
      "text": "Remove the crust from the oven and then let the temperature drop."
    },
    {
      "position": 10,
      "text": "Arrange the peaches over the crust. Cover with the second pastry dough. Make sure that the edges are sealed."
    },
    {
      "position": 11,
      "text": "Brush the remaining egg whites over the pastry dough. Create holes for the steam to escape using a fork."
    },
    {
      "position": 12,
      "text": "Reduce the heat to 350 degrees Fahrenheit. Bake for 35 minutes."
    },
    {
      "position": 13,
      "text": "Remove from the oven. Let the temp drop to room temperature and then chill in the fridge for at least 1 hour."
    },
    {
      "position": 14,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 15,
