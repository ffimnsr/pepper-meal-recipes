  "id": "f960d39c-3208-5479-9f6f-bba7ca0888db",
  "slug": "sizzling-gambas-shrimp-recipe",
  "name": "Sizzling Gambas Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Shrimp cooked in a spicy, garlicky sauce and served on a hot sizzling plate",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine lemon juice and shrimp and marinade for 30 minutes."
    },
    {
      "position": 2,
      "text": "Pour cooking oil in a wok of frying pan then apply heat."
    },
    {
      "position": 3,
      "text": "When the oil is hot enough, put-in the garlic and cook until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Add the onions and red bell pepper then cook until the texture softens."
    },
    {
      "position": 5,
      "text": "Put-in the shrimps and cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the cooking rice wine, salt, and pepper then cook for another minute."
    },
    {
      "position": 7,
      "text": "Add the tomato sauce and stir. Cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Put-in the hot sauce and simmer for 30 seconds. Turn off the heat and set-aside."
    },
    {
      "position": 9,
      "text": "Heat a sizzling plate and transfer the shrimp along with the other ingredients."
    },
    {
      "position": 10,
      "text": "Top with sliced green chilies and serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 8,
  "rest_time_minutes": null,
  "difficulty": "hard",
