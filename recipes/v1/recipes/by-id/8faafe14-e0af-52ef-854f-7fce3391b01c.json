{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "8faafe14-e0af-52ef-854f-7fce3391b01c",
  "slug": "sweet-pepper-relyeno-recipe",
  "name": "Sweet Pepper Relyeno Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Sweet Pepper Relyeno or Stuffed Sweet Peppers is an appetizer or main dish consisting of mini sweet peppers and ground pork.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the stuffing by combining the ground pork, 1 piece egg, minced onion and carrot, salt, ground black pepper, and garlic powder in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Scoop around 1 1/2 tablespoons (or more) of the mixture and arrange it over the sliced sweet pepper. Gently press the mixture to keep it intact."
    },
    {
      "position": 3,
      "text": "Meanwhile, heat the cooking oil in a pan."
    },
    {
      "position": 4,
      "text": "While the oil is heating, beat the remaining 2 eggs. Dip the sweet pepper with ground pork in the egg and roll it over the Panko bread crumbs. Make sure that the top is fully coated with the bread crumbs."
    },
    {
      "position": 5,
      "text": "Pan fry the sweet pepper with breadcrumbs in medium heat until the breadcrumbs turns light to medium brown. Turn it over and cook the other side (side without the stuffing) for 2 minutes. Remove from the pan. Arrange in a baking tray lined with Aluminum foil."
    },
    {
      "position": 6,
      "text": "Preheat the oven to 350F."
    },
    {
      "position": 7,
      "text": "Bake the pan fried sweet peppers for 25 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven. Arrange in a plate lined with paper towels."
    },
    {
      "position": 9,
      "text": "Serve with ketchup. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
