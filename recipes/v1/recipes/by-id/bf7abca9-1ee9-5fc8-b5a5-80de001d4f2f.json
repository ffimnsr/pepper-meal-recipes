  "id": "bf7abca9-1ee9-5fc8-b5a5-80de001d4f2f",
  "slug": "kinilaw-kilawin-na-tuna",
  "name": "Kinilaw na Tuna",
  "recipe_type": "salad",
  "brief_description": "Kinilaw na Tuna or raw fish salad is an appetizer dish that is usually consumed as \u201cpulutan\u201d; it is best served along with cold beer.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Place the cubed tuna meat in a large bowl then pour-in 3/4 cups of vinegar."
    },
    {
      "position": 2,
      "text": "Let stand for 2 minutes then gently squeeze the tuna by placing a spoon on top applying a little pressure."
    },
    {
      "position": 3,
      "text": "Gently wash the tuna meat with vinegar. Drain all the vinegar once done. This will help reduce the fishy smell."
    },
    {
      "position": 4,
      "text": "Add the remaining 3/4 cup vinegar, calamansi or lemon juice, ginger, salt, ground black pepper, and red chilies then mix well."
    },
    {
      "position": 5,
      "text": "Cover the bowl and refrigerate for at least 2 hours."
    },
    {
      "position": 6,
      "text": "Top with minced red onions and serve (you may also add the red onions with the rest of the ingredients in step 4)."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 1,
