  "id": "34943f06-48b2-5f8f-84b6-1013e98cf93d",
  "slug": "broiled-red-snapper-with-pico-de-gallo",
  "name": "Broiled Red Snapper with Pico de Gallo",
  "recipe_type": "main",
  "brief_description": "Fresh red snapper broiled with garlic and lemon, served with vibrant pico de gallo. A simple yet flavorful main course that comes together quickly.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make incisions on both sides of the fish."
    },
    {
      "position": 2,
      "text": "Rub salt all over the red snapper. Let it stay for 10 minutes."
    },
    {
      "position": 3,
      "text": "Preheat the oven to broil (around 510F)"
    },
    {
      "position": 4,
      "text": "Combine crushed garlic and juice from the lemon. Mix well."
    },
    {
      "position": 5,
      "text": "Spoon the lemon mixture over the fish. Make sure to pour it in the incisions to be better absorbed."
    },
    {
      "position": 6,
      "text": "Spray some cooking oil using the cooking spray on a baking tray. Arrange the fish on the baking tray and then lightly spray some cooking oil on top of the fish."
    },
    {
      "position": 7,
      "text": "Broil the fish in the oven for 18 to 25 minutes. Add more time if your fish is bigger."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with Pico de Gallo on the side."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
