  "id": "b8b73f47-1681-574c-94ec-4cfc9f69765d",
  "slug": "ginisang-monggo-with-kalabasa",
  "name": "Ginisang Monggo with Kalabasa",
  "recipe_type": "main",
  "brief_description": "Thick mung bean stew with calabaza squash, malunggay, spinach, dried shrimp, and crispy pork rinds. A satisfying and nutritious Filipino comfort food perfect with rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Soak the mung beans in \u00bd quart water overnight."
    },
    {
      "position": 2,
      "text": "Heat 3 tablespoons of cooking oil in a deep cooking pot."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the garlic until it starts to brown. Add the onion and tomato. Continue saut\u00e9ing until softened."
    },
    {
      "position": 4,
      "text": "Add the dried shrimp and soaked mung beans. Stir well."
    },
    {
      "position": 5,
      "text": "Pour in the fish sauce and 1 quart of water. Cover and simmer until the mung beans are completely soft and the soup develops a thick consistency. Note: Add more water as needed."
    },
    {
      "position": 6,
      "text": "Add the calabaza squash. Cover and continue cooking until the squash is tender."
    },
    {
      "position": 7,
      "text": "Add the malunggay leaves and spinach. Cook for 1 minute."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper and Maggi Magic Sarap. Stir well."
    },
    {
      "position": 9,
      "text": "Top with crispy chicharon."
    },
    {
      "position": 10,
      "text": "Serve hot with fried pork belly and steamed rice."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
