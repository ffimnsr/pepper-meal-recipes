  "id": "65d5b22f-fa24-5f55-8987-b9a6b181ed7f",
  "slug": "rellenong-talong-recipe",
  "name": "Rellenong Talong (Stuffed Eggplant) Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for stuffed eggplant.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Grill the eggplants until steam comes out (about 4 to 6 minutes per side)."
    },
    {
      "position": 2,
      "text": "Remove the eggplants from the grill; let the temperature cool down; peel-off the skin and then set aside"
    },
    {
      "position": 3,
      "text": "Meanwhile, heat 1 tablespoon of cooking in a pan."
    },
    {
      "position": 4,
      "text": "Saut\u00e9 onion, garlic, and tomato"
    },
    {
      "position": 5,
      "text": "Add the ground pork. Cook until color turns medium brown (about 8 to 10 minutes)"
    },
    {
      "position": 6,
      "text": "Put-in soy sauce, 1/2 teaspoon salt, and ground black pepper. Stir; turn off heat, and then set aside."
    },
    {
      "position": 7,
      "text": "Add remaining salt with the beaten eggs and then beat once more."
    },
    {
      "position": 8,
      "text": "Dip the eggplants in the beaten egg mixture."
    },
    {
      "position": 9,
      "text": "Heat a clean pan and then pour-in 1/2 cup cooking oil."
    },
    {
      "position": 10,
      "text": "Put-in one egg plant. Scoop about half of the ground pork mixture and distribute on top of the eggplant"
    },
    {
      "position": 11,
      "text": "Pour-in about 2 to 3 tablespoons of beaten egg mixture over the ground pork."
    },
    {
      "position": 12,
      "text": "Gently flip the egg (using 2 spatulas if possible) to cook the other side. Cook for 3 to 4 minutes in low to medium heat."
    },
    {
      "position": 13,
      "text": "Remove from the pan and transfer to a serving plate."
    },
    {
      "position": 14,
      "text": "Serve with banana ketchup and steamed rice."
    },
    {
      "position": 15,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
