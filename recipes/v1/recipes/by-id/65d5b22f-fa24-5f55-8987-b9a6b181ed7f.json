  "id": "65d5b22f-fa24-5f55-8987-b9a6b181ed7f",
  "slug": "rellenong-talong-recipe",
  "name": "Rellenong Talong (Stuffed Eggplant) Recipe",
  "recipe_type": "main",
  "brief_description": "Filipino-style grilled eggplant stuffed with savory ground pork, tomatoes, and aromatics, dipped in beaten egg and pan-fried until golden brown. Traditionally served with banana ketchup and steamed rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Grill the eggplants until steam comes out (about 4 to 6 minutes per side)."
    },
    {
      "position": 2,
      "text": "Remove the eggplants from the grill; let cool, peel off the skin, and set aside."
    },
    {
      "position": 3,
      "text": "Meanwhile, heat 1 tablespoon of cooking oil in a pan."
    },
    {
      "position": 4,
      "text": "Saut\u00e9 onion, garlic, and tomato until softened."
    },
    {
      "position": 5,
      "text": "Add the ground pork. Cook until color turns medium brown (about 8 to 10 minutes)."
    },
    {
      "position": 6,
      "text": "Add soy sauce, 1/2 teaspoon salt, and ground black pepper. Stir, turn off the heat, and set aside."
    },
    {
      "position": 7,
      "text": "Add the remaining salt to the beaten eggs and mix well."
    },
    {
      "position": 8,
      "text": "Dip the peeled eggplants in the beaten egg mixture."
    },
    {
      "position": 9,
      "text": "Heat a clean pan and pour in 1/2 cup cooking oil."
    },
    {
      "position": 10,
      "text": "Put in one eggplant. Scoop about half of the ground pork mixture and distribute on top of the eggplant."
    },
    {
      "position": 11,
      "text": "Pour 2 to 3 tablespoons of beaten egg mixture over the ground pork."
    },
    {
      "position": 12,
      "text": "Gently flip the eggplant (using two spatulas if possible) to cook the other side. Cook for 3 to 4 minutes over low-to-medium heat."
    },
    {
      "position": 13,
      "text": "Remove from the pan and transfer to a serving plate."
    },
    {
      "position": 14,
      "text": "Serve with banana ketchup and steamed rice."
    },
    {
      "position": 15,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
