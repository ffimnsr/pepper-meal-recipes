  "slug": "linguine-with-mussels-recipe",
  "name": "Linguine with Mussels Recipe",
  "recipe_type": null,
  "brief_description": "This Linguine with Mussels Recipe is amazing. It is easy to prepare, budget friendly, and delicious. Watch our video to learn how to make this dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a large pan."
    },
    {
      "position": 2,
      "text": "Saute onions and garlic"
    },
    {
      "position": 3,
      "text": "pour-in white wine and let boil."
    },
    {
      "position": 4,
      "text": "Add mussels, parsley, salt, and pepper. Stir gently and simmer for 4 to 7 minutes."
    },
    {
      "position": 5,
      "text": "Gradually add the linguine while stirring. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Turn off the heat and transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Garnish with parmesan cheese. Serve with garlic bread."
    },
    {
      "position": 8,
      "text": "Share and enjoy"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
