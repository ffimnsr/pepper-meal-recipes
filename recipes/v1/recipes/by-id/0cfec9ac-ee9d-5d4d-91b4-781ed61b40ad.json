  "id": "0cfec9ac-ee9d-5d4d-91b4-781ed61b40ad",
  "slug": "not-your-ordinary-chicken-adobo",
  "name": "Not Your Ordinary Chicken Adobo",
  "recipe_type": "main",
  "brief_description": "Filipino chicken adobo recipe for the Holidays",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken, soy sauce, vinegar, and half of the crushed garlic in a bowl. Mix until all ingredients are well blended. Let it stay for at least 1 hour."
    },
    {
      "position": 2,
      "text": "Fry the remaining garlic until golden brown. Set aside."
    },
    {
      "position": 3,
      "text": "Combine the butter and garlic-infused oil (this is the oil used to cook the garlic). Saut\u00e9 the onion and then add the marinated chicken. Cook until the chicken turns light brown."
    },
    {
      "position": 4,
      "text": "Add the oyster sauce and then pour the remaining marinade and water. Let it boil."
    },
    {
      "position": 5,
      "text": "Add Knorr chicken cube, sugar, bay leaves, fried garlic, and whole peppercorn. Reduce to a simmer. Cover the pot and cook for 35 to 45 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Garnish with chopped green onions."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
