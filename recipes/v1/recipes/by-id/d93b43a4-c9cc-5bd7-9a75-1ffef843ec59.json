  "id": "d93b43a4-c9cc-5bd7-9a75-1ffef843ec59",
  "slug": "pork-ribs",
  "name": "Sinarsahang Pork Ribs",
  "recipe_type": "main",
  "brief_description": "Stewed pork ribs served with steamed vegetables",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Steam string beans and carrots for 3 minutes. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan. Saut\u00e9 the onion and garlic until the onion softens."
    },
    {
      "position": 3,
      "text": "Put the pork ribs in the pan. Saut\u00e9 until it turns light brown."
    },
    {
      "position": 4,
      "text": "Pour the soy sauce, add tomato sauce, and water. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork Cube. Cover the pan. Simmer until the pork tenderizes completely."
    },
    {
      "position": 6,
      "text": "Add the butter. Continue simmering uncovered until the sauce reduces to half."
    },
    {
      "position": 7,
      "text": "Add sugar and season with salt and ground black pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with steamed vegetables."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
