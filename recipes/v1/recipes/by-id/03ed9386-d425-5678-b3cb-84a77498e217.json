  "id": "03ed9386-d425-5678-b3cb-84a77498e217",
  "slug": "spicy-laing-recipe",
  "name": "Spicy Laing Recipe",
  "recipe_type": null,
  "brief_description": "This Spicy Laing Recipe Tastes really awesome. It is the simplest and tastiest version that I did. Try it for yourself.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork, dried fish, garlic, onion, ginger, coconut milk, and coconut cream in a cooking pot."
    },
    {
      "position": 2,
      "text": "Apply heat and let boil."
    },
    {
      "position": 3,
      "text": "Add the dried taro leaves and Thai chili (do not stir). Simmer until the liquid almost dries out. Note: This will take about 40 to 50 minutes. When you notice a strong scent of coconut, this can be a sign that its ready."
    },
    {
      "position": 4,
      "text": "Put-in the long green chili, salt, and pepper. Gently stir the ingredients and cook for another 3 minutes."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
