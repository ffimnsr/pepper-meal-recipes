  "schema_version": 1,
  "id": "46dfb3e0-dbeb-520a-8ace-d3f358f1423a",
  "slug": "oven-baked-chicken",
  "name": "Oven Baked Chicken Recipe",
  "recipe_type": "main",
  "brief_description": "Whole chicken roasted with olive oil, lemon, garlic, and thyme. Crispy skin, juicy meat, and loaded with aroma.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Combine juice of 1 lemon, 1 teaspoon salt, 1 teaspoon garlic powder, 1/2 teaspoon ground black pepper in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Pour 3/4 of the mixture in the chicken's cavity, and rub the remaining on the outer part of the chicken. Place inside the fridge and marinate overnight."
    },
    {
      "position": 3,
      "text": "Preheat oven to 400 degrees Fahrenheit."
    },
    {
      "position": 4,
      "text": "Combine olive oil, remaining salt, remaining garlic powder, remaining pepper, and thyme."
    },
    {
      "position": 5,
      "text": "Separate the skin from the meat by gently sliding your fingers between the chicken's skin and meat starting either from the neck or the opposite side. Rub half of olive oil mixture between the skin and meat of the chicken. Rub the other half on the outer part of the chicken."
    },
    {
      "position": 6,
      "text": "Arrange the celery ribs and onions in the cavity of the chicken."
    },
    {
      "position": 7,
      "text": "Place the chicken on a roasting rack. Put inside the oven and bake for 30 minutes."
    },
    {
      "position": 8,
      "text": "Reduce the temperature to 350 degrees Fahrenheit, and continue baking for another 15 to 30 minutes or until the internal temperature of the chicken is 170 degrees Fahrenheit. Note: If the chicken skin needs more browning, you may need to put your oven to roast and cook the chicken until the skin darkens."
    },
    {
      "position": 9,
      "text": "Remove from the oven and place in a serving plate."
    },
    {
      "position": 10,
      "text": "Serve with Potato and Green Bean Salad."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
