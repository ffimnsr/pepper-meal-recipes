  "id": "998256b3-e3cc-555c-8882-6346f627a11e",
  "slug": "ginisang-repolyo-with-egg",
  "name": "Ginisang Repolyo with Egg",
  "recipe_type": "main",
  "brief_description": "Sauteed cabbage with cabbage and egg",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chopped cabbage and salt. Mix it altogether. Let it stay for 10 minutes and then rinse with water. Set the cabbage aside."
    },
    {
      "position": 2,
      "text": "Beat the eggs and add a bit of salt and ground black pepper."
    },
    {
      "position": 3,
      "text": "Heat 2 tablespoons of cooking oil in a pan. Once the oil gets hot, pour beaten eggs. Cook it until firm and then cut into small pieces using the tip of your spatula or cooking spoon. Remove the egg from the pan. Set it aside."
    },
    {
      "position": 4,
      "text": "Heat the remaining oil. Saut\u00e9 the onion and garlic."
    },
    {
      "position": 5,
      "text": "Once the onion softens. Add the carrots. Saut\u00e9 for 30 seconds."
    },
    {
      "position": 6,
      "text": "Add the cabbage. Continue saut\u00e9ing for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add the soy sauce , oyster sauce, and sesame oil. Cook for 1 minute. Note: this is also the time to add sugar if you want."
    },
    {
      "position": 8,
      "text": "Put the scrambled eggs into the pan and then add the chopped green onions and sesame oil."
    },
    {
      "position": 9,
      "text": "Season it with ground black pepper."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
