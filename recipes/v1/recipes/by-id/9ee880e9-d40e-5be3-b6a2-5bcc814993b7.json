  "id": "9ee880e9-d40e-5be3-b6a2-5bcc814993b7",
  "slug": "laing-with-shrimp-recipe",
  "name": "Laing with Shrimp Recipe",
  "recipe_type": null,
  "brief_description": "Laing with Shrimp is not your typical laing recipe because it make use of shrimp as an additional ingredient. It might have been common to use shrimp and other seafood ingredient in some version of laing, but the original laing version rarely use this ingredient.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large cooking pot, combine the 8 cups coconut milk, pork, onion, shrimp paste, ginger, and garlic. Turn the heat on and then place the cooking pot over the stove and start to boil the mixture."
    },
    {
      "position": 2,
      "text": "Once you see that the coconut milk starts to boil, gently stir. Let it boil completely and cover. Simmer (cook near boiling temp) for 18 minutes."
    },
    {
      "position": 3,
      "text": "Add the dried taro leaves (gabi leaves). Let it stay for 10 to 12 minutes in low to medium heat. Do not stir, but you can try to push the taro leaves so that it gets coated with coconut milk."
    },
    {
      "position": 4,
      "text": "After 15 minutes or when the leaves absorbed the coconut milk, you can start to stir the mixture. Cook for 8 to 10 minutes."
    },
    {
      "position": 5,
      "text": "Add the chili flakes (or Sriracha sauce) and shrimp. Stir and cook for 8 to 10 minutes. Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
