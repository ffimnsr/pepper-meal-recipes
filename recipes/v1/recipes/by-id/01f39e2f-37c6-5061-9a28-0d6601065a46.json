  "slug": "garlic-sesame-spinach-recipe",
  "name": "Garlic Sesame Spinach Recipe",
  "recipe_type": null,
  "brief_description": "This is a quick spinach saute recipe. Garlic and spinach are cooked in olive and sesame oils and sprinkled with salt.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan. Pour-in olive and sesame oils."
    },
    {
      "position": 2,
      "text": "Put-in the garlic after a few seconds. Make sure that the oils are not too hot, yet. This will prevent the garlic from browning."
    },
    {
      "position": 3,
      "text": "Add the spinach. Cook for a few minutes while stirring once in awhile."
    },
    {
      "position": 4,
      "text": "Sprinkle salt. Stir."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate and serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 5,
