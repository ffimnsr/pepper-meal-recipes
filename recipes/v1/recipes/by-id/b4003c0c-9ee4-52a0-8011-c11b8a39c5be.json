  "id": "b4003c0c-9ee4-52a0-8011-c11b8a39c5be",
  "slug": "scrambled-eggs-with-tomato-onion-and-spinach",
  "name": "Scrambled Eggs with Tomato, Onion, and Spinach",
  "recipe_type": "breakfast",
  "brief_description": "Scrambled Eggs with Tomato, Onion, and Spinach is my idea of a simple and healthy breakfast dish. A slice or two of toast on the side is perfect",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Crack the eggs in a bowl. Add salt and pepper. Beat until smooth. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil and butter in a pan. Make sure that the entire area of the pan is coated with oil and butter."
    },
    {
      "position": 3,
      "text": "Add the tomato and onion. Cook for 2 to 3 minutes in medium heat or until the onion gets soft."
    },
    {
      "position": 4,
      "text": "Add the spinach and then stir fry for 30 seconds."
    },
    {
      "position": 5,
      "text": "Pour-in the beaten egg. Cook one side until it starts to set. Gently scrape the the eggs from one end of the pan going towards the center using either a spatula or wooden spoon. Repeat the process until soft curds form."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with toast."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 8,
