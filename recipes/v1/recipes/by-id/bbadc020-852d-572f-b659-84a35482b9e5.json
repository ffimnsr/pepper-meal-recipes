  "slug": "butter-garlic-shrimp-and-squid",
  "name": "Butter Garlic Shrimp and Squid",
  "recipe_type": null,
  "brief_description": "This is a recipe for Butter Garlic Shrimp and Squid",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat butter in a pan."
    },
    {
      "position": 2,
      "text": "Once the butter melts and starts to get hot, add the garlic. Continue to cook between low to medium heat until the garlic starts to turn light brown."
    },
    {
      "position": 3,
      "text": "Add the shrimp and calamari. Stir fry for 5 minutes."
    },
    {
      "position": 4,
      "text": "Sprinkle some parsley and chili flakes. Add salt if needed."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
