  "id": "bf3a590a-19ad-5c42-be03-b1a9afb5676c",
  "slug": "squid-sisig-recipe",
  "name": "Squid Sisig Recipe",
  "recipe_type": null,
  "brief_description": "Squid Sisig is a pleasant-tasting dish made from chopped grilled squid along with some onions and seasonings. This recipe is my second seafood sisig version",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub 1 teaspoon salt on the squid. Let it stand for 5 minutes."
    },
    {
      "position": 2,
      "text": "Grill the squid for 3 to 4 minutes per side. Remove from the grill. Let cool."
    },
    {
      "position": 3,
      "text": "Chop the squid into small pieces."
    },
    {
      "position": 4,
      "text": "Heat the oil in a pan and then saute the garlic, onion, and ginger."
    },
    {
      "position": 5,
      "text": "Put-in the chopped squid. Stir and then cook for a minute."
    },
    {
      "position": 6,
      "text": "Add the garlic powder, salt, and soy sauce. Stir and cook for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Garnish with crushed chicharon and chopped scallions."
    },
    {
      "position": 8,
      "text": "Serve with lemon wedges. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
