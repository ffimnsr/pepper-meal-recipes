  "id": "0873bb43-7e68-5c5a-aa87-434a04e55543",
  "slug": "ginataang-mais-at-monggo-recipe",
  "name": "Ginataang Mais at Monggo",
  "recipe_type": "dessert",
  "brief_description": "A traditional Filipino dessert combining sweet corn and toasted mung beans cooked in coconut milk with glutinous rice. This hearty, creamy dish is perfect for merienda or as a comforting snack.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour the coconut milk into a cooking pot and bring to a boil."
    },
    {
      "position": 2,
      "text": "Stir in the sweet rice (also known as glutinous rice). Cook for 5 minutes over medium heat, stirring every minute."
    },
    {
      "position": 3,
      "text": "Add the toasted mung beans. Stir and cook for 6 to 8 minutes."
    },
    {
      "position": 4,
      "text": "Stir the corn into the pot. Continue to cook while constantly stirring for 8 to 10 minutes."
    },
    {
      "position": 5,
      "text": "Add the sugar and stir."
    },
    {
      "position": 6,
      "text": "Pour in the vanilla extract. Stir and cook until the mung beans are soft. Add salt if desired."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve hot."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
