  "id": "c522b576-f550-5de6-a677-0f9a4f0e91dc",
  "slug": "spicy-ginataang-hipon-recipe",
  "name": "Spicy Ginataang Hipon Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Spicy Ginataang Hipon or Spicy Shrimp in Coconut Milk",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the gata by combining lukewarm water and Knorr Ginataang Gulay mix. Stir and set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a pot"
    },
    {
      "position": 3,
      "text": "Saut\u00e9 garlic, onion, and ginger"
    },
    {
      "position": 4,
      "text": "Once the onion starts to get soft, add the green pepper, scallions, and chili. Stir and continue to cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour the gata mixture into the pot. Let boil."
    },
    {
      "position": 6,
      "text": "Add the shrimp. Continue to cook while stirring once in a while for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add ground black pepper and fish sauce. Stir and then cook for 1 to 2 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve with rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
