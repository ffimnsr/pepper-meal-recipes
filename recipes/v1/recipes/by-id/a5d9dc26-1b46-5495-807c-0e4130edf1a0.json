  "id": "a5d9dc26-1b46-5495-807c-0e4130edf1a0",
  "slug": "raisin-bran-muffin-recipe",
  "name": "Raisin Bran Muffin Recipe",
  "recipe_type": "snack",
  "brief_description": "This is a recipe for&nbsp; Bran Muffin.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine buttermilk and bran. Let it stay for 12 to 15 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, preheat oven to 370 degrees Fahrenheit."
    },
    {
      "position": 3,
      "text": "In a mixing bowl, beat eggs and then add the vanilla extract and sugars. Mix well until all the ingredients are well incorporated."
    },
    {
      "position": 4,
      "text": "Pour-in the buttermilk and bran. Mix well."
    },
    {
      "position": 5,
      "text": "Fold-in flour and raisins."
    },
    {
      "position": 6,
      "text": "Arrange the mixture in muffin cups and then bake for 14 to 18 minutes or until it passes the toothpick test."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
