  "id": "b34e610c-6cbe-5f76-ac4e-6157bc798466",
  "slug": "easy-meatball-with-mixed-vegetables-recipe",
  "name": "Easy Meatball with Mixed Vegetables Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Easy Meatball with Mixed Vegetables",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, combine ground beef, egg, milk, bread crumbs, garlic powder, parsley, 1 teaspoon salt, and ground black pepper. Mix well using an electric mixer or your clean hands."
    },
    {
      "position": 2,
      "text": "Shape into 1 to 1 1/2 inch balls. Set aside."
    },
    {
      "position": 3,
      "text": "Melt butter in a wide pan."
    },
    {
      "position": 4,
      "text": "Pan fry the meatballs in low to medium heat until the color of the meatball turns medium brown."
    },
    {
      "position": 5,
      "text": "Put-in the mixed vegetables. Sprinkle remaining salt and then cook for 5 to 7 minutes or until the liquid completely evaporates."
    },
    {
      "position": 6,
      "text": "Pour KFC Gravy over and transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 12,
