  "id": "88bfcf00-fda2-56d4-9df8-09f203e0a863",
  "slug": "pork-and-scallion-stir-fry-recipe",
  "name": "Pork and Scallion Stir Fry Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Pork and Scallion Stir Fry",
  "cuisine": "Asian Chinese Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork, soy sauce, ground black pepper, and cornstarch in a bowl. Mix well. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 3,
      "text": "Add the ginger once the oil gets hot. Stir fry for 20 seconds."
    },
    {
      "position": 4,
      "text": "Add the pork mixture. Continue to stir-fry for 5 to 7 minutes or until the pork turns medium brown."
    },
    {
      "position": 5,
      "text": "Stir-in the scallions. Cook for 3 minutes more."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve with a cup of rice."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 1,
  "cooking_time_minutes": 10,
