  "id": "17748b83-99d9-59e0-bed9-95f0afa74ae5",
  "slug": "pork-belly-asado",
  "name": "Pork Belly Asado",
  "recipe_type": "main",
  "brief_description": "Braised pork belly with soy sauce and star anise",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork belly, ketchup, soy sauce, and garlic. Mix well. Marinate overnight."
    },
    {
      "position": 2,
      "text": "Heat oil in a pot. Saute onion until it softens."
    },
    {
      "position": 3,
      "text": "Add marinated pork. Saute until it browns."
    },
    {
      "position": 4,
      "text": "Pour water into the pan. Let it boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork cube and star anise. Cover and continue cooking for 1 hour."
    },
    {
      "position": 6,
      "text": "Add brown sugar and butter. Stir."
    },
    {
      "position": 7,
      "text": "Make a slurry by combining cornstarch with \u00bc cup water. Mix well. Pour the mixture into the pot. Cook until the sauce thickens."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 9,
      "text": "Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
