  "id": "6f7c4258-2ab8-56af-937c-34f6e801e61b",
  "slug": "panlasang-pinoy-omelet",
  "name": "Panlasang Pinoy Omelet",
  "recipe_type": null,
  "brief_description": "Panlasang Pinoy Omelet is what I came-up with when I was craving for a great tasting omelet. This recipe is a product of all that's left in the fridge",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Crack the eggs and place in a bowl. Add some salt (a pinch to 1/4 teaspoon) and beat until the texture becomes smooth. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 3,
      "text": "Saute the yellow onion and tomato."
    },
    {
      "position": 4,
      "text": "Once the onion and tomato becomes soft. Add the bell pepper and scallions. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour-in the beaten egg. Spread the mixture over the pan. Cook in medium heat for 2 to 3 minutes or until the bottom part forms."
    },
    {
      "position": 6,
      "text": "Flip the omelet to cook the other side. Note: you can put the omelet on a plate with cooked part facing down. Gently flip and slide the omelet from the plate to the pan. The cooked part should be facing up now."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Top with shredded sharp cheddar cheese."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 5,
