  "id": "294c64c7-0e31-55b2-a37d-3ad644d19ca1",
  "slug": "lechon-sinigang",
  "name": "Lechon Sinigang",
  "recipe_type": null,
  "brief_description": "What if you can use lechon to cook other dishes? If you\u2019re curious about this, keep reading to learn how to make Lechon Sinigang!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot. Saut\u00e9 the garlic, onion, and tomato."
    },
    {
      "position": 2,
      "text": "Once the onion softens, add the lechon. Saut\u00e9 for 2 minutes."
    },
    {
      "position": 3,
      "text": "Pour the water into the cooking pot. Cover and let it boil."
    },
    {
      "position": 4,
      "text": "Add 2 sachets of Knorr Sinigang sa Sampaloc (original). Stir. Cover the pot and continue boiling (using the lowest heat setting of your stove) for 30 minutes."
    },
    {
      "position": 5,
      "text": "Add the daikon radish. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add the long green pepper, okra, string beans, and eggplant. Cover and continue cooking for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add the water spinach. Cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve hot with rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
