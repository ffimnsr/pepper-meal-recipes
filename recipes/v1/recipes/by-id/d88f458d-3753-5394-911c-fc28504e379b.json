  "id": "d88f458d-3753-5394-911c-fc28504e379b",
  "slug": "fried-fish-adobo",
  "name": "Fried Fish Adobo",
  "recipe_type": null,
  "brief_description": "Crispy Fried Fish Adobo is a simple fried fish dish made from fish adobo. Almost any kind of fish can be used, this recipe makes use of round scad.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Drain the liquid from the fish adobo."
    },
    {
      "position": 2,
      "text": "Heat a frying pan. Fry each side of the fish for 3 to 4 minutes or until the color turns golden brown and the texture starts to be crispy."
    },
    {
      "position": 3,
      "text": "Remove the fish from the pan, and place in a plate lined with paper towels to absorb the oil."
    },
    {
      "position": 4,
      "text": "Serve with warm rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
