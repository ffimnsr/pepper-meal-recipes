  "id": "e765cf73-bd52-5bb0-b158-49d9309548cb",
  "slug": "chicken-fried-rice-recipe",
  "name": "Chicken Fried Rice Recipe",
  "recipe_type": null,
  "brief_description": "Quick and easy chicken fried rice at home",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cut the chicken into small pieces. Arrange in a bowl and combine with the sauce ingredients. Mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the oil in a pan. Fry the beaten eggs until done. Remove the cooked eggs from the pan. Chop it into pieces, and then set it aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil (add more if needed), saute the garlic and onion."
    },
    {
      "position": 4,
      "text": "Add the marinated chicken once the onion softens. Stir-fry for 2 to 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the vegetables. Continue stir-frying for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the rice. Toss until all the ingredients are well blended. Continue cooking for 3 minutes."
    },
    {
      "position": 7,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve immediately."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
