  "id": "66dda783-cc64-500e-a96d-fd3206b39140",
  "slug": "easy-afritada",
  "name": "Easy Afritada",
  "recipe_type": null,
  "brief_description": "This Easy Pork Afritada recipe is another version of pork afritada. This will guide you on how to prepare your favorite afritada with ease and confidence",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a casserole or deep cooking pot."
    },
    {
      "position": 2,
      "text": "Saute garlic,onion, and tomato until soft."
    },
    {
      "position": 3,
      "text": "Add-in the pork. Cook for 2 to 3 minutes or until light brown."
    },
    {
      "position": 4,
      "text": "Pour-in broth and tomato sauce. Bring to a boil. Simmer for 40 to 60 minutes."
    },
    {
      "position": 5,
      "text": "Stir-in the potatoes. Cook for 8 minutes."
    },
    {
      "position": 6,
      "text": "Add the bell peppers and green peas. Stir and cook for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Sprinkle salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with warm rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
