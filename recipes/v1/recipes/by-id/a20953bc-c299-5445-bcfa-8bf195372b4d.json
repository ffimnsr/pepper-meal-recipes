  "id": "a20953bc-c299-5445-bcfa-8bf195372b4d",
  "slug": "nilasing-na-hipon",
  "name": "Nilasing na Hipon Recipe",
  "recipe_type": "appetizer",
  "brief_description": "This Nilasing na Hipon Recipe is transalated as Liquor Marinated Fried Shrimp. This is makes a good appetizer and main dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Marinade the shrimps in wine (or liquor) for 30 to 40 minutes"
    },
    {
      "position": 2,
      "text": "Place the flour, salt, and pepper in a clear plastic bag and mix well by shaking"
    },
    {
      "position": 3,
      "text": "Put the shrimps in the plastic bag and shake until all the shrimps are coated with flour"
    },
    {
      "position": 4,
      "text": "In a deep pot or pan, put-in the cooking oil and deep fry the shrimps until the shrimps floats"
    },
    {
      "position": 5,
      "text": "Remove from the pot and place in a plate with napkin or paper towel to absorb the excess oil"
    },
    {
      "position": 6,
      "text": "Serve hot with vinegar. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
