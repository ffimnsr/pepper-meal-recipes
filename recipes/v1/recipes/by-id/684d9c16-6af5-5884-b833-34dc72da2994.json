  "id": "684d9c16-6af5-5884-b833-34dc72da2994",
  "slug": "ginataang-manok-with-papaya",
  "name": "Ginataang Manok with Papaya",
  "recipe_type": "main",
  "brief_description": "Chicken and young papaya cooked in spicy coconut milk. This Filipino way of cooking is known as ginataan. It is best enjoyed with warm rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Pan-fry chicken for 1 1/2 minutes per side. Remove from the pot. Set aside."
    },
    {
      "position": 3,
      "text": "Saute onion, ginger, and garlic in the remaining oil until onion softens."
    },
    {
      "position": 4,
      "text": "Put- the pan-fried chicken into the pot. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour coconut milk into the pan. Let boil."
    },
    {
      "position": 6,
      "text": "Add chili pepper. Cover the pan and adjust heat between low to medium. Cook for 30 minutes or until the chicken becomes tender."
    },
    {
      "position": 7,
      "text": "Add papaya. Stir. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Put the spinach into the pot. Cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Season with patis and ground black pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
