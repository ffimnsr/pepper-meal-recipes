  "id": "346b7996-a3d8-5430-ae71-7bac140d5b85",
  "slug": "delicious-banana-nut-muffin-recipe",
  "name": "Banana Nut Muffin",
  "recipe_type": "dessert",
  "brief_description": "This is an easy recipe for banana muffin with nuts.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Combine all-purpose flour, baking soda, salt, and baking powder. Mix well. Set aside."
    },
    {
      "position": 3,
      "text": "Beat-in egg whites in a separate bowl. Gradually add the bananas, vegetable oil, sugar, lemon zest, and vanilla extract. Continue beating until all the ingredients are well distributed."
    },
    {
      "position": 4,
      "text": "Gradually fold-in the flour mixture, and then the walnuts. Mix well."
    },
    {
      "position": 5,
      "text": "Arrange muffin cups on a muffin tray. Scoop the mixture and arrange in each muffin cup. Make sure that you only fill about less than 3/4 of the cup's volume."
    },
    {
      "position": 6,
      "text": "Place in the oven and bake for 25 minutes, or until it passes the toothpick test."
    },
    {
      "position": 7,
      "text": "Remove from the oven and let cool by placing on a wire rack."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
