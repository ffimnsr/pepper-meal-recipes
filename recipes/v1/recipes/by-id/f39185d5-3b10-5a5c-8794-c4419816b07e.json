  "id": "f39185d5-3b10-5a5c-8794-c4419816b07e",
  "slug": "fried-grouper-steak",
  "name": "Fried Grouper Steak",
  "recipe_type": "main",
  "brief_description": "Fried lapu-lapu fish steak",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and pepper on the grouper steaks. Let it stand for 10 minutes."
    },
    {
      "position": 2,
      "text": "combine flour and cornstarch in a wide deep plate. Mix well."
    },
    {
      "position": 3,
      "text": "Lightly dust the grouper steak with the flour and cornstarch mixture. Make sure that both sides are coated."
    },
    {
      "position": 4,
      "text": "Heat the oil in a deep frying pan."
    },
    {
      "position": 5,
      "text": "Fry both sides of the grouper steak in medium heat for 6 to 8 minutes or until the color turns golden brown."
    },
    {
      "position": 6,
      "text": "Arrange the fried grouper steak in a plate line with paper towels. This will help absorb excess oil."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
