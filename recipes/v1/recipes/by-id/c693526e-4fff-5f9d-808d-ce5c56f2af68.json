  "id": "c693526e-4fff-5f9d-808d-ce5c56f2af68",
  "slug": "chicken-enchilada-casserole-recipe",
  "name": "Chicken Enchilada Casserole Recipe",
  "recipe_type": null,
  "brief_description": "Your meal can be more interesting when you have Chicken Enchilada Casserole. This recipe will show you how it\u2019s done in the simplest way possible.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350F."
    },
    {
      "position": 2,
      "text": "Combine the ground cumin with the shredded chicken. Mix well. Set aside."
    },
    {
      "position": 3,
      "text": "Meanwhile, scoop around 1/2 cup of enchilada sauce and pour in a baking dish. Spread the sauce all over the dish."
    },
    {
      "position": 4,
      "text": "Lay four pieces of flour tortilla over the enchilada sauce. Spread some refried beans and sour cream over the tortilla. Arrange half of the shredded chicken on top and then top with cheese and enchilada sauce."
    },
    {
      "position": 5,
      "text": "Make the next layer by arranging four pieces of flour tortilla on top of the enchilada sauce. Do the same step as in the first layer by spreading refried beans and sour cream over the tortillas. Top with the remaining chicken. Add cheese and enchilada sauce on top."
    },
    {
      "position": 6,
      "text": "Make the last layer by arranging the last 4 flour tortilla pieces over the enchilada sauce. Spread the remaining refried beans, sour cream, and enchilada sauce. Top with Monterey jack cheese."
    },
    {
      "position": 7,
      "text": "Bake the Chicken Enchilada Casserole for 35 to 40 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
