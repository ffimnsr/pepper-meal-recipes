  "id": "375d10a5-d233-514b-8336-2e11975ddaec",
  "slug": "rosemary-baked-chicken-recipe-vegetables",
  "name": "Rosemary Baked Chicken Recipe with Vegetables",
  "recipe_type": null,
  "brief_description": "Baked Chicken is probably the easiest and one of the healthiest ways to prepare chicken; all we need to do is rub the chicken with seasoning and place it in the oven to cook.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine rosemary, garlic powder, salt, pepper, and lemon juice, and olive oil in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Meanwhile, cook the vegetables according to your preference. You can steam the vegetables or stir-fry them using a little cooking oil. Sprinkle some salt and pepper and arrange in a plate. Set aside."
    },
    {
      "position": 3,
      "text": "Rub the mixture over the chicken breasts. Arrange the chicken breasts in a resealable bag and pour-in the remaining mixture. Marinate for 15 to 30 minutes."
    },
    {
      "position": 4,
      "text": "Preheat the oven to 375 degrees Fahrenheit."
    },
    {
      "position": 5,
      "text": "Arrange the marinated chicken breasts in a baking pan."
    },
    {
      "position": 6,
      "text": "Bake one side for 15 minutes. Turn the chicken breasts over and bake the other side for another 15 minutes or until internal temperature reads 160 degrees Fahrenheit (you will need to use a meat thermometer to get the internal temperature of meats)."
    },
    {
      "position": 7,
      "text": "Transfer the Baked Chicken on the plate where the vegetables are placed."
    },
    {
      "position": 8,
      "text": "Serve your baked chicken with vegetables. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
