  "id": "21349c28-30de-50b1-8cac-7971fef08de9",
  "slug": "how-to-cook-chicken-pastel",
  "name": "Chicken Pastel Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Filipino Chicken Pastel",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken, lemon juice, and soy sauce in a bowl. Mix well. Marinate for 15 minutes."
    },
    {
      "position": 2,
      "text": "Melt butter in a cooking pot. Once the butter start to bubble, add the marinated chicken. Include the marinade. Stir and cook for 2 minutes."
    },
    {
      "position": 3,
      "text": "Add chorizo de bilbao. Cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Pour water. Let boil. Add Knorr Chicken Cube. Stir and cook for 12 minutes."
    },
    {
      "position": 5,
      "text": "Add beef frank, carrot, potato, and mushroom. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour table cream. Stir until well blended. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Season with salt and pepper."
    },
    {
      "position": 8,
      "text": "Preheat oven to 375F."
    },
    {
      "position": 9,
      "text": "Transfer the chicken pastel to a baking pan or oven-proof container. Cover with pie dough. Poke holes on the dough for steam to escape."
    },
    {
      "position": 10,
      "text": "Bake for 25 minutes."
    },
    {
      "position": 11,
      "text": "Remove from the oven. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
