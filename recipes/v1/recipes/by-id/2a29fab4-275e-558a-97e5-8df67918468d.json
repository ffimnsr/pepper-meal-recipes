{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "2a29fab4-275e-558a-97e5-8df67918468d",
  "slug": "honey-garlic-pork-chops",
  "name": "Honey Garlic Pork Chops",
  "recipe_type": "main",
  "brief_description": "Crispy fried pork chops tossed in a buttery honey garlic glaze with a hint of chili. Served hot and perfect with sinangag or a cool cucumber salad.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make the brine by boiling 1/2 quart of water. Add salt, peppercorns, bay leaves, and sugar. Stir well, turn off the heat, then add ice cubes and the remaining water."
    },
    {
      "position": 2,
      "text": "Brine the pork chops for 35 minutes. Drain and pat dry with a paper towel."
    },
    {
      "position": 3,
      "text": "Season pork chops with paprika and garlic powder. Add the beaten egg and toss to coat. Dredge each chop in the cornstarch and flour mixture."
    },
    {
      "position": 4,
      "text": "Heat cooking oil in a pan. Fry the pork chops until both sides are golden brown and crispy. (Optional: Double fry for extra crispiness.)"
    },
    {
      "position": 5,
      "text": "For the glaze: Melt butter in a pan. Add garlic and saut\u00e9 until lightly browned."
    },
    {
      "position": 6,
      "text": "Add chili flakes and honey. Stir well."
    },
    {
      "position": 7,
      "text": "Pour in apple cider vinegar and water. Let boil and simmer until reduced by half."
    },
    {
      "position": 8,
      "text": "Season with onion powder, garlic powder, salt, and black pepper."
    },
    {
      "position": 9,
      "text": "Toss the fried pork chops in the glaze until fully coated. Transfer to a serving plate and enjoy with rice."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
  "difficulty": "medium",
