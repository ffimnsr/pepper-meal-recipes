  "slug": "ginataang-hipon-na-may-sitaw-at-kalabasa",
  "name": "Ginataang Hipon na may Sitaw at Kalabasa",
  "recipe_type": null,
  "brief_description": "This is a recipe Ginataang Hipon na may Sitaw at Kalabasa.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine coconut milk, garlic, onion, and ginger in a cooking pot. Apply heat. Let boil."
    },
    {
      "position": 2,
      "text": "Add Knorr Shrimp Cube. Stir. Cover and cook in medium heat for 15 minutes."
    },
    {
      "position": 3,
      "text": "Add kalabasa and long green pepper. Cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Add shrimp. Pour coconut cream into the pot. Stir and let it boil."
    },
    {
      "position": 5,
      "text": "Add snake beans (sitaw). Stir. Continue to cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Pour fish sauce into the pot and season with ground black pepper. Stir. Cook for 1 to 2 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
