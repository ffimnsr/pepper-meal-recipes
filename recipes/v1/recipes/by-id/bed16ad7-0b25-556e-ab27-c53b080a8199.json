  "id": "bed16ad7-0b25-556e-ab27-c53b080a8199",
  "slug": "buko-salad",
  "name": "Buko Salad Recipe",
  "recipe_type": "salad",
  "brief_description": "Buko Salad is a delicious Filipino Dessert Recipe. This is made from young coconut. Get the details here.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, combine young coconut, kaong, nata de coco, pineapple chunks, and fruit cocktail. Gently stir to distribute the ingredients."
    },
    {
      "position": 2,
      "text": "Add sweetened condensed milk and table cream. Mix until all the ingredients are properly distributed."
    },
    {
      "position": 3,
      "text": "Refrigerate for at least 4 hours or place in the freezer for 1 hour."
    },
    {
      "position": 4,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 5,
      "text": "Serve for dessert."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 20,
