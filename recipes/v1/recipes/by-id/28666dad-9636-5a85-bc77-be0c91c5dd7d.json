  "name": "Strawberry Greek Yogurt Smoothie",
  "recipe_type": "drink",
  "brief_description": "Strawberry greek yogurt smoothie is perfect to have any season of the year. In fact, I am having it today, which is winter time in Chicago.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the ingredients in a blender. Start with the ice then you can add the rest of the ingredients."
    },
    {
