      "text": "Blend until the texture of the mixture becomes smooth."
    },
    {
      "position": 3,
      "text": "Pour the Strawberry Greek Yogurt in a glass."
    },
    {
      "position": 4,
      "text": "Serve. Share and enjoy!"
    }
