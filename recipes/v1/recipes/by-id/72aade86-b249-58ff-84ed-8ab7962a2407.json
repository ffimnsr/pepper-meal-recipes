  "id": "72aade86-b249-58ff-84ed-8ab7962a2407",
  "slug": "biscoff-icebox-cake",
  "name": "Biscoff Icebox Cake",
  "recipe_type": "dessert",
  "brief_description": "This Biscoff Icebox Cake is a creamy, no-bake dessert with layers of Lotus Biscoff cookies and cookie butter cream. Only 4 ingredients needed \u2013 perfect for parties and make-ahead desserts.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Crush 6 Biscoff cookies into small pieces. Set aside for cream mixture and topping."
    },
    {
      "position": 2,
      "text": "Pour cold cream into a large mixing bowl. Whip with electric mixer until soft peaks form, about 4-5 minutes."
    },
    {
      "position": 3,
      "text": "Add 5 tablespoons Biscoff spread (warm 10 seconds in microwave first), all condensed milk, and 2/3 of crushed cookies. Mix until combined."
    },
    {
      "position": 4,
      "text": "In a 9x9 inch pan, arrange Biscoff cookies in a single layer. Spread cream mixture on top. Repeat layers, ending with cream on top."
    },
    {
      "position": 5,
      "text": "Cover and freeze for 2-3 hours until firm."
    },
    {
      "position": 6,
      "text": "Microwave remaining Biscoff spread for 30 seconds until pourable. Pour over frozen cake and spread to edges. Sprinkle remaining crushed cookies on top."
    },
    {
      "position": 7,
      "text": "Refrigerate for 1 hour until topping sets. Slice and serve cold."
    }
  ],
  "servings": 12,
