  "id": "3312c113-45fc-5a67-8943-43d62081d592",
  "slug": "adobong-baboy-sa-gata-pork-adobo-in-coconut-milk",
  "name": "Adobong Baboy sa Gata (Pork Adobo in Coconut Milk)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Adobong Baboy sa Gata.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork, soy sauce, vinegar, and crushed garlic. Mix well. Marinate the pork for 3 hours."
    },
    {
      "position": 2,
      "text": "Heat a cooking pot. Drain the liquid marinade from the pork and set it aside."
    },
    {
      "position": 3,
      "text": "Put the marinated pork into the cooking pot. Continue to cook until brown."
    },
    {
      "position": 4,
      "text": "Pour cooking oil. Cook for 1 minute until the garlic browns a bit."
    },
    {
      "position": 5,
      "text": "Pour the marinade and water. Let boil."
    },
    {
      "position": 6,
      "text": "Add whole peppercorn and dried bay leaves. Cover and continue to boil in medium heat until the pork becomes tender."
    },
    {
      "position": 7,
      "text": "Pour coconut cream. Stir. Cover and continue to cook for 10 minutes."
    },
    {
      "position": 8,
      "text": "Continue to boil until the coconut milk reduces to half."
    },
    {
      "position": 9,
      "text": "Add salt. Stir."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
