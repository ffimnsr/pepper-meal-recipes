  "slug": "chili-shrimp-recipe",
  "name": "Chili Shrimp Recipe",
  "recipe_type": null,
  "brief_description": "Chili Shrimp is a delicious shrimp dish that is best eaten with steamed white rice. This dish is very tasty, so expect to consume more rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and ginger"
    },
    {
      "position": 3,
      "text": "Put-in the shrimp. Stir and then cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the ketchup, hot sauce, chili sauce, and hoisin sauce. Stir. Cook for 2 to 4 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the fish sauce and some sesame oil."
    },
    {
      "position": 6,
      "text": "Add the leeks. Stir and then cook for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
