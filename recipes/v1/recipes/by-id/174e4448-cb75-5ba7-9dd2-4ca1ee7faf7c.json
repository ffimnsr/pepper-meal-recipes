  "id": "174e4448-cb75-5ba7-9dd2-4ca1ee7faf7c",
  "slug": "pineapple-fried-rice",
  "name": "Pineapple Fried Rice",
  "recipe_type": "side",
  "brief_description": "That is why I compiled more delicious components to create the ever vibrant, flavorful Pineapple Fried Rice!",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Beat the egg. Heat 2 tablespoons of cooking oil in a pan. Pour the beaten egg and fry until firm. Turn it over and do the same to the other side. Remove the egg and slice into smaller pieces."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Add pineapple tidbits. Saute for 1 minute."
    },
    {
      "position": 4,
      "text": "Add CDO Holiday Ham. Continue sauteing for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add bell pepper, cashew, and green peas. Stir."
    },
    {
      "position": 6,
      "text": "Add leftover rice. Toss and then stir fry for 1 minute."
    },
    {
      "position": 7,
      "text": "Pour soy sauce and add green onions."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper and then add sliced egg. Transfer the pineapple fried rice to a serving plate. Serve. Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
