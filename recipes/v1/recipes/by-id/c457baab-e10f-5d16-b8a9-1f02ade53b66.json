  "id": "c457baab-e10f-5d16-b8a9-1f02ade53b66",
  "slug": "bicol-express-ala-bebet",
  "name": "Bicol Express ala Bebet",
  "recipe_type": null,
  "brief_description": "This is the first episode of our Bisita Kusina series wherein Bebet Lainez shared his Bicol Express recipe.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a large cooking pot."
    },
    {
      "position": 2,
      "text": "Sear the pork. Continue to cook until it turns light brown and oil gets extracted. Set aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a cooking pot. Sauce garlic, onion, and ginger. Continue to cook until the onion becomes soft."
    },
    {
      "position": 4,
      "text": "Add the saut\u00e9ed pork. Stir. Continue to sauce for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Add the shrimp paste (bagoong alamang) stir. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add jalape\u00f1o pepper. Stir. Cook fo a minute."
    },
    {
      "position": 7,
      "text": "Pour-in coconut milk. Stir and let boil. Continue to cook between low to medium heat for 45 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
