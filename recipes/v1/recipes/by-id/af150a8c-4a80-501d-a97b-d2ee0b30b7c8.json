  "id": "af150a8c-4a80-501d-a97b-d2ee0b30b7c8",
  "slug": "special-tokwat-baboy",
  "name": "Special Tokwat Baboy",
  "recipe_type": "dessert",
  "brief_description": "Grilled pork belly with crispy fried tofu tossed in sweet and spicy vinegar sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a frying pan."
    },
    {
      "position": 2,
      "text": "Pat the tofu dry with paper towels. Fry both sides until the color turns golden brown.Let the temperature cool down and then slice each piece into smaller cubes. Set aside."
    },
    {
      "position": 3,
      "text": "Combine vinegar, soy sauce, sugar, salt, and ground black pepper in a bowl. Mix well. Microwave for 20 seconds."
    },
    {
      "position": 4,
      "text": "Combine pork belly and tofu in a large bowl.Add the onion and scallions. Toss."
    },
    {
      "position": 5,
      "text": "Pour-in the vinegar mixture. Toss once more."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
