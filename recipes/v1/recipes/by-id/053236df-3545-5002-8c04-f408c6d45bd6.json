  "id": "053236df-3545-5002-8c04-f408c6d45bd6",
  "slug": "fathers-day-chicken-macaroni-salad",
  "name": "Father's Day Chicken Macaroni Salad",
  "recipe_type": "salad",
  "brief_description": "Easy and delicious chicken macaroni salad for all occasions.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Cook macaroni based on package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Boil chicken in 3 cups of water for 30 minutes. Remove from the pot and let it cool down. Shred the chicken afterwards and set aside."
    },
    {
      "position": 3,
      "text": "Combine all the ingredients in a large bowl. Add Lady\u2019s Choice Real Mayonnaise and season with sugar, salt, and ground black pepper. Fold until all ingredients are well blended."
    },
    {
      "position": 4,
      "text": "Cover the bowl and refrigerate for at least 1 hour."
    },
    {
      "position": 5,
      "text": "Serve chilled. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 11,
  "preparation_time_minutes": 10,
