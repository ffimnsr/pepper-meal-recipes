  "id": "034f9a1e-c224-5418-94d6-281e84d6dc86",
  "slug": "how-to-cook-lumpiang-shanghai-lumpia-knr-pc",
  "name": "Lumpiang Shanghai Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Fiipino Lumpia or deep fried spring rolls.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine ground pork, carrot, onion, and parsley in a bowl. Mic well."
    },
    {
      "position": 2,
      "text": "Add egg, ground black pepper, salt, garlic, powder, and Sesame oil. Continue to mix until the ingredients are well blended."
    },
    {
      "position": 3,
      "text": "Crush the Knorr pork cube and add it into the mixture. Blend the ingredients altogether completely."
    },
    {
      "position": 4,
      "text": "Put 1 to 1 1/2 tablespoons of meat mixture over a piece of lumpia wrapper. Wrap and roll to secure the mixture. Continue this step until the mixture is completely consumed. Note: watch the video below to see how."
    },
    {
      "position": 5,
      "text": "Heat oil in a cooking pot in low to medium heat. Deep fry the lumpia until it turns golden brown. Remove from the pot and place in a plate lined with paper towel."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with sweet and sour sauce. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
