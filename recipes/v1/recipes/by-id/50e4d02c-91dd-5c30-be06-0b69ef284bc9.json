  "id": "50e4d02c-91dd-5c30-be06-0b69ef284bc9",
  "slug": "tuna-salad-over-crackers",
  "name": "Tuna Salad Over Crackers",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for Tuna Salad Over Crackers.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine tuna, onion, and celery in a bowl. Using a spoon, mix all the ingredients together."
    },
    {
      "position": 2,
      "text": "Add mayonnaise and mustard powder. Continue to mix. Taste the mixture and add salt and pepper as needed. Make sure that the ingredients are well blended."
    },
    {
      "position": 3,
      "text": "Refrigerate for at least 1 hour. Scoop a tablespoon of the mixture and top over crackers."
    },
    {
      "position": 4,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
