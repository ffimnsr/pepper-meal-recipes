  "id": "a7c1ebf0-1b39-578a-badd-8e21a2cb375f",
  "slug": "putok-batok-crispy-pata-slices",
  "name": "Putok Batok Crispy Pata Slices",
  "recipe_type": null,
  "brief_description": "This is a recipe for Putok Batok Crispy Pata Slices.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a pressure cooker. Let boil."
    },
    {
      "position": 2,
      "text": "Add pata slices, lemongrass (dahon ng tanglad), garlic, and whole peppercorn. Pressure cook for 20 to 25 minutes."
    },
    {
      "position": 3,
      "text": "Remove the tender pata from the pressure cooker. Place in a clean plate."
    },
    {
      "position": 4,
      "text": "Season with salt. Gently rub the salt all over the pata."
    },
    {
      "position": 5,
      "text": "Heat the oil in a deep fryer or a deep cooking pot. Deep fry the pata slices for 6 minutes."
    },
    {
      "position": 6,
      "text": "Let the pata cool down, and then deep fry for another 3 minutes."
    },
    {
      "position": 7,
      "text": "Remove from the fryer. Let the excess oil drip."
    },
    {
      "position": 8,
      "text": "Arrange in a serving plate and then prepare the crispy pata dipping sauce."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
