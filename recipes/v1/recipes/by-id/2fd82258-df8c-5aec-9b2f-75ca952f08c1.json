  "id": "2fd82258-df8c-5aec-9b2f-75ca952f08c1",
  "slug": "how-to-cook-humba-bisaya-version",
  "name": "Humba Recipe (Bisaya Version)",
  "recipe_type": "main",
  "brief_description": "Pork belly with black beans and banana blossoms stewed in soy sauce and lemon lime soda. This is a popular Filipino dish in the southern parts of the Philippines.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a wok or pan. Sear pork belly until it turns brown and enough oil gets extracted from the fat. Remove the pork from the wok. Set aside."
    },
    {
      "position": 2,
      "text": "Heat around 3 tablespoons of oil. Saut\u00e9 garlic and onion until the onion softens."
    },
    {
      "position": 3,
      "text": "Add the pork back into the wok and pour-in soy sauce. Saut\u00e9 for 1 minute."
    },
    {
      "position": 4,
      "text": "Add vinegar. Continue saut\u00e9ing until liquid dries-up."
    },
    {
      "position": 5,
      "text": "Pour clear soft drinks into the wok. Cover and let boil."
    },
    {
      "position": 6,
      "text": "Add crushed peppercorn. Adjust heat to low. Continue boiling for 35 minutes."
    },
    {
      "position": 7,
      "text": "Add banana blossoms and salted black beans. Cover the wok and continue cooking until the pork gets tender. Note: you can add water if needed."
    },
    {
      "position": 8,
      "text": "Add brown sugar. Stir. Cook for 1 minute."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve with warm rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 10,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 15,
