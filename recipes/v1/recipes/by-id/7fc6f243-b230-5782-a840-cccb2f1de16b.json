  "schema_version": 1,
  "id": "7fc6f243-b230-5782-a840-cccb2f1de16b",
  "slug": "beef-kebab-recipe",
  "name": "Beef Kebab Recipe",
  "recipe_type": "main",
  "brief_description": "Tender beef cubes marinated in a savory blend of soy sauce, garlic, and sesame oil, skewered with colorful vegetables, and grilled until perfectly charred.",
  "cuisine": "Middle Eastern Turkish",
  "instructions": [
    {
      "position": 1,
      "text": "Make the beef tenderloin marinade by combining soy sauce, vinegar, ginger, garlic, sesame oil, olive oil, sugar, salt, and ground black pepper in a large bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Add the cubed beef tenderloin on the bowl with the beef tenderloin marinade. Gently toss to coat the beef. Let it stay for 1 hour."
    },
    {
      "position": 3,
      "text": "Using a metal or bamboo skewer, assemble the beef kebob by skewering the vegetables and marinated beef tenderloin."
    },
    {
      "position": 4,
      "text": "Heat-up the grill and start grilling the beef kebobs for 3 minutes per side. This will give you a medium beef that is juicy and tender in the inside. Add more time if you want your beef well done, but it will be less tender."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve with Saffron rice."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
