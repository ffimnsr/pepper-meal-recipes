  "id": "6dbd16fd-ffc8-5c4c-914a-b51959d08524",
  "slug": "shrimp-bisque-and-clubhouse-sandwich",
  "name": "Shrimp Bisque and Clubhouse Sandwich",
  "recipe_type": "soup",
  "brief_description": "Another cuisine collaboration that you should be taking notice of as well is the ever delicious Shrimp Bisque and Clubhouse sandwich.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the shrimp bisque by combining 800 ml water with 60 g of Knorr Shrimp Bisque in a cooking pot. Mix well."
    },
    {
      "position": 2,
      "text": "Cover the pot and heat it. Stir once bubbles start to form on the mixture. Stir until the mixture boils. Cook for 2 minutes or until the desired consistency is achieved. Transfer to a serving bowl. Top with heavy cream."
    },
    {
      "position": 3,
      "text": "Make the clubhouse sandwich by toasting the bread. Spread Lady\u2019s Choice Mayonnaise on one side of the first slice of bread. Top with ham, a slice of cheese, turkey deli, and lettuce. Spread the mayonnaise on both sides of the second slice of bread. Put it over the turkey and top with bacon, lettuce, tomato, and another slice of cheese. Finish by spreading mayonnaise on the third slice of bread and put it on top of the sandwich. Slice in half."
    },
    {
      "position": 4,
      "text": "Serve the shrimp bisque and clubhouse sandwich together. Enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 7,
  "rest_time_minutes": null,
