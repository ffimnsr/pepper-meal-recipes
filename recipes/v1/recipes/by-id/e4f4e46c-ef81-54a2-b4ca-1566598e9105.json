  "id": "e4f4e46c-ef81-54a2-b4ca-1566598e9105",
  "slug": "sinigang-na-hipon-sa-sampaloc",
  "name": "Sinigang na Hipon sa Sampaloc",
  "recipe_type": "soup",
  "brief_description": "Sinigang na Hipon sa Sampaloc or Filipino Shrimp Soup in tamarind broth is a quick and easy soup dish that you can prepare for lunch or dinner.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the tamarind. Cover and boil for 30 minutes. Add more water if needed."
    },
    {
      "position": 3,
      "text": "Separate the tamarind from the water. Make sure to squeeze the juice out of the tamarind for maximum flavor."
    },
    {
      "position": 4,
      "text": "Heat the cooking pot with the remaining water and tamarind extract. You can add more water if you think that the amount of remaining liquid is less than 5 cups. Let boil."
    },
    {
      "position": 5,
      "text": "Add the tomato and onion. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the daikon,okra, and shrimp. Cook for 3 to 8 minutes in medium heat."
    },
    {
      "position": 7,
      "text": "Add the spinach and fish sauce. Stir. Cover and turn the heat off."
    },
    {
      "position": 8,
      "text": "Sprinkle some ground black pepper to taste."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
