  "id": "c8ef2c8c-8b36-5b8e-b182-ec18d39f28bb",
  "slug": "beef-hinalang",
  "name": "Beef Hinalang Recipe",
  "recipe_type": "soup",
  "brief_description": "Spicy beef soup with Thai chili and green onion.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot. Saute onion, garlic, and ginger."
    },
    {
      "position": 2,
      "text": "Once onion softens, add beef. Saute until medium brown."
    },
    {
      "position": 3,
      "text": "Pour vinegar and soy sauce. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Beef Cube. Stir and then pour-in water. Let the water boil. Continue to boil in low to medium heat for 30 minutes of until the beef gets tender. Note: add more water if needed."
    },
    {
      "position": 5,
      "text": "Add Thai chili pepper and green onions. Season with ground black pepper. Cook for 2 minutes. Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
