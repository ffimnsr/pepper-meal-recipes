  "id": "2d6bcf8d-754f-599a-a21f-7e8c9bdd5e64",
  "slug": "ginisang-gulay",
  "name": "Ginisang Gulay",
  "recipe_type": null,
  "brief_description": "Sauteed tomato, bitter gourd, okra, squash, eggplant, and string beans",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the tomato when the onion gets soft. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add the calabaza squash. Stir and cook for another 2 minutes."
    },
    {
      "position": 5,
      "text": "Put the eggplant, okra, string beans, and bitter gourd in the pan. Stir fry for 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour the vegetable broth. Cover and cook for 5 to 7 minutes."
    },
    {
      "position": 7,
      "text": "Remove the cover. Add salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
