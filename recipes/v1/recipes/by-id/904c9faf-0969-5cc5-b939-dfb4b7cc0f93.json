  "id": "904c9faf-0969-5cc5-b939-dfb4b7cc0f93",
  "slug": "pork-steak-recip",
  "name": "Pork Steak",
  "recipe_type": "main",
  "brief_description": "This Filipino-style pork steak features tender pork chops marinated in soy sauce and calamansi, then pan-fried and simmered until fork-tender. The savory-tangy sauce pairs perfectly with steamed rice for a satisfying home-cooked meal.",
  "cuisine": "Asian Filipino Southeast Asian",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork chops, soy sauce, and lime juice in a large bowl or resealable bag. Marinate for at least 1 hour."
    },
    {
      "position": 2,
      "text": "Heat a pan and pour in cooking oil."
    },
    {
      "position": 3,
      "text": "Pan fry the marinated pork chops over medium heat for 3 minutes per side. Remove the pork chops and set aside."
    },
    {
      "position": 4,
      "text": "Using the remaining oil, saut\u00e9 the garlic until it starts to brown."
    },
    {
      "position": 5,
      "text": "Add half of the onions. Saut\u00e9 until the onion softens."
    },
    {
      "position": 6,
      "text": "Pour in the remaining marinade and water. Add back the pork chops and simmer for 45 minutes or until the pork is tender. Add water as needed."
    },
    {
      "position": 7,
      "text": "Add the sugar, salt, and pepper, then stir."
    },
    {
      "position": 8,
      "text": "Put in the remaining onions and cook for 3 minutes more."
    },
    {
      "position": 9,
      "text": "Turn off heat and transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve, share, and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 55,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 60,
