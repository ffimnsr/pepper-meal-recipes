  "id": "58e05d6d-35ad-5ed0-8413-f367e81f4b75",
  "slug": "seafood-bicol-express",
  "name": "Seafood Bicol Express",
  "recipe_type": null,
  "brief_description": "Seafood Bicol Express is a delicious Filipino dish featuring a medley of seafood cooked in a rich, creamy coconut milk sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the gets hot, saute garlic, onion and ginger."
    },
    {
      "position": 3,
      "text": "Pour the coconut milk into the pot. Let boil."
    },
    {
      "position": 4,
      "text": "Add chili pepper and shrimp paste. Stir. Cover and cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the squid, mussels, and shrimp.Stir until all the seafood gets coated with coconut milk. Continue to cook for 3 to 5 minutes while occasionally stirring."
    },
    {
      "position": 6,
      "text": "Add ground black pepper. Stir."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
