  "name": "Crab Dip Recipe",
  "recipe_type": null,
  "brief_description": "Crab Dip is a rich tasting dip recipe that you can serve with your favorite chips during any occasion like a super bowl party or hosting on game day",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the ingredient in an oven and microwave safe bowl."
    },
    {
      "position": 2,
      "text": "Microwave for 1 minute. Gently fold until all the ingredients are well distributed."
    },
    {
      "position": 3,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 4,
      "text": "Bake the mixture for 15 to 20 minutes or until the top turns light brown."
    },
    {
      "position": 5,
      "text": "Serve with your favorite chips or bread."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
