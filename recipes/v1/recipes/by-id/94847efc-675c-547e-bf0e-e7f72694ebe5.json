  "id": "94847efc-675c-547e-bf0e-e7f72694ebe5",
  "slug": "purple-yam-dessert-ube-halaya-recipe",
  "name": "Ube Halaya",
  "recipe_type": "dessert",
  "brief_description": "Ube Halaya is a dessert made from boiled and grated purple yam which is locally known in the Philippines as \u201cUbe\u201d.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then put-in the butter and let it melt."
    },
    {
      "position": 2,
      "text": "Add the condensed milk then stir well."
    },
    {
      "position": 3,
      "text": "Put-in the purple yam then continue stirring."
    },
    {
      "position": 4,
      "text": "Add the vanilla extract and stir occasionally until the texture of the mixture becomes really thick (about 15 to 20 minutes under low fire)"
    },
    {
      "position": 5,
      "text": "Transfer the mixture to a mold or any container and let the temperature cool down."
    },
    {
      "position": 6,
      "text": "Refrigerate for at least 2 hours then serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
