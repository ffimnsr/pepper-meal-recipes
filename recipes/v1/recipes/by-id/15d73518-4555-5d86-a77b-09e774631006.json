  "id": "15d73518-4555-5d86-a77b-09e774631006",
  "slug": "how-to-cook-paksiw-na-pata",
  "name": "Paksiw na Pata",
  "recipe_type": "main",
  "brief_description": "Pork hocks with banana blossoms stewed in soy sauce and vinegar.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil pork pata in 6 to 8 cups of water for 15 minutes. Remove the pork pata after boiling. Discard the water."
    },
    {
      "position": 2,
      "text": "Heat oil in a wok or cooking pot. Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Once the onion softens and the garlic starts to brown, add the boiled pork pata. Cook for 2 minutes while occasionally stirring."
    },
    {
      "position": 4,
      "text": "Add soy sauce and water. Let boil."
    },
    {
      "position": 5,
      "text": "Add whole peppercorn, laurel leaves, and Knorr Pork Cube. Cover and adjust the heat to the lowest setting. Cook for 45 minutes."
    },
    {
      "position": 6,
      "text": "Turn the pork over and pour the vinegar into the pot. Cover and continue cooking for 10 minutes."
    },
    {
      "position": 7,
      "text": "Add the banana blossoms. Adjust the heat to medium setting. Cook for 20 minutes."
    },
    {
      "position": 8,
      "text": "Add the brown sugar and season with salt. Serve with warm rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
