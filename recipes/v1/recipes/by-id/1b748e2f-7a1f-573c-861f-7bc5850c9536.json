  "slug": "kilawing-tuna-with-coconut-cream-filipino-fish-ceviche",
  "name": "Kilawing Tuna with Coconut Cream (Fish Ceviche)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Filipino Ceviche known as Kilawing Tuna with Coconut Cream",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the cubed tuna in a bowl."
    },
    {
      "position": 2,
      "text": "Add salt, ground black pepper, ginger, onion, chili peppers, and lime juice. Mix well. Refrigerate for at least one hour."
    },
    {
      "position": 3,
      "text": "Pour the coconut cream into the bowl. Stir until all ingredients are well blended."
    },
    {
      "position": 4,
      "text": "Serve chilled. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
