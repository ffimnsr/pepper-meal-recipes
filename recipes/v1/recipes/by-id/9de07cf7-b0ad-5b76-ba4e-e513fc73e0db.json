  "id": "9de07cf7-b0ad-5b76-ba4e-e513fc73e0db",
  "slug": "rice-cake-bibingka-recipe",
  "name": "Bibingka Recipe",
  "recipe_type": "dessert",
  "brief_description": "Bibingka is a type of rice cake native to the Philippines. This is traditionally made from galapong, coconut milk, margarine, and sugar.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 375 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Combine rice flour, baking powder, and salt then mix well. Set aside."
    },
    {
      "position": 3,
      "text": "Cream butter then gradually put-in sugar while whisking."
    },
    {
      "position": 4,
      "text": "Add the eggs then whisk until every ingredient is well incorporated."
    },
    {
      "position": 5,
      "text": "Gradually add the rice flour, salt, and baking powder mixture then continue mixing."
    },
    {
      "position": 6,
      "text": "Pour-in coconut milk and fresh milk then whisk some more for 1 to 2 minutes."
    },
    {
      "position": 7,
      "text": "Arrange the pre-cut banana leaf on a cake pan or baking pan."
    },
    {
      "position": 8,
      "text": "Pour the mixture on the pan."
    },
    {
      "position": 9,
      "text": "Bake for 15 minutes."
    },
    {
      "position": 10,
      "text": "Remove from the oven then top with sliced salted egg and grated cheese (do not turn the oven off)."
    },
    {
      "position": 11,
      "text": "Put back in the oven and bake for 15 to 20 minutes or until the color of the top turn medium brown."
    },
    {
      "position": 12,
      "text": "Remove from the oven and let cool."
    },
    {
      "position": 13,
      "text": "Brush with butter and top with grated coconut."
    },
    {
      "position": 14,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 35,
