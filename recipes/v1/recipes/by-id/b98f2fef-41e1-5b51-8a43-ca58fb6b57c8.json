  "id": "b98f2fef-41e1-5b51-8a43-ca58fb6b57c8",
  "slug": "special-goto-recipe",
  "name": "Special Goto Recipe",
  "recipe_type": null,
  "brief_description": "Special Goto is a type of rice porridge cooked with ox tripe and sometimes with pig intestine. It is served with toasted garlic on top along with calamansi",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil 6 cups of water in a deep cooking pot."
    },
    {
      "position": 2,
      "text": "Add the ox tripe, pig intestine, and 1 teaspoon salt. Boil for 2 to 3 hours or until soft. Add water as needed. Remove the tripe and intestine from the pot to cool down and then slice into bite sized pieces. Set aside."
    },
    {
      "position": 3,
      "text": "Heat the cooking oil in a deep cooking pot."
    },
    {
      "position": 4,
      "text": "Saute the onion, ginger, and garlic."
    },
    {
      "position": 5,
      "text": "Once the onion is soft, add the tripe and intestine. Cook for 2 to 3 minutes."
    },
    {
      "position": 6,
      "text": "Add the beef powder( or cube), turmeric powder, and garlic powder."
    },
    {
      "position": 7,
      "text": "Pour-in the water. Stir and let boil."
    },
    {
      "position": 8,
      "text": "Add the rice. Allow the water to boil once more and then adjust the heat between low to medium. Cook for 30 to 45 minutes or until the desired texture is achieved. Add water if needed and stir every 5 minutes or so to prevent the rice from sticking on the pan."
    },
    {
      "position": 9,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Add egg and top with green onions, toasted garlic, and crushed chicharon."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
