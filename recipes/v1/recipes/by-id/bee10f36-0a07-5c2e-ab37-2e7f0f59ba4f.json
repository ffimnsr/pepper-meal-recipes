{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "bee10f36-0a07-5c2e-ab37-2e7f0f59ba4f",
  "slug": "cheesy-onion-rings",
  "name": "Cheesy Onion Rings",
  "recipe_type": "appetizer",
  "brief_description": "Crispy onion rings stuffed with mozzarella cheese. This is best served with marinara sauce.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Pair two slices of onion rings. One piece should be larger than the other and there should be a space in between the rings when the smaller piece is placed inside the larger one."
    },
    {
      "position": 2,
      "text": "Slice the mozzarella cheese in such a way that it fits the space in between the rings. Put the sliced cheese in between the two pieces of onions and secure by inserting a toothpick. Perform this step on all pairs of onion rings that you have."
    },
    {
      "position": 3,
      "text": "Heat oil in a deep cooking pot."
    },
    {
      "position": 4,
      "text": "Combine all dry ingredient mixture in a bowl. Mix well. Dredge all onion rings onto the dry ingredient mixture. Place over a wire rack. Set aside."
    },
    {
      "position": 5,
      "text": "Combine milk and egg. Mix well. Pour the mixture into the bowl with the dry ingredients. Mix well until a better is formed."
    },
    {
      "position": 6,
      "text": "Dip the onion rings in the batter mixture. Put it back over the wire rack for the excess batter to drip."
    },
    {
      "position": 7,
      "text": "Coat with Panko breadcrumbs."
    },
    {
      "position": 8,
      "text": "Fry one side until it turns golden brown. Turn it over and do the same thing on the opposite side."
    },
    {
      "position": 9,
      "text": "Serve warm with marinara sauce. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 7,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
