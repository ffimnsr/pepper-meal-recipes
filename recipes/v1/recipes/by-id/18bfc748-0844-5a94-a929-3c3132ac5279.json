  "id": "18bfc748-0844-5a94-a929-3c3132ac5279",
  "slug": "cathedral-window-jelly-recipe",
  "name": "Cathedral Window Gelatin Recipe",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Cathedral Window Gelatin",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Het the pineapple juice in the microwave oven for 35 seconds."
    },
    {
      "position": 2,
      "text": "Pour in a mixing bowl. Add the colorless unflavored gelatin. Stir until the gelatin completely dilutes in the juice."
    },
    {
      "position": 3,
      "text": "Pour the whipping cream in the bowl and then add the condensed milk. Stir until well blended."
    },
    {
      "position": 4,
      "text": "Add the colored jelly cubes. Stir."
    },
    {
      "position": 5,
      "text": "Pour the mixture in a Jelly mold large enough to hold everything."
    },
    {
      "position": 6,
      "text": "Refrigerate for 4 hours."
    },
    {
      "position": 7,
      "text": "Transfer to a plate. Slice and serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
