  "id": "542f87dd-3388-51f4-8076-9384be2e7616",
  "slug": "teriyaki-salmon",
  "name": "Teriyaki Salmon Recipe",
  "recipe_type": "main",
  "brief_description": "Teriyaki Salmon is a healthy and easy salmon recipe that makes use of our quick and easy Teriyaki sauce recipe. This is simply delicious.",
  "cuisine": "Japanese",
  "instructions": [
    {
      "position": 1,
      "text": "Place the salmon fillet in a freezer bag and then pour-in 3/4 cup of teriyaki sauce. Seal the freezer bag and let the salmon marinate for 3 hours."
    },
    {
      "position": 2,
      "text": "Meanwhile, prepare the teriyaki glaze by heating the remaining Teriyaki sauce in a sauce pan and adding-in the cornstarch diluted in water. Stir and cook until the texture becomes thicker. Turn off the heat and let cool. Set aside."
    },
    {
      "position": 3,
      "text": "Preheat oven to 360 degrees Fahrenheit."
    },
    {
      "position": 4,
      "text": "Arrange the marinated salmon in a greased baking pan. Brush the top with the teriyaki glaze."
    },
    {
      "position": 5,
      "text": "Bake the salmon for 15 to 17 minutes."
    },
    {
      "position": 6,
      "text": "Brush the remaining glaze on top. Arrange each salmon fillet over brown rice."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 180,
  "difficulty": "medium",
