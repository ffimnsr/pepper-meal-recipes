  "id": "f3f93b05-3e0b-518d-bf42-ca8d7df461b5",
  "slug": "pineapple-and-soy-sauce-pork-pot-roast",
  "name": "Pineapple and Soy Sauce Pork Pot Roast",
  "recipe_type": null,
  "brief_description": "Pineapple and Soy Sauce Pork Pot Roast is a tangy pork recipe that can be compared to pork hamonado and pork asado. All of these are best served with rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a Dutch oven."
    },
    {
      "position": 2,
      "text": "Saute the onion until it becomes soft."
    },
    {
      "position": 3,
      "text": "Put-in the pork and cook until all the sides turns light brown (you will need to turn the pork until all sides are done)."
    },
    {
      "position": 4,
      "text": "put-in crushed pineapple, soy sauce, sugar, salt, pepper, rosemary, and water. Let boil and then simmer for 45 minutes."
    },
    {
      "position": 5,
      "text": "Preheat oven to 400 degrees Fahrenheit."
    },
    {
      "position": 6,
      "text": "Put the Dutch oven inside the oven and then roast for 35 to 40 minutes (you can add more water if the liquid is not enough)."
    },
    {
      "position": 7,
      "text": "Remove from the oven and then transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with rice. share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 80,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
