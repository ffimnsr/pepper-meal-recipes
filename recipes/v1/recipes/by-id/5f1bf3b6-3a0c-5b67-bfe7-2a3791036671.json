  "id": "5f1bf3b6-3a0c-5b67-bfe7-2a3791036671",
  "slug": "spring-rolls-recipe",
  "name": "Spring Rolls Recipe",
  "recipe_type": null,
  "brief_description": "This Spring Rolls or Lumpiang Shanghai recipe is an all-time favorite. Learn how to make this by following our tested procedure.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan and pour-in 1 tablespoon cooking oil."
    },
    {
      "position": 2,
      "text": "Put-in the ginger and cook for a few seconds."
    },
    {
      "position": 3,
      "text": "Add the onion. Cook until tender."
    },
    {
      "position": 4,
      "text": "Add the ground pork. Cook until the color turns medium brown (about 5 to 6 minutes)."
    },
    {
      "position": 5,
      "text": "Add carrots, sesame oil, salt, garlic powder, and ground black pepper. Stir and cook for 3 to 5 minutes. Turn off heat."
    },
    {
      "position": 6,
      "text": "Let the temperature cool down while allowing excess oil and liquid to drip."
    },
    {
      "position": 7,
      "text": "Scoop cooked mixture and arrange in spring roll wrappers. Note: See lumpiang shanghai video for more information."
    },
    {
      "position": 8,
      "text": "Heat cooking oil in a deep cooking pot. Deep fry the spring rolls in medium heat until the color turns light to medium brown."
    },
    {
      "position": 9,
      "text": "Remove from the cooking pot and place in a plate lined with paper towels (this will absorb excess oil)."
    },
    {
      "position": 10,
      "text": "Serve with your favorite dipping sauce. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
