  "id": "1158800a-f392-5d5b-9d1b-3481f349fdb9",
  "slug": "pinoy-style-fried-chicken",
  "name": "Pinoy Style Fried Chicken",
  "recipe_type": "main",
  "brief_description": "Pinoy Style Fried Chicken is one of our Filipino Fried Chicken versions. Pinoy fried chicken is known for its simplicity and delicious taste. This recipe is no exception; it is simple, delicious, and budget friendly.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine salt, ground black pepper, garlic powder, and onion powder in a large mixing bowl."
    },
    {
      "position": 2,
      "text": "Arrange the chicken slices in the same mixing bowl. Rub the salt mixture all over the chicken ensuring that each piece is well covered. Cover the bowl. Refrigerate for 3 to 5 hours."
    },
    {
      "position": 3,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 4,
      "text": "Meanwhile, put the flour in a resealable bag. Add 2 to 3 pieces of chicken in the bag. Seal and shake. Make sure that the chicken pieces are covered will flour."
    },
    {
      "position": 5,
      "text": "Once the oil gets hot, pan-fry the chicken in medium heat for 5 minutes. Turn the chicken over and fry the other side for 5 minutes."
    },
    {
      "position": 6,
      "text": "Turn the chicken over for the second time and fry both sides again for 4 minutes."
    },
    {
      "position": 7,
      "text": "Remove the chicken from the pan. Let the excess oil drip, then transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with banana ketchup and white rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
