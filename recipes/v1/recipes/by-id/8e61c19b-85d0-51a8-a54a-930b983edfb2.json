  "name": "Strawberry Mandarin and Spinach Salad in Balsamic Vinaigrette Dressing",
  "recipe_type": "salad",
  "brief_description": "Strawberry Mandarin Spinach Salad is a very simple salad recipe. It is quick and easy to prepare. The balsamic vinaigrette complements the salad.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the balsamic vinaigrette by combining olive oil, balsamic vinegar, garlic powder, dijon mustard, salt and pepper (as indicated above).Set aside."
    },
    {
      "position": 2,
      "text": "Combine Spinach, strawberries, and mandarin in a large bowl."
    },
    {
      "position": 3,
      "text": "Toss the ingredients and then add the walnuts."
    },
    {
      "position": 4,
      "text": "Pour-in the balsamic vinaigrette dressing."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
