  "id": "4d072ec4-4f5f-586d-835f-2a8d937d1ba1",
  "slug": "garlic-tokwa-and-kangkong-in-oyster-sauce",
  "name": "Garlic Tokwa and Kangkong in Oyster Sauce",
  "recipe_type": "main",
  "brief_description": "Tofu and water spinach in oyster sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Crush and chop the garlic. Put it on a small pan and then add \u00bd cup cooking oil. Turn on the heat and adjust it to medium setting. Once the oil starts to bubble, adjust the heat to the lowest setting. Continue cooking the garlic while stirring until it turns golden brown in color."
    },
    {
      "position": 2,
      "text": "Separate the garlic from the garlic oil using a kitchen sieve. Set aside."
    },
    {
      "position": 3,
      "text": "Heat the remaining 1 cup of oil on a deep small cooking pot. Add the garlic oil (leaving around 3 tablespoons for later). Fry the tofu until it turns golden brown. Remove the tofu from the pot and let it cool down before dicing it. Set aside."
    },
    {
      "position": 4,
      "text": "Combine all the sauce ingredients in a bowl. Stir until well blended. Set aside."
    },
    {
      "position": 5,
      "text": "Heat the remaining 3 tablespoons of garlic oil in a clean pan. Saut\u00e9 the onions until it softens."
    },
    {
      "position": 6,
      "text": "Add the fried tofu and continue to saute for 30 seconds."
    },
    {
      "position": 7,
      "text": "Add the chopped water spinach (kangkong). Saute for 1 minute."
    },
    {
      "position": 8,
      "text": "Pour the sauce mixture into the pot. Stir and cook until the sauce thickens."
    },
    {
      "position": 9,
      "text": "Add half of the browned garlic and season with salt and ground black pepper as needed."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Top with the remaining garlic. Serve with white rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
