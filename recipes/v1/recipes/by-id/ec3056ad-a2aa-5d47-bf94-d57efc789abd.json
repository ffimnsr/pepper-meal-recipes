  "slug": "sauteed-spinach-with-tofu",
  "name": "Sauteed Spinach with Tofu",
  "recipe_type": null,
  "brief_description": "Saut\u00e9ed Spinach with Tofu is a quick and simple spinach recipe that you can prepare for lunch or dinner. This light dish has a delectable Asian flavor",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pan- Fry the tofu using the vegetable oil until all the sides brown. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the olive oil in a pan."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the spinach until it becomes soft."
    },
    {
      "position": 4,
      "text": "Add-in olive oil, salt and pepper. Stir."
    },
    {
      "position": 5,
      "text": "Put-in fried tofu. Stir and cook for a minute more."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
