  "id": "794e4fe1-8271-50cf-988c-5a03366b1dd5",
  "slug": "tuyo-pasta",
  "name": "Tuyo Pasta",
  "recipe_type": null,
  "brief_description": "When I was still living in an apartment complex, I felt so deprived when it comes to cooking what I like most. You see, I am having issues in cooking fried tuyo, daing, and danggit. We all know that that these dishes taste so good for us Filipinos, but the aroma that it produces is somewhat annoying to other people \u2013 especially if you live in a shared building. Now, I can fry tuyo whenever I want.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the spaghetti noodles according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Drain the oil from the bottled tuyo. Chop or shred the tuyo into fine pieces."
    },
    {
      "position": 3,
      "text": "In a large mixing bowl, combine the cooked spaghetti noodles, shredded tuyo, and Parmesan cheese. Toss to mix well."
    },
    {
      "position": 4,
      "text": "Add garlic powder, dried basil, and ground black pepper. Toss some more until all the ingredients are well blended."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
