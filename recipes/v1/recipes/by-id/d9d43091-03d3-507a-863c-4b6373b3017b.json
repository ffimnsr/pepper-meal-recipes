  "slug": "filipino-beef-morcon-with-garlic-fried-rice-and-eggs",
  "name": "Morcon with Garlic Fried Rice and Eggs",
  "recipe_type": null,
  "brief_description": "This is a recipe for a meal known as Morcon with Garlic Fried Rice and Eggs. It can also be called Morcon Silog",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare your meal by slicing the leftover morcon. Note: you may also cook the morcon from scratch using the recipe above if there are no leftovers."
    },
    {
      "position": 2,
      "text": "Prepare the garlic fried rice. The link for the recipe can be found in the ingredient section above. Once the rice is cooked, set it aside."
    },
    {
      "position": 3,
      "text": "Fry the eggs based on how you want it. Sunny-side-up is a good way to cook it."
    },
    {
      "position": 4,
      "text": "Arrange a cup of garlic fried rice in the middle of a plate. Add 2 pieces of fried eggs on the side and arrange the beef morcon on the other side."
    },
    {
      "position": 5,
      "text": "Serve hot for breakfast. Share and enjoy!"
    }
  ],
  "servings": 3,
