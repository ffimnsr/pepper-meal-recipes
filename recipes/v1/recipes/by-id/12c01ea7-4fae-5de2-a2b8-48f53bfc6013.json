  "id": "12c01ea7-4fae-5de2-a2b8-48f53bfc6013",
  "slug": "adobo-fried-rice",
  "name": "Adobo Rice",
  "recipe_type": "main",
  "brief_description": "Adobo Rice is a Filipino fried rice made with leftover pork adobo, day-old white rice, toasted garlic, and oyster sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan over medium heat."
    },
    {
      "position": 2,
      "text": "Add the crushed garlic and cook until golden brown."
    },
    {
      "position": 3,
      "text": "Remove about three quarters of the garlic from the pan and set it aside on a small plate. This will be used as a topping later."
    },
    {
      "position": 4,
      "text": "Add the white parts of the green onions to the pan. Saute for 20 seconds."
    },
    {
      "position": 5,
      "text": "Add the leftover rice. Stir fry for 2 minutes while breaking up any clumps with the back of the spatula."
    },
    {
      "position": 6,
      "text": "Pour in the oyster sauce. Toss until the rice is evenly coated, then cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Add the chopped pork adobo. Stir fry for 2 to 3 minutes, or until the pork is heated through and the flavor mixes well with the rice."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper to taste."
    },
    {
      "position": 9,
      "text": "Add the green parts of the onions and the toasted garlic that was set aside. Toss one last time, then transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
