  "id": "23bb3fc8-3bdc-5e1d-b026-32f08b096fbf",
  "slug": "pinoy-pork-barbeque-inihaw-recipe",
  "name": "Pinoy Pork Barbeque",
  "recipe_type": "main",
  "brief_description": "Grilled marinated pork slices arranged in bamboo skewers. This is best eaten as a main dish with white rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place the pork in a large bowl. Add all the BBQ marinade ingredients. Mix well. Cover the bowl and place inside the refrigerator. Marinate for at least 3 hours. Note: marinating for a longer period of time is ideal for the meat to absorb the flavors from the marinade."
    },
    {
      "position": 2,
      "text": "Skewer the marinated pork in bamboo skewers."
    },
    {
      "position": 3,
      "text": "Prepare the basting sauce by combining all the basting sauce ingredients in a bowl. Mix well and set aside."
    },
    {
      "position": 4,
      "text": "Heat-up the grill. Grill the pork barbeque for 2 minutes. Baste the top part using a brush and then turn it over. Baste the top again. Continue to grill one side for 2 to 2 \u00bd minutes while basting every time its flipped until the BBQ is done."
    },
    {
      "position": 5,
      "text": "Arrange in a serving plate. Serve with rice on the side and a dipping sauce of spicy vinegar. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 60,
  "rest_time_minutes": null,
  "difficulty": "hard",
