  "slug": "homemade-pork-and-beans-recipe",
  "name": "Homemade Pork and Beans Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Homemade Pork and Beans.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Add onions. Cook until the onions gets soft and somewhat caramelized."
    },
    {
      "position": 3,
      "text": "Add bacon. Cook for 1 minutes."
    },
    {
      "position": 4,
      "text": "Pour the tomato sauce, vinegar, and liquid from the can of beans into the pot. Add mustard powder. Let boil. Stir and cover. Continue to cook in low heat for 30 to 35 minutes. Note: add water if the liquid starts to dry-up."
    },
    {
      "position": 5,
      "text": "Add the molasses, beans, and salt into the pot. Gently stir. Cover and cook for 8 to 10 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to serving bowl. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
