  "id": "157e2f35-5ada-52d3-86f0-b8c38edd36b5",
  "slug": "sirloin-tip-roast-recipe",
  "name": "Sirloin Tip Roast",
  "recipe_type": "main",
  "brief_description": "A tender and flavorful sirloin tip roast seasoned with aromatic herbs and spices. This classic roasted beef dish is perfect for Sunday dinners or special occasions, served with your favorite steak sauce or gravy.",
  "cuisine": "american",
  "instructions": [
    {
      "position": 1,
      "text": "Pat the sirloin tip roast dry using paper towels. Set aside."
    },
    {
      "position": 2,
      "text": "In a small bowl, combine dried thyme, dried rosemary, garlic powder, dried oregano, paprika, sea salt, and ground black pepper. Mix well."
    },
    {
      "position": 3,
      "text": "Rub the spice mixture evenly over all sides of the sirloin tip roast. Cover and refrigerate for at least 1 hour to allow the flavors to penetrate the meat."
    },
    {
      "position": 4,
      "text": "Preheat the oven to 325\u00b0F (163\u00b0C). Place the seasoned roast in a roasting pan. Roast for approximately 70 minutes, or until the internal temperature reaches your desired doneness. For roasts of different sizes, calculate 23 minutes per pound."
    },
    {
      "position": 5,
      "text": "Remove the roast from the oven and transfer to a cutting board. Tent loosely with aluminum foil and let rest for 15 minutes to allow juices to redistribute."
    },
    {
      "position": 6,
      "text": "Slice against the grain and serve with steak sauce, Worcestershire sauce, or gravy."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 15,
  "rest_time_minutes": 15,
  "difficulty": "medium",
