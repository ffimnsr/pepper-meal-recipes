  "id": "bc9a00d3-ff47-5094-9d9a-59f34b47d83e",
  "slug": "ginataang-gulay-recipe-knr-mm",
  "name": "Ginataang Gulay",
  "recipe_type": null,
  "brief_description": "This is a recipe for ginataang gulay. It is a Filipino dish composed of calabaza squash, snake beans, pork, and shrimp cooked in coconut milk.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a sauce pan. Add pork. Cover and cook between low to medium heat for 20 minutes."
    },
    {
      "position": 2,
      "text": "Remove the pork from the sauce pan. Set aside. Reserve the water."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan. Saute onion and garlic until it onion softens."
    },
    {
      "position": 4,
      "text": "Add boiled pork. Saute for 1 minute."
    },
    {
      "position": 5,
      "text": "Combine Knorr Ginataang Gulay Recipe Mix with the water used to boil pork. Stir and then pour the mixture into the pot. Let boil."
    },
    {
      "position": 6,
      "text": "Add kalabasa. Cover and cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add shrimp and sitaw. Cover and continue to cook for 5 to 7 minutes.&nbsp;"
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve. Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 5,
