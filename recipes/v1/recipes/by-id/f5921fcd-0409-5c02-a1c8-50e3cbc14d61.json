  "id": "f5921fcd-0409-5c02-a1c8-50e3cbc14d61",
  "slug": "adobong-okra-with-pork-recipe",
  "name": "Adobong Okra with Pork Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Adobong Okra with Pork",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Add the garlic. Cook in medium heat until the garlic turns medium brown."
    },
    {
      "position": 3,
      "text": "Add the pork belly pieces. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour the soy sauce and water. Cover. Cook the pork in low heat for 30 minutes or until the pork becomes tender. You can add more water if the liquid starts to dry out."
    },
    {
      "position": 5,
      "text": "Pour the vinegar. Let the liquid re-boil."
    },
    {
      "position": 6,
      "text": "Put the okra in the pan. Stir. Cover and cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add the sugar. Sprinkle some salt and pepper. Stir."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
