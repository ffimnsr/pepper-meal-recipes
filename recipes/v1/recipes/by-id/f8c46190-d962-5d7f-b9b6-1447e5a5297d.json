  "id": "f8c46190-d962-5d7f-b9b6-1447e5a5297d",
  "slug": "italian-sausage-pasta-recipe",
  "name": "Italian Sausage Pasta Recipe",
  "recipe_type": null,
  "brief_description": "I enjoyed eating this Italian Sausage Pasta. It is a tasty pasta dish that is not complicated to prepare. Being a fan of grilled sausage (with peppers and onion), I really liked the outcome of this pasta dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the spaghetti noodles according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Heat-up the grill and start grilling the Italian sausage in low heat. Grill the sausages until the inside is completely cooked (around 15 to 25 minutes)."
    },
    {
      "position": 3,
      "text": "Remove the sausage from the grill. Let it rest for 10 minutes. Slice the sausages diagonally."
    },
    {
      "position": 4,
      "text": "Make the marinara sauce by following this marinara sauce recipe. Once the sauce is ready, add the sliced sausage and continue to cook for 5 minutes. Add additional salt and pepper, if needed."
    },
    {
      "position": 5,
      "text": "Arrange the spaghetti noodles in a pasta bowl. Top with marinara sauce with Italian sausage."
    },
    {
      "position": 6,
      "text": "Sprinkle with chopped basil and Parmesan cheese on top."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
