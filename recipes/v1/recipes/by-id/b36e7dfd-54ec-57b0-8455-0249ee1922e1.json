  "id": "b36e7dfd-54ec-57b0-8455-0249ee1922e1",
  "slug": "creamy-chicken-pastel",
  "name": "Creamy Chicken Pastel",
  "recipe_type": "main",
  "brief_description": "Creamy chicken stew with potato, carrots, chorizo, and hotdogs.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken, soy sauce, and lime in a large bowl. Mix well. Marinate chicken for at least 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot. Saute onion and garlic."
    },
    {
      "position": 3,
      "text": "Once the onion softens, add the chorizo. Saute for 1 minute."
    },
    {
      "position": 4,
      "text": "Put chicken into the pot. Saute until the color turns light brown."
    },
    {
      "position": 5,
      "text": "Add water. Let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Chicken Cube. Stir. Cover and continue to cook for 20 minutes."
    },
    {
      "position": 7,
      "text": "Put the sliced hotdogs into the pot. Cook in medium heat until the liquid reduces to half."
    },
    {
      "position": 8,
      "text": "Add potato and carrot. Pour-in all-purpose cream. Cover and cook for 8 minutes."
    },
    {
      "position": 9,
      "text": "Stir-in the mushroom and bell peppers. Stir. Cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Season with ground black pepper and salt."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve with warm rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "hard",
