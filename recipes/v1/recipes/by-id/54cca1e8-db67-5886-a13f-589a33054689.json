  "id": "54cca1e8-db67-5886-a13f-589a33054689",
  "slug": "sayote-guisado-with-chicken-and-shrimp",
  "name": "Sayote Guisado with Chicken and Shrimp",
  "recipe_type": null,
  "brief_description": "Sayote Guisado with Chicken and Shrimp is another way of making ginisang sayote. This variation is cooked with chicken slices and shrimp",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the garlic and onion until the onion is soft."
    },
    {
      "position": 3,
      "text": "Add the chicken slices. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in 1 cup of chicken broth. Cover and let boil. Simmer for 15 minutes."
    },
    {
      "position": 5,
      "text": "At this point, the liquid should have been reduced to more than half. Put-in the chayote. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the shrimp. Cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Pour-in the remaining chicken broth. Let boil and cook for 1 to 2 minutes."
    },
    {
      "position": 8,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
