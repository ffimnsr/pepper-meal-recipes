  "slug": "pork-adobo-paksiw-recipe",
  "name": "Pork Adobo Paksiw Recipe",
  "recipe_type": null,
  "brief_description": "Pork Adobo Paksiw or at least this recipe is all about the transformation of your leftover pork adobo into something better. It is a hybrid of our delicious adobo dish and the yummy lechon paksiw.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the leftover pork adobo in a cooking pot."
    },
    {
      "position": 2,
      "text": "Add the lechon sauce, sugar, and water, stir, cover and cook in low heat for 20 minutes. Try to stir after every 5 minutes. You can add more water if the sauce is getting too thick."
    },
    {
      "position": 3,
      "text": "Transfer to a serving bowl and serve."
    },
    {
      "position": 4,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
