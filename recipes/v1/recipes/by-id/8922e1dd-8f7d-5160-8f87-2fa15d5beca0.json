  "id": "8922e1dd-8f7d-5160-8f87-2fa15d5beca0",
  "slug": "apple-glazed-pork-chop-recipe",
  "name": "Apple Glazed Pork Chop Recipe",
  "recipe_type": null,
  "brief_description": "Apple Glazed Pork Chop is a delicious dish that you can prepare during ordinary days. This recipe is so simple and is easy to follow.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Run salt and pepper on the pork chop. Let stand for 15 minutes."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 3,
      "text": "Pan Fry both sides of the pork chop until it turns brown. Remove excess oil."
    },
    {
      "position": 4,
      "text": "Pour-in the apple juice. Let boil."
    },
    {
      "position": 5,
      "text": "Add rosemary, oregano, thyme, and half of the brown sugar. Simmer for 15 minutes (add extra apple juice as necessary). Turn the heat off when the sauce reduces."
    },
    {
      "position": 6,
      "text": "Heat a separate skillet and then put in the butter."
    },
    {
      "position": 7,
      "text": "Add the onion, apples, and remaining sugar. Stir and then cook for about 5 minutes."
    },
    {
      "position": 8,
      "text": "Arrange the pork chop in a serving plate and then top with the apples and onion."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
