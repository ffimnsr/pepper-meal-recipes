  "id": "025d7546-4a60-5f9f-ab00-cd777dd1c95b",
  "slug": "asian-filipino-pinoy-food-pansit-molo-soup-recipe",
  "name": "Molo Soup",
  "recipe_type": "soup",
  "brief_description": "Molo Soup or Pancit Molo is a soup dish composed of a mixture of ground pork wrapped in wonton wrapper, shredded chicken meat, and shrimps. This dish resembles the Chinese wonton soup but the array of ingredients and flavor makes this dish stand out.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a casserole and bring to a boil."
    },
    {
      "position": 2,
      "text": "Put in the chicken and boil for 40 to 60 minutes or until tender."
    },
    {
      "position": 3,
      "text": "While waiting for the chicken to be tender, combine the ground pork, water chestnut, green onions, onions, egg, salt, and ground black pepper in a large mixing bowl then mix well until ingredients are well distributed."
    },
    {
      "position": 4,
      "text": "Get a piece of wonton wrapper and place on a clean flat surface."
    },
    {
      "position": 5,
      "text": "Scoop a tablespoon of the ground pork mixture and place in the middle of the wonton wrapper."
    },
    {
      "position": 6,
      "text": "Wrap the ground pork mixture with wonton wrapper (watch the video for more information). Slightly wet the borders of the wonton wrapper with water. Fold the wonton wrapper to secure the filling. The lower left end should meet the upper right end forming a triangle. Press the edges to make it intact and to avoid possibilities of opening. Slightly wet the three pointed sides of the wonton wrapper then fold each of them towards the middle (as if you are trying to connect the pointed end to an imaginary dot in the center of the wrapper)."
    },
    {
      "position": 7,
      "text": "Continue doing this procedure until all the ground pork mixture is wrapped."
    },
    {
      "position": 8,
      "text": "Remove the chicken from the boiling water and let it cool down. Set chicken stock (water used for boiling) aside."
    },
    {
      "position": 9,
      "text": "Once the chicken reaches room temperature, manually separate the meat from the bones then chop the separated meat to your desired size. Set aside."
    },
    {
      "position": 10,
      "text": "Heat a clean casserole then pour in the cooking oil."
    },
    {
      "position": 11,
      "text": "Saut\u00e9 the garlic and onions then add the chopped chicken and cook for 3 to 5 minutes."
    },
    {
      "position": 12,
      "text": "Add the fish sauce, annatto water (water from the soaked annatto seeds), and chicken stock then bring to a boil."
    },
    {
      "position": 13,
      "text": "Pour in additional water, then bring to a boil once more."
    },
    {
      "position": 14,
      "text": "Add the shrimps, then cook for a minute."
    },
    {
      "position": 15,
      "text": "Add the wrapped ground pork mixture and cook for 12 to 18 minutes (use low heat)."
    },
    {
      "position": 16,
      "text": "Put in some minced green onions and toasted garlic as desired."
    },
    {
      "position": 17,
      "text": "Transfer to a serving bowl and serve while hot. Share and enjoy!"
    }
  ],
  "servings": 12,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
