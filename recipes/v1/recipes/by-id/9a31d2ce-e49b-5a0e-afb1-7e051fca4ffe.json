  "id": "9a31d2ce-e49b-5a0e-afb1-7e051fca4ffe",
  "slug": "homemade-cured-ham-with-brown-sugar-honey-glaze",
  "name": "Homemade Cured Ham with Brown Sugar Honey Glaze",
  "recipe_type": null,
  "brief_description": "This is a recipe for Homemade Cured Ham with Brown Sugar Honey Glaze",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the following curing ingredients in a large deep container: sea salt, brown sugar, Prague powder, and dried bay leaves. Pour hot water. Stir."
    },
    {
      "position": 2,
      "text": "Add cold water and ice. Soak the fresh pork ham into the brine for 3 days. Make sure to keep it in a cool place such as inside the refrigerator."
    },
    {
      "position": 3,
      "text": "After 3 days, wash the cured ham with running water. Discard the brine and then fill the container with clean tap water. Soak the ham for 3 hours to reduce the saltiness."
    },
    {
      "position": 4,
      "text": "Preheat oven to 320F."
    },
    {
      "position": 5,
      "text": "Arrange the ham in a roasting rack. Cover with aluminum foil. Roast for 2 hours."
    },
    {
      "position": 6,
      "text": "Remove the foil and increase the oven heat to 400F. Continue to roast for 1 hour."
    },
    {
      "position": 7,
      "text": "Prepare the Brown Sugar Honey Glaze by coming all the glaze ingredients in a sauce pan. Heat the pan and stir the mixture until well blended. Continue to cook in low to medium heat until the mixture reduces to half."
    },
    {
      "position": 8,
      "text": "Remove ham from the oven. Brush Brown Sugar Honey Glaze all over it. Continue to roast for 10 minutes or until the ham turns brown."
    },
    {
      "position": 9,
      "text": "Remove from the oven. Let it cool down."
    },
    {
      "position": 10,
      "text": "Carve the ham. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
