  "id": "425c0b2e-9d2c-52e1-9a79-df5a268d236e",
  "slug": "spicy-pork-kaldereta",
  "name": "Spicy Pork Kaldereta Recipe",
  "recipe_type": null,
  "brief_description": "A rich and spicy Filipino pork stew featuring tender pork belly, vegetables, and the distinctive flavor of liver spread. Traditionally served as pulutan (appetizer) or with steamed rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Add pork belly. Cook until light brown."
    },
    {
      "position": 4,
      "text": "Pour diced tomato into the pot. Stir."
    },
    {
      "position": 5,
      "text": "Add chili pepper, soy sauce, and liver spread. Stir and continue to cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour beef broth. Cover the pot. Let boil. Simmer for 45 minutes."
    },
    {
      "position": 7,
      "text": "Add carrot, potato, bell pepper, and green pea. Cover the pot. Cook for 5 to 7 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt and pepper."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
