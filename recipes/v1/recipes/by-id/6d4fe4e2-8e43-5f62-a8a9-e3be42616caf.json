  "id": "6d4fe4e2-8e43-5f62-a8a9-e3be42616caf",
  "slug": "crispy-baked-chicken-wings",
  "name": "Crispy Baked Chicken Wings",
  "recipe_type": null,
  "brief_description": "This is a recipe for Crispy Baked Chicken Wings",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Separate the drumette, flat, and tip by cutting using a knife. Discard the tip, or set it aside (you can use this to make chicken stock in the future)."
    },
    {
      "position": 2,
      "text": "Rub salt, garlic powder, and ground cayenne pepper all over the chicken wings. Let it stay for 15 minutes."
    },
    {
      "position": 3,
      "text": "Preheat oven to 375F."
    },
    {
      "position": 4,
      "text": "Heat a frying pan. Pour oil into it. Once the oil becomes hot, pan-fry the chicken wings in medium heat for 3 minutes per side."
    },
    {
      "position": 5,
      "text": "Pour water into the pan. Cover. Make sure that the steam gets trapped inside. Continue to cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Arrange the chicken wings in a greased baking tray. Bake for 20 to 25 minutes, or until crispy."
    },
    {
      "position": 7,
      "text": "Remove from the oven. Let it cool down."
    },
    {
      "position": 8,
      "text": "Serve with your favorite dip. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 15,
