  "id": "86339d9c-4154-51e6-9e49-3ba4b38aa80c",
  "slug": "suman-sa-ibos-recipe",
  "name": "Suman sa Ibos Recipe",
  "recipe_type": "dessert",
  "brief_description": "Suman sa ibos is a simple kakanin recipe. This is pretty much the same as suman sa lihiya except that the later uses lye water",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make the buri container by swirling the buri leaves on a mold that is about 1 1/2 inches in width. Lock the cylindrical leaf container that you made to prevent the leaf from swirling back."
    },
    {
      "position": 2,
      "text": "Wash the rice and then place in a large bowl."
    },
    {
      "position": 3,
      "text": "Pour-in water. Let the rice absorb the water."
    },
    {
      "position": 4,
      "text": "Pour-in the coconut milk and then add the salt. Gently mix and let stand for 10 minutes."
    },
    {
      "position": 5,
      "text": "Scoop the mixture to the buri container and then seal. Set aside."
    },
    {
      "position": 6,
      "text": "Arrange the suman in a large cooking pot. Pour-in about a quart of water. Let boil."
    },
    {
      "position": 7,
      "text": "Adjust the heat to low-medium and let the suman cook for 60 to 90 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the cooking pot. Let the temperature cool down."
    },
    {
      "position": 9,
      "text": "Serve with ripe mangoes on the side. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
