  "id": "956afa9f-7640-570b-8223-e3ab2c1a2a4a",
  "slug": "egg-roll-recipe",
  "name": "Egg Roll",
  "recipe_type": "appetizer",
  "brief_description": "An Egg roll is composed of meat and shredded vegetables wrapped in a wheat-based wrapper and deep fried until crispy. This deliciously appetizer is a close relative of the spring roll.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat 1 tablespoon of cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute ginger and the ground pork. Cook until the pork turns light brown."
    },
    {
      "position": 3,
      "text": "Add garlic powder, stir, and cook for a minute. Turn off heat and set aside."
    },
    {
      "position": 4,
      "text": "In a large bowl, combine cabbage and carrots. Mix well and microwave for 5 minutes."
    },
    {
      "position": 5,
      "text": "Combine cooked pork and cabbage mixture. Add soy sauce and mix."
    },
    {
      "position": 6,
      "text": "Wrap the mixture using the egg roll wrappers. This is done by placing about a quarter cup of mixture on the middle of the wrapper. Fold the two corners and roll. Brush some beaten egg mixture on the last corner to seal the wrapper."
    },
    {
      "position": 7,
      "text": "Heat 3 cups of cooking oil in a wok or a deep pan."
    },
    {
      "position": 8,
      "text": "Deep fry the egg rolls in medium heat until the color turns golden brown."
    },
    {
      "position": 9,
      "text": "Remove from the fryer and let excess oil drip."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve with sweet and sour sauce."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 15,
