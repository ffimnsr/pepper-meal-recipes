  "id": "925fcd8b-df19-589e-946f-10e268540d6a",
  "slug": "champorado-with-tuyo-chocolate-porridge-with-salted-dried-fish",
  "name": "Champorado with Tuyo (Chocolate Porridge with Salted Dried Fish)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Champorado with Tuyo (Chocolate Porridge with Salted Dried Fish)",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour 4 cups water in a pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add the sugar and tablea. Stir and continue to boil until the cocoa tablea dilutes."
    },
    {
      "position": 3,
      "text": "Add a pinch of salt and gently pour the glutinous rice in the pot. Stir and let the liquid re-boil."
    },
    {
      "position": 4,
      "text": "Continue to cook in low heat until the rice gets soft (the consistency should be similar to a porridge). Make sure to stir the mixture every 2 to 3 minutes to prevent the rice from sticking on the pot. Add the extra cup cup of water (or more) if needed."
    },
    {
      "position": 5,
      "text": "Scoop some cooked champorado using a ladle and pour in a bowl. Serve with crispy fried tuyo fish and evaporated milk."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
