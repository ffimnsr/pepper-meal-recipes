  "slug": "how-to-make-basic-asian-dipping-sauce",
  "name": "Basic Asian Dipping Sauce",
  "recipe_type": null,
  "brief_description": "A savory, no-cook dipping sauce made with soy sauce, rice vinegar, and sesame oil. Perfect alongside fried or steamed dim sum.",
  "cuisine": "asian",
  "instructions": [
    {
      "position": 1,
      "text": "Combine soy sauce, vinegar, and sesame oil (also add chili, if desired) in a dipping bowl."
    },
    {
      "position": 2,
      "text": "Stir the mixture using a teaspoon."
    },
    {
      "position": 3,
      "text": "Serve alongside fried or steamed dim sum."
    },
    {
      "position": 4,
      "text": "Serve immediately."
    }
  ],
