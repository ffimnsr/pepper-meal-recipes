  "id": "28141db1-4069-55a8-90cf-ddd186fdfd21",
  "slug": "grilled-swiss-cheese-sandwich",
  "name": "Grilled Swiss Cheese Sandwich",
  "recipe_type": null,
  "brief_description": "This is a recipe for Grilled Swiss Cheese Sandwich",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a grill pan or skillet."
    },
    {
      "position": 2,
      "text": "Spread some butter on one side of the sliced bread. Place the buttered side directly on the skillet."
    },
    {
      "position": 3,
      "text": "Put one Swiss cheese slice over the bread."
    },
    {
      "position": 4,
      "text": "Butter the second sliced bread. Arrange the bread on top of the cheese (buttered side on top)."
    },
    {
      "position": 5,
      "text": "Flip the bread once the first side browns. Let the other side brown."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 5,
