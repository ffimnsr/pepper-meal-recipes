  "schema_version": 1,
  "id": "f0d267b8-7525-52aa-b999-86a00d331b16",
  "slug": "mongolian-beef",
  "name": "Mongolian Beef",
  "recipe_type": null,
  "brief_description": "Cooking Mongolian Beef is easier than what you might be expecting. sure, it looks delicious and complicated, I assure you that this tastes good, but it is very easy to prepare. If you are new to cooking or about to try your first dish, this Mongolian Beef Recipe is perfect for you.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Season the beef with 1/4 teaspoon salt and 1/8 teaspoon white pepper. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat the oil in a frying pan."
    },
    {
      "position": 3,
      "text": "Dust the beef in 2 teaspoon cornstarch. I do this by combining the beef and cornstarch in a resealable bag, seal the bag with some air inside, and shake the bag until the beef is coated."
    },
    {
      "position": 4,
      "text": "Pan-fry the beef in medium heat for 1 minute per side. Do this in batches so that the beef gets cooked properly and the pan does not get over crowded. Remove the pan-fried beef from the pan. Set aside."
    },
    {
      "position": 5,
      "text": "Combine soy sauce, sugar,1 teaspoon cornstarch, cooking wine, hoisin sauce, vinegar, Sriracha, sesame oil, and remaining salt and pepper in a bowl.Mix well and set aside."
    },
    {
      "position": 6,
      "text": "On the same pan with remaining oil, add the garlic and ginger. Stir and cook until the garlic turns light brown."
    },
    {
      "position": 7,
      "text": "Put-in the beef. Stir."
    },
    {
      "position": 8,
      "text": "Pour-in the soy sauce mixture. Quickly stir and cook until the sauce gets thick."
    },
    {
      "position": 9,
      "text": "Add the scallions. Cook for 1 minute."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 11,
      "text": "Serve with white rice. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
