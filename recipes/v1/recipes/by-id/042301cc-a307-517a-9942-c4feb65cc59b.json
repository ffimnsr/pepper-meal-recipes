  "id": "042301cc-a307-517a-9942-c4feb65cc59b",
  "slug": "kinamunggayang-manok-recipe",
  "name": "Kinamunggayang Manok Recipe",
  "recipe_type": "soup",
  "brief_description": "Kinamunggayang Manok is a Filipino Chicken Soup recipe that originated from the southernmost part of the Philippines. This dish originally makes use of native chicken, banana blossoms, and malunggay leaves. At first glance, it can be mistaken as Tinolang Manok, but there are a few differences.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Soak the banana blossom in brine (combine 2 cups water and 1 tablespoon salt) for at least 3 hours. Let the sap out by squeezing the banana blossom. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Saute the garlic and onion."
    },
    {
      "position": 4,
      "text": "Add-in the chicken pieces. Cook for 2 to 3 minutes or until the chicken turns light brown."
    },
    {
      "position": 5,
      "text": "Pour-in the chicken broth and 3 cups water. Let boil. Simmer covered for 30 to 40 minutes. Add water if necessary."
    },
    {
      "position": 6,
      "text": "Put-in the shredded banana blossom. Stir and cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add the malunggay leaves. Cook for a minute."
    },
    {
      "position": 8,
      "text": "Pour-in the fish sauce and add the ground black pepper."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve with white rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
