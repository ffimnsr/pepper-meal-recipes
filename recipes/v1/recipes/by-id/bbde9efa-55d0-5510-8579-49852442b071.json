  "id": "bbde9efa-55d0-5510-8579-49852442b071",
  "slug": "monte-cristo-sandwich",
  "name": "Monte Cristo",
  "recipe_type": null,
  "brief_description": "Fried Ham and Turkey Sandwich with Swiss Cheese.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Crack eggs on a wide bowl. Beat until smooth. Set aside."
    },
    {
      "position": 2,
      "text": "Spread mustard on one side of each sliced bread. Spread Lady's Choice Ham Spread over the mustard. Top one slice of bread with 2 slices of Swiss cheese and then alternately arrange 2 slices of ham and turkey over the cheese. Put 2 slices of cheese over the protein and then finish by topping with the second slice of bread."
    },
    {
      "position": 3,
      "text": "Dip one side of the sandwich in beaten egg for 40 to 50 seconds. Do the same for the other side."
    },
    {
      "position": 4,
      "text": "Melt butter in a pan. Put the sandwich in and continue cooking using between low to medium heat until golden brown. Flip the sandwich and continue to do the same procedure on the opposite side."
    },
    {
      "position": 5,
      "text": "Slice the Monte Cristo sandwich in half. Arrange in a serving plate. Serve. Share and enjoy!"
    }
  ],
