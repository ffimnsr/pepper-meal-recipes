  "slug": "tonkatsu-recipe",
  "name": "Tonkatsu Recipe",
  "recipe_type": null,
  "brief_description": "Tonkatsu is a popular Asian breaded pork chop recipe that is usually consumed for lunch. This dish is simple and quick to prepare.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub some salt and pepper on the pork chops. Let stand for 15 minutes."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a frying pan."
    },
    {
      "position": 3,
      "text": "Coat the pork chops with flour and then dip in the beaten egg mixture."
    },
    {
      "position": 4,
      "text": "Coat the pork chop with Panko bread crumbs. Make sure that all sides are completely coated."
    },
    {
      "position": 5,
      "text": "Fry one side of the Tonkatsu in low to medium heat until the color turns golden brown (about 6 to 9 minutes)and them flip to cook the other side."
    },
    {
      "position": 6,
      "text": "Arrange in a serving plate with shredded cabbage and Tonkatsu sauce."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
