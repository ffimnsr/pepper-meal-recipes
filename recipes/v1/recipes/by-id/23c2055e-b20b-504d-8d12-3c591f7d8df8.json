  "id": "23c2055e-b20b-504d-8d12-3c591f7d8df8",
  "slug": "lengua-estofado-recipe",
  "name": "Lengua Estofado",
  "recipe_type": "dessert",
  "brief_description": "Tender beef tongue braised in a sweet and tangy sauce of diced tomatoes, white wine, soy sauce, vinegar, and olives. This Filipino-Spanish stew is a holiday favorite best served over steamed white rice.",
  "cuisine": "Filipino Mediterranean Spanish",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a wide cooking pot over medium heat."
    },
    {
      "position": 2,
      "text": "Dredge the sliced lengua in flour and shake off the excess. Pan-fry for about 1 minute per side or until lightly browned. Remove from the pot and set aside."
    },
    {
      "position": 3,
      "text": "Using the same pot, saut\u00e9 the onion and garlic until the onion becomes soft and aromatic."
    },
    {
      "position": 4,
      "text": "Pour in the diced tomatoes and white wine. Stir and allow the mixture to simmer for 2 minutes."
    },
    {
      "position": 5,
      "text": "Return the pan-fried beef lengua to the pot."
    },
    {
      "position": 6,
      "text": "Stir in the soy sauce and water, then add the beef bouillon. Bring everything to a boil."
    },
    {
      "position": 7,
      "text": "Add the bay leaves. Cover the pot and cook over low heat until the sauce reduces to about half."
    },
    {
      "position": 8,
      "text": "Pour in the vinegar and allow the sauce to re-boil."
    },
    {
      "position": 9,
      "text": "Add the brown sugar, green olives, black olives, and mushrooms. Stir and cook for 5 to 8 minutes."
    },
    {
      "position": 10,
      "text": "Season with salt and ground black pepper to taste."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate and serve warm."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 75,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
