  "id": "cb3d55c9-b3b7-51d0-973b-2c8b97cb1087",
  "slug": "rotisserie-chicken-arroz-caldo-recipe",
  "name": "Rotisserie Chicken Arroz Caldo Recipe",
  "recipe_type": null,
  "brief_description": "Rotisserie Chicken Arroz Caldo Recipe is my my other version of arroz caldo in which I used cooked chicken, instead of the usual raw chopped chicken",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a large cooking pot."
    },
    {
      "position": 2,
      "text": "Saute the onion until the texture becomes soft."
    },
    {
      "position": 3,
      "text": "Add the ginger and garlic powder. Shake-in some ground black pepper. Continue cooking for 1 minute."
    },
    {
      "position": 4,
      "text": "Put-in the chicken and rice. Stir fry for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in chicken broth and water. Let boil."
    },
    {
      "position": 6,
      "text": "Adjust the heat between low and medium. Stir. Cover while stirring every 5 minutes. Continue to cook for the next 35 to 44 minutes. Add more water if needed."
    },
    {
      "position": 7,
      "text": "Add-in a pinch of saffron or safflower (kasubha). Shake-in some salt and pepper to taste. You can also use fish sauce as a replacement for salt. stir."
    },
    {
      "position": 8,
      "text": "Transfer to a bowl. Top with a slice of lemon and some chopped scallions."
    },
    {
      "position": 9,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 5,
