  "id": "0afa3da7-e74d-5f4c-90bd-c5e5b84a14c4",
  "slug": "chicken-parmesan-recipe",
  "name": "Chicken Parmesan Recipe",
  "recipe_type": null,
  "brief_description": "Try this delicious Chicken Parmesan Recipe and you will enjoy the results. Our cooking video will guide you through the process.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour-in 2 tablespoons of extra virgin olive oil."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onions until the texture of the onions becomes soft."
    },
    {
      "position": 3,
      "text": "Add-in carrots and cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add the whole peeled tomatoes and lightly mash it while cooking. Bring to a boil and simmer for 15 to 18 minutes"
    },
    {
      "position": 5,
      "text": "Heat a skillet or frying pan and pour-in 4 tablespoons of extra virgin olive oil."
    },
    {
      "position": 6,
      "text": "While waiting for the oil to reach the desired temperature, rub the salt and pepper on each chicken breasts."
    },
    {
      "position": 7,
      "text": "Dredge the chicken breasts in flour, dip in the beaten egg mixture, and roll over bread crumbs."
    },
    {
      "position": 8,
      "text": "Pan-fry the chicken breast in the pan with extra virgin olive oil until half done. Flip the chicken to cook the other side."
    },
    {
      "position": 9,
      "text": "Preheat the oven to 350 degrees Fahrenheit."
    },
    {
      "position": 10,
      "text": "Arrange the cooked chicken breasts on an oven safe plate then pour the sauce over each piece."
    },
    {
      "position": 11,
      "text": "Sprinkle parmesan cheese over each chicken (this should be on top of the sauce)."
    },
    {
      "position": 12,
      "text": "Top the parmesan cheese with mozzarella cheese and pour the remaining sauce on the plate."
    },
    {
      "position": 13,
      "text": "Place the plate with chicken in the oven and bake for 20 minutes."
    },
    {
      "position": 14,
      "text": "Remove from the oven and garnish with chopped parsley."
    },
    {
      "position": 15,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 50,
