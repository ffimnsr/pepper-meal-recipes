{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "a4e3573f-5d9c-5eca-8df5-206aef4c5c36",
  "slug": "lumpiang-gulay-vegetable-egg-roll-recipe",
  "name": "Lumpiang Gulay (Vegetable Egg Roll Recipe)",
  "recipe_type": "appetizer",
  "brief_description": "Lumpiang Gulay or Vegetable Egg Roll is a simple fried appetizer dish made from vegetables and fried tofu. These are wrapped in egg roll wrappers and then fried until crispy. This dish is known as vegetable spring rolls in Asia. I think that the concept of egg roll vs. spring roll has something to do with\u2026",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat 3 tablespoons of cooking oil. Once the oil gets hot, saute garlic and onion."
    },
    {
      "position": 2,
      "text": "When the onion gets soft, add tomato and tofu. Stir fry for 2 minutes."
    },
    {
      "position": 3,
      "text": "Put some salt and ground black pepper. Stir."
    },
    {
      "position": 4,
      "text": "Add the cabbage and then cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Stir-in the bean sprouts and cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Transfer the cooked vegetable in a plate. Drain the excess liquid."
    },
    {
      "position": 7,
      "text": "Once the vegetable cools-off, start to wrap it using the egg roll wrappers. Lay the wrapper flat on a big plate. Place around 2 to 2 1/2 tablespoon of vegetable on one end of the wrapper. Fold the opposite edges of the wrapper and then roll until the vegetables are secured. Seal the end of the wrapper by dipping your finger in water and run it over the end of the wrapper; gently press the wet loose end towards the egg roll."
    },
    {
      "position": 8,
      "text": "Heat the remaining cooking oil in a cooking pot. Once the oil gets hot, fry one side of the egg rolls in medium heat until the color of the wrapper turns golden brown. Flip the egg roll to cook the opposite side."
    },
    {
      "position": 9,
      "text": "Remove the egg rolls from the cooking pot and arrange in a plate lined with paper towel."
    },
    {
      "position": 10,
      "text": "Serve warm with spiced vinegar."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 10,
