  "id": "e0915e84-afac-53be-8a63-fa9fddd8643d",
  "slug": "filipino-food-sweet-potato-camote-kamote-que-recipe",
  "name": "Kamote Cue Recipe",
  "recipe_type": "dessert",
  "brief_description": "Kamote Cue is deep fried sweet potatoes with a coating of caramelized brown sugar. This is a common meryenda (mid-afternoon snack) in the Philippines and can mostly be seen peddled around the busy streets.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the pan and pour the cooking oil."
    },
    {
      "position": 2,
      "text": "Let the cooking oil heat-up then put-in the brown sugar."
    },
    {
      "position": 3,
      "text": "When the brown sugar floats, put-in the sweet potato and fry for 7 to 10 minutes. Flip the sweet potato once in a while to allow the sugar to stick."
    },
    {
      "position": 4,
      "text": "Remove the sweet potato from the pan one after the other. You could directly skewer the fried sweet potatoes once removed from the pan."
    },
    {
      "position": 5,
      "text": "Let it cool down for a few minutes then serve. Share and Enjoy."
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
