  "id": "9a69d95e-e2db-5249-ac2c-11af854c65c4",
  "slug": "escabeche",
  "name": "Fish Escabeche Recipe",
  "recipe_type": "dessert",
  "brief_description": "Fish Escabeche is a type of sweet and sour fish recipe. There are many version of Escabeche around. This version that we have here is probably the most simple of all. However, the taste will not be as simple as it seems because this recipe has all the good flavors in it.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a frying pan then fry both sides of the fish until a bit crispy. Set aside."
    },
    {
      "position": 2,
      "text": "Heat a clean pan and pour-in the vinegar. Let boil."
    },
    {
      "position": 3,
      "text": "Add sugar, whole peppercorn, and garlic. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Put-in the onion and red bell pepper. Stir and cook until the vegetables are tender."
    },
    {
      "position": 5,
      "text": "Sprinkle salt and then stir."
    },
    {
      "position": 6,
      "text": "Put-in the fried fish. Cook for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Turn-off heat and transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
