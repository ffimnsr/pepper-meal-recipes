  "id": "5ea777e8-4d8c-5812-98ec-6d0dba867737",
  "slug": "seafood-pancit-canton",
  "name": "Seafood Pancit Canton",
  "recipe_type": null,
  "brief_description": "This is a recipe for Seafood Pancit Canton",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the topping ingredients by heating oil in a wok."
    },
    {
      "position": 2,
      "text": "Add shrimp, squid, crab meat, and squid balls. Stir fry for 1 minute."
    },
    {
      "position": 3,
      "text": "Add mushrooms, carrots, and Napa cabbage. Continue to cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add oyster sauce, sesame oil, and chicken broth. Stir. Let boil."
    },
    {
      "position": 5,
      "text": "Pour the cornstarch and water mixture. Stir and continue to cook until desired thickess is achieved. Turn the heat off. Set aside."
    },
    {
      "position": 6,
      "text": "Prepare the noodles by heating oil in a clean pot or wok."
    },
    {
      "position": 7,
      "text": "Saute the onion until it gets soft."
    },
    {
      "position": 8,
      "text": "Add soy sauce and chicken broth. Let boil."
    },
    {
      "position": 9,
      "text": "Add the pancit canton (flour stick noodles). Cover the pot and continue to cook in medium heat for 3 minutes."
    },
    {
      "position": 10,
      "text": "Remove the cover.Stir. Add the topping with sauce into the pot. Toss and continue to cook in medium heat until the noodles absorbs the sauce."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 12,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
