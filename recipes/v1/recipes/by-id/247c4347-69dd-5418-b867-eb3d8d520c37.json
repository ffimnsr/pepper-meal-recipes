  "id": "247c4347-69dd-5418-b867-eb3d8d520c37",
  "slug": "chicken-mami-recipe",
  "name": "Chicken Mami Recipe",
  "recipe_type": "soup",
  "brief_description": "Filipino Chicken Noodles Soup",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken breast, onion and 2 quarts water. Let the water boil."
    },
    {
      "position": 2,
      "text": "Add Knorr Chicken Cube. Continue to boil for 40 minutes between low to medium heat."
    },
    {
      "position": 3,
      "text": "While the chicken is cooking, prepare the toasted garlic. Combine crushed garlic and cooking oil in a small pan or pot. Turn the heat on and cook slowly while stirring until garlic browns. Filter the garlic using a kitchen sieve. Note: Save the oil to cook other dishes"
    },
    {
      "position": 4,
      "text": "Heat 1 quart water in a small pot. Let boil. Add fresh noodles. Cook for 1 minute. Discard water. Arrange noodles in serving bowls, including Napa cabbage, carrot, and egg."
    },
    {
      "position": 5,
      "text": "Once the chicken cooks completely, remove from the pot. Separate the meat from the bone and let it cool down. Slice the chicken into serving pieces."
    },
    {
      "position": 6,
      "text": "Arrange the noodles, vegetable, and chicken in a serving bowl. Pour hot broth and top with chopped green onions and toasted garlic. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
