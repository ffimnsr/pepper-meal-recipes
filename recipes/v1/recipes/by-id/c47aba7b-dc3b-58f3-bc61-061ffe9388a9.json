  "id": "c47aba7b-dc3b-58f3-bc61-061ffe9388a9",
  "slug": "hardinera",
  "name": "Hardinera (Jardinera) Recipe",
  "recipe_type": "side",
  "brief_description": "Hardinera is a famous meatloaf dish that originated in Quezon Province. This is considered as a special dish",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a cooking pot, add cooking oil and saut\u00e9 garlic and onions."
    },
    {
      "position": 2,
      "text": "Add the diced pork and cook for 3 to 5 minutes."
    },
    {
      "position": 3,
      "text": "Put-in the beef cube, water, and tomato sauce then bring to a boil. Simmer until the pork is tender and the liquid completely evaporates. Set aside and let cool."
    },
    {
      "position": 4,
      "text": "In a large mixing bowl, combine the cooked pork, salt, ground black pepper, beef franks, bread crumbs, liver spread, sweet pickle relish, pineapple chunks, raisins, and cheese."
    },
    {
      "position": 5,
      "text": "Mix all the ingredients until everything is well incorporated."
    },
    {
      "position": 6,
      "text": "Grease a llanera and arrange the sliced eggs and roasted sweet pepper."
    },
    {
      "position": 7,
      "text": "Pour close to half of the beaten egg mixture and ensure that the eggs are well distributed on the llanera."
    },
    {
      "position": 8,
      "text": "Scoop the pork mixture in to the llanera until it occupies at least 3/4 of the total volume."
    },
    {
      "position": 9,
      "text": "Cover the whole llanera with aluminum foil."
    },
    {
      "position": 10,
      "text": "Pour at least 6 cups of water in the steamer. Arrange the containers in the steamer and steam for 50 minutes."
    },
    {
      "position": 11,
      "text": "Remove the steamed mixture from the llanera and transfer to a serving plate."
    },
    {
      "position": 12,
      "text": "Serve either hot or cold. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
