  "id": "48e5adef-89d6-509e-add4-e81819cf38a6",
  "slug": "easy-pork-afritada",
  "name": "How to Cook Easy Pork Afritada",
  "recipe_type": "main",
  "brief_description": "Filipino pork stew recipe potato, carrots, and bell peppers.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Fry the pork belly until the color of the outer part turns light to medium brown. Remove the pork and place on a clean plate. Set aside."
    },
    {
      "position": 2,
      "text": "Put the hotdogs into the pot. Fry it for 1 minute. Remove and set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil, saut\u00e9 the garlic and onion."
    },
    {
      "position": 4,
      "text": "Add the pork back once the onion softens. Saut\u00e9 it for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour the tomato sauce into the cooking pot. Add water. Let the mixture boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Pork Cube and bay leaves. Cover the pot and simmer for 1 hour or until the pork tenderizes."
    },
    {
      "position": 7,
      "text": "Add the hotdogs, potato, and carrot. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Add the bell peppers and season with salt and ground black pepper. Cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Serve with white rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
