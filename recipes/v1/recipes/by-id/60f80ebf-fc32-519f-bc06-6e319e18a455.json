  "slug": "sinangag-na-kanin-recipe-how-to-make-garlic-fried-rice",
  "name": "Sinangag Recipe (Filipino Fried Rice)",
  "recipe_type": "breakfast",
  "brief_description": "Sinangag or Garlic Fried Rice has been a favorite part of every Filipino breakfast. This recipe shows how it can easily be cooked.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a wide pan."
    },
    {
      "position": 2,
      "text": "While the cooking oil is being heated, add the crushed garlic. Note: make sure that the oil is not hot when you add the garlic. Let the garlic slowly cook while the oil gets heated until it becomes golden brown and crisp."
    },
    {
      "position": 3,
      "text": "Sprinkle the salt over the rice. Toss until the salt gets distributed evenly."
    },
    {
      "position": 4,
      "text": "Gradually add the the rice into the pan. Stir to distribute the ingredients. Continue to stir fry for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve with your favorite dish."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
