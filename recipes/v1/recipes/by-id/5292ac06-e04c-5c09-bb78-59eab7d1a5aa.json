  "id": "5292ac06-e04c-5c09-bb78-59eab7d1a5aa",
  "slug": "easy-tuna-kilawin-recipe",
  "name": "Kilawin",
  "recipe_type": "appetizer",
  "brief_description": "Fresh, cubed ahi tuna marinated in citrus and spices.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine lemon juice, salt, garlic powder, ginger powder, and sugar. Mix well."
    },
    {
      "position": 2,
      "text": "Place the cubed ahi tuna in a large bowl. Pour-in the lemon mixture and gently toss until all the ingredients are well blended."
    },
    {
      "position": 3,
      "text": "Add the chopped chili and ground black pepper. Gently toss. Cover and place inside the fridge for at least 1 hour."
    },
    {
      "position": 4,
      "text": "Serve chilled. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 1,
