  "id": "c4aa982a-da6a-5082-9e80-7c6bf4efdf53",
  "slug": "slow-cooked-beef-lauya-soup-recipe",
  "name": "Slow Cooked Beef Lauya Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "Slow cooked beef lauya soup is tender and delicious beef soup composed of beef chuck, ginger, scallions, fish sauce, and onion.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the beef chuck, peppercorns, ginger, water, garlic powder, and onion in a slow cooker."
    },
    {
      "position": 2,
      "text": "Cover the slow cooker and start to slow cook in high for 8 to 10 hours."
    },
    {
      "position": 3,
      "text": "Put-in the scallions and fish sauce. Stir and continue to slow cook for 30 minutes."
    },
    {
      "position": 4,
      "text": "Transfer to a serving bowl. Serve with a small bowl of fish sauce and lemon along with some chili flakes."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 600,
