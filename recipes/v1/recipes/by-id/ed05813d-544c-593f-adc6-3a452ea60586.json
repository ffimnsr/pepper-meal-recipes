  "id": "ed05813d-544c-593f-adc6-3a452ea60586",
  "slug": "bok-choy-with-garlic-and-oyster-sauce",
  "name": "Bok Choy with Garlic and Oyster Sauce",
  "recipe_type": null,
  "brief_description": "This is a recipe for Bok Choy with Garlic and Oyster Sauce",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the oyster sauce, sugar, sesame oil, and water in a bowl. Stir. Set aside."
    },
    {
      "position": 2,
      "text": "Combine oil and garlic at the same time in a pan. Turn the heat to on. Cook the garlic in medium heat until it starts to turn light brown."
    },
    {
      "position": 3,
      "text": "Pour the oyster sauce mixture in the pan and sprinkle some ground black pepper. Stir. Let boil."
    },
    {
      "position": 4,
      "text": "Add the bok choy. Stir and cover. Cook until the sauce reduces to half. You may add some salt if needed."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve with rice."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 18,
