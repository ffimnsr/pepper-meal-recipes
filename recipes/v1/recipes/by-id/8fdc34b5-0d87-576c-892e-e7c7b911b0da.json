  "id": "8fdc34b5-0d87-576c-892e-e7c7b911b0da",
  "slug": "bacon-wrapped-sea-scallop",
  "name": "Bacon Wrapped Sea Scallop",
  "recipe_type": null,
  "brief_description": "This is a recipe for Bacon Wrapped Sea Scallop.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 375F"
    },
    {
      "position": 2,
      "text": "Place the scallops in a bowl. Add garlic powder and salt. Rub all over the scallops."
    },
    {
      "position": 3,
      "text": "Wrap 1 strip of bacon on the sides of a scallop. Secure by inserting a toothpick into the scallop. Do this step until all the scallops are wrapped with bacon."
    },
    {
      "position": 4,
      "text": "Arrange the bacon wrapped scallops on a baking tray. Bake for 15 to 18 minutes."
    },
    {
      "position": 5,
      "text": "Remove from the oven. Top each piece with a cube of butter."
    },
    {
      "position": 6,
      "text": "Arrange in a serving plate. Sprinkle minced parsley all over the scallops."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 10,
