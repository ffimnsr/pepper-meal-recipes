  "id": "01dee6ce-3e4d-5f77-b474-fcab56e6eabd",
  "slug": "longanisa-fried-rice-and-ginisang-corned-beef-with-kalabasa",
  "name": "Longanisa Fried Rice and Ginisang Corned Beef with Kalabasa",
  "recipe_type": "breakfast",
  "brief_description": "Fried rice composed of sweet Filipino sausage, eggs, green peas, and carrots. The main dish is sauteed corned beef with onions and butternut squash. This meal is perfect for breakfast or brunch.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the longanisa fried rice by combining salt and leftover rice. Gently mix until well blended. Set aside."
    },
    {
      "position": 2,
      "text": "Crack eggs in a bowl. Beat until smooth. Heat oil in a pan. Pour the beaten egg mixture. Cook until done. Set aside."
    },
    {
      "position": 3,
      "text": "Remove the casing from the longanisa. Heat oil in a pan. Add the longanisa meat. Cook while separating the mixture into smaller pieces."
    },
    {
      "position": 4,
      "text": "Add salted rice. Stir-fry for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Slice the eggs into smaller pieces. Add into the pan. Stir-fry for 1 minute."
    },
    {
      "position": 6,
      "text": "Add carrots and green peas. Cook for 3 to 5 minutes. Season with ground black pepper. Tranfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Cook the corned beef by heating oil in a clean pan. Saute garlic and onion until onion softens."
    },
    {
      "position": 8,
      "text": "Add corned beef. Saute for 3 minutes."
    },
    {
      "position": 9,
      "text": "Add kalabasa. Stir. Pour water. Cover and cook for 5 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve with longanisa fried rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
