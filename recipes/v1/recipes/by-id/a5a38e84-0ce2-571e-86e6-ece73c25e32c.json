  "id": "a5a38e84-0ce2-571e-86e6-ece73c25e32c",
  "slug": "pata-pochero-recipe",
  "name": "Pata Pochero Recipe",
  "recipe_type": "soup",
  "brief_description": "Pata Pochero is a soup dish composed of cut pork legs or pork hocks, potatoes, ripe saba banana , Calabaza squash, and bok choy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the pata and cook for 3 to 5 minutes or until all sides are light to medium brown."
    },
    {
      "position": 4,
      "text": "Pour-in the fish sauce, tomato sauce, and water. Add the beef cube (or powder). Let boil."
    },
    {
      "position": 5,
      "text": "Cover and then simmer for 50 to 70 minutes."
    },
    {
      "position": 6,
      "text": "Add the potato, banana, and calabaza squash. Cook for 5 to 7 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the bok choy (or pechay) and then sprinkle some ground black pepper. Cover."
    },
    {
      "position": 8,
      "text": "Turn the heat off. Let the cover stay for 5 minutes until the residual heat cooks the bok choy."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
