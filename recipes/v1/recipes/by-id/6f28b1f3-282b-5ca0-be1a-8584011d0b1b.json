  "id": "6f28b1f3-282b-5ca0-be1a-8584011d0b1b",
  "slug": "sauteed-string-beans-with-chicken",
  "name": "Saut\u00e9ed String Beans with Chicken",
  "recipe_type": null,
  "brief_description": "Saut\u00e9ed String Beans with Chicken is another easy dinner recipe that we have for you. This recipe involves string beans, which are locally known in the Philippines as \u201csitaw\u201d. This dish resembles ginisang sitaw in some ways.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and onion"
    },
    {
      "position": 3,
      "text": "Add the chicken slices. Cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the soy sauce, oyster sauce, and water. Stir and then cover the pan. Simmer until the water nearly evaporates."
    },
    {
      "position": 5,
      "text": "Increase the heat to high and then add the string beans. Cook while stirring for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Top with French fried onion."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
