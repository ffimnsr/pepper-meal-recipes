  "id": "2cadb9d6-b54e-5bba-90b3-399097878704",
  "slug": "chimichurri-steak-bites",
  "name": "Chimichurri Steak Bites",
  "recipe_type": "appetizer",
  "brief_description": "Seared rib eye cubes seasoned and topped with a fresh hand-chopped chimichurri sauce made from parsley, garlic, red wine vinegar, and Thai chili. Served over creamy garlic mashed potatoes with cream cheese.",
  "cuisine": "American Argentinian Spanish",
  "instructions": [
    {
      "position": 1,
      "text": "Season the steak. Combine the rib eye cubes with the Maggi Magic Sarap, paprika, ground black pepper, garlic powder, and olive oil in a bowl. Mix well until every piece is evenly coated. Set aside."
    },
    {
      "position": 2,
      "text": "Make the chimichurri. Finely chop the parsley by hand. Do not use a food processor. It will bruise the herbs and change the texture."
    },
    {
      "position": 3,
      "text": "Mince the garlic and finely chop the Thai chili peppers. Remove the seeds if you want less heat. Put everything in a bowl."
    },
    {
      "position": 4,
      "text": "Add the dried oregano, red wine vinegar, salt, and black pepper to the bowl. Stir well."
    },
    {
      "position": 5,
      "text": "Pour in the extra virgin olive oil and mix until fully combined. The sauce should be loose and easy to spoon, not thick."
    },
    {
      "position": 6,
      "text": "Let the chimichurri sit at room temperature for at least 20 minutes. This allows the flavors to blend together. Set aside."
    },
    {
      "position": 7,
      "text": "While waiting, prepare the mashed potatoes. Cut the potatoes into evenly sized pieces and place them in a pot with the water, garlic cloves, and salt."
    },
    {
      "position": 8,
      "text": "Bring to a boil and cook until fork-tender, about 12 to 15 minutes."
    },
    {
      "position": 9,
      "text": "Drain the potatoes and transfer them to a mixing bowl."
    },
    {
      "position": 10,
      "text": "Combine the milk, butter, and cream cheese in a separate bowl. Microwave for 45 seconds and stir until smooth and fully melted."
    },
    {
      "position": 11,
      "text": "Mash the potatoes until smooth. Do not overwork them."
    },
    {
      "position": 12,
      "text": "Gradually mix in the milk mixture until creamy. Season with salt and ground black pepper. Set aside."
    },
    {
      "position": 13,
      "text": "Cook the steak. Heat a pan over high heat and add olive oil."
    },
    {
      "position": 14,
      "text": "Sear the cubed steak for 60 to 90 seconds per side. Do not overcrowd the pan. Work in batches if needed. Remove and let the steak rest for 5 minutes."
    },
    {
      "position": 15,
      "text": "Arrange the mashed potatoes on a serving plate. Top with the steak bites and spoon the chimichurri over. Serve and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 20,
  "rest_time_minutes": 20,
