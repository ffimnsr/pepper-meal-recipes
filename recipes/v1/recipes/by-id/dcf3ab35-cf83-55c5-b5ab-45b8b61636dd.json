{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "dcf3ab35-cf83-55c5-b5ab-45b8b61636dd",
  "slug": "sardines-fish-ball-with-sweet-and-sour-sauce",
  "name": "Sardines Fish Ball with Sweet and Sour Sauce",
  "recipe_type": "appetizer",
  "brief_description": "Canned sardines made into balls and then fried to perfection and served with a sweet and sour dipping sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Open the can of the sardines. Separate the fish from the sauce using a kitchen sieve."
    },
    {
      "position": 2,
      "text": "Prepare the sweet and sour sauce by heating the sauce in a saucepan. Add vinegar. Let the mixture boil. Stir and then add sugar. Thicken the sauce by mixing cornstarch and 3 tablespoons water. Pour the mixture into the pot. Stir and cook until the sauce thickens. Set aside."
    },
    {
      "position": 3,
      "text": "Start making the sardine balls by placing the fish (sardines) in a bowl. Mash it and then add the chopped pechay and crack a piece of egg into the bowl. Mix well."
    },
    {
      "position": 4,
      "text": "Add Knorr liquid seasoning and around 3 tablespoons of breadcrumbs. Continue mixing until all ingredients are well blended. Note: add more breadcrumbs if needed."
    },
    {
      "position": 5,
      "text": "Crack the remaining egg and place it in a clean bowl. Beat until smooth. Scoop around 2 tablespoons of sardine mixture and mold it into a sphere. Dip in beaten egg and then roll it over the remaining breadcrumbs."
    },
    {
      "position": 6,
      "text": "Heat oil in a small cooking pot. Deep-fry the sardine balls using low to medium heat until it turns golden brown."
    },
    {
      "position": 7,
      "text": "Remove from the pot and arrange in a serving plate. Serve with sweet and sour sauce. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
