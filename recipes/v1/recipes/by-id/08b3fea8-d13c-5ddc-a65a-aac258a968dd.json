  "slug": "corn-salsa-side-dish-recipe",
  "name": "Corn Salsa Recipe",
  "recipe_type": "side",
  "brief_description": "Corn salsa makes a good side dish for steaks and barbecue. This recipe is highly recommended. Try it today!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large mixing bowl, combine the corn kernels, tomatoes, garlic, onion, cilantro, and salt then mix thoroughly."
    },
    {
      "position": 2,
      "text": "Squeeze-in the lime juice and mix until the juice is well distributed."
    },
    {
      "position": 3,
      "text": "Let sit for 12 to 20 minutes to infuse the flavors."
    },
    {
      "position": 4,
      "text": "Serve as a side for Grilled Pork Belly (Inihaw na Liempo) or Oven Barbequed Spare Ribs"
    },
    {
      "position": 5,
      "text": "Share and Enjoy!"
    }
  ],
  "servings": 4,
