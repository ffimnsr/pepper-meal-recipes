  "id": "f2e608c1-f328-5d49-8e2a-deb1314773f7",
  "slug": "ube-biko-recipe",
  "name": "Ube Biko Recipe",
  "recipe_type": "dessert",
  "brief_description": "Ube Biko is a delicious Filipino kakanin that seems to be a crossover between the traditional Filipino biko and ube halaya.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine rice and water in a cooking pot. Cover the pot and turn on the heat ."
    },
    {
      "position": 2,
      "text": "Adjust the heat to a simmer once the water starts to boil. continue to cook the rice until the water is completely absorbed. Note: try to stir the rice once in a while to prevent it from sticking to the cooking pot."
    },
    {
      "position": 3,
      "text": "Meanwhile, pour the coconut milk in another cooking pot . Let boil."
    },
    {
      "position": 4,
      "text": "Gradually add the sugar while stirring. Put-in the ube powder and stir. Cook for 5 to 7 minutes in low to medium heat while stirring."
    },
    {
      "position": 5,
      "text": "Add salt and ube flavoring. Continue to cook for 3 minutes or until the texture becomes thick."
    },
    {
      "position": 6,
      "text": "Once the rice absorbs the water, combine the coconut milk mixture to the glutinous rice. Mix well and continue to cook while stirring until the rice is completely cooked and the desired texture is achieved."
    },
    {
      "position": 7,
      "text": "Transfer to a serving tray lined with banana leaves."
    },
    {
      "position": 8,
      "text": "Top with toasted grated coconut."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
