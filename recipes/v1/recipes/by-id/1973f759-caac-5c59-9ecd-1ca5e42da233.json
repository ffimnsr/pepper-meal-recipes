  "id": "1973f759-caac-5c59-9ecd-1ca5e42da233",
  "slug": "breakfast-reuben-sandwich",
  "name": "Breakfast Reuben Sandwich",
  "recipe_type": "breakfast",
  "brief_description": "Have a yummy delicious Reuben Sandwich for breakfast. It is like enjoying a Reuben Sandwich and Eggs Benedict at the same time.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Toast the bread slices in an oven or bread toaster."
    },
    {
      "position": 2,
      "text": "Spread some Hollandaise sauce over a toasted bread slice."
    },
    {
      "position": 3,
      "text": "Arrange the American cheese slices on each bread slice over the sauce."
    },
    {
      "position": 4,
      "text": "Start to put in the sliced corned beef on top of the cheese and top with sauerkraut."
    },
    {
      "position": 5,
      "text": "Add one fried egg on top. You can pour more Hollandaise sauce on top of the egg."
    },
    {
      "position": 6,
      "text": "Top the egg with another toasted bread slice."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 5,
