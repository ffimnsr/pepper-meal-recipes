  "id": "c737231d-10ad-5676-940d-3becbf131f69",
  "slug": "banana-fritter-recipe",
  "name": "Banana Fritter Recipe",
  "recipe_type": "breakfast",
  "brief_description": "Mashed bananas combined with flour and other ingredients to make a batter and then fried until golden brown. It is best when rolled in granulated white sugar after frying.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine flour, baking powder, salt, and 1/2 cup sugar. Mix well."
    },
    {
      "position": 2,
      "text": "Gradually add the mashed bananas while mixing."
    },
    {
      "position": 3,
      "text": "Add the egg, vanilla extract, and milk. Mix to incorporate all the ingredients."
    },
    {
      "position": 4,
      "text": "Heat half of the oil in a pan."
    },
    {
      "position": 5,
      "text": "When the oil becomes hot, scoop about 1/2 cup of the mixture and then pour in the pan (add the remaining oil in the next batches)."
    },
    {
      "position": 6,
      "text": "Fry both sides until the color turns golden brown."
    },
    {
      "position": 7,
      "text": "Sprinkle the remaining sugar on both sides."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
