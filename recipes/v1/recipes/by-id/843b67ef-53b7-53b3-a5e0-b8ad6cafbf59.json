  "id": "843b67ef-53b7-53b3-a5e0-b8ad6cafbf59",
  "slug": "braised-beef-recipe",
  "name": "Braised Beef",
  "recipe_type": null,
  "brief_description": "Slow cooked braised beef with red wine, beef stock, carrot, celery, and onion. This recipe will give you a tasty and very tender beef dish to enjoy",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour-in olive oil."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 onion until soft and add dried thyme then put-in beef and cook for 5 minutes."
    },
    {
      "position": 3,
      "text": "Pour-in red wine and bring to a boil."
    },
    {
      "position": 4,
      "text": "Pour-in the beef stock and simmer until the beef becomes tender. This can be done using the following methods:"
    },
    {
      "position": 5,
      "text": "Slow cook for 4 to 5 hours using a Crockpot; Cooking in low heat using stovetop or burner; note that 2 to 2 1/2 hours is the average time to tenderize the meat and try to add water as needed; If you don\u2019t have the time, you may pressure cook the meat for 40 minutes."
    },
    {
      "position": 6,
      "text": "Add the carrots and celery then cook until the vegetables are tender."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate then serve."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 10,
