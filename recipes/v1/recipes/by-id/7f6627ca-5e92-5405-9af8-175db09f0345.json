  "id": "7f6627ca-5e92-5405-9af8-175db09f0345",
  "slug": "tokwa-at-baboy-humba-pork-humba-with-tofu",
  "name": "Tokwa at Baboy Humba",
  "recipe_type": "drink",
  "brief_description": "Pork belly stewed in soy sauce, pineapple juice, and vinegar with salted black beans and fried tofu.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a wok or cooking pot. Add tofu. Deep fry until outer part turns golden brown and crisp. Remove from the wok. Set aside."
    },
    {
      "position": 2,
      "text": "Transfer 3 tablespoons cooking oil used to fry tofu on a clean pan. Heat and saute garlic until it starts to brown. Add onion. Continue sauteing until the later softens."
    },
    {
      "position": 3,
      "text": "Add pork. Cook until the outer part turns light brown."
    },
    {
      "position": 4,
      "text": "Pour soy sauce. Continue sauteing until liquid reduces to half."
    },
    {
      "position": 5,
      "text": "Add pineapple juice and vinegar. Cover and let boil."
    },
    {
      "position": 6,
      "text": "Stir and then add salted black beans. Cover once more. Continue cooking between low to medium heat for 35 minutes."
    },
    {
      "position": 7,
      "text": "Add water and brown sugar. Cook on a covered pan until pork gets very tender. Note: I usually cook it for 40 minutes in low heat."
    },
    {
      "position": 8,
      "text": "Add star anise. Cook for 5 minutes. Remove star anise from the wok."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper and then add fried tofu. Stir and cook for 2 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 85,
  "preparation_time_minutes": 5,
