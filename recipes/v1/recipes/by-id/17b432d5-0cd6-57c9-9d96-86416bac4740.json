  "id": "17b432d5-0cd6-57c9-9d96-86416bac4740",
  "slug": "truffle-mushroom-pasta",
  "name": "Truffle Mushroom Pasta",
  "recipe_type": "main",
  "brief_description": "Truffle pasta is often associated with sophistication and luxury because it can come at a pretty high price in restaurants.",
  "cuisine": "American Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the fettuccine based on package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Make the sauce by melting butter in a pan. Add the olive oil."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the mushrooms until soft."
    },
    {
      "position": 4,
      "text": "Combine Knorr Cream of mushroom and water. Mix well. Pour the mixture into the pan and add the rosemary. Cook for 10 minutes using the lowest heat setting."
    },
    {
      "position": 5,
      "text": "Pour the heavy cream and add truffle oil. Season with ground black pepper and parmesan cheese."
    },
    {
      "position": 6,
      "text": "Toss-in the fettuccine making sure that it completely gets coated with the sauce."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Sprinkle parsley and top with more parmesan."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
