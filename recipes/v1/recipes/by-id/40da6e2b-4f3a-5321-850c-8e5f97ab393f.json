  "id": "40da6e2b-4f3a-5321-850c-8e5f97ab393f",
  "slug": "how-to-make-pastry-dough-for-flaky-double-crust-pie",
  "name": "How to Make Pastry Dough for Flaky Double Crust Pie",
  "recipe_type": "dessert",
  "brief_description": "Flaky, buttery double crust pastry made from scratch \u2014 perfect for both sweet and savory pies.",
  "cuisine": "Filipino Western",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all-purpose flour, salt, and sugar in a mixing bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Add chilled unsalted butter to the dry mixture. Cut the butter into the flour using a pastry cutter or fork until the mixture looks coarse with small butter bits."
    },
    {
      "position": 3,
      "text": "Gradually add ice-cold water, one tablespoon at a time, mixing gently until the dough starts to come together."
    },
    {
      "position": 4,
      "text": "Form the dough into a ball and divide it into two equal parts. Flatten each into a disk, wrap in plastic wrap, and refrigerate for at least 30 minutes."
    },
    {
      "position": 5,
      "text": "Place one disk of dough on a floured surface and roll it into a 12-inch circle. Transfer it to a pie pan and press gently into the bottom and sides."
    },
    {
      "position": 6,
      "text": "Add your preferred pie filling. Roll out the second dough disk to cover the pie, trim excess, and crimp the edges to seal. Cut small slits on top for steam to escape."
    },
    {
      "position": 7,
      "text": "Refrigerate the assembled pie for 15 minutes before baking. Bake in a preheated oven at 375\u00b0F to 400\u00b0F until the crust is golden brown."
    }
  ],
  "servings": 1,
  "cooking_time_minutes": 40,
