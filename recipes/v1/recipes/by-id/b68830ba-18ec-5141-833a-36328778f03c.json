  "id": "b68830ba-18ec-5141-833a-36328778f03c",
  "slug": "sweet-and-sour-meatballs-recipe",
  "name": "Sweet and Sour Meatball Recipe",
  "recipe_type": "dessert",
  "brief_description": "One quick and easy dinner that you can make for your family is Sweet and Sour Meatballs. As the name suggests, this is a meatball dish with sweet and sour sauce.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large mixing bowl, combine ground pork, minced onion, salt, ground black pepper, egg, and bread crumbs. Mix thoroughly."
    },
    {
      "position": 2,
      "text": "Scoop about 1 to 2 tablespoons of mixture and form into a ball shaped figure. Set aside."
    },
    {
      "position": 3,
      "text": "Heat a frying pan then pour-in 6 tablespoons of cooking oil."
    },
    {
      "position": 4,
      "text": "When the oil is hot enough, pan-fry the ball-shaped mixture until the outer side turns brown."
    },
    {
      "position": 5,
      "text": "Once done, turn off the heat and transfer the fried meatballs on a serving plate or bowl. Set aside."
    },
    {
      "position": 6,
      "text": "Heat a separate cooking pot then pour-in remaining 2 tablespoons of oil."
    },
    {
      "position": 7,
      "text": "When the oil is hot enough, saut\u00e9 the garlic."
    },
    {
      "position": 8,
      "text": "Add the quartered onion, sliced carrot, and bell peppers then cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Add pineapple chunks and cook for 1 minute."
    },
    {
      "position": 10,
      "text": "Put-in the tomato ketchup, brown sugar, and vinegar then stir."
    },
    {
      "position": 11,
      "text": "Pour-in water and let boil."
    },
    {
      "position": 12,
      "text": "Add the cornstarch diluted in water and cook until desired thickness is reached."
    },
    {
      "position": 13,
      "text": "Turn off heat then ladle the sauce over the pan-fried meatballs."
    },
    {
      "position": 14,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "expert",
