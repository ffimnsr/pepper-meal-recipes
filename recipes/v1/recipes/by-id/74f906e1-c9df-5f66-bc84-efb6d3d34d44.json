  "id": "74f906e1-c9df-5f66-bc84-efb6d3d34d44",
  "slug": "dutch-oven-pork-stew-recipe",
  "name": "Dutch Oven Pork Stew Recipe",
  "recipe_type": null,
  "brief_description": "I enjoyed having this Dutch Oven Pork Stew for dinner. It is delicious and the meat is very tender. Another good thing about this stew dish is that I do not need to keep an eye on it while cooking.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven (conventional oven) to 350F."
    },
    {
      "position": 2,
      "text": "Heat a Dutch oven in a stovetop."
    },
    {
      "position": 3,
      "text": "Pour-in the cooking oil."
    },
    {
      "position": 4,
      "text": "Once the oil gets hot, saute the onion and garlic."
    },
    {
      "position": 5,
      "text": "Add the pork belly slices. Cook until the pork turns light brown. Turn-off the fire or heat from the stovetop."
    },
    {
      "position": 6,
      "text": "Pour the tomato sauce and beef broth in the Dutch oven. Add the peppers and peas. Cover and place inside the conventional oven. Let it stay inside the oven for 2 hours at 350F."
    },
    {
      "position": 7,
      "text": "Remove from the oven, add salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 140,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "expert",
