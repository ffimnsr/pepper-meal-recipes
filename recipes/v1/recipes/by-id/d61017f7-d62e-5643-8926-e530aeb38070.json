  "id": "d61017f7-d62e-5643-8926-e530aeb38070",
  "slug": "asian-beef-with-mushroom",
  "name": "Asian Beef with Mushroom",
  "recipe_type": "main",
  "brief_description": "Asian Beef with Mushroom is an easy beef stir fry dish that takes less than 3o minutes to prepare. This is best for those of you who want to enjoy good food even if there is a limited time to spare.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine soy sauce, ginger, garlic powder, ground black pepper, and sherry (or Chinese cooking wine) in a bowl. Mix well. Set aside"
    },
    {
      "position": 2,
      "text": "Meanwhile, heat the cooking oil in a wok or wide pan."
    },
    {
      "position": 3,
      "text": "Once the oil gets hot, slowly add the beef slices. Stir fry for 1 to 2 minutes until the beef turns brown."
    },
    {
      "position": 4,
      "text": "Add the onion. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Put-in the mushrooms and snow peas. continue to stir fry for 1 minute."
    },
    {
      "position": 6,
      "text": "Pour-in the soy sauce mixture. Stir. Make sure that all the ingredients are blended properly. Continue to cook for a minute."
    },
    {
      "position": 7,
      "text": "Pour-in the beef broth. Let boil. Add the cornstarch diluted in water. Stir. Cook until the sauce gets thick."
    },
    {
      "position": 8,
      "text": "Add salt if needed."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
