  "id": "b8318a10-1dfc-5f7c-9ebd-f916e00dd525",
  "slug": "ginataang-sapsap",
  "name": "Ginataang Sapsap",
  "recipe_type": "main",
  "brief_description": "Butterfish and spinach cooked in coconut milk.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine Knorr Ginataang Gulay mix with water. Mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in pan. Saute onion, garlic, and ginger. Continue saut\u00e9ing until onion softens."
    },
    {
      "position": 3,
      "text": "Pour ginataan mixture into pan. Add chili pepper. Let boil. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add butterfish. Cover the pan. Cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Pour vinegar and add long green chili pepper. Cover and cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add spinach. Stir. Cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with warm rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
