  "id": "15d8a2a0-7c96-5e64-9774-e46015a56b3e",
  "slug": "tortilla-espanola-potato-omelet-recipe",
  "name": "Tortilla Espanola",
  "recipe_type": "main",
  "brief_description": "A classic Spanish potato omelet made with tender potatoes and onions slow-cooked in olive oil, then bound with eggs and cooked until golden. Traditionally served as tapas, breakfast, or a light meal, hot or at room temperature.",
  "cuisine": "Spanish",
  "instructions": [
    {
      "position": 1,
      "text": "Mix potatoes and onion in a large bowl."
    },
    {
      "position": 2,
      "text": "Add 1 tablespoon salt then mix thoroughly until well distributed. Set aside."
    },
    {
      "position": 3,
      "text": "Heat a cooking pot and pour-in olive oil."
    },
    {
      "position": 4,
      "text": "When the oil is hot enough, fry the potatoes and onion using medium heat. This should take between 7 to 10 minutes. Do not brown the potatoes."
    },
    {
      "position": 5,
      "text": "Remove the potatoes from the cooking pot, turn off heat, and then drain excess oil. Let the fried potatoes cool for a few minutes."
    },
    {
      "position": 6,
      "text": "Combine the remaining salt with the eggs then beat."
    },
    {
      "position": 7,
      "text": "Add the cooked potato in the beaten egg mixture then stir to distribute."
    },
    {
      "position": 8,
      "text": "Heat an 8 to 10 inches non-stick pan and pour-in about 2 to 3 tablespoons of olive oil. You may utilize the olive oil used to fry the potatoes."
    },
    {
      "position": 9,
      "text": "When the oil is hot enough, pour-in the eggs and potato mixture. Cook for about 5 to 7 minutes in low to medium heat. Cooking time may vary, it is recommended to manually check the omelet to prevent burns."
    },
    {
      "position": 10,
      "text": "Flip the omelet by placing a wide plate on top of the pan and turn the pan over in a way that the plate catches the omelet."
    },
    {
      "position": 11,
      "text": "Place the pan back on the stove and gently push the omelet from the plate to the pan. Cook until the other side is done."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
