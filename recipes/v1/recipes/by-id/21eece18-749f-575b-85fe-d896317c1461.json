  "id": "21eece18-749f-575b-85fe-d896317c1461",
  "slug": "korean-fried-chicken",
  "name": "Korean Fried Chicken",
  "recipe_type": "appetizer",
  "brief_description": "Fried chicken recipe with a batter and sauce to coat, then double-fried.",
  "cuisine": "Korean",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken wings, 1 teaspoon minced ginger, and 8 grams of Maggi Magic Sarap in a large bowl. Mix well. Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, make the sauce by heating 1 1/2 tablespoons of cooking oil in a saucepan. Saute the onion, ginger, and garlic for 30 to 40 seconds. Add mirin, and soy sauce. Let boil and then add the honey, gochujang, hot sauce, and sesame oil. Stir and continue simmering until the mixture thickens. Set aside."
    },
    {
      "position": 3,
      "text": "Heat 3 1/2 cups of canola oil in a deep pan or wok."
    },
    {
      "position": 4,
      "text": "Combine all the batter ingredients in a large bowl. Stir until well blended."
    },
    {
      "position": 5,
      "text": "Dip the chicken wings into the batter. Note: let the excess batter drip."
    },
    {
      "position": 6,
      "text": "Fry the chicken wings by batch for 5 to 7 minutes. Remove from the pan and let it rest for 10 minutes."
    },
    {
      "position": 7,
      "text": "Put the fried chicken wings back into the pan. Deep fry for 5 to 6 minutes of until the color turns golden brown. Remove from the pan and let it cool down."
    },
    {
      "position": 8,
      "text": "Brush each piece of chicken wing with sauce."
    },
    {
      "position": 9,
      "text": "Arrange on a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 40,
