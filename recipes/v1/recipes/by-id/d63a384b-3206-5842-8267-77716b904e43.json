  "id": "d63a384b-3206-5842-8267-77716b904e43",
  "slug": "afritadang-baboy-recipe",
  "name": "Afritadang Baboy",
  "recipe_type": null,
  "brief_description": "This is a recipe for Afritadang Baboy or Pork Afritada",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Add pork. Saute until light brown."
    },
    {
      "position": 4,
      "text": "Pour tomato sauce and beef broth. Let boil."
    },
    {
      "position": 5,
      "text": "Add bay leaves. Cover and then cook in medium heat for 45 minutes or until the pork gets tender. Note: add more beef broth if needed."
    },
    {
      "position": 6,
      "text": "Add potato and carrots. Cook for 5 to 8 minutes."
    },
    {
      "position": 7,
      "text": "Add bell peppers. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper. Stir."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
