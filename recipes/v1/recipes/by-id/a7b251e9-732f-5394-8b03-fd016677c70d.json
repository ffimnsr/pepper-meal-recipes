  "id": "a7b251e9-732f-5394-8b03-fd016677c70d",
  "slug": "squid-ball-chop-suey-recipe",
  "name": "Squid Ball Chop Suey",
  "recipe_type": "main",
  "brief_description": "Stir fried vegetables with oyster sauce and squid balls. This deliciously healthy dish is perfect to make for dinner.&nbsp;",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Once the oil is hot, saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the chicken liver. Cook for 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Add the oyster sauce and chicken broth. Stir and let boil."
    },
    {
      "position": 5,
      "text": "Put-in the squid balls. Cover and simmer for 10 to 12 minutes."
    },
    {
      "position": 6,
      "text": "Increase the heat to medium. Sprinkle some ground black pepper. Stir."
    },
    {
      "position": 7,
      "text": "Add the carrots and cauliflower. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Add the snow peas and bell peppers. Toss."
    },
    {
      "position": 9,
      "text": "Put-in the cabbage. Cover and steam the vegetables for 3 to 5 minutes."
    },
    {
      "position": 10,
      "text": "Remove the cover. Gently stir the ingredients and add the quail eggs."
    },
    {
      "position": 11,
      "text": "Add salt to taste."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
