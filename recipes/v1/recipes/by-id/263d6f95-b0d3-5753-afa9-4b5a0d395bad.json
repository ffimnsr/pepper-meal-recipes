  "id": "263d6f95-b0d3-5753-afa9-4b5a0d395bad",
  "slug": "crispy-pork-binagoongan",
  "name": "Crispy Pork Binagoongan",
  "recipe_type": "main",
  "brief_description": "Crispy pork belly topped with binagoongan sauce. This dish is best served with rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Steam the pork belly for 35 minutes."
    },
    {
      "position": 2,
      "text": "Remove from the steamer and let it cool down. Rub salt all over the pork belly. Let it dry-up a bit by leaving in open air for at least 15 minutes."
    },
    {
      "position": 3,
      "text": "Arrange the pork belly in an air fryer or turbo broiler. Air-fry in 350F for 25 minutes."
    },
    {
      "position": 4,
      "text": "Place the crispy fried pork on a serving plate."
    },
    {
      "position": 5,
      "text": "Prepare the binagoongan sauce by sauteing garlic, onion, ginger, and tomato."
    },
    {
      "position": 6,
      "text": "Once the tomato and onion softens, add the bagoong alamang (shrimp paste). Saute for 1 minute."
    },
    {
      "position": 7,
      "text": "Add long green pepper and vinegar. Stir."
    },
    {
      "position": 8,
      "text": "Pour water. Let boil. Season with sugar and ground black pepper. Cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Pour binagoongan sauce over the crispy fried pork. Serve with warm rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
  "difficulty": "medium",
