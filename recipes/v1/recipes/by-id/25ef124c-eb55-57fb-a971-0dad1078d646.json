  "slug": "nutritious-ulam-idea",
  "name": "Nutritious Ulam Idea",
  "recipe_type": "side",
  "brief_description": "Easy vegetable side dish for fried diishes",
  "cuisine": "American Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a pan. Saute garlic and onion."
    },
    {
      "position": 2,
      "text": "Add carrot once the onion softens. Cook for 2 minutes."
    },
    {
      "position": 3,
      "text": "Add whole kernel corn and string beans. Cook for 2 mimutes."
    },
    {
      "position": 4,
      "text": "Combine Knorr Cream of Mushroom Soup and water. Stir. Pour the mixture into the pan. Stir and cook until the mixture thickens."
    },
    {
      "position": 5,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 6,
      "text": "Add the boiled quail eggs. Gently stir."
    },
    {
      "position": 7,
      "text": "Serve this with your fried main dish."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
