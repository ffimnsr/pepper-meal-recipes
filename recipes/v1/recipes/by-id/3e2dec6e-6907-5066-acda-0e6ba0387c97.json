  "id": "3e2dec6e-6907-5066-acda-0e6ba0387c97",
  "slug": "creamy-macaroni-soup-ala-jollibee",
  "name": "Creamy Macaroni Sopas",
  "recipe_type": "soup",
  "brief_description": "Creamy chicken noodle soup recipe",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onion. Once the onion softens, add the chicken. Cook until it turns light brown in color."
    },
    {
      "position": 3,
      "text": "Add ham. Saut\u00e9 for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour 3 cups of water into the pot. Let it boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Chicken Cube and elbow macaroni. Stir and cover the pot. Let the liquid re-boil."
    },
    {
      "position": 6,
      "text": "Adjust the heat to medium setting. Boil for 8 minutes."
    },
    {
      "position": 7,
      "text": "Combine Knorr Cream of Mushroom Soup with 2 cups of water. Stir until well blended. Pour the mixture into the cooking pot."
    },
    {
      "position": 8,
      "text": "Add carrots and corn. Cover the pot and continue cooking for 8 minutes."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper as needed."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve hot. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
