  "id": "149b3bfd-82fe-5251-8372-5ee74256627b",
  "slug": "pork-ribs-caldereta",
  "name": "Pork Ribs Caldereta",
  "recipe_type": null,
  "brief_description": "A caldereta (tomato-based stew) version using pork ribs",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Marinate pork ribs in soy sauce for 5 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a wok. Saut\u00e9 onion and garlic."
    },
    {
      "position": 3,
      "text": "Once the onion softens, add pork spareribs. Saute until the ribs turns light brown in color."
    },
    {
      "position": 4,
      "text": "Pour tomato sauce and beef broth. Stir and let boil."
    },
    {
      "position": 5,
      "text": "Add beef broth. Cover the pan and then cook for 1 hour or until the meat gets tender."
    },
    {
      "position": 6,
      "text": "Add liver spread and chili pepper. Stir."
    },
    {
      "position": 7,
      "text": "Add carrot and potato and more water, as needed. Cover and cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Stir-in bell peppers and green peas. Cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper and salt."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl and serve along with warm rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 78,
  "preparation_time_minutes": 15,
