  "id": "f407f0f6-f1ea-5353-99f2-1f83d6d68db2",
  "slug": "better-beef-nilaga",
  "name": "Better Beef Nilaga",
  "recipe_type": "soup",
  "brief_description": "Filipino boiled beef soup with bok choy and corn",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Grill the beef neck bones for 11/2 minutes per side. Remove from the grill and set it aside."
    },
    {
      "position": 2,
      "text": "Meanwhile, heat cooking oil and saut\u00e9 the garlic and onion."
    },
    {
      "position": 3,
      "text": "Once the onion softens, add the beef. Saut\u00e9 for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour water into the pot. Let it boil. Cover and continue cooking using low heat setting until the meat gets tender. Note: add more water as needed."
    },
    {
      "position": 5,
      "text": "Add Knorr Beef Cube and corn. Cover the pot. Cook for 8 minutes."
    },
    {
      "position": 6,
      "text": "Add potatoes. Cook for 6 minutes."
    },
    {
      "position": 7,
      "text": "Add the long green beans, cabbage, and bok choy. Continue cooking for 3 minutes."
    },
    {
      "position": 8,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
