  "id": "552cac51-8e59-5bfd-ba7a-51efb382b903",
  "slug": "basil-pork-recipe",
  "name": "Basil Pork Recipe",
  "recipe_type": "main",
  "brief_description": "Ground pork stir-fried with garlic, chili, and fresh basil in a savory blend of soy sauce and fish sauce. Served hot and fragrant, this dish is bold, aromatic, and best paired with steamed rice and a fried egg on top.",
  "cuisine": "Thai",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a wok. Once the oil gets hot, add the garlic and chili.Stir and cook until the garlic turns medium brown."
    },
    {
      "position": 2,
      "text": "Add the ground pork. Stir-fry for 2 to 5 minutes or until the pork turns light brown."
    },
    {
      "position": 3,
      "text": "Pour-in the soy sauce and fish sauce. Continue to stir-fry."
    },
    {
      "position": 4,
      "text": "Add the sugar, holy basil, and bell peppers. Stir-fry for 3 to 6 minutes."
    },
    {
      "position": 5,
      "text": "Arrange in a plate with rice and fried egg."
    },
    {
      "position": 6,
      "text": "Serve. share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
