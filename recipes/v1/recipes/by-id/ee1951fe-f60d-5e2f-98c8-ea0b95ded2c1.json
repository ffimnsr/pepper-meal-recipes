  "id": "ee1951fe-f60d-5e2f-98c8-ea0b95ded2c1",
  "slug": "beef-nachos-with-cheese-sauce-homemade",
  "name": "Easy Beef Nachos",
  "recipe_type": "appetizer",
  "brief_description": "Homemade nachos with cheese sauce. Easy version.",
  "cuisine": "Mexican",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the beef by heating oil in a pan. Add beef. Cook until it turns brown while constantly stirring. Add chili powder, cumin, garlic powder, onion powder, salt, and pepper. Stir until blended. Continue cooking for 2 minutes. Set aside."
    },
    {
      "position": 2,
      "text": "Make the cheese sauce by melting butter in a cooking pot. Add flour. Continuously stir for 3 minutes. Pour-in milk. Stir until the mixture smoothens. Add cheese. Cook while stirring until the cheese melts and the mixture becomes smooth."
    },
    {
      "position": 3,
      "text": "Assemble the beef nachos by placing the tortilla chips on a serving plate. Top with beef and cheese sauce."
    },
    {
      "position": 4,
      "text": "Add chopped tomato and some sliced Jalapeno or Serrano pepper on top. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
