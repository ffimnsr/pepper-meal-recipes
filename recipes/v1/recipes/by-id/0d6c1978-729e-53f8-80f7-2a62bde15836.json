  "id": "0d6c1978-729e-53f8-80f7-2a62bde15836",
  "slug": "ham-and-potato-soup-recipe",
  "name": "Ham and Potato Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "A good soup can help build your appetite. This Ham and Potato Soup Recipe is a nice warm soup that can make your meals enjoyable.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt 2 tablespoons butter in a cooking pot."
    },
    {
      "position": 2,
      "text": "When the butter is hot, add ham. Cook for 1 minute."
    },
    {
      "position": 3,
      "text": "Put-in potato, onion, and celery. Cook for 1 to 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in chicken broth. Let boil. Simmer for 15 minutes."
    },
    {
      "position": 5,
      "text": "Meanwhile, melt the remaining butter in a saucepan."
    },
    {
      "position": 6,
      "text": "Gradually whisk-in flour. Stir until the mixture thickens."
    },
    {
      "position": 7,
      "text": "Slowly pour milk while continuously stirring. Cook (while stirring) until the texture becomes thick. Set aside."
    },
    {
      "position": 8,
      "text": "Pour the milk and flour mixture on the cooking pot where the ham and potatoes are. Add salt and pepper. Stir and simmer for 5 to 8 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a bowl and garnish with spring onion."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
