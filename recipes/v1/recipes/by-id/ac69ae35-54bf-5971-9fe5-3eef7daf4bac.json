  "id": "ac69ae35-54bf-5971-9fe5-3eef7daf4bac",
  "slug": "ground-beef-spaghetti-alfredo",
  "name": "Ground Beef Spaghetti Alfredo",
  "recipe_type": null,
  "brief_description": "Ground Beef Spaghetti Alfredo is a delicious and budget friendly recipe that can be easily prepared anytime. This makes use of regular spaghetti",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a wide pan."
    },
    {
      "position": 2,
      "text": "Add-in garlic. Cook for 20 seconds."
    },
    {
      "position": 3,
      "text": "Put-in ground beef. Stir and then brown the beef (about 5 to 7 minutes)."
    },
    {
      "position": 4,
      "text": "Pour-in heavy cream. Let boil and then simmer for 15 minutes (add water as necessary)."
    },
    {
      "position": 5,
      "text": "Put-in 1/2 cup Parmesan cheese. Stir."
    },
    {
      "position": 6,
      "text": "Arrange spaghetti noodles in a serving plate. Top with remaining Parmesan cheese and chopped parsley."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
