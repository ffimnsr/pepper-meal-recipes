  "id": "fe32d9b0-2fbb-587e-a2ee-5959d79023bd",
  "slug": "spaghetti-carbonara-recipe",
  "name": "Spaghetti Carbonara Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Spaghetti Carbonara",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine beaten eggs, heavy whipping cream, and parmesan cheese then mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Heat a cooking pot or pan then place the butter and let melt."
    },
    {
      "position": 3,
      "text": "Fry the bacon until the texture becomes crisp. Set aside."
    },
    {
      "position": 4,
      "text": "On the same cooking pot or pan, remove excess butter then saut\u00e9 the garlic and green onions."
    },
    {
      "position": 5,
      "text": "Put-in the spaghetti noodles and beaten egg- heavy whipping cream - parmesan cheese mixture then mix well. Cook for 1 to 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the fried bacon and distribute."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate then serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
