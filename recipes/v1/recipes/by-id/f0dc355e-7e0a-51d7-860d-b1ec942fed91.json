  "id": "f0dc355e-7e0a-51d7-860d-b1ec942fed91",
  "slug": "spam-and-egg-sandwich",
  "name": "Spam and Egg Sandwich",
  "recipe_type": "breakfast",
  "brief_description": "Spam and Egg Sandwich is a very simple sandwich that anyone can make. You might have done this before and may have your own recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Grease a frying pan with cooking oil. Fry the Spam for 2 minutes per side. Set aside."
    },
    {
      "position": 2,
      "text": "Place the bread slices in a toaster. Toast for 2 minutes."
    },
    {
      "position": 3,
      "text": "Spread the mayonnaise on one side of each bread slice. Set one bread slice on a plate \u2013 side with mayonnaise facing up. Put the American cheese followed by the Spam and egg. Top with the remaining bread slice \u2013 side with mayonnaise facing down."
    },
    {
      "position": 4,
      "text": "Serve with Crispy French fries."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 1,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 5,
