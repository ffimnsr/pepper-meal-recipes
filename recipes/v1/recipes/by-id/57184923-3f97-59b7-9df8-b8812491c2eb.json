{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "57184923-3f97-59b7-9df8-b8812491c2eb",
  "slug": "estofado-probinsya-style%ef%bf%bc",
  "name": "Estofado Recipe (Probinsya Style)",
  "recipe_type": "main",
  "brief_description": "This is a recipe for probinsya style pork estofado.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine pork, garlic, ground black pepper, soy sauce, and pineapple juice. Mix well. Marinate for 40 minutes."
    },
    {
      "position": 2,
      "text": "Prepare the saba bananas by frying it. Heat oil in a pan, fry the sliced bananas until it turns medium brown. Remove from the pan and set aside."
    },
    {
      "position": 3,
      "text": "Heat around 3 tablespoons of cooking oil in a pan. Saut\u00e9 garlic and onion until the latter softens."
    },
    {
      "position": 4,
      "text": "Add star anise. Continue cooking for 1 minute."
    },
    {
      "position": 5,
      "text": "Separate the pork from the marinade by filtering using a kitchen sieve. Saut\u00e9 the pork until it turns light brown."
    },
    {
      "position": 6,
      "text": "Add 1 tablespoon soy sauce and then pour the marinade into the pan. Pour 1 cup water. Cover and let boil."
    },
    {
      "position": 7,
      "text": "Add laurel leaves. Cover the pan and adjust your stove to the lowest setting. Cook for 40 minutes."
    },
    {
      "position": 8,
      "text": "Remove the star anise. You can discard it."
    },
    {
      "position": 9,
      "text": "Add brown sugar. Note: use half as indicated in the recipe first. You can add more later if needed."
    },
    {
      "position": 10,
      "text": "Continue cooking until the sauce reduces to half. Add the fried bananas. Continue cooking for 5 minutes."
    },
    {
      "position": 11,
      "text": "Transfer it on a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 80,
  "preparation_time_minutes": 10,
