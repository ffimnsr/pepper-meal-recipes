  "id": "e22f7b4a-2e3e-513c-ae18-45291bcae90b",
  "slug": "bacon-and-egg-fried-rice-recipe",
  "name": "Bacon and Egg Fried Rice Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Bacon and Egg Fried Rice",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a Dutch oven and then put-in the chopped bacon."
    },
    {
      "position": 2,
      "text": "Let the bacon cook until semi-crispy and all the oils come out."
    },
    {
      "position": 3,
      "text": "Scoop out excess oil to the point that around 4 to 5 tablespoons are left."
    },
    {
      "position": 4,
      "text": "Put the bacon on one end of the Dutch oven or cooking pot and then fry the eggs on the other side."
    },
    {
      "position": 5,
      "text": "When the eggs are cooked, use the spatula to chop them into small pieces."
    },
    {
      "position": 6,
      "text": "Put-in the rice. Sprinkle salt and garlic powder. Gently stir while cooking for about 4 minutes."
    },
    {
      "position": 7,
      "text": "Pour-in soy sauce. Stir and then cook for 4 minutes. Stir continuously by scooping the rice at the bottom to prevent it from getting burnt."
    },
    {
      "position": 8,
      "text": "Add the green peas. Stir once more and cook for another 3 to 6 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve with your favorite main dish. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
