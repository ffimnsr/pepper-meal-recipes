  "id": "2321ce39-3a31-528d-a268-8b20f6ceb561",
  "slug": "sinigang-na-baka-recipe",
  "name": "Sinigang na Baka",
  "recipe_type": "soup",
  "brief_description": "A comforting Filipino beef soup simmered in a tangy tamarind broth with tender cuts of beef and fresh vegetables.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Saut\u00e9 garlic, onions, and half the number of tomatoes until the onions soften."
    },
    {
      "position": 2,
      "text": "Add the beef and then continue to saut\u00e9 until it browns."
    },
    {
      "position": 3,
      "text": "Pour the rice water. Cover the pot and let the liquid boil. Simmer until the beef tenderizes completely. Add water as needed. Note: Scrape off the scums using a fat skimmer spoon."
    },
    {
      "position": 4,
      "text": "Add Maggi Magic Sinigang sa Sampaloc Mix and beef powder. Stir."
    },
    {
      "position": 5,
      "text": "Add the taro root and daikon radish. Cover and continue cooking until the taro softens."
    },
    {
      "position": 6,
      "text": "Put the eggplant, remaining tomatoes, and long green peppers into the cooking pot. Continue cooking for 5 minutes."
    },
    {
      "position": 7,
      "text": "Season with fish sauce."
    },
    {
      "position": 8,
      "text": "Add the okra and string beans. Continue cooking for another 5 minutes."
    },
    {
      "position": 9,
      "text": "Add the water spinach."
    },
    {
      "position": 10,
      "text": "Cook for 1 minute."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl. Serve hot with rice."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
