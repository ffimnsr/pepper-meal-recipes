  "slug": "asian-filipino-food-noodles-pansit-pancit-palabok-recipe",
  "name": "Pancit Palabok Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pancit Palabok",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Soak the rice noodles in water for about 15 minutes. Drain and set aside."
    },
    {
      "position": 2,
      "text": "Cook the sauce by heating a saucepan. Pour-in the cooking oil."
    },
    {
      "position": 3,
      "text": "When the oil is hot enough, put-in the ground pork and cook for about 5 to 7 minutes"
    },
    {
      "position": 4,
      "text": "Dilute the annato powder in pork broth then pour the mixture in the saucepan. Bring to a boil (If you are using anatto seeds, soak them first in 3 tbsp water to bring-out the color)"
    },
    {
      "position": 5,
      "text": "Add the shrimp cube and stir and simmer for 3 minutes"
    },
    {
      "position": 6,
      "text": "Add the flour gradually while stirring."
    },
    {
      "position": 7,
      "text": "Add the fish sauce and ground black pepper then simmer until sauce becomes thick. Set aside."
    },
    {
      "position": 8,
      "text": "Meanwhile, boil enough water in a pot."
    },
    {
      "position": 9,
      "text": "Place the soaked noodles in a strainer (use metal or bamboo strainer) then submerge the strainer in the boiling water for about a minute or until the noodles are cooked. (make sure that the noodles are still firm)"
    },
    {
      "position": 10,
      "text": "Remove the strainer from the pot and drain the liquid from the noodles."
    },
    {
      "position": 11,
      "text": "Place the noodles in the serving plate."
    },
    {
      "position": 12,
      "text": "Pour the sauce on top of the noodles then arrange the toppings over the sauce."
    },
    {
      "position": 13,
      "text": "Serve with a slice of lemon or calamansi. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
