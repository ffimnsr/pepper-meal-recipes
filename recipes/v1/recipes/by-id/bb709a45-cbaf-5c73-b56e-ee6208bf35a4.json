  "id": "bb709a45-cbaf-5c73-b56e-ee6208bf35a4",
  "slug": "filipino-lumpia-recipe",
  "name": "Lumpia Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Crispy and delicious deep fried Filipino egg rolls or lumpiang Shanghai.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all filling ingredients in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Scoop around 1 to 1 1/2 tablespoons of filling and place over a piece of lumpia wrapper. Spread the filling and then fold both sides of the wrapper. Fold the bottom. Brush beaten egg mixture on the top end of the wrapper. Roll-up until completely wrapped. Perform the same step until all mixture are consumed."
    },
    {
      "position": 3,
      "text": "Heat oil in a cooking pot. Deep fry lumpia in medium heat until it floats."
    },
    {
      "position": 4,
      "text": "Remove from the pot. Let excess oil drip. Serve. Share and enjoy"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "easy",
