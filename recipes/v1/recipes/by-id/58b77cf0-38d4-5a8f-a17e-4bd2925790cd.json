  "id": "58b77cf0-38d4-5a8f-a17e-4bd2925790cd",
  "slug": "kare-kare-recipe-beef-tripe",
  "name": "Beef Tripe Kare Kare",
  "recipe_type": "main",
  "brief_description": "Filipino beef kare kare recipe",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine 4 cups water and tripe in a pot. Boil for 1 hour. Discard water and set the tripe aside."
    },
    {
      "position": 2,
      "text": "Boil 1 \u00bd cups water in a small pot. Add annatto seeds. Continue to boil for 2 minutes. Set aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a pot. Saute onion and garlic until onion softens."
    },
    {
      "position": 4,
      "text": "Add tripe. Saute for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour annatto water into the pot while filtering using a kitchen sieve. Let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Beef Cube. Stir and then add peanut paste. Pour remaining water. Boil for 8 minutes."
    },
    {
      "position": 7,
      "text": "Combine rice flour and \u00bc cup water. Stir until blended. Pour mixture into the pot. Stir and continue to cook until the texture of the sauce thickens based on your preference."
    },
    {
      "position": 8,
      "text": "Add snake beans and eggplant. Cook for 5 minutes."
    },
    {
      "position": 9,
      "text": "Add baby bok choy or pechay. Cook for 1 minute."
    },
    {
      "position": 10,
      "text": "Season with ground black pepper."
    },
    {
      "position": 11,
      "text": "Serve with bagoong alamang over warm rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
