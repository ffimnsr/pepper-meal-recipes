  "id": "b7e92c6e-f0fb-5c46-9130-50d172e29673",
  "slug": "filipino-style-creamy-bacon-and-mushroom-carbonara",
  "name": "Filipino Style Creamy Bacon and Mushroom Carbonara",
  "recipe_type": null,
  "brief_description": "This is a recipe for Filipino Style Creamy Bacon and Mushroom Carbonara",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a deep cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add salt. Put the spaghetti into the pot. Cook the spaghetti according to the time indicated in the package instructions. Remove the spaghetti from the cooking pot. Drain the water. Set aside."
    },
    {
      "position": 3,
      "text": "Prepare the sauce by heating a clean cooking pot. Add bacon and cook in medium heat until the bacon fat gets extracted. Continue to cook until the texture of the bacon becomes crispy."
    },
    {
      "position": 4,
      "text": "Remove the bacon from the pot and place in a clean bowl. Set aside. Discard the bacon fat or keep for future use. Leave 2 to 3 tablespoons of bacon fat in the pot."
    },
    {
      "position": 5,
      "text": "Using the remaining bacon fat (oil), saute garlic until light brown. Add mushrooms. Cook for 30 seconds."
    },
    {
      "position": 6,
      "text": "Add Knorr Beef Cube. Crush the cube and cook for another 30 seconds while continuously stirring."
    },
    {
      "position": 7,
      "text": "Pour the all-purpose cream into the pot. Stir and cook for 3 to 4 minutes."
    },
    {
      "position": 8,
      "text": "Add Parmesan cheese and half of the cooked bacon into the pot. Stir until smooth."
    },
    {
      "position": 9,
      "text": "Arrange some pasta in a large bowl. Pour Carbonara sauce over the pasta. Sprinkle some bacon and chopped parsley. Toss until all ingredients are well blended."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Top with more Parmesan cheese, bacon, and chopped parsley."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
