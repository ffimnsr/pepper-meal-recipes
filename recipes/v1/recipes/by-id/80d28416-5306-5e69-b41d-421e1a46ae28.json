  "id": "80d28416-5306-5e69-b41d-421e1a46ae28",
  "slug": "bok-choy-adobo-pechay-recipe",
  "name": "Bok Choy Adobo",
  "recipe_type": null,
  "brief_description": "Bok Choy Adobo is a quick and simple way to cook bok choy. This is one of the easy bok choy recipes out there that you should try. The local bok choy variety in the Philippines is called \"Pechay\"; this dish is also known as adobong pechay or inadobong pechay.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a frying pan."
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot, put-in the crushed garlic and dried bay leaves. Cook until the garlic turns light to medium brown."
    },
    {
      "position": 3,
      "text": "Remove half of the garlic and then set them aside."
    },
    {
      "position": 4,
      "text": "Add the chopped bok choy. Stir and cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the soy sauce and vinagar. Let boil. Stir, cover, and simmer for 5 to 8 minutes."
    },
    {
      "position": 6,
      "text": "Add salt (if needed), pepper, and sugar.Stir and then cook for another minute more."
    },
    {
      "position": 7,
      "text": "Tranfer to a serving plate. Top with fried garlic."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 3,
  "rest_time_minutes": null,
  "difficulty": "medium",
