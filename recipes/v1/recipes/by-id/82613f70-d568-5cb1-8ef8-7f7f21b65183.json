  "id": "82613f70-d568-5cb1-8ef8-7f7f21b65183",
  "slug": "arroz-palabok",
  "name": "Arroz Palabok",
  "recipe_type": null,
  "brief_description": "Palabok congee topped with shrimp, boiled egg, and toasted garlic.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil shrimp in 2 cups water for 30 seconds. Set the shrimp aside. Save the water for later."
    },
    {
      "position": 2,
      "text": "Heat annatto oil in pot. Saute garlic until it starts to brown. Add onion. Continue saut\u00e9ing until soft."
    },
    {
      "position": 3,
      "text": "Add rice. Cook for 30 seconds."
    },
    {
      "position": 4,
      "text": "Pour water used to boil shrimp along with the remaining water. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Shrimp Cube. Stir."
    },
    {
      "position": 6,
      "text": "Add tinapa flakes. Stir occasionally and cook in low heat until the rice gets fully cooked and the texture becomes mushy."
    },
    {
      "position": 7,
      "text": "Season with pats and ground white pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Swirl some annatto oil on top and then top with chicharon, shrimp, toasted garlic, tinapa flakes, and green onions."
    },
    {
      "position": 9,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
