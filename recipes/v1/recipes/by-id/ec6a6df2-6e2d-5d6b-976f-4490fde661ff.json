  "slug": "tortang-tuna-with-spinach-omelet-recipe",
  "name": "Tortang Tuna with Spinach - Omelet Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Tortang Tuna with Spinach Omelet",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat 3 tablespoons of cooking oil in a pan"
    },
    {
      "position": 2,
      "text": "Saute onion until soft"
    },
    {
      "position": 3,
      "text": "Add tuna. Continue to cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Put the spinach into the pan. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Season with salt and ground black pepper. Remove from the pan and let it cool down."
    },
    {
      "position": 6,
      "text": "Crack the eggs and place in a large mixing bowl. Beat until yellow and white parts are well blended."
    },
    {
      "position": 7,
      "text": "Add the saut\u00e9ed tuna and spinach to beaten eggs. Make sure that the temperature cools first. Mix well."
    },
    {
      "position": 8,
      "text": "Heat remaining oil in an omelet pan or small frying pan"
    },
    {
      "position": 9,
      "text": "Pour the egg and tuna mixture. Gently push the cooked portion of the omelet towards the center to be able to heat the uncooked mixture. Continue to cook between low to medium heat for 2 minutes or until completely cooked. Turn over the omelet to cook the opposite side."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
