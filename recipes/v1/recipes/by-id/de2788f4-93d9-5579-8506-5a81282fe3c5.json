  "id": "de2788f4-93d9-5579-8506-5a81282fe3c5",
  "slug": "chicken-adobo-with-egg",
  "name": "Chicken Adobo with Egg",
  "recipe_type": "main",
  "brief_description": "Authentic Filipino chicken adobo cooked in adobo sauce with boiled eggs.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken, soy sauce, whole peppercorn, and half of the crushed garlic in a large bowl. Mix well and ensure that the chicken gets coated with the marinade. Cover the bowl and marinate for at least 1 hour. Note: the longer the time to marinate, the better."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot"
    },
    {
      "position": 3,
      "text": "Add the remaining crushed garlic. Cook until the garlic starts to turn brown."
    },
    {
      "position": 4,
      "text": "Add the marinated chicken including the marinade. Stir and cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Pour the chicken broth into the pot. Let boil."
    },
    {
      "position": 6,
      "text": "Add the bay leaves and pour the vinegar into the pot. Let boil. Stir and cover the pot. Continue to cook until the chicken gets tender and the sauce reduces to your preference."
    },
    {
      "position": 7,
      "text": "Add salt (only if needed) and then add the eggs. Stir and cook for 2 minutes more."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
