  "id": "3f6e3613-933a-51e1-8301-1c6fc669e3fb",
  "slug": "yellow-arroz-caldo-recipe",
  "name": "Yellow Arroz Caldo Recipe",
  "recipe_type": null,
  "brief_description": "Yellow Arroz Caldo is another version that I have for you. This recipe makes use of packaged yellow rice, which is better known as arroz amarillo.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot. Once the oil gets hot, put the garlic in and then cook in low to medium heat until the garlic turns light brown."
    },
    {
      "position": 2,
      "text": "Stir-in the onion. Continue to cook until the onion gets soft."
    },
    {
      "position": 3,
      "text": "Add the chicken. Stir and then cook for 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Gradually add the yellow rice. Stir. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the chicken broth and water. Stir."
    },
    {
      "position": 6,
      "text": "Add the onion powder, garlic powder, paprika, ground black pepper, and salt. Continue to cook in medium heat for 20 to 30 minutes. Cover the cooking pot and stir every 5 minutes or if needed. You can add more water or chicken broth if the liquid gets absorbed quickly by the rice. Add more salt only if needed."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Top with green onions. Serve with lime or calamansi."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
