  "id": "cf0d7fe7-b6e1-5f50-91c8-8264c67e0a08",
  "slug": "sarciadong-pechay-at-itlog",
  "name": "Sarciadong Pechay at Itlog",
  "recipe_type": "main",
  "brief_description": "Boiled eggs and fresh pechay cooked in a savory tomato and egg sauce seasoned with fish sauce.",
  "cuisine": "Asian Filipino Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 12 eggs in a pot of water until firm, about 10 to 12 minutes. Peel them, and then set aside."
    },
    {
      "position": 2,
      "text": "Beat the remaining 3 eggs in a bowl, and then set aside."
    },
    {
      "position": 3,
      "text": "Heat the oil in a wok or cooking pot over medium heat. Saute the onion for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the garlic, and continue sauteing for another minute."
    },
    {
      "position": 5,
      "text": "Add the tomatoes. Cook until they soften, and then add the fish sauce and ground black pepper."
    },
    {
      "position": 6,
      "text": "Pour in the water, and let it boil. Continue cooking for 1 to 2 minutes."
    },
    {
      "position": 7,
      "text": "Pour the beaten eggs into the pot in a slow stream. Let them set briefly, and then stir until well incorporated with the other ingredients."
    },
    {
      "position": 8,
      "text": "Add the pechay, and cook for 1 to 2 minutes."
    },
    {
      "position": 9,
      "text": "Season with Maggi Magic Sarap. Add the boiled eggs, and cook for another minute."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve with rice."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
