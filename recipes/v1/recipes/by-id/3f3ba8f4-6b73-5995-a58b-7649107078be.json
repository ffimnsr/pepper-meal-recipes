  "id": "3f3ba8f4-6b73-5995-a58b-7649107078be",
  "slug": "tuscan-salmon",
  "name": "Tuscan Salmon",
  "recipe_type": "main",
  "brief_description": "Creamy salmon fillet with spinach and sun-dried tomato",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and pepper all over the salmon. Let it rest for 5 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Fry salmon until lightly browned. Flip and cook the other side. Remove salmon from the pan and set aside."
    },
    {
      "position": 3,
      "text": "Melt butter in the same pan with the remaining oil."
    },
    {
      "position": 4,
      "text": "Add garlic. Cook until it starts to brown."
    },
    {
      "position": 5,
      "text": "Add onion. Saut\u00e9 until it softens. Add the sun-dried tomato. Cook for 30 seconds. Pour in water, cover the pan, and continue cooking for 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour in heavy whipping cream and stir. Cover and let boil."
    },
    {
      "position": 7,
      "text": "Add Parmesan cheese and spinach. Cover and cook for 1 minute."
    },
    {
      "position": 8,
      "text": "Return the fried salmon fillet to the pan. Cover and cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper as needed. Sprinkle chopped parsley on top."
    },
    {
      "position": 10,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
