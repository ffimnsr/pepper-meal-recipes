  "id": "667e7834-9d48-58ec-84a9-601559a06116",
  "slug": "dinuguan-blood-stew",
  "name": "Dinuguan",
  "recipe_type": "main",
  "brief_description": "A rich and savory Filipino stew made with tender pork simmered in vinegar, garlic, and fresh pork blood. Finished with green chili peppers for a gentle heat, this comforting dish is traditionally served with steamed rice or soft rice cakes.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saut\u00e9 the garlic and onion."
    },
    {
      "position": 2,
      "text": "Once the onion softens, add the pork kasim. Continue saut\u00e9ing for 2 to 3 minutes."
    },
    {
      "position": 3,
      "text": "Add the pork ears. Saut\u00e9 for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour the vinegar. Cover the pot and then let it boil. Stir."
    },
    {
      "position": 5,
      "text": "Pour the beef broth. Let the liquid boil."
    },
    {
      "position": 6,
      "text": "Add dried bay leaves and lemongrass. Cover the pot and adjust the heat to the lowest setting. Simmer for 50 minutes or until the pork tenderizes completely. Note: Make sure to stir occasionally. You can add water as needed."
    },
    {
      "position": 7,
      "text": "Pour the pork blood into the pot. Stir. Let the mixture boil and then simmer for 12 minutes."
    },
    {
      "position": 8,
      "text": "Add the long green pepper. Continue cooking for 3 minutes."
    },
    {
      "position": 9,
      "text": "Season with sugar, salt, and ground black pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 11,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 10,
