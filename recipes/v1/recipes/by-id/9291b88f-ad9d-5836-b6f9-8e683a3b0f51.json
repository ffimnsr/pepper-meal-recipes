  "id": "9291b88f-ad9d-5836-b6f9-8e683a3b0f51",
  "slug": "ways-to-cook-ground-beef-casserole",
  "name": "Ground Beef Casserole Recipe",
  "recipe_type": null,
  "brief_description": "There are many ways to cook ground beef. One way that I recommend is to make Ground Beef Casserole. This recipe might look like the typical Shepherds Pie.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a pan. Once the butter is hot, put-in the onions and cook until soft."
    },
    {
      "position": 2,
      "text": "Add the beef and cook until the color turns medium brown."
    },
    {
      "position": 3,
      "text": "Turn the heat off and let the temperature cool down."
    },
    {
      "position": 4,
      "text": "In a large mixing bowl, combine the cooked beef with the remaining ingredients (except the cheese). Mix well."
    },
    {
      "position": 5,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 6,
      "text": "Transfer the mixture on an oven-safe container. Top with cheese."
    },
    {
      "position": 7,
      "text": "Bake for 40 to 50 minutes."
    },
    {
      "position": 8,
      "text": "Serve, Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
