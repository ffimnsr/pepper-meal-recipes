  "id": "7745ad12-5c70-5845-9998-67c55b11adc5",
  "slug": "corned-beef-fried-rice-with-egg",
  "name": "Corned Beef Fried Rice with Egg",
  "recipe_type": null,
  "brief_description": "This is a recipe for Corned Beef Fried Rice with Egg",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a wide frying pan."
    },
    {
      "position": 2,
      "text": "Add the beaten egg. Cook one side for 1 minute in medium heat. Turn the egg over and cook the other side for another minute or until the egg is completely cooked. Remove the egg and put in a plate. Set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil (add more oil f needed), brown the minced garlic. Add the corned beef. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Put the rice in the pan. Stir-fry for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add the egg. Manually divide the egg into small pieces using a spatula. Add a dash of salt and then continue to stir-fry for 2 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a plate. Top with a piece of sunny side up egg."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
