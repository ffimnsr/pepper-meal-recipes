  "id": "c55e7d3c-493e-5d20-adaa-34c126d3085e",
  "slug": "ginarep-recipe-shrimp-and-corn-soup",
  "name": "Ginarep Recipe (Shrimp and Corn Soup)",
  "recipe_type": "soup",
  "brief_description": "Ginarep or shrimp and corn soup with malunggay is a tasty soup dish that originated from the Bicol region. This simple yet healthy soup dish is packed with vitamins and nutrients that gives you energy to face your day -- take it easy on the shrimp though.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Shred the kernel corn using a food processor. Set aside."
    },
    {
      "position": 2,
      "text": "Meanwhile, heat the oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Saute the garlic, onion, and tomatoes."
    },
    {
      "position": 4,
      "text": "Once the onion and tomatoes become soft, add the shredded corn. Cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the chicken broth and water. Bring to a boil. Cover and simmer for 10 to 12 minutes."
    },
    {
      "position": 6,
      "text": "Add the shrimp. Stir and cook for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the malunggay leaves. cook for a minute."
    },
    {
      "position": 8,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
