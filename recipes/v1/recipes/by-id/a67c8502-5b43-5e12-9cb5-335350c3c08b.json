  "id": "a67c8502-5b43-5e12-9cb5-335350c3c08b",
  "slug": "adobong-itlog-egg-adobo",
  "name": "Adobong Itlog (Egg Adobo)",
  "recipe_type": "main",
  "brief_description": "Adobong Itlog is a Filipino egg adobo of hard-boiled eggs simmered in soy sauce, vinegar, garlic, oyster sauce, and bay leaves.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place the eggs in a pot, cover with water, and boil for 10 minutes. Drain, peel, and set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan over medium heat. Saute the garlic until it starts to brown."
    },
    {
      "position": 3,
      "text": "Add the onion and cook until soft."
    },
    {
      "position": 4,
      "text": "Pour in the oyster sauce, soy sauce, and vinegar. Let it come to a boil. Do not stir right away."
    },
    {
      "position": 5,
      "text": "Add the water, bay leaves, and cracked peppercorn. Let the sauce simmer for 10 minutes."
    },
    {
      "position": 6,
      "text": "Add the boiled eggs and gently toss to combine."
    },
    {
      "position": 7,
      "text": "Add the sugar and season with Maggi Magic Sarap. Continue cooking until the sauce reduces slightly."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl and top with the chopped green onions. Serve with warm rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 39,
  "preparation_time_minutes": 5,
