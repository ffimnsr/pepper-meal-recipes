  "id": "26d189fb-d9bf-574c-84ec-c07650230d0a",
  "slug": "vegetable-spring-roll-recipe",
  "name": "Vegetable Spring Roll",
  "recipe_type": null,
  "brief_description": "Vegetable spring roll is a fried spring roll variation that makes use of vegetables such as cabbage, carrots, and bean sprouts as ingredients.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan and then scoop about 1 to 1 1/2 tablespoons of cooking oil."
    },
    {
      "position": 2,
      "text": "When the oil becomes hot, saute the garlic and ginger."
    },
    {
      "position": 3,
      "text": "Add the green onion, cabbage, and carrots. Cook for 3 to 4 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the bean sprouts, soy sauce, and sesame oil. Mix well and then cook for 1 to 2 minutes."
    },
    {
      "position": 5,
      "text": "Turn off the heat and then transfer the vegetables to a colander to drain the liquid. Let it cool down."
    },
    {
      "position": 6,
      "text": "Lay a piece of spring roll wrapper in a clean flat surface. Scoop about 2 tablespoons of vegetable mixture. Wrap the mixture by folding the opposite ends of the wrapper inward and then rolling the other side until a cylindrical shape is formed. Seal the edge by brushing the beaten egg mixture in the end of the wrapper. Repeat this step until the veggie mixture is consumed."
    },
    {
      "position": 7,
      "text": "Meanwhile, heat the cooking oil in a deep cooking pot."
    },
    {
      "position": 8,
      "text": "When the oil becomes hot, put-in the spring rolls gently one at a time until the maximum capacity of the cooking pot is reached. For better results, try to limit the rolls by cooking around 5 to 6 pieces at a time."
    },
    {
      "position": 9,
      "text": "Deep fry for 3 to 5 minutes or until the wrapper turns light to medium brown."
    },
    {
      "position": 10,
      "text": "Remove the fried spring rolls from the pot and place in a plate lined with paper towel."
    },
    {
      "position": 11,
      "text": "Serve with your favorite spring roll dipping sauce."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 25,
