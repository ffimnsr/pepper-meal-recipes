  "schema_version": 1,
  "id": "06aa9732-e54d-5f58-8052-35ed8e94f184",
  "slug": "garlic-roast-chicken",
  "name": "Garlic Roast Chicken",
  "recipe_type": "main",
  "brief_description": "Easy garlicky roast chicken. I love to have this with rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 450F"
    },
    {
      "position": 2,
      "text": "Pat chicken dry with a paper towel and arrange on a roasting pan."
    },
    {
      "position": 3,
      "text": "Crush the garlic and rosemary using a mortar and pestle tool until the texture becomes paste-like."
    },
    {
      "position": 4,
      "text": "Make the compound butter by mashing the butter using a fork. Add the garlic and rosemary paste and season with Knorr Liquid Seasoning. Mix well. Set aside."
    },
    {
      "position": 5,
      "text": "Place the chicken on a clean cast iron pan or a baking tray."
    },
    {
      "position": 6,
      "text": "Loose the skin from the meat by sliding your fingers between the meat and the skin. Spread the compound butter between the meat and skin of the chicken. Put the remaining butter inside the cavity."
    },
    {
      "position": 7,
      "text": "Squeeze lemon all over the chicken and sprinkle salt and ground black pepper. Stuff the lemon peel inside the cavity."
    },
    {
      "position": 8,
      "text": "Put the chicken inside the oven and bake for 20 minutes. Lower the temperature to 350F and continue baking until the internal temperature reaches 165F (it took me 50 minutes for this step, total baking time is 70 minutes)."
    },
    {
      "position": 9,
      "text": "Remove the chicken from the oven. Cover with aluminum foil and let the chicken rest for 20 minutes."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 70,
