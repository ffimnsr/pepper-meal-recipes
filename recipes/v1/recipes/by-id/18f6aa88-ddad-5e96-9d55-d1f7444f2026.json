  "id": "18f6aa88-ddad-5e96-9d55-d1f7444f2026",
  "slug": "pata-hamonado-recipe",
  "name": "Pata Hamonado",
  "recipe_type": "dessert",
  "brief_description": "Sweet Filipino Pork Hock with Soy Sauce and Pineapple.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 4 cups of water in a cooking pot. Add pork hock. Let boil for 15 minutes. Discard water. Set the pork aside."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a cooking pot. Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the boiled pork hock once the onion softens."
    },
    {
      "position": 4,
      "text": "Pour soy sauce, pineapple juice, and water. Let boil. Add whole peppercorn and dried bay leaves Pressure cook for 18 minutes. Note: if not using a pressure cooker, boil pork for 90 minutes on a regular cooking pot. Make sure to add water if the liquid is about to dry-up."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork Cube, brown sugar, and pineapple chunks. Stir. Let it simmer until the sauce reduces to half."
    },
    {
      "position": 6,
      "text": "Season with salt. Transfer to a serving plate. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 106,
