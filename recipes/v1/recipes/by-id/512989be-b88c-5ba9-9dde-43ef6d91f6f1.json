  "id": "512989be-b88c-5ba9-9dde-43ef6d91f6f1",
  "slug": "chicken-curry",
  "name": "Chicken Curry",
  "recipe_type": null,
  "brief_description": "This is a recipe for chicken curry",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub curry powder all over the chicken pieces. Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Once the oil gets hot, saute onion, ginger, and garlic."
    },
    {
      "position": 4,
      "text": "Add the chicken into the pot. Cook until the color turns light brown."
    },
    {
      "position": 5,
      "text": "Combine ginataang gulay mix with 1 cup water. Stir and then pour the mixture into the cooking pot."
    },
    {
      "position": 6,
      "text": "Pour the remaining 1 cup water. Let boil."
    },
    {
      "position": 7,
      "text": "Add the ground turmeric. Cover and reduce the heat between low to medium. Cook until the chicken gets tender."
    },
    {
      "position": 8,
      "text": "Add potato and green peas. Cook for 12 minutes."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve!"
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
