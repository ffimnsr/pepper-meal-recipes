  "id": "03c70cd3-5440-5688-a79f-5c1e7e20088f",
  "slug": "pork-picadillo",
  "name": "Pork Picadillo Recipe",
  "recipe_type": "main",
  "brief_description": "Stewed ground pork with potatoes, carrots, and green peas.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic, onion, and tomato until the onion softens."
    },
    {
      "position": 3,
      "text": "Add ground pork. Cook until the color of the pork turns light brown."
    },
    {
      "position": 4,
      "text": "Add fish sauce and water. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork Cube and tomato paste. Cover the pan. Continue cooking for 30 minutes using the lowest heat setting of your stove."
    },
    {
      "position": 6,
      "text": "Add raisins. Cover the pan. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add potatoes, carrots, and green peas. Cover and cook for 7 minutes."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper and fish sauce."
    },
    {
      "position": 9,
      "text": "Add boiled eggs."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
