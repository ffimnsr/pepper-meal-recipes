  "slug": "pancit-lomi-recipe",
  "name": "Lomi Recipe",
  "recipe_type": null,
  "brief_description": "Pancit Lomi is a delicious Filipino Noodle Recipe. Learn how to cook this dish by reading this post.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in cooking oil."
    },
    {
      "position": 2,
      "text": "When the oil is hot enough, saut\u00e9 the garlic and onions."
    },
    {
      "position": 3,
      "text": "Put-in the sliced pork and cook until the color turns medium brown."
    },
    {
      "position": 4,
      "text": "Add-in the ham and liver then cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add fish sauce and soy sauce then stir."
    },
    {
      "position": 6,
      "text": "Pour-in the broth and let boil. Simmer until the pork strips are tender (about 20 to 30 minutes)"
    },
    {
      "position": 7,
      "text": "Put-in the cooked meatballs and kikiam then simmer for 3 minutes."
    },
    {
      "position": 8,
      "text": "Add-in the ground black pepper and miki noodles then cook for 5 to 6 minutes."
    },
    {
      "position": 9,
      "text": "Add the cassava flour diluted in water and stir well. Cook until the sauce thickens."
    },
    {
      "position": 10,
      "text": "Turn-off the heat then pour-in the beaten egg. Stir constantly until the egg is well incorporated."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl and top with chicharon and sliced boiled egg. Garnish with onion leeks."
    },
    {
      "position": 12,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
