{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "8812b003-e34f-5fb7-b554-d5c7a39af897",
  "slug": "corned-beef-lomi-batangas-style",
  "name": "Corned Beef Lomi Batangas Style",
  "recipe_type": "soup",
  "brief_description": "Meatball noodle soup topped with chicharon and boiled egg.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make the meatballs by combining \u00be the amount of the corned beef, carrot, salt, ground black pepper, and 1-piece cracked egg in a bowl. Mix well. Gradually add all-purpose flour and continue mixing until all ingredients are well blended."
    },
    {
      "position": 2,
      "text": "Heat oil in pan. Scoop 1 \u00bd tablespoon of mixture and mold into a ball-shaped figure. Fry in low heat for 1 \u00bd minutes per side. Remove from the pan and transfer to a clean plate. Set aside."
    },
    {
      "position": 3,
      "text": "Transfer the remaining oil on a pot. Heat and then saut\u00e9 garlic until it starts to brown. Add onion and continue cooking until the later softens."
    },
    {
      "position": 4,
      "text": "Add remaining corned beef from the can. Saut\u00e9 for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour water into pot. Let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Beef Cube. Stir. Pour-in soy sauce and add fresh noodles. Cover and cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Combine cornstarch and \u00bd cup water. Mix well. Pour the mixture into the pot. Stir until the soup thickens."
    },
    {
      "position": 8,
      "text": "Crack a piece of egg into the pot. Quickly stir and continue cooking for 1 minute."
    },
    {
      "position": 9,
      "text": "Add fried meatballs and season with salt and ground black pepper. Cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Top with meatballs, boiled egg, chicharron, and chopped green onions."
    },
    {
      "position": 11,
      "text": "Serve warm. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
