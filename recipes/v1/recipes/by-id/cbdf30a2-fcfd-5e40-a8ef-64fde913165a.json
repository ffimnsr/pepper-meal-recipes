  "id": "cbdf30a2-fcfd-5e40-a8ef-64fde913165a",
  "slug": "pancit-guisado",
  "name": "Pancit Bihon Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pancit Bihon",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a large wok. Saute garlic and onion"
    },
    {
      "position": 2,
      "text": "Add the pork and chicken then let cook for 2 minutes"
    },
    {
      "position": 3,
      "text": "Add the chicken powder and water then simmer for 15 minutes"
    },
    {
      "position": 4,
      "text": "Put in the carrots, snow peas, cabbage, and celery leaves and simmer for a few minutes"
    },
    {
      "position": 5,
      "text": "Remove all the ingredients in the pot except for the liquid and set them aside"
    },
    {
      "position": 6,
      "text": "In the pot with the liquid in, add the soy sauce and mix well"
    },
    {
      "position": 7,
      "text": "Add the pancit bihon (makes sure to first soak it in water for about 10 minutes) and mix well. Cook until liquid evaporates completely"
    },
    {
      "position": 8,
      "text": "Put-in the vegetables and meat that were previously cooked and simmer for a minute or two"
    },
    {
      "position": 9,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
