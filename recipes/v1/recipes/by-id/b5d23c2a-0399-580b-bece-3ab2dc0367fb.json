  "id": "b5d23c2a-0399-580b-bece-3ab2dc0367fb",
  "slug": "classic-roast-turkey-recipe",
  "name": "Classic Roast Turkey Recipe",
  "recipe_type": null,
  "brief_description": "Turkey is the star of thanksgiving dinner. This Classic Roast Turkey Recipe will give you a simple and easy to prepare turkey meal that you will enjoy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pre-heat oven to 400 degrees Fahrenheit"
    },
    {
      "position": 2,
      "text": "Clean the turkey by placing under running water while gently rubbing the skin and cavity. Drain and pat dry with a paper towel."
    },
    {
      "position": 3,
      "text": "Combine butter, sage, thyme, salt, and pepper. Mix well."
    },
    {
      "position": 4,
      "text": "Place half of the butter mixture in between the skin and the meat of the turkey. Do this by creating an incision on the lower breast and then insert your finger to separate the skin and meat."
    },
    {
      "position": 5,
      "text": "Arrange the chopped celery and rosemary inside the cavity of the turkey and then tie the end of the legs together using a kitchen twine."
    },
    {
      "position": 6,
      "text": "Brush the remaining butter mixture all over the turkey."
    },
    {
      "position": 7,
      "text": "Place the turkey in a roasting rack and then put-inside the oven."
    },
    {
      "position": 8,
      "text": "Roast for about 20 minutes and then pour water on the roasting pan."
    },
    {
      "position": 9,
      "text": "Reduce the temperature to 350 degrees Fahrenheit."
    },
    {
      "position": 10,
      "text": "Cover the turkey with aluminum foil. Continue roasting for 1 hour and 30 minutes."
    },
    {
      "position": 11,
      "text": "Remove the foil and then roast the turkey for 30 to 45 minutes more."
    },
    {
      "position": 12,
      "text": "Arrange in a serving plate. Serve with turkey gravy."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 12,
