  "id": "0221485f-3717-539a-8e80-c397ee4b5b76",
  "slug": "sinigang-na-isda-sa-kamias-miso",
  "name": "Sinigang na Isda sa Kamias with Miso",
  "recipe_type": "main",
  "brief_description": "Sinigang na Isda sa Kamias - There is something in Fish sinigang and other sinigang versions that makes me feel good and energized",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the tomato, onion, and kamias. continue to boil for a minute."
    },
    {
      "position": 3,
      "text": "Add the miso paste. Stir and boil for 10 minutes more while covered."
    },
    {
      "position": 4,
      "text": "Gently add the fish fillet in the cooking pot. Cook in medium heat for 10 to 12 minutes."
    },
    {
      "position": 5,
      "text": "Add the long green pepper, string beans, and okra. Cook for 5 to 7 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the fish sauce. Stir."
    },
    {
      "position": 7,
      "text": "Add the kangkong. Cover the cooking pot and turn the heat off. Let it stay covered for 8 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
