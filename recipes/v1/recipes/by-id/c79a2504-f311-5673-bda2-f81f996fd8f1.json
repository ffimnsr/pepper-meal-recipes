  "id": "c79a2504-f311-5673-bda2-f81f996fd8f1",
  "slug": "buffalo-chicken-wing-with-sauce-recipe",
  "name": "Buffalo Chicken Wings Recipe with Sauce",
  "recipe_type": null,
  "brief_description": "This is a recipe for Buffalo Chicken Wings with Sauce",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Separate the drumette and flat part of the chicken wing by cutting using a knife."
    },
    {
      "position": 2,
      "text": "Rub salt all over the wings. Let it stay for 10 minutes."
    },
    {
      "position": 3,
      "text": "Combine flour and paprika in a small bowl. Arrange the salted wings into a large bowl and pour the salt and Cayenne pepper powder mixture. Toss until the wings are coated. Let this stay for 30 minutes. Note: This will produce lighty breaded fried chicken wings. Add more flour if you want a thicker breading."
    },
    {
      "position": 4,
      "text": "Heat oil in a cooking pot. Deep fry chicken wings in medium heat for 12 minutes or until golden brown."
    },
    {
      "position": 5,
      "text": "Meanwhile, prepare the buffalo sauce by melting butter in a sauce pan. Add hot sauce and garlic powder. Stir until well blended."
    },
    {
      "position": 6,
      "text": "Place the fried chickwn wings in a large bowl. Pour Buffalo sauce over. Toss until coated."
    },
    {
      "position": 7,
      "text": "Arrange in a serving plate. Serve with Ranch dressing and vegetable slices."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
