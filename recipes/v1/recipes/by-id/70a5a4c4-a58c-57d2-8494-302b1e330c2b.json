  "id": "70a5a4c4-a58c-57d2-8494-302b1e330c2b",
  "slug": "baking-dessert-sweets-carrot-cake-recipe",
  "name": "Carrot Cake Recipe",
  "recipe_type": "dessert",
  "brief_description": "This Carrot Cake Recipe is moist and has an amazing flavor. This is definitely a keeper. Your family and friends will surely enjoy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the cake by combining flour, baking soda, ground cinnamon, baking powder, and salt in a mixing bowl than whisk until everything is properly distributed. Beat the eggs using an electric mixer in a separate mixing bowl. Add the granulated and light brown sugar then continue mixing until fully blended. Add the vegetable oil, fresh milk, and vanilla extract then continue mixing until texture becomes smooth. Put-in the flour-baking soda-cinnamon-baking powder-salt mixture then continue mixing using low speed. Fold-in the carrots and walnuts. Pour the batter on a cake pan with shaped wax paper. Preheat oven to 350 degrees Fahrenheit and bake the batter for 35 to 50 minutes (you know that the cake is done when toothpick inserted comes out clean). Remove from the oven and allow to cool down."
    },
    {
      "position": 2,
      "text": "Make the frosting by whisking the cream cheese using an electric mixer. Add-in the butter and vanilla extract then continue mixing until the mixture is well blended. Add the confectioners sugar then mix until texture becomes smooth. Set aside"
    },
    {
      "position": 3,
      "text": "Apply the frosting over the cake. Place the first cake on a flat surface and apply frosting on the top part spreading it evenly. Place the second cake on top of the first cake and align properly. Apply the remaining frosting on top and on the sides of the cake. Garnish with chopped walnuts on top and on the sides."
    },
    {
      "position": 4,
      "text": "Refrigerate for at least an hour then serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
