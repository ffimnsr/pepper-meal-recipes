  "id": "f3e0448e-058e-5c72-9a79-11c1f6c94853",
  "slug": "tulapho-recipe-crispy-fried-pork",
  "name": "Tulapho Recipe (Crispy Fried Pork)",
  "recipe_type": null,
  "brief_description": "Tulapho is a term used to describe crispy fried pork. I am not sure where this term came about, but it is catchy enough to get my attention.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add salt, pepper, and bay leaves."
    },
    {
      "position": 3,
      "text": "Slide-in the pork and let the water re-boil. Cover and boil in medium heat until the pork gets tender. You can add more water if needed."
    },
    {
      "position": 4,
      "text": "Once the pork is tender, remove the cover. Adjust the heat to medium and then cook while stirring until the water completely evaporates."
    },
    {
      "position": 5,
      "text": "Continue to fry the pork in its own oil while constantly flipping it over until it turns golden brown."
    },
    {
      "position": 6,
      "text": "Remove the pork from the cooking pot or pan and transfer to plate with paper towel."
    },
    {
      "position": 7,
      "text": "You can serve it as it is or use it as an ingredient in other Filipino dishes. Enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 5,
