  "id": "edf7e20a-a919-5d2a-be59-074b7524f710",
  "slug": "broccoli-cheddar-soup",
  "name": "Broccoli Cheddar Soup",
  "recipe_type": "soup",
  "brief_description": "Broccoli cheddar soup is a thick and creamy cheese soup made with sharp cheddar, fresh broccoli, butter, flour, and milk. This easy recipe is ready in about 25 minutes and uses no broth at all.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pan over medium heat and melt the butter."
    },
    {
      "position": 2,
      "text": "Add the chopped onion and cook until soft and fragrant."
    },
    {
      "position": 3,
      "text": "Stir in the flour and continue cooking while mixing to form a smooth base. Let it cook for about a minute until the raw flour smell disappears."
    },
    {
      "position": 4,
      "text": "Slowly pour in the milk, stirring constantly to prevent lumps. Bring to a gentle boil, then simmer for 2 minutes until the mixture starts to thicken."
    },
    {
      "position": 5,
      "text": "Add the ground black pepper and stir to combine."
    },
    {
      "position": 6,
      "text": "Add the chopped broccoli and cook for 3 to 5 minutes, or until the florets are tender."
    },
    {
      "position": 7,
      "text": "Turn off the heat. Stir in the grated cheddar cheese a handful at a time, mixing well until each addition is fully melted before adding more."
    },
    {
      "position": 8,
      "text": "Transfer the soup to a serving bowl. Serve hot and enjoy."
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
