{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "f28ab1e5-4a4d-5502-a2f9-08bf975a3c1b",
  "slug": "breakfast-quesadilla",
  "name": "Breakfast Quesadilla",
  "recipe_type": "breakfast",
  "brief_description": "Seasoned Eggs are cooked flat over sliced tomatoes and green onions, then folded inside a crispy flour tortilla with melted mozzarella cheese.",
  "cuisine": "American Mexican",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the egg and Maggi Magic Sarap in a small bowl. Beat well until the seasoning is mixed in, and then set aside."
    },
    {
      "position": 2,
      "text": "Heat the olive oil in a nonstick pan over medium heat."
    },
    {
      "position": 3,
      "text": "Arrange the sliced tomatoes in the pan. Cook for 30 seconds until they start to soften."
    },
    {
      "position": 4,
      "text": "Sprinkle the chopped green onions over the tomatoes and within the spaces in between. Pour in the beaten egg over the entire surface. Continue cooking over low to medium heat until the egg sets enough that it no longer runs."
    },
    {
      "position": 5,
      "text": "Place the flour tortilla on top of the egg and press down gently. Carefully flip the whole thing so the tortilla is on the bottom."
    },
    {
      "position": 6,
      "text": "Sprinkle the mozzarella cheese over one half of the egg. Fold the tortilla in half and continue cooking until the cheese fully melts, about 1 to 2 minutes. You can also use other cheeses here."
    },
    {
      "position": 7,
      "text": "Transfer to a cutting board. Slice and serve for breakfast or brunch."
    }
  ],
  "servings": 1,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
