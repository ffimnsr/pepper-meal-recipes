  "id": "5b7ac98f-ad42-5c7e-9ab2-595f3e538332",
  "slug": "clam-soup-tinolang-halaan",
  "name": "Clam Soup Recipe (Tinolang Halaan)",
  "recipe_type": "soup",
  "brief_description": "A Filipino clam soup made with fresh clams, ginger, and spinach. This version uses vegetables readily available in your local market.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil the water in a stockpot."
    },
    {
      "position": 2,
      "text": "Add the ginger and onion. Cover and continue to boil over medium heat for 3 to 5 minutes."
    },
    {
      "position": 3,
      "text": "Stir in the clams. Simmer for 5 to 10 minutes."
    },
    {
      "position": 4,
      "text": "Add the spinach. Cover and cook for a minute more."
    },
    {
      "position": 5,
      "text": "Sprinkle some salt and freshly ground black pepper to taste."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
