  "id": "21516f42-86fb-543c-8ee8-a680b9b764a2",
  "slug": "chicken-guisantes-recipe",
  "name": "Chicken Guisantes Recipe",
  "recipe_type": null,
  "brief_description": "Chicken Guisantes or Chicken and Green Peas Stew is my go to dish when I want to eat something simple yet satisfying for dinner. I like chicken guisantes because its taste is not overpowering and it is also easy to prepare.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Once the onion becomes soft, add the chicken slices. Cook each side of the chicken until it turns light brown (around 2 minutes). Make sure to turn the chicken over to cook the other side."
    },
    {
      "position": 4,
      "text": "Add the diced tomatoes and chicken broth. Stir and let boil. Cover and simmer for 30 to 40 minutes."
    },
    {
      "position": 5,
      "text": "Add the green peas. Stir and cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the red bell pepper. Stir and cook for another 3 minutes."
    },
    {
      "position": 7,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
