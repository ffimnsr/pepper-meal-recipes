  "id": "98c1416f-87be-557d-a143-f82a575d2d9a",
  "slug": "tuna-sisig",
  "name": "Tuna Sisig",
  "recipe_type": null,
  "brief_description": "This is a recipe for Tuna Sisig.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the tuna by draining the liquid. You can place it in a cheese cloth and squeeze until the liquid comes-out."
    },
    {
      "position": 2,
      "text": "Heat 1 tablespoon oil in a pan. Pan fry the tuna until it turns light to medium brown."
    },
    {
      "position": 3,
      "text": "Add onion. Continue to saute until the onion becomes soft."
    },
    {
      "position": 4,
      "text": "Add scallions and chili pepper. Saute for 2 more minutes."
    },
    {
      "position": 5,
      "text": "Season with garlic powder, ground black pepper, and soy sauce. Stir and cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Add half of the chicharon and put the mayonnaise into the pot. Mix well. Set aside."
    },
    {
      "position": 7,
      "text": "Melt butter in sizzling plate (metal plate), put the cooked tuna sisig on the plate. Continue to cook for 30 seconds or until sizzling hot."
    },
    {
      "position": 8,
      "text": "Top with remaining chicharon. Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
