{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "cc61d8b4-b565-5bd1-8e9c-408ed7ead5d9",
  "slug": "dyanamite-lumpia",
  "name": "Dynamite Lumpia",
  "recipe_type": "appetizer",
  "brief_description": "Wrapped spicy long green peppers stuffed with cheese and saut\u00e9ed ground pork and deep fried to perfection.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the ground pork stuffing by heating 3 tablespoons oil in a pan. Saute garlic and onion until the latter softens. Add ground pork. Saute until medium brown. Season with salt and ground black pepper. Remove from the pan and put on a large bowl. Let it cool down."
    },
    {
      "position": 2,
      "text": "Beat 1 piece of egg and pour into the cooked ground pork. Mix well. Set aside."
    },
    {
      "position": 3,
      "text": "Slice one side of the peppers lengthwise all the way to the bottom. Remove the seeds by gently scraping using a small spoon or a butter knife. Set aside."
    },
    {
      "position": 4,
      "text": "Slice the cheddar cheese into long pieces. Stuff individual slices of cheese into each pepper. Sccop the cooked meat mixture and stuff into the chili peppers. Make sure that there is enough meat."
    },
    {
      "position": 5,
      "text": "Wrap the stuffed peppers in lumpia wrapper."
    },
    {
      "position": 6,
      "text": "Heat 2 cups of oil in a pan. Fry each piece of dynamite lumpia in medium heat for 2 minutes per side or until lumpia wrapper turns golden brown. Note: you may fry longer if needed."
    },
    {
      "position": 7,
      "text": "Remove from pan and place over a wire rack. Let it cool down. Arrange in a serving plate and then serve with your favorite condiment."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 8,
