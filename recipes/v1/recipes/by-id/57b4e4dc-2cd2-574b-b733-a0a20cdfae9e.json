  "id": "57b4e4dc-2cd2-574b-b733-a0a20cdfae9e",
  "slug": "breakfast-sausage-hash",
  "name": "Breakfast Sausage Hash",
  "recipe_type": "breakfast",
  "brief_description": "Breakfast Sausage Hash is a cheesy way to make sausage and hashbrown casserole. This recipe makes use of 2 kinds of cheeses: salsa con queso and shredded cheese.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan, pour-in the beef broth, bring to a boil. Add the sausage links and butter. Parboil the sausage links until the beef broth evaporates."
    },
    {
      "position": 2,
      "text": "Once the broth completely evaporates, continue to fry the sausage links using the remaining butter in low to medium heat for 5 minutes."
    },
    {
      "position": 3,
      "text": "Remove the sausage links from the pan, let it cool down. Slice into thin pieces."
    },
    {
      "position": 4,
      "text": "Combine the remaining butter and add the canola oil, apply heat. Once the mixture heats-up, put the sliced sausages in. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Add the shredded potatoes. Stir and cook for 5 to 7 minutes."
    },
    {
      "position": 6,
      "text": "Transfer the cooked potato and sausage in a mixing bowl. Add the salsa con queso, shredded cheese, hot sauce, salt, and onion powder. Fold until the ingredients are well blended."
    },
    {
      "position": 7,
      "text": "Preheat oven to 400F. Arrange the mixture in a baking plate. Top with chopped green onions Bake for 35 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven. Serve for breakfast."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
