  "id": "18ee8b11-a1b5-5ffe-b4fb-da149b81ad8f",
  "slug": "home-fries-recipe",
  "name": "Home Fries Recipe",
  "recipe_type": "breakfast",
  "brief_description": "Crispy cubed potatoes saut\u00e9ed with bell peppers and onions, seasoned with garlic, salt, and pepper.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Add the potato. Saute for 3 to 5 minutes."
    },
    {
      "position": 2,
      "text": "Add onion. Saute the onion until soft."
    },
    {
      "position": 3,
      "text": "Add bell peppers. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add salt, pepper, and garlic powder. Stir and cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve for breakfast as a side dish."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 10,
