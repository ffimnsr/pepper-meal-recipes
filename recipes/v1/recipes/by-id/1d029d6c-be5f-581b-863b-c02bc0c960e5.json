  "id": "1d029d6c-be5f-581b-863b-c02bc0c960e5",
  "slug": "tokwat-baka-recipe",
  "name": "Tokwat Baka (Fried Tofu and Grilled Beef in Vinegar Sauce)",
  "recipe_type": null,
  "brief_description": "Tokwat Baka is the beef version of the well loved tokwat baboy recipe. Similar dishes often use boiled beef -- this particular recipe is quite different",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the sliced steak and cubed tofu in a bowl."
    },
    {
      "position": 2,
      "text": "On a separate bowl, combine soy sauce, vinegar, sesame oil, sugar, pepper, salt, and onion. Stir. Microwave for 20 to 30 seconds"
    },
    {
      "position": 3,
      "text": "Pour the mixture over the steak and tofu."
    },
    {
      "position": 4,
      "text": "Top with chopped green onions and sesame seeds."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 3,
  "preparation_time_minutes": 10,
