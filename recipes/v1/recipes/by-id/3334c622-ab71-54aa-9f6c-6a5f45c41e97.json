  "id": "3334c622-ab71-54aa-9f6c-6a5f45c41e97",
  "slug": "how-to-cook-dinuguan-using-sinigang-mix",
  "name": "How to Cook Dinuguan Using Sinigang Mix",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Filipino pork dinuguan using Knorr Sinigang Mix Original. It is a good alternative to vinegar.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok. Saute onion, garlic, and ginger until the onion softens."
    },
    {
      "position": 2,
      "text": "Add pork. Saute until the color of the outer part turns light brown."
    },
    {
      "position": 3,
      "text": "Add Knorr Sinigang sa Sampaloc Mix. Stir."
    },
    {
      "position": 4,
      "text": "Add Knorr Pork Cube and dried bay leaves."
    },
    {
      "position": 5,
      "text": "Pour soy sauce and water. Cover and let boil. Continue boiling using low to medium heat for 35 minutes."
    },
    {
      "position": 6,
      "text": "Add long green pepper and pour the pork blood into the wok. Stir and cook for 5 to 8 minutes."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and sugar (note: you can add salt if needed). Serve warm. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 1,
