  "id": "be39f39e-05cb-5599-83fe-4f12433856b9",
  "slug": "dinardaraan-recipe-dinuguan",
  "name": "Dinardaraan Recipe (Dinuguan)",
  "recipe_type": null,
  "brief_description": "This is a recipe for dinardaraan. It is the Ilocano version of dinuguan",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and onion until soft"
    },
    {
      "position": 3,
      "text": "Add the pork and ground black pepper. Saut\u00e9 until it turns medium brown."
    },
    {
      "position": 4,
      "text": "Pour the broth or water. Let boil. Adjust the heat to low. Cook for 25 to 30 minutes. You may add more water if it starts to dry out while you simmer."
    },
    {
      "position": 5,
      "text": "Pour the vinegar in the pot. Let boil. Stir. Add the green peppers and pork blood. Continue to cook for 15 to 20 minutes or until the sauce thickens."
    },
    {
      "position": 6,
      "text": "Sprinkle some salt to taste."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
