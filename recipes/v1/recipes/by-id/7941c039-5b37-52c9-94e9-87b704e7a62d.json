  "id": "7941c039-5b37-52c9-94e9-87b704e7a62d",
  "slug": "tuna-pesto-pasta-recipe-creamy-version",
  "name": "Tuna Pesto Pasta Recipe Creamy Version",
  "recipe_type": "main",
  "brief_description": "Basil pesto, tuna, and cream in a pasta dish",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Boil the penne pasta al dente (see notes below) according to package instructions. Drain the pasta water. Set both aside."
    },
    {
      "position": 2,
      "text": "Melt butter in a pan. Add olive oil."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the onion for 30 seconds."
    },
    {
      "position": 4,
      "text": "Add the garlic. Continue saut\u00e9ing until the onion softens and the garlic starts to brown. Note: Do not brown the garlic completely. (see notes below)"
    },
    {
      "position": 5,
      "text": "Add the tuna. Saut\u00e9 for 1 minute."
    },
    {
      "position": 6,
      "text": "Add the pesto sauce. Stir and continue cooking for another minute."
    },
    {
      "position": 7,
      "text": "Pour Nestle all-purpose cream and 3 tablespoons of pasta water."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper. Gently stir the mixture."
    },
    {
      "position": 9,
      "text": "Add the cooked penne pasta into the pan. Toss until coated completely."
    },
    {
      "position": 10,
      "text": "Add the Parmesan cheese. Toss. (see notes below)"
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 15,
