  "id": "8c7e4b5d-ba60-5fe3-8601-ab9e8e4334a8",
  "slug": "creamy-lengua-with-corn",
  "name": "Creamy Lengua with Corn",
  "recipe_type": "soup",
  "brief_description": "Super tender and delicious ox tongue cooked with sweet corn with creamy sauce.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine ox tongue, 5 pieces dried bay leaves, 1 tablespoon whole peppercorn, and 6 cups water in a pressure cooker. Pressure cook for 45 minutes. Discard the water and let the ox tongue cooldown. Peel-off the outer layer. Slice tongue into serving pieces. Set aside."
    },
    {
      "position": 2,
      "text": "Melt butter in a pan. As the butter melts, add garlic. Continue to cook between low to medium heat until the garlic starts to brown."
    },
    {
      "position": 3,
      "text": "Add onion. Cook until tender."
    },
    {
      "position": 4,
      "text": "Put the ox tongue into the pan. Saut\u00e9 for 2 minutes while continuously stirring."
    },
    {
      "position": 5,
      "text": "Pour water into the pan. Let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Beef Cube. Stir."
    },
    {
      "position": 7,
      "text": "Add whole kernel corn. Stir and cover the pan. Cook for 20 minutes."
    },
    {
      "position": 8,
      "text": "Pour cream of mushroom soup and all-pupose cream. Stir. Cook for 10 minutes."
    },
    {
      "position": 9,
      "text": "Season with salt and pepper. Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 45,
