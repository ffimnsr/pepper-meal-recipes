  "id": "7addcbe4-d2b1-58c6-a789-5687bf52f062",
  "slug": "making-mcdonalds-style-chicken-nuggets-at-home",
  "name": "McDonalds Style Chicken Nuggets",
  "recipe_type": "snack",
  "brief_description": "Copycat recipe of Mcdonald&#039;s Chicken Nugget.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Make the sauce by combining all barbecue sauce ingredients in a saucepan. Heat and let it simmer for 2 minutes. Stir and turn off the heat. Let it cool down before serving."
    },
    {
      "position": 2,
      "text": "Prepare the chicken nuggets. Cut chicken into cubes. Place in a food processor."
    },
    {
      "position": 3,
      "text": "Add Knorr Chicken Cube, sugar, and salt. Process until the texture becomes paste-like."
    },
    {
      "position": 4,
      "text": "Combine batter ingredients in a bowl. Mix well. Set aside."
    },
    {
      "position": 5,
      "text": "Heat oil to 350F."
    },
    {
      "position": 6,
      "text": "Scoop around 1 tablespoon of chicken mixture. Mold into a nugget shaped figure. You may also flatten it by covering with parchment paper and slice into individual pieces."
    },
    {
      "position": 7,
      "text": "Dredge in cornstarch and dip in batter. Let excess liquid drip."
    },
    {
      "position": 8,
      "text": "Deep-fry until the color turns golden brown. Remove from the cooking pot and place on a plate lined with paper towels."
    },
    {
      "position": 9,
      "text": "Serve with barbecue sauce. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
