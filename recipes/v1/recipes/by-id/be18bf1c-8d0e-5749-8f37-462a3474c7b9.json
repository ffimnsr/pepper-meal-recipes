  "id": "be18bf1c-8d0e-5749-8f37-462a3474c7b9",
  "slug": "mutya-ng-cavite-recipe",
  "name": "Mutya ng Cavite",
  "recipe_type": "soup",
  "brief_description": "Seafood bouillabaisse",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a wok or pan. Add crab. Continue boiling for 8 minutes. Transfer the crab and the stock to a clean bowl. Set aside."
    },
    {
      "position": 2,
      "text": "Make the roux by melting butter in a wok. Add flour. Constantly stir while cooking for 2 minutes. Pour evaporated milk into the wok. Stir until mixture thickens. Pour the crab stock and stir until the texture of the mixture becomes smooth."
    },
    {
      "position": 3,
      "text": "Add Knorr Shrimp Cube. Stir."
    },
    {
      "position": 4,
      "text": "Add Crab, mussels, fish, onion, carrot, and celery. Cook for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Put the bell pepper, shrimp, and squid into the wok. Stir and cook until the color of the shrimp turns orange."
    },
    {
      "position": 6,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve warm. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
