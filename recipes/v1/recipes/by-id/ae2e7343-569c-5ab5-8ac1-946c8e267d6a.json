  "id": "ae2e7343-569c-5ab5-8ac1-946c8e267d6a",
  "slug": "bopis-na-manok",
  "name": "Bopis na Manok",
  "recipe_type": null,
  "brief_description": "This is a recipe for bopis na manok. It is a dish composed of chopped chicken innards.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat 6 cup water on a pressure cooker. Add chicken gizzard. cover and pressure cook for 15 minutes. Note: Start the timer once the pressure regulator moves. You can also boil in a regular pot for 45 minutes."
    },
    {
      "position": 2,
      "text": "Remove the gizzard from the pressure cooker. Drain the water. Chop into small pieces and set aside."
    },
    {
      "position": 3,
      "text": "Meanwhile, boil 6 cups water on a regular pot. Add chicken heart. Boil for 15 minutes. Remove from the pot and chop into small pieces."
    },
    {
      "position": 4,
      "text": "Make annatto oil by heating oil in a saucepan. Add annatto seeds. Cook in low heat until the oil turns red."
    },
    {
      "position": 5,
      "text": "Heat a cooking pot and pour annatto oil. Note: use a kitchen strainer to filter the seeds."
    },
    {
      "position": 6,
      "text": "Saute onion, garlic, ginger, and tomato."
    },
    {
      "position": 7,
      "text": "Add the chopped chicken gizzard. Cook for 1 to 2 minutes."
    },
    {
      "position": 8,
      "text": "Add chicken heart. Cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Add chili pepper and bay leaves."
    },
    {
      "position": 10,
      "text": "Pour soy sauce into the pot. Stir."
    },
    {
      "position": 11,
      "text": "Pour water. Let boil. Cover and cook for 15 minutes."
    },
    {
      "position": 12,
      "text": "Add vinegar. Let the mixture re-boil. Stir and continue to cook for 5 minutes."
    },
    {
      "position": 13,
      "text": "Add carrots, daikon radish, and red bell pepper. Stir. Cook for 3 minutes."
    },
    {
      "position": 14,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 15,
      "text": "Transfer to a serving bowl. Serve."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 12,
