  "id": "aecab7b8-18d9-520d-8453-966a2f66f51b",
  "slug": "chicken-asado-asadong-manok-recipe",
  "name": "Chicken Asado",
  "recipe_type": null,
  "brief_description": "Chicken Asado (also called Asadong Manok) is a piquant Filipino chicken stew cooked in a tomato based sauce with potatoes.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub the chicken with salt and pepper and let stand for at least 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat a frying pan then pour-in the cooking oil and Pan Fry the chicken. Set aside."
    },
    {
      "position": 3,
      "text": "Heat a cooking pot or wok then put-in the butter."
    },
    {
      "position": 4,
      "text": "When the butter is hot enough, add the onions and saut\u00e9 until the texture becomes soft."
    },
    {
      "position": 5,
      "text": "Add-in the bay leaves and cook for a minute."
    },
    {
      "position": 6,
      "text": "Pour-in the tomato sauce and bring to a boil."
    },
    {
      "position": 7,
      "text": "Add the soy sauce and lemon juice then stir to ensure that the mixture is properly distributed and simmer for 5 to 7 minutes."
    },
    {
      "position": 8,
      "text": "Add the pan-fried chicken and simmer for 10 minutes."
    },
    {
      "position": 9,
      "text": "Place the potatoes in and continue to simmer for 7 to 12 minutes."
    },
    {
      "position": 10,
      "text": "Turn off the heat then transfer to a serving plate and serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
