  "id": "235dbc10-b462-5629-a3ae-75dd588f6d4a",
  "slug": "chewy-coconut-macaroons-recipe",
  "name": "Chewy Coconut Macaroons Recipe",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Chewy Coconut Macaroons",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350F."
    },
    {
      "position": 2,
      "text": "Beat the egg in a mixing bowl. Add butter, vanilla extract, and condensed milk. Whisk until well blended."
    },
    {
      "position": 3,
      "text": "Add the desiccated coconut and salt. Fold until the mixture is distributed."
    },
    {
      "position": 4,
      "text": "Arrange mini baking cups on a mini muffin pan. Scoop around 1 tablespoon of mixture and place it into each baking cup."
    },
    {
      "position": 5,
      "text": "Put the muffin pan in the oven. Bake for 10 to 13 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven. Let it cool down."
    },
    {
      "position": 7,
      "text": "Transfer to a plate. Serve for dessert."
    },
    {
      "position": 8,
      "text": "Share and enjoy"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 13,
  "preparation_time_minutes": 10,
