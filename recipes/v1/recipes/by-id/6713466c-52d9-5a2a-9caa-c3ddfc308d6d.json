  "id": "6713466c-52d9-5a2a-9caa-c3ddfc308d6d",
  "slug": "pinakbet-with-squid-in-coconut-milk-pinakbet-sa-gata",
  "name": "Pinakbet with Squid in Coconut Milk (Pinakbet sa Gata)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pinakbet with Squid in Coconut Milk.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a bowl."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic, ginger, and onion. Continue to cook until the onion are soft."
    },
    {
      "position": 3,
      "text": "Add the squid and then saut\u00e9 for 2 minutes."
    },
    {
      "position": 4,
      "text": "Remove the squid. Set aside."
    },
    {
      "position": 5,
      "text": "Add the butternut squash. Continue to saut\u00e9 for 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour the coconut milk into the cooking pot. Let boil. Cover the pot and then simmer for 10 minutes."
    },
    {
      "position": 7,
      "text": "Add the okra, snake beans, bitter melon, and eggplant. Stir and cook for 8 minutes."
    },
    {
      "position": 8,
      "text": "Stir in the squid, shrimp paste, and ground black pepper. Cook for 5 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
