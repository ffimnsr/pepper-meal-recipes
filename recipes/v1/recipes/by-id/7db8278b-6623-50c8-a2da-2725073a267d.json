  "id": "7db8278b-6623-50c8-a2da-2725073a267d",
  "slug": "pork-ginataan-with-squash-and-string-beans",
  "name": "Pork Ginataan with Squash and String Beans",
  "recipe_type": null,
  "brief_description": "Pork Ginataan with Squash and String Beans is a rich and delicious Filipino dish that makes use of pork, coconut milk, and vegetables such as squash and string beans.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the ground black pepper. Stir and then add the pork. Cook the pork until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Pour the beef broth in the cooking pot. Let it boil."
    },
    {
      "position": 5,
      "text": "Add the coconut milk. Stir and allow to boil once more. Cover and cook in low to medium heat until the pork gets tender."
    },
    {
      "position": 6,
      "text": "Add the squash. Stir, cover and cook for 8 to 10 minutes."
    },
    {
      "position": 7,
      "text": "Add the shrimp paste. Stir."
    },
    {
      "position": 8,
      "text": "Add the string beans. Cover and cook for 3 to 5 minutes. Add salt only if needed."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
