  "id": "36971a9a-6f8e-5080-bd07-1bfcad503ebb",
  "slug": "luncheon-meat-caldereta",
  "name": "Luncheon Meat Caldereta",
  "recipe_type": "main",
  "brief_description": "Filipino caldereta recipe using luncheon meat",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a pan. Fry all sides of the cubed CDO Luncheon Meat until it browns. Set aside."
    },
    {
      "position": 2,
      "text": "Using the remaining oil (note: add more oil if needed), saute garlic and onion until the onion softens."
    },
    {
      "position": 3,
      "text": "Add the liver spread. Cook for 30 seconds."
    },
    {
      "position": 4,
      "text": "Pour tomato sauce and water. Let boil."
    },
    {
      "position": 5,
      "text": "Add potato and carrot. Cover the pan. Cook for 10 minutes."
    },
    {
      "position": 6,
      "text": "Add green peas, bell pepper, and fried luncheon meat. Stir. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Season with salt and ground black pepper."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
