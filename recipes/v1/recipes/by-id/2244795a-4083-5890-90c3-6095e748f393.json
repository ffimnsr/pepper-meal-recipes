  "id": "2244795a-4083-5890-90c3-6095e748f393",
  "slug": "healthy-bitter-melon-ginisang-ampalaya-recipe",
  "name": "Ginisang Ampalaya",
  "recipe_type": "side",
  "brief_description": "A simple Filipino sauteed bitter melon with eggs, tomatoes, garlic, and onion. Healthy, budget-friendly, and ready in under 20 minutes. Best served hot with steamed rice and fried fish on the side.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place the sliced ampalaya in a large bowl and set it aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan over medium heat."
    },
    {
      "position": 3,
      "text": "Saute the garlic, onion, and tomato until the onion softens and the tomato starts to break down."
    },
    {
      "position": 4,
      "text": "Add the ampalaya. Saute for 1 1/2 minutes."
    },
    {
      "position": 5,
      "text": "Season with ground black pepper."
    },
    {
      "position": 6,
      "text": "Pour in the beaten eggs. Let them sit for 20 seconds before stirring. Continue cooking for 1 minute."
    },
    {
      "position": 7,
      "text": "Season with Maggi Magic Sarap. Stir until well blended."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
