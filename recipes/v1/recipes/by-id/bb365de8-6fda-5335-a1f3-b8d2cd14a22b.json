  "id": "bb365de8-6fda-5335-a1f3-b8d2cd14a22b",
  "slug": "rosemary-crusted-roast-rack-of-lamb",
  "name": "Rosemary Crusted Roast Rack of Lamb",
  "recipe_type": null,
  "brief_description": "This is a Recipe for Rosemary Crusted Roast Rack of Lamb",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and ground black pepper all over the lamb. Let it stay for at least 12 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile preheat oven to 450F"
    },
    {
      "position": 3,
      "text": "Combine Panko bread crumbs, Rosemary, garlic, and olive oil in a bowl. Mix well. Rub the mixture all over the rack of lamb. Arrange on a baking tray and roast for 18 minutes."
    },
    {
      "position": 4,
      "text": "Remove from the oven. Let it cool down for 8 to 12 minutes."
    },
    {
      "position": 5,
      "text": "Slice the lamb between each bones."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 12,
