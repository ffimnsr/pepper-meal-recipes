  "id": "73123b2b-14ab-5be0-910f-39433cc88f97",
  "slug": "tofu-balls-with-miswa-and-patola-recipe",
  "name": "Tofu Balls Almondigas with Misua and Patola",
  "recipe_type": "soup",
  "brief_description": "Filipino tofu almondigas soup with patola and misua",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Start making the tofu balls by pressing the tofu to drain excess liquid. Mash it in a bowl and then add all the tofu ball ingredients. Mix well. Mold into balls. Note: you have the option to fry this in oil or to use an air fryer. This recipe suggests frying these in oil."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a pan. Fry the tofu balls until the exterior part turns medium brown. Remove from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Heat 3 tablespoons of cooking oil in a pot. (Note: you can utilize some of the oil used to cook the tofu balls.)"
    },
    {
      "position": 4,
      "text": "Saute garlic until it starts to brown. Add onion. Cook until the onion softens."
    },
    {
      "position": 5,
      "text": "Pour water into the pot. Let it boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Shrimp Cube and fried tofu. Cook for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Add patola. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Put the miswa into the pot. Stir and season with fish sauce and ground black pepper."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate and top with chopped green onions. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
