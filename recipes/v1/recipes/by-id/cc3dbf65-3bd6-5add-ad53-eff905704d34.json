  "schema_version": 1,
  "id": "cc3dbf65-3bd6-5add-ad53-eff905704d34",
  "slug": "beef-with-broccoli-recipe-knr-kls",
  "name": "Beef and Broccoli",
  "recipe_type": "main",
  "brief_description": "Tender sliced beef and crisp broccoli florets stir fried in a savory sauce made with soy sauce, oyster sauce, and ginger. The cornstarch marinade keeps the beef juicy while the quick steaming method keeps the broccoli green. Serve over steamed rice for a complete meal.",
  "cuisine": "Asian Cantonese Chinese Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the sauce ingredients in a bowl. Stir until the sugar dissolves and set aside."
    },
    {
      "position": 2,
      "text": "Combine the beef with all the marinade ingredients in a bowl. Mix until the beef is evenly coated. Let it sit for at least 10 minutes."
    },
    {
      "position": 3,
      "text": "Heat 1 tablespoon of cooking oil in a wok or pan over high heat. Stir fry the broccoli for 30 seconds. Pour in 2 tablespoons of water, cover the pan, and steam the broccoli for 1 minute. Remove from the pan and set aside."
    },
    {
      "position": 4,
      "text": "Heat the remaining cooking oil in the same pan over high heat. Fry the marinated beef for about 40 to 90 seconds per side or until lightly browned."
    },
    {
      "position": 5,
      "text": "Add the garlic and stir for 30 seconds until fragrant."
    },
    {
      "position": 6,
      "text": "Return the broccoli to the pan and toss to combine with the beef."
    },
    {
      "position": 7,
      "text": "Pour in the sauce mixture. Gently stir and cook over medium high heat for 1 to 2 minutes until the sauce thickens and coats the beef and broccoli."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with steamed rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 15,
  "rest_time_minutes": 10,
  "difficulty": "medium",
