  "id": "cccff69c-9a19-554c-95d7-68585d96b77a",
  "slug": "special-pork-kaldereta",
  "name": "Special Pork Kaldereta",
  "recipe_type": null,
  "brief_description": "This is a recipe for Special Pork Kaldereta.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Once the onion starts to get transparent, add the pork. Saute until the color if the meat gets light brown."
    },
    {
      "position": 4,
      "text": "Pour tomato sauce into the cooking pot and then add water. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork Cube. Stir. Cover and cook between low and medium heat until the pork becomes tender."
    },
    {
      "position": 6,
      "text": "Add carrots and olives. Cover. Cook for 3 to 4 minutes."
    },
    {
      "position": 7,
      "text": "Add potato and bell peppers. Stir."
    },
    {
      "position": 8,
      "text": "Put the liver spread into the pot. Cover and cook for 5 to 7 minutes."
    },
    {
      "position": 9,
      "text": "Add salt and ground black pepper. Stir."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Top with shredded cheese."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
