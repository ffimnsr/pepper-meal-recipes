  "slug": "grilled-liempo-with-fried-tofu",
  "name": "Grilled Liempo with Fried Tofu",
  "recipe_type": null,
  "brief_description": "This is a recipe for Grilled Liempo with Fried Tofu in spicy vinegar with sliced onions",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the spiced vinegar by combining all of its ingredients listed above. Stir and ensure that it gets well blended."
    },
    {
      "position": 2,
      "text": "Place the chopped pork belly and cubed fried tofu in a large bowl. Pour the spiced vinegar into the bowl. Toss until pork and tofu gets completely coated."
    },
    {
      "position": 3,
      "text": "Transfer to a serving bowl. Sprinkle green onions on top."
    },
    {
      "position": 4,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
