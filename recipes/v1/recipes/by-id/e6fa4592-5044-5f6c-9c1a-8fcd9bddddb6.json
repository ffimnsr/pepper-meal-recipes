  "id": "e6fa4592-5044-5f6c-9c1a-8fcd9bddddb6",
  "slug": "crispy-palabok",
  "name": "Crispy Palabok",
  "recipe_type": "main",
  "brief_description": "The crispy version of a savory, flavorful Filipino noodle dish enriched with the flavors of shrimp, garlic, fish flakes and pork.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat 2 \u00bd cups of cooking oil in a wok or cooking pot. Once the oil reaches 350F, fry the vermicelli until it gets puffed and crispy. Remove from the pan and let the oil drip off. Arrange on a serving plate. Also arrange half of the topping ingredients around the plate."
    },
    {
      "position": 2,
      "text": "Make the sauce by heating the oil in a wok. Saute the white part of the green onion until it softens. Add the ground pork. Saute until it browns."
    },
    {
      "position": 3,
      "text": "Add the annatto powder and flour. Continue cooking while stirring for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour the water into the wok. Bring it to a simmer."
    },
    {
      "position": 5,
      "text": "Add Knorr Shrimp Cube, smoked fish flakes, and anion powder. Continue to simmer while stirring for 3 to 5 minutes. Make sure to add more water if the sauce needs to be thinned down. Season with fish sauce and ground black pepper."
    },
    {
      "position": 6,
      "text": "Pour the sauce over the crispy noodles (Note: it is recommended to do this while the sauce is hot). Top with the remaining ingredients."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
