  "id": "55922568-4b7f-5fc1-ae8c-853313a63f04",
  "slug": "cream-of-asparagus-soup",
  "name": "Cream of Asparagus Soup",
  "recipe_type": "appetizer",
  "brief_description": "Cream of Asparagus Soup makes a rich and delicious appetizer. It has a nice thick texture and full of good flavor that will satisfy your taste buds. Aside from having theses positive qualities, Cream of Asparagus Soup is also easy to prepare and takes just a fraction of your time.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute the onion, asparagus, and garlic for 5 minutes."
    },
    {
      "position": 3,
      "text": "Pour-in water and chicken broth. Bring to a boil. cover and simmer for 15 minutes."
    },
    {
      "position": 4,
      "text": "Add the heavy cream."
    },
    {
      "position": 5,
      "text": "Start to refine the mixture using an immersion blender. Note: make sure that you take extra caution while blending the mixture."
    },
    {
      "position": 6,
      "text": "Once the mixture is smooth and creamy, add salt and pepper to taste.Stir."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
