  "id": "9dece5a5-4d32-523f-bf4c-db64827715de",
  "slug": "easy-chicken-parm",
  "name": "Easy Chicken Parm",
  "recipe_type": null,
  "brief_description": "Chicken Pam is a favorite in our family. We always have this during the weekend.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pound the chicken breast until half thick."
    },
    {
      "position": 2,
      "text": "Whisk the egg and milk together in a bowl. Dip the chicken breasts in the egg mixture and then roll on the bread crumbs. Do this on all 4 breasts."
    },
    {
      "position": 3,
      "text": "Heat oil in a fry pan. Brown the chicken by frying on the oil for 4 to 5 minutes per side in medium heat."
    },
    {
      "position": 4,
      "text": "Preheat oven to 350F."
    },
    {
      "position": 5,
      "text": "Grease a baking dish. Put the fried chicken on the baking dish. Pour marinara sauce over each chicken breast. Put Parmesan and mozzarella cheeses on top. Bake for 20 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven. Serve!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 15,
