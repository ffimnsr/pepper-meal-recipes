  "id": "16e95610-fedc-5490-bbc2-d255fc488cf3",
  "slug": "pocherong-baka-recipe",
  "name": "Pocherong Baka Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for beef pochero",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot saute garlic and onion until soft."
    },
    {
      "position": 3,
      "text": "Add beef chuck. Cook until light brown."
    },
    {
      "position": 4,
      "text": "Add the sliced chorizo. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour the diced tomatoes into the pot. Stir and cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour the beef broth into the pot, Let boil. Cover and cook until the beef becomes tender."
    },
    {
      "position": 7,
      "text": "Add the chickpeas, potato, and plantains. Stir. Cook for 6 minutes."
    },
    {
      "position": 8,
      "text": "Add the long green beans. Cook for 1 minute."
    },
    {
      "position": 9,
      "text": "Add cabbage and bok choy. Cover and cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Season with fish sauce and ground black pepper. Continue to cook for 3 minutes."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
