  "id": "0960bc59-41f1-597b-961a-baf5069538a7",
  "slug": "pepper-steak",
  "name": "Pepper Steak",
  "recipe_type": null,
  "brief_description": "Tender beef stir fried with bell peppers and onion in a savory sauce. Best served with steamed rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine the sliced beef sirloin along with all the marinade ingredients. Mix well. Cover the bowl and refrigerate for at least 3 hours."
    },
    {
      "position": 2,
      "text": "Combine all the sauce ingredients in a bowl. Stir until well blended. Set aside."
    },
    {
      "position": 3,
      "text": "Heat 1 tablespoon of cooking oil in a wok. Add the garlic. Saut\u00e9 for 10 seconds"
    },
    {
      "position": 4,
      "text": "Add the onion and bell peppers. Continue to saut\u00e9 until the layers from the onion separates (around 1 minute). Remove all the ingredients from the wok and set aside."
    },
    {
      "position": 5,
      "text": "Heat the remaining cooking oil in the same wok. Add the marinated beef one piece at a time. Cook each side for around 20 to 35 seconds."
    },
    {
      "position": 6,
      "text": "Add the stir-fried vegetables back into the wok. Stir-fry for 20 seconds."
    },
    {
      "position": 7,
      "text": "Pour the sauce mixture. Continue cooking using high heat while stirring until the sauce thickens."
    },
    {
      "position": 8,
      "text": "Season with white pepper powder. Serve hot with rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
