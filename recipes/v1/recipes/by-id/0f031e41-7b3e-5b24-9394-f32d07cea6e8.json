  "id": "0f031e41-7b3e-5b24-9394-f32d07cea6e8",
  "slug": "lechon-lomi",
  "name": "Lechon Lomi",
  "recipe_type": null,
  "brief_description": "Lechon Lomi is a version of pancit lomi that makes use of roasted pork which is popularly known in the Philippines as Lechon. Unlike our previous lomi recipe, this one is less complex in terms of ingredients and preparation, but it has same good comforting taste.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a wide cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and onion"
    },
    {
      "position": 3,
      "text": "Put-in the lechon and beef cube or powder. Cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in water. Let boil and simmer for 30 minutes."
    },
    {
      "position": 5,
      "text": "Add the soy sauce and fish sauce. Stir."
    },
    {
      "position": 6,
      "text": "Add the diluted cornstarch. Stir."
    },
    {
      "position": 7,
      "text": "Pour in the egg. Stir continuously until well incorporated."
    },
    {
      "position": 8,
      "text": "Put-in the noodles and ground black pepper. Stir and then cook in low to medium heat for 5 to 8 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to as serving bowl."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
