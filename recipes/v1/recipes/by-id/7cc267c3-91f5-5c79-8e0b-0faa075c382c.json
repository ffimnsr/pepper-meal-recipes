  "id": "7cc267c3-91f5-5c79-8e0b-0faa075c382c",
  "slug": "dinengdeng-with-bilong-bilong-recipe",
  "name": "Dinendeng with Bilong-bilong Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for dinengdeng with bilong-bilong or boiled vegetables with fried fish.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the water boils, add ginger, onion, and tomato. Cover and cook for 15 minutes."
    },
    {
      "position": 3,
      "text": "Pour the bagoong isda in the cooking pot. Stir."
    },
    {
      "position": 4,
      "text": "Add the ampalaya, okra, and sitaw. Stir. Let boil. Cover and then cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add the malunggay and fried moonfish. Cover and then cook in medium heat for 5 to 7 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
