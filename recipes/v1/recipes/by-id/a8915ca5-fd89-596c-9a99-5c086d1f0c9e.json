  "id": "a8915ca5-fd89-596c-9a99-5c086d1f0c9e",
  "slug": "bulalo-beef-pares-recipe",
  "name": "Bulalo Beef Pares Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Bulalo Beef Pares",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a pressure cooker. Let boil,"
    },
    {
      "position": 2,
      "text": "Add wedged onion, ground black pepper, and salt."
    },
    {
      "position": 3,
      "text": "Put the beef shank in the pressure cooker. Cover and pressure cook for 20 to 30 minutes."
    },
    {
      "position": 4,
      "text": "Remove the beef shank. Set the beef stock aside."
    },
    {
      "position": 5,
      "text": "In a clean pot, heat oil."
    },
    {
      "position": 6,
      "text": "Saute garlic, onion, and ginger."
    },
    {
      "position": 7,
      "text": "Add the boiled beef shank. Cook for 1 minute."
    },
    {
      "position": 8,
      "text": "Pour soy sauce and 1 3/4 cups of beef stock (water used to boil beef) into the pot. Let boil. Cover and then cook in medium heat for 8 minutes."
    },
    {
      "position": 9,
      "text": "Add star anise. Cook for 12 minutes. Remove the star anise from the pot."
    },
    {
      "position": 10,
      "text": "Add brown sugar. Stir. Cook for 3 to 5 minutes."
    },
    {
      "position": 11,
      "text": "Add salt and ground black pepper to taste."
    },
    {
      "position": 12,
      "text": "Transfer to a serving bowl. Serve with garlic fried rice and beef stock (soup)."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
