  "slug": "beef-stir-fry-with-chopped-broccoli-recipe",
  "name": "Beef Stir Fry with Chopped Broccoli",
  "recipe_type": null,
  "brief_description": "This is a version of stir fried beef with broccoli.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt and pepper on the beef. Add oyster sauce. Mix well and Marinate for 15 minutes."
    },
    {
      "position": 2,
      "text": "Add cornstarch on the marinated beef mixture. Mix well using your clean hands."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan."
    },
    {
      "position": 4,
      "text": "Stir fry the beef until both sides are done (about 10 minutes in high heat)."
    },
    {
      "position": 5,
      "text": "Add the chopped broccoli. Cook for 3 minutes more."
    },
    {
      "position": 6,
      "text": "Tranfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve with brown rice. Share and enjoy!"
    }
  ],
  "servings": 4,
