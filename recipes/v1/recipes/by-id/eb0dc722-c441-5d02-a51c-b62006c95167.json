  "name": "Salted Eggs and Tomato Salad",
  "recipe_type": "salad",
  "brief_description": "Salted Eggs and Tomato Salad or Itlog na maalat with kamatis is probably one of the easiest Filipino salad that I\u2019ve ever made. This dish is quick and very easy to prepare. It is best served as a side for grilled dishes.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Slice the salted eggs in half."
    },
    {
      "position": 2,
      "text": "Scrape the egg white and yolk then arrange in a bowl."
    },
    {
      "position": 3,
      "text": "Add the cubed tomatoes and fish sauce. Mix well."
    },
    {
      "position": 4,
      "text": "Serve. Share and enjoy!"
    }
