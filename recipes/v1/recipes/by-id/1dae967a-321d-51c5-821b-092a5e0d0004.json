  "id": "1dae967a-321d-51c5-821b-092a5e0d0004",
  "slug": "mie-goreng",
  "name": "Mie Goreng",
  "recipe_type": "main",
  "brief_description": "Mie Goreng, originally from Indonesia, is also enjoyed in the Philippines with local twists. It&#039;s a tasty stir-fried noodle dish with eggs, meat, and veggies, commonly found as street food, showcasing the diverse flavors of Southeast Asia.",
  "cuisine": "Indonesian Malaysian",
  "instructions": [
    {
      "position": 1,
      "text": "Start by mixing all the sauce ingredients and set aside."
    },
    {
      "position": 2,
      "text": "Boil 1 quart of water in a wok. Add Good Life Egg Noodles. Continue boiling while gently stirring for 2 minutes."
    },
    {
      "position": 3,
      "text": "Discard the water. Set the noodles aside."
    },
    {
      "position": 4,
      "text": "Heat 2 tablespoons of cooking oil. Pour the beaten eggs. Cook the eggs until they become firm."
    },
    {
      "position": 5,
      "text": "Cut them into pieces using the tip of your spatula or cooking spoon. Set aside."
    },
    {
      "position": 6,
      "text": "Heat the remaining oil in the same pan. Add the garlic. Saut\u00e9 until it starts to brown."
    },
    {
      "position": 7,
      "text": "Add the sliced chicken. Continue saut\u00e9ing for 2 minutes."
    },
    {
      "position": 8,
      "text": "Add the shrimp. Stir-fry for 1 minute."
    },
    {
      "position": 9,
      "text": "Add the green onions, bok choy, and mung bean sprouts. Cook this for 1 minute."
    },
    {
      "position": 10,
      "text": "Stir in the cooked Good Life Egg Noodles. Toss."
    },
    {
      "position": 11,
      "text": "Pour the sauce mixture into the wok. Toss again until all the ingredients are well blended."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Share and enjoy!"
    }
  ],
  "servings": null,
