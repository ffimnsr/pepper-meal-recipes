  "schema_version": 1,
  "id": "7ac1be7e-932a-56b5-a355-ce622c4c7fdd",
  "slug": "espasol",
  "name": "Espasol",
  "recipe_type": "dessert",
  "brief_description": "Espasol is a Filipino rice cake from Laguna made with toasted glutinous rice flour cooked in sweetened coconut milk with toasted grated coconut. The dough is shaped into cylinders, dusted in toasted sweet rice flour, and sliced into pieces. Enjoy it as a snack, dessert, or pasalubong.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour the coconut milk into a cooking pot and bring it to a boil over medium heat."
    },
    {
      "position": 2,
      "text": "Add the sugar and stir continuously for about 10 minutes, making sure it fully dissolves into the coconut milk."
    },
    {
      "position": 3,
      "text": "Add the toasted grated coconut to the pot and continue cooking for 5 minutes while stirring."
    },
    {
      "position": 4,
      "text": "Stir in the vanilla essence and the toasted glutinous rice flour. Cook while continuously folding the mixture for 40 minutes to 1 hour, or until it becomes very thick and pulls away from the sides of the pot."
    },
    {
      "position": 5,
      "text": "Remove the mixture from the pot and allow it to cool slightly until it is easy to handle."
    },
    {
      "position": 6,
      "text": "Spread the toasted sweet rice flour on a flat surface."
    },
    {
      "position": 7,
      "text": "Divide the mixture into portions and roll each one over the sweet rice flour to form a cylindrical shape."
    },
    {
      "position": 8,
      "text": "Slice according to your preferred size."
    },
    {
      "position": 9,
      "text": "Arrange on a serving plate or wrap individually in wax paper or banana leaves. Serve and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
