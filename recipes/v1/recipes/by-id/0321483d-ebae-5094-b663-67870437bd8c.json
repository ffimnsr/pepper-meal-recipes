  "id": "0321483d-ebae-5094-b663-67870437bd8c",
  "slug": "coke-pork-adobo",
  "name": "Coke Pork Adobo",
  "recipe_type": "main",
  "brief_description": "Pinoy pork adobo cooked with Coca-Cola.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat pan. Sear pork belly until it browns and enough oil is extracted. Note: stir the pork continuosly while searing."
    },
    {
      "position": 2,
      "text": "Push the pork on one side of the pan. Add garlic on the open area. Saute garlic for 30 seconds. Mix pork and garlic together. Cook for 1 minute."
    },
    {
      "position": 3,
      "text": "Pour-in soy sauce and vinegar. Let boil. Stir. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add whole peppercorn and dry bay leaves."
    },
    {
      "position": 5,
      "text": "Add cola drink. Let it boil. Cover the pan. Continue cooking in low heat until pork gets tender. Note: add water if needed."
    },
    {
      "position": 6,
      "text": "Season with salt (optional)."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
