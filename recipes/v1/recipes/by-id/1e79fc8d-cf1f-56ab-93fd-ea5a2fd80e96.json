  "id": "1e79fc8d-cf1f-56ab-93fd-ea5a2fd80e96",
  "slug": "no-bake-chocolate-fudge-tart-cake",
  "name": "No-Bake Chocolate Fudge Tart",
  "recipe_type": "dessert",
  "brief_description": "No-Bake Chocolate Fudge Tart is a quick and easy dessert recipe that makes use of semi-sweet chocolate, unsweetened chocolate, and an Oreo chocolate pie crust.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine half and half and 2 tablespoons of sugar in a mixing bowl then stir well."
    },
    {
      "position": 2,
      "text": "Heat the mixture in a microwave oven for 1 1/2 to 2 minutes"
    },
    {
      "position": 3,
      "text": "Put-in sweet and semi-sweet chopped chocolates and vanilla extract then mix thoroughly. You'll know that you are done when the mixture thickens."
    },
    {
      "position": 4,
      "text": "Pour-in the mixture on the chocolate cookie pie crust then refrigerate for at least 3 hours."
    },
    {
      "position": 5,
      "text": "Pour heavy whipping cream in a mixing bowl then beat until soft peaks forms. Add remaining teaspoon of sugar then continue mixing for a minute. Use an electric hand mixer of an electric stand mixer to make the job easier and faster."
    },
    {
      "position": 6,
      "text": "Top the refrigerated chocolate tart with the heavy whipping cream mixture by spreading the mixture gently in the center of the tart."
    },
    {
      "position": 7,
      "text": "Garnish with chocolate curls."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 180,
