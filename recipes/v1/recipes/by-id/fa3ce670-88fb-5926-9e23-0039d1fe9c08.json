  "id": "fa3ce670-88fb-5926-9e23-0039d1fe9c08",
  "slug": "pinakamasarap-na-pork-adobo",
  "name": "Most Delicious Pork Adobo Recipe",
  "recipe_type": "main",
  "brief_description": "This is the most delicious pork adobo version that I&#039;ve ever cooked.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the garlic into thin pieces. Set aside."
    },
    {
      "position": 2,
      "text": "Start making the garlic chips by heating the cooking oil in pan. Add all the garlic. Continue cooking using low heat while stirring occasionally until the garlic turns golden brown and crispy."
    },
    {
      "position": 3,
      "text": "Separate the oil from the garlic. Set aside. Note: the oil is now garlic infused and can be used to cook other dishes in the future."
    },
    {
      "position": 4,
      "text": "Pour 3 tablespoons of garlic-infused oil on the same pan. Saut\u00e9 the onion until it starts to caramelize."
    },
    {
      "position": 5,
      "text": "Add pork. Cook until the outer part turns medium brown in color."
    },
    {
      "position": 6,
      "text": "Add soy sauce, white vinegar, oyster sauce, lemon lime soda, and water. Let boil."
    },
    {
      "position": 7,
      "text": "Add cracked peppercorn, bay leaves, and half of the garlic chips. Cover the pan and continue cooking in low heat for 1 hour or until the pork gets tender."
    },
    {
      "position": 8,
      "text": "Remove the cover of the pan. Continue cooking until the sauce completely evaporates."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve with warm rice."
    },
    {
      "position": 10,
      "text": "Garnish with chopped parsley and remaining garlic chips"
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 5,
