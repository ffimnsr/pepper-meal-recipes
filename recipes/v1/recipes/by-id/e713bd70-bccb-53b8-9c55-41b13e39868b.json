  "id": "e713bd70-bccb-53b8-9c55-41b13e39868b",
  "slug": "nilagang-manok",
  "name": "Nilagang Manok Recipe",
  "recipe_type": "soup",
  "brief_description": "Boiled chicken soup with potato, banana, and bok choy.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a pot."
    },
    {
      "position": 2,
      "text": "Add onion and whole peppercorn. Pour-in chicken broth. Cover and let boil."
    },
    {
      "position": 3,
      "text": "Gently add chicken pieces. Boil in medium heat for 30 minutes."
    },
    {
      "position": 4,
      "text": "Add banana and potato. Cover and continue to boil for 12 minutes."
    },
    {
      "position": 5,
      "text": "Season with fish sauce."
    },
    {
      "position": 6,
      "text": "Add bok choy. Cover the pot and let the residual heat cook it for around 5 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve with white rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
