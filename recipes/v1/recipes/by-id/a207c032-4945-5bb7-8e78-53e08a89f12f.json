  "id": "a207c032-4945-5bb7-8e78-53e08a89f12f",
  "slug": "garlic-fried-chicken",
  "name": "Garlic Fried Chicken",
  "recipe_type": null,
  "brief_description": "Garlic Fried Chicken is one of the Best Fried Chicken Recipes available. This Fried Chicken variation uses a hefty amount of garlic powder",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine salt, ground black pepper, paprika, garlic powder, Panko Bread crumbs, and all-purpose flour in a mixing bowl. Mix well and set aside."
    },
    {
      "position": 2,
      "text": "Combine the egg and milk in another bowl, and whisk. Set aside."
    },
    {
      "position": 3,
      "text": "Dip the chicken slices in the egg and milk mixture, and then roll in the flour, bredcrumbs, salt, pepper, and paprika mixture until all the sides are evenly coated."
    },
    {
      "position": 4,
      "text": "Heat a deep cooking pot and pour-in the cooking oil."
    },
    {
      "position": 5,
      "text": "When the oil becomes hot, deep-fry the coated chicken in medium heat for 10 to 15 minutes or until the color turns golden brown. Note: Do not use high heat as it will cook the outer part of the chicken right away while leaving the inside uncooked."
    },
    {
      "position": 6,
      "text": "Turn-off the heat, and then remove the garlic fried chicken from the pot. Let the excess oil drip."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate and serve with KFC gravy."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 10,
