  "id": "26f548ed-3f0d-5207-bc54-f764c172a02b",
  "slug": "apple-cake-recipe",
  "name": "Apple Cake Recipe",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for apple cake.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 325F"
    },
    {
      "position": 2,
      "text": "Combine flour, cinnamon powder, sugar, and baking soda in a bowl. Mix well using a wire whisk."
    },
    {
      "position": 3,
      "text": "Using a hand blender or a stand mixer, whisk the eggs on a separate bowl. Stir-in the vanilla extract and oil. Continue to whisk until all ingredients are well blended."
    },
    {
      "position": 4,
      "text": "Gradually add the dry ingredient mixture in step 1 while whisking. Do this until all the ingredients are well blended. Fold-in the apples and walnuts."
    },
    {
      "position": 5,
      "text": "Grease a bundt pan with shortening. Arrange the cake mixture in the pan and bake for 80 to 85 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven and let it cool down."
    },
    {
      "position": 7,
      "text": "Take the cake out of the pan and arrange in a wide plate."
    },
    {
      "position": 8,
      "text": "Meanwhile, prepare the glaze by combining caster sugar, honey, and milk in a bowl. Mix well using a spoon."
    },
    {
      "position": 9,
      "text": "Glaze the cake with the glaze mixture."
    },
    {
      "position": 10,
      "text": "Chill for 2 hours in the refrigerator."
    },
    {
      "position": 11,
      "text": "Serve with coffee or hot chocolate."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
