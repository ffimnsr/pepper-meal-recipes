  "slug": "adobong-mani-fried-peanuts-recipe",
  "name": "Adobong Mani Recipe",
  "recipe_type": "appetizer",
  "brief_description": "This Adobong Mani Recipe will give you nice tasting fried peanuts for appetizer or snack. It has a well balanced flavor that you will like.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in cooking oil."
    },
    {
      "position": 2,
      "text": "When the oil is hot, put-in the garlic and fry until the color turns golden to medium brown."
    },
    {
      "position": 3,
      "text": "Remove the garlic and set aside."
    },
    {
      "position": 4,
      "text": "Adjust the heat to low then fry the peanuts while stirring occasionally. This should take about 10 to 14 minutes."
    },
    {
      "position": 5,
      "text": "Take the peanuts out of the cooking pot and drain excess oil using a sieve."
    },
    {
      "position": 6,
      "text": "Transfer the peanuts to a mixing bowl. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 14,
