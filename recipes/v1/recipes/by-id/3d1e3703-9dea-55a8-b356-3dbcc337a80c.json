  "id": "3d1e3703-9dea-55a8-b356-3dbcc337a80c",
  "slug": "talong-bola-bola",
  "name": "Eggplant Meatballs Talong Bola Bola Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Easy meatballs composed of eggplant and ground pork with a rich and creamy dipping sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add eggplant. Cover and continue to boil for 6 minutes or until tender. Remove from the pot and let it cool down. Peel the skin off the eggplant and chop into small pieces."
    },
    {
      "position": 2,
      "text": "Arrange the eggplant in a bowl. Add ground pork, onion, salt, ground black pepper, garlic powder, egg, and all-purpose flour. Mix until all ingredients are well blended."
    },
    {
      "position": 3,
      "text": "Heat oil in a cooking pot using low fire."
    },
    {
      "position": 4,
      "text": "Scoop a portion of the mixture. Dredge in breadcrumbs. Deep-fry for 8 minutes. Remove from the pot and arrange on a wire rack. Note: continue to perform this step until the entire mixture is consumed."
    },
    {
      "position": 5,
      "text": "Prepare the dipping sauce by combining mayonnaise and banana ketchup. Mix well."
    },
    {
      "position": 6,
      "text": "Transfer the fried meatballs and dipping sauce on a serving plate and bowl respectively. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
