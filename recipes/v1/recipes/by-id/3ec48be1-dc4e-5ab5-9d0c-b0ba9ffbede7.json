  "id": "3ec48be1-dc4e-5ab5-9d0c-b0ba9ffbede7",
  "slug": "cheeseburger-and-hotdog-sandwich-recipe",
  "name": "Cheeseburger and Hotdog Sandwich Recipe",
  "recipe_type": "snack",
  "brief_description": "Cheeseburger with yummy spread and my version of Jolly hotdog sandwich",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Make the cheeseburger by combining the ground beef, salt, pepper, and onion powder. Mix well and scoop \u00bc cup of the mixture, roll it, and then flatten to form a patty. Do this until all the meat mixture is consumer."
    },
    {
      "position": 2,
      "text": "Heat a pan and spray cooking oil. Toast the buns until light brown. Remove from the pan and set aside."
    },
    {
      "position": 3,
      "text": "Heat cooking oil on the same pan. Fry the patties until brown."
    },
    {
      "position": 4,
      "text": "Top each patty with American cheese."
    },
    {
      "position": 5,
      "text": "Spread the mayo mixture on the bun and assemble the cheeseburger."
    },
    {
      "position": 6,
      "text": "Start to make the hotdog sandwich by boiling the beef franks for 5 minutes."
    },
    {
      "position": 7,
      "text": "Make the cheese sauce mixture by combining cheese sauce and Lady's Choice Mayonnaise. Mix well."
    },
    {
      "position": 8,
      "text": "Arrange the beef franks onto the hotdog bun and generously pour the cheese mixture over it. Top with bacon bits and shredded cheese."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
