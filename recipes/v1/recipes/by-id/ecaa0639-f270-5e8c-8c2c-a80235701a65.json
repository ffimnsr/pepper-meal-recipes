  "id": "ecaa0639-f270-5e8c-8c2c-a80235701a65",
  "slug": "ginataang-salmon",
  "name": "Ginataang Salmon Recipe",
  "recipe_type": null,
  "brief_description": "This ginataang salmon recipe pertains to steak cut salmon cooked in coconut milk. This is a rich and creamy Asian salmon dish that tastes great",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the salmon slices flat in a pan."
    },
    {
      "position": 2,
      "text": "Put-in the red and green chillies, garlic, ginger, onion, ground black pepper, fish sauce and water."
    },
    {
      "position": 3,
      "text": "Turn-on the heat and let boil."
    },
    {
      "position": 4,
      "text": "Pour-in the vinegar. Let it cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add the coconut cream. Gently stir. cover and bring to a boil. Simmer for 20 minutes or until the liquid reduces to half."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
