  "id": "0c242d32-9755-50f6-9ae4-17d2741f7597",
  "slug": "pinatisang-manok-recipe",
  "name": "Pinatisang Manok",
  "recipe_type": null,
  "brief_description": "Pinatisang Manok or chicken cooked in fish sauce is a simple chicken dish that resembles Chicken Tinola in some way. This is one of the traditional Filipino dishes that our grand parents enjoy during their time.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then and add the bacon fat."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the ginger for 1 to 2 minutes."
    },
    {
      "position": 3,
      "text": "Add the chicken and cook until outer part turns brown."
    },
    {
      "position": 4,
      "text": "Pour-in the fish sauce and cook in low heat for 5 minutes."
    },
    {
      "position": 5,
      "text": "Pour the chicken broth and increase the heat to medium then let boil. Simmer for 30 minutes or until the chicken is tender and at least half of the liquid evaporates."
    },
    {
      "position": 6,
      "text": "Add the spinach and cook for a few seconds."
    },
    {
      "position": 7,
      "text": "Turn of heat and cover for at least 2 minutes to further cook the spinach."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl and serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
