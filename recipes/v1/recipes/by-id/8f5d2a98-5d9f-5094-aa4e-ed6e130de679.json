  "id": "8f5d2a98-5d9f-5094-aa4e-ed6e130de679",
  "slug": "seared-scallops-in-herbed-butter-sauce-recipe",
  "name": "Seared Scallops in Herbed Butter Sauce Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Seared Scallops in Herbed Butter Sauce.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt 1-tablespoon butter in a pan. Add 2 tablespoons olive oil."
    },
    {
      "position": 2,
      "text": "Once the butter and oil gets hot, sear both sides of the scallops until it turns light brown in color. Remove the seared scallops from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Prepare the herbed sauce by melting the remaining butter in the same pan and add the remaining olive oil."
    },
    {
      "position": 4,
      "text": "Saute the onion until soft."
    },
    {
      "position": 5,
      "text": "Pour the white wine and clam juice. Let boil."
    },
    {
      "position": 6,
      "text": "Add the parsley and lemon juice. Continue to cook in medium heat until the liquid reduces to half."
    },
    {
      "position": 7,
      "text": "Add the seared scallops back into the pan. Sprinkle salt and ground black pepper. Stir. Cook for 1 minute."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
