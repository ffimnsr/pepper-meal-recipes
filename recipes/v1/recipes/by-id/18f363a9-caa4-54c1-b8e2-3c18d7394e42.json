  "id": "18f363a9-caa4-54c1-b8e2-3c18d7394e42",
  "slug": "carne-norte-corned-beef-baked-macaroni",
  "name": "Corned Beef Baked Macaroni",
  "recipe_type": "main",
  "brief_description": "A hearty Filipino-style baked macaroni dish featuring savory corned beef in rich tomato sauce, layered with mozzarella and ricotta cheeses, then baked until bubbly and golden.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the sauce by heating oil in a pot."
    },
    {
      "position": 2,
      "text": "Saute onion and garlic."
    },
    {
      "position": 3,
      "text": "Once the onion becomes soft, add the corned beef. Stir and cook for 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Pour tomato sauce. Stir. Add beef broth. Let boil. Cover and continue to cook for 20 minutes using low to medium heat."
    },
    {
      "position": 5,
      "text": "Add tomato paste, salt, ground black pepper, and sugar. Stir. Continue to cook for 5 minutes. Set aside."
    },
    {
      "position": 6,
      "text": "Prepare the macaroni by boiling water in a cooking pot. Add 1/4 teaspoon salt."
    },
    {
      "position": 7,
      "text": "Once the water boils, put the macaroni into the pot and cook for 7 minutes."
    },
    {
      "position": 8,
      "text": "Drain the water from the pot. Combine macaroni with meaty tomato sauce. Add the cheeses and mix well. Transfer the mixture into a baking pan."
    },
    {
      "position": 9,
      "text": "Preheat oven to 375F. Bake for 15 minutes."
    },
    {
      "position": 10,
      "text": "Remove from the oven and serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 43,
  "preparation_time_minutes": 10,
