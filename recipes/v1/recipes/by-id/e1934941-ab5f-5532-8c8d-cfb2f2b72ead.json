  "id": "e1934941-ab5f-5532-8c8d-cfb2f2b72ead",
  "slug": "chicken-mechado",
  "name": "Chicken Mechado",
  "recipe_type": "main",
  "brief_description": "Chicken stew with bell peppers and potato cooked in tomato sauce",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Fry the potatoes for 3 minutes per side. Remove from the pan. Set aside."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 onion and garlic until the former softens."
    },
    {
      "position": 3,
      "text": "Add chicken pieces. Saut\u00e9 for 3 to 4 minutes."
    },
    {
      "position": 4,
      "text": "Add the soy sauce. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Add tomato sauce and water. Let it boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Chicken Cube and laurel leaves. Cover the pan. Adjust the heat to the lowest setting. Continue cooking for 40 minutes."
    },
    {
      "position": 7,
      "text": "Add lemon zest and bell pepper. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Put the sugar and fried potato in the pot. Cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 10,
      "text": "Serve warm with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
