  "id": "d2cc35de-3642-5454-8d61-dd67bc51b134",
  "slug": "chicken-spring-roll-recipe",
  "name": "Chicken Spring Roll Recipe",
  "recipe_type": null,
  "brief_description": "Spring rolls made of ground chicken deep fried until golden brown.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large mixing bowl, combine chicken, onion, carrot, parsley, garlic powder, sesame oil, salt, and pepper. Mix well."
    },
    {
      "position": 2,
      "text": "Scoop about 2 to 3 tablespoons of the mixture and then arrange on top of a spring roll wrapper. Wrap the mixture and then seal the edge by brushing the beaten egg mixture in the end of the wrapper."
    },
    {
      "position": 3,
      "text": "Heat the cooking oil in a deep frying pan."
    },
    {
      "position": 4,
      "text": "When the oil becomes hot, deep fry the wrapped spring rolls in low to medium heat for about 10 to 12 minutes or until the color turns golden brown."
    },
    {
      "position": 5,
      "text": "Transfer the fried chicken spring roll in a plate lined with paper towel."
    },
    {
      "position": 6,
      "text": "Serve with sweet and sour sauce or banana ketchup."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 10,
