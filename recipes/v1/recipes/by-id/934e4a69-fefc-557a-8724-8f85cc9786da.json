  "id": "934e4a69-fefc-557a-8724-8f85cc9786da",
  "slug": "sarciado",
  "name": "Sarciado",
  "recipe_type": "main",
  "brief_description": "Crispy fried fish simmered in a savory tomato and egg sauce with garlic, onions, and green onions. A comforting Filipino favorite perfect with warm rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub Maggi Magic Sarap all over the fish."
    },
    {
      "position": 2,
      "text": "Heat \u00be cup of cooking oil in a pan. Fry both sides of the fish until until the color turns golden brown. Remove the fish from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Reduce the oil that was used to fry the fish to 3 tablespoons. Saute the garlic, onion, and tomato."
    },
    {
      "position": 4,
      "text": "Season with ground black pepper and fish sauce once the onion and tomatoes soften."
    },
    {
      "position": 5,
      "text": "Pour water. Let it boil. Simmer for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add the chopped green onions and pour the beaten eggs. Quickly stir. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Put the fried fish back into the pan. Continue cooking for 2 to 3 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
