  "id": "6969cc30-b27d-546f-88bb-98a90e45e987",
  "slug": "roasted-okra-recipe",
  "name": "Roasted Okra",
  "recipe_type": "side",
  "brief_description": "This is a Roast Okra Recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine okra and olive oil. Shake the bowl so that the oil coats the vegetable."
    },
    {
      "position": 2,
      "text": "Sprinkle salt and pepper. Shake again to distribute."
    },
    {
      "position": 3,
      "text": "Arrange the okra in a cookie sheet or oven tray."
    },
    {
      "position": 4,
      "text": "Set the oven to broil (about 500 degrees Fahrenheit)."
    },
    {
      "position": 5,
      "text": "Put the okra in the oven and roast/broil for 10 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven and transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve as an appetizer. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
