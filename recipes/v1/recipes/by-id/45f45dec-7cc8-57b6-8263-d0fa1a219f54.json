  "id": "45f45dec-7cc8-57b6-8263-d0fa1a219f54",
  "slug": "beef-stew-recipe",
  "name": "Beef Stew Recipe",
  "recipe_type": null,
  "brief_description": "This Beef Stew Recipe is comforting. It is simple yet all the flavors work in harmony.Beef Stew is made by simmering beef in liquid until it becomes tender.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Sear the beef, add onion, garlic, bay leaves, ground cloves, and paprika. Stir and cook for 2 minutes."
    },
    {
      "position": 3,
      "text": "Pour-in beef broth and let boil. Simmer until beef becomes tender.Note: This can take up to more than 1 hour depending on the meat that you will use. Add water as needed."
    },
    {
      "position": 4,
      "text": "Add celery ribs, carrots, potatoes, salt, and pepper. Stir and cook for 6 to 10 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in diluted cornstarch. Stir and cook for a minute more."
    },
    {
      "position": 6,
      "text": "Turn off heat and transfer to a serving bowl."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
