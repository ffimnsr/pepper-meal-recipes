  "id": "3c9de4ca-23c7-576c-91ac-ca992709c00b",
  "slug": "pork-adobo-with-boiled-eggs",
  "name": "Pork Adobo with Boiled Eggs",
  "recipe_type": "main",
  "brief_description": "Pork Adobo with Boiled Eggs is a Filipino pork adobo cooked in soy sauce and vinegar, then finished with hard boiled eggs that soak up the sauce. Oyster sauce and a splash of dry sherry go in along with the usual garlic, peppercorns, and bay leaves. Serve it over warm rice for a filling everyday meal.",
  "cuisine": "Asian Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, combine the pork slices with 4 tablespoons of the soy sauce. Coat the pork with the soy sauce, then marinate for 1 hour."
    },
    {
      "position": 2,
      "text": "Heat a wide cooking pot and pour in the cooking oil."
    },
    {
      "position": 3,
      "text": "When the oil becomes hot, add the garlic. Add the whole peppercorn and dried bay leaves. Continue cooking until the garlic turns light to golden brown."
    },
    {
      "position": 4,
      "text": "Add the pork along with the remaining marinade and the sherry. Cook for about 5 minutes."
    },
    {
      "position": 5,
      "text": "Pour in the remaining soy sauce, oyster sauce, and water. Let it boil, then simmer for about 40 minutes."
    },
    {
      "position": 6,
      "text": "Add the vinegar. Allow it to re-boil."
    },
    {
      "position": 7,
      "text": "Add the sugar, then stir."
    },
    {
      "position": 8,
      "text": "Add the boiled eggs and cook for 2 to 3 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve with warm rice. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 60,
  "difficulty": "hard",
