  "slug": "food-meat-holiday-dish-meatloaf-recipe",
  "name": "Meatloaf Recipe",
  "recipe_type": null,
  "brief_description": "How to make Meatloaf with cooking video",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the ground beef, minced celery, and minced onions in a mixing bowl then mix well."
    },
    {
      "position": 2,
      "text": "Add the eggs, minced garlic, bread crumbs, salt, ground black pepper, worcestershire sauce, mustard powder, and tomato paste then mix all the ingredients together"
    },
    {
      "position": 3,
      "text": "Transfer the mixed ingredients in a loaf pan."
    },
    {
      "position": 4,
      "text": "Spread the ketchup evenly on top of the meatloaf"
    },
    {
      "position": 5,
      "text": "Preheat oven to 350 degrees Fahrenheit and bake for 75 minutes"
    },
    {
      "position": 6,
      "text": "Remove from the oven and transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 75,
