  "id": "59421178-5785-5ca9-b4c2-11603770bb61",
  "slug": "ginataang-langka-with-malunggay-and-dilis",
  "name": "Ginataang Langka with Malunggay and Dilis",
  "recipe_type": "main",
  "brief_description": "Young jackfruit, moringa leaves, and dried anchovies cooked in coconut milk with chili peppers.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute onion and garlic."
    },
    {
      "position": 3,
      "text": "Once the onion softens, add anchovies. Cook for 30 seconds."
    },
    {
      "position": 4,
      "text": "Add the jackfruit. Continue to saute for 3 minutes."
    },
    {
      "position": 5,
      "text": "Pour coconut milk into the pan. Stir. Cover and cook in medium heat until the sauce reduces to half."
    },
    {
      "position": 6,
      "text": "Add malunggay leaves. Cook until the coconut milk evaporates."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and patis."
    },
    {
      "position": 8,
      "text": "Serve with warm rice. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
