  "id": "2e95631f-4978-506b-a371-2be9aad08d75",
  "slug": "adobong-pusit-sa-gata",
  "name": "Adobong Pusit sa Gata",
  "recipe_type": null,
  "brief_description": "This is a recipe for Adobong Pusit sa Gata",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Add the garlic. Cook until it turns light brown."
    },
    {
      "position": 3,
      "text": "Stir the squid into the pot. Partially cook the squid for 2 minutes. Remove the squid from the pot and put in a clean plate. Set aside."
    },
    {
      "position": 4,
      "text": "Pour the coconut milk into the pot. Let boil."
    },
    {
      "position": 5,
      "text": "Add soy sauce, vinegar, bay leaves, and ground black pepper. Cover and cook until the liquid reduces to half."
    },
    {
      "position": 6,
      "text": "Add the squid back into the pot and then pour-in 1 teaspoon of fish sauce. Cover and continue to cook for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Taste to see if the saltiness is just about right. You can add a tablespoon more of fish sauce if needed."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve with warm rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
