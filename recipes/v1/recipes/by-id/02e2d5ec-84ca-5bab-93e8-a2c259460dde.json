  "id": "02e2d5ec-84ca-5bab-93e8-a2c259460dde",
  "slug": "how-to-cook-bicol-express-knr-pc",
  "name": "Bicol Express",
  "recipe_type": "main",
  "brief_description": "This is a guide on how to cook Bicol express using pork belly and balaw or salted shrimp.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine coconut milk, onion, ginger, garlic, and pork in a cooking pot. Stir. Turn the heat on and let the coconut milk boil. Cover the pot and continue to boil in medium heat until the liquid reduces to half. Note: Stir the mixture every 7 minutes to prevent lumps from forming."
    },
    {
      "position": 2,
      "text": "Add balaw or bagoong alamang, chili peppers, coconut cream, and Knorr pork cube. Stir. Continue to boil until the coconut milk reduces to your desired consistency.&nbsp;"
    },
    {
      "position": 3,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
