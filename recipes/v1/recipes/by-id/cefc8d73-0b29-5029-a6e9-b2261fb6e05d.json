  "id": "cefc8d73-0b29-5029-a6e9-b2261fb6e05d",
  "slug": "paksiw-na-lechon-manok",
  "name": "Paksiw na Lechon Manok",
  "recipe_type": null,
  "brief_description": "This is a recipe for lechon manok paksiw.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Sauce the garlic and onion until the onion gets soft."
    },
    {
      "position": 3,
      "text": "Add the lechon manok (set roasted chicken) and pour-in water and lechon manok sauce. Stir and let boil."
    },
    {
      "position": 4,
      "text": "Add the peppercorn, bay leaves, chicken bouillon, and soy sauce. cover and cook in medium heat for 30 minutes."
    },
    {
      "position": 5,
      "text": "Pour the vinegar in the pot. Let the mixture re-boil. Stir and add the sugar and salt."
    },
    {
      "position": 6,
      "text": "Cook for 10 to 15 minutes more or until the sauce thickens to your desired consistency."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
