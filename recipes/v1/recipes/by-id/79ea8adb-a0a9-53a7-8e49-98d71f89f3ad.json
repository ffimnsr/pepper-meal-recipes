  "id": "79ea8adb-a0a9-53a7-8e49-98d71f89f3ad",
  "slug": "roasted-pork-belly-lechon",
  "name": "Roasted Pork Belly (Lechon Liempo)",
  "recipe_type": null,
  "brief_description": "Roasted Pork Belly or Lechon Liempo is a good and simpler way to make Filipino Style Roast Pork. It is deliciously crunchy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Lay the pork belly on a flat surface in a way that the side with the skin is facing down. Rub the salt and pepper all over the top of the pork belly (meat part). Let it stand for 15 minutes."
    },
    {
      "position": 2,
      "text": "Arrange the lemongrass, scallions, and onion slices on one one of the belly. Roll the side where you had the lemongrass all the way to the opposite side until a spiral shape is formed. Secure the rolled pork belly by tying it with a kitchen twine. Rub the oil all over the skin."
    },
    {
      "position": 3,
      "text": "Preheat oven to 350F. Arrange the pork belly in a roasting pan and roast for 2 hours."
    },
    {
      "position": 4,
      "text": "Remove the belly from the oven and brush with fresh milk. Put it back into the oven and continue to roast for 30 minutes or until the skin is brown and crispy."
    },
    {
      "position": 5,
      "text": "Remove from the oven. Let it cool down for 15 minutes. Slice the Roasted Pork Belly and serve with homemade lechon sauce."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 180,
  "preparation_time_minutes": 15,
