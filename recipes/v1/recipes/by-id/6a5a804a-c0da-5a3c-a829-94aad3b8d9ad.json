  "id": "6a5a804a-c0da-5a3c-a829-94aad3b8d9ad",
  "slug": "make-eggs-benedict",
  "name": "Eggs Benedict",
  "recipe_type": null,
  "brief_description": "Classic eggs Benedict with homemade Hollandaise sauce, crispy bacon, and poached eggs on toasted English muffins.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "To make Eggs Benedict, start with the Hollandaise sauce. Pour an inch of water into the bottom of a double boiler and place over medium-low heat to simmer."
    },
    {
      "position": 2,
      "text": "Mix the egg yolks with lemon juice in a bowl, then transfer to the top of the double boiler. Whisk vigorously while adding the butter. Once the butter has melted, season with salt and pepper, remove from heat, and set aside."
    },
    {
      "position": 3,
      "text": "Set the oven to broil and toast the English muffin halves until golden. Remove and set aside. Meanwhile, heat a skillet over medium-high heat and add the bacon slices. If they stick, add a little olive oil and fry until crispy. Top the toasted muffins with the bacon."
    },
    {
      "position": 4,
      "text": "To poach the eggs, fill a pan halfway with water and bring to a gentle simmer over medium-low heat; do not boil. Crack an egg into a bowl, keeping the yolk intact, then gently slide it into the water. Repeat with the remaining eggs. When the whites are set but the yolks are still runny, remove with a slotted spoon and place on top of the bacon."
    },
    {
      "position": 5,
      "text": "Drizzle the Hollandaise sauce over the poached eggs and muffins. Serve immediately and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
