  "id": "4c537aad-e449-5a4f-8b85-5eba62b4d17a",
  "slug": "ube-halaya-with-cheese-recipe",
  "name": "Ube Halaya with Cheese",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Ube Halaya with Cheese",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour coconut milk in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Stir and add the condensed milk."
    },
    {
      "position": 3,
      "text": "Once the mixture starts to boil, add the grated purple yam and ube flavoring. Continue to cook in medium heat while continuously stirring for 30 minutes."
    },
    {
      "position": 4,
      "text": "Add butter. Stir. Cook until the mixture reaches your desired thickness. (I usually cook it for 10 to 12 minutes after adding butter)."
    },
    {
      "position": 5,
      "text": "Transfer to a container. Top with shredded cheese."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
