{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "fa7b9c0c-09b3-5179-aca1-1d0b818c527d",
  "slug": "peach-mango-nuggets",
  "name": "Peach Mango Nuggets",
  "recipe_type": "dessert",
  "brief_description": "Deep-fried Mini Peach Mango Pie with a Crispy Crust.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the filling. Combine mango, peaches, sugar, cinnamon powder, and cornstarch in a bowl. Mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Flatten a slice of bread using a rolling pin. Slice the flattened bread in half."
    },
    {
      "position": 3,
      "text": "Make a symmetrical fold and seal the edges by rubbing water and then pressing against each other. Leave one side open."
    },
    {
      "position": 4,
      "text": "Fill the pocket with enough peach-mango filling. Seal. You now have your peach mango nuggets."
    },
    {
      "position": 5,
      "text": "Heat oil in a pot."
    },
    {
      "position": 6,
      "text": "Beat eggs in a bow. Dip nuggets in egg and then roll over bred crumbs until completely coated. You can press the crumbs lightly towards the nuggets to ensure that it adheres well."
    },
    {
      "position": 7,
      "text": "Fry one side in medium heat until it turns golden brown. Do the same to the opposite side."
    },
    {
      "position": 8,
      "text": "Remove from the pot and place on a plate lined with paper towel."
    },
    {
      "position": 9,
      "text": "Serve for dessert. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 10,
