  "id": "493ee5e8-026d-5084-826c-7d87ee5783bf",
  "slug": "chicken-egg-fried-rice-recipe",
  "name": "Chicken and Egg Fried Rice",
  "recipe_type": "main",
  "brief_description": "This chicken and egg fried rice combines tender marinated chicken, fluffy scrambled eggs, and day-old rice tossed together in a hot pan. Ready in under 30 minutes, it is a satisfying one-pan meal.",
  "cuisine": "Asian Chinese Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the diced chicken breast and Maggi Savor in a bowl. Mix well and let it sit for 5 minutes."
    },
    {
      "position": 2,
      "text": "Heat 2 tablespoons of cooking oil in a pan over medium-high heat. Pour in the beaten eggs and cook while stirring until scrambled and firm. Break into small pieces, then set aside."
    },
    {
      "position": 3,
      "text": "Heat the remaining oil in the same pan. Add the marinated chicken and cook for 3 to 5 minutes or until cooked through. Smaller pieces cook faster and mix better with the rice."
    },
    {
      "position": 4,
      "text": "Add the garlic and cook until it starts to brown."
    },
    {
      "position": 5,
      "text": "Add the green peas and stir to combine."
    },
    {
      "position": 6,
      "text": "Put the leftover rice into the pan. Toss to combine and cook over high heat for 2 minutes. Leftover rice works best because it is less sticky."
    },
    {
      "position": 7,
      "text": "Add the Maggi Magic Sarap and continue cooking for 3 minutes while tossing."
    },
    {
      "position": 8,
      "text": "Return the cooked eggs to the pan. Add the green onions and toss to combine."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate and serve."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 5,
  "difficulty": "medium",
