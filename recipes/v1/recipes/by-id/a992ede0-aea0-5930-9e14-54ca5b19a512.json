  "id": "a992ede0-aea0-5930-9e14-54ca5b19a512",
  "slug": "filipino-chicken-pasta-alfredo",
  "name": "Filipino Chicken Pasta Alfredo",
  "recipe_type": "main",
  "brief_description": "The classic chicken pasta alfredo is famous for its creamy and satisfyingly savory quality. It can also be hearty with our yummy fettuccine",
  "cuisine": "American Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Cook pasta according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Make the creamy sauce by melting butter in a cooking pot. Saut\u00e9 onion and garlic until the onion softens."
    },
    {
      "position": 3,
      "text": "Add CDO chicken flakes. Continue cooking for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour the all-purpose cream into the pot. Let it boil. Adjust the heat to low setting. Continue cooking while stirring occasionally until the sauce thicken to your desired consistency."
    },
    {
      "position": 5,
      "text": "Add parmesan cheese. Stir."
    },
    {
      "position": 6,
      "text": "Put the cooked pasta unto the cooking pot with the sauce. Toss until well blended. Season with chopped parsley."
    },
    {
      "position": 7,
      "text": "Transfer to a pasta bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
