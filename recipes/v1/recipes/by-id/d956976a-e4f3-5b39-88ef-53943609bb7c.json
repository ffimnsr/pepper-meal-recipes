  "id": "d956976a-e4f3-5b39-88ef-53943609bb7c",
  "slug": "homemade-ranch-dressing-recipe",
  "name": "Homemade Ranch Dressing Recipe",
  "recipe_type": "salad",
  "brief_description": "Ranch Dressing has always been my favorite for salads and even dips. It goes well with buffalo chicken wings, French fries, and even a stick of celery; it also make potato chips taste more exciting.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the mayonnaise, sour cream, and buttermilk in a bowl."
    },
    {
      "position": 2,
      "text": "Add vinegar, Sriracha sauce, salt, pepper, and garlic powder."
    },
    {
      "position": 3,
      "text": "Put-in the chopped chives and dill. Mix well."
    },
    {
      "position": 4,
      "text": "Place in the fridge to chill for 1 hour. Tranfer to a serving bowl."
    },
    {
      "position": 5,
      "text": "serve with onion rings, fries, potato chips, potato wedges or buffalo chicken wings."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
