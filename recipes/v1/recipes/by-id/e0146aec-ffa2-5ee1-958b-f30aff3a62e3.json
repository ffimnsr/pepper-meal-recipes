  "slug": "ginisang-pechay-sauteed-bok-choy",
  "name": "Ginisang Pechay (Saut\u00e9ed Bok Choy)",
  "recipe_type": null,
  "brief_description": "Ginisang Pechay is simply Saut\u00e9ed Bok Choy. This healthy vegetable is classified as a cabbage. This Filipino bok choy recipe is simple and delicious.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the pan and put-in the cooking oil"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic, onion, and tomato"
    },
    {
      "position": 3,
      "text": "Add the pork and cook for 5 minutes"
    },
    {
      "position": 4,
      "text": "Put-in the fish sauce and ground black pepper"
    },
    {
      "position": 5,
      "text": "Add the water and simmer for 10 to 15 minutes"
    },
    {
      "position": 6,
      "text": "When the pork is tender enough, put-in the pechay or bok choy. Cook for a few seconds, turn off the heat, and wait for 5 minutes before serving."
    },
    {
      "position": 7,
      "text": "Serve hot. Share and Enjoy this delightful Vegetable dish!"
    }
  ],
  "servings": 4,
