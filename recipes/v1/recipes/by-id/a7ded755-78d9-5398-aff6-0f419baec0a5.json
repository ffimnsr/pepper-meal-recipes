  "id": "a7ded755-78d9-5398-aff6-0f419baec0a5",
  "slug": "pochero",
  "name": "Pochero Recipe",
  "recipe_type": null,
  "brief_description": "This pochero recipe shows the basic way on how to cook pork pochero.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic, onions, and tomatoes"
    },
    {
      "position": 3,
      "text": "Add pork and cook until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Put-in fish sauce, whole pepper corn, and tomato sauce. Stir."
    },
    {
      "position": 5,
      "text": "Add water and let boil. Simmer until pork is tender (about 30 to 40 minutes)."
    },
    {
      "position": 6,
      "text": "Put-in potato, plantain, and chick peas. Cook for 5 to 7 minutes."
    },
    {
      "position": 7,
      "text": "Add cabbage and long green beans. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Stir-in the bok choy. Cover the pot and turn off the heat."
    },
    {
      "position": 9,
      "text": "Let the residual heat cook the bok choy (about 5 minutes)."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate and serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
