  "slug": "chicken-nilaga-with-kalabasa",
  "name": "Chicken Nilaga with Kalabasa",
  "recipe_type": null,
  "brief_description": "Thisi s a recipe for Chicken Nilaga with Kalabasa",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour chicken broth into a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add onion, whole peppercorn, and chicken. Cover and continue to boil in medium heat for 30 minutes. Note: add more broth or water, if needed."
    },
    {
      "position": 3,
      "text": "Put the kalabasa and cabbage into the pot. Cook for 5 to 8 minutes."
    },
    {
      "position": 4,
      "text": "Add the baby bok choy and fish sauce. Stir. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Transfer to a serving bowl. Serve with rice,"
    },
    {
      "position": 6,
      "text": "Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
