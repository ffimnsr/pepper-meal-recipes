  "id": "13c282a4-b510-5080-b803-cc7d5b091347",
  "slug": "ginataang-langka-with-malunggay-and-daing",
  "name": "Ginataang Langka with Malunggay and Daing",
  "recipe_type": null,
  "brief_description": "This is a version of Ginataang Langka (unripe jackfruit cooked in coconut milk) with moringa leaves and salted fish flakes.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, add the onion, chili, and garlic. Saute until the onion becomes soft."
    },
    {
      "position": 3,
      "text": "Put in the jackfruit. Stir and cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the dried fish flakes. Stir. Cook for 30 seconds."
    },
    {
      "position": 5,
      "text": "Pour-in the coconut milk. Let boil. Set the heat to medium and continue to cook while stirring once in a while until the coconut milk evaporates."
    },
    {
      "position": 6,
      "text": "Add the malunggay leaves and fish sauce. Stir and cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
