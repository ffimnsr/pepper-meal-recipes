  "id": "17a9f624-eeac-59f2-94af-d9494eb76a20",
  "slug": "super-tasty-chop-suey",
  "name": "Super Tasty Chop Suey",
  "recipe_type": "main",
  "brief_description": "Chop Suey with chicken breast and chicken liver. This version makes use of Knorr SavorRich Chicken Liquid Seasoning, which helps make the dish tasty and delicious.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute onion and garlic until onion softens."
    },
    {
      "position": 3,
      "text": "Add chicken breast. Saute until light brown."
    },
    {
      "position": 4,
      "text": "Add chicken liver. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour water. Let boil. Cover and cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add carrot, cauliflower, and snap peas. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add bell peppers. Cover the pan. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Add cabbage. Toss. Cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Pour water with cornstarch. Stir."
    },
    {
      "position": 10,
      "text": "Season with Knorr SavorRich Chicken liquid seasoning and ground black pepper."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
