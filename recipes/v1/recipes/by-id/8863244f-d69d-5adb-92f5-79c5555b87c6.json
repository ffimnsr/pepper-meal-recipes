  "schema_version": 1,
  "id": "8863244f-d69d-5adb-92f5-79c5555b87c6",
  "slug": "puto-pao",
  "name": "Puto Pao",
  "recipe_type": "dessert",
  "brief_description": "Filipino cake with pork asado filling topped with sliced salted egg.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the asado filling. Heat oil in a cooking pot. Saute onion until translucent."
    },
    {
      "position": 2,
      "text": "Add pork. Cook until it turns light brown."
    },
    {
      "position": 3,
      "text": "Pour-in soy sauce and water. Let boil."
    },
    {
      "position": 4,
      "text": "Add star anise. Cook on low heat for 30 to 35 minutes."
    },
    {
      "position": 5,
      "text": "Add sugar. Stir. Put-in Knorr liquid seasoning and ground black pepper."
    },
    {
      "position": 6,
      "text": "Combine cornstarch and 3 tablespoons water. Mix well. Pour into the pot and cook until the sauce thickens. Set aside."
    },
    {
      "position": 7,
      "text": "Start making the puto batter. In a large bowl, combine all purpose flour, cake flour, sugar, and baking powder. Mix well."
    },
    {
      "position": 8,
      "text": "Add egg, evaporated milk, water, and butter. Mix all the ingredients thoroughly."
    },
    {
      "position": 9,
      "text": "Pour about 1 tablespoons of batter mixture on each mold."
    },
    {
      "position": 10,
      "text": "Put about 1 to 1/2 teaspoon of asado filling per mold. Add more batter until the mold is around 3/4 full."
    },
    {
      "position": 11,
      "text": "Arrange the molds in a steamer. Steam for 2 to 3 minutes."
    },
    {
      "position": 12,
      "text": "Top with a slice of salted duck egg. Continue steaming for 13 to 15 minutes."
    },
    {
      "position": 13,
      "text": "Remove the molds from the steamer. Let it cool down."
    },
    {
      "position": 14,
      "text": "Gently loosen the Puto Pao and remove from the mold. Arrange on a serving plate. Serve!"
    }
  ],
