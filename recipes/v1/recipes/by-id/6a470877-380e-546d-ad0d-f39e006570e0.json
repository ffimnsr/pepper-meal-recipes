  "id": "6a470877-380e-546d-ad0d-f39e006570e0",
  "slug": "seafood-noche-buena-holiday-christmas-dinner-baked-king-crab-legs-with-garlic-lemon-butter-sauce-recipe",
  "name": "Baked King Crab Legs with Garlic Lemon Butter Sauce",
  "recipe_type": null,
  "brief_description": "A simple, elegant holiday dish featuring baked king crab legs brushed with a rich garlic lemon butter sauce. Perfect for special occasions and ready in under 30 minutes.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a saucepan over low heat."
    },
    {
      "position": 2,
      "text": "Add the butter and allow to melt."
    },
    {
      "position": 3,
      "text": "When the butter is hot enough, add the garlic and cook for 1 minute (do not brown the garlic)."
    },
    {
      "position": 4,
      "text": "Pour in the lemon juice, stir, and let stand for 15 to 20 seconds."
    },
    {
      "position": 5,
      "text": "Pour in the extra virgin olive oil, parsley, and salt to taste, then turn off the heat. Set aside."
    },
    {
      "position": 6,
      "text": "Cut the crab legs in half crosswise to shorten them, then make a 3- to 4-inch opening in each leg by cutting one side of the shell lengthwise with kitchen shears, keeping the meat intact."
    },
    {
      "position": 7,
      "text": "Place the crab legs in a baking tray and brush the garlic lemon butter sauce over the openings."
    },
    {
      "position": 8,
      "text": "Preheat the oven to 300\u00b0F and bake the crab legs for 12 to 15 minutes, or until fragrant."
    },
    {
      "position": 9,
      "text": "Remove from the oven, let cool slightly, then transfer to a serving plate with the sauce on the side."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
