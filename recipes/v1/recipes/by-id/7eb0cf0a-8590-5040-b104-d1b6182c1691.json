  "id": "7eb0cf0a-8590-5040-b104-d1b6182c1691",
  "slug": "macaroni-salad",
  "name": "Recipe for Chicken Macaroni Salad",
  "recipe_type": "salad",
  "brief_description": "This is a Recipe for Chicken Macaroni Salad which makes use of boneless chicken breasts, elbow macaroni, pineapple slices, and other yummy ingredients",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the macaroni as directed in the package"
    },
    {
      "position": 2,
      "text": "Place the macaroni in a large container"
    },
    {
      "position": 3,
      "text": "Add the mayonnaise (and /or miracle whip) and mix well"
    },
    {
      "position": 4,
      "text": "Put-in the minced onions and mix well"
    },
    {
      "position": 5,
      "text": "Place the cheddar cheese in and mix again"
    },
    {
      "position": 6,
      "text": "Now, add the chicken and distribute evenly"
    },
    {
      "position": 7,
      "text": "Put-in the pineapple chunks, boiled eggs, and raisins and mix well"
    },
    {
      "position": 8,
      "text": "Add salt and pepper to taste"
    },
    {
      "position": 9,
      "text": "Chill inside the refrigerator for about an hour"
    },
    {
      "position": 10,
      "text": "Serve chilled. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
