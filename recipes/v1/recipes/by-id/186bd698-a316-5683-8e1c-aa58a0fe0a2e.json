  "id": "186bd698-a316-5683-8e1c-aa58a0fe0a2e",
  "slug": "crispy-fried-noodles",
  "name": "Crispy Noodles",
  "recipe_type": null,
  "brief_description": "Crispy Noodles is a type of noodle dish wherein the noodles (usually egg or flour) are fried until crispy. A special sauce made with vegetables, meat, and seafood is topped on the fried noodles.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a wok and pour-in cooking oil."
    },
    {
      "position": 2,
      "text": "Deep Fry the noodles in medium heat until texture becomes crisp and crunchy."
    },
    {
      "position": 3,
      "text": "Turn-off heat and transfer fried noodles on a serving plate (make sure to let excess oil drip)."
    },
    {
      "position": 4,
      "text": "Reduce the cooking oil from the same wok to 3 tablespoons and apply heat."
    },
    {
      "position": 5,
      "text": "Saute garlic and add chicken slices. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add shrimps then stir."
    },
    {
      "position": 7,
      "text": "Put-in the green beans, red bell pepper, and carrots. Stir-fry for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Add bok choy and chicken broth. Bring to a boil and simmer for 3 minutes."
    },
    {
      "position": 9,
      "text": "Add the oyster sauce, five spice powder, and sesame oil, and cornstarch diluted in water. Cook until sauce thickens."
    },
    {
      "position": 10,
      "text": "Pour sauce on top of arranged fried noodles."
    },
    {
      "position": 11,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
