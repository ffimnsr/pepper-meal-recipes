  "id": "8cfeb2e8-0454-5bce-b547-45380ee03e91",
  "slug": "ginisang-ampalaya-na-may-itlog-at-hipon-sauteed-bitter-melon-with-egg-and-shrimp",
  "name": "Ginisang Ampalaya na May Itlog at Hipon (Sauteed Bitter Melon with Egg and Shrimp)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Sauteed Bitter Melon with Egg and Shrimp.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt, ground black pepper, and garlic powder all over the shrimp. Rub. Let it stay for 5 minutes."
    },
    {
      "position": 2,
      "text": "Crack the egg and place in a bowl. Beat until smooth. Set aside."
    },
    {
      "position": 3,
      "text": "Spray or pour cooking oil in a wok. Pan-fry shrimp for 1 minute per side. Remove from the wok. Set aside."
    },
    {
      "position": 4,
      "text": "Pour oil on the wok. Let it heat-up."
    },
    {
      "position": 5,
      "text": "Saute onion, garlic, and tomato. Continue to cook until the onion and tomato softens."
    },
    {
      "position": 6,
      "text": "Add the ampalaya (bitter gourd). Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Pour beaten egg into the wok. Stir-fry until the eggs are cooked."
    },
    {
      "position": 8,
      "text": "Put the shrimp back into the wok. Stir."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
