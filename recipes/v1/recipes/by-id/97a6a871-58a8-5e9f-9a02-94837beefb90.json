  "id": "97a6a871-58a8-5e9f-9a02-94837beefb90",
  "slug": "chicken-pochero",
  "name": "Chicken Pochero Recipe",
  "recipe_type": "main",
  "brief_description": "Chicken stewed in tomato sauce with chorizo, potato, and green vegetables. It is a comfort food best enjoyed for lunch with hot rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Pan-fry the chicken for 2 minutes per side. Set aside."
    },
    {
      "position": 2,
      "text": "Using the remaining oil, saute onion and garlic."
    },
    {
      "position": 3,
      "text": "Add chorizo. Saute for 1 minute."
    },
    {
      "position": 4,
      "text": "Add tomato. Continue to saute until onion and tomato softens."
    },
    {
      "position": 5,
      "text": "Put the pan-fried chicken back into the pot. Stir."
    },
    {
      "position": 6,
      "text": "Pour tomato sauce and water.Let boil."
    },
    {
      "position": 7,
      "text": "Add Knorr Chicken Cube. Stir and cover the pot. Cook in medium heat for 15 minutes."
    },
    {
      "position": 8,
      "text": "Put potato, saba banana, and chick pea into the pot. Cover and cook for 12 minutes."
    },
    {
      "position": 9,
      "text": "Add long green beans and cabbage. Cover and cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Add bok choy. Cook for 2 minutes. Season with crushed peppercorn and fish sauce. Stir."
    },
    {
      "position": 11,
      "text": "Tranfer to a serving bowl. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
