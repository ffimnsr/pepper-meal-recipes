  "id": "eac32ab3-dddb-514c-b8ca-d8c769781fe4",
  "slug": "estofadong-baboy-recipe",
  "name": "Estofadong Baboy",
  "recipe_type": null,
  "brief_description": "This is a recipe for Filipino pork Estofado with pan-fried carrots and saba banana.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork, crushed peppercorn, garlic, soy sauce, and vinegar in a bowl. Mix well. Marinate for at least 3 hours."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Once the oil becomes hot, pan fry the carrots for 45 seconds per side. Remove from the pot. Set aside."
    },
    {
      "position": 4,
      "text": "Pan fry the banana for 45 seconds per side. Remove from the pot. Set aside."
    },
    {
      "position": 5,
      "text": "Using the remaining oil, pan fry the marinated pork for around 1 to 1 1/2 minutes per side. Note: You may add more cooking oil if needed."
    },
    {
      "position": 6,
      "text": "Put the crushed garlic into the pot. Cook for 30 seconds. Note: This is the same ingredient used to marinate the pork."
    },
    {
      "position": 7,
      "text": "Pour-in the remaining marinade from the bowl and add beef broth. Let boil. Cover and cook in medium heat for 50 minutes to 1 hour, or until the pork becomes tender."
    },
    {
      "position": 8,
      "text": "Add brown sugar. Stir. Cook for 15 minutes."
    },
    {
      "position": 9,
      "text": "Add the pan fried carrots and bananas. Stir."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
