  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "1e868dad-6d08-5e78-ba0e-b4402621e98a",
  "slug": "misua-and-meatball-soup",
  "name": "Misua Soup with Meatballs",
  "recipe_type": "soup",
  "brief_description": "Misua and Meatball Soup is my version of albondigas. I am using thin flour noodles called misua or miswa and I also added loofah gourd, which is known as \u201cpatola\u201d in the Philippines. This is delicious treat that you will enjoy either for lunch or dinner.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the meatballs by combining the ground pork, bread crumbs, egg, salt, and pepper in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Scoop about a tablespoon of the mixture and roll it into a ball shaped figure. Do this step until all the ground pork mixture is consumed."
    },
    {
      "position": 3,
      "text": "Heat 4 tablespoons of cooking oil in a pan. Pan fry the meatballs in low to medium heat until the color of the outer part turns medium brown. Remove the fried meatballs and set aside."
    },
    {
      "position": 4,
      "text": "Meanwhile, start to prepare the soup by pouring the remaining 2 tablespoons of cooking oil in a clean cooking pot."
    },
    {
      "position": 5,
      "text": "Saute the onion and garlic. Once the onion becomes soft, put-in the cooked meatballs."
    },
    {
      "position": 6,
      "text": "Pour-in the water. Let boil."
    },
    {
      "position": 7,
      "text": "Add the beef broth and tomato sauce. Let boil and simmer for 10 minutes."
    },
    {
      "position": 8,
      "text": "Pour-in the fish sauce then add the loofah and spring onions. Stir and cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Put-in the misua noodles. Cook for 2 minutes (add more water if needed)."
    },
    {
      "position": 10,
      "text": "Tranfer to a serving bowl. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
