  "id": "075e4e47-0b48-570b-b0a4-e92574861127",
  "slug": "roasted-chicken-dinner-recipe",
  "name": "Roasted Chicken Recipe",
  "recipe_type": "main",
  "brief_description": "This traditional roasted chicken recipe is tender, juicy, and flavorful. It is best eaten with mashed potato, or with rice, which is the Filipino way.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 375 degrees Fahrenheit"
    },
    {
      "position": 2,
      "text": "Combine salt, ground black pepper, and garlic powder then mix."
    },
    {
      "position": 3,
      "text": "Rub the mixture around the chicken."
    },
    {
      "position": 4,
      "text": "Combine melted butter, dried thyme, and lemon zest and mix well."
    },
    {
      "position": 5,
      "text": "Loosen the skin of the chicken and spread the lemon zest-butter-thyme mixture in between the skin and flesh."
    },
    {
      "position": 6,
      "text": "Stuff the quartered lemon, celery stalks, and onion in the chicken and secure by tying the legs together using a kitchen thread."
    },
    {
      "position": 7,
      "text": "Bake / Roast for 60 to 65 minutes."
    },
    {
      "position": 8,
      "text": "Turn the oven off and take the chicken out."
    },
    {
      "position": 9,
      "text": "Remove the thread and place in serving plate."
    },
    {
      "position": 10,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 10,
  "difficulty": "hard",
