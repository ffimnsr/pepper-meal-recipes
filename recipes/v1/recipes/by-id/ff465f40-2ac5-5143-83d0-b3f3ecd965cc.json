  "id": "ff465f40-2ac5-5143-83d0-b3f3ecd965cc",
  "slug": "yema-recipe",
  "name": "Yema Recipe",
  "recipe_type": "dessert",
  "brief_description": "Filipino custard candy.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Chop the peanuts. Set aside."
    },
    {
      "position": 2,
      "text": "Pour condensed milk on a cooking pot. Let boil. Stir constantly while boiling for 10 minutes."
    },
    {
      "position": 3,
      "text": "Lower the heat. Add chopped peanuts. Continue cooking while stirring for another 10 minutes or until consistency becomes paste-like."
    },
    {
      "position": 4,
      "text": "Transfer yema mixture to a bowl."
    },
    {
      "position": 5,
      "text": "Start wrapping the yema candies individually on a pre-cut cellophane. (Note: The dimensions of my cellophane were 4x4 inches. You can decrease the dimension for smaller candies.)"
    },
    {
      "position": 6,
      "text": "Let it cool down before eating. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
