  "id": "ebd0e6e2-97de-5de5-9d8a-0c06a7c63621",
  "slug": "low-carb-breaded-pinatisang-baboy",
  "name": "Low-Carb Breaded Pinatisang Baboy",
  "recipe_type": "main",
  "brief_description": "Almond flour-breaded pork butt with fish sauce marinade that is fried until golden brown and crispy.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the pork into thin pieces. Arrange in a large bowl."
    },
    {
      "position": 2,
      "text": "Add ground black pepper. Squeeze lime over the pork and pour patis. Mix everything together. Let it stay for 10 minutes for the meat to absorb the flavors of the seasonings."
    },
    {
      "position": 3,
      "text": "Heat oil in a pot or deep fryer."
    },
    {
      "position": 4,
      "text": "Beat eggs in a bowl. Prepare almond flour by transferring to a bowl. Place the two bowls side-by-side."
    },
    {
      "position": 5,
      "text": "Dip sliced pork in almond flour, then on beaten eggs. Dip it again in almond flour making sure that all sides are coated. Place on a frying basket (for deep-frying), or a clean plate (for traditional frying)."
    },
    {
      "position": 6,
      "text": "Fry pork until golden brown and crispy. Note: this should take around 4 to 6 minutes in medium heat."
    },
    {
      "position": 7,
      "text": "Remove from the fryer and arrange in a serving plate. Serve with a spicy vinegar dipping sauce."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
