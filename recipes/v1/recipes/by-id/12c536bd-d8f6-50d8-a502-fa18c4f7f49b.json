  "id": "12c536bd-d8f6-50d8-a502-fa18c4f7f49b",
  "slug": "easy-banana-muffin",
  "name": "Easy Banana Muffin",
  "recipe_type": "dessert",
  "brief_description": "Easy banana muffins are really good. They go well with coffee, hot chocolate, soda, and almost any drink. They are quick and easy to prepare.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 350 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Mash the bananas. Set aside."
    },
    {
      "position": 3,
      "text": "Combine flour, baking powder, salt, and baking soda in a bowl. Mix using a wire whisk. Set aside."
    },
    {
      "position": 4,
      "text": "In a large mixing bowl, combine the mashed bananas, butter, egg, vanilla extract, and granulated white sugar. Mix well."
    },
    {
      "position": 5,
      "text": "Fold-in the dry ingredient mixture in the large mixing bowl. Continue this step until the texture becomes smooth."
    },
    {
      "position": 6,
      "text": "Arrange regular sized paper cups in the muffin pan. Scoop the mixture in each paper cup. Do not fill the cup as it will overflow."
    },
    {
      "position": 7,
      "text": "Bake in the oven for 13 to 16 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven and let cool by placing in a wire rack."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 16,
  "preparation_time_minutes": 10,
