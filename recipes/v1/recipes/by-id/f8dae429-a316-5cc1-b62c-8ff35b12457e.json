  "id": "f8dae429-a316-5cc1-b62c-8ff35b12457e",
  "slug": "shared-recipe-jeans-graham-mango-float",
  "name": "Jean's Graham Mango Float",
  "recipe_type": "dessert",
  "brief_description": "Graham Mango Float recipe. I would describe this dessert as a big hit during fiesta celebration. I always make this on special occasion. It's an easy recipe and most of all you don't even need to bake. Although I love baking but it's nice to have a quick and easy recipe. Most of all, this is a refreshing dessert for the whole family.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a rectangular dish, arrange 8 to 10 pieces of graham crackers. Set aside."
    },
    {
      "position": 2,
      "text": "In a bowl, combine the cream/cool whip and condensed milk. (Mix well)"
    },
    {
      "position": 3,
      "text": "Then on the layered crackers on the bottom, spread the milk and cream mixture."
    },
    {
      "position": 4,
      "text": "Then spread out the thin sliced mangoes evenly on top of the cream."
    },
    {
      "position": 5,
      "text": "Make another layer of graham crackers; spread the cream and mango slices. (You can do lots of layers if you want)"
    },
    {
      "position": 6,
      "text": "Garnish top layer with mango and sprinkle the crushed graham."
    },
    {
      "position": 7,
      "text": "Chill for at least 3 hours before serving."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
