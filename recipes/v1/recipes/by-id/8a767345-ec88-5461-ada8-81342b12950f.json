  "id": "8a767345-ec88-5461-ada8-81342b12950f",
  "slug": "marinated-grilled-pork-chop",
  "name": "Marinated Grilled Pork Chop",
  "recipe_type": null,
  "brief_description": "Marinated Grilled Pork Chop is one tasty grilled pork chop version that I really enjoyed. It is really delicious and quicker to prepare",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the pork chop and marinade ingredients. Mix well and ensure that the pork chops are coated with the marinade. Cover and refrigerate for at least 4 hours."
    },
    {
      "position": 2,
      "text": "Prepare the basting sauce by combining all the basting sauce ingredients in a bowl. Stir to mix."
    },
    {
      "position": 3,
      "text": "Heat-up the grill. Start to grill one side of the pork chop in medium heat for 4 minutes."
    },
    {
      "position": 4,
      "text": "Baste the top and turn the pork chop over. Grill the opposite side for another 4 minutes. Continue the cycle 2 more times or until the pork chops are cooked according to your preference."
    },
    {
      "position": 5,
      "text": "Transfer to as serving plate. Serve with papaya atchara and spicy vinegar."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
