  "id": "6d4cc25f-efea-5f67-af3a-2f272decdb12",
  "slug": "ginataang-puso-ng-saging",
  "name": "Ginataang Puso ng Saging",
  "recipe_type": null,
  "brief_description": "Banana blossoms cooked in coconut milk with ground pork and shrimp.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice banana blossom into thin pieces. Soak in 1/2 cup vinegar for 15 minutes. Rinse and wring tight. Set aside."
    },
    {
      "position": 2,
      "text": "Combine Knorr Ginataang Gulay Mix and water. Stir until powder dilutes completely. Set aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a pot. Add garlic and cook until it starts to brown."
    },
    {
      "position": 4,
      "text": "Add onion. Saute while constantly stirring until onion softens."
    },
    {
      "position": 5,
      "text": "Add ground pork. Cook until pork turns light brown."
    },
    {
      "position": 6,
      "text": "Put the banana blossoms in the pan. Saute for 2 minutes. Pour vinegar. Cover and cook in medium heat for another 2 minutes."
    },
    {
      "position": 7,
      "text": "Pour Knorr Ginataang Gulay mixture and add chili peppers. Let boil. Cover the pot and continue cooking in low to medium heat for 7 to 10 minutes. Note: add more water as needed."
    },
    {
      "position": 8,
      "text": "Add shrimp. Cook for 2 minutes. Season with ground black pepper."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl and serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
