  "slug": "easy-simplest-paksiw-na-galunggong-recipe",
  "name": "The Simplest Paksiw na Galunggong Recipe",
  "recipe_type": null,
  "brief_description": "Paksiw na Galunggong is a Filipino dish wherein fish such as galunggong is cooked with water, vinegar, and some spices. Get the recipe here.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the fish including the inner cavity. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Arrange the fish in a cooking pot along with the ginger, garlic, and long green pepper. Pour water and vinegar. Let boil."
    },
    {
      "position": 3,
      "text": "Cover and simmer for 30 to 45 minutes. Add more water if needed."
    },
    {
      "position": 4,
      "text": "Add salt to taste. Stir."
    },
    {
      "position": 5,
      "text": "Serve with warm rice. Enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
