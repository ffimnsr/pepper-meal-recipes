  "id": "d2969455-7af1-5f00-abfd-74a41d5a3228",
  "slug": "brined-roast-beef-recipe",
  "name": "Brined Roast Beef",
  "recipe_type": null,
  "brief_description": "Brined Roast Beef is a perfect dish for lunch. This recipe will show you how its easily done in the comfort of your own kitchen.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the brining ingredients in a saucepan, except for the ice cubes. Mix well."
    },
    {
      "position": 2,
      "text": "Place the saucepan in a stovetop. Let boil and continue to cook for 2 minutes."
    },
    {
      "position": 3,
      "text": "Arrange the ice cubes in a large metal mixing bowl. Pour-in the boiling mixture in the mixing bowl. Stir."
    },
    {
      "position": 4,
      "text": "Meanwhile, place the beef inside a large resealable bag. Pour the brine mixture inside the bag. Seal and place inside the refrigerator. Let it brine for 16 to 20 hours."
    },
    {
      "position": 5,
      "text": "After brining the meat, discard the brine. Preheat oven to 375 Fahrenheit."
    },
    {
      "position": 6,
      "text": "Rub salt, pepper, and garlic powder all over the meat and then place it in a roasting rack."
    },
    {
      "position": 7,
      "text": "Roast the beef for 23 to 27 minutes per pound. Note: A 3 lbs. beef needs to be roasted for 69 to 81 minutes."
    },
    {
      "position": 8,
      "text": "Remove the meat from the oven. Let is rest for 12 to 15 minutes."
    },
    {
      "position": 9,
      "text": "Carve the roast beef. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
