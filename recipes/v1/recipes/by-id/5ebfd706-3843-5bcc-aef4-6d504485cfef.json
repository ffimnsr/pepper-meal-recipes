  "id": "5ebfd706-3843-5bcc-aef4-6d504485cfef",
  "slug": "how-to-cook-baked-cilantro-lime-cod",
  "name": "Baked Cilantro Lime Cod Recipe",
  "recipe_type": null,
  "brief_description": "The outcome of this baked cilantro lime cod recipe is a delicious fish dish can easily be prepared for dinner. It is quick and easy to cook.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Brush the cod fillets with olive oil then sprinkle some salt and pepper."
    },
    {
      "position": 3,
      "text": "Place the cod fillets in a baking pan and bake for 15 minutes. Set aside."
    },
    {
      "position": 4,
      "text": "Make the sauce by combining cilantro, lime juice, extra virgin olive oil, sugar, and red pepper flakes in a blender. Blend until the texture becomes smooth."
    },
    {
      "position": 5,
      "text": "Arrange the baked cod fillets in a serving plate then spoon the sauce on top."
    },
    {
      "position": 6,
      "text": "Serve with steamed rice."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
