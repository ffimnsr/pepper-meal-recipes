  "slug": "hoisin-glazed-grilled-tofu-recipe",
  "name": "Hoisin Glazed Grilled Tofu",
  "recipe_type": null,
  "brief_description": "Hoisin Glazed Grilled Tofu is a healthy and tangy dish that you can have for lunch; it has high protein content with low fat and cholesterol.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine hoisin sauce, salt, and pepper. Mix well."
    },
    {
      "position": 2,
      "text": "Brush the mixture all over the tofu to coat. Let it stand for 1 hour."
    },
    {
      "position": 3,
      "text": "Grill the tofu in medium heat for about 10 minutes per side. Baste with the remaining hoisin sauce mixture."
    },
    {
      "position": 4,
      "text": "Transfer to a serving plate. Serve with steamed broccoli."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
