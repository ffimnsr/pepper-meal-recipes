  "id": "ba3ed7e3-e060-58cf-b5ca-373d3d6bc199",
  "slug": "pork-menudo-recipe",
  "name": "Pork Menudo",
  "recipe_type": null,
  "brief_description": "This is a recipe for basic pork menudo. It is a delicious dish that makes use pork, liver, and vegetables such as carrot and potato.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork, soysauce, and lemon in a bowl. Marinate for at least 1 hour."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan"
    },
    {
      "position": 3,
      "text": "Saute garlic and onion."
    },
    {
      "position": 4,
      "text": "Add the marinated pork. Cook for 5 to 7 minutes."
    },
    {
      "position": 5,
      "text": "Pour in tomato sauce and water and then add the bay leaves.Let boil and simmer for 30 minutes to an hour depending on the toughness of the pork. Note: Add water as necessary."
    },
    {
      "position": 6,
      "text": "Add-in the liver and hot dogs.Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Put-in potatoes, carrots, sugar,salt, and pepper. Stir and cook for 8 to 12 minutes."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
