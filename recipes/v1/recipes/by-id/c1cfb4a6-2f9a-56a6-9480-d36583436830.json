  "id": "c1cfb4a6-2f9a-56a6-9480-d36583436830",
  "slug": "tuyo-fried-rice",
  "name": "Tuyo Fried Rice",
  "recipe_type": "breakfast",
  "brief_description": "I love to eat sinangag for breakfast; it pairs great with tocino, longganisa, and hotdog. I also enjoy eating tuyo. If I get a chance, I make a type of sinangag with tuyo flakes in it \u2013 I call it tuyo fried rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine salt and leftover rice in a bowl. Gently mash to mix the ingredients and to separate the rice from each other."
    },
    {
      "position": 2,
      "text": "Heat a pan. Pour-in the oil."
    },
    {
      "position": 3,
      "text": "Once the oil becomes hot, add the garic. Cook the garlic in medium heat until it turns medium brown."
    },
    {
      "position": 4,
      "text": "Add the tuyo (salted dried fish). Cook for 20 seconds."
    },
    {
      "position": 5,
      "text": "Add-in the rice. Toss once in a while. Cook the rice for 10 to 12 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 7,
      "text": "Serve for breakfast. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
