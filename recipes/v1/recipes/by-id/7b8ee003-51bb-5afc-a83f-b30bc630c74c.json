  "id": "7b8ee003-51bb-5afc-a83f-b30bc630c74c",
  "slug": "fried-tilapia-in-coconut-milk-ginataang-tilapia",
  "name": "Fried Tilapia in Coconut Milk (Ginataang Tilapia)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Fried Tilapia in Coconut Milk",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic, onion, and ginger"
    },
    {
      "position": 3,
      "text": "Pour the coconut milk in the pot. Let boil."
    },
    {
      "position": 4,
      "text": "Add the banana pepper and fried tilapia. Cover and cook in low heat for 15 minutes."
    },
    {
      "position": 5,
      "text": "Add chili peppers and dish sauce. Stir. Turn the fish over. Cover the pot and then continue to cook for 10 minutes."
    },
    {
      "position": 6,
      "text": "Add the malunggay leaves. Cook for 5 to 8 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 15,
