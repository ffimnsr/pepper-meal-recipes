  "id": "cd9d3915-1eb6-5492-ab00-7cc30a60f1e7",
  "slug": "chicken-bistek",
  "name": "Chicken Bistek",
  "recipe_type": "main",
  "brief_description": "Marinated chicken breast stewed in soy sauce with onion.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the marinade ingredients in a large bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Add the chicken. Make sure that the chicken is completely coated with the marinade. Cover the bowl. Refrigerate overnight."
    },
    {
      "position": 3,
      "text": "Separate the chicken from the remaining marinade. Note: make sure to let most of the liquid drip-off."
    },
    {
      "position": 4,
      "text": "Heat 2 tablespoons of cooking oil in a wok. Fry the chicken for 2 minutes per side. Remove from the wok. Set it aside."
    },
    {
      "position": 5,
      "text": "Heat the remaining cooking oil. Saut\u00e9 the garlic and around \u00bd of the total amount of onions."
    },
    {
      "position": 6,
      "text": "Add the chicken once the onion softens. Continue cooking for 30 seconds."
    },
    {
      "position": 7,
      "text": "Pour the remaining marinade and 1 cup water. Let it boil. Adjust the heat to a simmer, cover the wok, and continue cooking for 35 minutes. Note: add more water as needed."
    },
    {
      "position": 8,
      "text": "Add the remaining onions. Cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Add the sugar and season with salt and ground black pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
