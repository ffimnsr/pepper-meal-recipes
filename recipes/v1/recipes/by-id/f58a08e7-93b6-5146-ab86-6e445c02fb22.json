  "id": "f58a08e7-93b6-5146-ab86-6e445c02fb22",
  "slug": "filipino-roasted-chicken-pandan-recipe",
  "name": "Filipino Roasted Chicken Pandan Recipe",
  "recipe_type": null,
  "brief_description": "Here is a delicious Roasted Chicken Recipe that is full of nice flavor and aroma; I call it Filipino Roasted Chicken Pandan. Enjoy this yummy chicken recipe",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 425F."
    },
    {
      "position": 2,
      "text": "Rub salt all over the chicken, including the cavity."
    },
    {
      "position": 3,
      "text": "Combine the garlic, onion, bay leaves, and peppercorn in a bowl. Toss to mix. Stuff the mixture into the cavity of the chicken followed by the Pandan leaves and lemongrass."
    },
    {
      "position": 4,
      "text": "Arrange the chicken in a roasting rack or roasting pan."
    },
    {
      "position": 5,
      "text": "Roast in the oven for 90 minutes."
    },
    {
      "position": 6,
      "text": "Remove the Filipino Roasted Chicken Pandan from the oven. Let it rest for 10 minutes."
    },
    {
      "position": 7,
      "text": "Remove the stuffing from the cavity. Transfer the chicken to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with atcharang papaya. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
