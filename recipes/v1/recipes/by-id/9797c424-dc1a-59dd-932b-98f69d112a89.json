  "id": "9797c424-dc1a-59dd-932b-98f69d112a89",
  "slug": "ginisang-monggo-with-inihaw-na-liempo",
  "name": "Ginisang Monggo with Inihaw na Liempo",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginisang Monggo with Inihaw na Liempo",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the Inihaw na Liempo by placing the pork belly in a large bowl. Pour the Knorr Liquid Seasoning into the bowl and squeeze out the juice from the lime or calamansi (lemon can also be used). Mix well. Let it marinate for at least 1 hour."
    },
    {
      "position": 2,
      "text": "Meanwhile, cook the ginisang monggo starting by heating oil in a pot. Saute garlic, onion, and tomato."
    },
    {
      "position": 3,
      "text": "Add pork. Cook for 3 minutes or until it turns light brown."
    },
    {
      "position": 4,
      "text": "Pour water into the pot. Let boil."
    },
    {
      "position": 5,
      "text": "Add the pork cube. Stir. Cover and cook in medium heat until the mung beans completely absorb the water and become soft (this should take around 30 to 40 minutes)."
    },
    {
      "position": 6,
      "text": "Add the malunggay leaves and then season with ground black pepper and fish sauce. Cook for 5 minutes more. Turn the heat to off and transfer to a serving bowl. Set aside."
    },
    {
      "position": 7,
      "text": "Start to grill the liempo (pork belly) for 3 minutes per side while basting it with a mixture of Knorr liquid seasoning, juice from a piece of lime, and 2 tablespoons cooking oil on every turn. Continue to grill until the liempo until completely done."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with ginisang monggo."
    },
    {
      "position": 9,
      "text": "Share and enjoy"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 60,
  "rest_time_minutes": null,
