  "id": "a5728995-0f41-5b6b-9e68-75b8a5dacf0f",
  "slug": "oxtail-kare-kare-recipe-peanut-stew",
  "name": "Oxtail Kare-Kare Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Oxtail Kare-Kare (peanut stew).",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Once the onion becomes soft, saute the Oxtail until light brown."
    },
    {
      "position": 4,
      "text": "Pour water into the the pot. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Beef Cube. Stir. Cover and cook between low to medium heat until the oxtail becomes tender. Note: This will take around 2 to 2 1/2 hours for conventional cooking, and 30 to 40 minutes if a pressure cooker is used."
    },
    {
      "position": 6,
      "text": "Add peanut butter and ground peanuts. Stir."
    },
    {
      "position": 7,
      "text": "Pour annatto water. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Combine cornstarch and 1/2 cup cold water. Stir. Pour the mixture into the pot. Stir until the sauce gets thicker."
    },
    {
      "position": 9,
      "text": "Add banana blossoms. Cook for 3 to 4 minutes."
    },
    {
      "position": 10,
      "text": "Add eggplant and snake beans (sitaw). Cook for 5 minutes."
    },
    {
      "position": 11,
      "text": "Put the bok choy into the pot. Stir. Cover and cook for 2 minutes."
    },
    {
      "position": 12,
      "text": "Transfer to a serving dish. Serve with bagoong alamang."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 150,
  "preparation_time_minutes": 15,
