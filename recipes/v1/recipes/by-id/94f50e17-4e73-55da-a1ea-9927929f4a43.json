  "id": "94f50e17-4e73-55da-a1ea-9927929f4a43",
  "slug": "simple-baked-pork-chop-recipe",
  "name": "Baked Pork Chops",
  "recipe_type": "drink",
  "brief_description": "Tender baked pork chops brushed with calamansi juice and olive oil, then seasoned with a simple spice rub. Bakes at 400 degrees in about 20 minutes for juicy results. Serve with steamed rice or mashed potatoes.",
  "cuisine": "American Filipino Mediterranean",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 400 degrees F."
    },
    {
      "position": 2,
      "text": "Pat the pork chops dry with paper towels."
    },
    {
      "position": 3,
      "text": "Combine 2 tablespoons of olive oil and calamansi juice in a small bowl. Mix well."
    },
    {
      "position": 4,
      "text": "Brush the mixture on both sides of the pork chops."
    },
    {
      "position": 5,
      "text": "Combine all the rub ingredients in a separate bowl. Mix well."
    },
    {
      "position": 6,
      "text": "Season both sides of the pork chops evenly with the rub."
    },
    {
      "position": 7,
      "text": "Lightly brush a baking tray with the remaining olive oil. Arrange the pork chops on the tray in a single layer and top with butter."
    },
    {
      "position": 8,
      "text": "Bake uncovered for 18 to 25 minutes, depending on thickness, until the internal temperature reaches 145 degrees F."
    },
    {
      "position": 9,
      "text": "Remove from the oven and let the pork chops rest for 5 minutes. Spoon the pan juices over the chops before serving."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 5,
  "difficulty": "medium",
