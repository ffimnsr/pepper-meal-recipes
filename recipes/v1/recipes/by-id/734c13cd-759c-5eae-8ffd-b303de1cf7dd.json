  "id": "734c13cd-759c-5eae-8ffd-b303de1cf7dd",
  "slug": "pork-chop-sinigang",
  "name": "Pork Chop Sinigang",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Pork Chop Sinigang",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Bring water to a boil in a pot."
    },
    {
      "position": 2,
      "text": "Add tomato and onion. Boil for 3 minutes."
    },
    {
      "position": 3,
      "text": "Put the pork chops in and then cover the pot. Continue to cook in medium heat for 30 to 40 minutes."
    },
    {
      "position": 4,
      "text": "Add the sinigang mix. Stir."
    },
    {
      "position": 5,
      "text": "Put the okra, eggplant, long green peppers, and snake beans into the cooking pot. Cover and continue to cook for 10 to 12 minutes."
    },
    {
      "position": 6,
      "text": "Pour fish sauce. Stir. Add the spinach and cover the pot. Turn off the heat and let it stay covered for 5 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve with white rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
