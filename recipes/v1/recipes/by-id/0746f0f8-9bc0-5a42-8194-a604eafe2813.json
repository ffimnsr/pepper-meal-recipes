{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "0746f0f8-9bc0-5a42-8194-a604eafe2813",
  "slug": "fried-chicken-with-mayo-garlic-glaze",
  "name": "Fried Chicken with Mayo Garlic Glaze",
  "recipe_type": "main",
  "brief_description": "Crispy boneless fried chicken tossed glazed with mayonnaise and garlic dressing",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken with the chicken seasoning ingredients. Mix well. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile combine flour mixture ingredients. Mix well and set aside."
    },
    {
      "position": 3,
      "text": "Heat 2 cups of cooking oil in a deep cooking pot."
    },
    {
      "position": 4,
      "text": "While the oil is heating-up, dredge the chicken in flour mixture. Dip in beaten egg, and then dredge once more with the flour mixture."
    },
    {
      "position": 5,
      "text": "Deep-fry the chicken for 14 minutes or until golden brown. Remove chicken from the cooking pot. Set aside."
    },
    {
      "position": 6,
      "text": "Make the Mayo Garlic glaze by melting butter on a clean pan. Add garlic. Cook until it starts to brown. Turn the heat off and add Lady\u2019s Choice Mayonnaise, lemon juice, honey, and Knorr Liquid Seasoning. Mix well."
    },
    {
      "position": 7,
      "text": "Add the crispy fried chicken and toss with the glaze until completely coated."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
