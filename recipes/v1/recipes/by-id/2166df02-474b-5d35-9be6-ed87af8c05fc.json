  "id": "2166df02-474b-5d35-9be6-ed87af8c05fc",
  "slug": "filipino-chicken-macaroni-sopas",
  "name": "Filipino Chicken Macaroni Sopas",
  "recipe_type": "appetizer",
  "brief_description": "This is a recipe for Filipino Chicken Macaroni Sopas",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Bring the water to a boil."
    },
    {
      "position": 2,
      "text": "Add the chicken. Boil the chicken in low to medium heat for 45 minutes or until tender."
    },
    {
      "position": 3,
      "text": "Remove the chicken and let cool. Set-aside the water used to boil the chicken. We'll use this later."
    },
    {
      "position": 4,
      "text": "Once the chicken reaches room temperature, shred the meat using your hands. Discard (throw away) the bones."
    },
    {
      "position": 5,
      "text": "Meanwhile, heat a clean large cooking pot."
    },
    {
      "position": 6,
      "text": "Pour-in the butter and oil. Once the butter and oil becomes hot, saut\u00e9 the onion, carrot, and celery for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add the shredded chicken and chopped ham. Cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Pour-in the chicken broth and the remaining water used to boil the chicken. Stir and let boil. Simmer for 20 minutes."
    },
    {
      "position": 9,
      "text": "Add the elbow macaroni. Cook for 15 minutes. Add more water if needed."
    },
    {
      "position": 10,
      "text": "Pour-in the milk. Stir and let boil."
    },
    {
      "position": 11,
      "text": "Add salt and pepper to adjust the taste."
    },
    {
      "position": 12,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
