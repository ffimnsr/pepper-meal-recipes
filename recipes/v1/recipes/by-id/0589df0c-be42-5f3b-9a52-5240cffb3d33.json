  "id": "0589df0c-be42-5f3b-9a52-5240cffb3d33",
  "slug": "christmas-chicken-curry",
  "name": "Christmas Chicken Curry",
  "recipe_type": "main",
  "brief_description": "Special creamy Filipino stle chicken curry.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot. Saut\u00e9 garlic, onion, and ginger."
    },
    {
      "position": 2,
      "text": "Add the chicken once the onion softens. Cook until the chicken turns light brown."
    },
    {
      "position": 3,
      "text": "Add curry powder and turmeric powder. Stir and pour coconut milk and water. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr chicken cube. Cover the pot. Cook in a low heat setting for 20 minutes."
    },
    {
      "position": 5,
      "text": "Add potato and carrots. Cook for 8 minutes."
    },
    {
      "position": 6,
      "text": "Combine 1 tablespoon of Knorr cream of mushroom soup mix with \u00bd cup water. Mix well. Add mixture to the pot. Stir."
    },
    {
      "position": 7,
      "text": "Add bell pepper and long green chili pepper. Cover the pot and continue cooking for 5 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper. Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
