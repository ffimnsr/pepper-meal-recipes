  "id": "bddc268d-d4ba-5964-99ff-6dffd32671ed",
  "slug": "kinamatisang-baboy",
  "name": "Kinamatisang Baboy",
  "recipe_type": "main",
  "brief_description": "Pork stew cooked with tomatoes, ginger, garlic, and vegetables.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saut\u00e9 the garlic until it starts to brown."
    },
    {
      "position": 2,
      "text": "Add ginger and onion. Continue cooking for 1 minute."
    },
    {
      "position": 3,
      "text": "Add the pork belly. Saut\u00e9 until the color turns light brown (around 2 minutes)."
    },
    {
      "position": 4,
      "text": "Add half of the tomatoes. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour the water and let it boil. Simmer for 45 minutes."
    },
    {
      "position": 6,
      "text": "Add remaining tomatoes, long green pepper, and bok choy. Cover and cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the Maggi Magic Chicken Cube. Stir. Cook for 1 minute."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve with warm rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
