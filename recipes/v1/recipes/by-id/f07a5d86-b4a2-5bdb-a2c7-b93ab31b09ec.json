  "id": "f07a5d86-b4a2-5bdb-a2c7-b93ab31b09ec",
  "slug": "pork-dinuguan-sa-gata-recipe",
  "name": "Pork Dinuguan sa Gata Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pork Dinuguan sa Gata",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onion until the onion becomes soft"
    },
    {
      "position": 3,
      "text": "Add the pork. Saut\u00e9 until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Add the ground black pepper. Stir."
    },
    {
      "position": 5,
      "text": "Pour-in 1 \u00bd cups water. Let boil. Cover and continue to cook in low to medium heat for 20 minutes."
    },
    {
      "position": 6,
      "text": "Pour the vinegar. Let the liquid reboil. Stir and continue to cook until the pork gets tender."
    },
    {
      "position": 7,
      "text": "Pour the pork blood into the pot while stirring. Cook for 12 minutes. Add salt if needed."
    },
    {
      "position": 8,
      "text": "Prepare the gata by combining \u00be cup lukewarm water and ginataang gulay mix. Stir until well blended."
    },
    {
      "position": 9,
      "text": "Pour the gata into the cooking pot. Stir and cook for 8 to 10 minutes."
    },
    {
      "position": 10,
      "text": "Add the long green chili peppers. Cook for 2 minutes more."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
