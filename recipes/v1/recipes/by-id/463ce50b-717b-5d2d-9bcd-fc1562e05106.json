  "id": "463ce50b-717b-5d2d-9bcd-fc1562e05106",
  "slug": "crispy-spinach-recipe",
  "name": "Crispy Spinach Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Crispy Spinach is an appetizer dish where in spinach are dipped in a batter and fried until crispy. This is a very simple recipe that takes minimal effort",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine flour, egg, salt, and water and mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Heat a small cooking pot or frying pan then pour-in the cooking oil."
    },
    {
      "position": 3,
      "text": "When the oil is hot enough, dip the spinach in the batter one after the other (the mixture that you prepared in step #1 and fry each side until crispy. Repeat this step until all the leaves are cooked."
    },
    {
      "position": 4,
      "text": "Remove from the pot or pan and transfer to a plate lined with paper towel (this will absorb the oil)."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 6,
      "text": "Serve with Asian Dipping Sauce."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 10,
