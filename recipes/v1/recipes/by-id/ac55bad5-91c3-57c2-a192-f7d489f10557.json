  "id": "ac55bad5-91c3-57c2-a192-f7d489f10557",
  "slug": "pan-fried-noodles-with-beef-and-veggies",
  "name": "Pan Fried Noodles",
  "recipe_type": "main",
  "brief_description": "Fried flour noodles with beef, bok choy, and carrots.",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the noodles based on package instructions. Discard remaining water."
    },
    {
      "position": 2,
      "text": "Heat 2 tablespoons of cooking oil in a pan. Add the noodles. Fry until the bottom part turns light brown. Continue by frying the opposite side (Note: if necessary, do this in 2 batches). Remove the noodles from the pan and arrange on a serving dish."
    },
    {
      "position": 3,
      "text": "Combine all the sauce ingredients in a bowl. Mix well. Set aside."
    },
    {
      "position": 4,
      "text": "Heat remaining oil on the same pan. Stir fry the beef until it browns. Add onion, ginger, and garlic. Cook until onion softens."
    },
    {
      "position": 5,
      "text": "Add green onion and bok choy. Cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Pour the sauce mixture into the pan. Stir. Continue cooking until the sauce thickens to your desired consistency."
    },
    {
      "position": 7,
      "text": "Pour everything over the fried noodles. Serve hot."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
