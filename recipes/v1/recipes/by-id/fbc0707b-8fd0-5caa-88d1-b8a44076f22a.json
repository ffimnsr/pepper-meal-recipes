  "id": "fbc0707b-8fd0-5caa-88d1-b8a44076f22a",
  "slug": "bbq-beef-short-ribs-recipe",
  "name": "BBQ Beef Short Ribs Recipe",
  "recipe_type": "dessert",
  "brief_description": "Juicy beef short ribs marinated in a sweet and savory glaze, grilled until tender and caramelized to perfection.",
  "cuisine": "Korean",
  "instructions": [
    {
      "position": 1,
      "text": "Make the marinade by combining all the ingredients (except for the beef short ribs) in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Place the beef short ribs in a large Ziploc bag or a container with cover and then pour-in the marinade."
    },
    {
      "position": 3,
      "text": "Make sure that the beef is coated with marinade. Place inside the fridge and marinate for at least 3 hours."
    },
    {
      "position": 4,
      "text": "Heat the grill and then start grilling the beef short ribs. Try grilling each side for 5 minutes in medium heat. Lower the grill time if the heat is too much."
    },
    {
      "position": 5,
      "text": "Serve with Worcestershire sauce. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 30,
