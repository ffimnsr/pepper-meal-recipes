  "slug": "binakol-na-manok-recipe",
  "name": "Binakol na Manok Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Binakol na Manok",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and pepper all over the chicken. Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Arrange the chicken, onion, tomato, ginger, and young coconut water in a pot. Turn on the heat. Let boil."
    },
    {
      "position": 3,
      "text": "Put the lemongrass in the pot. Cover. Cook in low heat for 40 minutes."
    },
    {
      "position": 4,
      "text": "Add the potato. Cover and then cook for 10 minutes."
    },
    {
      "position": 5,
      "text": "Put the scallions, hot pepper leaves, and young coconut meat. Stir. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
