  "id": "ac569d84-07d5-54fa-99d4-e38c994f15d2",
  "slug": "how-to-cook-beef-kaldereta",
  "name": "How To Cook Beef Kaldereta",
  "recipe_type": null,
  "brief_description": "This is a recipe for Filipino Beef Kaldereta",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan or wok and then pour 3 tablespoons cooking oil. Stir-fry the bell peppers for 3 minutes. Remove the bell peppers and put in a plate. Set aside."
    },
    {
      "position": 2,
      "text": "Using the oil in the pan (add more if necessary), pan fry the carrots and potato for 3 to 5 minutes. Put these in a plate and then set aside."
    },
    {
      "position": 3,
      "text": "Heat the remaining 3 tablespoons of oil in a clean pot."
    },
    {
      "position": 4,
      "text": "Saut\u00e9 the garlic and onion"
    },
    {
      "position": 5,
      "text": "Add the beef. Cook until it turns light brown."
    },
    {
      "position": 6,
      "text": "Pour \u2013in tomato sauce and water. Let boil."
    },
    {
      "position": 7,
      "text": "Add the Knorr Beef Cube. Stir. Cover the pot. Continue to cook in low heat for 60 minutes or until the beef gets tender. Add more water if needed."
    },
    {
      "position": 8,
      "text": "Stir-in the liver spread and then add some salt and pepper."
    },
    {
      "position": 9,
      "text": "Put the pan-fried potato and carrots in the pot. Stir. Add the bell peppers."
    },
    {
      "position": 10,
      "text": "Cover the pot. Continue to cook for 5 minutes."
    },
    {
      "position": 11,
      "text": "Add the red pepper flakes. Stir and cook for 3 minutes more."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 80,
  "preparation_time_minutes": 10,
