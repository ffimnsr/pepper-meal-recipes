  "name": "Easy Pasta Salad Recipe",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for rotini pasta salad.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine pasta, bell pepper, olives, and broccoli. Gently toss."
    },
    {
      "position": 2,
      "text": "Pour-in olive oil."
    },
    {
      "position": 3,
      "text": "Sprinkle salt and ground black pepper. Toss."
    },
    {
      "position": 4,
      "text": "Refrigerate for 30 minutes."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
