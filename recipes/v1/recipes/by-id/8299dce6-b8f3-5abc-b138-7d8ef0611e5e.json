  "id": "8299dce6-b8f3-5abc-b138-7d8ef0611e5e",
  "slug": "spare-ribs-hamonado",
  "name": "Spare Ribs Hamonado",
  "recipe_type": "drink",
  "brief_description": "Pork ribs marinated and stewed in pineapple juice, soy sauce, and pineapple chunks.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Separate pineapple juice from the chunks. Combine juice with spare ribs in a bowl. Marinate for at least 1 hour. Remove the juice afterwards and set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Saute onion and garlic until onion softens."
    },
    {
      "position": 3,
      "text": "Add marinated ribs. Saute until color turns light brown."
    },
    {
      "position": 4,
      "text": "Pour-in pineapple juice. Add soy sauce and beef broth. Stir. Let the mixture boil."
    },
    {
      "position": 5,
      "text": "Put the pineapple chunks into the pan. Cover and adjust the heat between low to medium. Cook for 1 hour."
    },
    {
      "position": 6,
      "text": "Add brown sugar and season with ground black pepper and salt. Continue cooking until sauce reduces to half."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
