  "slug": "turkey-egg-and-cheese-breakfast-sandwich",
  "name": "Turkey, Egg, and Cheese Breakfast Sandwich",
  "recipe_type": "breakfast",
  "brief_description": "A delicious breakfast sandwich made of roast turkey, cheese, and fried egg",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Toast the bread slices."
    },
    {
      "position": 2,
      "text": "Spread mayonnaise on one side of the bread."
    },
    {
      "position": 3,
      "text": "Arrange Colby jack cheese (or your favorite cheese variety), turkey, and place the fried egg on top. Note: you can add ketchup if desired."
    },
    {
      "position": 4,
      "text": "Serve for breakfast along with coffee, hot chocolate, milk, or orange juice."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
