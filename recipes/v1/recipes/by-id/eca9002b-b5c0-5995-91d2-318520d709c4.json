  "schema_version": 1,
  "id": "eca9002b-b5c0-5995-91d2-318520d709c4",
  "slug": "pork-tapa-with-fried-banana-and-salted-egg",
  "name": "Pork Tapa with Fried Banana and Salted Egg",
  "recipe_type": "breakfast",
  "brief_description": "Pork Tapa with Fried Banana and Salted Egg is another breakfast option that you should consider. It is delicious and will surely give you the energy that you need to start the day.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine vinegar, sugar, salt, and pepper in a large bowl. Stir the mixture to blend completely."
    },
    {
      "position": 2,
      "text": "Put-in the sliced pork. Make sure that the pork slices gets coated with the vinegar mixture. Marinate for at least 3 hours (the longer the you marinate, the tastier it gets)."
    },
    {
      "position": 3,
      "text": "Remove the pork slices from the marinade. Arrange in a wide plate and let it stay in open air for 1 to 2 hours. You can also soak this under the sun for the same time if desired, but make sure to cover the meat to avoid contamination. I use either cling wrap or a strainer to cover the plate."
    },
    {
      "position": 4,
      "text": "Heat half of the cooking oil in a pan."
    },
    {
      "position": 5,
      "text": "Meanwhile, roll the sliced bananas in cornstarch. Make sure that the bananas are coated all over. The cornstarch will give a nice crisp texture to the outer part of the banana when fried."
    },
    {
      "position": 6,
      "text": "Once the oil gets hot, fry the bananas in medium heat for 1 to 2 minutes per side. Remove the fried banana from the pan and place in a plate lined with paper towels."
    },
    {
      "position": 7,
      "text": "Add more oil if needed then continue by frying the pork slices until it turns medium brown."
    },
    {
      "position": 8,
      "text": "Remove the fried pork slices from the pan. Arrange a single serving portion in a plate along with a cup of white rice and salted egg. Put-in the fried banana."
    },
    {
      "position": 9,
      "text": "Serve with a spicy vinegar dip."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
