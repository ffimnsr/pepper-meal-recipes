  "id": "9d098f3d-c1fb-5065-a701-591481bff822",
  "slug": "easy-cranberry-sauce-recipe",
  "name": "Easy Cranberry Sauce Recipe",
  "recipe_type": null,
  "brief_description": "This Easy Cranberry Sauce Recipe is the perfect match for any thanksgiving roast turkey. It also makes roast or baked chicken taste better.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour orange juice and water to a medium sauce pan. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add sugar. Stir until the sugar dissolves completely."
    },
    {
      "position": 3,
      "text": "Put-in cranberry and then let the liquid re-boil. Simmer for about 10 to 12 minutes."
    },
    {
      "position": 4,
      "text": "Let cool and then refrigerate overnight."
    },
    {
      "position": 5,
      "text": "Serve with Turkey for thanksgiving."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 18,
