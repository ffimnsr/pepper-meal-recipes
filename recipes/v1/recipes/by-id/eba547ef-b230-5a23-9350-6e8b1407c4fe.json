  "id": "eba547ef-b230-5a23-9350-6e8b1407c4fe",
  "slug": "pinoy-fried-chicken-recipe",
  "name": "Pinoy Fried Chicken",
  "recipe_type": "main",
  "brief_description": "Marinated chicken drumsticks that are steamed, air-dried, and deep-fried to perfection.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken, onion powder, nutmeg, cooking wine, patis, and Knorr SavorRich. Mix well and make sure that the chicken gets completely coated. Transfer everything to a resealable bag. Seal the bag and marinate overnight inside the refrigerator."
    },
    {
      "position": 2,
      "text": "Arrange the marinated chicken drumsticks on a steamer. Boil water and steam the chicken for 45 minutes."
    },
    {
      "position": 3,
      "text": "Remove the chicken from the steamer. Arrange over a wire rack. Air dry for 1 hour."
    },
    {
      "position": 4,
      "text": "Heat oil in a cooking pot or deep fryer. Fry the chicken until color turns golden brown."
    },
    {
      "position": 5,
      "text": "Arrange on a serving plate. Serve with banana ketchup. Serve and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 60,
  "rest_time_minutes": null,
