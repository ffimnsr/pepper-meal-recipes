  "id": "0017bb2a-d9c4-5d05-94db-5357aa60b4ac",
  "slug": "ginisang-sardinas-with-ampalayasardines-bitter-melon",
  "name": "Ginisang Sardinas with Ampalaya",
  "recipe_type": "main",
  "brief_description": "A Filipino dish of saut\u00e9ed sardines in tomato sauce with bitter melon, garlic, and onion. Quick to prepare and full of savory umami flavor balanced by the distinctive bitterness of ampalaya.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot over medium heat."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onion until the garlic starts to turn light brown."
    },
    {
      "position": 3,
      "text": "Add the sliced bitter melon. Continue to saut\u00e9 for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour in the sardines in tomato sauce. Gently stir to combine."
    },
    {
      "position": 5,
      "text": "Season with ground black pepper and fish sauce. Cover and cook over medium heat for 2 to 3 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Top with chopped scallions and toasted garlic."
    },
    {
      "position": 7,
      "text": "Serve hot with steamed rice. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 3,
