  "slug": "ginisang-sardinas-with-ampalayasardines-bitter-melon",
  "name": "Ginisang Sardinas with Ampalaya",
  "recipe_type": null,
  "brief_description": "This is a recipe for Sauteed Sardines with bittermelon. It is translated as Ginisang Sardinas with Ampalaya in Filipino.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onion until the garlic starts to turn light brown."
    },
    {
      "position": 3,
      "text": "Add the sliced bitter melon. Continue to saut\u00e9 for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour the contents of the large can of sardines. Gently stir."
    },
    {
      "position": 5,
      "text": "Add ground black pepper and fish sauce. Cover and continue to cook in medium heat for 2 to 3 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Top with chopped scallions and toasted garlic."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 3,
