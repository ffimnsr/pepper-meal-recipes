{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "7e391c5d-cec9-5e0b-9ba0-28bbe5694936",
  "slug": "beef-empanadas-recipe",
  "name": "Beef Empanada Recipe",
  "recipe_type": "snack",
  "brief_description": "Fried Beef Empanadas with paprika, raisins, and green peas in a homemade flaky dough.",
  "cuisine": "Cuban Filipino Spanish",
  "instructions": [
    {
      "position": 1,
      "text": "Make the filing by heating 2 tablespoons of cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the onion and then add the ground black pepper."
    },
    {
      "position": 3,
      "text": "Put-in the beef and then cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Add the raisins, paprika, sugar, and salt. Stir and then pour-in the beef broth."
    },
    {
      "position": 5,
      "text": "Cover and then simmer for 10 to 15 minutes."
    },
    {
      "position": 6,
      "text": "Remove the cover and let the liquid evaporate."
    },
    {
      "position": 7,
      "text": "Add the green peas.Stir and then cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Turn-off the heat. Set aside."
    },
    {
      "position": 9,
      "text": "Prepare the dough by placing the salt, AP flour, baking powder, and sugar in a mixing bowl. Use a wire whisk to mix the ingredients."
    },
    {
      "position": 10,
      "text": "Put the butter pieces in the mixing bowl along with the cold water. Mix using a pastry blender. If you don't have one, use 2 kitchen knives instead. You should mix like you are cutting the dough in several pieces."
    },
    {
      "position": 11,
      "text": "Grab about 3 tablespoons of the mixture and then shape it into a ball. do this until all the dough is consumed."
    },
    {
      "position": 12,
      "text": "Refrigerate the dough balls for about 20 to 25 minutes."
    },
    {
      "position": 13,
      "text": "Flatten the dough ball by gently pressing the center with your hand against a clean flour-dusted flat surface. Use a rolling pin to spread the dough and make a flat circle about 4 to 5 inches in diameter."
    },
    {
      "position": 14,
      "text": "Arrange about 4 to 5 tablespoons of filling in the middle of the dough. Lock the edges by folding or by pressing the tip of a fork in both sides."
    },
    {
      "position": 15,
      "text": "Meanwhile, heat about 2 to 3 cups of oil in a cooking pot. Deep fry the empanadas for about 3 to 5 minutes or until the color turns golden brown."
    },
    {
      "position": 16,
      "text": "Remove from the cooking pot and then arrange in a plate lined with paper towels. Let the excess oil drip-off."
    },
    {
      "position": 17,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 18,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
