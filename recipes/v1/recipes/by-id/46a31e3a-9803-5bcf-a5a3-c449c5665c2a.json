  "id": "46a31e3a-9803-5bcf-a5a3-c449c5665c2a",
  "slug": "pork-menudo-with-ham-recipe",
  "name": "Pork Menudo with Ham Recipe",
  "recipe_type": null,
  "brief_description": "A classic Filipino pork stew featuring tender pork and ham simmered with potatoes, carrots, and bell peppers in a rich tomato sauce with sweet raisins.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onion"
    },
    {
      "position": 3,
      "text": "Once the onion gets soft, add the pork. Cook until light brown."
    },
    {
      "position": 4,
      "text": "Add the ham. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour the tomato sauce and beef broth. Let boil."
    },
    {
      "position": 6,
      "text": "Add the raisins. Cover and cook between low to medium heat until the pork gets tender."
    },
    {
      "position": 7,
      "text": "Add potato, carrot, and bell pepper. Cook for 5 to 8 minutes."
    },
    {
      "position": 8,
      "text": "Add salt and ground black pepper. Stir. Cook for 2 to 3 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve with rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
