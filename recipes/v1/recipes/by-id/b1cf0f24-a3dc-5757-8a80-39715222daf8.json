  "id": "b1cf0f24-a3dc-5757-8a80-39715222daf8",
  "slug": "bacon-and-egg-filipino-chicken-adobo",
  "name": "Bacon and Egg Chicken Adobo",
  "recipe_type": null,
  "brief_description": "This is a recipe for Bacon and Egg Chicken Adobo",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken, garlic, vinegar, soy sauce and whole peppercorn in a bowl. Mix well. Cover the bowl and marinate the chicken for at least 3 hours. Note:I suggest to marinate overnight for better results."
    },
    {
      "position": 2,
      "text": "Heat the bacon in a pan. Continue to cook the bacon until the oil is extracted and the bacon becomes crispy. Remove the bacon from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Pan-fry the marinated chicken in bacon grease (usen medium heat) for 3 minutes per side. Add the garlic used to marinate the chicken."
    },
    {
      "position": 4,
      "text": "Pour the remaining marinade ingredients in the pan and add water. Also add the crisp bacon. Let boil. Cover and cook between low to medium heat for 30 minutes."
    },
    {
      "position": 5,
      "text": "Add the brown sugar. Stir."
    },
    {
      "position": 6,
      "text": "Add boiled eggs. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 15,
