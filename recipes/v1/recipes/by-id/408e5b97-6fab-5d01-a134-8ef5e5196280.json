  "slug": "how-to-cook-new-york-strip-steak-with-sauteed-spinach",
  "name": "New York Strip Steak with Sauteed Spinach Recipe",
  "recipe_type": null,
  "brief_description": "This Yummy New York Strip Steak was a hit. Learn to cook this dish by following our detailed Recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and ground black pepper on all sides of the steak. Let stand for at least 10 minutes."
    },
    {
      "position": 2,
      "text": "Grill the steak in medium heat for about 6 to 8 minutes per side."
    },
    {
      "position": 3,
      "text": "Note: if you are using charcoal grill, try flipping the steak once in a while to prevent it from burning."
    },
    {
      "position": 4,
      "text": "Remove the steak from the grill and let it rest for 15 minutes."
    },
    {
      "position": 5,
      "text": "Meanwhile, heat a pan and pour-in the extra virgin olive oil."
    },
    {
      "position": 6,
      "text": "Add the garlic and cook until the color turns light brown,"
    },
    {
      "position": 7,
      "text": "Put-in the spinach and saut\u00e9 for 1 minute."
    },
    {
      "position": 8,
      "text": "Turn off the heat and arrange the spinach in a large serving plate."
    },
    {
      "position": 9,
      "text": "Put the grilled steak on top of the spinach."
    },
    {
      "position": 10,
      "text": "Serve with mashed potato on the side along with your favorite steak sauce."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
