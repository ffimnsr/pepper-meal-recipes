  "id": "8466ea16-bf72-597e-b277-55576c40d85f",
  "slug": "beef-pares-lomi",
  "name": "Beef Pares Lomi",
  "recipe_type": "dessert",
  "brief_description": "Sweet beef stew with fresh noodles in a thick and savory sauce.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok. Saut\u00e9 garlic, onion, and ginger until the onion softens."
    },
    {
      "position": 2,
      "text": "Add beef. Saut\u00e9 until the beef turns light brown."
    },
    {
      "position": 3,
      "text": "Pour the soy sauce and water. Cover and Let boil."
    },
    {
      "position": 4,
      "text": "Add star anise, sugar, and Knorr Beef Cube. Stir. Cover the wok and then adjust the heat to a low setting. Continue cooking until the beef tenderizes"
    },
    {
      "position": 5,
      "text": "Remove and discard the star anise. Add the fresh noodles and then season with salt and ground black pepper. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Thicken the soup by adding a slurry. Do this by combining potato starch with 3 tablespoons of water. Pour it into the wok and add beaten egg. Stir. Cook until the soup thickens based on your desired consistency."
    },
    {
      "position": 7,
      "text": "Serve with soy dipping sauce and garlic fried rice, if preferred. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
