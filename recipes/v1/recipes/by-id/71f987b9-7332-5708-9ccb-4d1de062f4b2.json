  "id": "71f987b9-7332-5708-9ccb-4d1de062f4b2",
  "slug": "filipino-fried-chicken",
  "name": "Filipino Fried Chicken",
  "recipe_type": null,
  "brief_description": "Moist and juicy fried chicken with light breading",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the marinade ingredients in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Put the chicken in a resealable bag. Pour-in the marinade mixture. Let all the air out of the bag, seal it, and then place inside the refrigerator. Marinate for at least 1 hour."
    },
    {
      "position": 3,
      "text": "Combine the breading ingredients in a bowl. Mix well."
    },
    {
      "position": 4,
      "text": "Dredge the marinated chicken in the breading mixture. Shake off the excess and place the chicken on a plate."
    },
    {
      "position": 5,
      "text": "Meanwhile, heat the cooking oil in a wok until it reaches 300 F."
    },
    {
      "position": 6,
      "text": "Deep fry the chicken for 25 minutes while turning the chicken over in the middle of the process."
    },
    {
      "position": 7,
      "text": "Remove the Filipino fried chicken from the wok. Place it over a wire rack to cool down. (See notes below)2"
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with Filipino Chicken Gravy."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
