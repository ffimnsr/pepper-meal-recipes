{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "f39dd0cc-9073-5758-9bd6-bd9bd2a16f77",
  "slug": "bbq-chicken-wrap",
  "name": "BBQ Chicken Wrap",
  "recipe_type": "main",
  "brief_description": "Tender grilled chicken glazed in smoky barbecue sauce, wrapped in a soft tortilla with crisp lettuce and vegetables.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the chicken breasts. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Coat the chicken with vegetable oil."
    },
    {
      "position": 3,
      "text": "Heat-up the grill. Start to grill one side of the chicken for 3 minutes per side."
    },
    {
      "position": 4,
      "text": "Baste BBQ sauce on each side of the chicken and continue to grill for another 3 to 4 minutes per side. Remove from the grill and let it cool down."
    },
    {
      "position": 5,
      "text": "Slice the grilled chicken BBQ croswise into strips. Apply the remaining BBQ sauce on top."
    },
    {
      "position": 6,
      "text": "Meanwhile, lay a piece of flour tortilla flat on a large plate. Arrange half of each fresh vegetables (see recipe above) over the tortilla. Top with cheese and slices of chicken from one breast."
    },
    {
      "position": 7,
      "text": "Secure the contents by wrapping the tortilla all over it. Do this by folding a quarter of both sides (left and right) inwards. Roll the flour tortilla from bottom to top until the contents are secured."
    },
    {
      "position": 8,
      "text": "Serve with your favorite dressing."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 10,
