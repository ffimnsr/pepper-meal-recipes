  "id": "68cc15e4-0a96-59c3-8da6-0403fc301ecc",
  "slug": "garlic-mashed-potato",
  "name": "Garlic Mashed Potato",
  "recipe_type": "side",
  "brief_description": "Creamy garlic mashed potatoes made with skin-on baking potatoes for extra nutrients and flavor. This simple side dish pairs perfectly with fried chicken, grilled steaks, or any protein.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Boil the water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the water starts to boil, add the potatoes with the skin on. Boil for 20 minutes."
    },
    {
      "position": 3,
      "text": "Drain the water and let the potatoes cool down."
    },
    {
      "position": 4,
      "text": "Place the potatoes in a mixing bowl. Mash using a potato masher or a fork."
    },
    {
      "position": 5,
      "text": "Add the salt, pepper, garlic powder, parsley, butter and milk. Continue to mash until all the ingredients are evenly distributed."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve as is or with delicious gravy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
