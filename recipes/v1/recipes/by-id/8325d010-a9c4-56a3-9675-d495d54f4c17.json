  "slug": "almond-jelly-with-fruit-cocktail-gelatin-recipes",
  "name": "Almond Jelly with Fruit Cocktail Recipe",
  "recipe_type": "dessert",
  "brief_description": "This Almond Jelly with Fruit Cocktail recipe is the best. Discover why this is different from any other gelatin recipes.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine milk and agar powder. Stir"
    },
    {
      "position": 2,
      "text": "Add almond extract and mix well. Set aside."
    },
    {
      "position": 3,
      "text": "Boil water and put-in sugar. Stir until well dissolved."
    },
    {
      "position": 4,
      "text": "Pour-in the agar and milk mixture and let boil while gently stirring."
    },
    {
      "position": 5,
      "text": "Let the temperature cool down then transfer to a shallow container."
    },
    {
      "position": 6,
      "text": "Refrigerate for 2 to 3 hours."
    },
    {
      "position": 7,
      "text": "Slice the jelly into squares and mix with the fruit cocktail."
    },
    {
      "position": 8,
      "text": "Serve for dessert. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
