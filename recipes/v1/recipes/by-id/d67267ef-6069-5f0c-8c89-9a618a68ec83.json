  "id": "d67267ef-6069-5f0c-8c89-9a618a68ec83",
  "slug": "pork-monggo-with-kangkong",
  "name": "Pork Monggo with Kangkong Recipe",
  "recipe_type": null,
  "brief_description": "Sauteed mung beans with pork and water spinach.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Soak mung beans in 3 cups water overnight. Drain water."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot. Saute onion, garlic, and tomato. Once onion and tomato softens, add lechon kawali. Cook for 1 to 2 minutes. Note: if using raw pork, saute until it turns light brown."
    },
    {
      "position": 3,
      "text": "Add soaked mung beans and saute for 2 minute. Pour water. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Pork Cube. Stir. Cover and boil between low to medium heat until mung beans are soft (around 30 minutes). Add water if needed. Note: if using un-soaked mung beans, the boiling time will be longer."
    },
    {
      "position": 5,
      "text": "Add chicharon and kangkong. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Season with patis and ground white pepper."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 60,
  "rest_time_minutes": null,
