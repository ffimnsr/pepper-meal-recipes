  "id": "572cc3b2-3672-5d68-82c0-a14e455b4d01",
  "slug": "breakfast-daing-na-bisugo-sinangag",
  "name": "Breakfast Daing na Bisugo with Sinangag",
  "recipe_type": "breakfast",
  "brief_description": "Daing na Bisugo with Sinangag sounds like a perfect pair for a Filipino breakfast; it will be even better if we add some spicy vinegar dip.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a frying pan."
    },
    {
      "position": 2,
      "text": "Once the oil is hot, fry all 3 pieces of daing (salted dried fish) at the same time for 1 minute per side. Make sure to quickly turn the fish over to avoid the first side from being burnt."
    },
    {
      "position": 3,
      "text": "Once both sides are fried, remove the fish from the pan. Place it in a plate lined with paper towel to absorb the oil."
    },
    {
      "position": 4,
      "text": "Transfer the fried daing na bisugo in a plate with sinangag."
    },
    {
      "position": 5,
      "text": "Serve with spiced vinegar."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 1,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
