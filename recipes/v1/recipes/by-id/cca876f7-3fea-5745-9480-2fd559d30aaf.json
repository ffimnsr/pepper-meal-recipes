  "id": "cca876f7-3fea-5745-9480-2fd559d30aaf",
  "slug": "pork-bicol-express-recipe",
  "name": "Pork Bicol Express Recipe",
  "recipe_type": null,
  "brief_description": "Pork cooked in coconut milk mixture with chillies and shrimp paste. This is a dish has the spiciness and delicious taste that is perfect with white rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onion until the onions get soft."
    },
    {
      "position": 3,
      "text": "Add the ground black pepper and pork. Saut\u00e9 until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Pour 1 1/2 cups water. Let boil. Cover and continue to cook in medium heat until the pork gets tender and the water almost evaporates completely."
    },
    {
      "position": 5,
      "text": "Prepare the gata by combining \u00be cup lukewarm water and Knorr Ginataang Gulay mix. Stir until the powder dissolves completely. Set aside."
    },
    {
      "position": 6,
      "text": "Add the long green pepper, chili pepper, and shrimp paste into the cooking pot. Stir."
    },
    {
      "position": 7,
      "text": "Pour the gata mixture into the pot. Let boil. Cover and cook in medium heat until the liquid reduces to half. Make sure to stir once in a while."
    },
    {
      "position": 8,
      "text": "Add salt to taste. Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
