  "id": "8a17f160-d41f-5010-ac61-fdba28c825dd",
  "slug": "bbq-baby-back-ribs-recipe",
  "name": "BBQ Baby Back Ribs Recipe",
  "recipe_type": "dessert",
  "brief_description": "Tender baby back ribs in a sweet, smoky barbecue glaze, baked then grilled until glossy and caramelized.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and pepper on the baby back ribs. Let stand for 15 minutes."
    },
    {
      "position": 2,
      "text": "Rub the Worcestershire sauce and 1/4 cup of barbecue sauce. Refrigerate for 30 minutes to 1 hour for the meat to absorb the flavor."
    },
    {
      "position": 3,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 4,
      "text": "Place the slab in a covered oval roaster. Bake for 90 minutes."
    },
    {
      "position": 5,
      "text": "Remove the cover and then brush the remaining barbecue sauce over the baby back ribs."
    },
    {
      "position": 6,
      "text": "Increase the temperature to 410 degrees Fahrenheit."
    },
    {
      "position": 7,
      "text": "Put-the uncovered roasted back in the oven and bake for 10 to 12 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven and then transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 12,
