  "id": "fddcabdb-3377-5b46-8567-bd43f0d3c21b",
  "slug": "bok-choy-guisado-recipe",
  "name": "Bok Choy Guisado Recipe",
  "recipe_type": null,
  "brief_description": "Bok Choy Guisado is a simple bok choy dish with shrimp and pork. This dish is ideal for ordinary days wherein you want to enjoy something simple yet delicious.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pan or wide cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil is hot, saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the pork. Cook for 10 minutes or until medium brown."
    },
    {
      "position": 4,
      "text": "Put-in the shrimp. Stir and cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the bok choy. Stir-fry for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the chicken broth, fish sauce, and ground black pepper. Let boil. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve with white rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
