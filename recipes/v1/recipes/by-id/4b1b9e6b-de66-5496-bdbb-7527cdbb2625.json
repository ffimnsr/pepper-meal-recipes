  "id": "4b1b9e6b-de66-5496-bdbb-7527cdbb2625",
  "slug": "ginisang-sitaw-recipe",
  "name": "Ginisang Sitaw",
  "recipe_type": "side",
  "brief_description": "Ginisang sitaw is sauteed string beans with ground pork, garlic, onion, and tomato, seasoned with fish sauce and black pepper. Everything cooks in one pan in under 30 minutes. Serve it with steamed rice and fried fish for a classic Filipino meal.",
  "cuisine": "Asian Filipino Southeast Asian",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan over medium heat."
    },
    {
      "position": 2,
      "text": "Saute the chopped garlic and onion until the onion softens."
    },
    {
      "position": 3,
      "text": "Add the ground pork to the pan and cook until it turns medium brown."
    },
    {
      "position": 4,
      "text": "Add the diced tomatoes and cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Add the string beans and saute for 1 minute."
    },
    {
      "position": 6,
      "text": "Pour in the water and bring to a boil. Cook until the string beans become tender."
    },
    {
      "position": 7,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
