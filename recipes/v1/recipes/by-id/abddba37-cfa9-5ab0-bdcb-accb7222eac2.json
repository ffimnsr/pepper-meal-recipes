  "id": "abddba37-cfa9-5ab0-bdcb-accb7222eac2",
  "slug": "sotanghon-vermicelli-guisado",
  "name": "Sotanghon Guisado Recipe",
  "recipe_type": null,
  "brief_description": "This Sotanghon Guisado Recipe is perfect. It has everything that I like with this noodle dish. Try it and see for yourself.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in the cooking pot and apply heat."
    },
    {
      "position": 2,
      "text": "When the water starts boiling, add celery, 3/4 cup diced onions, whole peppercorns, and chicken"
    },
    {
      "position": 3,
      "text": "Simmer for 40 to 60 minutes then turn off the heat and let cool."
    },
    {
      "position": 4,
      "text": "Remove the meat from the chicken using your hands. Discard the bones and skin. Set aside."
    },
    {
      "position": 5,
      "text": "Filter the liquid using a strainer and set aside. This will be the chicken broth."
    },
    {
      "position": 6,
      "text": "Soak the noodles in water until it becomes soft."
    },
    {
      "position": 7,
      "text": "Heat a clean wok or cooking pot and pour-in cooking oil."
    },
    {
      "position": 8,
      "text": "When the oil is hot enough, saut\u00e9 garlic and the remaining 3/4 cup diced onions."
    },
    {
      "position": 9,
      "text": "Add-in chicken and cook for 2 minutes."
    },
    {
      "position": 10,
      "text": "Pour-in annatto water and chicken broth then bring to a boil."
    },
    {
      "position": 11,
      "text": "Stir-in the carrots and half of the chopped onion leeks. Cook for 3 minutes."
    },
    {
      "position": 12,
      "text": "Add the noodles and fish sauce then cook for another 2 minutes."
    },
    {
      "position": 13,
      "text": "Transfer to a serving plate and top with remaining onion leeks and place lemon or calamansi slices on the side."
    },
    {
      "position": 14,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
