  "id": "f4827e14-676b-540a-b45f-79d8b3609f43",
  "slug": "stuffed-eggplant",
  "name": "Stuffed Eggplant",
  "recipe_type": null,
  "brief_description": "Simplicity is beauty, just like what you are seeing now. My wife made this simple stuffed eggplant out of some available ingredients that we have in the fridge and everything went well.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Grill the eggplants until the insides are soft and the skin gets burnt. Peel the skin. Arrange the eggplants in a flat surface and press with a fork. Set aside."
    },
    {
      "position": 2,
      "text": "Combine the beaten eggs, salt, and ground black pepper. Whisk to mix well."
    },
    {
      "position": 3,
      "text": "Heat the oil in a frying pan."
    },
    {
      "position": 4,
      "text": "Dip the eggplant in the egg mixture then lay flat on the pan. Fry for 1 minute."
    },
    {
      "position": 5,
      "text": "While frying one side, arrange the chopped sweet peppers and scallions on top of the eggplant. Scoop a tablespoon or two of the egg mixture and pour over the eggplant."
    },
    {
      "position": 6,
      "text": "Turn the eggplant over using a wide spatula. Fry the opposite side for 3 to 5 minutes in low to medium heat."
    },
    {
      "position": 7,
      "text": "Top the other half with sweet peppers and scallions, then pour some beaten egg mixture over."
    },
    {
      "position": 8,
      "text": "Flip the eggplant so that the opposite side gets cooked. Fry for 2 to 3 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
