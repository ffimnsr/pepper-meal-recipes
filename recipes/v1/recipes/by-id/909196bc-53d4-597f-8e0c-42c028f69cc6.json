  "id": "909196bc-53d4-597f-8e0c-42c028f69cc6",
  "slug": "ground-pork-giniling-recipe",
  "name": "Pork Giniling Recipe",
  "recipe_type": null,
  "brief_description": "Pork Giniling is a pork dish that makes use of ground pork as the primary ingredient. Ground pork is stewed in tomato sauce and water to bring out the taste while vegetables such as carrots and potatoes (some also like this with raisins and green peas) are added for additional flavor and nutrition.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour-in the cooking oil."
    },
    {
      "position": 2,
      "text": "When the oil is hot enough, put-in the garlic and saut\u00e9 until the color turns light brown."
    },
    {
      "position": 3,
      "text": "Add the onions and saut\u00e9 until the texture becomes soft."
    },
    {
      "position": 4,
      "text": "Put-in the ground pork and cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add the beef or pork cube, tomato sauce, and water and let boil. Simmer for 20 minutes."
    },
    {
      "position": 6,
      "text": "Put the carrots and potatoes in then stir until every ingredient is properly distributed. Simmer for 10 to 12 minutes."
    },
    {
      "position": 7,
      "text": "Add salt, ground black pepper, and sugar then stir."
    },
    {
      "position": 8,
      "text": "Put in the boiled eggs and turn off the heat."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl and serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
