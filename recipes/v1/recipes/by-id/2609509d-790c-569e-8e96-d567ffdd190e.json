  "id": "2609509d-790c-569e-8e96-d567ffdd190e",
  "slug": "pancit-recipe",
  "name": "Pancit Recipe",
  "recipe_type": null,
  "brief_description": "Egg noodles tossed with pork belly, squid balls, kikiam and a medley of vegetables",
  "cuisine": "Asian Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Sear the pork belly until the outer part turns medium brown. Pour 1 \u00bd cups of water. Let boil. Simmer until the pork tenderizes and enough fat gets rendered."
    },
    {
      "position": 2,
      "text": "Remove the pork from the pan. Using the rendered fat, fry the squid balls, and kikiam for 2 to 2 \u00bd minutes or until it browns. Remove from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Reduce the oil to at least 2 tablespoons. Saut\u00e9 the bell peppers, carrots, and cabbage. Continue saut\u00e9ing for 2 minutes. Remove from the pan. Set aside."
    },
    {
      "position": 4,
      "text": "Put 3 tablespoons of the oil back into a clean pan. Saut\u00e9 the Chinese sausage for 30 seconds. Add the onion and garlic, then cook until the onion softens"
    },
    {
      "position": 5,
      "text": "Add soy sauce, oyster sauce, and water. Let boil. Adjust the heat to the lowest setting."
    },
    {
      "position": 6,
      "text": "Add Maggi Magic Chicken Cubes. Stir."
    },
    {
      "position": 7,
      "text": "Add the egg noodles. Cook for 2 minutes while occasionally tossing the noodles. (see notes below)"
    },
    {
      "position": 8,
      "text": "Season with ground black pepper."
    },
    {
      "position": 9,
      "text": "Combine \u00bc cup water with 2 tablespoons of cornstarch. Stir and pour the mixture into the pan. Toss. (see notes below)"
    },
    {
      "position": 10,
      "text": "Add back the pork, Chinese sausage, squid balls, and kikiam. Toss until everything is evenly distributed."
    },
    {
      "position": 11,
      "text": "Add the sauteed vegetables. Toss."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 25,
