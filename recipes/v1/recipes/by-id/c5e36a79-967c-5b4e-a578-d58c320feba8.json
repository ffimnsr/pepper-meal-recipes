  "id": "c5e36a79-967c-5b4e-a578-d58c320feba8",
  "slug": "taiwanese-popcorn-chicken",
  "name": "Taiwanese Popcorn Chicken",
  "recipe_type": "appetizer",
  "brief_description": "Crispy bite-sized breaded fried chicken with holy basil",
  "cuisine": "Taiwanese",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the chicken into bite sized pieces."
    },
    {
      "position": 2,
      "text": "Arrange sliced chicken in a mixing bowl and add the marinade ingredients. Mix well. Cover the bowl. Refrigerate for at least 3 hours."
    },
    {
      "position": 3,
      "text": "Combine 1 cup of tapioca flour with the marinated chicken. Sprinkle around 1 tablespoon of water and dredge the chicken until it gets completely coated. Let it stay for at least 3 minutes."
    },
    {
      "position": 4,
      "text": "Heat the oil to 300F."
    },
    {
      "position": 5,
      "text": "Deep fry the chicken for 6 to 7 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the pot and arrange over a wire rack."
    },
    {
      "position": 7,
      "text": "Fry the basil for 1 minute."
    },
    {
      "position": 8,
      "text": "Place everything in a clean mixing bowl. (See notes3)"
    },
    {
      "position": 9,
      "text": "Sprinkle salt and ground black pepper. Toss."
    },
    {
      "position": 10,
      "text": "Serve and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 25,
