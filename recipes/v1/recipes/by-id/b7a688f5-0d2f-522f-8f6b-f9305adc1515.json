  "id": "b7a688f5-0d2f-522f-8f6b-f9305adc1515",
  "slug": "ham-and-egg-fried-rice",
  "name": "Ham and Egg Fried Rice",
  "recipe_type": "breakfast",
  "brief_description": "Easy fried rice recipe with ham and egg.",
  "cuisine": "American Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine rice, salt and garlic powder. Gently mix the ingredients using a slotted spoon or your clean hands. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 3,
      "text": "Add the ham and cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the rice. Stir."
    },
    {
      "position": 5,
      "text": "Add soy sauce and stir. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Clear one side of the pan by moving the rice on the other side to the point where you can see the bottom of the pan."
    },
    {
      "position": 7,
      "text": "Pour-in the beaten egg. Let it cook then cut it into small pieces using the tip of your spatula."
    },
    {
      "position": 8,
      "text": "Mix the egg with the rice and other ingredients. Cook for 2 to 3 minutes more."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
