  "id": "94d32634-acc1-5089-8023-e228284f4e8e",
  "slug": "slow-cooked-beef-nilaga-soup-recipe",
  "name": "Slow Cooked Beef Nilaga Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "Slow Cooked Beef Nilaga Soup is the tastiest and the most tender beef nilaga that I ever had. It is quite obvious that 8 to 10 hours of slow cooking would extract the flavors from the beef and make it very tender to the point that it literally melts in your mouth.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine water, beef, bananas, potato, onion, fish sauce, and whole peppercorn in a slow cooker. Set the slow cooker or crock pot to high and slow cook for 8 to 10 hours."
    },
    {
      "position": 2,
      "text": "Gently stir the mixture. Add cabbage, green beans, and bok choy. Continue to cook for 12 to 15 minutes. Add more fish sauce if necessary."
    },
    {
      "position": 3,
      "text": "Transfer to a serving bowl. Serve hot."
    },
    {
      "position": 4,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 480,
