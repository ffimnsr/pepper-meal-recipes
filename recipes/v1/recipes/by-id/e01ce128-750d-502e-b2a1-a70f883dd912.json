  "slug": "sotanghon-and-egg-noodle-soup",
  "name": "Sotanghon and Egg Noodle Soup",
  "recipe_type": "soup",
  "brief_description": "Chicken and Egg Noodle Soup is a comforting and flavorful dish featuring tender chicken and egg noodles simmered in a savory broth, often enriched with vegetables and garnished for added taste.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic until it starts to brown. Add the onion and continue saut\u00e9ing until it softens."
    },
    {
      "position": 3,
      "text": "Stir in the annatto powder and 2 teaspoons of fish sauce."
    },
    {
      "position": 4,
      "text": "Pour in the water and bring it to a boil."
    },
    {
      "position": 5,
      "text": "Add the vermicelli and chicken powder. Cover and let it re-boil, then reduce the heat to a simmer and cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Toss the noodles, then add the cabbage."
    },
    {
      "position": 7,
      "text": "Cover and cook for an additional 2 minutes."
    },
    {
      "position": 8,
      "text": "Add the boiled eggs and green onions, and season with fish sauce and ground black pepper."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate and top with toasted garlic. Serve hot, share, and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
