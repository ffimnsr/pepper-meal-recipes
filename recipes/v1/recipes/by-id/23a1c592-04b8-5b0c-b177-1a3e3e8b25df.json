  "id": "23a1c592-04b8-5b0c-b177-1a3e3e8b25df",
  "slug": "fried-rice",
  "name": "Fried Rice",
  "recipe_type": null,
  "brief_description": "All of us have our own concept of fried rice. In my case, I had this notion ever since I was a kid. Fried rice to me is not as simple as it sound; it is a medley of different ingredients collaborating together to produce colorful and great tasting rice dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Gently mash the leftover rice using your hands to loosen it. Make sure that your hand are clean."
    },
    {
      "position": 2,
      "text": "Add salt and garlic powder and toss. Set aside."
    },
    {
      "position": 3,
      "text": "Meanwhile, heat the cooking oil in a frying pan."
    },
    {
      "position": 4,
      "text": "Once the oil becomes hot, saut\u00e9 the minced ham. Continue to cook the ham for 1 minute."
    },
    {
      "position": 5,
      "text": "Put the ham on one side of the pan. Pour-in the beaten eggs. Cook one side for 1 minute. Flip the egg and cook the other side for another minute. Separate the eggs into multiple pieces by letting the tip of the spatula run through in a chopping motion."
    },
    {
      "position": 6,
      "text": "Add the rice. Cook and continuously toss every minute for 5 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the green peas. Toss and cook for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Top with chopped green onions."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
