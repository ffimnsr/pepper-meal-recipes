  "id": "8decbc0a-1a33-5337-8685-d981060a2c2f",
  "slug": "century-egg-congee-with-salted-pork",
  "name": "Century Egg Congee with Salted Pork",
  "recipe_type": null,
  "brief_description": "Century Egg Congee is a type of rice porridge with slices of black eggs and some chopped scallions. The egg is known as Century Egg or Hundred Year Old Egg.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the pork. Let it stand for 1 to 2 hours."
    },
    {
      "position": 2,
      "text": "Steam the salted pork for 30 to 40 minutes."
    },
    {
      "position": 3,
      "text": "Let the pork cool down and then shred the pork using your fingers. Set Aside."
    },
    {
      "position": 4,
      "text": "Prepare the congee by combining 4 to 5 cups of water with the chicken stock in a large cooking pot. Boil."
    },
    {
      "position": 5,
      "text": "Add the rice and then wait for the liquid to re-boil. Stir every 5 minutes. Continue cooking in medium heat until porridge-like texture is achieved (usually about 30 minutes or more)."
    },
    {
      "position": 6,
      "text": "Transfer the congee in an individual serving bowl. Top with sliced century egg, shredded salted pork, and scallions."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
