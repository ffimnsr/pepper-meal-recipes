  "slug": "manila-clam-and-mussel-tinola-recipe",
  "name": "Manila Clam and Mussel Tinola Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Manila Clams and Mussels Tinola",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute ginger, fennel, and onion."
    },
    {
      "position": 3,
      "text": "Once onion becomes translucent, pour water into the pot. Let boil. Cover and continue to boil in medium heat for 8 minutes.Note: This process will extract the flavor from the onion, fennel, and ginger."
    },
    {
      "position": 4,
      "text": "Add mussels and clams. Continue to cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add spinach, red pepper flakes, and salt. Stir. Cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 7,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
