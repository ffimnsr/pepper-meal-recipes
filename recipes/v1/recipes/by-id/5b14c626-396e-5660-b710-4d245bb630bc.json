  "schema_version": 1,
  "id": "5b14c626-396e-5660-b710-4d245bb630bc",
  "slug": "easy-liempo-inihaw",
  "name": "Easy Liempo Inihaw",
  "recipe_type": "main",
  "brief_description": "Marinated pork belly grilled to perfection and served with spicy vinegar and pickled papaya. This is a perfect barbecue dish to serve during tailgate parties or excursions.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange pork belly in a large bowl. Add all marinade ingredients including Knorr SavorRich Pork Liquid Seasoning. Mix well. Let it stay for at least 30 minutes."
    },
    {
      "position": 2,
      "text": "Prepare the basting sauce by combining all basting sauce ingredients in a bowl. Stir until well blended. Set aside."
    },
    {
      "position": 3,
      "text": "Heat-up the grill. Start to grill the marinated liempo for 3 minutes. Brush basting sauce on the top part and the turn it. Baste and grill the opposite side for 3 minutes. Perform these steps with the same duration of grilling until the liempo gets medium brown. Note: it usually takes 3 cycles to completely cook the pork belly."
    },
    {
      "position": 4,
      "text": "Remove from the grill. Let the liempo cool down. Slice into serving pieces."
    },
    {
      "position": 5,
      "text": "Serve with spicy vinegar and papaya atchara. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "medium",
