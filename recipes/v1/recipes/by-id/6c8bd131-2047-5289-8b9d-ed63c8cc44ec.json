  "id": "6c8bd131-2047-5289-8b9d-ed63c8cc44ec",
  "slug": "how-to-make-tofu-in-black-bean-sauce",
  "name": "Tofu in Black Bean Sauce Recipe",
  "recipe_type": null,
  "brief_description": "This Tofu in Black Bean Sauce Recipe is so delicious and is easy to follow. Try this recipe today and see how amazing this dish is. Happy cooking!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a bowl, combine vegetable stock, cornstarch, sesame oil, cooking rice wine, soy sauce, salt, and ground black pepper. Stir until everything is well incorporated and set aside."
    },
    {
      "position": 2,
      "text": "Heat a pan and pour-in cooking oil."
    },
    {
      "position": 3,
      "text": "When the oil is hot enough, saut\u00e9 the garlic and ginger."
    },
    {
      "position": 4,
      "text": "Add the black beans and cook for a minute."
    },
    {
      "position": 5,
      "text": "Add the red bell pepper and cook for another minute."
    },
    {
      "position": 6,
      "text": "Put-in the fried tofu and cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add the green onion and bok choy and cook for 2 minutes more."
    },
    {
      "position": 8,
      "text": "Pour-in the sauce mixture and cook until the texture becomes thick."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl and serve."
    },
    {
      "position": 10,
      "text": "Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
