  "id": "ec6863b0-de24-5faa-95d8-93478123605b",
  "slug": "how-to-make-crispy-potato-wedges",
  "name": "Crispy Potato Wedges Recipe",
  "recipe_type": "side",
  "brief_description": "Crispy Potato Wedges make a good side with burger or hotdog sandwich. This can be enjoyed simply with ketchup. Try this delicious recipe today!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Slice the potatoes into wedges. Set aside."
    },
    {
      "position": 2,
      "text": "Preheat oven to 450 degrees Fahrenheit."
    },
    {
      "position": 3,
      "text": "Combine flour, garlic powder, onion powder, paprika, seasoned salt, and ground black pepper in a freezer bag then shake to mix the ingredients."
    },
    {
      "position": 4,
      "text": "Dip the potato wedges in beaten egg then place 5 to 8 pieces at a time in the freezer bag with the dry ingredient combination and shake until all wedges are evenly coated."
    },
    {
      "position": 5,
      "text": "Arrange the coated wedges in a baking sheet then apply a little spray of cooking oil on each piece."
    },
    {
      "position": 6,
      "text": "Bake for 20 to 30 minutes or until the color turns golden brown. Deep-frying is another option."
    },
    {
      "position": 7,
      "text": "Turn the oven off and remove the baked wedges."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate then serve with your favorite dipping sauce."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
