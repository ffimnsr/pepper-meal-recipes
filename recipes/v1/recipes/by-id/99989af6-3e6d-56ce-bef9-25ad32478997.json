  "id": "99989af6-3e6d-56ce-bef9-25ad32478997",
  "slug": "corned-beef-sinigang",
  "name": "Corned Beef Sinigang",
  "recipe_type": null,
  "brief_description": "This is a recipe for Corned Beef Sinigang.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a cooking pot. Add tomato, onion, and corned beef. Let boil. Cover and cook between low to medium heat for 1 1/2 to 2 hours or until the beef becomes tender. Note: add more water as needed."
    },
    {
      "position": 2,
      "text": "Add Knorr Sinigang sa Sampaloc Mix. Stir."
    },
    {
      "position": 3,
      "text": "Add daikon radish, okra, eggplant, long green pepper, and snake beans.Cover and cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 5,
      "text": "Add Spinach. Turn off heat."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 10,
