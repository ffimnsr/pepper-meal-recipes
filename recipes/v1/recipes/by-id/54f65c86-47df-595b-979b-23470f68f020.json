  "id": "54f65c86-47df-595b-979b-23470f68f020",
  "slug": "pork-and-potato-stew-recipe",
  "name": "Pork and Potato Stew Recipe",
  "recipe_type": "side",
  "brief_description": "Are you looking for an easy weeknight dinner ideas? Pork and Potato stew is a good dish that I recommend. It is easy to make and can be eaten with different side dishes such as whit rice, wild rice, or even unsalted crackers.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Dredge the pork slices in all-purpose flour. Pan fry until the color turns medium brown."
    },
    {
      "position": 3,
      "text": "Add onion, tomato, and celery. Stir and cook for 5 minutes in medium heat."
    },
    {
      "position": 4,
      "text": "Add thyme and oregano."
    },
    {
      "position": 5,
      "text": "Pour-in the chicken stock; let boil. Cover and simmer for 45 minutes while stirring every 10 minutes."
    },
    {
      "position": 6,
      "text": "Add the potato. Cook for 10 to 12 minutes in medium heat."
    },
    {
      "position": 7,
      "text": "Once the texture thickens, add salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
