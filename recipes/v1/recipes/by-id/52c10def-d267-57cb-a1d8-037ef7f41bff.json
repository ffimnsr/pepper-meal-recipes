  "id": "52c10def-d267-57cb-a1d8-037ef7f41bff",
  "slug": "sinigang-na-buntot-ng-baboy-with-gabi",
  "name": "Sinigang na Buntot ng Baboy with Gabi",
  "recipe_type": "soup",
  "brief_description": "A hearty Filipino sour soup featuring tender pig tails, taro (gabi), and vegetables in a tangy tamarind broth.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 3 cups water in a pot."
    },
    {
      "position": 2,
      "text": "Add the pork and cook for 10 minutes."
    },
    {
      "position": 3,
      "text": "Discard the water. Pour the remaining 5 cups of water and let boil with the pork. Add tomato and onion. Boil in medium heat for 40 minutes. Add more water if needed."
    },
    {
      "position": 4,
      "text": "Add the taro (gabi). Continue to cook for 20 minutes."
    },
    {
      "position": 5,
      "text": "Stir-in the sinigang mix and add the peppers, string beans, and eggplant. Cover and continue to cook for 12 minutes."
    },
    {
      "position": 6,
      "text": "Taste the soup and decide if you want to add more water. Pour some fish sauce (patis) and stir."
    },
    {
      "position": 7,
      "text": "Put the spinach on top. Turn the heat off and then cover the pot. Let it stay covered for 5 minutes."
    },
    {
      "position": 8,
      "text": "Stir the soup so that all the ingredients will be evenly distributed. Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
