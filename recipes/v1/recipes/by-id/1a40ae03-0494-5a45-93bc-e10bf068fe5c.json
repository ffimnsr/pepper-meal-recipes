  "id": "1a40ae03-0494-5a45-93bc-e10bf068fe5c",
  "slug": "spicy-wonton-soup-recipe",
  "name": "Spicy Wonton Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "Spicy Wonton Soup is a Chinese dish that features wontons, which are dumplings filled with meat or vegetables, in a spicy broth. The soup typically includes ingredients like chili oil, garlic, and scallions, providing a flavorful and warming meal with a balance of heat and savory depth!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add the pork neck bones and medium chopped onion. Continue to boil between low to medium heat for 1 \u00bd hours."
    },
    {
      "position": 3,
      "text": "Meanwhile, prepare the wonton by combining all the wonton ingredients in a bowl (except the wrapper). Mix well."
    },
    {
      "position": 4,
      "text": "Scoop 2 teaspoons of pork mixture and arrange it in the middle of the wrapper. Seal by folding the wrapper in a way that both ends meet together forming a triangular shape. Press against the side of the wonton to ensure that it remains intact. Set aside."
    },
    {
      "position": 5,
      "text": "Remove the pork neck bones from the pot. Set it aside. (You can use it to make another dish)."
    },
    {
      "position": 6,
      "text": "Add 1 teaspoon salt, 1 teaspoon garlic powder, and \u00bd teaspoon ground black pepper in the cooking pot. Stir."
    },
    {
      "position": 7,
      "text": "Add the noodles and wonton into the pot. Let the liquid re-boil. Continue to cook 8 minutes."
    },
    {
      "position": 8,
      "text": "Add the scallions and half of the chili oil and toasted garlic. Cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a bowl. Top with remaining toasted garlic and chili oil."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 90,
  "rest_time_minutes": null,
  "difficulty": "hard",
