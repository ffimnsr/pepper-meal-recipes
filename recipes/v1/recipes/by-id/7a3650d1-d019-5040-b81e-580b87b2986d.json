  "id": "7a3650d1-d019-5040-b81e-580b87b2986d",
  "slug": "sizzling-pusit",
  "name": "Sizzling Pusit",
  "recipe_type": "appetizer",
  "brief_description": "Quick and easy sizzling squid appetizer.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make the sauce by melting 2 tablespoons of margarine in a pan. Add flour. Stir and continue cooking using medium to high heat for 1 minute. Add Knorr Shrimp Cube. Continue stirring until all ingredients are well blended. Add Knorr Liquid Seasoning, banana ketchup, cooking wine, and water. Stir and let boil. Season with garlic powder and onion powder. Set aside."
    },
    {
      "position": 2,
      "text": "Heat 2 tablespoons of cooking oil in a pan. Saut\u00e9 ginger and onion until the layers of the onion separate."
    },
    {
      "position": 3,
      "text": "Stir-in carrot and celery. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add bell pepper and squid. Continue cooking for 2 minutes. Season with salt and ground black pepper."
    },
    {
      "position": 5,
      "text": "Heat 1 \u00bd tablespoons margarine in a metal plate. Add squid and vegetables and pour sauce all over."
    },
    {
      "position": 6,
      "text": "Serve while sizzling hot."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 7,
  "rest_time_minutes": null,
  "difficulty": "medium",
