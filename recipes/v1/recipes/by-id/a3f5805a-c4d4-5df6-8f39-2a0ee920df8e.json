  "id": "a3f5805a-c4d4-5df6-8f39-2a0ee920df8e",
  "slug": "burger-steak-sardinas",
  "name": "Burger Steak Sardinas",
  "recipe_type": "main",
  "brief_description": "Burger patty made from sardines and banana blossoms with creamy gravy",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the minced banana blossom in a bowl. Add 1 tablespoon of salt. Rub it all over. Wash the salt off and drain the excess water."
    },
    {
      "position": 2,
      "text": "Separate the sardines from the sauce. Combine the sardines and banana heart. Add 1 egg, \u00bd teaspoon garlic powder, 1 teaspoon onion powder, \u00bd teaspoon salt, and \u00bc teaspoon ground black pepper. Mix everything together while mashing the sardines in the process."
    },
    {
      "position": 3,
      "text": "Gradually add all-purpose flour. Continue mixing until the mixture becomes firm."
    },
    {
      "position": 4,
      "text": "Scoop around \u00bc cup of the mixture and shape it into patties. Set aside."
    },
    {
      "position": 5,
      "text": "Make the gravy by melting the butter in a saucepan. Add all-purpose flour. Stir while cooking until lumps form and the mixture turns medium brown in color. Add the sauce from the canned sardines and half of the amount of milk while constantly stirring. Add more milk as needed until your desired consistency is achieved. Season with onion powder, salt, and ground black pepper. Set aside."
    },
    {
      "position": 6,
      "text": "Meanwhile, heat 2 tablespoons of cooking oil in a clean pan. Fry the burger patties in medium heat until it browns. Do the same thing on the opposite side."
    },
    {
      "position": 7,
      "text": "Arrange the sardines burger steak on a plate and then top with the gravy."
    },
    {
      "position": 8,
      "text": "Serve this with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
