  "id": "28a7c705-2f73-592c-8cfb-169d4adad738",
  "slug": "how-to-make-suchi-california-roll-recipe-video",
  "name": "California Roll",
  "recipe_type": "side",
  "brief_description": "California Roll or California Maki is a sushi roll that is made inside out. Crabstick, avocado, and cucumber are placed in the center of the nori",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a small bowl, combine the rice vinegar, sugar, and salt then stir well."
    },
    {
      "position": 2,
      "text": "Place in a microwave oven for about 10 seconds then stir again so that all the ingredients will be dissolved."
    },
    {
      "position": 3,
      "text": "Pour the vinegar-sugar-salt mixture on the sushi rice then mix well. Set aside."
    },
    {
      "position": 4,
      "text": "Cut the sushinori (nori) in half crosswise."
    },
    {
      "position": 5,
      "text": "Lay one sushinori (shiny side down) on a flat surface"
    },
    {
      "position": 6,
      "text": "Scoop some sushi rice and spread over the sushinori (make sure to distribute the rice evenly)"
    },
    {
      "position": 7,
      "text": "Sprinkle sesame seeds on top of the sushi rice"
    },
    {
      "position": 8,
      "text": "Cover the mat (or bamboo mat) with plastic (such as cling wrap)"
    },
    {
      "position": 9,
      "text": "Place the mat on a flat surface then put the sushinori with rice over the mat. The part that has the rice should be facing down."
    },
    {
      "position": 10,
      "text": "Arrange the crabstick, cucumber, and avocado in the center of the sheet"
    },
    {
      "position": 11,
      "text": "Grab the edge of the mat, keeping the fillings in place with your fingers, and roll it into a tight cylinder, using the mat to shape the cylinder. Set aside."
    },
    {
      "position": 12,
      "text": "Continue doing the process until all the rice are used."
    },
    {
      "position": 13,
      "text": "Trim the edge of the rolled sushi then cut the cylinder in half using a sharp knife"
    },
    {
      "position": 14,
      "text": "Slice each half crosswise into three equal pieces."
    },
    {
      "position": 15,
      "text": "Place in a serving plate then serve with soysauce and wasabi. Share and enjoy!"
    }
  ],
  "servings": 4,
