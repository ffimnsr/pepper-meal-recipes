  "id": "8594c39a-84a0-5fde-adf3-527cd48d8ce0",
  "slug": "beef-teriyaki-tapa-with-fried-rice-and-egg",
  "name": "Beef Teriyaki Tapa with Fried Rice and Egg",
  "recipe_type": "dessert",
  "brief_description": "Beef teriyaki tapa with fried rice and egg is a sweet version of tapsilog that is as good as the traditional dish. This comes with garlic fried rice and egg",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the sliced beef in a medium bowl. Pour the teriyaki sauce in the bowl and then mix. Cover and refrigerate for at least 1 hour."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan. Once the oil gets hot, put the beef in the pan including the marinade. Stir fry for 5 to 10 minutes or until the sauce completely evaporates."
    },
    {
      "position": 3,
      "text": "Cook the egg depending on your preference. See this post about ways on how to cook eggs."
    },
    {
      "position": 4,
      "text": "Arrange a cup of garlic fried rice in a plate along with the egg. Put half of the beef teriyaki tapa on the plate and then serve."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 60,
