  "schema_version": 1,
  "id": "fb9eb99d-6c6a-5a73-a727-94bf1bd7743d",
  "slug": "ginisang-puso-ng-saging",
  "name": "Ginisang Puso ng Saging",
  "recipe_type": "main",
  "brief_description": "At the heart of this Ginisang Puso ng Saging recipe is an ingredient that Filipinos love to work with in their food",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Clean the banana heart and slice it into thin pieces. Combine \u00bd cup vinegar and 1 cup of water in a large bowl. Put the sliced banana heart into the mixture. Rub the salt onto it and soak for 10 to 20 minutes. Drain the liquid mixture and then wring the banana hearts (a chunk at a time) to force the liquid to come out. Set aside."
    },
    {
      "position": 2,
      "text": "Soak the vermicelli in 2 cups of water for 12 minutes. Drain the water and then set the vermicelli aside."
    },
    {
      "position": 3,
      "text": "Heat the oil in pan. Saut\u00e9 the garlic and onion until the latter softens."
    },
    {
      "position": 4,
      "text": "Add the pork sliced. Continue to cook until it browns."
    },
    {
      "position": 5,
      "text": "Pour 1 cup of water into the pan. Cover it and let the water boil. Adjust the heat between low to medium heat setting. Cook until the liquid completely evaporates."
    },
    {
      "position": 6,
      "text": "Add the sliced banana hearts. Saut\u00e9 it for 2 minutes."
    },
    {
      "position": 7,
      "text": "Pour the remaining 1 cup of water into the pan. Let it boil. Add Knorr Pork Cube. Cover and cook until the water reduces to half. Note: you can add more water if the banana heart slices needs to be cooked further to soften."
    },
    {
      "position": 8,
      "text": "Remove the cover and season with fish sauce and ground black pepper as needed."
    },
    {
      "position": 9,
      "text": "Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
