{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "16df06d6-d4b7-5938-9d1a-debb625a32f3",
  "slug": "no-bake-filipino-style-lasagna",
  "name": "No Bake Filipino Style Lasagna",
  "recipe_type": "main",
  "brief_description": "I love lasagna! It is rich, tasty, and delicious. The sauce is cooked the same way as that of Filipino Spaghetti. I simply call it Filipino Style Lasagna.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the meat sauce by heating oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute onion and garlic until onion softens."
    },
    {
      "position": 3,
      "text": "Add ground pork. Cook until it turns light brown."
    },
    {
      "position": 4,
      "text": "Put the hotdog into the pot and saute with the rest of the ingredients for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour tomato sauce and water. Let boil. Cover and cook between low to medium heat for 40 minutes."
    },
    {
      "position": 6,
      "text": "Add sugar and season with ground black pepper and salt. Set aside."
    },
    {
      "position": 7,
      "text": "Boil around 1 \u00bc pint water in a cooking pot. Add \u00bd teaspoon salt. Put the lasagna in boiling water and continue to boil based on the package instructions. Note: I boiled the lasagna for 10 minutes as indicated in the carton instructions. Drain the water. Set lasagna aside."
    },
    {
      "position": 8,
      "text": "Prepare the white sauce by melting butter in a saucepan. Add half of the flour. Stir until blended. Add remaining flour and continue to stir. Gradually pour milk while stirring until the white sauce thickens. Add \u00bd cup cheddar cheese. Stir until melted."
    },
    {
      "position": 9,
      "text": "Assemble the lasagna by spreading meat sauce on an 8x8 baking pan. Layer the lasagna and then spread meat sauce over the lasagna. Spread the white sauce next and sprinkle some shredded cheese on top. Arrange the second layer of lasagna and top with meat sauce, white sauce, and cheese in the order mentioned. Arrange the third layer of lasagna. Top with white sauce first followed by the meat sauce. Sprinkle cheese all over."
    },
    {
      "position": 10,
      "text": "Cover the pan with aluminum foil. Note: Make sure that the foil does not touch the toppings of the lasagna. Place in a turbo broiler. Broil in 400F for 35 minutes. Remove the foil, set the temp to 350F and continue to broil for 12 minutes."
    },
    {
      "position": 11,
      "text": "Remove the lasagna from the broiler. Slice and serve."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
