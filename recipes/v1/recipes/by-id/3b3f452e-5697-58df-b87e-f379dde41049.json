{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "3b3f452e-5697-58df-b87e-f379dde41049",
  "slug": "caldereta",
  "name": "Caldereta",
  "recipe_type": null,
  "brief_description": "Beef neck bones and chuck cooked in tomato sauce with vegetables",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the beef neck bones, beef chuck, and soy sauce in a bowl. Mix well. Marinate for 10 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, heat 2 cups of cooking oil in a wok. Deep fry the potatoes and carrots until it starts to brown. Remove and set aside."
    },
    {
      "position": 3,
      "text": "Heat 3 tablespoons of oil used to fry the potatoes and carrots in a clean wok. Saut\u00e9 the onion for 1 minute."
    },
    {
      "position": 4,
      "text": "Add garlic. Continue saut\u00e9ing until the garlic starts to brown."
    },
    {
      "position": 5,
      "text": "Add the marinated beef. Saut\u00e9 until the outer layer of the beef starts to turn light brown (around 3 to 5 minutes)."
    },
    {
      "position": 6,
      "text": "Pour tomato sauce and water. Cover and let boil."
    },
    {
      "position": 7,
      "text": "Adjust the heat to a simmer. Continue cooking for 40 minutes."
    },
    {
      "position": 8,
      "text": "Add tomato paste. Simmer for 20 to 35 minutes or until the beef tenderizes completely. Note: Stir occasionally and add water as needed."
    },
    {
      "position": 9,
      "text": "Add beef powder, liver spread, peanut butter. Stir."
    },
    {
      "position": 10,
      "text": "Add green olives and bell peppers. Cook for 3 minutes."
    },
    {
      "position": 11,
      "text": "Season with Maggi Magic Sarap and ground black pepper. Stir."
    },
    {
      "position": 12,
      "text": "Put the fried potatoes and carrots into the wok. Toss."
    },
    {
      "position": 13,
      "text": "Add cheese. Continue cooking for 2 to 3 minutes."
    },
    {
      "position": 14,
      "text": "Transfer to a serving bowl. Serve with rice."
    },
    {
      "position": 15,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
