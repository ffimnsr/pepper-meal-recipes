  "id": "73c99d55-31f1-5fdf-be50-f67bbe2d9dad",
  "slug": "pesang-baboy-at-manok-recipe",
  "name": "Pesang Baboy at Manok Recipe",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Pesang Baboy at Manok. It pertains to pork and chicken cooked in ginger broth.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine 8 cups water, pork, chicken, whole peppercorn and ginger in a cooking pot. Let boil. Cover and continue to cook in low to medium heat for 1 hour."
    },
    {
      "position": 2,
      "text": "Pour the remaining 2 cups of water (add more if needed). Let it boil once more."
    },
    {
      "position": 3,
      "text": "Add the cubed potato and banana pepper (or siling pansigang). Continue to cook in medium heat for 10 minutes."
    },
    {
      "position": 4,
      "text": "Add the sliced Napa cabbage and pour-in the fish sauce. Stir and cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve with a cup of white rice."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 5,
