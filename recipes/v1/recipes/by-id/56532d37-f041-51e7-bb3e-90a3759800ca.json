  "id": "56532d37-f041-51e7-bb3e-90a3759800ca",
  "slug": "nilagang-buto-buto-ng-baka-recipe",
  "name": "Nilagang Buto-buto ng Baka Recipe",
  "recipe_type": "main",
  "brief_description": "A comforting Filipino beef soup featuring tender beef neck bones simmered for hours with saba bananas, potatoes, and leafy greens, finished with fish sauce for a savory broth.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a deep soup pot."
    },
    {
      "position": 2,
      "text": "Add onion, whole peppercorn, and beef neck bone. Let boil. Cover and continue to boil in low heat for 3 hours. Add water if needed. Note: You can use a pressure cooker to quickly cook the beef and tenderize the meat. It should take around 40 to 45 minutes."
    },
    {
      "position": 3,
      "text": "Add saba banana and potato. Boil in medium heat for 10 minutes."
    },
    {
      "position": 4,
      "text": "Add bok choy and Napa cabbage. Cover the pot, Turn the heat off. Let it stay covered for 8 minutes for the residual heat to partially cook the vegetables."
    },
    {
      "position": 5,
      "text": "Add patis. Stir."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve with rice."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 180,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 8,
  "difficulty": "easy",
