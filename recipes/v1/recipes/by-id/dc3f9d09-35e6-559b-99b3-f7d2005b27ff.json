  "id": "dc3f9d09-35e6-559b-99b3-f7d2005b27ff",
  "slug": "sisig-pizza",
  "name": "Sisig Pizza",
  "recipe_type": null,
  "brief_description": "Sisig Pizza is not a new dish. In fact, there has been a similar product included in the menu of a fast food Pizza chain in the Philippines some years back. To be honest, Sisig Pizza is something that will be appreciated by sisig lovers \u2013- this is simply sisig presented differently.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 400."
    },
    {
      "position": 2,
      "text": "Meanwhile, place the pizza though in a flat surface. Pour the Alfredo sauce over the pizza though and spread it all throughout equally."
    },
    {
      "position": 3,
      "text": "Arrange the sisig over the Alfredo sauce. This is best done using your hands (it will be better if you wear plastic gloves during the process)."
    },
    {
      "position": 4,
      "text": "Arrange the onion and sliced finger chili on top. Sprinkle chili flakes all over the pizza."
    },
    {
      "position": 5,
      "text": "Put the pizza in the oven. Bake for 20 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven. Slice."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
