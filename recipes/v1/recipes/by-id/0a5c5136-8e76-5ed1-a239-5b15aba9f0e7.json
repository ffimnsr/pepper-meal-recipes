  "id": "0a5c5136-8e76-5ed1-a239-5b15aba9f0e7",
  "slug": "chicken-bicol-express",
  "name": "Chicken Bicol Express",
  "recipe_type": "main",
  "brief_description": "Tender chicken pieces simmered in creamy coconut milk with shrimp paste and chili. A flavorful Filipino favorite that delivers comfort and spice in one dish.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saute garlic, onion, and ginger."
    },
    {
      "position": 2,
      "text": "Once the onion softens, add chicken and chili peppers. Stir and cook until chicken turns light brown."
    },
    {
      "position": 3,
      "text": "Pour-in coconut milk. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Chicken Cube. Continue to cook between low to medium heat until the coconut milk reduces to half."
    },
    {
      "position": 5,
      "text": "Add bagoong alamang and log green peppers. Cover and cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve!"
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
