  "id": "aaf12df0-f960-5929-97bb-36cf17e25bce",
  "slug": "healthy-chicken-menudo",
  "name": "Healthy Chicken Menudo",
  "recipe_type": null,
  "brief_description": "This is a recipe for healthy chicken menudo.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange chicken in a bowl.Add lime (or calamansi) and pour soy sauce. Also add garlic powder. Mix well. Let it stay for 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat a pan and pour safflower oil."
    },
    {
      "position": 3,
      "text": "Once the oil becomes hot, saute onion and garlic until onion becomes soft."
    },
    {
      "position": 4,
      "text": "Add the marinated chicken. Continue to cook until the chicken turns light brown."
    },
    {
      "position": 5,
      "text": "Pour tomato sauce into the pan. Stir."
    },
    {
      "position": 6,
      "text": "Pour chicken broth. Let boil. Continue to cook uncovered in medium heat until the sauce reduces to half."
    },
    {
      "position": 7,
      "text": "Add raisin, carrot, and potato. Cover the pan. Cook between low to medium heat for 8 to 10 minutes."
    },
    {
      "position": 8,
      "text": "Add the bell peppers. Continue to cook for 5 minutes. Note: add more chicken broth or water if needed."
    },
    {
      "position": 9,
      "text": "Sprinkle some ground black pepper to taste."
    },
    {
      "position": 10,
      "text": "Tranfer to a serving plate. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "hard",
