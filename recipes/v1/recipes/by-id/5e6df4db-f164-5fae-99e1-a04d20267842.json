  "id": "5e6df4db-f164-5fae-99e1-a04d20267842",
  "slug": "fried-pork-chops",
  "name": "Fried Pork Chop Recipe",
  "recipe_type": null,
  "brief_description": "Everyone loves Fried Pork Chops. Learn how to make this juicy and tastier variation by following our Fried Pork Chop Recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine salt, pepper, and garlic powder in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Rub the mixture on all the sides of the pork chops. Make sure to distribute evenly. Let stand for 1 hour."
    },
    {
      "position": 3,
      "text": "Heat a frying pan and pour-in cooking oil."
    },
    {
      "position": 4,
      "text": "When the oil becomes hot, put in the pork chops and adjust the heat to low."
    },
    {
      "position": 5,
      "text": "Fry each side for 8 to 10 minutes. Do not overcook."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate and serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
