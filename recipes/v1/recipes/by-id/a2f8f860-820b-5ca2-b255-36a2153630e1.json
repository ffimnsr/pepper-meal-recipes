  "id": "a2f8f860-820b-5ca2-b255-36a2153630e1",
  "slug": "artichoke-dip",
  "name": "Artichoke Dip",
  "recipe_type": "appetizer",
  "brief_description": "Artichoke Dip makes a good dipping sauce for almost all kinds of chips, vegetables, and crackers. This is the mainstay of every party.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In an oven safe bowl, combine artichoke hearts, Romano cheese, cream cheese, and green chiles. Mix well."
    },
    {
      "position": 2,
      "text": "Preheat oven to 375 degrees Fahrenheit."
    },
    {
      "position": 3,
      "text": "Put the bowl with the artichoke heart mixture. Bake for 16 to 20 minutes."
    },
    {
      "position": 4,
      "text": "Sprinkle some dried parsley flakes on top."
    },
    {
      "position": 5,
      "text": "Serve as a dipping sauce. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 20,
