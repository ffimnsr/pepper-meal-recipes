  "id": "deffd3b5-ac6c-531f-beb5-d6210d591865",
  "slug": "blueberry-muffins",
  "name": "Blueberry Muffins Recipe",
  "recipe_type": "dessert",
  "brief_description": "Blueberry Muffins are some of the best muffin varieties that you should try. Muffins refer to breads that are baked in small quantities.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "In a mixing bowl, combine flour, sugar, baking powder, and salt. Mix well and set aside."
    },
    {
      "position": 3,
      "text": "In another large mixing bowl, combine egg, vegetable oil, and milk. Whisk until all the ingredients are distributed (using an electric mixer)."
    },
    {
      "position": 4,
      "text": "Continue whisking while gradually adding the flour mixture."
    },
    {
      "position": 5,
      "text": "Turn the mixer off and add-in the blueberries. Fold-in the mixture until the blueberries are distributed well."
    },
    {
      "position": 6,
      "text": "Arrange paper cups (muffin or cupcake cups) on a muffin pan. Scoop mixture and arrange in each paper cups."
    },
    {
      "position": 7,
      "text": "Place the muffin pan inside the oven and bake for 22 to 25 minutes, or until it passes the toothpick test."
    },
    {
      "position": 8,
      "text": "Remove from the oven and allow the temperature to cool down."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate and then serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
