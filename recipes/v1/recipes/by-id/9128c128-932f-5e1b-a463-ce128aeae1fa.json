  "id": "9128c128-932f-5e1b-a463-ce128aeae1fa",
  "slug": "nilagang-baboy",
  "name": "Nilagang Baboy (Boiled Pork Soup)",
  "recipe_type": "soup",
  "brief_description": "Nilagang Baboy or Pork Nilaga is translated as boiled pork in Filipino. This is a soup dish commonly served for lunch or dinner on regular days. This is eaten with steamed white rice and is best served with patis (fish sauce) and siling labuyo (birds eye chili).",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a deep cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot, saute the onion."
    },
    {
      "position": 3,
      "text": "Add the whole pepper corn. Continue to cook for 20 seconds."
    },
    {
      "position": 4,
      "text": "Put-in the pork. Cook until the color turns light brown (about 3 to 5 minutes)."
    },
    {
      "position": 5,
      "text": "Pour-in the beef or pork broth. Bring to a boil. Simmer for 45 to 60 minutes or until the pork becomes tender."
    },
    {
      "position": 6,
      "text": "Add the saba banana and potatoes. Stir and cook for 12 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the cabbage. Add salt to taste. Stir. Cover and continue to cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve with a spicy fish sauce dipping sauce."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 2,
