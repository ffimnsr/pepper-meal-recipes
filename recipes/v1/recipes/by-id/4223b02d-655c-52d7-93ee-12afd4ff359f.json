  "id": "4223b02d-655c-52d7-93ee-12afd4ff359f",
  "slug": "ginataang-hipon-recipe",
  "name": "Ginataang Hipon Recipe",
  "recipe_type": "main",
  "brief_description": "Ginataang Hipon or Shrimps Cooked in Coconut Milk is a tasty Filipino shrimp recipe that goes well with warm steamed rice",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 onion, ginger, and garlic"
    },
    {
      "position": 3,
      "text": "Add ground black pepper and fish sauce. Cook for 30 seconds."
    },
    {
      "position": 4,
      "text": "Pour-in coconut milk. Let boil and reduce to half. Note: this is done by letting coconut milk evaporate by boiling in medium heat in about 20 to 25 minutes."
    },
    {
      "position": 5,
      "text": "Put-in shrimps. Cook for 5 to 7 minutes."
    },
    {
      "position": 6,
      "text": "Add green and red chilies. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Turn-off heat and then transfer to a serving plate"
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
