  "id": "8991c5ab-b1fe-54ec-85b9-21d63fe426a6",
  "slug": "egg-fried-rice",
  "name": "Egg Fried Rice",
  "recipe_type": "side",
  "brief_description": "This Egg Fried Rice is a quick and flavorful way to turn leftover rice into a satisfying meal. Tossed with eggs, soy sauce, and vegetables, it is perfect for busy days when you want comfort food in minutes.",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Crack the eggs into a bowl and beat lightly until smooth."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a wok over medium heat. Pour in the beaten eggs and cook until the bottom side turns light brown. Flip, cook the other side, then break into smaller pieces."
    },
    {
      "position": 3,
      "text": "Add the onion, bell pepper, and sweet peppers. Stir fry for about one minute until fragrant but still crisp."
    },
    {
      "position": 4,
      "text": "Add half of the leftover rice and stir fry for two minutes to loosen the grains. Then add the remaining rice and continue mixing until well combined."
    },
    {
      "position": 5,
      "text": "Pour in the soy sauce and sesame oil. Toss everything well so the rice absorbs the seasonings evenly."
    },
    {
      "position": 6,
      "text": "Season with salt and sugar. Add the green onions and cook for another minute while stirring continuously."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve hot and enjoy your Egg Fried Rice with your favorite dishes."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
