{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "02c1a1b8-afee-5e07-84e3-eeaffe1af5de",
  "slug": "grilled-rib-eye-steak-with-arroz-amarillo",
  "name": "Grilled Rib Eye Steak with Arroz Amarillo",
  "recipe_type": null,
  "brief_description": "This is a recipe for Grilled Rib Eye Steak with Arroz Amarillo",
  "cuisine": "Beef",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the Arroz Amarillo by heating olive oil in a pot."
    },
    {
      "position": 2,
      "text": "Add the long grain rice. Saute for 30 seconds."
    },
    {
      "position": 3,
      "text": "Add turmeric powder, paprika, and salt. Stir until all ingredients are well blended."
    },
    {
      "position": 4,
      "text": "Pour chicken broth. Bring to a boil. Cover the pot and continue to cook in medium heat for 9 to 11 minutes. Lower the heat to low and continue to cook for 20 to 25 minutes or until the rice completely absorbs the liquid. Set aside."
    },
    {
      "position": 5,
      "text": "Prepare the simple steak rub by combining the rub ingredients. Rub all over the steaks. Let it stay for 8 to 12 minutes."
    },
    {
      "position": 6,
      "text": "Grill each side of the steak for 5 to 6 minutes (for medium rare, which is my preference), or grill longer if desired to have either medium and well done steak. Note: Grilling steak for a longer amount of time can make the meat less tender."
    },
    {
      "position": 7,
      "text": "Remove the steak from the grill. let it rest for 10 minutes."
    },
    {
      "position": 8,
      "text": "Arrange Arroz Amarillo in a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 12,
