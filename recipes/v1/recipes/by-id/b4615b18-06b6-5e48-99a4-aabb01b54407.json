  "id": "b4615b18-06b6-5e48-99a4-aabb01b54407",
  "slug": "puto-cake",
  "name": "Puto Cake",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Puto Cake",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Sift the dry ingredients together in a bowl. Mix thoroughly using a wire whisk."
    },
    {
      "position": 2,
      "text": "Gradually pour milk into the mixture while whisking. You can also use a hand mixer, but it is not necessary."
    },
    {
      "position": 3,
      "text": "Add eggs. Continue to whisk until the mixture is well blended and the texture is soft. Note: you can also add vanilla extract in this step if desired."
    },
    {
      "position": 4,
      "text": "Pour the mixture into a mold such as a llanera or round baking pan."
    },
    {
      "position": 5,
      "text": "In a coking pot, boil water for steaming."
    },
    {
      "position": 6,
      "text": "Arrange the llanera mold in a steamer. Cover and steam for 12 minutes."
    },
    {
      "position": 7,
      "text": "Top with salted eggs. Continue to steam for 18 minutes or until it passes the toothpick test."
    },
    {
      "position": 8,
      "text": "Remove from the steamer. Let it cool down."
    },
    {
      "position": 9,
      "text": "Gently take the cake puto out of the mold and arrange in a plate."
    },
    {
      "position": 10,
      "text": "Serve for merienda. This can also be enjoyed with dinuguan."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 30,
