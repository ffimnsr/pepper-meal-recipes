  "id": "4f1f8ddb-304f-57c1-94c0-34460a38eee0",
  "slug": "sweet-and-sour-chicken-meatballs",
  "name": "Sweet and Sour Chicken Meatballs",
  "recipe_type": "dessert",
  "brief_description": "Ground chicken meatballs cooked in sweet and sour sauce.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the chicken balls by placing the ground chicken in a large mixing bowl. Grate a piece of Knorr chicken cube and then add salt and pepper. Crack egg on the bowl and then mix well until all ingredients are blended. Gradually add breadcrumbs while mixing."
    },
    {
      "position": 2,
      "text": "Scoop 2 tablespoons of mixture. Roll into a ball-shaped figure. Set aside. Perform this step until all the chicken mixture is consumed."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan. Fry the chicken meatballs using medium heat while rolling the balls every few seconds to cook it evenly. Remove the chicken meatballs from the pot once the outer part turns brown. Set aside."
    },
    {
      "position": 4,
      "text": "Make the sweet and sour sauce. Using remaining oil, saute onion until layers separate. Add bell pepper and carrot. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour-in water and then add sugar, vinegar, and banana ketchup. Let boil. Stir until all ingredients are well incorporated. Thicken the sauce by adding cornstarch diluted in water. Stir until desired consistency is achieved."
    },
    {
      "position": 6,
      "text": "Put the chicken back into the pot. Stir to coat with sauce."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
