  "slug": "crockpot-beef-pares-recipe",
  "name": "Crockpot Beef Pares Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Crockpot Beef Pares",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the crockpot ingredients in a crockpot / slow cooker. Cover and set to low heat. Slow cook for 8 hours"
    },
    {
      "position": 2,
      "text": "Remove the cover. Stir. Taste and add salt (if needed)."
    },
    {
      "position": 3,
      "text": "Transfer the beef pares with some sauce in a serving bowl. Top with chopped scallions. Prepare the soup by pouring 3 tablespoons of sauce in a bowl and add a cup of hot beef broth."
    },
    {
      "position": 4,
      "text": "Serve with garlic-fried rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 480,
  "preparation_time_minutes": 5,
