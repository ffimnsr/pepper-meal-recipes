  "id": "b4306614-1528-5e0c-b0ea-7339f8e87078",
  "slug": "how-to-make-apple-coleslaw",
  "name": "Apple Coleslaw Recipe",
  "recipe_type": "salad",
  "brief_description": "This Apple Coleslaw Recipe is very easy to prepare. It goes well with burgers, fried chicken, pork chops, and many more. Try it yourself.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the dressing by combining vinegar, honey, mayonnaise, salt, and ground black pepper. Mix well. Set aside."
    },
    {
      "position": 2,
      "text": "In a large mixing bowl, combine cabbage, apples, onion, parsley, and carrots."
    },
    {
      "position": 3,
      "text": "Pour-in the dressing and toss until the vegetables are coated."
    },
    {
      "position": 4,
      "text": "Refrigerate for at least 3 hours."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 10,
