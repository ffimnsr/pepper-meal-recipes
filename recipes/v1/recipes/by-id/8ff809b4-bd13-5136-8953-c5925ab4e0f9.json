  "id": "8ff809b4-bd13-5136-8953-c5925ab4e0f9",
  "slug": "tinolang-manok-sa-gata-recipe",
  "name": "Tinolang Manok sa Gata",
  "recipe_type": null,
  "brief_description": "This is a recipe for Tinolang Manok sa Gata",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute garlic, onion, and ginger. Continue to cook for 3 minutes or until the onion starts to get soft."
    },
    {
      "position": 3,
      "text": "Add the chicken. Stir fry until it turns light brown."
    },
    {
      "position": 4,
      "text": "Pour the coconut milk into the pot. Let boil."
    },
    {
      "position": 5,
      "text": "Add ground black pepper and chili pepper. Cover and cook in low heat for 35 minutes or until the chicken gets tender."
    },
    {
      "position": 6,
      "text": "Add papaya. Cover and cook for 7 minutes."
    },
    {
      "position": 7,
      "text": "Pour water into the pot. Let it boil."
    },
    {
      "position": 8,
      "text": "Add the chicken cube. Stir. Cover and cook for 5 to 8 minutes."
    },
    {
      "position": 9,
      "text": "Add the malunggay and fish sauce (patis). Stir and cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
