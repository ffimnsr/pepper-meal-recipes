  "id": "7f7ae6ee-9292-5fe1-a3da-5061936e3d74",
  "slug": "chicken-molo-soup-recipe",
  "name": "Chicken Molo Soup",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Chicken Molo Soup or Pancit Molo.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a bowl, combine the ground chicken, minced shrimp, half of the minced onion, 1 teaspoon ground black pepper, salt and sesame oil. Mix well."
    },
    {
      "position": 2,
      "text": "Lay a piece of wonton wrapper on a flat surface. Scoop a tablespoon of the chicken and shrimp mixture and then place it in the middle of the wrapper. Fold the wrapper until the mixture is secured. Do this step until the mixture is completely consumed. Set aside."
    },
    {
      "position": 3,
      "text": "Prepare the soup by heating the water in a cooking pot. Let boil."
    },
    {
      "position": 4,
      "text": "Add the onion, shrimp juice, annatto powder (or annatto water), and half of the toasted garlic. Cook in medium heat covered for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the wrapped chicken wontons, chicken cube, ground black pepper, and fish sauce. Cover and cook in low to medium heat for 12 to 15 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a bowl. Top with chopped scallions and more toasted garlic."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
