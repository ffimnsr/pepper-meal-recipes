  "id": "a8cca1d9-b54c-5513-81f6-c8845da3e2dc",
  "slug": "nilasing-na-tilapia-recipe",
  "name": "Nilasing na Tilapia Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for fried tilapia known as Nilasing na Tilapia. The fish is seasoned and soaked in wine for a few minutes and then fried to perfection.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Season both sides of the tilapia with salt, ground black pepper, and garlic powder. Rub all over the fish including the cavity."
    },
    {
      "position": 2,
      "text": "Arrange a fish in a deep plate. Pour the cooking wine on the tilapia. Marinate each side for 15 minutes."
    },
    {
      "position": 3,
      "text": "Combine the cornstarch and flour in a resealable bag. Shake well. Put the marinated tilapia in the bag and shake until it is coated with flour and cornstarch mixture. Set aside."
    },
    {
      "position": 4,
      "text": "Heat oil in a pan. Once the oil gets hot, gently fry one side of the tilapia in medium heat until it turns golden brown and crisp. Turn the fish over to cook the opposite side."
    },
    {
      "position": 5,
      "text": "Remove the tilapia from the pan and put in a plate lined with paper towel."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 35,
  "rest_time_minutes": null,
  "difficulty": "medium",
