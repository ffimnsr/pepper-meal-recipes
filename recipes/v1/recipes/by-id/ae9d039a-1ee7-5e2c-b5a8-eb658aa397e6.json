  "slug": "sardines-with-chayote-recipe",
  "name": "Sardines with Chayote Recipe",
  "recipe_type": null,
  "brief_description": "Sardines with Chayote is a common everyday dish. This has been a favorite among majority of Filipino households because it is affordable",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "When the oil becomes hot, saute the garlic until it turns light brown."
    },
    {
      "position": 3,
      "text": "Add the onion and chayote. Cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Put-in sardines, water, fish sauce, and pepper. Stir. Cook for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Transfer to a serving bowl. You can also top this over a cup of warm steamed white rice."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 12,
