  "slug": "how-to-make-kfc-style-gravy-recipe",
  "name": "KFC-Style Gravy",
  "recipe_type": null,
  "brief_description": "A rich, savory copycat KFC-style gravy perfect for drizzling over fried chicken or mashed potatoes.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a saucepan and put-in the butter. Let the butter melt under low heat."
    },
    {
      "position": 2,
      "text": "Add 2 tablespoons of all-purpose flour and cook in low heat while continuously stirring for 7 to 8 minutes or until the color turns medium brown. There is a tendency that the flour might burn when overcooked or if high heat is applied. Be extra cautious."
    },
    {
      "position": 3,
      "text": "Add the remaining flour and continue stirring."
    },
    {
      "position": 4,
      "text": "Gradually add water and chicken cube. Continuous stirring is needed to prevent lumps from forming."
    },
    {
      "position": 5,
      "text": "Put the heat to medium and bring the mixture to a boil. Cook for 5 minutes more while stirring once in a while until the texture thickens."
    },
    {
      "position": 6,
      "text": "Serve hot with fried chicken or mashed potato."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
