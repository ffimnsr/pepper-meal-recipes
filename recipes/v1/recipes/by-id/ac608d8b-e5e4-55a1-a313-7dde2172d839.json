  "id": "ac608d8b-e5e4-55a1-a313-7dde2172d839",
  "slug": "pamplina-recipe",
  "name": "Pamplina Recipe (Pork and Chorizo Soup with Beans)",
  "recipe_type": "soup",
  "brief_description": "Pamplina is a Spanish soup dish that was embraced by Filipinos. It is usually made from leftover soup dishes such as beef nilaga or pork nilaga",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the pork, pork and beans, onion, tomato, chorizo, and pork broth in a slow cooker. Slow cook in high mode for 5 hours. This will make the pork pata very tender and the soup more flavorful because of the flavors extracted from the ingredients."
    },
    {
      "position": 2,
      "text": "Once the pata becomes tender. Add water and Napa cabbage. Continue to slow cook for 1 to 1 1/2 hours."
    },
    {
      "position": 3,
      "text": "Add salt and pepper to taste. Stir."
    },
    {
      "position": 4,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
