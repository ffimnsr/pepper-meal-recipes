  "id": "2d808347-b06d-5856-99db-8201aabadb3c",
  "slug": "garlic-pepper-beef",
  "name": "Garlic Pepper Beef",
  "recipe_type": "main",
  "brief_description": "Easy beef stir fry with toasted garlic",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine beef sirloin and all the marinade ingredients. Mix well. Let it stay for at least 10 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, make the toasted garlic by heating oil in a pan. Add the garlic. Cook in a low heat setting until golden brown. Filter the garlic using a kitchen strainer. Set the toasted garlic and garlic oil aside."
    },
    {
      "position": 3,
      "text": "Heat the garlic oil on the same pan."
    },
    {
      "position": 4,
      "text": "Fry both sides of the marinated beef until it browns. Remove the fried beef from the pan. Set aside."
    },
    {
      "position": 5,
      "text": "Combine butter with the remaining oil. Let it melt. Add half of the knorr beef cube."
    },
    {
      "position": 6,
      "text": "Add the fried beef back into the pan. Stir fry for 30 seconds."
    },
    {
      "position": 7,
      "text": "Pour water. Let boil. Stir and continue cooking until the sauce thickens to your desired consistency."
    },
    {
      "position": 8,
      "text": "Sprinkle toasted garlic on top."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
