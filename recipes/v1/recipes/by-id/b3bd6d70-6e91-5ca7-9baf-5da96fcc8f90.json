  "id": "b3bd6d70-6e91-5ca7-9baf-5da96fcc8f90",
  "slug": "pork-adobo-flakes",
  "name": "Pork Adobo Flakes",
  "recipe_type": "breakfast",
  "brief_description": "I like to have Pork Adobo Flakes for breakfast. It is perfect with garlic fried rice and a cup of coffee. It is also a good way to recycle leftover pork adobo. Some like it crispy, while other like the texture to be just right.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Shred the pork adobo meat. You can do this with your hands. Simply pull the threads of the pork slices until all the pork are consumed. Set aside."
    },
    {
      "position": 2,
      "text": "Meanwhile, heat the oil in a pan."
    },
    {
      "position": 3,
      "text": "Once the oil starts to gets hot, put-in the minced garlic. Make sure that the oil is not too hot yet so that the garlic won't burn easily. Continue to cook the garlic until the color turns light brown. Remove the garlic and set aside."
    },
    {
      "position": 4,
      "text": "Using the remaining cooking oil, start to cook the adobo threads or by putting it in the pan. Cook for 1 minute while tossing once in a while."
    },
    {
      "position": 5,
      "text": "Add the soy sauce or worcestershire sauce and ground black pepper. Stir fry for 3 minutes."
    },
    {
      "position": 6,
      "text": "Transfer the cooked pork adobo flakes in a a serving bowl and top with fried garlic."
    },
    {
      "position": 7,
      "text": "Serve with garlic fried rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
