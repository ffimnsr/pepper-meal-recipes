  "id": "5098e567-a63f-54f8-a0b5-5b90f5a88079",
  "slug": "nilagang-pata-recipe-2",
  "name": "Nilagang Pata",
  "recipe_type": "soup",
  "brief_description": "Boiled pork hock soup with corn and bok choy",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Clean the pork hocks thoroughly. Set aside."
    },
    {
      "position": 2,
      "text": "Pour the water into a large cooking pot. Let it boil."
    },
    {
      "position": 3,
      "text": "Add the pork hocks. Cover and cook for 10 minutes."
    },
    {
      "position": 4,
      "text": "Skim-off the scums from the surface and then add Knorr Pork cube, onion and whole peppercorn. Cover, adjust the heat to the lowest setting. Simmer until the pork tenderizes completely. Note: this can take between 60 to 90 minutes."
    },
    {
      "position": 5,
      "text": "Adjust the heat between low and medium setting. Add the corn and potatoes. Cook for 10 minutes."
    },
    {
      "position": 6,
      "text": "Add the long green beans, bok choy, and cabbage. Continue boiling for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Season with fish sauce. Transfer to a serving bowl. Serve hot with rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
