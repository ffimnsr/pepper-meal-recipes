  "slug": "ginisang-upo-with-ground-pork-and-shrimp",
  "name": "Ginisang Upo with Ground Pork and Shrimp",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginisang Upo with Ground Pork and Shrimp",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in cooking pot"
    },
    {
      "position": 2,
      "text": "Saute garlic until light brown"
    },
    {
      "position": 3,
      "text": "Add onion and tomato. Continue to cook until soft"
    },
    {
      "position": 4,
      "text": "Put the ground pork into the pot. Cook until light brown"
    },
    {
      "position": 5,
      "text": "Add shrimp. Cook for 2 minutes"
    },
    {
      "position": 6,
      "text": "Add the opo squash (upo) into the pot. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add water. Cover the pot and continue to cook between low to medium heat for 7 minutes."
    },
    {
      "position": 8,
      "text": "Add patis, ground black pepper, and parsley. Stir."
    },
    {
      "position": 9,
      "text": "Transfer to serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
