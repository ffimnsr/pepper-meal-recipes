  "id": "0a4be0a7-987c-53f3-8016-3eb592f5c864",
  "slug": "ginisang-sayote-at-sardinas",
  "name": "Ginisang Sayote at Sardinas",
  "recipe_type": "main",
  "brief_description": "Sauteed chayote and canned sardines in tomato sauce cooked with garlic, onion, and tomato.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat 3 tablespoons of cooking oil in a pan over medium heat."
    },
    {
      "position": 2,
      "text": "Saute the garlic until it starts to brown."
    },
    {
      "position": 3,
      "text": "Add the onion and tomato. Continue sauteing for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the chayote and saute for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour the sardines in tomato sauce into the pan. Stir gently and cook for 30 seconds."
    },
    {
      "position": 6,
      "text": "Pour in the water and let it boil. Lower the heat. Simmer until the sauce reduces by half."
    },
    {
      "position": 7,
      "text": "Season with Maggi Magic Sarap."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve with rice. You can also top this with chopped green onions before serving."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
