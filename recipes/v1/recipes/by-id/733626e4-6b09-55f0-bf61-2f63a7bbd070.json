  "id": "733626e4-6b09-55f0-bf61-2f63a7bbd070",
  "slug": "stir-fried-beef-with-oyster-sauce-and-snap-peas",
  "name": "Stir Fried Beef with Oyster Sauce and Snap Peas",
  "recipe_type": null,
  "brief_description": "This is a recipe for Stir Fried Beef with Oyster Sauce and Snap Peas",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine 2 tablespoons oyster sauce, soy sauce, sherry, garlic powder, salt, and ground black pepper in a large mixing bowl. Stir."
    },
    {
      "position": 2,
      "text": "Add the beef slices. Continue to stir until the beef gets coated. Marinate the beef for 30 minutes."
    },
    {
      "position": 3,
      "text": "Heat the cooking oil in a wok or frying pan."
    },
    {
      "position": 4,
      "text": "Once the oil gets hot, put the onion and then cook for 30 seconds."
    },
    {
      "position": 5,
      "text": "Add the marinated beef including the marinade. Stir-fry for 4 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Add the snap peas and remaining oyster sauce."
    },
    {
      "position": 7,
      "text": "Combine cornstarch and water. Mix well. Pour the mixture in and then continue to cook while stirring for 3 to 4 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate and serve with rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 15,
