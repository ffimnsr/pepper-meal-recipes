  "id": "ca66a874-d1bf-5ca4-9210-957f34906737",
  "slug": "asian-recipe-rice-ball-mochiko-butsi-buchi-recipe",
  "name": "Buchi",
  "recipe_type": "dessert",
  "brief_description": "Buchi or Butsi is a rice cake made from sweet rice flour that is molded into shape with a sweet bean paste filling and sesame seed coating. This delectable treat is deep fried under high heat before serving.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, combine the sweet rice flour and water then mix wel (This should form a dough)."
    },
    {
      "position": 2,
      "text": "Separate the dough into individual pieces"
    },
    {
      "position": 3,
      "text": "Roll each individual piece of dough until a spherical (round) shape is formed"
    },
    {
      "position": 4,
      "text": "Press the center of the spherical dough until the shape becomes concave (there should be a hollow spot in the center)."
    },
    {
      "position": 5,
      "text": "Scoop the sweet red bean paste using an ordinary teaspoon or measuring spoon then fill it in the hollow space of the dough (amount is up to you, just don't overfill)."
    },
    {
      "position": 6,
      "text": "Seal the dough and roll it once more until the shape is spherical"
    },
    {
      "position": 7,
      "text": "Place the sesame seeds in a bowl then roll the sphere shaped dough over it. Make sure that the seeds stick on the dough"
    },
    {
      "position": 8,
      "text": "Heat the pan and pour-in the cooking oil."
    },
    {
      "position": 9,
      "text": "When the cooking oil is very hot, deep fry the dough until the sesame seed's color turns golden brown (about 2 to 3 minutes)"
    },
    {
      "position": 10,
      "text": "Remove the cooked buchi from the pan and drain excess oil."
    },
    {
      "position": 11,
      "text": "Serve and Enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 10,
