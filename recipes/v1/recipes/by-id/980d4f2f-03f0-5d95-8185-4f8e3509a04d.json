  "id": "980d4f2f-03f0-5d95-8185-4f8e3509a04d",
  "slug": "oven-baked-broiled-barbeque-spare-ribs-sauce-recipe",
  "name": "Oven BBQ Spareribs",
  "recipe_type": "main",
  "brief_description": "Barbecued spare ribs cooked in the oven with the perfect sauce",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 230F."
    },
    {
      "position": 2,
      "text": "Combine dry rub ingredients. Mix well. Rub it all over the pork ribs."
    },
    {
      "position": 3,
      "text": "Arrange the ribs in a roasting rack."
    },
    {
      "position": 4,
      "text": "Combine sauce ingredients in a bowl. Mix well. Pour it over the pork ribs. Cover the roasting rack. Put it in the oven and roast for 3 to 3 \u00bd hours."
    },
    {
      "position": 5,
      "text": "Set the oven to broil mode. Broil for 5 minutes"
    },
    {
      "position": 6,
      "text": "Remove the ribs from the oven and let it cool down. Transfer the sauce into a saucepan. Boil until the sauce thickens. Set aside."
    },
    {
      "position": 7,
      "text": "Arrange the ribs on a serving plate and then brush with the thickened sauce."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 225,
