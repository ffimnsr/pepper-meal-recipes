  "id": "c91c44ae-20c3-51f9-ac65-721b0502f763",
  "slug": "classic-macaroni-salad-recipe",
  "name": "Classic Macaroni Salad Recipe",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for Classic Macaroni Salad.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add 2 teaspoons salt and then put-in the elbow macaroni. Continue to boil for 6 minutes."
    },
    {
      "position": 3,
      "text": "Drain the water and add cold water into the pot. Let is stay for 3 minutes and then drain. Set the macaroni aside."
    },
    {
      "position": 4,
      "text": "Combine mayonnaise, vinegar, mustard powder, ground black pepper, salt, and sugar. Mix well."
    },
    {
      "position": 5,
      "text": "Add the minced vegetables (onion, carrot, celery, and bell peppers). Fold the mixture until blended."
    },
    {
      "position": 6,
      "text": "Add the macaroni. Continue to fold until all the ingredients are well blended."
    },
    {
      "position": 7,
      "text": "Cover the bowl. Refrigerate the macaroni salad for at least 3 hours."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve cold."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 12,
