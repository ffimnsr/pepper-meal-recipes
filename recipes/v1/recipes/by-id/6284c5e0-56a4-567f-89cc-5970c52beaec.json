  "id": "6284c5e0-56a4-567f-89cc-5970c52beaec",
  "slug": "pata-pochero",
  "name": "Pata Pochero",
  "recipe_type": "main",
  "brief_description": "Pork hock stew with chorizo.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok. Saut\u00e9 onion for 30 seconds. Add garlic. Saut\u00e9 for 20 seconds, and then add tomato. Saut\u00e9 until the onion softens."
    },
    {
      "position": 2,
      "text": "Add chorizo. Cook for 2 minutes."
    },
    {
      "position": 3,
      "text": "Add pata (pork leg), fish sauce, tomato sauce, and water. Let boil. Cook for 1 to 1 \u00bd hours between low to medium heat. Note: add water as needed."
    },
    {
      "position": 4,
      "text": "Add banana, potato, and garbanzos. Cook for 5 to 8 minutes."
    },
    {
      "position": 5,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 6,
      "text": "Put the cabbage and long green beans into the wok. Cover and cook for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Add bok choy. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve with warm rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
