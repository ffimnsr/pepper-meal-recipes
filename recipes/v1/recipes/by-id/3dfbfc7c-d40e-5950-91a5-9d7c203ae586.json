  "id": "3dfbfc7c-d40e-5950-91a5-9d7c203ae586",
  "slug": "how-to-cook-chicken-kare-kare-sa-gata",
  "name": "Chicken Kare-kare sa Gata",
  "recipe_type": "main",
  "brief_description": "Boneless Chicken with vegetables cooked in coconut milk and peanut sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over chicken pieces. Let it stay for 5 minutes."
    },
    {
      "position": 2,
      "text": "Heat 3 tablespoons oil in a cooking pot. Pan-fry chicken for 2 minutes per side. Remove from pan. Set aside."
    },
    {
      "position": 3,
      "text": "Add remaining oil. Saute garlic and onion until the latter turns translucent."
    },
    {
      "position": 4,
      "text": "Pour-in coconut milk. Let boil. Add paprika and turmeric powder. Stir."
    },
    {
      "position": 5,
      "text": "Add chicken. Cover the pot and let the sauce boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Chicken Cube. Set heat between low to medium. Continue cooking for 25 minutes."
    },
    {
      "position": 7,
      "text": "Add peanut paste. Stir until paste is completely diluted."
    },
    {
      "position": 8,
      "text": "Put the eggplant, snake beans into the pot. Cover and cook for 5 to 8 minutes. Add bok choy. Cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve with bagoong alamang. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
