  "id": "529d8b43-b6f6-548b-b0e6-35098f0ce4ac",
  "slug": "pinoy-baked-whole-wheat-penne-pasta",
  "name": "Pinoy Baked Whole Wheat Penne Pasta",
  "recipe_type": null,
  "brief_description": "Pinoy Baked Whole Wheat Penne Pasta is a rich and delicious pasta dish. The pasta sauce that I used for this dish is similar to Joillibee Style Spaghetti",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the pasta according to package instructions. Drain and set aside."
    },
    {
      "position": 2,
      "text": "Combine the spaghetti meat sauce, pimiento, and garlic powder in a large mixing bowl. Stir to mix."
    },
    {
      "position": 3,
      "text": "Arrange the cooked pasta on a deep and wide baking dish. Pour-in 3/4 of the meat sauce mixture. Toss to mix the sauce and pasta."
    },
    {
      "position": 4,
      "text": "Pour the remaining sauce on top and then distribute. Top with shredded cheese."
    },
    {
      "position": 5,
      "text": "Preheat oven to 350 degrees Fahrenheit. Bake for 20 to 25 minutes."
    },
    {
      "position": 6,
      "text": "Change to oven setting to broil. Broil for 7 minutes."
    },
    {
      "position": 7,
      "text": "Remove from the oven. Serve Hot."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
