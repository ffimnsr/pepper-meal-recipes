  "id": "1a1ef1f8-c7e7-5ebf-b2e5-90e128fcc82f",
  "slug": "chicago-style-hotdog",
  "name": "Chicago Style Hotdog",
  "recipe_type": null,
  "brief_description": "Chicago style hotdog is like no other. It is complete with all the good flavor and it is simply delicious. You can take it anywhere you like",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water on the steamer. Let boil."
    },
    {
      "position": 2,
      "text": "Steam the hot dogs for 7 to 8 minutes. Set Aside"
    },
    {
      "position": 3,
      "text": "Steam the buns for 30 to 40 seconds. Set aside."
    },
    {
      "position": 4,
      "text": "Arrange the condiments on the bun starting with the onion, tomato, and dill spears."
    },
    {
      "position": 5,
      "text": "Squeeze-in the hotdog and then top with mustard, neon green pickle relish, and sport pepper."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
