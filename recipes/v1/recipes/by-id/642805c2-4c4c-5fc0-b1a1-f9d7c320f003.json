  "id": "642805c2-4c4c-5fc0-b1a1-f9d7c320f003",
  "slug": "chicken-pita",
  "name": "Chicken Pita",
  "recipe_type": "snack",
  "brief_description": "Chicken Pita is ideal for lunch or a heavy snack. This healthy chicken pita recipe makes use of non-fat yogurt, which makes this more interesting.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat olive oil in a fry pan in medium heat."
    },
    {
      "position": 2,
      "text": "Add chicken. Cook for about 5 minutes."
    },
    {
      "position": 3,
      "text": "Turn over chicken and cook 2 minutes."
    },
    {
      "position": 4,
      "text": "Stir-in onion. Cook until onion is clear."
    },
    {
      "position": 5,
      "text": "Place chicken and sauteed onion in bowl.Sprinkle with salt and pepper."
    },
    {
      "position": 6,
      "text": "Add vinegar, and chives."
    },
    {
      "position": 7,
      "text": "Spread yogurt in every pita bread. Put the chicken mixture in each bread and the green chili."
    },
    {
      "position": 8,
      "text": "Serve cold."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 10,
