  "id": "6f61adef-98e6-578a-aed7-ac89ee00659c",
  "slug": "loco-moco-recipe",
  "name": "Loco Moco Recipe",
  "recipe_type": null,
  "brief_description": "Easy Loco Moco using CDO Ulam Burger",
  "cuisine": "American Beef",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan. Fry the burger patties until both sides are completely cooked. Set aside."
    },
    {
      "position": 2,
      "text": "Fry the eggs. Set aside."
    },
    {
      "position": 3,
      "text": "Make the sauce by heating 2 tablespoons of cooking oil in a saucepan. Saute onion and mushrooms for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour the beef broth into the pan and season with soy sauce and Worcestershire sauce. Let boil. Cook for 3 minutes in low heat setting."
    },
    {
      "position": 5,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 6,
      "text": "Make a slurry by combining 2 tablespoons cornstarch with 3 tablespoons water. Stir until well blended."
    },
    {
      "position": 7,
      "text": "Pour the slurry into the saucepan. Stir until the sauce thickens."
    },
    {
      "position": 8,
      "text": "Arrange the CDO Ulam Burger Patties on a plate over rice. Top with sauce. Add fried egg. Garnish with chopped parsley."
    },
    {
      "position": 9,
      "text": "Share. Serve and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
