  "id": "4988e065-f681-5d99-83cc-26fbbb227196",
  "slug": "super-special-chopsuey",
  "name": "Super Special Chopsuey",
  "recipe_type": null,
  "brief_description": "This is a recipe for Super Special Chop Suey",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute garlic until light brown."
    },
    {
      "position": 3,
      "text": "Add onion. Cook until soft."
    },
    {
      "position": 4,
      "text": "Add pork and chicken. Saute for 3 minutes or until light brown."
    },
    {
      "position": 5,
      "text": "Put the chicken liver into the pot. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour water. Let boil. Add Knorr Shrimp Cube. Cover the pot. Cook in medium heat for 15 minutes."
    },
    {
      "position": 7,
      "text": "Add cauliflower and carrot. Cover the pot. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Add bell peppers, shrimp, and cabbage. Cover and cook for another 3 minutes."
    },
    {
      "position": 9,
      "text": "Add salt and pepper. Toss."
    },
    {
      "position": 10,
      "text": "Add quail eggs and pour the cornstarch diluted in water. Toss and continue to cook until the sauce thickens to your desired consistency."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
