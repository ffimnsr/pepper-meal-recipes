  "id": "1ab7609e-6aab-5dda-96da-a8c47a739f46",
  "slug": "aligue-crab-fat-pasta",
  "name": "Aligue Pasta",
  "recipe_type": null,
  "brief_description": "Aligue Pasta Recipe - Aligue is another term for crab fat. The aligue in this recipe comes from Asian shore crabs. In the Philippines, we call these crabs \u201ctalangka\u201d while the fat that comes from these crabs is known as \u201ctaba ng talangka\u201d.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange cooked fettuccine noodles in a serving plate. Set aside."
    },
    {
      "position": 2,
      "text": "Heat a cooking pot and pour-in cooking oil."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 garlic and onions."
    },
    {
      "position": 4,
      "text": "Pour-in cooking rice wine, stir, and cook for a minute."
    },
    {
      "position": 5,
      "text": "Put-in the crab fat (taba ng talangka) then stir. Simmer for 2 minutes."
    },
    {
      "position": 6,
      "text": "Sprinkle salt and ground black pepper, pour-in heavy whipping cream, and stir. Simmer for 3 to 4 minutes."
    },
    {
      "position": 7,
      "text": "Add mixed seafood and cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Turn-off heat and pour over fettuccine noodles. Garnish with green onions."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
  "difficulty": "medium",
