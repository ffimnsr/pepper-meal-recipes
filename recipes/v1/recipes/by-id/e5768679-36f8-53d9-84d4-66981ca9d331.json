  "id": "e5768679-36f8-53d9-84d4-66981ca9d331",
  "slug": "15-minute-pork-stir-fry",
  "name": "15 Minute Pork Stir Fry",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pork Stir Fry.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange pork in a bowl. Add oyster sauce , ground black pepper, and garlic powder. Mix well."
    },
    {
      "position": 2,
      "text": "Add cornstarch. Continue to mix until all ingredients are well blended."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan or work. Once the oil gets hot, stir fry the pork until it turns brown. Note: always use high heat when stir-frying."
    },
    {
      "position": 4,
      "text": "Add young corn and soy sauce. Stir fry for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add snow peas. Stir fry for 1 minute."
    },
    {
      "position": 6,
      "text": "Pour beef broth and cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
