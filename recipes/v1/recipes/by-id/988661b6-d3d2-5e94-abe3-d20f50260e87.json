  "id": "988661b6-d3d2-5e94-abe3-d20f50260e87",
  "slug": "sisig-recipe-knr-kls",
  "name": "Sisig Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Filipino Sisig.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a pot. Add pork belly and pig face. Cover and continue to boil for 1 hour in medium heat. Drain water and let the meat cool down."
    },
    {
      "position": 2,
      "text": "Grill boiled meats for 5 minutes per side. Remove from the grill and chop into small pieces. Note: feel free to mince the meat if preferred."
    },
    {
      "position": 3,
      "text": "Heat oil on a pan. Saute onion for 1 minute."
    },
    {
      "position": 4,
      "text": "Add chicken liver. Continue to saut\u00e9 until thoroughly cooked. Mash the liver while cooking until it breaks down into small pieces."
    },
    {
      "position": 5,
      "text": "Add minced meat and chicharon into the pan. Stir until all ingredients are evenly distributed."
    },
    {
      "position": 6,
      "text": "Add chili flakes, onion powder, and ground black pepper."
    },
    {
      "position": 7,
      "text": "Pour Knorr Liquid Seasoning. Stir."
    },
    {
      "position": 8,
      "text": "Add Lady\u2019s Choice Mayonnaise. Stir and cook for 3 minutes. Set aside."
    },
    {
      "position": 9,
      "text": "Heat a metal plate. Add butter. Tranfer cooked sisig onto the metal plate. Continue to cook until it sizzles. Top with more chicharon."
    },
    {
      "position": 10,
      "text": "Serve with calamansi or lime. Serve. Share and enjoy with white rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
