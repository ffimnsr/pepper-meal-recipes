  "id": "2157236f-d8f8-574f-abf5-d44f512466c6",
  "slug": "lo-mein-with-beef-and-broccoli",
  "name": "Lo Mein with Beef and Broccoli",
  "recipe_type": "main",
  "brief_description": "Lo Mein with Beef and Broccoli is a easy-to-make noodle dish that satisfies my appetite. It is simply delicious and easy to cook -- this means that this recipe is under the basic or beginner level.",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Combine 2 1/2 tablespoons soy sauce, sherry, and garlic powder in bowl. Mix well. Put-in the beef. Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Add the cornstarch in the bowl with the beef. Mix well."
    },
    {
      "position": 3,
      "text": "Meanwhile, cook the egg noodles according to package instructions. Set aside."
    },
    {
      "position": 4,
      "text": "Heat the cooking oil in a pan. Once the oil gets hot, saute the marinated beef. Cook for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Add the broccoli. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the cooked egg noodles. Toss and cook for 2 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Mix the oyster sauce, remaining soy sauce, sugar, ginger, salt and pepper in a bowl."
    },
    {
      "position": 8,
      "text": "Pour the mixture on the noodles with beef. Cook for 5 to 7 minutes in medium heat while tossing once in a while."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 12,
