  "id": "f3be5ca9-15cb-55dc-9b9d-6e3f6a6ceb74",
  "slug": "adobong-pata-ham-hock",
  "name": "Adobong Pata (Ham Hock Adobo)",
  "recipe_type": null,
  "brief_description": "Ham Hock Adobo or Adobong Pata is a Filipino dish composed of hocks and sometimes pig knuckles. It is cooked using the inabo method in Philippines Cuisine",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil 8 cups of water in a large cooking pot. Add the ham hock (pata). Continue to boil for 60 minutes. Discard the water and set the ham hock aside."
    },
    {
      "position": 2,
      "text": "Heat the oil on a large cooking pot. You may use the same pot that you had for the pata."
    },
    {
      "position": 3,
      "text": "Add the crushed garlic and cook until brown. Add the peppercorn and bay leaves and cook for 30 seconds."
    },
    {
      "position": 4,
      "text": "Put the boiled ham hock in the cooking pot and then pour-in the water. Let boil. Cover and simmer for 15 minutes."
    },
    {
      "position": 5,
      "text": "Add the beef cube and soy sauce. Cook for 40 minutes in low heat. Add more water if needed."
    },
    {
      "position": 6,
      "text": "Add the onion powder, vinegar, and sugar. Let the mixture boil. Stir and cover the cooking pot. Continue to simmer for 20 minutes. Add more water if necessary. Make sure that there is enough sauce left."
    },
    {
      "position": 7,
      "text": "Add salt (optional). Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
