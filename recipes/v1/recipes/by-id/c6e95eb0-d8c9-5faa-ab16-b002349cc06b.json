  "id": "c6e95eb0-d8c9-5faa-ab16-b002349cc06b",
  "slug": "linguine-pasta-with-clams",
  "name": "Linguine Pasta with Clams",
  "recipe_type": null,
  "brief_description": "Linguine Pasta with Clams is a good idea for a quick and easy lunch. I like this pasta dish because it is pleasing to the palate: the flavor is not overwhelming and so delish!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the linguine according to package instructions. Set aside in a large bowl."
    },
    {
      "position": 2,
      "text": "Heat the olive oil in a saut\u00e9 pan."
    },
    {
      "position": 3,
      "text": "Add the onion and garlic. Cook until the onion turns soft."
    },
    {
      "position": 4,
      "text": "Add the red and green bell peppers and clams. Stir."
    },
    {
      "position": 5,
      "text": "Pour-in white wine and clam juice. Continue to cook until the liquid reduces in half."
    },
    {
      "position": 6,
      "text": "Add scallions and salt."
    },
    {
      "position": 7,
      "text": "Pour the cooked clams along with the sauce over the cooked linguine pasta. Toss."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
