  "id": "6f28aefc-bd61-57c8-beeb-6a145bf3fd66",
  "slug": "gising-gising-recipe",
  "name": "Gising gising Recipe (Green bean with Pork in Coconut milk)",
  "recipe_type": null,
  "brief_description": "Gising gising is made up of ground pork and green beans cooked in coconut milk. This tried and tested recipe is worth a try.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onion"
    },
    {
      "position": 3,
      "text": "Add pork. Cook for 3 to 5 minutes or until color turns medium brown"
    },
    {
      "position": 4,
      "text": "Put-in ground black pepper, shrimp paste, and chili. Stir."
    },
    {
      "position": 5,
      "text": "Pour-in coconut milk. Let boil and simmer for 20 minutes."
    },
    {
      "position": 6,
      "text": "Add the green beans. Cook for 5 to 7 minutes while stirring gradually."
    },
    {
      "position": 7,
      "text": "Turn off heat. Serve with white rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 5,
