  "id": "e9f1e9f6-7043-531a-ad61-146c990d920c",
  "slug": "easy-ham-and-green-peas-saute",
  "name": "Easy Ham and Green Peas Saute",
  "recipe_type": null,
  "brief_description": "Ham and Green Peas Saut\u00e9 is a Quick and Easy Recipe that can be prepared for lunch. This goes well with steamed white or brown rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Put-in the ham and then cook for 2 minutes while stirring after every 30 seconds."
    },
    {
      "position": 3,
      "text": "Add soy sauce, oyster sauce, and water. Stir and simmer until the liquid completely evaporates."
    },
    {
      "position": 4,
      "text": "Put-in green peas, bell pepper, and dried parsley. Gently stir. Cook covered in low to medium heat for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Serve with steamed white rice."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 3,
