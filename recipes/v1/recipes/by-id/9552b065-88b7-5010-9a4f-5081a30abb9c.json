  "id": "9552b065-88b7-5010-9a4f-5081a30abb9c",
  "slug": "popcorn-chicken-recipe-2",
  "name": "Popcorn Chicken Recipe",
  "recipe_type": "appetizer",
  "brief_description": "This is a recipe for Popcorn Chicken.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Place chicken in a bowl. Add garlic powder, ground black pepper, salt, and paprika. Mix well. Let the chicken absorb the seasonings for 10 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, Crack the eggs in a bowl. Beat."
    },
    {
      "position": 3,
      "text": "Place flour in a bowl. Line-up with the bowl of beaten egg and then the one the marinated chicken breasts."
    },
    {
      "position": 4,
      "text": "Heat the oil in a cooking pot to 300F."
    },
    {
      "position": 5,
      "text": "Dip each piece of chicken in beaten egg, and then dredge in flour. Make sure that the chicken gets coated with flour all over. Put in a clean plate or bowl."
    },
    {
      "position": 6,
      "text": "Double coat the chicken by repeating the previous step (dip in egg again and then dredge in flour)."
    },
    {
      "position": 7,
      "text": "Deep fry each coated chicken piece for 3 to 5 minutes or until light to medium brown. Remove from the pot and let the excess oil drip."
    },
    {
      "position": 8,
      "text": "Arrange in a a serving plate with your favorite dip. I suggest that you serve this with ranch dressing."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 12,
