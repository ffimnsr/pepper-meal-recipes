  "id": "2e0f2f5f-d035-5780-8cf7-0bb62ce3c0a0",
  "slug": "adobong-pusit-recipe",
  "name": "Adobong Pusit Recipe",
  "recipe_type": "main",
  "brief_description": "Quick and easy adobong pusit recipe.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a wok or cooking pot then pour-in soy sauce, vinegar, and water then bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the squid and wait for the liquid to re-boil. Simmer for 5 minutes."
    },
    {
      "position": 3,
      "text": "Turn off the heat then separate the squid from the liquid. Set aside."
    },
    {
      "position": 4,
      "text": "Pour-in cooking oil on a separate wok or cooking pot then apply heat."
    },
    {
      "position": 5,
      "text": "When the oil is hot enough, saut\u00e9 the garlic, onions, and tomatoes."
    },
    {
      "position": 6,
      "text": "Put-in the squid then cook for a few seconds."
    },
    {
      "position": 7,
      "text": "Pour-in the soy sauce-vinegar-water mixture that was used to cook the squid a while back. Bring to a boil and simmer for 3 minutes."
    },
    {
      "position": 8,
      "text": "Add the ink, salt, ground black pepper, and sugar then stir. Simmer for 3 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl then serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    },
    {
      "position": 11,
      "text": "Note: If you want a thicker sauce, remove the squid from the wok or cooking pot and let the sauce boil until enough liquid evaporates. Once done, you may top the squid with the sauce."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
