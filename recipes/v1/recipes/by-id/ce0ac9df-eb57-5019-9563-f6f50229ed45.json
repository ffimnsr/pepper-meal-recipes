  "id": "ce0ac9df-eb57-5019-9563-f6f50229ed45",
  "slug": "pork-pochero-recipe",
  "name": "Pork Pochero Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for pork pochero",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic onion, and tomato"
    },
    {
      "position": 3,
      "text": "Once the onion becomes tender, add the Chinese sausage and pork belly. Continue to cook until the pork belly browns (around 3 minutes)."
    },
    {
      "position": 4,
      "text": "Pour the tomato sauce and water. Let boil."
    },
    {
      "position": 5,
      "text": "Add the pork (or beef cubes). Stir. Cover the pot and set the heat to low. Boil for 50 minutes."
    },
    {
      "position": 6,
      "text": "Add the banana and potato. Cover and continue to cook in medium heat for 12 minutes."
    },
    {
      "position": 7,
      "text": "Add the green beans and bok choy. Cook for 5 to 7 minutes."
    },
    {
      "position": 8,
      "text": "Add salt and ground black pepper to taste."
    },
    {
      "position": 9,
      "text": "Serve, Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
