  "id": "f381a72c-def7-50df-8612-e30cd442a591",
  "slug": "pineapple-cake",
  "name": "Pineapple Cake",
  "recipe_type": "dessert",
  "brief_description": "Pineapple Cake with Cream Cheese frosting is an extended pineapple upside down cake recipe. This has the same good flavor",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Combine the brown sugar and melted butter. Stir."
    },
    {
      "position": 3,
      "text": "Pour the mixture on a deep cake pan. Spread."
    },
    {
      "position": 4,
      "text": "Arrange the slices of pineapple over the mixture. Set aside."
    },
    {
      "position": 5,
      "text": "Meanwhile, combine the AP flour, white sugar, salt, and baking powder in a bowl. Mix well."
    },
    {
      "position": 6,
      "text": "Beat the eggs using an electric mixer. Gently pour-in the milk and then add the shortening."
    },
    {
      "position": 7,
      "text": "Gradually whisk-in the mixture of dry ingredients."
    },
    {
      "position": 8,
      "text": "Pour the batter on the cake pan."
    },
    {
      "position": 9,
      "text": "Bake for 55 to 60 minutes or until it passes the toothpick test."
    },
    {
      "position": 10,
      "text": "Remove from the oven. Let it cool down."
    },
    {
      "position": 11,
      "text": "Separate the cake from the cake pan by inserting an icing spatula on the side of the cake.Gently move the spatula around the cake pan to let the cake loose."
    },
    {
      "position": 12,
      "text": "Flip the cake pan to let the cake loose and then securely place the cake on top of a plate or cake stand."
    },
    {
      "position": 13,
      "text": "Apply the cream cheese frosting and chopped walnuts over the frosting."
    },
    {
      "position": 14,
      "text": "Put the cherries in the center of each slice pineapple."
    },
    {
      "position": 15,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 55,
  "preparation_time_minutes": 20,
