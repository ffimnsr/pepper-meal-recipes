  "slug": "how-to-make-annatto-oil",
  "name": "How to Make Annatto Oil",
  "recipe_type": null,
  "brief_description": "This is a recipe for annatto oil",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the annatto seeds and olive oil in a saucepan then apply heat."
    },
    {
      "position": 2,
      "text": "Maintain the heat to medium. When bubbles start to form around the annatto seeds, turn off the heat and let the seeds soak in oil for 1 to 2 minutes (Do not overcook the seeds because it will produce a bitter taste)."
    },
    {
      "position": 3,
      "text": "Transfer the oil to a container. Use a strainer to filter-out the annatto seeds."
    },
    {
      "position": 4,
      "text": "You are now ready to use annatto oil as an ingredient to any dish that requires it."
    }
  ],
  "servings": 4,
