  "id": "40fb9655-9160-5de8-b968-9850e81a4b4e",
  "slug": "how-to-cook-garlic-fried-steamed-rice-dish-recipe",
  "name": "Garlic Fried Rice",
  "recipe_type": "side",
  "brief_description": "Garlic Fried Rice made with day old medium grain rice, lots of toasted garlic, chopped chives, and a finish of toasted sesame oil.",
  "cuisine": "Asian Chinese Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place the day old medium grain rice in a large bowl. Break apart any clumps with a fork or your hands. Sprinkle the salt over the rice and mix gently until the salt is spread evenly across the grains."
    },
    {
      "position": 2,
      "text": "Heat a wide pan over medium heat and pour in the cooking oil."
    },
    {
      "position": 3,
      "text": "Once the oil is warm, add the minced garlic and lower the heat. Cook the garlic gently, stirring often, until the pieces turn light brown and crisp at the edges."
    },
    {
      "position": 4,
      "text": "Scoop out about half of the toasted garlic with a slotted spoon and set it aside for topping."
    },
    {
      "position": 5,
      "text": "Add half of the salted rice to the pan with the remaining garlic and oil. Stir fry for about a minute, breaking up any clumps. Add the rest of the rice and toss everything together until the grains are coated in garlic oil."
    },
    {
      "position": 6,
      "text": "Spread the rice in the pan and let it sit for 30 to 45 seconds so some grains toast at the bottom. Stir once more, then keep cooking for 3 to 5 minutes, tossing now and then, until the rice is hot and lightly toasted."
    },
    {
      "position": 7,
      "text": "Turn the heat off. Drizzle the sesame oil over the rice if using, and toss once or twice. Return the rice to a serving plate or bowl. Top with the reserved toasted garlic and the chopped chives. Serve hot with your favorite main dish. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
