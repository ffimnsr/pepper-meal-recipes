  "id": "5f55c43a-bb00-5b05-ac34-46ae245bbbd7",
  "slug": "chicken-congee-recipe",
  "name": "Chicken Congee Recipe",
  "recipe_type": null,
  "brief_description": "A comforting Filipino rice porridge with tender shredded chicken, ginger, and scallions.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat water in a cooking pot. Add ginger, half of the chopped scallions, and chicken. Let boil."
    },
    {
      "position": 2,
      "text": "Add Knorr chicken cube. Stir. Cover and continue to cook over medium heat for 15 minutes."
    },
    {
      "position": 3,
      "text": "Remove the chicken from the pot. Let it cool down. Shred the chicken meat. Discard the bones. Note: You can shred the chicken using two forks, or your bare clean hands."
    },
    {
      "position": 4,
      "text": "Add rice into the pot. Cover and cook for 30 minutes."
    },
    {
      "position": 5,
      "text": "Put the shredded chicken in the pot. Continue to cook for 30 minutes more or until the consistency of the porridge gets thick. Note: Add water if needed."
    },
    {
      "position": 6,
      "text": "Add salt, ground black pepper, and sesame oil. Stir."
    },
    {
      "position": 7,
      "text": "Transfer to a bowl. Top with chopped scallions and toasted garlic."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
