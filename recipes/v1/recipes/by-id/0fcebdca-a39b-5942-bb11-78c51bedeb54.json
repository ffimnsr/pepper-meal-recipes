  "id": "0fcebdca-a39b-5942-bb11-78c51bedeb54",
  "slug": "beef-short-rib-kare-kare",
  "name": "Beef Short Rib Kare Kare",
  "recipe_type": null,
  "brief_description": "This is a recipe for Beef Short Rib Kare Kare",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pressure cooker."
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot, saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the ground peanut. Cook while stirring for 3 minutes."
    },
    {
      "position": 4,
      "text": "Put the beef short ribs in. Cook until light brown."
    },
    {
      "position": 5,
      "text": "Pour annatto water and water. Let boil. Note: Make your own annatto water by soaking 1/2 cup annatto or atsuete seeds in 3/4 cup warm water for at least 10 minutes and then stir thoroughly to extract the color."
    },
    {
      "position": 6,
      "text": "Cover the pressure cooker. Cook for 30 minutes."
    },
    {
      "position": 7,
      "text": "Safely remove the cover and then add the banana blossoms. Cook for 5 minutes. Note: Prepare the banana blossoms by soaking it in water with 3 tablespoons salt for 15 minutes. Wring the banana blossoms before cooking."
    },
    {
      "position": 8,
      "text": "Pour the glutinous rice flour with water into the pot. Stir until the texture of the liquid thickens. Note: You can use cornstarch as an alternative ingredient."
    },
    {
      "position": 9,
      "text": "Add snake beans and bok choy. Cook for 5 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve with shrimp paste."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
