  "id": "8a372538-6bdb-55d2-985c-d201bc180c68",
  "slug": "simple-kimchi-fried-rice",
  "name": "Simple Kimchi Fried Rice",
  "recipe_type": null,
  "brief_description": "Simple Kimchi Fried Rice is the simplest fried rice recipe that involves kimchi. All I have here are kimchi, rice, and the oils",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the vegetable oil and sesame oil in a pan."
    },
    {
      "position": 2,
      "text": "Add-in the chopped kimchi. Cook for 1 to 2 minutes."
    },
    {
      "position": 3,
      "text": "Put-in the white rice. Stir-fry for 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in the kimchi juice. Stir. Cook for 2 minutes more."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Enjoy with galbi."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 12,
