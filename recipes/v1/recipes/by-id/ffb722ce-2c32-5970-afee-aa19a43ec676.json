  "id": "ffb722ce-2c32-5970-afee-aa19a43ec676",
  "slug": "grilled-tilapia",
  "name": "Grilled Tilapia Recipe",
  "recipe_type": null,
  "brief_description": "This Grilled Tilapia Recipe is very simple and easy to prepare. Try this now!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine tomato, onion, salt, ground black pepper, and lemon juice in a bowl then mix well."
    },
    {
      "position": 2,
      "text": "Stuff the mixture inside the cavity of the tilapia. Note: do not overstuff the fish."
    },
    {
      "position": 3,
      "text": "Meanwhile, combine oil with 1 teaspoon of salt and mix."
    },
    {
      "position": 4,
      "text": "Brush the oil and salt mixture on the exterior part of the tilapia. Note: The salt adds more taste while the oil prevents the skin to stick on the foil."
    },
    {
      "position": 5,
      "text": "Wrap the tilapia in aluminum foil then secure the sides."
    },
    {
      "position": 6,
      "text": "Grill the wrapped fish for about 12 minutes per side."
    },
    {
      "position": 7,
      "text": "Remove from the grill and transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with ensaladang talong and steamed rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
