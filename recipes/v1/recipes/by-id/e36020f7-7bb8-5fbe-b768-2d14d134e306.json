  "slug": "ginisang-sitaw-kalabasa-at-malunggay-with-shrimp-sauteed-butternut-squash-with-shrimp",
  "name": "Ginisang Sitaw at Kalabasa with Shrimp",
  "recipe_type": null,
  "brief_description": "This is a recipe for sauteed butternut squash with shrimp.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, pan-fry the shrimp in medium heat for 1 minute per side. Remove from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil (add more if needed), saut\u00e9 garlic and onion."
    },
    {
      "position": 4,
      "text": "Add the squash. Stir-fry for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the snake beans. Continue to cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Put the malunggay leave into the pot and then pour the chicken broth. Let boil. Stir. Cover and cook for 5 to 8 minutes."
    },
    {
      "position": 7,
      "text": "Sprinkle salt and ground black pepper to taste."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
