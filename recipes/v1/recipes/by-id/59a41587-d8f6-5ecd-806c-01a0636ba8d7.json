  "id": "59a41587-d8f6-5ecd-806c-01a0636ba8d7",
  "slug": "how-to-cook-ginataang-langka-with-pork-recipe-knr-mm",
  "name": "Ginataang Langka with Pork Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Green jackfruit and pork with coconut milk.&nbsp;",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine Knorr Ginataang Gulay Recipe Mix with 2 cups water. Mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot. Saute onion and garlic."
    },
    {
      "position": 3,
      "text": "Add pork slices once onion softens. Continue to saute for 3 to 5 minutes until the pork turns medium brown and gets completely cooked."
    },
    {
      "position": 4,
      "text": "Add unripe jackfruit. Cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Put the chopped chili in the pot. Stir and cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour the coconut milk mixture. Let boil. Continue to cook uncovered until the sauce reduces to a quarter."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
