  "id": "5218a259-99b5-5f88-bc3b-3cb7676b187b",
  "slug": "pork-lomi",
  "name": "Pork Lomi",
  "recipe_type": "soup",
  "brief_description": "Pork and chorizo noodle soup with carrots, cabbage, and egg. This Filipino meryenda dish is a hit.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 5 cups water in a cooking pot. Add pork belly. Cover and continue to boil between low to medium heat for 30 minutes. Remove the pork from the pot and slice into thin pieces. Save the pork stock."
    },
    {
      "position": 2,
      "text": "Heat oil on a clean cooking pot. Saut\u00e9 garlic and onion."
    },
    {
      "position": 3,
      "text": "Once the onion softens, add chorizo. Saut\u00e9 for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add the sliced boiled pork. Saut\u00e9 for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour pork stock into the pot and add 1 to 2 cups water. Let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Pork Cube. Stir. Cover the pot and cook for 10 minutes."
    },
    {
      "position": 7,
      "text": "Add carrots, cabbage, and fresh noodles. Stir. Cover and cook for 8 minutes."
    },
    {
      "position": 8,
      "text": "Combine cornstarch and \u00bd cup water. Stir until well blended. Pour the mixture into the pot and stir thoroughly until the soup thickens."
    },
    {
      "position": 9,
      "text": "Crack a piece of egg into the pot. Stir until well distributed."
    },
    {
      "position": 10,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 5,
