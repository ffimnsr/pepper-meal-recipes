  "id": "2bd8b536-2168-5220-92ee-ee6bfaeef0e0",
  "slug": "fried-eggplant-pritong-talong",
  "name": "Fried Eggplant (Pritong Talong)",
  "recipe_type": "side",
  "brief_description": "Classic Filipino fried eggplant dredged in flour and pan-fried until golden brown and tender, traditionally served with bagoong alamang (shrimp paste) and a soy sauce-chili dip.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the eggplant in half lengthwise. Cut into 3 inch pieces."
    },
    {
      "position": 2,
      "text": "Dredge the eggplants in flour."
    },
    {
      "position": 3,
      "text": "Heat 4 tablespoons oil in a pan. Once the oil gets hot, pan-fry the eggplant slices until one side gets dark brown. Turn it over to cook the other side. Add the remaining oil if necessary since eggplants tend to absorb oil when fried. Continue to cook until the eggplant is done."
    },
    {
      "position": 4,
      "text": "Transfer to a plate and serve with bagoong alamang and a dip of soy sauce with chili."
    },
    {
      "position": 5,
      "text": "Eat with rice. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
