  "slug": "ginisang-upo-at-kalabasa-sauteed-opo-and-butternut-squash",
  "name": "Ginisang Upo at Kalabasa - Sauteed Opo and Butternut Squash",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginisang Upo at Kalabasa -",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot."
    },
    {
      "position": 2,
      "text": "Add sliced pork belly. Sear until oil gets extracted."
    },
    {
      "position": 3,
      "text": "Add onion, garlic, and tomato. Saute until the onion becomes soft."
    },
    {
      "position": 4,
      "text": "Pour water. Let boil. Cover the pot and continue to boil in low to medium heat until the water completely evaporates or the pork becomes tender. Note: add more water if needed."
    },
    {
      "position": 5,
      "text": "Put the kalabasa into the pot. Saute for 3 to 5 minutes. Note: use high heat when saut\u00e9ing."
    },
    {
      "position": 6,
      "text": "Add upo. Continue to saute for 2 minutes."
    },
    {
      "position": 7,
      "text": "Season with fish sauce and ground black pepper"
    },
    {
      "position": 8,
      "text": "Stir. You can add up to \u00bd cup water if you want your dish to have sauce in it"
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve with fried fish and rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
