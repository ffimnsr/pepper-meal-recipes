  "id": "df0d35e5-5008-5830-bb60-869d13a076b6",
  "slug": "simple-pancit-palabok-recipe",
  "name": "Simple Pancit Palabok",
  "recipe_type": "main",
  "brief_description": "Thick noodles topped with a savory orange shrimp sauce and finished with shrimp, tinapa flakes, chicharon, scallions, Napa cabbage, and egg.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Soak palabok noodles in water until softened, then drain and set aside."
    },
    {
      "position": 2,
      "text": "Bring 6 cups of water to a boil. Quickly submerge softened noodles and cook for 1 to 3 minutes. Drain immediately and set aside."
    },
    {
      "position": 3,
      "text": "Heat cooking oil in a pan. Pan-fry shrimp for about 30 seconds per side, then remove and set aside."
    },
    {
      "position": 4,
      "text": "Add pork to the same pan and saut\u00e9 until lightly browned."
    },
    {
      "position": 5,
      "text": "Pour in beef broth and add the shrimp cube (or shrimp powder). Bring to a boil, cover, and simmer until pork is tender."
    },
    {
      "position": 6,
      "text": "Stir in the annatto soaking water for color and flavor."
    },
    {
      "position": 7,
      "text": "Make the slurry by combining flour with water until smooth. Pour into the pan while stirring. Continue cooking over low to medium heat until the sauce thickens."
    },
    {
      "position": 8,
      "text": "Add 2 tablespoons of tinapa flakes and season with salt and ground black pepper to taste. Stir and set the sauce aside."
    },
    {
      "position": 9,
      "text": "Assemble: Arrange noodles on a serving plate and pour sauce over. Gently toss until evenly coated."
    },
    {
      "position": 10,
      "text": "Top with Napa cabbage, scallions, crushed pork rinds, shrimp, remaining tinapa flakes, and sliced hard-boiled eggs. Serve warm."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
  "difficulty": "hard",
