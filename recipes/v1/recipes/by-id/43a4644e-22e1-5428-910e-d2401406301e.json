  "id": "43a4644e-22e1-5428-910e-d2401406301e",
  "slug": "how-to-cook-filipino-chicken-arroz-caldo",
  "name": "How To Cook Filipino Chicken Arroz Caldo",
  "recipe_type": null,
  "brief_description": "This is a recipe for Filipino Chicken Arroz Caldo",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute garlic, onion, and ginger."
    },
    {
      "position": 3,
      "text": "When the onion starts to turn soft and translucent, put the chicken into the pot. Cook until it turns light brown."
    },
    {
      "position": 4,
      "text": "Add glutinous and Jasmine rice. Saute for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour 6 cups of chicken broth. Let boil. Cover the pot. Continue to cook in medium heat for 35 to 40 minutes. Make sure to stir the mixture every few minutes to prevent the rice from sticking on the pot. Add more broth if necessary."
    },
    {
      "position": 6,
      "text": "Add kasubha, patis, and ground black pepper. Stir. Continue to cook until it reaches your desired consistency."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Top with egg, scallions, garlic, and lemon wedges."
    },
    {
      "position": 8,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
