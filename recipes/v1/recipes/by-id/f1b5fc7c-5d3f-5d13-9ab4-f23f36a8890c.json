  "id": "f1b5fc7c-5d3f-5d13-9ab4-f23f36a8890c",
  "slug": "smothered-pork-chop-recipe",
  "name": "Smothered Pork Chop Recipe",
  "recipe_type": null,
  "brief_description": "This Smothered Pork Chop Recipe is very tasty. This is best eaten with steamed or brown rice. Get the details of this tested recipe here.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt, pepper, and garlic powder on each pork chop. Rub and let stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan."
    },
    {
      "position": 3,
      "text": "Pan fry the pork chops in medium heat for about 6 to 8 minutes per side or until the color turns medium brown."
    },
    {
      "position": 4,
      "text": "Remove from the pork chops from the pan, set aside."
    },
    {
      "position": 5,
      "text": "On the same pan, melt-in butter."
    },
    {
      "position": 6,
      "text": "Put-in the onions and cook until caramelized (about 6 to 8 minutes)."
    },
    {
      "position": 7,
      "text": "Put-in garlic. Cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Sprinkle-in flour. Stir and cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Pour-in beef broth, water, and heavy cream. Bring to a boil. Simmer for 12 minutes."
    },
    {
      "position": 10,
      "text": "Place the fried pork chops in the pan. Cook for 5 more minutes or until the sauce reduces."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve with rice."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 20,
