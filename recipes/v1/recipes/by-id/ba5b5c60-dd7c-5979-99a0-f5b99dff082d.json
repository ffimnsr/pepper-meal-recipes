  "id": "ba5b5c60-dd7c-5979-99a0-f5b99dff082d",
  "slug": "chicken-paksiw-recipe",
  "name": "Chicken Paksiw",
  "recipe_type": "main",
  "brief_description": "Leftover fried chicken cooked in liver sauce with vinegar.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saute onion and garlic."
    },
    {
      "position": 2,
      "text": "Once the onion softens, add chicken. Stir and saute for 1 minute."
    },
    {
      "position": 3,
      "text": "Pour the lechon sauce into the pan and then add vinegar. Let the mixture boil before stirring."
    },
    {
      "position": 4,
      "text": "Pour water into the pan. Let it boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Chicken Cube, bay leaves, and whole peppercorn. Stir. Cover the pan and then adjust the heat to the lowest setting. Continue cooking for 35 minutes."
    },
    {
      "position": 6,
      "text": "Take the cover off the pan. Continue cooking until the sauce evaporates and reduces to half."
    },
    {
      "position": 7,
      "text": "Add sugar and then season with salt."
    },
    {
      "position": 8,
      "text": "Transfer it to a serving bowl and serve with warm rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
