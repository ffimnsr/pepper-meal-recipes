  "id": "bcc57e3e-c97c-5b96-b725-d3663f579d96",
  "slug": "oven-baked-pork-chop-silog-with-atchara",
  "name": "Oven Baked Pork Chop Silog with Atchara",
  "recipe_type": null,
  "brief_description": "This is a recipe for oven baked pork chop in a meal composed of garlic fried rice, pickled papaya, and fried eggs.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and pepper all over the pork chop. Let it stay for 10 to 15 minutes."
    },
    {
      "position": 2,
      "text": "Beat the raw egg in a bowl. On a separate bowl, arrange the flour. Set aside."
    },
    {
      "position": 3,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 4,
      "text": "While the oil is heating-up, dredge a piece of pork chop in flour. Dip it in beaten egg and then dredge it back on the flour bowl. Fry each side for 1 minute. Place the semi-fried pork chops in baking tray. Do this step on all remaining pork chops."
    },
    {
      "position": 5,
      "text": "Meanwhile, heat the oven to 350F. Place the baking tray with pork chops in the oven. Bake for 35 minutes."
    },
    {
      "position": 6,
      "text": "Arrange the pork chop in individual plates. Add a cup of rice and 2 pieces of fried eggs. Finish with a tablespoon of papaya atchara on the side."
    },
    {
      "position": 7,
      "text": "Serve with banana ketchup. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
