  "id": "52ead7d9-e3f5-5d5a-841d-dce06943468d",
  "slug": "seafood-lomi-noodles-recipe",
  "name": "Seafood Lomi Recipe",
  "recipe_type": "main",
  "brief_description": "Seafood Lomi Recipe Hack",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saut\u00e9 the garlic and onion until the latter softens."
    },
    {
      "position": 2,
      "text": "Add the squid balls and soy sauce. Saut\u00e9 for 2 minutes."
    },
    {
      "position": 3,
      "text": "Combine Knorr Crab and Corn Soup with 5 cups water. Stir until blended. Pour the mixture into the cooking pot. Let it boil."
    },
    {
      "position": 4,
      "text": "Add the carrot, kani, long green beans, and cabbage. Cover and cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the noodles and egg. Stir and continue cooking for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 7,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
