{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "76aea2ce-c76b-5573-b5d2-9788a9b99a49",
  "slug": "pata-humba-braised-pork-hocks",
  "name": "Pata Humba (Braised Pork Hocks)",
  "recipe_type": "main",
  "brief_description": "Slow braised pork hocks in pineapple soy sauce with star anise, salted black beans, banana blossoms, and peanuts, finished with savory seasoning for a tender and glossy dish.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil the pork hocks for 10 minutes. Rinse thoroughly under cold water to remove impurities. Pat dry with paper towels."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a wok. Fry the pork hocks for 2 minutes per side until golden brown. Remove from the wok and set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil, saut\u00e9 the garlic until it starts to brown and becomes fragrant, about 1-2 minutes."
    },
    {
      "position": 4,
      "text": "Add the onions. Continue saut\u00e9ing until they soften and become translucent, about 3-4 minutes."
    },
    {
      "position": 5,
      "text": "Add the salted black beans. Mash them using your cooking spoon to release their flavor into the oil."
    },
    {
      "position": 6,
      "text": "Add the star anise, dried bay leaves, and whole peppercorns. Saut\u00e9 for 30 seconds until fragrant and the spices bloom."
    },
    {
      "position": 7,
      "text": "Pour in the soy sauce, vinegar, pineapple juice, and water. Stir to combine all ingredients."
    },
    {
      "position": 8,
      "text": "Add the pork hocks back to the wok. Cover and simmer on low heat until the pork is completely tender and falls off the bone, about 1\u00bd to 2 hours. Add water as needed to prevent burning."
    },
    {
      "position": 9,
      "text": "Add the brown sugar, banana blossoms (if using), and peanuts. Continue cooking for 10 minutes to allow the sauce to reduce slightly and flavors to meld."
    },
    {
      "position": 10,
      "text": "Season with Maggi Magic Sarap. Taste and adjust seasoning as needed."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve hot with steamed rice. Spoon the rich sauce over the rice for the best experience."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 20,
