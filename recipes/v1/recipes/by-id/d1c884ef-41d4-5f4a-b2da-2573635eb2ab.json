  "id": "d1c884ef-41d4-5f4a-b2da-2573635eb2ab",
  "slug": "chicken-lomi-recipe",
  "name": "Chicken Lomi Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Chicken Lomi.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute garlic, onion, and carrots."
    },
    {
      "position": 3,
      "text": "Add the sliced chicken. Cook until the chicken turns light brown."
    },
    {
      "position": 4,
      "text": "Pour the water into the pot. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr chicken cube. Stir. Cover the pot. Cook the chicken between low to medium heat for 15 minutes."
    },
    {
      "position": 6,
      "text": "Add cabbage and miki noodles. Cook for 8 to 10 minutes."
    },
    {
      "position": 7,
      "text": "Add scallions. Stir."
    },
    {
      "position": 8,
      "text": "Pour the egg. Continuously stir to prevent the egg from forming."
    },
    {
      "position": 9,
      "text": "Add 1/4 cup water to cornstarch and stir to mix. Pour it into the pot. Stir until the soup thickens."
    },
    {
      "position": 10,
      "text": "Add salt and ground black pepper. Cook for 2 minutes."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
