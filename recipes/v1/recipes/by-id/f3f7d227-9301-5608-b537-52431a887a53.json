  "id": "f3f7d227-9301-5608-b537-52431a887a53",
  "slug": "how-to-cook-adobo-steak",
  "name": "Adobo Steak Recipe",
  "recipe_type": null,
  "brief_description": "This Adobo Steak Recipe is my take to raise ordinary Adobo to the next level. It is full of nice flavor and is totally amazing.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in 2 tablespoons of olive oil."
    },
    {
      "position": 2,
      "text": "Put-in the beef and cook for 1 to 2 minutes."
    },
    {
      "position": 3,
      "text": "Pour-in soy sauce and water then allow to boil. Simmer for 15 to 20 minutes. Note: Add more water if the mixture dries-up."
    },
    {
      "position": 4,
      "text": "Put-in the honey and red wine vinegar and allow to boil. Stir and simmer for 10 minutes. Turn-off heat and set aside."
    },
    {
      "position": 5,
      "text": "Heat a wok and pour-in remaining olive oil."
    },
    {
      "position": 6,
      "text": "Put-in bell pepper and onion then cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add the cooked beef tenderloin, salt, and pepper then stir. Cook for a minute more."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate then serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
