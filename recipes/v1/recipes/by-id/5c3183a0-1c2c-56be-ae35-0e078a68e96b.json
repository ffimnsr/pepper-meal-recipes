{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "5c3183a0-1c2c-56be-ae35-0e078a68e96b",
  "slug": "crispy-cabbage-rolls",
  "name": "Crispy Cabbage Rolls",
  "recipe_type": "appetizer",
  "brief_description": "Crispy deep fried cabbage rolls with meat filling",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 4 cups of water in a cooking pot. Add 1 teaspoon salt."
    },
    {
      "position": 2,
      "text": "Put the Napa cabbage in the pot. Boil for 1 minute. Pour cold water in a large bowl. Remove the cabbage from the pot and submerge it into the cold water until it cools-down. Remove and dry the cabbage. Set aside."
    },
    {
      "position": 3,
      "text": "Cook the meat filling by heating 3 tablespoons of cooking oil in a pan. Saut\u00e9 the garlic until it starts to brown. Add onion. Cook until the onion softens. Add the ground pork and continue cooking while stirring until the pork turns light brown. Add Knorr Pork Cube and then cook for 2 minutes. Season with salt and ground black pepper. Transfer to a large bowl. Let it cool down."
    },
    {
      "position": 4,
      "text": "Add minced carrot, minced green onion, egg, all-purpose flour, soy sauce, and sesame oil. Mix well."
    },
    {
      "position": 5,
      "text": "Scoop 3 tablespoons of the meat mixture and arrange it over a piece of Napa cabbage. Secure the filling by folding both sided of the cabbage inwards and roll until the filling is completely covered. Secure by inserting a toothpick into the cabbage roll."
    },
    {
      "position": 6,
      "text": "Start to fry the cabbage rolls by heating cooking oil in a pan. Meanwhile, dredge the cabbage roll in all-purpose flour, dip in beaten egg, and dredge in panko breadcrumbs until completely coated. Fry one side until it turns golden brown. Turn it over and do the same on the opposite side. Remove from the pan place over a plate lined with paper towel or on a wire rack. Let it cool down."
    },
    {
      "position": 7,
      "text": "Slice the cabbage rolls into bite-sized pieces. Serve with your favorite dipping sauce. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
