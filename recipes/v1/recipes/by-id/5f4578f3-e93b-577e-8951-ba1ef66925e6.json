  "id": "5f4578f3-e93b-577e-8951-ba1ef66925e6",
  "slug": "pancit-molo-recipe",
  "name": "Pancit Molo Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pancit Molo.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Start to prepare the wonton by chopping the shrimp into small pieces and put it in a mixing bowl."
    },
    {
      "position": 2,
      "text": "Add ground pork, onion, sesame oil, egg, salt, garlic powder, and pepper. Mix well."
    },
    {
      "position": 3,
      "text": "Lay a piece of wonton wrapper flat on a plate. Scoop 1 1/2 teaspoon of the mixture and place on the middle of the wrapper. Fold the wonton wrapper to form a triangle. Press the sides to keep the meat mixture intact. Gold both sides of the triangle wrapper inward. Set aside. Do this step until the pork mixture is completely consumed."
    },
    {
      "position": 4,
      "text": "Make the soup by combining water and chicken broth in a soup pot. Let boil."
    },
    {
      "position": 5,
      "text": "Add the rotisserie chicken (with bones). Cover and boil in low heat for 20 minutes. Turn the heat off temporarily."
    },
    {
      "position": 6,
      "text": "Remove the chicken and let it cool down. Separate the meat from the bones. Shred the meat."
    },
    {
      "position": 7,
      "text": "Turn the heat back on and wait until the liquid reboils. Add the shredded chicken meat."
    },
    {
      "position": 8,
      "text": "Put the wontons in the soup pot. Cover and cook for 5 to 10 minutes in low to medium heat."
    },
    {
      "position": 9,
      "text": "Add the fish sauce and half of the chopped scallions. Stir."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Top with toasted garlic and additional scallions."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
