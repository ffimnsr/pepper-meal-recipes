  "id": "485f2174-6e65-5397-8d06-9c65c5043b54",
  "slug": "sinigang-na-bangus-recipe",
  "name": "Sinigang na Bangus Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for sinigang na bangus",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot. Pour water into it."
    },
    {
      "position": 2,
      "text": "Add tomato and anion. Let boil."
    },
    {
      "position": 3,
      "text": "Add bangus. Cover and cook in medium heat between 8 to 12 minutes."
    },
    {
      "position": 4,
      "text": "Add Knorr Sinigang sa Sampaloc Mix. Stir. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Put the long green pepper into the pot. Add snake beans and okra. Stir. Cover and cook for 5 to 7 minutes."
    },
    {
      "position": 6,
      "text": "Add fish sauce and ground black pepper. Stir."
    },
    {
      "position": 7,
      "text": "Put the kangkong leaves into the pot. Cover the pot and turn the heat off. Let it stay for 5 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
