  "id": "3b5e9d46-4d46-55d0-98f1-2b9a9d826c7d",
  "slug": "pancit-sotanghon-na-may-hipon",
  "name": "Pancit Sotanghon Na May Hipon",
  "recipe_type": null,
  "brief_description": "A savory Filipino glass noodle dish featuring delicate sotanghon noodles, succulent shrimp, and Chinese sausage in a flavorful broth infused with garlic, fish sauce, and annatto.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Soak noodles in water for 5 minutes or until it starts to get softer and manageable. Drain the water. Set the noodles aside. Note: Make sure to not soak the noodles longer than 8 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pot. Saut\u00e9 garlic until light brown"
    },
    {
      "position": 3,
      "text": "Add onion. Saut\u00e9 until soft"
    },
    {
      "position": 4,
      "text": "Put the Chinese sausage, parsley, and paprika. Saut\u00e9 for 30 seconds to 1 minute."
    },
    {
      "position": 5,
      "text": "Pour-in water and fish sauce. Let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Shrimp Cube. Stir. Cover the pot and continue to cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Put ground black pepper, shrimp, carrot and cabbage into the pot. Stir and cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Add sotanghon and gently stir. Let the noodles absorb the liquid. Cover the pot and continue to cook for 3 to 5 minutes or until the liquid is absorbed fully."
    },
    {
      "position": 9,
      "text": "Add scallions and toss the noodles."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
