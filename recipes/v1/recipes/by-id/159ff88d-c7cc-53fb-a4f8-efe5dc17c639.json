  "id": "159ff88d-c7cc-53fb-a4f8-efe5dc17c639",
  "slug": "pumpkin-muffins-recipe",
  "name": "Pumpkin Muffins",
  "recipe_type": "breakfast",
  "brief_description": "Moist and warmly spiced pumpkin muffins topped with coarse sugar, perfect for breakfast or pairing with your morning coffee.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 375\u00b0F (190\u00b0C)."
    },
    {
      "position": 2,
      "text": "Grease a muffin tin with cooking spray and set aside."
    },
    {
      "position": 3,
      "text": "In a large mixing bowl, whisk together the flour, granulated sugar, baking powder, baking soda, cinnamon, and nutmeg."
    },
    {
      "position": 4,
      "text": "Add the pumpkin, eggs, water, and oil. Stir until just combined."
    },
    {
      "position": 5,
      "text": "Scoop the batter into the prepared muffin cups, filling each about two-thirds full. Sprinkle coarse sugar evenly over the tops."
    },
    {
      "position": 6,
      "text": "Bake for 20 to 30 minutes, or until a toothpick inserted into the center of a muffin comes out clean."
    },
    {
      "position": 7,
      "text": "Remove from the oven and let cool in the pan for 5 minutes, then transfer to a wire rack to cool completely."
    },
    {
      "position": 8,
      "text": "Serve warm or at room temperature with coffee or hot chocolate."
    }
  ],
  "servings": 15,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
