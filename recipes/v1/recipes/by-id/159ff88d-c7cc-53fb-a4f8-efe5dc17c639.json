  "recipe_notes": [
    "Do not overmix the batter once the wet ingredients are added; stir just until combined to avoid tough muffins.",
    "For added texture, fold in 1/2 cup of chopped walnuts or pecans with the wet ingredients."
  ],
  "storage_notes": [
    "Store cooled muffins in an airtight container at room temperature for up to 3 days.",
    "Muffins can be frozen for up to 3 months; thaw at room temperature or reheat in the microwave."
