  "id": "0ef8e393-6e9a-5874-aad8-6e3a9a646557",
  "slug": "broken-lasagna",
  "name": "Broken Lasagna",
  "recipe_type": "main",
  "brief_description": "Broken lasagna cooked in a rich tomato and beef sauce, finished with ricotta, mozzarella, parmesan, and sharp cheddar, and topped with fresh basil.",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Heat olive oil in a large pan. Arrange the whole tomatoes around the pan."
    },
    {
      "position": 2,
      "text": "Add the ground beef in the center and saut\u00e9 gently without disturbing the tomatoes until the beef browns."
    },
    {
      "position": 3,
      "text": "Add the garlic and onion. Saut\u00e9 for about 2 minutes."
    },
    {
      "position": 4,
      "text": "Peel off the tomato skins, mash the tomatoes, and stir well with the beef mixture."
    },
    {
      "position": 5,
      "text": "Add tomato paste and pour in beef broth. Stir and simmer for 20 minutes."
    },
    {
      "position": 6,
      "text": "Add the broken lasagna pieces. Stir occasionally and cook until al dente according to package directions."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and mix in the chopped fresh basil."
    },
    {
      "position": 8,
      "text": "Stir in ricotta, sharp cheddar, parmesan, and mozzarella. Gently mix until the cheeses melt and the sauce becomes creamy."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve warm with garlic bread."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
