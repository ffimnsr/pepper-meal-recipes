  "id": "7ffb5d8b-4011-5d4c-a246-146d78cc3b93",
  "slug": "chicken-and-egg-macaroni-salad",
  "name": "Chicken and Egg Macaroni Salad",
  "recipe_type": "salad",
  "brief_description": "Macaroni Salad with mayonnaise, boiled chicken, and eggs. This is perfect for the holidays.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Combine 5 cups water and chicken in a cooking pot. Let the liquid boil. Continue to cook the chicken for 15 to 18 minutes using medium heat. Remove the chicken from the pot. Let it cool down and then slice into cubes. Set aside."
    },
    {
      "position": 2,
      "text": "Cook macaroni according to package instructions using the remaining water. Drain water and place macaroni on a large bowl."
    },
    {
      "position": 3,
      "text": "Make the salad dressing by combining Lady\u2019s Choice Mayonnaise, onion, sugar, salt, and ground black pepper. Stir until well blended. Set aside."
    },
    {
      "position": 4,
      "text": "Combine cooked macaroni, cheese, raisins, pineapple, and chicken. Toss."
    },
    {
      "position": 5,
      "text": "Add eggs and salad dressing. Continue to toss until all ingredients are well distributed."
    },
    {
      "position": 6,
      "text": "Sprinkle the chopped parsley. Toss. Refrigerate the salad for at least 1 hour."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
