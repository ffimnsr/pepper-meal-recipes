{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "9b872e99-f8a2-536f-87c6-75466302f96e",
  "slug": "how-to-cook-chicken-adobo-using-boneless-chicken",
  "name": "Chicken Adobo Recipe (boneless thigh)",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Filipino chicken adobo using boneless chicken thigh. This is an easy recipe that can be served during special occassions.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the chicken by removing the bones. Use a sharp knife and score the meat around the bone until you can easily pull out the bone. You can also remove the skin if preferred."
    },
    {
      "position": 2,
      "text": "Crush 3 cloves of garlic and combine with soy sauce, vinegar, sugar, and \u00bc teaspoon ground black pepper. Stir and add the chicken. Marinate for at least 1 hour."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan. Fry the marinated chicken for 2 minutes per side. Remove the chicken and set aside."
    },
    {
      "position": 4,
      "text": "Saut\u00e9 the onion and remaining garlic. Once the onion softens, add the chicken back into the pan. Saut\u00e9 for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour the remaining marinade, add oyster sauce, water, and bay leaves, cover and let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Chicken Cube, cook for 30 minutes on low heat setting."
    },
    {
      "position": 7,
      "text": "Season with salt and ground black pepper as needed."
    },
    {
      "position": 8,
      "text": "Arrange on a serving plate and top with sliced green onions."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 60,
  "rest_time_minutes": null,
  "difficulty": "expert",
