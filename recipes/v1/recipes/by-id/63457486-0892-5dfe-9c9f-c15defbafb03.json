  "id": "63457486-0892-5dfe-9c9f-c15defbafb03",
  "slug": "grilled-cheese-ham-and-egg-sandwich",
  "name": "Grilled Cheese Ham and Egg Sandwich",
  "recipe_type": null,
  "brief_description": "One way to pump-up a Grilled Cheese sandwich is to add more ingredients. Grilled Cheese Ham and Egg Sandwich is one example.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a nonstick frying pan."
    },
    {
      "position": 2,
      "text": "Spread half of the butter on one side of the first bread slice."
    },
    {
      "position": 3,
      "text": "When the pan becomes hot, put in the bread (buttered side down)"
    },
    {
      "position": 4,
      "text": "Arrange the cheese and ham on top of the bread."
    },
    {
      "position": 5,
      "text": "Spread the remaining butter on the second bread slice. Top the second bread slice on the ham (buttered side up). Let it cook for 1 to 2 minutes or until the cheese melts."
    },
    {
      "position": 6,
      "text": "Flip the bread using a spatula to cook the other side of the bread. Cook for 1 to 2 minutes."
    },
    {
      "position": 7,
      "text": "Remove the bread from the pan and then place in a plate."
    },
    {
      "position": 8,
      "text": "Remove the second bread slice and arrange the egg on top of the ham. Put the second bread slice over the egg."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 1,
  "cooking_time_minutes": 5,
