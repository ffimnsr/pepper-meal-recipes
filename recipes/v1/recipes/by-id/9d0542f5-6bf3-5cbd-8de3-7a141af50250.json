  "id": "9d0542f5-6bf3-5cbd-8de3-7a141af50250",
  "slug": "tortang-noodles-at-sardinas",
  "name": "Tortang Noodles at Sardinas",
  "recipe_type": "appetizer",
  "brief_description": "Instant noodle and sardine patty topped with tasty sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the instant noodles by boiling water in a cooking pot. Add noodles and then cook until soft. Discard the water after cooking."
    },
    {
      "position": 2,
      "text": "While cooking the noodles, prepare the sardines. Separate the fish from the sauce. Put the fish in a bowl. Mash. Crack 2 eggs and place it in the same bowl. Mix with the mashed sardines. Season with ground black pepper and salt. Set aside"
    },
    {
      "position": 3,
      "text": "Add the cooked noodles in the bowl with the sardine mixture. Mix"
    },
    {
      "position": 4,
      "text": "Add flour and green onion. Continue mixing until all ingredients are well blended."
    },
    {
      "position": 5,
      "text": "Heat oil in a pan. Scoop around \u00bd cup of mixture and cook one side for 1 \u00bd minutes. Top with green onion and then flip to cook the other side using the same duration. Remove from the pan and arrange on a clean plate. Note: do this step until the mixture is totally consumed."
    },
    {
      "position": 6,
      "text": "Prepare the sauce by heating oil in a pot. Saut\u00e9 onion until soft. Pour the sauce into the pot and then cook for 30 seconds. Add remaining green onions. Stir."
    },
    {
      "position": 7,
      "text": "Top the sauce over the sardines and noodle omelet. Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
