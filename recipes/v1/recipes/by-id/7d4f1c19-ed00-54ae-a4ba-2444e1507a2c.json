  "id": "7d4f1c19-ed00-54ae-a4ba-2444e1507a2c",
  "slug": "arroz-a-la-cubana-recipe",
  "name": "Arroz a la Cubana Recipe",
  "recipe_type": "breakfast",
  "brief_description": "This Filipino Arroz a la Cubana Recipe is so delicious. You can enjoy this as a heavy breakfast or lunch. This Filipino Recipe version is a must try.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large cooking pan, saut\u00e9 the onion, garlic, and tomato"
    },
    {
      "position": 2,
      "text": "When the tomato becomes soft, put-in the ground beef and pork. Cook for 5 to 7 minutes."
    },
    {
      "position": 3,
      "text": "Pour-in tomato paste, Worcestershire sauce, soy sauce, and raisins. Stir and then cover the pan. Simmer for 10 to 12 minutes or until the liquid evaporates."
    },
    {
      "position": 4,
      "text": "Remove the cover and then put-in the green peas. Cook for 5 to 8 minutes in low to medium heat."
    },
    {
      "position": 5,
      "text": "Arrange in individual plates with steamed rice, fried bananas, and fried egg."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
