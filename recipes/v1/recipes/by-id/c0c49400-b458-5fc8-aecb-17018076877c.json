  "id": "c0c49400-b458-5fc8-aecb-17018076877c",
  "slug": "filipino-food-dessert-holiday-cassava-cake-recipe",
  "name": "Cassava Cake",
  "recipe_type": "dessert",
  "brief_description": "Filipino moist cake made from grated cassava.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Make the batter by combining the grated cassava, butter, 1/2 cup condensed milk, 6 oz. evaporated milk, 6 tablespoons cheddar cheese, 14 tablespoons sugar, and 2 eggs in a mixing bowl and mix thoroughly."
    },
    {
      "position": 2,
      "text": "Add the 2 cups coconut milk in the mixing bowl where the mixed ingredients are. Mix again."
    },
    {
      "position": 3,
      "text": "Grease the baking tray then pour-in the batter (these are the ingredients that you just mixed together)."
    },
    {
      "position": 4,
      "text": "Pre -heat oven for 350 degrees Fahrenheit for 10 minutes then put-in the baking tray with batter and bake for 1 hour.Remove from the oven and set aside."
    },
    {
      "position": 5,
      "text": "Meanwhile prepare the topping by combining 2 tablespoons sugar and flour in the heated saucepan."
    },
    {
      "position": 6,
      "text": "Pour-in 1/2 cup condensed milk then mix thoroughly."
    },
    {
      "position": 7,
      "text": "Add 2 tablespoons cheddar cheese while stirring constantly."
    },
    {
      "position": 8,
      "text": "Pour 2 cups of coconut milk and stir constantly for 10 minutes"
    },
    {
      "position": 9,
      "text": "Pour the topping over the Cassava Cake (baked batter) and spread evenly."
    },
    {
      "position": 10,
      "text": "Separate the yolk from the egg white of the remaining egg (we\u2019ll be needing the egg white only)"
    },
    {
      "position": 11,
      "text": "Glaze the topping with the egg white using a basting brush. Simply dip the brush to the egg white and brush it on the cassava cake."
    },
    {
      "position": 12,
      "text": "Set your oven to broil mode. Broil the Cassava cake until color turns light brown."
    },
    {
      "position": 13,
      "text": "Garnish with extra grated cheese on top. Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
