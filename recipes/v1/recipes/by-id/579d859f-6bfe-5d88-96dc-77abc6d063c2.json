{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "579d859f-6bfe-5d88-96dc-77abc6d063c2",
  "slug": "menudo-with-raisins-and-green-peas",
  "name": "Menudo with Raisins and Green Peas",
  "recipe_type": null,
  "brief_description": "A Filipino dish made with pork, liver, and vegetables, enhanced by raisins and peas.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Combine sliced pork with soy sauce and half of the minced garlic. Mix well and marinate for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat 2 tablespoons of cooking oil in a pan. Saut\u00e9 the hotdogs for 1 minute, then set aside. Saut\u00e9 1 onion until it softens. Add the liver and continue to saut\u00e9 for 2 minutes. Remove the liver from the pan and set aside."
    },
    {
      "position": 3,
      "text": "Heat the remaining cooking oil in a cooking pot. Add the remaining garlic and saut\u00e9 until it starts to brown. Then, add the remaining onion and continue saut\u00e9ing until it softens."
    },
    {
      "position": 4,
      "text": "Add the marinated pork meat and stir. Cook for 3 minutes, stirring occasionally. Pour the tomato sauce into the pot, stir, and then add water. Cover the pot and let the liquid boil."
    },
    {
      "position": 5,
      "text": "Add the bay leaves and raisins. Adjust the heat to a simmer and continue cooking until the pork is completely tender. Add the saut\u00e9ed liver and hotdogs, then stir."
    },
    {
      "position": 6,
      "text": "Next, add the carrots and potatoes. Cover and cook for 8 minutes. Add the green peas to the pot along with Maggi Magic Sarap. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Season with fish sauce and ground black pepper. Transfer to a serving plate and serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
