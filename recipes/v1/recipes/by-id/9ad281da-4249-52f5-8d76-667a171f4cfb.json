  "id": "9ad281da-4249-52f5-8d76-667a171f4cfb",
  "slug": "no-bake-macaroni",
  "name": "No Bake Macaroni",
  "recipe_type": "main",
  "brief_description": "No Bake Macaroni with Home Style Corned Beef",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the macaroni based on package instructions. Drain the water and set the macaroni aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a wide cooking pot. Saut\u00e9 onion and garlic until the onion softens."
    },
    {
      "position": 3,
      "text": "Add CDO Home Style Corned Beef in Pasta Sauce. Continue cooking for 3 to 5 minutes while stirring occasionally. Season with salt and ground black pepper as needed."
    },
    {
      "position": 4,
      "text": "Put the cooked macaroni into the pot. Toss and cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Top with grated cheese and garnish with chopped parsley."
    },
    {
      "position": 6,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 5,
