  "id": "464c4b2b-8b5a-5e27-9ad9-a8c13fd2bf30",
  "slug": "how-to-cook-tandoori-chicken",
  "name": "Tandoori Chicken Recipe",
  "recipe_type": null,
  "brief_description": "This Tandoori Chicken Recipe is straightforward and easy to prepare. Try to make it for yourself and enjoy its delicious taste. Happy cooking!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine all of the ingredients except for chicken and olive oil. Mix thoroughly."
    },
    {
      "position": 2,
      "text": "Put the chicken in the bowl and coat with the mixture."
    },
    {
      "position": 3,
      "text": "Marinade for 8 to 10 hours."
    },
    {
      "position": 4,
      "text": "Remove the chicken from the marinade and brush with olive oil."
    },
    {
      "position": 5,
      "text": "Grill until both sides are done."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate and garnish with sliced onions, carrots, and cucumber."
    },
    {
      "position": 7,
      "text": "Serve. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 18,
