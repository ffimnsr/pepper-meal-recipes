  "id": "10e3168c-1f1a-5736-9ad4-50fb06d8429b",
  "slug": "saging-con-hielo-recipe",
  "name": "Saging con Hielo",
  "recipe_type": "dessert",
  "brief_description": "Saging con Hielo is a simple dessert that I like to have during summertime. It is simply \"minatamis na saging\" (banana with caramel sauce) topped with shaved ice and milk.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour-in the water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Put-in the brown sugar. Stir."
    },
    {
      "position": 3,
      "text": "Add the vanilla extract (or essence) and salt. Stir once more. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the saba banana. Cover the cooking pot. Adjust the heat to low and cook for 10 to 15 minutes. Let the liquid reduce to half. Turn-off the heat and allow the banana to cool."
    },
    {
      "position": 5,
      "text": "Transfer to a serving bowl. Top with shaved ice and pour evaporated milk."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
