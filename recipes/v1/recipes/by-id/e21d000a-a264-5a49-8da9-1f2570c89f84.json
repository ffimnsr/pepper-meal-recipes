  "id": "e21d000a-a264-5a49-8da9-1f2570c89f84",
  "slug": "ginisang-papaya",
  "name": "Ginisang Papaya",
  "recipe_type": null,
  "brief_description": "Ginisang Papaya is a delicious and easy to prepare dish that you can make for lunch or dinner. This dish is similar to ginisang upo or ginseng sayote - although the meat used might vary.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Once the onion becomes soft, add the parsley and papaya. Continue to saut\u00e9 for 3 minutes. Cover and cook in medium heat for another 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Remove the cover. Add the shrimp. Stir. Cook for 1 to 2 minutes."
    },
    {
      "position": 5,
      "text": "Add the malunggay leaves. Stir and cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the fish sauce and add the ground black pepper. Stir."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
