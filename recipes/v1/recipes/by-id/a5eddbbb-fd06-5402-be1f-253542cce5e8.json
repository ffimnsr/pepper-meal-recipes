  "slug": "how-to-cook-shrimp-and-pasta-in-tomato-cream-cheese-sauce",
  "name": "Shrimp Pasta in Tomato Cream Cheese Sauce Recipe",
  "recipe_type": null,
  "brief_description": "Shrimp Pasta in Tomato Cream Cheese Sauce is another way to cook seafood pasta. Follow or Recipe for best results.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the cooked spaghetti in a serving plate. Set aside."
    },
    {
      "position": 2,
      "text": "Heat a cooking pot then pour-in olive oil"
    },
    {
      "position": 3,
      "text": "When the oil is hot, saute the onion."
    },
    {
      "position": 4,
      "text": "Pour-in crushed tomato and stir. Let boil and simmer for 10 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the thyme, salt, and pepper. Stir."
    },
    {
      "position": 6,
      "text": "Add the cream cheese and stir thoroughly until melted. Simmer for 5 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the shrimp and cook for 3 to 5 minutes more."
    },
    {
      "position": 8,
      "text": "Turn-off heat then pour the sauce over the pasta."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
