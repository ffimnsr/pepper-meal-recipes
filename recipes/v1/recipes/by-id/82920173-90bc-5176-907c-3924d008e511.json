  "id": "82920173-90bc-5176-907c-3924d008e511",
  "slug": "easy-pork-afritada-recipe",
  "name": "Tasty Pork Afritada Recipe",
  "recipe_type": null,
  "brief_description": "Pork Afritada is a tomato based pork stew. This afritada recipe makes use of pork along with hotdogs or beef franks and potatoes",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot or deep pan."
    },
    {
      "position": 2,
      "text": "Saute the garlic and onion when the oil becomes hot."
    },
    {
      "position": 3,
      "text": "Once the onion is soft, add the pork and cook until light brown (around 3 to 5 minutes)."
    },
    {
      "position": 4,
      "text": "Pour-in the tomato sauce and beef broth. Stir. Let boil. Cover and simmer for 45 to 60 minutes or until the pork becomes tender."
    },
    {
      "position": 5,
      "text": "Add the hotdogs and potatoes. Cook for 8 minutes."
    },
    {
      "position": 6,
      "text": "Add the green peas, sugar, salt, and pepper. Stir and cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
