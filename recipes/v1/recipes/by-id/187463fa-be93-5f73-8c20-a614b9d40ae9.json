  "id": "187463fa-be93-5f73-8c20-a614b9d40ae9",
  "slug": "beef-and-mushroom-braised-stew",
  "name": "Beef and Mushroom Braised Stew",
  "recipe_type": null,
  "brief_description": "Beef and Mushroom Braised Stew is a rich and flavorful beef stew dish that I enjoy eating with mashed potato.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and ground black pepper on the beef. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Melt 1 tablespoon butter in a Dutch oven or cooking pot. Put the beef in and cook for 3 to 5 minutes or until the color turns light brown."
    },
    {
      "position": 3,
      "text": "Remove the beef. Set Aside. Melt the remaining butter in the same cooking pot."
    },
    {
      "position": 4,
      "text": "Once the butter melts, saute the mushrooms, onions, and garlic. Continue to cook until the mushrooms become soft."
    },
    {
      "position": 5,
      "text": "Add the beef. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the tomato paste, parsley, oregano, and beef broth. Stir and let boil. Cover and simmer 60 min."
    },
    {
      "position": 7,
      "text": "Add the cream of mushroom. Stir and cook for 2 to 3 minutes."
    },
    {
      "position": 8,
      "text": "Turn the heat off. Transfer to a serving plate. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 80,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
