  "schema_version": 1,
  "id": "c496b59e-276c-5294-9f54-3fa2cc110776",
  "slug": "pork-embutido-steamed-filipino-meatloaf",
  "name": "Pork Embutido",
  "recipe_type": null,
  "brief_description": "This is a recipe for pork embutido meatloaf",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the embutido meatloaf by combining the following ingredients in a large mixing bowl: ground pork, onion, red bell pepper, carrot, sweet relish, raisins, cheese, eggs, salt, and ground black pepper. Mix well until all ingredients are blended."
    },
    {
      "position": 2,
      "text": "Add the bread crumbs. Continue to mix until well blended."
    },
    {
      "position": 3,
      "text": "Scoop a cup of embutido mixture and place over a sheet of pre-cut aluminum foil (12 x 10 inches). Mold the mixture to form a cylindrical shape. Roll the foil and secure both edges. Set aside. Do this until all the embutido meatloaf mixture is consumed."
    },
    {
      "position": 4,
      "text": "Arrange the wrapped embutido in a steamer. Pour water on the steamer and let boil. Steam (in medium heat) for 60 minutes."
    },
    {
      "position": 5,
      "text": "Remove the steamed pork embutido from the steamer. Let it cool down. Chill in the refrigerator for 2 hours. Slice and arrange in a serving plate. You can also fry it."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 10,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
