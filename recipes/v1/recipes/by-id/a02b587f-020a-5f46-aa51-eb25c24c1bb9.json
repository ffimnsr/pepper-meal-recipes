  "id": "a02b587f-020a-5f46-aa51-eb25c24c1bb9",
  "slug": "tuna-alfredo-casserole",
  "name": "Tuna Alfredo Casserole",
  "recipe_type": null,
  "brief_description": "Tuna Alfredo Casserole is a good tasting comfort food that you can make anytime you wish. It is simple to prepare and can easily be made even by beginners.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350F."
    },
    {
      "position": 2,
      "text": "Combine the tuna and Alfredo sauce in a large mixing bowl. Stir gently until all the ingredients are blended."
    },
    {
      "position": 3,
      "text": "Add-in the cooked macaroni noodles. Toss until the macaroni is coated with the sauce. Add salt and pepper to taste."
    },
    {
      "position": 4,
      "text": "Transfer the tuna Alfredo in a baking pan.Top with shredded cheese."
    },
    {
      "position": 5,
      "text": "Bake for 18 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 15,
