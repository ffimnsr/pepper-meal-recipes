{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "ba9bf02f-1eee-58da-ad24-9b3e500a2b8a",
  "slug": "chocolate-cupcake-with-cream-cheese-frosting",
  "name": "Chocolate Cupcake with Cream Cheese Frosting",
  "recipe_type": "dessert",
  "brief_description": "Chocolate Cupcake with Cream Cheese Frosting are a hit in any party or events. The chocolate cupcakes are moist and rich. The cream cheese frosting has the right amount of sweetness.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the cream cheese frosting by creaming the butter using an electric mixer. Add the cream cheese and then continue mixing until the texture is smooth. Gradually add the confectioners\u2019 sugar while beating and then pour-in the vanilla extract. Continue whisking until the texture becomes fluffy. Set aside."
    },
    {
      "position": 2,
      "text": "Boil about a cup and a half of water in a saucepan."
    },
    {
      "position": 3,
      "text": "Combine chocolate chips, butter, and cocoa powder in a medium bowl. Place the bowl over the saucepan and then adjust the heat to a simmer."
    },
    {
      "position": 4,
      "text": "Let the ingredients melt while whisking until the texture becomes smooth. Set aside."
    },
    {
      "position": 5,
      "text": "Combine the dry ingredients (baking powder, flour, and baking soda). Mix well using a balloon whisk and then gradually whisk-in the eggs, salt, and white sugar."
    },
    {
      "position": 6,
      "text": "Put-in the chocolate mixture and sour cream and then continue whisking until all the ingredients are well incorporated."
    },
    {
      "position": 7,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 8,
      "text": "Arrange paper cups on cupcake pans and then pour-in the mixture in each paper cups."
    },
    {
      "position": 9,
      "text": "Bake for 12 to 15 minutes or until it passes the toothpick test (The toothpick test is done by inserting a toothpick in a single cupcake. When you pull the toothpick and it comes out clean, that means that the cupcakes are ready.)"
    },
    {
      "position": 10,
      "text": "Sprinkle some brown sugar on top, and then pipe the cream cheese frosting on top of each cupcake."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 30,
