  "id": "b63723e3-ce40-5395-b4d5-44fac5e19b95",
  "slug": "sauteed-spinach",
  "name": "Sauteed Spinach",
  "recipe_type": "side",
  "brief_description": "Simple sauteed spinach recipe",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Place the spinach on a colander and then wash with running water. You can also first put the spinach in a mixing bowl with water and wash it there. Use the colander afterwards to drain the water. Let the water drain completely by constantly shaking the colander or using a salad spinner."
    },
    {
      "position": 2,
      "text": "Heat the olive oil on a pan and then add the garlic immediately. Slowly cook the garlic using low heat until it turns golden brown in color. Note: Avoid using high heat on your stove when browning minced garlic as it can burn quickly. (see notes)"
    },
    {
      "position": 3,
      "text": "Add the spinach. Give it a quick toss. Cover the pan and adjust the heat setting to medium. Let it cook for 1 minute. Note: This will make the spinach shrink a bit making it easier for you to stir it later on."
    },
    {
      "position": 4,
      "text": "Remove the cover and stir. Continue cooking for 2 to 2 1/2 minutes."
    },
    {
      "position": 5,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 6,
      "text": "Serve. share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 3,
  "preparation_time_minutes": 1,
