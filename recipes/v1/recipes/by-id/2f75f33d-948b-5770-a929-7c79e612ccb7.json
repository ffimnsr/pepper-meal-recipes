  "id": "2f75f33d-948b-5770-a929-7c79e612ccb7",
  "slug": "pulled-chicken-bbq-sandwich-recipe",
  "name": "Pulled Chicken BBQ Sandwich recipe",
  "recipe_type": null,
  "brief_description": "I enjoyed eating pulled chicken sandwich. This is similar to pulled pork sandwich except that we use boneless and skinless breast for this recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the BBQ sauce, vinegar, sugar, Worcestershire sauce, and pepper in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Place the chicken in a slow cooker and then pour-in the sauce mixture."
    },
    {
      "position": 3,
      "text": "Slow cook in low for about 5 to 6 hours. Shred the chicken on the 3rd hour and then continue to slow cook. Keep an eye on the cooker to ensure that there is still enough liquid."
    },
    {
      "position": 4,
      "text": "Arrange the slow cooked chicken BBQ in the middle of each sub."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 300,
  "preparation_time_minutes": 5,
