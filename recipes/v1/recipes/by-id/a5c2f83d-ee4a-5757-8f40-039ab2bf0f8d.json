  "id": "a5c2f83d-ee4a-5757-8f40-039ab2bf0f8d",
  "slug": "sardines-with-sotanghon-and-pechay",
  "name": "Sardines with Sotanghon and Pechay",
  "recipe_type": "soup",
  "brief_description": "Fish and noodle soup with bok choy. This budget dish is easy to make.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Crush the garlic and chop into small pieces. Saute in oil until it starts to brown. Add onion. Continue to cook until the later softens."
    },
    {
      "position": 3,
      "text": "Pour the contents of the canned sardines into the pan. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add pechay or bok choy. Saute for 30 seconds."
    },
    {
      "position": 5,
      "text": "Pour water into the pan. Let boil."
    },
    {
      "position": 6,
      "text": "Add sotanghon (vermicelli) noodles. Stir and cook until the noodles softens."
    },
    {
      "position": 7,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve hot."
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
