  "id": "ada700b0-d407-5bf5-aa71-a93fa2a638c0",
  "slug": "chicken-with-ampalaya-in-oyster-sauce",
  "name": "Chicken with Ampalaya in Oyster Sauce",
  "recipe_type": null,
  "brief_description": "Chicken with Ampalaya in Oyster Sauce is a quick and easy dish that you can make for lunch or dinner. This dish will surely be a hit.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Once the oil is hot, saut\u00e9 the onion and the garlic until the onion becomes soft."
    },
    {
      "position": 3,
      "text": "Add the sliced chicken breast. Cook for 2 to 3 minutes or until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Add the oyster sauce. Continue to cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in water or chicken broth. Let it boil. Cover and simmer for 10 to 12 minutes (add water, if necessary)."
    },
    {
      "position": 6,
      "text": "Put-in the sliced Ampalaya. Stir and cook in medium heat for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with brown or white rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
