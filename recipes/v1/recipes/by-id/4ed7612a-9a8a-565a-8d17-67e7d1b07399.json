  "id": "4ed7612a-9a8a-565a-8d17-67e7d1b07399",
  "slug": "creamy-veggie-lasagna",
  "name": "Creamy Veggie Lasagna",
  "recipe_type": null,
  "brief_description": "This is a recipe for Vegetable Lasagna",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine broccoli, mushrooms, and carrots in a large glass bowl. Microwave for 5 minutes. Set aside."
    },
    {
      "position": 2,
      "text": "Melt the butter in a saucepan. Gradually add-in flour and cook until light brown.."
    },
    {
      "position": 3,
      "text": "Gently stir-in the milk. Cook while stirring until the texture thickens. Add-in nutmeg and salt. Stir and turn off heat. This is now your bechamel sauce."
    },
    {
      "position": 4,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 5,
      "text": "Prepare a wide rectangular baking pan. Start setting-up your masterpiece by spreading the bechamel sauce on the pan. Arrange a layer of lasagna noodles, followed by another layer of vegetables. Sprinkle some mozzarella, Parmesan, and ricotta cheese on top, and then pour-in some bechamel sauce. Create another layer of lasagna noodles. Continue doing the process until you are able to fill your pan. Make sure that the last layer is made-up of lasagna noodles topped with parmesan cheese."
    },
    {
      "position": 6,
      "text": "Cover the rectangular pan with aluminum foil. Bake for 25 to 35 minutes."
    },
    {
      "position": 7,
      "text": "Remove the foil and bake for another 10 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven and let cool."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 50,
