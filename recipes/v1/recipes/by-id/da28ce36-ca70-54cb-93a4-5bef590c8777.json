  "id": "da28ce36-ca70-54cb-93a4-5bef590c8777",
  "slug": "lemon-cupcake-with-cream-cheese-frosting",
  "name": "Lemon Cupcake with Cream Cheese Frosting",
  "recipe_type": "dessert",
  "brief_description": "Lemon Cupcake with Cream Cheese Frosting makes a good breakfast or snack. It tastes fresh and I think that it pairs well with hot tea.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Using a hand mixer or a stand mixer, cream the butter and gradually add the sugar. Add-in the eggs and vanilla extract.Continue to beat until the texture becomes frothy."
    },
    {
      "position": 3,
      "text": "Gradually beat the flour and baking powder in. Add milk, lemon juice, and zest. Continue to beat until the texture becomes smooth."
    },
    {
      "position": 4,
      "text": "Arrange the paper cups on the muffin pans."
    },
    {
      "position": 5,
      "text": "Scoop the batter into the paper cups. Sprinkle some graham cracker crumbs on top."
    },
    {
      "position": 6,
      "text": "Bake for 23 to 25 minutes or until it passes the toothpick test."
    },
    {
      "position": 7,
      "text": "Arrange the cupcakes over a wire rack to cool."
    },
    {
      "position": 8,
      "text": "Pipe-in the cream cheese frosting on top."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 23,
