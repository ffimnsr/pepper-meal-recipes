  "id": "b5758133-b7c2-557b-8deb-997cbbf60c68",
  "slug": "shrimp-alfredo-pasta-with-scallops",
  "name": "Shrimp Alfredo Pasta with Scallops",
  "recipe_type": null,
  "brief_description": "Shrimp Alfredo Pasta with Scallops is a rich and delicious dish perfect for lunch or dinner. This recipe makes use of our homemade Alfredo sauce along.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook spaghetti or fetuccine according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the oil in a pan. Once the oil starts to heat-up, pan fry the shrimp for 1 minute per side. Remove the shrimp from the pan and set aside."
    },
    {
      "position": 3,
      "text": "Sear the scallops in medium heat for 2 minutes per side.Remove from the pan including the liquid that comes from it."
    },
    {
      "position": 4,
      "text": "On the same pan, melt the butter, and then cook the garlic until light brown."
    },
    {
      "position": 5,
      "text": "Pour the heavy cream in the pan and then stir. Cook between low to medium heat for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add the shrimp and scallops. Stir and cook for 3 minutes more."
    },
    {
      "position": 7,
      "text": "Add the Parmesan cheese and turn off the heat. Add salt and pepper if needed.Stir."
    },
    {
      "position": 8,
      "text": "Top the sauce over the spaghetti or you can add the spaghetti on the pan and then give and toss."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
