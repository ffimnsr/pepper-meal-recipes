  "slug": "roasted-garlic-parmesan-red-potato-recipe",
  "name": "Roasted Garlic Parmesan Red Potato",
  "recipe_type": "side",
  "brief_description": "This is a recipe for roasted potato.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine butter, garlic, lemon juice, olive oil, pepper, and salt. Mix well"
    },
    {
      "position": 2,
      "text": "Preheat oven to 370 degrees Fahrenheit"
    },
    {
      "position": 3,
      "text": "Place potatoes in an oven safe pan. Coat with the butter mixture"
    },
    {
      "position": 4,
      "text": "Sprinkle the Parmesan cheese on top."
    },
    {
      "position": 5,
      "text": "Place the pan inside the oven and then bake for 35 to 45 minutes."
    },
    {
      "position": 6,
      "text": "Serve as a side dish to chicken or pork dishes. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
