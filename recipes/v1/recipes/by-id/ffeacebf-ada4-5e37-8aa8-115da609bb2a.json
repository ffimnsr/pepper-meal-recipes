  "schema_version": 1,
  "id": "ffeacebf-ada4-5e37-8aa8-115da609bb2a",
  "slug": "oriental-lomi-recipe",
  "name": "Oriental Lomi Recipe",
  "recipe_type": "soup",
  "brief_description": "Oriental Lomi is an easy soup dish composed of round miki noodles, Chinese sausage, pork, and veggies. This version is more of the Chinese version and it is easier to prepare compared to the famous Batangas lomi. What I liked about this version aside from its ease of preparation is the delicious taste.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, saute the onion and garlic. Make sure that the garlic do not get burnt."
    },
    {
      "position": 3,
      "text": "When the onion gets soft, add the pork. Cook until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Put-in the Chinese sausage. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour-in the chicken broth and water. Let boil. Cover and simmer for 30 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the lomi noodles. Cook for 15 to 18 minutes."
    },
    {
      "position": 7,
      "text": "Add the carrot. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Put-in the savoy cabbage and scallions. Stir. Cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Add the flour diluted in water. Yes, this is flour that we are using this time, although I know that most of us are used to cornstarch. Cook while stirring until the sauce thickens a bit."
    },
    {
      "position": 10,
      "text": "Put-in the egg. Quickly stir until the egg blends with the rest of the ingredients."
    },
    {
      "position": 11,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 80,
  "preparation_time_minutes": 10,
