  "id": "14c433f5-287c-5a41-aacc-791e397542ec",
  "slug": "adobong-kangkong",
  "name": "Adobong Kangkong Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for adobong kangkong. It is a Filipino vegetable dish wherein the water spinach is cooked inadobo style.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Add the garlic. Saute until the color turns golden brown. Scoop-out a quarter of the browned garlic and put in a clean bowl. Save this later for garnish."
    },
    {
      "position": 3,
      "text": "Add chopped onion. Saute until it softens."
    },
    {
      "position": 4,
      "text": "Pour the soy sauce and vinegar in the pan. Let the liquid boil."
    },
    {
      "position": 5,
      "text": "Add the Kangkong stalks. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the Kangkong leaves. Stir. Continue cooking for 30 to 1 minute. Cover the pan and cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper. Note: you may also add salt if needed."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl and then top with browned garlic."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
