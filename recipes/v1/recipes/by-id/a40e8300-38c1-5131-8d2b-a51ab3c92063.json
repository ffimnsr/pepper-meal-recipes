  "id": "a40e8300-38c1-5131-8d2b-a51ab3c92063",
  "slug": "shrimp-scampi-recipe",
  "name": "Shrimp Scampi Recipe",
  "recipe_type": null,
  "brief_description": "This amazing Shrimp Scampi Recipe will surely make your day. It is fast and easy to prepare and the outcome is something that you will be proud about.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat olive oil in a pan."
    },
    {
      "position": 2,
      "text": "Add garlic and cook for 20 seconds."
    },
    {
      "position": 3,
      "text": "Pour-in the clam juice and white wine. Stir and let boil."
    },
    {
      "position": 4,
      "text": "Add salt, pepper, and shrimps. Cook for 3 to 4 minutes."
    },
    {
      "position": 5,
      "text": "Remove the shrimps one by one. Meanwhile, reduce the sauce (this is done simmering the sauce for a few minutes). Turn the heat off."
    },
    {
      "position": 6,
      "text": "Add butter and stir. Put-in lemon juice and parsley."
    },
    {
      "position": 7,
      "text": "Arrange the cooked pasta in pasta bowls. Top with shrimps and pour the sauce over."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
