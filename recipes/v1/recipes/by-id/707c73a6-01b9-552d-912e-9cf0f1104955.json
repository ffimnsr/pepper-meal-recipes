  "id": "707c73a6-01b9-552d-912e-9cf0f1104955",
  "slug": "utan-nga-langka",
  "name": "Utan nga Langka Recipe",
  "recipe_type": "main",
  "brief_description": "Unripe jackfruit with dried fish cooked in coconut milk.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a large wok."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 onion and garlic."
    },
    {
      "position": 3,
      "text": "Add the dried fish once the onions soften. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add unripe jackfruit. Cook while stirring for 2 to 3 minutes."
    },
    {
      "position": 5,
      "text": "Add chili peppers and bago leaves. Stir."
    },
    {
      "position": 6,
      "text": "Season with 1 tablespoon fish sauce and then pour-in the coconut milk. Let boil."
    },
    {
      "position": 7,
      "text": "Add vinegar. Cook for 5 to 8 minutes."
    },
    {
      "position": 8,
      "text": "Add Knorr Shrimp Cube. Continue cooking until the liquid evaporates completely."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper and fish sauce as needed."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve with warm rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
