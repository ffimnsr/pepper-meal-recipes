{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "bb72d4ab-7d9e-5160-80da-5b513927fa73",
  "slug": "crab-and-corn-pearl-soup-and-chinese-spring-rolls",
  "name": "Crab and Corn Pearl Soup and Chinese Spring Roll",
  "recipe_type": "appetizer",
  "brief_description": "Two great appetizers to make for the Chinese New Year. Both dishes complement each other. The tasty crab and corn soup with lobster balls and squid balls is best enjoyed warm while munching on the crispy chicken spring roll.",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Make the Crab and Corn Pearl Soup by boiling 5 cups water in a soup pot."
    },
    {
      "position": 2,
      "text": "Combine Knorr Crab and Corn Soup mix with 1 cup water. Stir until diluted. Set aside."
    },
    {
      "position": 3,
      "text": "Add lobster balls and squid balls into the boiling water. Cook for 3 minutes. Add crab stick. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour the crab and corn mixture. Quickly stir the soup until it thickens."
    },
    {
      "position": 5,
      "text": "Add scallions and season with ground white pepper. Transfer to a serving bowl."
    },
    {
      "position": 6,
      "text": "Prepare the Chinese Spring Rolls by first cooking the filling. Heat oil in a pan. Add the ground chicken. Cook until the chicken turns light brown."
    },
    {
      "position": 7,
      "text": "Add cabbage and carrots. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Add mushroom. Cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Pour Sesame oil and add the scallions. Season with Knorr Liquid seasoning and ground white pepper. Remove from heat and let it cool down."
    },
    {
      "position": 10,
      "text": "Place 1 \u00bd tablespoons of filling on a spring roll wrapper. Wrap by following the instructions on the video below. Perform this step until all filling are consumed."
    },
    {
      "position": 11,
      "text": "Heat cooking oil in a cooking pot. Deep fry the spring rolls until golden brown."
    },
    {
      "position": 12,
      "text": "Arrange on a serving plate. Serve with Crab and Corn Pearl Soup. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
