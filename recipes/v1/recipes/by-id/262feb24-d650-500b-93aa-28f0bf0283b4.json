  "slug": "baked-salmon-recipe",
  "name": "Baked Salmon Recipe",
  "recipe_type": null,
  "brief_description": "This delicious and healthy Baked Salmon Recipe is quick and easy to prepare. Allow me to guide you on how to make this dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the lemon juice over the salmon and distribute evenly. Let stand for 5 minutes."
    },
    {
      "position": 2,
      "text": "Rub salt, pepper, and garlic powder all over the salmon fillets."
    },
    {
      "position": 3,
      "text": "Wrap the entire salmon with an aluminum foil."
    },
    {
      "position": 4,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 5,
      "text": "Bake the salmon for 15 minutes."
    },
    {
      "position": 6,
      "text": "Open the aluminum foil to expose the top part of the fillet. Increase the heat to 400 degrees Fahrenheit and continue baking for 5 to 7 minutes."
    },
    {
      "position": 7,
      "text": "Remove the salmon from the oven and let cool."
    },
    {
      "position": 8,
      "text": "Meanwhile, combine spring mix, Feta, grape tomatoes, and vinaigrette. Toss."
    },
    {
      "position": 9,
      "text": "Transfer the mixture on a serving plate and top with the Baked Salmon."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
