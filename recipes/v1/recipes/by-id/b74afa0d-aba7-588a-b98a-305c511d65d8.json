  "id": "b74afa0d-aba7-588a-b98a-305c511d65d8",
  "slug": "sinigang-na-lechon",
  "name": "Sinigang na Lechon",
  "recipe_type": "soup",
  "brief_description": "Roasted pork soup in sour broth.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice lechon into serving pieces."
    },
    {
      "position": 2,
      "text": "Heat oil in a pot. Add lechon and saute for 1 minute."
    },
    {
      "position": 3,
      "text": "Put-in onion. Continue to cook for 35 seconds to 1 minute."
    },
    {
      "position": 4,
      "text": "Pour water into the pot. Let boil. Cover and continue boiling for 20 minutes using medium heat."
    },
    {
      "position": 5,
      "text": "Add Knorr Sinigang sa Sampaloc recipe mix. Stir."
    },
    {
      "position": 6,
      "text": "Add tomato and long green pepper. Cook for 8 minutes."
    },
    {
      "position": 7,
      "text": "Add okra, snake beans, and eggplant. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Season with ground white pepper and fish sauce."
    },
    {
      "position": 9,
      "text": "Put kangkong leaves into the pot. Continue cooking for 1 minute."
    },
    {
      "position": 10,
      "text": "Serve hot with rice. Serve!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
