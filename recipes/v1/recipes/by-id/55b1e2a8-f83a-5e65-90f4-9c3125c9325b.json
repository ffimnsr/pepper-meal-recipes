  "id": "55b1e2a8-f83a-5e65-90f4-9c3125c9325b",
  "slug": "shrimps-with-quail-eggs-and-green-peas",
  "name": "Shrimp with Quail Eggs and Green Peas",
  "recipe_type": null,
  "brief_description": "Shrimp with Quail Eggs and Green Peas is a quick and easy dish that you can prepare for lunch. This recipe is easy to follow",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a pan or cooking pot."
    },
    {
      "position": 2,
      "text": "Put-in the onions and cook in low fire until the texture becomes soft."
    },
    {
      "position": 3,
      "text": "Add the carrots and jicama then cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add the green peas and cashews then cook for 2 minutes"
    },
    {
      "position": 5,
      "text": "Move the vegetables on one side of the pan to form an extra space. Place the shrimp over the extra space and cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Stir the ingredients until well incorporated then pour the chicken broth in. Simmer for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add the salt and ground black pepper then stir."
    },
    {
      "position": 8,
      "text": "Put-in the quail eggs and cornstarch (diluted in water) and stir lightly. Cook until desired thickness is achieved."
    },
    {
      "position": 9,
      "text": "Turn of the heat and transfer to a serving bowl."
    },
    {
      "position": 10,
      "text": "Serve hot with lots of love. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
