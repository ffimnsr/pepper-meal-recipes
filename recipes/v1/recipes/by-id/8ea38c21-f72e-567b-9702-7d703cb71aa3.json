  "id": "8ea38c21-f72e-567b-9702-7d703cb71aa3",
  "slug": "roasted-pumpkin-seeds",
  "name": "Roasted Pumpkin Seeds",
  "recipe_type": "salad",
  "brief_description": "Roasted Pumpkin Seeds make a great snack; it can also be added to vegetable salad to make the texture better. I usually have roasted pumpkin seeds if I am not doing anything.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 400F."
    },
    {
      "position": 2,
      "text": "Meanwhile, combine the pumpkin seeds, oil, and salt in a bowl. Toss"
    },
    {
      "position": 3,
      "text": "Prepare a baking tray and line it with an aluminum foil."
    },
    {
      "position": 4,
      "text": "Spread the pumpkin seeds over the foil."
    },
    {
      "position": 5,
      "text": "Put the tray in the oven and roast the pumpkin seeds for 7 to 12 minutes."
    },
    {
      "position": 6,
      "text": "Remove the tray and let the seeds cool down."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl.Serve!"
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
