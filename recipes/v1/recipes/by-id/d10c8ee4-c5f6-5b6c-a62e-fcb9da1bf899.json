  "id": "d10c8ee4-c5f6-5b6c-a62e-fcb9da1bf899",
  "slug": "filipino-shrimp-pancit-bihon-recipe",
  "name": "Shrimp Pancit Bihon Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Shrimp Pancit Bihon Recipe.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, pan-fry the shrimp for 1 minute per side. Remove from the pot. Set aside."
    },
    {
      "position": 3,
      "text": "Meanwhile, using the remaining oil (you can add more if needed), saute garlic, onion, and celery."
    },
    {
      "position": 4,
      "text": "Add the parsley and ground black pepper. Stir."
    },
    {
      "position": 5,
      "text": "Pour-in soy sauce and water. Let boil."
    },
    {
      "position": 6,
      "text": "Add the shrimp cube. Stir and cook for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Add the carrot, cabbage, and snow peas."
    },
    {
      "position": 8,
      "text": "Add the pancit bihon. Gently toss until it absorbs all the liquid. Note: you can add more water if needed."
    },
    {
      "position": 9,
      "text": "Put the pan-fried shrimp back into the pot. Cook for 3 minutes more."
    },
    {
      "position": 10,
      "text": "Tranfer to a serving plate. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
