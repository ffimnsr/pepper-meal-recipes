  "id": "638a0444-6a18-5bb4-9804-341cf68d5b9d",
  "slug": "lumpiang-togue-toge-recipe",
  "name": "Lumpiang Togue Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Filipino vegetable lumpia",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a wok or a frying pan and put-in 2 tablespoons of cooking oil."
    },
    {
      "position": 2,
      "text": "When the oil is hot enough, Saut\u00e9 the garlic and onions."
    },
    {
      "position": 3,
      "text": "Add the dried shrimp. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Put-in the fried tofu then stir."
    },
    {
      "position": 5,
      "text": "Add the fish sauce and ground black pepper."
    },
    {
      "position": 6,
      "text": "Put-in the mung bean sprouts and cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add the carrot and cook for 1 to 2 minutes. Remove from the pan and let cool."
    },
    {
      "position": 8,
      "text": "Wrap the cooked vegetable in spring roll (lumpia) wrapper."
    },
    {
      "position": 9,
      "text": "Pour the remaining cooking oil in a cooking pot or deep fryer then apply heat."
    },
    {
      "position": 10,
      "text": "Deep fry the wrapped lumpia until the color of the wrapper turns golden brown."
    },
    {
      "position": 11,
      "text": "Remove from the cooking pot or deep fryer and place in a container lined with paper towel to absorb excess oils."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate"
    },
    {
      "position": 13,
      "text": "Serve with vinegar and onion dip."
    },
    {
      "position": 14,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
