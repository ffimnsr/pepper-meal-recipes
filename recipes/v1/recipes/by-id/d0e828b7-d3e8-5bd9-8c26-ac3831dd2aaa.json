  "id": "d0e828b7-d3e8-5bd9-8c26-ac3831dd2aaa",
  "slug": "bas-uy-recipe",
  "name": "Bas-uy Recipe (Pork and Liver Soup with Lemongrass and Chayote)",
  "recipe_type": "soup",
  "brief_description": "Bas-uy is a soup dish composed of pig liver cooked with ginger, lemongrass, and a variety of vegetables. This popular Ilonggo dish",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot, saut\u00e9 onion and ginger until the onion becomes soft."
    },
    {
      "position": 3,
      "text": "Add the sliced liver. Continue to saut\u00e9 for 2 minutes. This will remove the gamy taste and aroma. Remove the liver and temporarily place in a clean plate."
    },
    {
      "position": 4,
      "text": "Put-in the garlic. Saute until color turns light brown."
    },
    {
      "position": 5,
      "text": "Add-in the pork. Cook for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the beef broth. Let boil."
    },
    {
      "position": 7,
      "text": "Put-in the lemongrass. Cover and simmer for 30 to 45 minutes."
    },
    {
      "position": 8,
      "text": "Remove the lemongrass. Put-in the chayote and cooked liver. Continue to cook in medium heat for 3 to 5 minutes. Add water, if needed."
    },
    {
      "position": 9,
      "text": "Add-in the green onion or onion leeks. Cook for 2 minutes."
    },
    {
      "position": 10,
      "text": "Add salt and pepper to taste. You can also use fish sauce if you prefer."
    },
    {
      "position": 11,
      "text": "Serve hot with rice."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
