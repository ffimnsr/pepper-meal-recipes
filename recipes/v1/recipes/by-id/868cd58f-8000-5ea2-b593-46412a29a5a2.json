  "id": "868cd58f-8000-5ea2-b593-46412a29a5a2",
  "slug": "bam-i-cebuano-pansit-recipe",
  "name": "Bam-I Recipe",
  "recipe_type": "main",
  "brief_description": "Pancit canton and sotanghon guisado with chicken, shrimp, and pork.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in cooking oil."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onions then add the sliced pork and cook for 3 minutes."
    },
    {
      "position": 3,
      "text": "Put-in the Chinese sausage and shredded chicken and cook for 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Add soy sauce, shrimp juice, salt, ground black pepper, chicken bouillon, and chicken stock then let boil. Simmer for 5 to 8 minutes."
    },
    {
      "position": 5,
      "text": "Put the shrimps, cabbage, carrots, and wood ears in then cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the soaked noodles then stir. Cook for a minute."
    },
    {
      "position": 7,
      "text": "Put-in the flour sticks then stir well. Cook for 3 minutes or until the liquid is gone."
    },
    {
      "position": 8,
      "text": "Top with green onions and place calamansi on the side."
    },
    {
      "position": 9,
      "text": "Serve hot. Share and enjoy! Mangaon na Ta!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
