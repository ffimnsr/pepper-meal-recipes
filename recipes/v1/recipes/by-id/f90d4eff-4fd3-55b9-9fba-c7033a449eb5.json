  "name": "Cheese Pimiento Sandwich Spread",
  "recipe_type": null,
  "brief_description": "Cheese Pimiento Sandwich Spread is a type sandwich spread made from mayonnaise, grated or shredded cheese, and pimiento.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the mayonnaise, cheese, sugar, and salt. Mix well."
    },
    {
      "position": 2,
      "text": "Add the pimiento and then stir until all the ingredients are properly distributed."
    },
    {
      "position": 3,
      "text": "Transfer to a jar and refrigerate or make a cheese pimiento sandwich right away."
    },
    {
      "position": 4,
      "text": "Serve. Share and enjoy!"
    }
