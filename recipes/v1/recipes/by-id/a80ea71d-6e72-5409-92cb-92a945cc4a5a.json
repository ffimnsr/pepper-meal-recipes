  "id": "a80ea71d-6e72-5409-92cb-92a945cc4a5a",
  "slug": "pancit-sotanghon",
  "name": "Pancit Sotanghon",
  "recipe_type": null,
  "brief_description": "Pancit Sotanghon is a delicious noodle dish. This recipe features a combination of ingredients that make the entire dish look and taste special. Pancit Sotanghon is at its best when lemon or calamansi is squeezed on top before eating.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Place 6 cups water on a large mixing bowl. Put-in the vermicelli noodles and soak for 10 minutes or until the noodles becomes a bit soft. Discard the water."
    },
    {
      "position": 2,
      "text": "Boil 4 cups of water. Blanch the carrots, snap peas, and cabbage. Set aside. (note: I explained the concept of blanching in the pancit canton post)."
    },
    {
      "position": 3,
      "text": "Heat a wok or wide pan. Pour-in the cooking oil."
    },
    {
      "position": 4,
      "text": "Saute the garlic and onion."
    },
    {
      "position": 5,
      "text": "Once the onion becomes soft, add-in the Chinese sausage, pork, and baked chicken. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add-in the chopped parsley, soy sauce, and \u00be cup water. Stir and let boil."
    },
    {
      "position": 7,
      "text": "Add the vermicelli noodles. Make sure that the noodles are soft and that excess water has been drained. Toss until all the ingredients are well blended."
    },
    {
      "position": 8,
      "text": "Add salt and ground black pepper as needed."
    },
    {
      "position": 9,
      "text": "Put-in the blanched vegetables; toss and cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 20,
