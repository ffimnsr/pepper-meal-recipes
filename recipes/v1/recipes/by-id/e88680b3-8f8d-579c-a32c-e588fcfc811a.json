  "name": "Super Easy Pork Burger Recipe",
  "recipe_type": null,
  "brief_description": "This is a simple recipe for pork burger.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the ingredients in a large mixing bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Refrigerate for about an hour."
    },
    {
      "position": 3,
      "text": "Scoop the mixture and then form into patties."
    },
    {
      "position": 4,
      "text": "Grill each side for 5 minutes."
    },
    {
      "position": 5,
      "text": "Place the patty between the bread slices."
    },
    {
      "position": 6,
      "text": "Serve with apple coleslaw. Share and enjoy"
    }
  ],
