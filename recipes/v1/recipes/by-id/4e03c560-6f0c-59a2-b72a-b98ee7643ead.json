  "slug": "how-to-cook-spinach-and-feta-pasta",
  "name": "Spinach and Feta Pasta Recipe",
  "recipe_type": null,
  "brief_description": "This Spinach and Feta Pasta Recipe is simple and easy to follow. This dish really tastes good.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the olive oil in a skillet or frying pan then apply heat."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the tomatoes and cook for a minute."
    },
    {
      "position": 4,
      "text": "Put-in the mushroom, spinach, salt, and ground black pepper. Cook for 2 to 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the pasta then stir for the sauce to coat."
    },
    {
      "position": 6,
      "text": "Put-in the feta cheese and cook for a minute more."
    },
    {
      "position": 7,
      "text": "Turn-off the heat and transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with garlic bread on the side. Share and enjoy!"
    }
  ],
  "servings": 5,
