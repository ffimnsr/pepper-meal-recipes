  "id": "1faa00b6-60d1-58e8-a026-06ec8cd8dbde",
  "slug": "chicken-asparagus-soup-recipe",
  "name": "Chicken Asparagus Soup",
  "recipe_type": "soup",
  "brief_description": "How to cook a hearty chicken soup with fresh asparagus at home.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add chicken. Cover and boil for 20 minutes. Remove chicken and let it cool down. Shred the meat and set aside. Save the chicken stock."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot. Saut\u00e9 onion and garlic until onion softens."
    },
    {
      "position": 3,
      "text": "Add chicken. Saut\u00e9 for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour-in chicken stock. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Chicken Cube. Stir. Cover and cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add asparagus. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add spinach and season with salt and ground black pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    }
  ],
  "servings": 4,
