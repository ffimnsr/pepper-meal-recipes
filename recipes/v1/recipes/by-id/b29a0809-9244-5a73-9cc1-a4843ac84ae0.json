  "id": "b29a0809-9244-5a73-9cc1-a4843ac84ae0",
  "slug": "creamy-chicken-with-mushroom-recipe",
  "name": "Creamy Chicken with Mushroom Recipe",
  "recipe_type": null,
  "brief_description": "Creamy Chicken with Mushroom is a rich chicken dish that you can prepare for yourself and your family for dinner. This can be prepared in 30 minutes.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a pan and then add the olive oil."
    },
    {
      "position": 2,
      "text": "Pan-fry the chicken until the color turns light brown."
    },
    {
      "position": 3,
      "text": "Put-in the rosemary. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the cream of mushroom and chicken broth. Stir and let boil."
    },
    {
      "position": 5,
      "text": "Simmer for 20 minutes or until the liquid reduces."
    },
    {
      "position": 6,
      "text": "Put-in the mushroom and heavy whipping cream. Continue cooking for 3 to 5 minutes,"
    },
    {
      "position": 7,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Top with sour cream and cheese."
    },
    {
      "position": 9,
      "text": "Serve with mashed potato. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
