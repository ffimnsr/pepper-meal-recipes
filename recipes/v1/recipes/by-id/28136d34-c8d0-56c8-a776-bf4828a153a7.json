  "id": "28136d34-c8d0-56c8-a776-bf4828a153a7",
  "slug": "turkey-noodle-soup-recipe",
  "name": "Turkey Noodle Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "A simple Turkey noodle soup with celery, carrots, and wide egg noodle.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water in a large soup stock or cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Put-in the turkey (with bones), celery, onion, and carrots. Boil for 30 to 45 minutes."
    },
    {
      "position": 3,
      "text": "Remove the turkey and let it cool down. Discard the meat from the bones and shred the meat."
    },
    {
      "position": 4,
      "text": "Place the shredded turkey meat back to the cooking pot. Add the chicken powder or cube. Allow to re-boil."
    },
    {
      "position": 5,
      "text": "Add-in the wide noodles and then cook for 10 to 2 minutes."
    },
    {
      "position": 6,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
