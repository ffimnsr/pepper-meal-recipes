  "id": "2f22f6b9-c015-56ac-9dc8-6d532c06ea01",
  "slug": "buttermilk-fried-chicken-recipe",
  "name": "Easy Buttermilk Fried Chicken",
  "recipe_type": null,
  "brief_description": "I always enjoy my fried chicken when cooking using this recipe. The chicken always turns our crispy, juicy, tender, and tasty as well. Buttermilk is indeed the secret to tender and juicy fried chicken. I hope that you give this recipe a try.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken with marinade ingredients in a bowl. Mix well. Cover the bowl and refrigerate for 8 hours."
    },
    {
      "position": 2,
      "text": "Combine all breading ingredients in a clean bowl. Mix well. Set aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan."
    },
    {
      "position": 4,
      "text": "While the oil is heating up, separate the chicken from the remaining buttermilk. Do not wash the chicken. Dredge each chicken piece in flour mixture until fully coated. Shake-off excess flour."
    },
    {
      "position": 5,
      "text": "Once the oil temperature reaches 350F, fry the chicken for 9 to 11 minutes. Turn it over and continue frying the opposite side for 8 minutes or until the chicken gets fully cooked (165F internal temperature)."
    },
    {
      "position": 6,
      "text": "Remove the fried chicken from the pan. Place it on a plate lined with a paper towel."
    },
    {
      "position": 7,
      "text": "Serve with chicken gravy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
