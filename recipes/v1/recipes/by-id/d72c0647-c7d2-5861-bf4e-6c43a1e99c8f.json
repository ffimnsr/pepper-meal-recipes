  "id": "d72c0647-c7d2-5861-bf4e-6c43a1e99c8f",
  "slug": "chicken-barbecue-fried-rice",
  "name": "Chicken Barbecue Fried Rice",
  "recipe_type": null,
  "brief_description": "Presenting this delicious and tasty Chicken Barbecue Fried Rice Recipe. Definitely the best fried rice that you can make for yourself.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine salt with the rice and mix well."
    },
    {
      "position": 2,
      "text": "Heat a pan and pour-in the cooking oil."
    },
    {
      "position": 3,
      "text": "Add garlic when the oil becomes hot, and then cook until the color turns medium brown."
    },
    {
      "position": 4,
      "text": "Put-in the chicken and cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add the barbecue sauce. Stir and cook for a minute."
    },
    {
      "position": 6,
      "text": "Put-in the rice and gently mix until the sauce and chicken is well distributed. Cook for 5 to 8 minutes while occasionally stirring."
    },
    {
      "position": 7,
      "text": "Turn the heat off, and transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with your favorite main dish."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
