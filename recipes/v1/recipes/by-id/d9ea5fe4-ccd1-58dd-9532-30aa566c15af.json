  "id": "d9ea5fe4-ccd1-58dd-9532-30aa566c15af",
  "slug": "peanut-brittle-holiday-recipe",
  "name": "Peanut Brittle Recipe",
  "recipe_type": "dessert",
  "brief_description": "Peanut Brittle is a hard but breakable confection made from mainly sugar and peanuts. This is considered as good treat for the Christmas Season.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Grease a baking tray or cookie sheet. Set aside."
    },
    {
      "position": 2,
      "text": "Heat a saucepan then put-in corn syrup, sugar, water, and salt. Stir and bring to a boil."
    },
    {
      "position": 3,
      "text": "Add the peanuts then stir."
    },
    {
      "position": 4,
      "text": "Using a candy thermometer, measure the temperature until it reaches 290 degrees Fahrenheit. It is a must that you use low heat to avoid the sugar and peanuts from being burnt."
    },
    {
      "position": 5,
      "text": "Turn-off heat then put-in the butter and baking soda. Stir thoroughly"
    },
    {
      "position": 6,
      "text": "Pour the mixture on the greased baking tray then arrange. Allow the mixture to completely cool."
    },
    {
      "position": 7,
      "text": "Remove the mixture from the tray and snap into desired sizes."
    },
    {
      "position": 8,
      "text": "Place in a container and serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 10,
