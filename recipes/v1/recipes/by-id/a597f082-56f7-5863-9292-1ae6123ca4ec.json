  "slug": "tastylicious-adobong-pusit-recipe",
  "name": "Tastylicious Adobong Pusit Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Tastylicious Adobong Pusit",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot, saute garlic until it turns light brown."
    },
    {
      "position": 3,
      "text": "Add onion and tomato. Saute until the onion gets soft"
    },
    {
      "position": 4,
      "text": "Add the squid. Saut\u00e9 for 2 to 3 minutes"
    },
    {
      "position": 5,
      "text": "Remove the squid from the pan and place in a clean bowl.Set aside."
    },
    {
      "position": 6,
      "text": "Pour soy sauce and water into the pan. Let boil."
    },
    {
      "position": 7,
      "text": "Add vinegar. Let the liquid re-boil. Stir and cover the pan. Continue to cook in medium heat for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Add the saut\u00e9ed squid back in the pan along with sugar, salt, and ground black pepper. Stir. Continue to cook for 2 minutes. Note: do not overcook the squid to retain its tender texture."
    },
    {
      "position": 9,
      "text": "Using a slotted spoon or a spider strainer, remove the squid from the cooking pot leaving the liquid behind. Arrange the squid in a bowl. Continue to cook the liquid until it reduces to half."
    },
    {
      "position": 10,
      "text": "Pour the thick liquid into the serving bowl with the squid. Toss."
    },
    {
      "position": 11,
      "text": "Serve with white rice. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 25,
