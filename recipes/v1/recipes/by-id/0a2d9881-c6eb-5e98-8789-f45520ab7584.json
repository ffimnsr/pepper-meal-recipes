  "id": "0a2d9881-c6eb-5e98-8789-f45520ab7584",
  "slug": "pinakbet-tagalog-recipe-knr-sc",
  "name": "Pinakbet Tagalog Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Pinakbet or bulanglang that makes use of deep fried crispy pork belly or lechon kawali.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a pot. Saute onion and garlic. Add ginger and continue to cook until the onion softens."
    },
    {
      "position": 2,
      "text": "Add half of the lechon kawali. Saute for 1 minute."
    },
    {
      "position": 3,
      "text": "Pour water. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Shrimp Cube. Cover the pot and cook in medium heat for 20 minutes."
    },
    {
      "position": 5,
      "text": "Add tomato and bagoong alamang. Stir. Cover the pot. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Put the kalabasa and kamote into the pot. Cook for 7 minutes."
    },
    {
      "position": 7,
      "text": "Add sitaw, okra, ampalaya, and eggplant. Stir. Cover the pot and cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper and add remaining lechon kawali. Cook for minutes."
    },
    {
      "position": 9,
      "text": "Tranfer to a serving plate. Serve. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
