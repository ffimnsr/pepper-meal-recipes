  "id": "f394b18c-722f-51f9-998f-43d91ca4ef19",
  "slug": "panko-parmesan-crusted-halibut",
  "name": "Panko Parmesan Crusted Halibut",
  "recipe_type": null,
  "brief_description": "Get to know how to cook Panko Parmesan Crusted Halibut. A healthy and delicious fish recipe that you can enjoy for dinner.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub the lemon juice and olive oil on each side of the halibut. Season with salt and pepper"
    },
    {
      "position": 2,
      "text": "Place a wire rack over a baking tray."
    },
    {
      "position": 3,
      "text": "Combine the Parmesan cheese, parsley , bread crumbs, garlic powder, and some additional salt and pepper. Roll the fish over the mixture to coat. Put the coated fish above the wire rack."
    },
    {
      "position": 4,
      "text": "Preheat the oven to 460F."
    },
    {
      "position": 5,
      "text": "Place the tray inside the refrigerator for 15 minutes."
    },
    {
      "position": 6,
      "text": "Bake for 17 minutes or until the fish is flaky. Remove from the oven and serve with a mixed vegetables on the side."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 17,
