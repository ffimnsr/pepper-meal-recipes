  "id": "c5ccdc41-ee73-582d-ae05-f66798d60d13",
  "slug": "fish-kardilyo-recipe",
  "name": "Fish Kardilyo Recipe",
  "recipe_type": null,
  "brief_description": "Fish Kardilyo or Kardilyong Isda is a Filipino Fish Recipe with a special sauce. This dish is also similar to Fish Sarciado.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Run salt and pepper on the tilapia fillet. Let it stand for 10 minutes"
    },
    {
      "position": 2,
      "text": "Heat the oil in a frying pan."
    },
    {
      "position": 3,
      "text": "Dredge the tilapia in flour and then dip in the beaten egg. Roll the tilapia on the corn meal. Make sure that the fish is properly coated."
    },
    {
      "position": 4,
      "text": "Fry each side until the color turns light to golden brown. Set aside."
    },
    {
      "position": 5,
      "text": "Meanwhile, make the sauce by sauteing garlic, onion, and tomato."
    },
    {
      "position": 6,
      "text": "Once the tomato and onion are soft, add the fish sauce and sprinkle some pepper."
    },
    {
      "position": 7,
      "text": "Add water and then let boil. Simmer for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Pour-in remaining beaten egg and then stir for 5 seconds."
    },
    {
      "position": 9,
      "text": "Arrange the fried fish on a serving plate and then top with the sauce. You can also serve the sauce separately."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
