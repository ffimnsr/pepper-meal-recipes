  "id": "f5cc7235-5c22-5c80-8980-add084f46398",
  "slug": "crispy-mini-lechon-belly-roll",
  "name": "Crispy Lechon Belly Roll",
  "recipe_type": "main",
  "brief_description": "Rolled pork belly with herbs and spices air fried until crispy.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the pork belly in half. Lay it flat on a clean surface and then rub salt and ground black pepper on the side with meat."
    },
    {
      "position": 2,
      "text": "Spread the garlic over each piece of belly and arrange the sliced onion, lemongrass, and green onion."
    },
    {
      "position": 3,
      "text": "Roll the pork belly in a way that all ingredients remain inside. Make sure that both ends are touching. Securely tie the belly using a kitchen twine."
    },
    {
      "position": 4,
      "text": "Arrange the two pork belly rolls in a steamer. Steam for 45 minutes."
    },
    {
      "position": 5,
      "text": "Remove from the steamer and let it cool down for 15 minutes. Rub oil all over each belly roll."
    },
    {
      "position": 6,
      "text": "Arrange the belly rolls in a turbo broiler and then broil for 45 minutes."
    },
    {
      "position": 7,
      "text": "Slice and serve while still hot. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
