  "id": "4066cc58-b13d-524a-9848-f47a02681b2e",
  "slug": "chicken-spaghetti-recipe",
  "name": "Chicken Spaghetti Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for spicy chicken spaghetti. It makes use of chipotle adobo sauce to add a little spice to the dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add the chicken and simmer for 20 to 25 minutes or until tender."
    },
    {
      "position": 3,
      "text": "Remove the chicken from the pot. Let the temperature cool down a little bit, and then shred the meat. Discard the bones."
    },
    {
      "position": 4,
      "text": "Heat olive oil in a pan."
    },
    {
      "position": 5,
      "text": "Saut\u00e9 onion and add the shredded chicken."
    },
    {
      "position": 6,
      "text": "Put-in tomato sauce, diced tomatoes, chicken stock, and chipotle pepper in adobo sauce. Let boil and simmer for 20 minutes."
    },
    {
      "position": 7,
      "text": "Add basil, dried parsley, sugar, salt, and pepper. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Arrange spaghetti noodles in individual plates and pour the sauce over. Top shredded cheese."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
