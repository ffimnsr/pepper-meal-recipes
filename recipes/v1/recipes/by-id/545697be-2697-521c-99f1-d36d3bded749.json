  "id": "545697be-2697-521c-99f1-d36d3bded749",
  "slug": "sweet-pata-asado",
  "name": "Sweet Pata Asado",
  "recipe_type": "dessert",
  "brief_description": "Pork hocks stewed in soy sauce and star anise.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the pata by boiling. Pour water in a pot. Arrange pata slices. Cover and let boil. Continue boiling for 15 minutes while scraping scums and impurities. Discard water afterwards and wash the pork pata once it cools down. Set aside."
    },
    {
      "position": 2,
      "text": "Start cooking Sweet Pata Asado by heating oil in a pan. Saut\u00e9 onion and garlic until onion softens."
    },
    {
      "position": 3,
      "text": "Add pata slices. Sautee for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour soy sauce and water into the pot. Add star anise. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork Cube. Stir and cover. Set the heat between low and medium. Continue boiling until pata tenderizes. Note: make sure to stir once in a while to cook the meat evenly. Note: add more water as needed."
    },
    {
      "position": 6,
      "text": "Add sugar. Stir and cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Season with ground white pepper and salt."
    },
    {
      "position": 8,
      "text": "Combine cornstarch with 3 tablespoons water. Mix well. Pour mixture into the pot. Stir and cook until sauce thickens."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
