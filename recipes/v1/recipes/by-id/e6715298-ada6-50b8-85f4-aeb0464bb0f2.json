  "id": "e6715298-ada6-50b8-85f4-aeb0464bb0f2",
  "slug": "fish-tinola",
  "name": "Fish Tinola Recipe",
  "recipe_type": "soup",
  "brief_description": "Fish Tinola is a Filipino ginger based soup dish. This is composed of fish (fillet or otherwise), papaya or chayote wedges, malunggay and hot pepper leaves.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the olive oil in a pan."
    },
    {
      "position": 2,
      "text": "When the oil becomes hot, pan-fry the salmon fillets for about a minute per side. Remove from the pan and set aside."
    },
    {
      "position": 3,
      "text": "On the same pan using the remaining oil, saut\u00e9 the onion and ginger"
    },
    {
      "position": 4,
      "text": "Sprinkle the ground black pepper and then pour-in the fish sauce."
    },
    {
      "position": 5,
      "text": "Pour-in the water. Let boil."
    },
    {
      "position": 6,
      "text": "Put-in the chayote and finger chili. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add the pan-fried salmon. Simmer for 5 minutes."
    },
    {
      "position": 8,
      "text": "Add-in the malunggay leaves. Turn off the heat and then cover the cooking pot. Let it stay for 5 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
