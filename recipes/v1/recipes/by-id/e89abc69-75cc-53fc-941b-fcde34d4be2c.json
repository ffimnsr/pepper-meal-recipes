  "id": "e89abc69-75cc-53fc-941b-fcde34d4be2c",
  "slug": "chicken-and-rice-casserole-recipe",
  "name": "Chicken and Rice Casserole Recipe",
  "recipe_type": null,
  "brief_description": "Chicken and Rice Casserole is an easy to prepare casserole recipe that is full of flavor. I like how the flavor of cream of chicken and mushroom blends with the rest of the ingredients \u2013 there is always a celebration going-on in my mouth every time I chew.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 375F."
    },
    {
      "position": 2,
      "text": "Lightly salt the chicken breast. Set aside for 10 minutes."
    },
    {
      "position": 3,
      "text": "In a large bowl, combine Cream of Chicken and Mushroom, water, and French onion dip mix. Stir to mix."
    },
    {
      "position": 4,
      "text": "Add-in rice and mixed vegetables. Gently stir to distribute all the ingredients."
    },
    {
      "position": 5,
      "text": "Pour the rice mixture on a baking dish. Top with the chicken pieces.Place inside the oven and bake for 30 minutes."
    },
    {
      "position": 6,
      "text": "Remove the baking dish from the oven and gently stir the rice mixture so that it will be cooked equally.Place it back in the oven and continue to bake for 20 to 30 minutes or until the rice is about done. Remove from the oven and top with shredded cheese."
    },
    {
      "position": 7,
      "text": "Put it back in the oven for 5 minutes or until the cheese melts."
    },
    {
      "position": 8,
      "text": "Take the baking dish from the oven and serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
