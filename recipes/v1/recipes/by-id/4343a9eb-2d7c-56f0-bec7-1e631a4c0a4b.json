  "id": "4343a9eb-2d7c-56f0-bec7-1e631a4c0a4b",
  "slug": "fried-bangus-recipe",
  "name": "Fried Bangus Recipe (Fried Milkfish)",
  "recipe_type": null,
  "brief_description": "This Marinated Fried Bangus Recipe enhances the flavor of the milkfish through the marinade. Get the details of the recipe here.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine vinegar, garlic, whole peppercorn, and salt in a bowl. Stir."
    },
    {
      "position": 2,
      "text": "In a deep wide plate, pour-in the mixture and then lay down the fish in a manner that the sliced part is facing down (skin should face up). Cover and place in the fridge. Marinate for 8 to 12 hours."
    },
    {
      "position": 3,
      "text": "Heat the cooking oil in a pan. Fry both sides of the bangus in medium heat until the color turns medium brown (note: it should take around 5 minutes per side). Note: the oil has a tendency to splatter because of the liquid from the marinade. Make sure to cover the pan while leaving open a small space for the steam to escape."
    },
    {
      "position": 4,
      "text": "Serve with spiced vinegar (sinamak)."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 720,
