  "id": "c74c754a-42f8-527a-9fb3-ff6e2ffe5dd5",
  "slug": "chicharon-bituka",
  "name": "Chicharon Bituka Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Chicharon Bituka are deep fried pig or cow intestine prepared similar to that of Chicharones or Pork Cracklings (Pork Rinds). This dish is usually served as an appetizer or \"pulutan\" and is best when accompanied with beer.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water in a large pot and bring to a boil"
    },
    {
      "position": 2,
      "text": "Add 2 tbsp salt and vinegar then let boil for another 2 minutes"
    },
    {
      "position": 3,
      "text": "Place the intestine in the pot and wait until the liquid re-boils"
    },
    {
      "position": 4,
      "text": "Put-in the dried bay leaves and whole pepper corn then simmer for 40 minutes or until intestine is tender."
    },
    {
      "position": 5,
      "text": "Remove the intestine from the pot then drain excess water"
    },
    {
      "position": 6,
      "text": "Cut the intestine according to desired length."
    },
    {
      "position": 7,
      "text": "Sprinkle the remaining salt over the intestine. Make sure that it is evenly distributed over all the intestines."
    },
    {
      "position": 8,
      "text": "In a separate pot/pan, pour the oil and heat until the temperature is good for frying"
    },
    {
      "position": 9,
      "text": "Deep fry the intestines. Make sure that the texture is crunchy before removing from the pot/pan"
    },
    {
      "position": 10,
      "text": "Serve with vinegar and chili pepper dip. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
