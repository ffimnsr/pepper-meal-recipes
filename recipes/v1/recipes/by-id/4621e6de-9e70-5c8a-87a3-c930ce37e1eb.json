  "id": "4621e6de-9e70-5c8a-87a3-c930ce37e1eb",
  "slug": "tuna-and-zucchini-omelet",
  "name": "Tuna and Zucchini Omelet",
  "recipe_type": "breakfast",
  "brief_description": "Breakfast can be more fun when you are having Tuna and Zucchini Omelet. This breakfast omelet looks so appealing and it tastes really good too.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to broil (510F)."
    },
    {
      "position": 2,
      "text": "Combine salt, pepper, and beaten eggs in a bowl. Mix well and then set aside."
    },
    {
      "position": 3,
      "text": "Heat an oven-safe frying pan or skillet in a stove top. Pour-in the cooking oil."
    },
    {
      "position": 4,
      "text": "Once the oil becomes hot, saute the onion and zucchini for 2 to 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the tuna. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the beaten eggs. Gradually stir to distribute the ingredients. Cook in low to medium heat for 4 to 6 minutes."
    },
    {
      "position": 7,
      "text": "Turn off heat from the stove top and then place the pan inside the oven. Broil for 5 to 7 minutes or until the top part of the omelet is done."
    },
    {
      "position": 8,
      "text": "Serve for breakfast."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
