  "id": "cfaf5106-dc87-55ab-afd2-006d1ffa254b",
  "slug": "how-to-make-pasta-cheese-baked-macaroni-recipe",
  "name": "Baked Macaroni Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Baked Macaroni",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the elbow macaroni according to instructions in the package and intentionally cut the cooking time so that the macaroni is not well done (the macaroni will be fully cooked once baked) then drain and set aside."
    },
    {
      "position": 2,
      "text": "Prepare the meat sauce by heating a cooking pot and melt-in the butter."
    },
    {
      "position": 3,
      "text": "When the butter is hot enough, add the ground beef and cook for 5 minutes or until the color turns medium brown."
    },
    {
      "position": 4,
      "text": "Add the onion, green bell pepper, and diced tomatoes then stir and simmer for 3 minutes or until the vegetables are soft."
    },
    {
      "position": 5,
      "text": "Add the tomato paste and paprika then stir and cook for a minute"
    },
    {
      "position": 6,
      "text": "Add the beef cube and water then stir until everything is well distributed. Simmer for 20 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the sugar, salt, and pepper then mix well. Turn of the heat and set aside."
    },
    {
      "position": 8,
      "text": "Prepare the Mornay sauce by melting the butter in a sauce pan over medium heat."
    },
    {
      "position": 9,
      "text": "Add the flour stir constantly for about a minute (color must be yellowish and not brown)."
    },
    {
      "position": 10,
      "text": "Slowly whisk in the milk and continue to whisk until the sauce thickens and comes to a boil."
    },
    {
      "position": 11,
      "text": "Add salt and pepper then simmer for 2 to 3 minutes."
    },
    {
      "position": 12,
      "text": "Stir in the cheeses and whisk until melted. Set aside"
    },
    {
      "position": 13,
      "text": "Combine the cooked macaroni and meat sauce in a baking dish then toss until the meat sauce is well distributed."
    },
    {
      "position": 14,
      "text": "Arrange the macaroni and pour the Mornay sauce over it. (Spread the Mornay sauce over the macaroni and meat sauce mixture ensuring that every space is covered)"
    },
    {
      "position": 15,
      "text": "Preheat oven to 350 degrees Fahrenheit and bake for about 15 to 20 minutes."
    },
    {
      "position": 16,
      "text": "Remove from the oven and allow to cool down a bit."
    },
    {
      "position": 17,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
