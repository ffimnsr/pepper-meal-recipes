  "id": "fbec2455-6cea-52b4-8c74-953f3fe4494d",
  "slug": "bistek-tagalog-beefsteak-recipe",
  "name": "Bistek Tagalog (beefsteak) Recipe",
  "recipe_type": null,
  "brief_description": "Beef slices cooked in soy sauce with lemon and onions. This is bistek tagalog.&nbsp;",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Marinate beef in soy sauce, lemon (or calamansi), and ground black pepper for at least 1 hour. Note: marinate overnight for best result"
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan then pan-fry half of the onions until the texture becomes soft. Set aside"
    },
    {
      "position": 3,
      "text": "Drain the marinade from the beef. Set it aside. Pan-fry the beef on the same pan where the onions were fried for 1 minute per side.&nbsp;Remove from the pan. Set aside"
    },
    {
      "position": 4,
      "text": "Add more oil if needed. Saute garlic and remaining raw onions until onion softens."
    },
    {
      "position": 5,
      "text": "Pour the remaining marinade and water.&nbsp;Bring to a boil."
    },
    {
      "position": 6,
      "text": "Add beef. Cover the pan and simmer until meat is tender. Note: Add water as needed."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and salt as needed. Top with pan-fried onions."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 60,
  "rest_time_minutes": null,
