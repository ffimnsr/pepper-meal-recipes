  "id": "94f3ae76-c48b-5130-8299-f88973a5ad90",
  "slug": "rotini-chicken-alfredo",
  "name": "Rotini Chicken Alfredo Recipe",
  "recipe_type": null,
  "brief_description": "Try this Rotini Chicken Alfredo Recipe and discover the delicious and rich taste of this pasta dish. Get the details here.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the rotini according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Heat a saucepan or cooking pot and pour-in the milk then bring to a boil"
    },
    {
      "position": 3,
      "text": "Add the heavy whipping cream and stir then let boil."
    },
    {
      "position": 4,
      "text": "Adjust the heat to low and add the Parmesan and Romano cheeses. Stir continuously until mixture becomes fine."
    },
    {
      "position": 5,
      "text": "Whisk the egg yolks in a mixing bowl then add about 5 tablespoons of the milk and cheese mixture. Continue whisking until all the ingredients are distributed."
    },
    {
      "position": 6,
      "text": "Add the remaining egg yolk mixture and stir until the texture is thick. Set Aside."
    },
    {
      "position": 7,
      "text": "Heat a skillet and pour-in butter."
    },
    {
      "position": 8,
      "text": "Saut\u00e9 the chicken for 3 to 5 minutes or until the color turns light brown. Add thyme at the middle of the cooking time."
    },
    {
      "position": 9,
      "text": "Pour-in the Alfredo sauce (this is the sauce that you made by following steps 2 to 6) and stir. Cook for a minute then turn off the heat and set aside."
    },
    {
      "position": 10,
      "text": "Arrange the rotini in a serving plate and top with the Alfredo sauce and chicken."
    },
    {
      "position": 11,
      "text": "Serve. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
