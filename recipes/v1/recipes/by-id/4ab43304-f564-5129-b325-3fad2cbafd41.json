  "slug": "chopped-tomato-onion-bagoong-isda",
  "name": "Chopped Tomato and Onion with Bagoong Isda",
  "recipe_type": "side",
  "brief_description": "Have you had a side dish composed of chopped tomato, onion, and bagoong isda? Actually, this can also be both a side dish and a main dish at the same time,",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine tomato, onion, and bagoong in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Add lemon or calamansi and ground black pepper. Continue to mix until well blended."
    },
    {
      "position": 3,
      "text": "Top with chopped scallions."
    },
    {
      "position": 4,
      "text": "Serve with fried fish or bagnet. Share and enjoy!"
    }
  ],
  "servings": 2,
