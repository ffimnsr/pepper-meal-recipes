  "id": "d8a710fa-5ff8-539a-9ed2-ece366abecdc",
  "slug": "shared-recipe-tortang-talong-with-giniling",
  "name": "Shared Recipe: Tortang Talong with Giniling",
  "recipe_type": null,
  "brief_description": "This shared Tortang Talong with Giniling recipe is a winner. Learn how to cook eggplant omelet with ground beef with this recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Grill the eggplants until the color of the skin is black."
    },
    {
      "position": 2,
      "text": "Let the eggplants cool for a while and peel off the skin."
    },
    {
      "position": 3,
      "text": "Crack the eggs (2 or 3 at a time) and place in a bowl.Add salt and beat the eggs."
    },
    {
      "position": 4,
      "text": "Place the eggplants on a flat surface and flatten carefully using a fork (avoid to peek holes in the eggplants)."
    },
    {
      "position": 5,
      "text": "In a pan, add and heat cooking oil (2 tbsp) and saut\u00e9 garlic cloves, onion and tomato."
    },
    {
      "position": 6,
      "text": "Add ground beef and let it simmer on medium heat until its done. Stir occasionally. Set aside."
    },
    {
      "position": 7,
      "text": "Heat a pan (use one where the eggplant exactly fits in it, see picture) and pour cooking oil (2Tbsp)."
    },
    {
      "position": 8,
      "text": "On medium heat, put 1/4 of the beaten eggs in the pan and then put the flatten eggplant on top."
    },
    {
      "position": 9,
      "text": "Add the ground beef on top, flatten so its compact and pour the rest of the beaten eggs."
    },
    {
      "position": 10,
      "text": "After 2-3 mins, using a spatula on one hand and on the other hand, holding the end of the eggplant, flip the eggplant."
    },
    {
      "position": 11,
      "text": "Let it fry for 2-3 mins."
    },
    {
      "position": 12,
      "text": "Put on a plate and serve hot."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
