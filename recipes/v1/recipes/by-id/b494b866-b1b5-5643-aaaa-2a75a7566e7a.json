  "schema_version": 1,
  "id": "b494b866-b1b5-5643-aaaa-2a75a7566e7a",
  "slug": "butter-garlic-shrimp-pasta",
  "name": "Butter Garlic Shrimp Pasta",
  "recipe_type": "main",
  "brief_description": "A rich and creamy fettuccine dish with saut\u00e9ed shrimp, butter, garlic, and a tomato-based cheese sauce, finished with fresh basil. Perfect for seafood and pasta lovers.",
  "cuisine": "Fusion",
  "instructions": [
    {
      "position": 1,
      "text": "Combine shrimp with salt, ground black pepper, lemon juice, and olive oil for the marinade. Mix well and marinate for at least 5 minutes."
    },
    {
      "position": 2,
      "text": "Heat 2 tablespoons olive oil in a pan over medium high heat. Saut\u00e9 the marinated shrimp until it turns orange, 1 to 2 minutes per side. Set aside."
    },
    {
      "position": 3,
      "text": "Boil 1 quart of water and add 1 teaspoon salt. Add the fettuccine and cook until al dente according to package instructions. Reserve a little pasta water and set pasta aside."
    },
    {
      "position": 4,
      "text": "Melt the butter in a clean pan and add 2 tablespoons olive oil. Saut\u00e9 garlic, chili flakes, and grape tomatoes until the tomatoes soften."
    },
    {
      "position": 5,
      "text": "Add tomato paste and pour in chicken broth. Simmer for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add cream cheese and stir until fully melted and smooth."
    },
    {
      "position": 7,
      "text": "Stir in Italian seasoning and return the saut\u00e9ed shrimp to the pan. Simmer for 3 minutes."
    },
    {
      "position": 8,
      "text": "Stir in sharp cheddar, Parmesan, and basil leaves. If the sauce is too thick, add a splash of reserved pasta water to loosen it."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper to taste and stir to combine."
    },
    {
      "position": 10,
      "text": "Add the cooked fettuccine and toss until the pasta is well coated with the sauce."
    },
    {
      "position": 11,
      "text": "Transfer to a pasta bowl and serve warm. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
