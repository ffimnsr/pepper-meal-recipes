{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "fb501431-3963-55ef-869a-8efde873e6a0",
  "slug": "chicken-liver-and-gizzard-adobo",
  "name": "Chicken Liver and Gizzard Adobo",
  "recipe_type": "main",
  "brief_description": "Indulge in Chicken Liver and Gizzard Adobo, a Filipino favorite with tender chicken parts simmered in a savory, tangy adobo sauce. Just make sure to prepare bowls of white rice before digging in!",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil the chicken gizzard in 4 cups of water (covered) for 60 to 90 minutes. Drain the water and set aside."
    },
    {
      "position": 2,
      "text": "Sprinkle 1 teaspoon garlic powder and 1/4 teaspoon salt all over the chicken liver. Let it stay for 10 minutes."
    },
    {
      "position": 3,
      "text": "Heat the cooking oil in a frying pan."
    },
    {
      "position": 4,
      "text": "Dredge the chicken liver in all-purpose flour. Pan fry for 2 minutes per side. Remove the pan-fried chicken liver. Set aside."
    },
    {
      "position": 5,
      "text": "On the same pan using the remaining oil, add the garlic, Cook until the color turns light brown."
    },
    {
      "position": 6,
      "text": "Put-in the gizzard and pan-fried liver. Stir."
    },
    {
      "position": 7,
      "text": "Add the soy sauce and water. Let boil."
    },
    {
      "position": 8,
      "text": "Add the bay leaves and whole peppercorn. Cover and simmer for 15 to 20 minutes."
    },
    {
      "position": 9,
      "text": "Add the vinegar. Let the liquid re-boil. Stir and cook for 5 minutes."
    },
    {
      "position": 10,
      "text": "Turn the heat off. Transfer to a serving plate."
    },
    {
      "position": 11,
      "text": "Top with chopped green onions. Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
