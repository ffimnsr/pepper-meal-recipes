  "id": "107102cf-b847-5e3b-bd22-59e3e64ed195",
  "slug": "sweet-and-sour-tilapia",
  "name": "Sweet and Sour Tilapia",
  "recipe_type": "dessert",
  "brief_description": "Crispy Fried Tilapia cooked in a tasty sweet and sour sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Apply Knorr Liquid Seasoning all over the tilapia. Let it stand for 10 minutes so that the fish can absorb the flavor of the seasoning."
    },
    {
      "position": 2,
      "text": "Heat around 1 cup of cooking oil in a pan. Once the oil gets hot, fry the fish until the color turns golden brown. Flip to fry the opposite side. Remove from the pan. Place on a clean plate. Set aside."
    },
    {
      "position": 3,
      "text": "Make the sauce by heating 3 tablespoons of cooking oil in a cooking pot. Saute onion and garlic for 10 seconds. Add ginger. Saute for 12 seconds."
    },
    {
      "position": 4,
      "text": "Pour white vinegar and water. Let boil."
    },
    {
      "position": 5,
      "text": "Add tomato ketchup. Stir until it completely dilutes in the mixture."
    },
    {
      "position": 6,
      "text": "Add sugar. Stir until the sugar gets fully incorporated."
    },
    {
      "position": 7,
      "text": "Put carrots and bell peppers. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Combine cornstarch and 3 tablespoons water. Mix well. Pour into the cooking pot. Stir until sauce thickens."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper. Add a piece of tilapia and cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
