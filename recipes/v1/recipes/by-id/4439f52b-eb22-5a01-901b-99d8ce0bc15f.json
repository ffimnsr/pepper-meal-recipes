  "schema_version": 1,
  "id": "4439f52b-eb22-5a01-901b-99d8ce0bc15f",
  "slug": "rellenong-alimasag",
  "name": "Rellenong Alimasag Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for stuffed crab. It is known as Rellenong Alimasag or Relyenong Alimasag in Filipino.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat pan and pour-in 2 tablespoons of cooking oil."
    },
    {
      "position": 2,
      "text": "Saute onion and tomatoes."
    },
    {
      "position": 3,
      "text": "Add potato and carrot. Cook for 3 to 5 minutes"
    },
    {
      "position": 4,
      "text": "Put-in the long green chili and crab meat (you may include the juice of the crab for additional flavor). Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add parsley, garlic powder, salt, and ground black pepper. Stir. Turn off the heat and place in a large bowl."
    },
    {
      "position": 6,
      "text": "Once the temperature cools down, combine the cooked mixture with breadcrumbs and eggs. Mix well."
    },
    {
      "position": 7,
      "text": "Stuff each crab shell with the mixture."
    },
    {
      "position": 8,
      "text": "Heat a pan and pour-in 1 cup of oil."
    },
    {
      "position": 9,
      "text": "When the oil becomes hot, fry the stuffed crab shells. The part with the stuffing should be facing up. Gently scoop the hot oil using a spoon and pour the oil on the stuffings. This will slowly cook the stuffing."
    },
    {
      "position": 10,
      "text": "Flip the crab shell and fry the side with stuffing in medium heat for about 3 to 5 minutes."
    },
    {
      "position": 11,
      "text": "Turn off the heat and transfer to a serving plate."
    },
    {
      "position": 12,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
