  "id": "d1700426-205c-52ad-8025-2225a10c70da",
  "slug": "oxtail-soup-recipe_knr_bc",
  "name": "Oxtail Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for oxtail soup.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine water and oxtail. Let boil. Continue to cook in medium heat for 15 minutes. Discard the water."
    },
    {
      "position": 2,
      "text": "Pour 10 to 12 cups water into the cooking pot. Add the semi-boiled oxtail, onion, ginger, and star anise. Let boil."
    },
    {
      "position": 3,
      "text": "Add Knorr beef cube. Stir. Continue to cook between low to medium heat until the oxtail becomes tender. Note: this usually takes between 2 to 3 hours. You can use a pressure cooker to make the cooking time faster. If using a pressure cooker, 35 minutes should be enough."
    },
    {
      "position": 4,
      "text": "Add the Shiitake mushroom. Cook for 15 minutes."
    },
    {
      "position": 5,
      "text": "Season with ground black pepper and salt. Stir."
    },
    {
      "position": 6,
      "text": "Add scallions and bok choy. Stir."
    },
    {
      "position": 7,
      "text": "Turn the heat off. Cover and let it stay for 5 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 10,
