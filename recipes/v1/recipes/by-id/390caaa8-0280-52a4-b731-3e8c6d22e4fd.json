  "id": "390caaa8-0280-52a4-b731-3e8c6d22e4fd",
  "slug": "kielbasa-fried-rice",
  "name": "Kielbasa Fried Rice",
  "recipe_type": null,
  "brief_description": "Kielbasa Fried Rice is a type of fried rice with Kielbasa sausage. It is a delicious dish that is very easy to prepare. Although I used Kielbasa, I tried to make this taste more Asian (fried rice is associated with Asian Cuisine anyway \ud83d\ude42 ) by adding soy sauce and green onions. It will be better\u2026",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a pan."
    },
    {
      "position": 2,
      "text": "Add the Kielbasa sausage. Cook in low to medium heat for 1 minute per side."
    },
    {
      "position": 3,
      "text": "Push the Kielbasa on the side. Crack the eggs and stir. Continue to cook until the eggs are formed."
    },
    {
      "position": 4,
      "text": "Put the rice in the pan. Gently fold until all the ingredients are well blended."
    },
    {
      "position": 5,
      "text": "Add the green peas, garlic powder and soy sauce. Stir fry until blended."
    },
    {
      "position": 6,
      "text": "Put the chopped green onions on top. Stir fry for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 10,
