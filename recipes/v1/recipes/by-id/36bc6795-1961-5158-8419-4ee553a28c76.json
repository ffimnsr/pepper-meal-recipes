  "id": "36bc6795-1961-5158-8419-4ee553a28c76",
  "slug": "pinoy-chicken-noodle-soup",
  "name": "Pinoy Chicken Noodle Soup",
  "recipe_type": "soup",
  "brief_description": "Pinoy Chicken Noodle Soup is something that I make when the weather starts getting chilly. I like it because it is delicious and keeps me feel warm and cozy. I also like it because I get to enjoy two of my favorite noodle dishes in just one dish since this is somewhat a crossover between chicken mami and lomi.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, saute the garlic and onion. Continue until the onion gets soft."
    },
    {
      "position": 3,
      "text": "Add the chicken, cook for 3 to 5 minutes or until it turns light brown."
    },
    {
      "position": 4,
      "text": "Add the chicken liver. Stir and cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in water and chicken broth. Let boil. Cover and simmer for 30 minutes."
    },
    {
      "position": 6,
      "text": "Add the bacon, carrots, and cabbage. Stir and cook for 5 to 8 minutes."
    },
    {
      "position": 7,
      "text": "Pour-in the fish sauce. Stir."
    },
    {
      "position": 8,
      "text": "Stir-in the noodles. Cook for 5 to 7 minutes. Add chicken broth or water if needed."
    },
    {
      "position": 9,
      "text": "Add the green onions."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
