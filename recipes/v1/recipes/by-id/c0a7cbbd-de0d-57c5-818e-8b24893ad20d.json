  "id": "c0a7cbbd-de0d-57c5-818e-8b24893ad20d",
  "slug": "huevos-rancheros",
  "name": "Huevos Rancheros",
  "recipe_type": "breakfast",
  "brief_description": "Huevos Rancheros is a simple breakfast dish made from hot salsa, egg, and flour tortilla. This dish tastes fresh and delicious.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the salsa by heating 2 tablespoons of cooking oil in a pan. Saute the onion until it becomes soft. Add the diced tomatoes, add the chipotle pepper, and banana pepper. Cook for 3 to 5 minutes. Add salt and pepper to taste."
    },
    {
      "position": 2,
      "text": "Cook the eggs. I prefer either sunny side up or ever easy. Set Aside."
    },
    {
      "position": 3,
      "text": "Heat a clean frying pan. Once the pan starts to heat-up, lay a corn tortilla flat over the pan and continue to heat up (using medium heat) for 2 minutes per side."
    },
    {
      "position": 4,
      "text": "Arrange the warm tortillas on a serving plate. Top with fried egg and salsa. Garnish with cilantro."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 3,
