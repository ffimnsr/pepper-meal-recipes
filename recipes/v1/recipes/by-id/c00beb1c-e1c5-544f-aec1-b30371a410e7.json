  "id": "c00beb1c-e1c5-544f-aec1-b30371a410e7",
  "slug": "how-to-cook-tonkatsu",
  "name": "Pork Loin Tonkatsu Recipe",
  "recipe_type": null,
  "brief_description": "This tonkatsu recipe is quick and simple. It is a popular lunch dish in Japan and is often served on top of rice",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pound the meat to flatten a little then rub salt and ground pepper all over. Allow to sit for at least 30 minutes to absorb the flavor."
    },
    {
      "position": 2,
      "text": "Dredge the loin chops in flour then dip in the beaten egg mixture."
    },
    {
      "position": 3,
      "text": "Place the chops in a container with bread crumbs and shake until the sides of the loin chops are coated."
    },
    {
      "position": 4,
      "text": "Heat a skillet or frying pan then pour-in cooking oil."
    },
    {
      "position": 5,
      "text": "Deep fry for 5 to 7 minutes. Do not cook in high heat as it will burn the bread crumbs before the meat is done."
    },
    {
      "position": 6,
      "text": "Turn-off heat and transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Make the sauce by heating a saucepan and combining all the sauce ingredients. Simmer for 5 minutes or until the texture of the sauce thickens."
    },
    {
      "position": 8,
      "text": "Top the fried loin chops with sauce and serve with shredded cabbage."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
