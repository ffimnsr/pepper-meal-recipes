  "slug": "ginisang-bagoong-guisado",
  "name": "Bagoong Guisado Recipe",
  "recipe_type": null,
  "brief_description": "Bagoong Guisado is the Filipino term for Sauteed Shrimp Paste.This quick and recipe will help you make the best version around.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan and sear the pork until the oil comes out."
    },
    {
      "position": 2,
      "text": "Add garlic, onion, and tomato then saut\u00e9 for 3 minutes."
    },
    {
      "position": 3,
      "text": "Put the raw shrimp paste, sugar, and vinegar then stir. Cover and cook in low heat for 10 to 15 minutes. Stir once in awhile."
    },
    {
      "position": 4,
      "text": "Transfer to a serving bowl and serve."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 12,
