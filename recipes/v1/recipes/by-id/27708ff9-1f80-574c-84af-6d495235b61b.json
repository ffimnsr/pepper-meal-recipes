  "id": "27708ff9-1f80-574c-84af-6d495235b61b",
  "slug": "sweet-and-sour-red-snapper",
  "name": "Sweet and Sour Red Snapper",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for sweet and sour red snapper",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rubs salt all over the fish including the cavity. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Pan-fry both sides of the red snapper until it turns golden brown. Remove the fish from the pan, set aside."
    },
    {
      "position": 3,
      "text": "Prepare the sweet and sour sauce by boiling pineapple juice. Add sugar. Stir until well blended."
    },
    {
      "position": 4,
      "text": "Add ketchup and vinegar. Let the liquid re-boil."
    },
    {
      "position": 5,
      "text": "Stir-in the garlic powder and then add the bell peppers and onion. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour the cornstarch and water mixture. Stir. Cook until the texture reaches desired thickness."
    },
    {
      "position": 7,
      "text": "Arrange the fried fish on a serving plate. Pour sweet and sour sauce on top."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
