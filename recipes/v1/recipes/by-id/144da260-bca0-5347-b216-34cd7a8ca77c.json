  "id": "144da260-bca0-5347-b216-34cd7a8ca77c",
  "slug": "binatog-bualaw-corn-recipe",
  "name": "Binatog Recipe (Boiled white corn kernels with Shredded Coconut)",
  "recipe_type": "snack",
  "brief_description": "Binatog or boiled white corn kernels is a popular Filipino snack and street food. This is made by soaking mature white corn in water and salt until puffed.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in the canned hominy (include the liquid)."
    },
    {
      "position": 2,
      "text": "Add 1 cup of water and bring to a boil."
    },
    {
      "position": 3,
      "text": "Simmer for 12 to 15 minutes."
    },
    {
      "position": 4,
      "text": "Drain the water and place the boiled hominy in a serving plate."
    },
    {
      "position": 5,
      "text": "Top with sugar (or salt depending on your preference) and grated coconut."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!!!!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
