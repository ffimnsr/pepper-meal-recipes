{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "da8ab3d9-a811-54db-84fb-ff08c46cd02c",
  "slug": "creamy-garlic-parmesan-chicken-with-mushrooms",
  "name": "Creamy Garlic Parmesan Chicken with Mushrooms",
  "recipe_type": "main",
  "brief_description": "Low-fat chicken breast slices cooked in a creamy garlic cheese sauce with fresh mushrooms.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Slice the boneless chicken breast into thin pieces. Brush Knorr savorRich chicken seasoning all over the chicken. Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Fry the chicken for 4 1.2 minutes per side. Transfer the chicken to a plate afterwards. Set aside."
    },
    {
      "position": 3,
      "text": "Start to make the creamy sauce by melting butter on the same pan the chicken was cooked. Saute mushrooms for 2 minutes. Add garlic and continue to cook for 30 seconds."
    },
    {
      "position": 4,
      "text": "Gradually add all-purpose flour. Continuously stir until lumps form."
    },
    {
      "position": 5,
      "text": "Slowly pour around \u00be of the total milk amount. Stir until the cream sauce becomes smooth. Add Parmesan cheese. Stir."
    },
    {
      "position": 6,
      "text": "Pour remaining milk while stirring. Season with ground black pepper."
    },
    {
      "position": 7,
      "text": "Put the chicken back into the pan. Cover and cook between low to medium heat for 3 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with your favorite side."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
