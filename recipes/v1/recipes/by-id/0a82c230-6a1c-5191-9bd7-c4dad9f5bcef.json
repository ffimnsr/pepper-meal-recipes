  "id": "0a82c230-6a1c-5191-9bd7-c4dad9f5bcef",
  "slug": "arroz-valenciana",
  "name": "Arroz ala Valenciana",
  "recipe_type": "main",
  "brief_description": "Paella Valenciana recipe",
  "cuisine": "Filipino Spanish",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the glutinous rice and jasmine rice. Wash with water twice and then drain. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the olive oil in a paellera or wide pan."
    },
    {
      "position": 3,
      "text": "Saute the garlic, onion, and tomato until the onion and tomato becomes soft."
    },
    {
      "position": 4,
      "text": "Put-in the chopped chicken. Cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the chorizo de bilbao. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add-in the salt, pepper, saffron, and paprika. Stir."
    },
    {
      "position": 7,
      "text": "Pour-in the chicken broth and coconut milk. Stir and let boil."
    },
    {
      "position": 8,
      "text": "Add-in the washed rice. Stir. Let boil."
    },
    {
      "position": 9,
      "text": "Add the tomato paste. Stir. Cover and simmer for 5 minutes."
    },
    {
      "position": 10,
      "text": "Put-in the raisins, and green peas. Cover and simmer for 8 minutes."
    },
    {
      "position": 11,
      "text": "Add-in the red bell pepper. Continue to simmer until the rice is fully cooked."
    },
    {
      "position": 12,
      "text": "Garnish with sliced boiled egg. Serve."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
