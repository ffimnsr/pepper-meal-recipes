  "id": "99fcc5bd-40e7-50e4-bfdb-ce108c02f165",
  "slug": "easy-adobong-pusit",
  "name": "Easy Adobong Pusit Recipe",
  "recipe_type": "main",
  "brief_description": "Fresh squid cooked in soy sauce and vinegar.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine squid, salt, soy sauce, and vinegar in a bowl. Mix well. Marinate for 12 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot. Saute garlic until it starts to turn light brown. Add onion and tomato. Continue to saute until onion and tomato completely softens."
    },
    {
      "position": 3,
      "text": "Pour the marinade liquid into the pot. Add ground black pepper. Let boil and then cook for 3 minute using low to medium heat. Make sure to cover the pot."
    },
    {
      "position": 4,
      "text": "Add the squid. Let the sauce boil. Cover the pot and continue cooking for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add sugar. Stir. Remove the squid from the pot and then arrange in a bowl. Continue cooking the sauce until it reduces to half."
    },
    {
      "position": 6,
      "text": "Pour the sauce over the squid. Serve. Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
