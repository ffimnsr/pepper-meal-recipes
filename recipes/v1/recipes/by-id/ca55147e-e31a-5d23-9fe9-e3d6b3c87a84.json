  "id": "ca55147e-e31a-5d23-9fe9-e3d6b3c87a84",
  "slug": "red-wine-beef-stew",
  "name": "Red Wine Beef Stew",
  "recipe_type": "main",
  "brief_description": "Delicious beef stew with red wine, pearl onion, and carrots.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sear bacon in a cooking pot until fat gets extracted."
    },
    {
      "position": 2,
      "text": "Add onion. Cook for 25 seconds while stirring."
    },
    {
      "position": 3,
      "text": "Add minced garlic. Saut\u00e9 for 30 seconds."
    },
    {
      "position": 4,
      "text": "Put the beef into the pot and then continue to cook until the color turns light brown."
    },
    {
      "position": 5,
      "text": "Add tomato paste and then stir."
    },
    {
      "position": 6,
      "text": "Pour red wine and beef broth into the pan. Stir and let boil."
    },
    {
      "position": 7,
      "text": "Add carrot and thyme. Cover the pot and continue to cook between low to medium heat for 2 to 3 hours or until beef gets tender."
    },
    {
      "position": 8,
      "text": "Put the pearl onions into the pot. Cook for 5 minutes."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 5,
