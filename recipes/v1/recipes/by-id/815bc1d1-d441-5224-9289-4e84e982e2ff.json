  "id": "815bc1d1-d441-5224-9289-4e84e982e2ff",
  "slug": "filipino-food-tsampurado-champorado-champurado-chocolate-rice-porridge-recipe",
  "name": "Champorado Recipe",
  "recipe_type": "dessert",
  "brief_description": "Champorado is a sweet chocolate rice porridge that uses sweet glutinous rice (locally known as malagkit) and cocoa powder as main ingredients. A more traditional approach would be using tableya (pure cocoa blocks) instead of cocoa powder.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour 2 1/2 cups of water in a pot and bring to a boil"
    },
    {
      "position": 2,
      "text": "Put-in the glutinous rice and allow water to re-boil for a few minutes"
    },
    {
      "position": 3,
      "text": "Dilute the cocoa powder in 1 cup warm water then pour-in the pot. Stir continuously"
    },
    {
      "position": 4,
      "text": "Once the glutinous rice is cooked (about 12 to 18 minutes of cooking with constant stirring), add the sugar and cook for another 5 minutes or until the texture becomes thick."
    },
    {
      "position": 5,
      "text": "Remove from the pot and place in a serving bowl."
    },
    {
      "position": 6,
      "text": "Serve hot with a swirl of condensed milk on top."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
