  "id": "38c6254d-ec89-56e7-91eb-cee6996ccbd0",
  "slug": "paksiw-na-pata-with-pineapple",
  "name": "Paksiw na Pata with Pineapple",
  "recipe_type": null,
  "brief_description": "Paksiw na Pata with Pineapple refers to pork hocks cooked in soy sauce and vinegar with banana blossoms and pineapple chunks.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour 6 cups water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add the pork hocks. Continue to boil for 30 minutes. Discard the water used for boiling and then place the boiled pork hock in a plate. Set aside."
    },
    {
      "position": 3,
      "text": "Heat the oil in a clean cooking pot. Once the oil gets hot, saut\u00e9 the garlic until it turns light brown."
    },
    {
      "position": 4,
      "text": "Put the boiled pork hock in the cooking pot. Stir and then add soy sauce, pineapple chunks including the juice, and remaining 2 cups water. Let boil."
    },
    {
      "position": 5,
      "text": "Add bay leaves, peppercorn, and vinegar. Let boil. Continue to cook for 15 minutes."
    },
    {
      "position": 6,
      "text": "Add the beef cube and brown sugar (or panutsa). Stir."
    },
    {
      "position": 7,
      "text": "Add the banana blossom. Let the liquid reboil and then stir. Continue to cook until the pork becomes tender. Note that you may add more water if you need extra time to tenderize the pork."
    },
    {
      "position": 8,
      "text": "Add salt to taste."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
