  "slug": "filipino-street-food-inihaw-bituka-grilled-isaw-recipe",
  "name": "Grilled Isaw (Intestine) Recipe",
  "recipe_type": null,
  "brief_description": "Grilled Isaw or Inihaw na Bituka ng Baboy is pig's large intestine boiled until tender then grilled. This is probably the most sought and most popular street food in the Philippines.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water in a cooking pot and bring to a boil."
    },
    {
      "position": 2,
      "text": "Put-in the salt, whole pepper corn, and dried bay leaves"
    },
    {
      "position": 3,
      "text": "Add the large intestines then simmer for a few minutes"
    },
    {
      "position": 4,
      "text": "Add vinegar then simmer until the intestines are tender (about 30 minutes). Set aside until the temperature goes down."
    },
    {
      "position": 5,
      "text": "Cut the intestines crosswise (about 1 inch in length)"
    },
    {
      "position": 6,
      "text": "Skewer the intestine (about 3 to 4 pieces per skewer)"
    },
    {
      "position": 7,
      "text": "Grill the intestine while basting with the mixture of cooking oil, banana catsup, and soy sauce"
    },
    {
      "position": 8,
      "text": "Serve with vinegar and chili dip"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 20,
