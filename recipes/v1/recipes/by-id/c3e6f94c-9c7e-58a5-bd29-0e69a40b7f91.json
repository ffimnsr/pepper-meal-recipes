  "slug": "baked-garlic-rosemary-chicken-recipe",
  "name": "Baked Garlic Rosemary Chicken Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Baked Garlic Rosemary Chicken",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil the potatoes for 8 minutes. Remove from the pot and let cool."
    },
    {
      "position": 2,
      "text": "Slice the potatoes into quarters. Sprinkle some garlic powder and then set aside."
    },
    {
      "position": 3,
      "text": "In a bowl, combine garlic, rosemary, 1 tablespoon olive oil, juice of 2 lemons, salt, and ground black pepper. Mix well."
    },
    {
      "position": 4,
      "text": "Combine the rosemary mixture with the chicken. Make sure that the chicken is coated with the mixture equally. Marinate for 30 minutes."
    },
    {
      "position": 5,
      "text": "Heat a frying pan and then pour-in remaining olive oil."
    },
    {
      "position": 6,
      "text": "Pan-fry each side of the chicken for 4 to 6 minutes."
    },
    {
      "position": 7,
      "text": "Preheat oven to 425 degrees Fahrenheit."
    },
    {
      "position": 8,
      "text": "Arrange chicken and potatoes in an oven-proof tray."
    },
    {
      "position": 9,
      "text": "Bake for 30 to 40 minutes."
    },
    {
      "position": 10,
      "text": "Remove from the oven, and then serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
