  "id": "1b88037b-2f1b-5330-8758-845f453b0144",
  "slug": "sinanglay-na-tilapia",
  "name": "Sinanglay na Tilapia Recipe",
  "recipe_type": "main",
  "brief_description": "Sinanglay na Tilapia is a Filipino Recipe that involves Tilapia being cooked in coconut milk. This is best eaten with steamed rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a bowl, combine garlic, onion, tomatoes, and ginger then mix."
    },
    {
      "position": 2,
      "text": "Stuff the tilapia with the garlic, onion, and ginger mixture."
    },
    {
      "position": 3,
      "text": "Wrap the bok choy around the tilapia. I use 2 bok choy leaves to ensure that the entire fish is wrapped."
    },
    {
      "position": 4,
      "text": "Secure the bok choy by tying a kitchen twine around the tilapia. (this step is optional)"
    },
    {
      "position": 5,
      "text": "Arrange the wrapped tilapia in a wide cooking pan then pour-in coconut milk and water. Sprinkle salt, cover, and turn on heat."
    },
    {
      "position": 6,
      "text": "Cook the fish in medium heat for 20 minutes."
    },
    {
      "position": 7,
      "text": "Turn off heat. Remove the cooking twine and transfer the fish to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
