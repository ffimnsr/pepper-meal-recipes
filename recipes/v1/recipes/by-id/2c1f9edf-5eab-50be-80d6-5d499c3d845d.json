  "id": "2c1f9edf-5eab-50be-80d6-5d499c3d845d",
  "slug": "adobong-manok-sa-buko",
  "name": "Adobong Manok sa Buko",
  "recipe_type": "main",
  "brief_description": "Chicken adobo cooked in young coconut water.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a bowl, combine chicken, soy sauce and vinegar. Marinate for at least 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Saute onion and garlic."
    },
    {
      "position": 3,
      "text": "Once onion softens, add marinated chicken. Saute until light brown."
    },
    {
      "position": 4,
      "text": "Pour remaining marinade, and then add whole peppercorn, dried bay leaves, and buko juice. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Chicken Cube. Stir. Adjust heat to between low to medium and continue to cook for 30 minutes."
    },
    {
      "position": 6,
      "text": "Add green onions. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 30,
