  "id": "5459c63f-379e-5b0a-9cd7-c46ebc29c14e",
  "slug": "7up-chicken-asado",
  "name": "7Up Chicken Asado",
  "recipe_type": null,
  "brief_description": "This is a recipe for 7Up Chicken Asado.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place chicken on a plate or bowl. Pour soy sauce all over the chicken. Sprinkle crushed peppercorn and then rub all over the chicken."
    },
    {
      "position": 2,
      "text": "Insert onion and lemongrass into the cavity of the chicken. Let it stay for 10 minutes."
    },
    {
      "position": 3,
      "text": "Heat oil in a large cooking pot, and then saut\u00e9 onion and garlic until the onion becomes soft."
    },
    {
      "position": 4,
      "text": "Add the marinated chicken. Cook one side in medium heat for 3 minutes. Turn the chicken over and cook the opposite side for 3 minutes."
    },
    {
      "position": 5,
      "text": "Pour the remaining marinade and 1 liter of 7up (or any similar product). Let boil."
    },
    {
      "position": 6,
      "text": "Add star anise. Cover and cook between low to medium heat for 30 minutes."
    },
    {
      "position": 7,
      "text": "Turn the chicken over and continue to boil the opposite side for 12 minutes."
    },
    {
      "position": 8,
      "text": "Remove the chicken from the cooking pot. Slice in half and arrange on a serving plate."
    },
    {
      "position": 9,
      "text": "Continue to cook the sauce in the cooking pot until it reduces to half. Add garlic powder and onion powder. Stir"
    },
    {
      "position": 10,
      "text": "Filter the sauce using a kitchen sieve or strainer. Pour all over the chicken."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
