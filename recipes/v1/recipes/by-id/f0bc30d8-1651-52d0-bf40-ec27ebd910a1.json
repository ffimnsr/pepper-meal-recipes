  "id": "f0bc30d8-1651-52d0-bf40-ec27ebd910a1",
  "slug": "tortang-giniling-omelet-recipe",
  "name": "Tortang Giniling Recipe",
  "recipe_type": "breakfast",
  "brief_description": "Tortang Giniling or ground meat omelet is a quick and easy Filipino omelet recipe that you can prepare for breakfast or lunch.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a frying pan or wok and pour-in 2 tablespoons of cooking oil"
    },
    {
      "position": 2,
      "text": "When the oil is hot enough, saut\u00e9 the onion, garlic, and tomato."
    },
    {
      "position": 3,
      "text": "Add the ground meat and cook for 8 to 10 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the bell peppers and green peas. Cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add salt and pepper then stir to distribute. Transfer to a large bowl. Let it cool down."
    },
    {
      "position": 6,
      "text": "When the cooked ground meat reaches room temperature, beat the eggs and pour into the bowl same bowl. Stir to distribute all the ingredients."
    },
    {
      "position": 7,
      "text": "Heat a clean non-stick pan. Add the remaining cooking oil."
    },
    {
      "position": 8,
      "text": "Scoop 1/3 of the egg and pork mixture to the pan."
    },
    {
      "position": 9,
      "text": "Cook each side for 3 minutes or until you see that the eggs are fully cooked. Avoid overcooking the eggs. Do the same step until the mixture is consumed."
    },
    {
      "position": 10,
      "text": "Turn off the heat and transfer to a serving plate."
    },
    {
      "position": 11,
      "text": "Serve with banana ketchup. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
