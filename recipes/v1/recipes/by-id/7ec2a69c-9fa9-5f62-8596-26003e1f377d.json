  "id": "7ec2a69c-9fa9-5f62-8596-26003e1f377d",
  "slug": "macaroni-fruit-salad",
  "name": "Macaroni Fruit Salad",
  "recipe_type": "salad",
  "brief_description": "Sweet Macaroni Salad with Fruit Cocktail and Cheese.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook macaroni according to package instructions. Discard water and arranged cooked macaroni in a mixing bowl. Set aside."
    },
    {
      "position": 2,
      "text": "Prepare the salad dressing by combining all the dressing ingredients in a bowl, including Lady\u2019s Choice Mayonnaise. Mix until the texture smoothens. Set aside."
    },
    {
      "position": 3,
      "text": "Combine macaroni, fruit cocktail, kaong, and cheese. Gently toss."
    },
    {
      "position": 4,
      "text": "Pour the dressing mixture into the bowl. Toss until all ingredients are well bleneded."
    },
    {
      "position": 5,
      "text": "Cover the bowl. Refrigerate for at least 1 hour."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve for dessert. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
