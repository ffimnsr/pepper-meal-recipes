  "id": "1ac80b59-39c4-5c6e-bf6a-688179438c2a",
  "slug": "ginataang-monggo-filipino-dessert",
  "name": "Ginataang Monggo Recipe",
  "recipe_type": "dessert",
  "brief_description": "Ginataang Munggo or Ginataang Monggo is a simple Filipino dessert dish wherein toasted Mung beans and sticky rice are cooked in coconut milk.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan and put-in the Mung beans."
    },
    {
      "position": 2,
      "text": "Toast the Mung beans until brown."
    },
    {
      "position": 3,
      "text": "Turn-off heat and let the mung beans cool down."
    },
    {
      "position": 4,
      "text": "Crack the toasted mung beans using a mortar and pestle (almires). Set aside."
    },
    {
      "position": 5,
      "text": "Heat a cooking pot and pour-in coconut milk. Let boil."
    },
    {
      "position": 6,
      "text": "Add the sticky rice and Mung beans then stir. Cook in low heat for 15 to 20 minutes while stirring once in a while, or until the coconut milk is almost absorbed."
    },
    {
      "position": 7,
      "text": "Add sugar then stir."
    },
    {
      "position": 8,
      "text": "Turn off heat and transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve! You may serve this either hot or cold. I like having this cold with some extra coconut milk on top."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 15,
