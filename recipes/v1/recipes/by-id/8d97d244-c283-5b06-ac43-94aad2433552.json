  "slug": "sauteed-napa-cabbage-with-ground-pork",
  "name": "Saut\u00e9ed Napa Cabbage with Ground Pork",
  "recipe_type": "main",
  "brief_description": "A quick and easy dinner idea during an ordinary day can be Saut\u00e9ed Napa Cabbage with Ground Pork. This simple recipe can help you make one.",
  "cuisine": "Flipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan"
    },
    {
      "position": 2,
      "text": "Once the oil is hot, saut\u00e9 the garlic and onion"
    },
    {
      "position": 3,
      "text": "Add the diced tomatoes. Stir and cook until the liquid evaporates"
    },
    {
      "position": 4,
      "text": "Put-in the ground pork. Cook for 8 to 12 minutes."
    },
    {
      "position": 5,
      "text": "Add the cabbage. Stir and cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
