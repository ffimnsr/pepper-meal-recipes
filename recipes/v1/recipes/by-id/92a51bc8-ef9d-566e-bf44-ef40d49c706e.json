  "id": "92a51bc8-ef9d-566e-bf44-ef40d49c706e",
  "slug": "pork-kare-kare-recipe_knr_pc",
  "name": "Pork Kare Kare Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pork Kare Kare",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine 1/2 cup warm water and atsuete. Soak for 10 minutes.Extract the color from the seeds by stirring using a spoon. Filter the seeds out using a kitchen strainer, set the atsuete water aside, we will use it later."
    },
    {
      "position": 2,
      "text": "Boil 2 quarts water in a cooking pot. Add pata. Cover and continue to boil in medium heat for 20 minutes."
    },
    {
      "position": 3,
      "text": "Remove the boiled pata from the pot. Throw away the water used."
    },
    {
      "position": 4,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 5,
      "text": "Saute garlic and onion once the oil is hot. Cook until onion starts to soften."
    },
    {
      "position": 6,
      "text": "Add boiled pork hocks (pata). Saute for 2 minutes."
    },
    {
      "position": 7,
      "text": "Pour 1 1/2 quart water. Let boil. Cover the pot and continue to cook between low to medium heat for 60 minutes or until the pata becomes tender. Add more water if needed."
    },
    {
      "position": 8,
      "text": "Add Knorr Pork Cube. Stir."
    },
    {
      "position": 9,
      "text": "Add peanut butter into the pot and pour atsuete water. Stir. Continue to cook in medium heat for 5 to 8 minutes."
    },
    {
      "position": 10,
      "text": "Combine 1/2 cup water with cornstarch. Stir until cornstarch completely dissolves. Pour mixture into the pot. Stir and continue to cook for 5 minutes or until the sauce thickens a bit."
    },
    {
      "position": 11,
      "text": "Season with ground black pepper and salt."
    },
    {
      "position": 12,
      "text": "Add sitaw and talong. Cover and cook for 5 minutes."
    },
    {
      "position": 13,
      "text": "Add bok choy. Cook for 2 minutes."
    },
    {
      "position": 14,
      "text": "Tranfer to a serving bowl. Serve with bagoong alamang. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 80,
