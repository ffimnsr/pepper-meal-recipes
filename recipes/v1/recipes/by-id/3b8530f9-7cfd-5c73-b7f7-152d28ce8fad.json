  "id": "3b8530f9-7cfd-5c73-b7f7-152d28ce8fad",
  "slug": "seafood-curry",
  "name": "Seafood Curry",
  "recipe_type": "main",
  "brief_description": "Shrimp, mussel, and squid, curried with coconut milk with a hint of spice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Add onion. Cook for 20 seconds. Put the garlic and ginger. Continue cooking until onion softens."
    },
    {
      "position": 2,
      "text": "Pour coconut milk into the pot. Stir. Cover the pot and let boil."
    },
    {
      "position": 3,
      "text": "Add curry powder. Stir until it completely dilutes in coconut milk."
    },
    {
      "position": 4,
      "text": "Add Knorr Shrimp Cube. Stir. Put some cayenne pepper powder, if desired."
    },
    {
      "position": 5,
      "text": "Add bell peppers, mussels, and shrimp. Cook for 2 minutes. Stir until all ingredients are coated with coconut milk. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add squid. Cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Season with fish sauce (patis) and ground black pepper. Cook for 1 minute more."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with rice. Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
