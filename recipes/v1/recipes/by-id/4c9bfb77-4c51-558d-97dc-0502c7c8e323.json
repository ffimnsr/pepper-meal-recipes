  "id": "4c9bfb77-4c51-558d-97dc-0502c7c8e323",
  "slug": "easy-chicken-tacos",
  "name": "Easy Chicken Tacos",
  "recipe_type": null,
  "brief_description": "Are you craving for a delicious Tacos? You are in luck because we have this delicious easy chicken tacos recipe just for you.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a bowl, combine garlic powder, paprika, chili powder, salt, and pepper. Mix well."
    },
    {
      "position": 2,
      "text": "Rub the mixture over the chicken breasts. Let it stand for at least 1 hour."
    },
    {
      "position": 3,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 4,
      "text": "Arrange the chicken breast in a greased baking tray. Bake for 35 minutes."
    },
    {
      "position": 5,
      "text": "Remove the chicken from the oven. Let it rest and then slice."
    },
    {
      "position": 6,
      "text": "Cover the flour tortilla with paper towel. Microwave for 20 seconds"
    },
    {
      "position": 7,
      "text": "Arrange the chicken slices in the middle of the flour tortilla along with the guacamole and pico de gallo"
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
