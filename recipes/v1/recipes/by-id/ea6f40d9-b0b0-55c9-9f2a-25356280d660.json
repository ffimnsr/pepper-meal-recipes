  "id": "ea6f40d9-b0b0-55c9-9f2a-25356280d660",
  "slug": "beef-oyster-sauce-snow-peas",
  "name": "Beef in Oyster Sauce with Snow Peas",
  "recipe_type": "side",
  "brief_description": "Beef in Oyster Sauce with Snow Peas is a perfect dish for dinner. It can go well with rice or with sauteed vegetables on the side. I love to have this dish with a glass of Merlot.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the sirloin. Continue to saut\u00e9 until the beef turns medium brown."
    },
    {
      "position": 4,
      "text": "Add the oyster sauce, soy sauce, and water. Stir. Let boil."
    },
    {
      "position": 5,
      "text": "Cover and cook in low to medium heat for 30 to 45 minutes. You can add water if needed."
    },
    {
      "position": 6,
      "text": "Add salt and pepper to adjust the flavor. Stir."
    },
    {
      "position": 7,
      "text": "Put the snow peas in. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Pour-in the water with cornstarch. Stir and cook until the sauce thickens."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
