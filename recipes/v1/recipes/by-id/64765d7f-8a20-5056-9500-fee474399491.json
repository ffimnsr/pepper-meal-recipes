  "id": "64765d7f-8a20-5056-9500-fee474399491",
  "slug": "baked-chicken-and-vegetable-stir-fry-recipe",
  "name": "Baked Chicken and Vegetable Stir Fry",
  "recipe_type": null,
  "brief_description": "This Baked Chicken and Vegetable Stir Fry Recipe is the perfect guide to follow if you plan to cook an easy nice meal for lunch.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub the creole seasoning on the chicken breasts. Let stay for at least 30 minutes"
    },
    {
      "position": 2,
      "text": "Heat a pan, pour-in 1 tablespoon cooking oil."
    },
    {
      "position": 3,
      "text": "Sear the chicken breast for 1 to 2 minutes."
    },
    {
      "position": 4,
      "text": "Preheat oven to 350 degrees Fahrenheit. Bake the seared chicken breast for 12 to 15 minutes. Note: The thicker the cut, the longer the baking time."
    },
    {
      "position": 5,
      "text": "Remove the chicken from the oven and allow to rest. Set aside."
    },
    {
      "position": 6,
      "text": "On the same pan where the chicken was seared, pour remaining cooking oil."
    },
    {
      "position": 7,
      "text": "When the oil becomes hot, put-in the carrots, Italian beans, cauliflower, red kidney beans, and yellow squash. Sprinkle with garlic powder, salt, and pepper. Stir fry (in high heat) for 5 to 8 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Top with the sliced baked chicken."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
