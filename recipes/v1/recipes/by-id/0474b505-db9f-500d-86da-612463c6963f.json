  "id": "0474b505-db9f-500d-86da-612463c6963f",
  "slug": "sizzling-chicken-sisig",
  "name": "Sizzling Chicken Sisig",
  "recipe_type": "main",
  "brief_description": "Sizzling Chicken Sisig is the chicken version of the popular sisig dish. This recipe is quick and easy and can be low in fat",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan"
    },
    {
      "position": 2,
      "text": "When the oil becomes hot, saute the onion until it becomes soft"
    },
    {
      "position": 3,
      "text": "Add the chicken liver. Cook until the liver browns."
    },
    {
      "position": 4,
      "text": "Add-in the grilled chopped chicken breast. Stir and cook for 3 to 4 minutes."
    },
    {
      "position": 5,
      "text": "Put the garlic powder and soy sauce in. Stir."
    },
    {
      "position": 6,
      "text": "Sprinkle salt and pepper. Stir."
    },
    {
      "position": 7,
      "text": "Add the mayonnaise and then stir right away until all the ingredients are well incorporated."
    },
    {
      "position": 8,
      "text": "Heat the sizzling plate (cast iron pan)."
    },
    {
      "position": 9,
      "text": "Once the pan is hot, put the butter in and let it melt."
    },
    {
      "position": 10,
      "text": "Transfer the chicken sisig on the cast iron pan."
    },
    {
      "position": 11,
      "text": "Crack the egg and drop on top of the chicken."
    },
    {
      "position": 12,
      "text": "Arrange the green chili on top."
    },
    {
      "position": 13,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
