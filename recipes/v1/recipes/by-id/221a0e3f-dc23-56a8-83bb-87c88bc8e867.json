  "id": "221a0e3f-dc23-56a8-83bb-87c88bc8e867",
  "slug": "air-fryer-bangus-salpicao",
  "name": "Bangus Salpicao",
  "recipe_type": null,
  "brief_description": "Air-fried marinated milk fish topped with toasted garlic.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the boneless bangus into serving pieces."
    },
    {
      "position": 2,
      "text": "Prepare the marinade. Combine half of the garlic, ground black pepper, salt, olive oil, and Worcestershire sauce in a bowl. Mix well."
    },
    {
      "position": 3,
      "text": "Place the milksfish inside a resealable bag. Add the marinade. Make sure that the fish gets coated all throughout. Release the air from the bag and seal. Marinate for 30 minutes."
    },
    {
      "position": 4,
      "text": "Prepare the toasted garlic. Heat cooking oil in a sauce pan. Add remaining garlic. Cook until golden brown. Separate the garlic from the oil using a kitchen sieve. Set aside."
    },
    {
      "position": 5,
      "text": "Arrange the marinated milkfish in an air fryer. Air-fry for 8 minutes at 350F."
    },
    {
      "position": 6,
      "text": "Remove from the air fryer. Arrange on a serving plate. Top the milkfish with toasted garlic and chopped parsley. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 15,
