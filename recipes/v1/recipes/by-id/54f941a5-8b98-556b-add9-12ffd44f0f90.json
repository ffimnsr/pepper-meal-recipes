  "id": "54f941a5-8b98-556b-add9-12ffd44f0f90",
  "slug": "adobong-baboy-with-boiled-egg",
  "name": "Adobong Baboy with Boiled Egg",
  "recipe_type": "soup",
  "brief_description": "A milder Filipino pork adobo version made with pork shoulder, light soy sauce, and beef broth, then finished with boiled eggs.",
  "cuisine": "Asian Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the pork and light soy sauce in a bowl. Mix well, then marinate for 1 hour."
    },
    {
      "position": 2,
      "text": "Heat the oil in a pan. Add the garlic and cook until golden brown, then remove the garlic and set it aside."
    },
    {
      "position": 3,
      "text": "Add the marinated pork along with the remaining marinade. Cook until it turns brown, about 3 to 4 minutes."
    },
    {
      "position": 4,
      "text": "Pour in the water and beef broth. Let it boil."
    },
    {
      "position": 5,
      "text": "Add the peppercorn, bay leaves, and the toasted garlic. Cover and cook over low to medium heat for 30 to 40 minutes, until the pork is easy to chew. Add more water if the liquid starts to dry out."
    },
    {
      "position": 6,
      "text": "Pour in the vinegar. Let the liquid boil again, then stir."
    },
    {
      "position": 7,
      "text": "Add the sugar and the boiled eggs. Cook for 3 to 5 minutes, then add salt only if needed."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
  "rest_time_minutes": 60,
  "difficulty": "medium",
