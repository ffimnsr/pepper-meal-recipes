  "id": "a45f4b77-9f90-5132-9152-904d46b6736e",
  "slug": "aligue-fried-rice",
  "name": "Aligue Fried Rice",
  "recipe_type": "main",
  "brief_description": "Crab fat fried rice with shrimp, mussels, and squid.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the seafood by heating 2 tablespoons of oil in a pan. Put the shrimp and mussels. Make sure to remove the mussels from the shell. Continue cooking for 1 minute. Add half of the butter and let it melt. Put the squid into the pan and cook for 30 seconds. Season with salt and pepper. Set aside."
    },
    {
      "position": 2,
      "text": "On the same pan, heat remaining oil. Saut\u00e9 garlic until it starts to brown. Add onion. Saut\u00e9 until onion becomes tender."
    },
    {
      "position": 3,
      "text": "Put the remaining butter in the pan and let it melt. Add rice. Stir-fry for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add crab fat (taba ng talangka). Stir and fold until all ingredients are well blended."
    },
    {
      "position": 5,
      "text": "Squeeze lemon or calamansi and pour the sauce from the saut\u00e9ed seafood. Adjust heat to high and continue stir-frying for 1 to 2 minutes. Season with ground black pepper and salt."
    },
    {
      "position": 6,
      "text": "Arrange the aligue rice on a serving plate. Top with cooked seafood. Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 7,
  "rest_time_minutes": null,
  "difficulty": "medium",
