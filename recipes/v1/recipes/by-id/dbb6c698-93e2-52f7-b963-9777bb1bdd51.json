  "id": "dbb6c698-93e2-52f7-b963-9777bb1bdd51",
  "slug": "simple-pork-hamonado",
  "name": "Easy Pork Hamonado",
  "recipe_type": "dessert",
  "brief_description": "Pork Hamonado is a sweet pork dish that make use of pork shoulders, pineapple, sugar, and seasonings. Use this budget-friendly recipe anytme",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the pork and cook until the color turns light to medium brown."
    },
    {
      "position": 4,
      "text": "Add the pineapple. Stir and cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the soy sauce. Stir. Add the beef broth. Let boil. Simmer for 45 to 50 minutes. Add water if needed."
    },
    {
      "position": 6,
      "text": "Stir-in the sugar and add salt and pepper. Cook for 3 to 5 minutes more."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
