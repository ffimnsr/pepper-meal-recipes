  "id": "b7ff41f5-d5eb-5ac2-bcfb-42280cd040a9",
  "slug": "banana-chocolate-chip-muffin",
  "name": "Banana Chocolate Chip Muffin Recipe",
  "recipe_type": "dessert",
  "brief_description": "This Banana Chocolate Chip Muffin Recipe is quick and easy to prepare. This is best eaten with a cup of coffee or hot chocolate.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 400 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "In a mixing bowl, beat the egg and gradually add the sugar. Mix well."
    },
    {
      "position": 3,
      "text": "Mix-in the vegetable oil and mashed bananas."
    },
    {
      "position": 4,
      "text": "Add the pancake mix. Continue mixing until all the ingredients are distributed."
    },
    {
      "position": 5,
      "text": "Fold-in the chocolate chips."
    },
    {
      "position": 6,
      "text": "Place the paper cups on the muffin pan, and pour-in or place a scoop of banana mixture in each paper cup."
    },
    {
      "position": 7,
      "text": "Put the muffin pan inside the oven and bake for 14 to 17 minutes (or until it passes the toothpick test)."
    },
    {
      "position": 8,
      "text": "Remove the muffins from the oven and let cool by placing on top of a cooling rack."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 17,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
