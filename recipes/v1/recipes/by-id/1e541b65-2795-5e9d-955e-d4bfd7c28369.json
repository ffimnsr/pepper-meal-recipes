  "id": "1e541b65-2795-5e9d-955e-d4bfd7c28369",
  "slug": "balbacua-recipe",
  "name": "Balbacua Recipe",
  "recipe_type": "main",
  "brief_description": "Balbacua is a delightful Filipino dish that is most popular in those areas of the Philippines. Just imagine Pochero and Kare Kare",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saut\u00e9 garlic, onion, and ginger until the onion softens. Set aside."
    },
    {
      "position": 2,
      "text": "Combine trotters, 10 cups water, ground black pepper, and lemongrass in a cooking pot. Let it boil. Adjust the stove to the lowest heat setting and then simmer for 3 hours or until the meat and fibers on the trotters soften."
    },
    {
      "position": 3,
      "text": "Remove the lemongrass. Add the annatto powder, sauteed aromatics (onion, garlic, and ginger), salted black beans, and Knorr Beef Cube. Continue cooking for 30 minutes."
    },
    {
      "position": 4,
      "text": "Add jalapeno, bell pepper, and green onions. Cook for 10 minutes."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 180,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "expert",
