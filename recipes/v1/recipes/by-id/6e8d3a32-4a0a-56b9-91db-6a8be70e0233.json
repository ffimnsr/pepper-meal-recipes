  "slug": "pinoy-fruit-salad-recipe",
  "name": "Filipino Fruit Salad",
  "recipe_type": "salad",
  "brief_description": "Creamy Filipino dessert with fruit cocktail, kaong, nata de coco, and sweetened cream.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Drain the syrup from the fruit cocktail, nata de coco, and kaong."
    },
    {
      "position": 2,
      "text": "Combine all the ingredients in a bowl."
    },
    {
      "position": 3,
      "text": "Gently fold the mixture until all ingredients are well blended."
    },
    {
      "position": 4,
      "text": "Cover the bowl. Refrigerate for 3 hours."
    },
    {
      "position": 5,
      "text": "Serve chilled. Share and enjoy!"
    }
  ],
