  "id": "e2fcfc60-ae68-5ad1-8b67-f757fc985ea3",
  "slug": "potato-croquettes-2",
  "name": "Potato Croquette Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Golden brown and crisp on the outside with a soft, seasoned mashed potato filling inside. These Potato Croquettes make a perfect appetizer or snack that pairs well with your favorite dipping sauce.",
  "cuisine": "French",
  "instructions": [
    {
      "position": 1,
      "text": "Combine mashed potatoes, milk, salt, ground black pepper, flour, and 1 egg. Mix thoroughly."
    },
    {
      "position": 2,
      "text": "Scoop a mixture of mashed potatoes then dip in the remaining beaten egg and roll over bread crumbs."
    },
    {
      "position": 3,
      "text": "Heat a cooking pot then pour-in cooking oil."
    },
    {
      "position": 4,
      "text": "Fry in medium heat until the color of the sides turns golden brown."
    },
    {
      "position": 5,
      "text": "Transfer to plate lined with paper towel."
    },
    {
      "position": 6,
      "text": "Serve with your favorite condiment. The combination of mayonnaise and banana ketchup works well for me."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 10,
