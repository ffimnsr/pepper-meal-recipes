  "id": "811c3377-7b6d-5cd0-bff8-a0148e64a7f9",
  "slug": "pancit-luglug-recipe",
  "name": "Pancit Luglug Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pancit Luglug",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 mussels and squid for 2 minutes; remove from the pan and then set aside."
    },
    {
      "position": 3,
      "text": "On the same pot with remaining oil and juices, add the ground pork continue to cook until the color turns to medium brown."
    },
    {
      "position": 4,
      "text": "Add the tinapa flakes and Knorr Shrimp Cube. Continue to cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Stir-in the all-purpose flour."
    },
    {
      "position": 6,
      "text": "Pour the annatto water (do not include the seeds) and 3 cups of water in the cooking pot. Stir."
    },
    {
      "position": 7,
      "text": "Add the fish sauce and continue to stir until the desired texture is achieved (I like it a bit thick). Set the palabok sauce aside."
    },
    {
      "position": 8,
      "text": "Meanwhile, boil 6 to 8 cups water in clean pot."
    },
    {
      "position": 9,
      "text": "Arrange the palabok noodles in a blanching basket. Dip it in boiling water until it gets cooked."
    },
    {
      "position": 10,
      "text": "Drain the water and arrange the noodles in a serving plate. Top with palabok sauce. Arrange the toppings over the sauce. Refer to the topping ingredients above."
    },
    {
      "position": 11,
      "text": "Serve with lots of love."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
  "difficulty": "hard",
