  "id": "531068a5-e142-5f55-a2fe-bee90b7b7126",
  "slug": "pork-giniling-hardinera-recipe",
  "name": "Pork Giniling Hardinera Recipe",
  "recipe_type": null,
  "brief_description": "Pork giniling hardinera is a version of the popular Lucban fiesta favorite hardinera, except that this dish is made from pork giniling.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the boiled eggs in half, lengthwise. Set aside."
    },
    {
      "position": 2,
      "text": "Combine all the ingredients in a mixing bowl. Crack the raw eggs and add to the bowl. Mix well."
    },
    {
      "position": 3,
      "text": "Arrange the mixture including the sliced boiled eggs in oval containers. These are locally known as llanera. Cover the llanera with aluminum foil."
    },
    {
      "position": 4,
      "text": "Boil 8 cups water in a steamer. Using the steamer, steam the llaneras with pork giniling hardinera for 30 minutes."
    },
    {
      "position": 5,
      "text": "Remove from the steamer. Let it cool for 1 to 2 hours."
    },
    {
      "position": 6,
      "text": "Serve after cooling down or refrigerate for 3 hours and serve chilled."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
