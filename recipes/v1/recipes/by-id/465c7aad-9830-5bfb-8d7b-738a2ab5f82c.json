  "id": "465c7aad-9830-5bfb-8d7b-738a2ab5f82c",
  "slug": "pepper-pork-belly",
  "name": "Pepper Pork Belly Recipe",
  "recipe_type": "main",
  "brief_description": "Pork stew with bell peppers and garlic java rice",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 onion and garlic."
    },
    {
      "position": 3,
      "text": "Add pork belly once the onion softens. Continue saut\u00e9ing until the exterior of the pork turns light brown."
    },
    {
      "position": 4,
      "text": "Add Knorr Liquid Seasoning, oyster sauce, soy sauce, and water. Let it boil. Cover the pot. Adjust the heat to a low setting. Cook until the pork becomes tender. Note: add water as needed."
    },
    {
      "position": 5,
      "text": "Add the sugar and put all the bell peppers into the pot. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Combine cornstarch with 3 tablespoons of water. Stir. Pour the mixture into the pot."
    },
    {
      "position": 7,
      "text": "Once the sauce thickens, season your dish with salt and ground black pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
