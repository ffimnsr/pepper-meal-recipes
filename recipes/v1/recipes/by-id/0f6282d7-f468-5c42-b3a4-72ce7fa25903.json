  "id": "0f6282d7-f468-5c42-b3a4-72ce7fa25903",
  "slug": "ham-and-hotdog-omelette-with-cheese",
  "name": "Ham and Hotdog Omelet with Cheese",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ham and Hotdog Omelet with Cheese",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat 2 tablespoons oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute cubed ham and hotdogs for 2 minutes. Remove from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Crack eggs in a bowl. Add salt and ground black pepper. Beat until the texture is smooth."
    },
    {
      "position": 4,
      "text": "Add cheese. Continue to beat until well blended."
    },
    {
      "position": 5,
      "text": "Heat remaining oil in a pan. Pour a quarter of the egg mixture. Top with a quarter of cubed ham and hotdog. Using a wide spatula, turn the egg over to cook the other side. Let it stay for 40 to 80 seconds in medium heat or until the other side is fully cooked. Perform the same steps until all the eggs and meat are consumed."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
