  "id": "0dbd601d-0295-5c95-a760-b5acaa3d8edd",
  "slug": "tonkatsu-sinangag-at-itlog",
  "name": "Tonkatsu Sinangag at Itlog",
  "recipe_type": "main",
  "brief_description": "A Filipino breakfast favorite (Tosi-log) featuring crispy Japanese-style breaded pork cutlet served with garlic fried rice (sinangag) and fried egg (itlog).",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and pepper all over the pork. Let it stay for 5 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan."
    },
    {
      "position": 3,
      "text": "While the oil is heating-up, dredge the pork on flour. Dip into the beaten egg to coat, and then roll over the plate with Panko breadcrumbs. Note: make sure that the pork is totally covered with crumbs."
    },
    {
      "position": 4,
      "text": "Fry between low to medium heat for 7 minutes per side or until it turns golden brown. Turn over and pan fry the other side until golden brown. Note: do not apply too much heat because the outer part will get brown quicker leaving the inside uncooked."
    },
    {
      "position": 5,
      "text": "Remove from the pan. Let excess oil drip. Transfer to a serving plate."
    },
    {
      "position": 6,
      "text": "Prepare the garlic fried rice and egg (see link above for recipe). Arrange in a serving plate along with the tonkatsu."
    },
    {
      "position": 7,
      "text": "Serve with tonkatsu sauce. Share and enjoy!"
    }
  ],
  "servings": 1,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
