  "id": "3b0abfab-9a87-5b72-8773-89310bc0296d",
  "slug": "creamy-mais-maja-blanca",
  "name": "Creamy Mais Maja Blanca",
  "recipe_type": "dessert",
  "brief_description": "Creamy Mais Maja Blanca is a version Maja Blanca. It is a type of Filipino coconut pudding composed of coconut milk, white sugar",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine fresh milk, table cream, and cornstarch in a bowl. Stir to mix. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the coconut milk in a pot. Let boil."
    },
    {
      "position": 3,
      "text": "Add the sugar, condensed milk, cream style sweet corn. Stir. Add the cornstarch mixture from step 1. Continue to cook while stirring until the texture thickens to a paste-like texture."
    },
    {
      "position": 4,
      "text": "Transfer the mixture to a mold. Let it cool down. Refrigerate for 1 hour."
    },
    {
      "position": 5,
      "text": "Top with latik."
    },
    {
      "position": 6,
      "text": "Slice into serving pieces."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
