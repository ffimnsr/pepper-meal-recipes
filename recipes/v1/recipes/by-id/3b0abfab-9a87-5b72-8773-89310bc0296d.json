  "id": "3b0abfab-9a87-5b72-8773-89310bc0296d",
  "slug": "creamy-mais-maja-blanca",
  "name": "Creamy Mais Maja Blanca",
  "recipe_type": "dessert",
  "brief_description": "A decadent version of the classic Filipino coconut pudding made with coconut milk, fresh milk, table cream, and sweet corn. Thickened with cornstarch and topped with latik for a rich, silky finish.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine fresh milk, table cream, and cornstarch in a bowl. Stir until smooth and well combined. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the coconut milk in a pot over medium heat until it boils."
    },
    {
      "position": 3,
      "text": "Add the sugar, condensed milk, and cream-style sweet corn. Stir well, then gradually pour in the cornstarch mixture while stirring continuously. Cook until the mixture thickens to a paste-like consistency."
    },
    {
      "position": 4,
      "text": "Transfer the mixture to a mold. Let it cool to room temperature, then refrigerate for at least 1 hour to set."
    },
    {
      "position": 5,
      "text": "Top with latik."
    },
    {
      "position": 6,
      "text": "Slice into serving pieces."
    },
    {
      "position": 7,
      "text": "Serve and enjoy."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
