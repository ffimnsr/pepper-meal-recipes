  "id": "63ed8ed6-9487-5a8a-8699-d2a079d70c9c",
  "slug": "ginataang-langka-with-pork-recipe",
  "name": "Ginataang Langka with Pork Recipe",
  "recipe_type": null,
  "brief_description": "Ginataang Langka with Pork is a version of unripe jackfruit cooked in coconut milk using sliced pork along with chillies.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot, saut\u00e9 the onion and garlic."
    },
    {
      "position": 3,
      "text": "Add the pork. Cook until medium brown."
    },
    {
      "position": 4,
      "text": "Pour the coconut milk in the pan. Let boil. Cover and simmer for 20 minutes. Add water if needed."
    },
    {
      "position": 5,
      "text": "Add the ground black pepper, chili, and fish sauce. Stir."
    },
    {
      "position": 6,
      "text": "Add the jackfruit. Stir and cook for 5 to 7 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
