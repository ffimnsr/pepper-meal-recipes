  "id": "103d4426-8ae0-585f-b0db-630781d5fe6b",
  "slug": "tulingan-bistek-braised-bullet-tuna-in-soy-sauce-and-onion",
  "name": "Tulingan Bistek (Braised Bullet Tuna in Soy Sauce and Onion)",
  "recipe_type": "main",
  "brief_description": "Firm and flavorful tulingan slices marinated in soy sauce and calamansi, fried until golden, and simmered with onions and seasonings for a tangy and savory Filipino classic.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine tulingan, calamansi juice, soy sauce, and 3 cloves minced garlic in a bowl. Mix and marinate for 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Fry the tulingan slices until golden brown. Remove from the pan."
    },
    {
      "position": 3,
      "text": "Discard excess oil, leaving about 3 tablespoons. Saut\u00e9 the remaining garlic until golden brown. Add ginger and onion. Cook until the onion turns slightly soft."
    },
    {
      "position": 4,
      "text": "Pour the remaining marinade into the pan. Add water. Bring to a boil."
    },
    {
      "position": 5,
      "text": "Add the fried tulingan into the pan. Lower the heat and simmer for 30 minutes. Note: add water as needed."
    },
    {
      "position": 6,
      "text": "Season with sugar, ground black pepper, and Maggi Magic Sarap."
    },
    {
      "position": 7,
      "text": "Add the onions and green onions. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve hot with rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
