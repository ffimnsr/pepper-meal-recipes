{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "20cd4612-274b-5c4d-a32e-c62a1b370109",
  "slug": "loaded-breakfast-potato",
  "name": "Loaded Breakfast Potato",
  "recipe_type": "breakfast",
  "brief_description": "A hearty baked potato stuffed with scrambled eggs, saut\u00e9ed vegetables, cheddar cheese, sour cream, and crispy bacon. Perfect for a filling breakfast to start your day.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Wash the potato under running water and make sure to scrub the surface thoroughly. Prick holes around the potato using a fork. Place it on a plate and microwave for 15 minutes."
    },
    {
      "position": 2,
      "text": "Let the potato cool down. Slice a portion off the top, then scrape out the potato from the sliced portion. Make the potato as hollow as possible. Set aside."
    },
    {
      "position": 3,
      "text": "Melt butter in a pan."
    },
    {
      "position": 4,
      "text": "Saut\u00e9 the onion, mushrooms, and bell pepper until the onion and mushrooms become soft. Add a pinch of salt and ground black pepper."
    },
    {
      "position": 5,
      "text": "Push the saut\u00e9ed vegetables to the side and pour in the beaten eggs. Continue to cook the eggs while gently stirring, similar to scrambled eggs. When the eggs get half cooked, blend them with the vegetables. Make sure that the eggs and veggies are well blended."
    },
    {
      "position": 6,
      "text": "Add the shredded cheese and stir in 1/4 cup of sour cream. Turn the heat off and continue stirring until the sour cream and cheese are mixed with the rest of the ingredients."
    },
    {
      "position": 7,
      "text": "Preheat oven to 350\u00b0F. Fill the cavity of the potato with the cooked egg mixture and add more mixture on top. Bake for 11 to 14 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven and let cool. Top with crumbled bacon, remaining sour cream, and green onion."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
