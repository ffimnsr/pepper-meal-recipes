  "id": "ac7c7384-f8aa-52b5-bc34-9c8c33aac015",
  "slug": "creamy-tofu-with-mixed-vegetables",
  "name": "Creamy Tofu with Mixed Vegetables",
  "recipe_type": "main",
  "brief_description": "Fried firm tofu cooked in creamy mushroom sauce with vegetables",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Salt and ground black pepper to taste"
    },
    {
      "position": 2,
      "text": "Deep fry the tofu until it turns golden brown. Set aside."
    },
    {
      "position": 3,
      "text": "Melt butter in a pan and then add 2 tablespoons of cooking oil. Saut\u00e9 the garlic and onion until the onion softens."
    },
    {
      "position": 4,
      "text": "Add the fried tofu. Saute for 30 seconds."
    },
    {
      "position": 5,
      "text": "Add the green peas, carrots, and corn. Saute for 2 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the Knorr Chicken Cube."
    },
    {
      "position": 7,
      "text": "Combine water and Knorr Cream of Mushroom. Mix well and then pour the mixture into the pan. Stir."
    },
    {
      "position": 8,
      "text": "Pour the heavy cream. Adjust the heat to the lowest setting. Simmer until the sauce reduces to half."
    },
    {
      "position": 9,
      "text": "Add some toasted garlic (if desired) and season with salt and ground black pepper."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
