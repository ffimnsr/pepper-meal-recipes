  "id": "c3b05620-3ed9-51b3-b94e-89f6b3f98c2f",
  "slug": "homemade-lechon-paksiw-sauce",
  "name": "Homemade Lechon Paksiw",
  "recipe_type": "dessert",
  "brief_description": "Leftover roast pork stew in sweet liver sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Add the pork liver. Fry until color turns brown."
    },
    {
      "position": 2,
      "text": "Remove the liver from the pot and place inside the blender. Add water. Puree the mixture. Set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil, saut\u00e9 garlic and onion until the latter softens."
    },
    {
      "position": 4,
      "text": "Pour the liver puree. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork Cube, soy sauce, vinegar, and ground black pepper. Let the mixture boil. Stir."
    },
    {
      "position": 6,
      "text": "Add brown sugar and breadcrumbs. Turn the heat off and pour the entire mixture back into the blender. Puree for 1 minute."
    },
    {
      "position": 7,
      "text": "Pour the puree back into the cooking pot. Let it boil."
    },
    {
      "position": 8,
      "text": "Add laurel leaves and roasted pork. Cover the pan. Continue cooking in a low heat setting for 40 minutes."
    },
    {
      "position": 9,
      "text": "Season with salt as needed."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve warm. Share and enjoy with rice."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
