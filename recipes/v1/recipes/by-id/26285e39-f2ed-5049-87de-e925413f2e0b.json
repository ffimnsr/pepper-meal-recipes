  "id": "26285e39-f2ed-5049-87de-e925413f2e0b",
  "slug": "healthy-ginataang-gulay-with-tofu-and-shrimp",
  "name": "Healthy Ginataang Gulay with Tofu and Shrimp",
  "recipe_type": "main",
  "brief_description": "Healthy vegetables with tofu and shrimp cooked in coconut milk and turmeric",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok or wide pan. Fry shrimp for 1 minute per side. Remove from the pan and set aside."
    },
    {
      "position": 2,
      "text": "Using the remaining oil, saut\u00e9 onion, garlic, and ginger."
    },
    {
      "position": 3,
      "text": "Add carrot, long green beans. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add broccoli, bell pepper, and half of the fried tofu. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Combine Knorr Ginataang Gulay Mix with 1 \u00bd cups water. Mix well and then pour into the pan."
    },
    {
      "position": 6,
      "text": "Add turmeric powder and fried shrimp. Cover the pan and continue cooking for 5 to 7 minutes or until the vegetables are cooked according to your preference."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and salt."
    },
    {
      "position": 8,
      "text": "Add the remaining tofu. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
