  "id": "7a65be4c-f425-5cf1-a8b4-c2d2629037f6",
  "slug": "shrimp-stir-fry",
  "name": "Sweet and Spicy Shrimp Stir Fry",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for shrimp stir fry.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine soy sauce, ketchup, sugar, and sherry. Mix and set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan."
    },
    {
      "position": 3,
      "text": "Add ginger and garlic. Cook for 20 to 30 seconds or until light brown."
    },
    {
      "position": 4,
      "text": "Put-in the shrimp and stir fry for 1 to 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the ketchup mixture, scallions, and chili. Stir fry for 2 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Add salt and pepper."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 5,
