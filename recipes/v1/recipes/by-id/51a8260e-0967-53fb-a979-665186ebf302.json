  "id": "51a8260e-0967-53fb-a979-665186ebf302",
  "slug": "filipino-food-bread-of-salt-pandesal-recipe",
  "name": "Pandesal",
  "recipe_type": "breakfast",
  "brief_description": "Traditional Filipino bread roll.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the yeast, 2 tablespoons sugar, and warm milk and stir until the yeast and sugar are fully dissolved"
    },
    {
      "position": 2,
      "text": "In the mixing bowl, combine the dry ingredients starting with the flour then the remaining sugar, salt, and baking powder . Mix well by stirring"
    },
    {
      "position": 3,
      "text": "Add the egg, butter, cooking oil, and yeast-sugar-milk mixture in the mixing bowl with the dry ingredients then mix again until a dough is formed. Use your clean hands to effectively mix the ingredients."
    },
    {
      "position": 4,
      "text": "In a flat surface, knead the dough until the texture becomes fine. For faster and easier kneading, you may use a Stand Mixer with dough hook."
    },
    {
      "position": 5,
      "text": "Mold the dough until shape becomes round then put back in the mixing bowl. Cover the mixing bowl with damp cloth and let the dough rise for at least 1 hour"
    },
    {
      "position": 6,
      "text": "Put the dough back to the flat surface and divide into 4 equal parts using a dough slicer"
    },
    {
      "position": 7,
      "text": "Roll each part until it forms a cylindrical shape"
    },
    {
      "position": 8,
      "text": "Slice the cylindrical dough diagonally (These slices will be the individual pieces of the pandesal)"
    },
    {
      "position": 9,
      "text": "Roll the sliced dough over the breadcrumbs and place in a baking tray with wax paper (makes sure to provide gaps between dough as this will rise later on)"
    },
    {
      "position": 10,
      "text": "Leave the sliced dough with breadcrumbs in the tray for another 10 to 15 minutes to rise"
    },
    {
      "position": 11,
      "text": "Pre-heat the oven at 375 degrees Fahrenheit for 10 minutes"
    },
    {
      "position": 12,
      "text": "Put the tray with dough in the oven and bake for 15 minutes"
    },
    {
      "position": 13,
      "text": "Turn off the oven and remove the freshly baked pandesal."
    },
    {
      "position": 14,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 8,
