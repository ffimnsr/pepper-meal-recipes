  "id": "410deda7-7724-5ea7-aa4d-7fb7cb4ca6c8",
  "slug": "tahong-bicol-express",
  "name": "Tahong Bicol Express",
  "recipe_type": "main",
  "brief_description": "Mussels simmered in spicy coconut milk with shrimp paste, ginger, and chilies. A creamy, flavorful seafood dish that can be enjoyed with rice or as pulutan.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a pot and add the crushed ginger. Cook for 2 minutes to infuse the liquid."
    },
    {
      "position": 2,
      "text": "Add the mussels and boil for 1 minute. Drain using a strainer, then separate the meat from the shells and set aside."
    },
    {
      "position": 3,
      "text": "Heat cooking oil in a large pan over medium heat. Saut\u00e9 the garlic until it starts to brown."
    },
    {
      "position": 4,
      "text": "Add the onion and minced ginger. Continue saut\u00e9ing until the onion softens."
    },
    {
      "position": 5,
      "text": "Stir in the shrimp paste and Thai chili pepper. Cook for 30 to 45 seconds to bloom the flavors."
    },
    {
      "position": 6,
      "text": "Pour in the coconut milk and bring to a gentle boil."
    },
    {
      "position": 7,
      "text": "Add the mussels and simmer for 1 minute. Remove the mussels and continue cooking the sauce until it thickens and reduces by half."
    },
    {
      "position": 8,
      "text": "Add the long green pepper and return the mussels to the pan. Cook for 1 minute or until the peppers slightly soften."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper, adjust to taste, and serve hot with rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
