  "id": "8a22fa73-fd5f-52bc-9974-06399abf6095",
  "slug": "seafood-aligue-pasta",
  "name": "Seafood Aligue Pasta",
  "recipe_type": "main",
  "brief_description": "Seafood Aligue Pasta is a creamy Filipino pasta dish made with crab fat, mixed seafood, ricotta, and parmesan. The sauce coats every strand of linguine with briny richness. Serve this for lunch or dinner when you want to treat your family to something memorable.",
  "cuisine": "Filipino Italian Mediterranean",
  "instructions": [
    {
      "position": 1,
      "text": "Bring the water to a boil in a cooking pot. Add 1 teaspoon of salt, then cook the linguine according to package directions. Drain and set aside."
    },
    {
      "position": 2,
      "text": "Heat the olive oil in a wide pan. Saut\u00e9 the onion and garlic until the onion softens."
    },
    {
      "position": 3,
      "text": "Add the crab fat and saut\u00e9 for about 30 seconds, just until fragrant."
    },
    {
      "position": 4,
      "text": "Add the tomatoes and cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Put in the seafood mix and saut\u00e9 for another 30 seconds."
    },
    {
      "position": 6,
      "text": "Add the tomato paste and spinach, then pour in the chicken stock. Let it come to a boil."
    },
    {
      "position": 7,
      "text": "Pour in the Carnation Everyday Creamer, then add the ricotta and parmesan cheeses. Stir until the sauce becomes creamy."
    },
    {
      "position": 8,
      "text": "Season with the remaining salt, then add the cooked linguine. Toss until the pasta is fully coated with the sauce."
    },
    {
      "position": 9,
      "text": "Add the chopped parsley and toss once more."
    },
    {
      "position": 10,
      "text": "Serve warm and enjoy."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
