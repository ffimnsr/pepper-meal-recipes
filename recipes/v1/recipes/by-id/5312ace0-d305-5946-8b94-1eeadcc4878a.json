{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "5312ace0-d305-5946-8b94-1eeadcc4878a",
  "slug": "chicken-soup-with-misua-and-patola",
  "name": "Chicken Soup with Misua and Patola",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Chicken Soup with Misua and Patola.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour 5 cups water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add the chicken breast. Cover and then boil for 15 to 18 minutes in medium heat."
    },
    {
      "position": 3,
      "text": "Remove the chicken breast from the pot. Let it cool. Save the water (this is now the chicken stock) for later use."
    },
    {
      "position": 4,
      "text": "Discard the skin and separate the chicken meat from the bone. Shred the chicken using your hands. Set aside."
    },
    {
      "position": 5,
      "text": "Heat oil in the same cooking pot."
    },
    {
      "position": 6,
      "text": "Once the oil gets hot, saute the garlic until it turns light brown."
    },
    {
      "position": 7,
      "text": "Add the onion. Continue to saute until tender."
    },
    {
      "position": 8,
      "text": "Add the shredded chicken. Saute for 2 minutes."
    },
    {
      "position": 9,
      "text": "Pour the chicken stock into the pot (This is the water used to boil the chicken) and add the remaining water. Let boil."
    },
    {
      "position": 10,
      "text": "Add Knorr chicken cube. Stir. Cover and cook in medium heat for 12 minutes."
    },
    {
      "position": 11,
      "text": "Put the patola and hot pepper leaves in the cooking pot. Cook for 5 minutes."
    },
    {
      "position": 12,
      "text": "Add the miswa. Cook for 2 minutes."
    },
    {
      "position": 13,
      "text": "Add the scallions, fish sauce, and ground black pepper.Cook for 2 minutes."
    },
    {
      "position": 14,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 15,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 5,
