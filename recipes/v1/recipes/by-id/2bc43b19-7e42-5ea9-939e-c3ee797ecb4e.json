  "id": "2bc43b19-7e42-5ea9-939e-c3ee797ecb4e",
  "slug": "pork-sisig",
  "name": "Pork Sisig",
  "recipe_type": "appetizer",
  "brief_description": "Recipe for pork sisig",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pig ears, snout, pork belly, ginger, bay leaves, 2 teaspoons salt, and 1 quart of water in a cooking pot. Boil for 1 hour. Remove from the pot and drain the water."
    },
    {
      "position": 2,
      "text": "Heat-up your grill. Start grilling the pig parts for around 5 minutes per side. Remove from the grill afterwards and let it cool down."
    },
    {
      "position": 3,
      "text": "Make the dressing by combining all the dressing ingredients. Mix well."
    },
    {
      "position": 4,
      "text": "Chop the grilled pig parts into small pieces. In a large mixing bowl, combine the chopped pork with onion and the dressing mixture. Toss until all the ingredients are well blended."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve with your favorite drink. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
