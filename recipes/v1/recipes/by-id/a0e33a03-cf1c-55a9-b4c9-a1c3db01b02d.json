  "id": "a0e33a03-cf1c-55a9-b4c9-a1c3db01b02d",
  "slug": "adobong-manok-sa-gata",
  "name": "Adobong Manok sa Gata",
  "recipe_type": "main",
  "brief_description": "Classic Filipino chicken adobo stewed in coconut milk. This rich and creamy adobo version is perfect to have with warm rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Crush the garlic, and then saute until it starts to brown."
    },
    {
      "position": 3,
      "text": "Fry the chicken for 1 to 1 \u00bd minutes per side."
    },
    {
      "position": 4,
      "text": "Pour soy sauce and vinegar. Cover the pan. Let boil. Flip the chicken pieces afterwards. Continue cooking for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add whole peppercorn and bay leaves. Pour coconut milk. Stir and then let the mixture boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Chicken Cube. Stir and cover the pan. Adjust heat to low. Cook for 20 minutes."
    },
    {
      "position": 7,
      "text": "Remove the cover and continue to cook until sauce reduces to desired amount."
    },
    {
      "position": 8,
      "text": "Serve with warm rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
