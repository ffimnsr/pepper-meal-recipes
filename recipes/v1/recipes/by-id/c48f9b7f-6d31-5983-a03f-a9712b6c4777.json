  "id": "c48f9b7f-6d31-5983-a03f-a9712b6c4777",
  "slug": "baked-swai-fillet-recipe",
  "name": "Baked Swai Fillet Recipe",
  "recipe_type": null,
  "brief_description": "I think that this simple Baked Swai Fillet is something that you should try for many reasons. The first reason will be the taste, it is not that overpowering and unlike other fish, while the smell is not too fishy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 425 Fahrenheit."
    },
    {
      "position": 2,
      "text": "Line a baking tray with aluminum foil."
    },
    {
      "position": 3,
      "text": "Grease the the foil by spraying cooking oil spray all throught."
    },
    {
      "position": 4,
      "text": "Meanwhile, brush the melted butter on the fish and then sprinkle the lemon pepper seasoning all over the fish (swai fillet). Arrange the fish over the aluminum foil."
    },
    {
      "position": 5,
      "text": "Bake for 10 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven and transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 12,
