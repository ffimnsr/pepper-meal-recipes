  "id": "d985707d-ac86-5cc8-9ce3-9590c72e08d2",
  "slug": "kare-kare-buntot-ng-baka",
  "name": "Kare Kare Buntot ng Baka",
  "recipe_type": "main",
  "brief_description": "Filipino kare kare oxtail cooked in peanut sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water. Add the vegetable ingredients. Cook this for 2 minutes. Remove and soak it in a bowl with cold water for 3 minutes. Drain the water and dry the vegetables. Set it aside."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a pot. Saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the Ox tail once the onion softens. Saute it until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Pour the water that was used to cook the vegetables into the cooking pot. Cover and bring it into a simmer. Continue cooking until the ox tail tenderizes."
    },
    {
      "position": 5,
      "text": "Add Knorr Beef Cube, peanut paste, and annatto powder. Cook for 10 minutes."
    },
    {
      "position": 6,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Top with blanched vegetables. Serve with shrimp paste (bagoong alamang)."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
