  "slug": "vegetable-fried-rice-recipe",
  "name": "Vegetable Fried Rice Recipe",
  "recipe_type": null,
  "brief_description": "Vegetable Fried Rice is an easy fried rice recipe involving vegetables and white rice. This dish can be prepared quickly and can be eaten with any main dish",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine salt and rice. Gently mix using your hands."
    },
    {
      "position": 2,
      "text": "Heat a wide frying pan and then pour-in the olive oil."
    },
    {
      "position": 3,
      "text": "When the oil turns hot, stir-fry the peppers, carrots, and broccoli for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the rice and then cook for 5 to 6 minutes while continuously stirring. This will prevent the rice from sticking on the pan."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 6,
      "text": "Serve with the main course. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
