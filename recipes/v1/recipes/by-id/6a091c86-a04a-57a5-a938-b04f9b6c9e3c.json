  "id": "6a091c86-a04a-57a5-a938-b04f9b6c9e3c",
  "slug": "ginataang-halo-halo-recipe",
  "name": "Ginataang Halo-halo Recipe (Binignit)",
  "recipe_type": "dessert",
  "brief_description": "Ginataang Halo-halo or Binignit is a delicious Filipino dessert and snack recipe that makes use of glutinous rice flour balls and coconut milk.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a large cooking pot and apply heat. Let boil."
    },
    {
      "position": 2,
      "text": "Add 1 3/4 cups of coconut milk then wait until it re-boils."
    },
    {
      "position": 3,
      "text": "Put-in the sweet potatoes, purple yam, and taro roots and simmer for 8 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in the remaining coconut milk, sugar, and glutinous rice balls then stir. Simmer for 7 minutes."
    },
    {
      "position": 5,
      "text": "Add the plantains then cook for an additional 2 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the jack fruit and cook for 2 minutes more."
    },
    {
      "position": 7,
      "text": "Slowly slide-in the cooked tapioca pearls then stir. Simmer for 1 minute."
    },
    {
      "position": 8,
      "text": "Turn off heat and transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve either hot or cold. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
