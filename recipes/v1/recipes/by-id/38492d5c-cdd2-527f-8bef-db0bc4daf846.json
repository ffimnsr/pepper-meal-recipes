  "id": "38492d5c-cdd2-527f-8bef-db0bc4daf846",
  "slug": "corned-beef-with-cabbage-and-potato",
  "name": "Corned Beef with Cabbage and Potato",
  "recipe_type": null,
  "brief_description": "This is a recipe for Corned Beef with Cabbage and Potato",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Add corned beef. Saute for 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour beef broth. Let boil."
    },
    {
      "position": 5,
      "text": "Add potato and cabbage. Cover and continue to cook in medium heat for 8 to 10 minutes."
    },
    {
      "position": 6,
      "text": "Add parsley along with salt and ground black pepper. Stir. Transfer to a serving bowl."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 18,
