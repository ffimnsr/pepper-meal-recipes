  "id": "9e812776-5db8-51e8-9eba-48cd19c6e73a",
  "slug": "steamed-cassava-cake",
  "name": "Steamed Cassava Cake",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Steamed Cassava Cake",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Combine grated cassava, coconut milk, butter, eggs, and condensed milk in a large bowl. Mix well using a wire whisk."
    },
    {
      "position": 3,
      "text": "Pour the cassava mixture into individual molds. Arrange the molds in a steamer. Steam the cassava cake for 45 minutes."
    },
    {
      "position": 4,
      "text": "Remove the molds with cassava cake from the steamer. Let it cool down."
    },
    {
      "position": 5,
      "text": "Gently separate the cassava cake from the mold. Arrange on a plate. Top with shredded cheese."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
