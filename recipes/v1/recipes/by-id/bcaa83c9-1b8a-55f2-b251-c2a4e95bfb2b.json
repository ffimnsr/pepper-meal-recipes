  "id": "bcaa83c9-1b8a-55f2-b251-c2a4e95bfb2b",
  "slug": "sotanghon-with-upo-soup",
  "name": "Sotanghon with Upo Soup",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Sotanghon with Upo Soup.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 onion and garlic"
    },
    {
      "position": 3,
      "text": "Once the onion becomes soft, add pork. Continue to cook until the pork turns light brown."
    },
    {
      "position": 4,
      "text": "Pour chicken broth into the pot. Let boil. Cover and cook for 15 minutes in medium eat."
    },
    {
      "position": 5,
      "text": "Add shrimp. Stir and let the liquid re-boil."
    },
    {
      "position": 6,
      "text": "Put the sotanghon noodles into the pot. Stir."
    },
    {
      "position": 7,
      "text": "Add the opo squash (upo). Cover the pot. Cook for 8 to 10 minutes in medium heat. Note: add water or chicken broth, if needed."
    },
    {
      "position": 8,
      "text": "Season with crushed black pepper and fish sauce. Stir."
    },
    {
      "position": 9,
      "text": "Put the deep fried garlic into the pot. Continue to cook for 1 to 2 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
