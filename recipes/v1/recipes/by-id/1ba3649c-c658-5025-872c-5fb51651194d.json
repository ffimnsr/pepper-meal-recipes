  "id": "1ba3649c-c658-5025-872c-5fb51651194d",
  "slug": "chicken-pandan-recipe",
  "name": "Chicken Pandan",
  "recipe_type": null,
  "brief_description": "This is a recipe for Chicken pandan",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, combine soy sauce, fish sauce, oyster sauce, sugar, ground black pepper, garlic, ginger, and lemon juice. Mix well."
    },
    {
      "position": 2,
      "text": "Put-in the chicken pieces in the bowl with the mixture and marinade for at least 3 hours. I always marinade meat overnight to absorb the flavors better. When marinating overnight, make sure to cover the bowl and refrigerate it to avoid contamination."
    },
    {
      "position": 3,
      "text": "Wrap the chicken with Pandan leaves. This is done by taking a long leaf and start wrapping about 3 inches down the leaf until the chicken piece is covered. Wrap back from where you started and tie one end of the leaf to the other end until a knot is formed."
    },
    {
      "position": 4,
      "text": "Heat a cooking pot and pour-in cooking oil."
    },
    {
      "position": 5,
      "text": "When the oil is hot enough, deep fry the chicken until the color turns golden brown. You may also grill the chicken instead of frying it."
    },
    {
      "position": 6,
      "text": "Turn-off heat and transfer the chicken to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
