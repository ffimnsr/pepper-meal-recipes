  "id": "ad8e9a6a-409d-5d2b-99f3-bd7d3f39f044",
  "slug": "peanut-butter-cupcake-recipe",
  "name": "Peanut Butter Cupcake with Nutella Frosting",
  "recipe_type": "dessert",
  "brief_description": "Soft and moist peanut butter cupcakes topped with a generous spread of Nutella. The rich peanut butter batter pairs perfectly with the chocolate-hazelnut topping, making these cupcakes a crowd favorite for parties and snacking.",
  "cuisine": "American Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the flour, baking powder, and salt in a bowl, then mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Combine the peanut butter and vegetable shortening in a separate bowl, then whisk until well blended."
    },
    {
      "position": 3,
      "text": "Gradually add the sugar while whisking, then continue to mix for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add the eggs and vanilla extract, then continue mixing until all ingredients are well incorporated."
    },
    {
      "position": 5,
      "text": "Add the flour mixture and milk alternately, beginning and ending with the flour mixture. Continue whisking for 3 more minutes until the batter is smooth."
    },
    {
      "position": 6,
      "text": "Preheat the oven to 350 degrees Fahrenheit."
    },
    {
      "position": 7,
      "text": "Line the cupcake or muffin pan with muffin cups, then pour the batter into each cup, filling about two-thirds full."
    },
    {
      "position": 8,
      "text": "Bake for 16 to 20 minutes or until a toothpick inserted in the center comes out clean."
    },
    {
      "position": 9,
      "text": "Remove the cupcakes from the oven and place them on a wire rack to cool completely."
    },
    {
      "position": 10,
      "text": "Spread Nutella generously on top of each cupcake."
    },
    {
      "position": 11,
      "text": "Arrange the cupcakes on a serving tray and serve."
    }
  ],
  "servings": 12,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
