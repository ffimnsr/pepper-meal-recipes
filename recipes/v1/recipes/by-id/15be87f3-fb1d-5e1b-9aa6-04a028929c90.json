  "id": "15be87f3-fb1d-5e1b-9aa6-04a028929c90",
  "slug": "saucy-adobong-kangkong",
  "name": "Saucy Adobong Kangkong",
  "recipe_type": null,
  "brief_description": "Saucy Adobong Kangkong is a simple adobong kangkong recipe with extra sauce. Don't get me wrong, the \"saucy\" description is all about the sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a frying pan."
    },
    {
      "position": 2,
      "text": "Once the oil is hot, fry the garlic until the color turns golden brown. Remove the garlic and set aside."
    },
    {
      "position": 3,
      "text": "Pour-in water, soy sauce, and vinegar. Add the sugar. Let boil."
    },
    {
      "position": 4,
      "text": "Add the kangkong. Cover and cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add salt and pepper. Stir."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Top with fried garlic."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 3,
