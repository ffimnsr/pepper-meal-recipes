  "id": "044bf284-f2f0-54cd-8875-1a2a4b8687d2",
  "slug": "misua-sardines-patola-recipe",
  "name": "Sardines with Misua and Patola Recipe",
  "recipe_type": "soup",
  "brief_description": "A nutritious Filipino dish featuring thin wheat noodles and sponge gourd simmered with sardines.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a soup pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic until medium brown. Add the onion and continue to saut\u00e9 until it becomes soft."
    },
    {
      "position": 3,
      "text": "Pour in the canned sardines in tomato sauce and stir. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add the patola and cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour in the water, let it boil, then simmer for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Add the misua, gently stir, and cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Season with salt and pepper to taste. Add the green onions."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl and serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
