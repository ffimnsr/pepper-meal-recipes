  "id": "df250997-f0ef-593a-b6f3-2236d9b79800",
  "slug": "sauteed-chayote-with-pork-and-tomato",
  "name": "Sauteed Chayote with Pork and Tomato",
  "recipe_type": null,
  "brief_description": "This is a recipe for Sauteed Chayote with Pork and Tomato",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute garlic, onion, and tomato"
    },
    {
      "position": 3,
      "text": "Once the onion gets soft, add the pork slices. Continue to cook for 3 to 4 minutes."
    },
    {
      "position": 4,
      "text": "Pour 1/2 cup chicken broth. Let boil. Continue to cook until the liquid evaporates (this will help tenderize the pork)."
    },
    {
      "position": 5,
      "text": "Add the chayote. Saute for 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour the remaining broth. Continue to cook until the liquid reduces based on your preference."
    },
    {
      "position": 7,
      "text": "Add salt and ground black pepper to taste."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
