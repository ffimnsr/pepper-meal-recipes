  "slug": "parmesan-crusted-fish-recipe",
  "name": "Parmesan Crusted Fish Recipe",
  "recipe_type": null,
  "brief_description": "Parmesan crusted fish is a quick and easy fish recipe that you can prepare anytime. This dish is perfect for lent. Tilapia is the most common fish",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pre-heat the oven to 350 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Combine the Parmesan cheese, paprika, parsley flakes, and ground black pepper. Mix well."
    },
    {
      "position": 3,
      "text": "Rub the olive oil on the fish fillets."
    },
    {
      "position": 4,
      "text": "Coat the fish with the Parmesan Cheese mixture. Let stand for 10 minutes."
    },
    {
      "position": 5,
      "text": "Arrange the fish in a baking tray and then bake for 12 to 15 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 12,
