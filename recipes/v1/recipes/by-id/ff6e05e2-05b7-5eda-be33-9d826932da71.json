  "id": "ff6e05e2-05b7-5eda-be33-9d826932da71",
  "slug": "shared-recipe-chicken-satay-with-peanut-sauce-recipe",
  "name": "Chicken Satay with Peanut Sauce",
  "recipe_type": null,
  "brief_description": "Chicken Satay with Peanut Sauce Recipe. The flavors come together like they were made for each other. The chicken by itself was very flavorful and could stand on it's own; the Peanut Sauce was good too.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, combine the milk, soy sauce, fish sauce,shallot, garlic,brown sugar, curry powder and ginger. Season with salt and pepper, mix well."
    },
    {
      "position": 2,
      "text": "Add the chicken cubes and marinate for 1- 3 hours."
    },
    {
      "position": 3,
      "text": "Pre-heat your grill pan on medium-high heat and spray or brush with oil."
    },
    {
      "position": 4,
      "text": "Thread chicken onto skewers while pan is heating."
    },
    {
      "position": 5,
      "text": "Grill chicken satay for 2-3 minutes per side, or until meat is cooked through and has light grill marks."
    },
    {
      "position": 6,
      "text": "Serve Chicken Satay warm with Peanut Dipping Sauce and Asian salad of your choice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 10,
