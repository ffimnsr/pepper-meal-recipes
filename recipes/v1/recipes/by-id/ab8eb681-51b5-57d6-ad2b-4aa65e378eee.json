  "id": "ab8eb681-51b5-57d6-ad2b-4aa65e378eee",
  "slug": "ginisang-togue-sauteed-mung-bean-sprouts",
  "name": "Ginisang Togue Recipe",
  "recipe_type": null,
  "brief_description": "Ginisang Togue is basically Sauteed Mung Bean Sprout with carrots, bell pepper, shrimp, and tofu. This Mung Bean Sprout Recipe is a regular dish sered in filipino households and is best eaten with steamed white rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Fry the tofu until color turns golden brown then set aside. (slice the tofu into cubes)"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic, onion, and tomato."
    },
    {
      "position": 3,
      "text": "Once the onion and tomato softens, add the shrimp. Saute for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the tofu. Cook for 30 seconds."
    },
    {
      "position": 5,
      "text": "Add the mung bean sprouts and carrot. Saute for 1 minute."
    },
    {
      "position": 6,
      "text": "Add the bell peppers. Cook for another minute."
    },
    {
      "position": 7,
      "text": "Season with oyster sauce and ground black pepper."
    },
    {
      "position": 8,
      "text": "Serve hot with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
