  "id": "dcd4f156-d2b7-59ce-a5ef-c6333fe69b59",
  "slug": "shrimp-fried-rice-recipe",
  "name": "Shrimp Fried Rice Recipe",
  "recipe_type": null,
  "brief_description": "This Shrimp Fried Rice Recipe makes use of little frozen shrimp. I like to use these types of shrimp because these are tastier compared to the larger varieties. I also like the idea that these are cheaper, most of the time.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the rice, salt, garlic powder, and onion powder Gently mix to blend all the ingredients."
    },
    {
      "position": 2,
      "text": "Melt the butter in a pan."
    },
    {
      "position": 3,
      "text": "Once the butter starts to get hot (make sure not to get the butter very hot), put-in green peas and carrots. Cook for 1 to 2 minutes."
    },
    {
      "position": 4,
      "text": "Put the shrimp in the wok and cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Add the rice mixture. Cook for 10 minutes in medium heat while tossing once in a while. Make sure to toss the ingredients while cooking to blend them properly."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve for breakfast or lunch with your favorite dish."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
