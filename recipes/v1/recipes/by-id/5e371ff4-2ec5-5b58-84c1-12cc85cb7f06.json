  "id": "5e371ff4-2ec5-5b58-84c1-12cc85cb7f06",
  "slug": "kilawing-kambing-recipe",
  "name": "Kilawing Kambing Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Kilawing Kambing Recipe or Chopped Goatskin Kilawin is a Filipino appetizer dish wherein boiled and chopped goatskin is marinated in a sour spicy mixture",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the bay leaves and goatskin. Cover and boil in low heat for 60 minutes or until the skin gets tender."
    },
    {
      "position": 3,
      "text": "Remove the tender skin from the cooking pot and discard the water. Let it cool down and then chop into small pieces. Set aside."
    },
    {
      "position": 4,
      "text": "In a large glass or plastic bowl, combine chili, ginger, onion, and vinegar. Mix well."
    },
    {
      "position": 5,
      "text": "Add the chopped goat. Toss to mix all the ingredients."
    },
    {
      "position": 6,
      "text": "Add salt and pepper according to your taste preference. Toss one more time to ensure that the salt and pepper blends well."
    },
    {
      "position": 7,
      "text": "Cover the bowl with a clear plastic wrap, or simply with a wide plate. Refrigerate for 3 hours."
    },
    {
      "position": 8,
      "text": "Transfer to a serving platter. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 1,
