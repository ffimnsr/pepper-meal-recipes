  "id": "5fe513c6-f9aa-555a-a382-327ee7de8c54",
  "slug": "festive-tuna-carbonara",
  "name": "Festive Tuna Carbonara",
  "recipe_type": "main",
  "brief_description": "Festive tuna carbonara for the holidays.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil water and add some salt. Cook the pasta based on package instructions. Separate the pasta from the pasta water. Set aside."
    },
    {
      "position": 2,
      "text": "Heat a pan. Add bacon and cook until crispy. Remove the bacon and set aside. Also remove half of the bacon fat and keep it for later use while leaving the other half on the pan."
    },
    {
      "position": 3,
      "text": "Combine butter and bacon fat on the pan. Heat the pan and let the butter melt."
    },
    {
      "position": 4,
      "text": "Once the butter and bacon fat mixture get hot enough, saut\u00e9 onion and garlic until the onion softens."
    },
    {
      "position": 5,
      "text": "Add the tuna. Cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Combine Knorr cream of mushroom with 1 \u00bd cup water. Mix well. Pour the mixture into the pot and let it boil."
    },
    {
      "position": 7,
      "text": "Add bell pepper, half of the parsley, and half of the Parmesan cheese. Stir."
    },
    {
      "position": 8,
      "text": "Add the fettuccine. Arrange until well blended. Note: add pasta water to make the sauce thinner, if needed."
    },
    {
      "position": 9,
      "text": "Arrange the tuna carbonara on a pasta bowl and top with crispy bacon, parsley, and Parmesan."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
