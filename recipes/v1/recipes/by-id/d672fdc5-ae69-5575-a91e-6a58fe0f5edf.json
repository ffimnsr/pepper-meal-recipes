  "id": "d672fdc5-ae69-5575-a91e-6a58fe0f5edf",
  "slug": "kangkong-and-ground-pork-with-oyster-sauce-stir-fry",
  "name": "Kangkong and Ground Pork with Oyster Sauce Stir Fry",
  "recipe_type": "main",
  "brief_description": "Today, we\u2019ll be introducing you to an enjoyable dish you can use this green in, kangkong and ground pork with oyster sauce stir fry!",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Brown the garlic by slowly frying it in oil until it turns golden brown. Do this by heating the oil in a pan. After around 20 seconds, add the crushed garlic. Stir and fry using a low to medium heat setting until it browns. Separate the garlic with the oil. Set aside. Note: This is an optional step. The browned garlic can be used as a topping or condiment for this dish and for other dishes too."
    },
    {
      "position": 2,
      "text": "Using 3 tablespoons of the oil used to fry the garlic, Saute the onion until it softens."
    },
    {
      "position": 3,
      "text": "Add the ground pork. Saut\u00e9 for 3 to 5 minutes or until the pork turns light brown."
    },
    {
      "position": 4,
      "text": "Add oyster sauce and water. Stir and cook until the water evaporates completely."
    },
    {
      "position": 5,
      "text": "Put the water spinach stalks into the pan. Stir fry for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the water spinach leaves and a portion of the browned garlic. Cook for 1 minute. Note: you may add up to \u00bd cup of water if you like this with a bit of sauce."
    },
    {
      "position": 7,
      "text": "Season with salt and ground black pepper. Arrange on a serving plate and top with more browned garlic."
    },
    {
      "position": 8,
      "text": "Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 26,
  "preparation_time_minutes": 5,
