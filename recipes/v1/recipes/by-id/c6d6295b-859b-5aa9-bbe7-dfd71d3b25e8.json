  "id": "c6d6295b-859b-5aa9-bbe7-dfd71d3b25e8",
  "slug": "chicken-afritada-with-bell-pepper",
  "name": "Chicken Afritada with Bell Pepper",
  "recipe_type": null,
  "brief_description": "This is a recipe for chicken afritada with green and red bell peppers.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and onion"
    },
    {
      "position": 3,
      "text": "Add the chicken pieces when the onion gets soft. Cook both sides until it turns light brown."
    },
    {
      "position": 4,
      "text": "Add the tomato sauce and water. Let boil."
    },
    {
      "position": 5,
      "text": "Put the dried bay leaves in the pot and then add the Knorr Chicken Cube. Stir and cover. Cook between low to medium heat for 30 minutes or until the chicken gets tender."
    },
    {
      "position": 6,
      "text": "Add the carrot, bell peppers, and potato. Stir. Cover and cook for 12 minutes."
    },
    {
      "position": 7,
      "text": "Add salt and ground black pepper to taste. Stir and cook for 3 minutes more."
    },
    {
      "position": 8,
      "text": "Transfer to serving bowl or plate. Serve!"
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
