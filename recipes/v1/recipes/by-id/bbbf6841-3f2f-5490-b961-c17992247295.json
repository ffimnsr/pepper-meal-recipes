  "id": "bbbf6841-3f2f-5490-b961-c17992247295",
  "slug": "pata-estofado",
  "name": "Pata Estofado Recipe",
  "recipe_type": "dessert",
  "brief_description": "Pork Hocks stewed in sweet soy sauce with banana and carrots.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Add bananas and fry each side until it turns brown. Remove from the pan and set aside."
    },
    {
      "position": 2,
      "text": "Pan fry the pork pata on the same pan for 3 minutes per side."
    },
    {
      "position": 3,
      "text": "Add garlic directly over the oil. Stir."
    },
    {
      "position": 4,
      "text": "Add brown sugar. Stir and continue cooking until the sugar melts."
    },
    {
      "position": 5,
      "text": "Pour soy sauce, vinegar, and water into the pot. Cover and let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Pork cube, whole peppercorn, and dried bay leaves. Stir. Cover the pot and continue boiling the pata in low heat until tender (around 40 minutes)."
    },
    {
      "position": 7,
      "text": "Turn the pork pata over. Cover the pot once more and boil for 30 to 40 minutes."
    },
    {
      "position": 8,
      "text": "Add the carrot and fried bananas. Cover and cook for 5 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
