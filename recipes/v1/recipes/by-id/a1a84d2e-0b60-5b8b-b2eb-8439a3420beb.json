  "slug": "tocino-recipe-with-salted-egg-and-chopped-tomato",
  "name": "Pork Tocino with Salted Egg and Chopped Tomato",
  "recipe_type": null,
  "brief_description": "This is a recipe for Homemade Pork Tocino with Salted Egg and Chopped Tomato",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a pan or cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add oil and homemade pork tocino in the pot with boiling water. Continue to cook in medium heat until the water completely evaporates."
    },
    {
      "position": 3,
      "text": "Once the water evaporates, continue to cook by frying the pork on the remaining oil until brown. Turn the pork over to fry the opposite side."
    },
    {
      "position": 4,
      "text": "Remove the pork tocino from the pan. Arrange in a plate with salted egg and chopped tomato."
    },
    {
      "position": 5,
      "text": "Serve with rice and spicy vinegar dip."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
