  "id": "ba670e9f-0a3a-537d-af31-b05642ba673d",
  "slug": "baked-spaghetti-recipe",
  "name": "Baked Spaghetti Recipe",
  "recipe_type": null,
  "brief_description": "I will describe Baked Spaghetti as a simple Spaghetti dish topped with a rich b\u00e9chamel sauce and baked to perfection. This recipe will give life to a simple spaghetti dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the spaghetti noodles according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a saucepan. Saut\u00e9 onion and garlic"
    },
    {
      "position": 3,
      "text": "Add the ground meat and then cook for 5 minutes or until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Pour-in the marinara sauce. Let boil and then simmer for 30 minutes while stirring every 10 minutes. Add salt and pepper."
    },
    {
      "position": 5,
      "text": "Combine the cooked spaghetti noodles and meat sauce. Mix well and then arrange in a baking pan."
    },
    {
      "position": 6,
      "text": "Preheat the oven to 350 degrees Fahrenheit."
    },
    {
      "position": 7,
      "text": "Quickly prepare the white sauce by melting the butter in a small pan."
    },
    {
      "position": 8,
      "text": "Add the flour and stir. Pour-in the milk and then stir continuously until a thick sauce is formed."
    },
    {
      "position": 9,
      "text": "Put-in the Parmesan cheese. Stir and then turn the heat off."
    },
    {
      "position": 10,
      "text": "Pour the white sauce over the spaghetti. Arrange the shredded cheese on top of the sauce."
    },
    {
      "position": 11,
      "text": "Bake for 10 minutes."
    },
    {
      "position": 12,
      "text": "Set the oven to broil and then broil for 5 minutes."
    },
    {
      "position": 13,
      "text": "Remove from the oven. Serve with garlic bread."
    },
    {
      "position": 14,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 5,
