  "id": "0a0b5029-cbdf-503e-b26d-c9ef939efff1",
  "slug": "pork-and-chicken-sinigang",
  "name": "Pork and Chicken Sinigang",
  "recipe_type": "main",
  "brief_description": "Filipino sinigang with pork and chicken.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saute pork until most of the fat renders. Add chicken. Continue saut\u00e9ing until the exterior of the chicken turns light brown in color."
    },
    {
      "position": 2,
      "text": "Add onion, taro, daikon radish, and half of the tomato. Cook for 5 minutes. Remove the chicken and set it aside."
    },
    {
      "position": 3,
      "text": "Pour water into the cooking pot. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Sinigang sa Sampaloc Recipe Mix. Cover the pot and continue cooking in low heat until the pork gets tender (note: around 1 hour)."
    },
    {
      "position": 5,
      "text": "Add the chicken back into the pot. Cook for 15 minutes."
    },
    {
      "position": 6,
      "text": "Put the long green pepper, string beans, okra, and eggplant. Cook for 8 minutes."
    },
    {
      "position": 7,
      "text": "Add the remaining tomatoes. Season with fish sauce and ground black pepper."
    },
    {
      "position": 8,
      "text": "Add the kangkong leaves. Cover the pot. Turn the heat off and let it stay for 2 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve hot with rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
