  "id": "11379ba4-36d2-5322-a17d-6e5d2d481335",
  "slug": "no-bake-lasagna-pinoy-style",
  "name": "No Bake Lasagna",
  "recipe_type": null,
  "brief_description": "This is a recipe for No Bake Lasagna Filipino Style.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the meat sauce by searing the ground pork until light brown. Do this by heating a pan and then add the ground pork. Let the pork cook for 30 seconds and then stir for 15 seconds while trying to separate the meat from each other. Let the side that touches the pan cook for another 30 seconds and then repeat the process until the pork turns light to medium brown."
    },
    {
      "position": 2,
      "text": "Add onion. Saute for 30 seconds."
    },
    {
      "position": 3,
      "text": "Add garlic. Continue to cook until onion becomes soft."
    },
    {
      "position": 4,
      "text": "Add chopped parsley and dried basil. Stir."
    },
    {
      "position": 5,
      "text": "Pour tomato sauce into the pan. Stir. Let boil. Cover and cook in low heat for 15 minutes."
    },
    {
      "position": 6,
      "text": "Add tomato paste. Stir. Cover and cook in low heat for 12 minutes or until the sauce thickens."
    },
    {
      "position": 7,
      "text": "Add salt and ground black pepper. Set the meat sauce aside."
    },
    {
      "position": 8,
      "text": "Start to prepare the white sauce by melting the butter in a sauce pan."
    },
    {
      "position": 9,
      "text": "Gradually add the flour. Stir the mixture continuously until it forms a huge lump."
    },
    {
      "position": 10,
      "text": "Pour milk into the sauce pan. Stir thoroughly until the mixture becomes thick and smooth."
    },
    {
      "position": 11,
      "text": "Add cheese. Stir until melted. Set the white sauce aside."
    },
    {
      "position": 12,
      "text": "Boil water in a cooking pot. Add salt. Boil the lasagna for 10 minutes or use the instruction from the package."
    },
    {
      "position": 13,
      "text": "Let the lasagna cool down by discarding the water. You can add tap water to it so that it won't be soggy and for it to cool down quickly."
    },
    {
      "position": 14,
      "text": "Assemble the lasagna in a square or rectangular baking pan by pouring the meat sauce into the pan. Top with a layer of lasagna (around 4 pieces). Top the lasagna layer with meat sauce, followed by the white sauce. Continue the process by doing the same step until the lasagna is consumed. Finalize the topping by adding shredded cheese on top."
    },
    {
      "position": 15,
      "text": "Microwave for 8 to 10 minutes."
    },
    {
      "position": 16,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 15,
