  "id": "68a41523-d3b2-5614-853c-a0db81096191",
  "slug": "ground-beef-tostada",
  "name": "Ground Beef Tostada",
  "recipe_type": null,
  "brief_description": "Ground Beef Tostada is a delicious taco like dish. It is great for all occasions. Get to know how to prepare this dish through this recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan and put-in the cooking oil."
    },
    {
      "position": 2,
      "text": "Add the ground beef and cook until the color turns light brown."
    },
    {
      "position": 3,
      "text": "Put-in the taco seasoning and water. Stir, let boil, and cook for 15 to 20 minutes. Note: add water as necessary."
    },
    {
      "position": 4,
      "text": "Add the refried beans and cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Sprinkle salt and pepper. Turn the heat off, and then set aside."
    },
    {
      "position": 6,
      "text": "Place the tostada shell in a plate, and then top with cooked ground beef."
    },
    {
      "position": 7,
      "text": "Arrange lettuce, tomatoes, sour cream, and cheese on top of the ground beef."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
