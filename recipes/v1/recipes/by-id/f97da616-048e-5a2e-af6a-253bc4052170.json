  "id": "f97da616-048e-5a2e-af6a-253bc4052170",
  "slug": "sinampalukang-manok",
  "name": "Sinampalukang Manok Recipe",
  "recipe_type": "soup",
  "brief_description": "Sinampalukang Manok is a delicious sour chicken soup recipe boiled with vegetables and souring agents. Tamarind leaves are used to make the soup sour.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute onion and tomatoes."
    },
    {
      "position": 3,
      "text": "When the onions and tomatoes becomes soft, add the chicken and then cook until the color of the outer part turns light brown."
    },
    {
      "position": 4,
      "text": "Pour-in the fish sauce, and then add chicken bouillon. Stir."
    },
    {
      "position": 5,
      "text": "Pour-in water and let boil."
    },
    {
      "position": 6,
      "text": "Add tamarind leaves and sinigang mix powder. Simmer until chicken becomes tender."
    },
    {
      "position": 7,
      "text": "Add the eggplant and long green beans. Cook for 5 to 8 minutes."
    },
    {
      "position": 8,
      "text": "Put-in the spinach and cover the cooking pot. Let the cover stay for 5 to 6 minutes for the residual heat to cook the spinach."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
