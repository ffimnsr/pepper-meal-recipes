  "id": "3b66dbd5-58c2-577f-b04a-57fe9b88b595",
  "slug": "chicken-cordon-bleu-with-dijon-cream-sauce",
  "name": "Chicken Cordon Bleu with Dijon Cream Sauce",
  "recipe_type": null,
  "brief_description": "This is a recipe for Chicken Cordon Bleu with Dijon Cream Sauce",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Place a plastic wrap over a flat surface. Arrange a piece of chicken over the wrap, and then cover the chicken with it. Pound the chicken using a meat tenderizer tool until it flattens."
    },
    {
      "position": 2,
      "text": "Sprinkle salt all over the chicken breast."
    },
    {
      "position": 3,
      "text": "Prepare the filling by putting a slice of cheese and ham over the chicken. Roll the chicken to cover the filling and then seal it by inserting toothpicks into the rolled chicken."
    },
    {
      "position": 4,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 5,
      "text": "Dip the chicken in beaten egg and then roll over the bread crumbs. Do this step twice to make the coating thicker."
    },
    {
      "position": 6,
      "text": "Deep fry for 12 minutes in medium heat. Note. if you need to turn the chicken over to fry the opposite side, you can do so and cook it for 8 minutes. If you will deep while the chicken is fully submerged, 12 minutes should be enough, but feel free to cook no longer than 15 minutes."
    },
    {
      "position": 7,
      "text": "Remove the chicken from the pot. Let it cool down. Slice into serving pieces."
    },
    {
      "position": 8,
      "text": "Prepare the sauce by melting butter in a sauce pan. Add onion. Cook until soft."
    },
    {
      "position": 9,
      "text": "Pour heavy whipping cream. Let boil. Add Dijon mustard. Stir and continue to cook in medium heat until it reduces to half. Add salt to taste."
    },
    {
      "position": 10,
      "text": "Pour sauce over the chicken. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 15,
