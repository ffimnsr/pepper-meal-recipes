  "slug": "upo-guisado-recipe",
  "name": "Upo Guisado Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for upo guisado or sauteed bottle gourd with pork.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic, onion, and tomato"
    },
    {
      "position": 3,
      "text": "Add the pork. Cook for 3 minutes"
    },
    {
      "position": 4,
      "text": "Pour 1 cup water. Let boil. Adjust the heat to medium and then continue to cook until the liquid completely evaporates"
    },
    {
      "position": 5,
      "text": "Add the sliced upo. Stir and then cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Season with ground black pepper and fish sauce."
    },
    {
      "position": 7,
      "text": "Add water. Cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
