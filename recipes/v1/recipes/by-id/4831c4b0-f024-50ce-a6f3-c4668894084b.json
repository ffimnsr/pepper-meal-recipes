  "id": "4831c4b0-f024-50ce-a6f3-c4668894084b",
  "slug": "misua-with-ground-beef-and-zucchini-soup",
  "name": "Misua with Ground Beef and Zucchini Soup",
  "recipe_type": "soup",
  "brief_description": "Misua with Ground Beef and Zucchini soup is a delicious recipe that you ought to try. This recipe makes use of Misua, which are thin flour noodles.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and onion"
    },
    {
      "position": 3,
      "text": "Add the ground beef. Cook until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Put-in the beef cube or powder and then pour-in the water. Stir and let boil. Simmer covered for 15 minutes."
    },
    {
      "position": 5,
      "text": "Add the zucchini and then cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the Misua along with the fish sauce and ground black pepper. Stir. Continue cooking for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Add the quail eggs and green onion. Transfer to a serving bowl."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
