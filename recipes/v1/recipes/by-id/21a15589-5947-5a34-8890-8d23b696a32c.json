{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "21a15589-5947-5a34-8890-8d23b696a32c",
  "slug": "fish-pochero-filipino-fish-and-vegetable-stew",
  "name": "Fish Pochero",
  "recipe_type": "soup",
  "brief_description": "Fish pochero is a delicious Filipino twist on the classic pochero recipe. This version uses tender white fish with fried tilapia, Chinese sausage, chickpeas, and fresh vegetables simmered in a rich tomato based broth.",
  "cuisine": "Asian Filipino Southeast Asian",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the fish, making sure to get it inside the cavity and on both sides. Let it stay for 5 minutes. This helps draw out moisture and seasons the fish."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a pan over medium high heat. Once the oil is hot (it should shimmer), carefully place the fish in the pan. Fry both sides until golden brown, about 4 to 5 minutes per side. Remove from the pan and set aside on a plate."
    },
    {
      "position": 3,
      "text": "In a clean pan over medium heat, add the diced pork fat. Sear until enough fat renders and you see crispy bits, about 3 to 4 minutes. The fat should be golden and the oil clear."
    },
    {
      "position": 4,
      "text": "Add the crushed garlic and sliced onion. Saut\u00e9 until the onion softens and becomes translucent, about 2 minutes."
    },
    {
      "position": 5,
      "text": "Put in the sliced Chinese sausage and saut\u00e9 for 1 minute to release its oils."
    },
    {
      "position": 6,
      "text": "Stir in the wedged tomatoes and saut\u00e9 until they start to break down and become tender, about 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Mix in the tomato paste and water. Stir everything together and let it come to a boil."
    },
    {
      "position": 8,
      "text": "Drop in the potato chunks once the liquid is boiling. Cook for 3 minutes. The potatoes should start to soften but still hold their shape."
    },
    {
      "position": 9,
      "text": "Toss in the saba banana slices and drained chickpeas. Cook for another 3 minutes. The bananas should be tender but not mushy."
    },
    {
      "position": 10,
      "text": "Add the long green beans and season the broth with fish sauce and ground black pepper to taste. Stir gently."
    },
    {
      "position": 11,
      "text": "Slide in the fried fish carefully. Try not to break it apart. Simmer for 2 minutes to let the fish absorb the flavors."
    },
    {
      "position": 12,
      "text": "Place the pechay on top of everything. Cover the pot and cook for 1 minute. The residual heat will wilt the pechay perfectly."
    },
    {
      "position": 13,
      "text": "Transfer everything carefully to a serving bowl. Serve hot with steamed rice. The broth is perfect for spooning over the rice, so don't leave any behind!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 15,
