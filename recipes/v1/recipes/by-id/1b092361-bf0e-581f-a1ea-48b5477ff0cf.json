  "id": "1b092361-bf0e-581f-a1ea-48b5477ff0cf",
  "slug": "vegetable-okoy",
  "name": "Vegetable Okoy",
  "recipe_type": "appetizer",
  "brief_description": "Crispy fried battered Calabaza squash, carrot, and onion with moringa leaves, served with spicy vinegar dip.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the kalabasa and carrot into matchstick pieces."
    },
    {
      "position": 2,
      "text": "Combine all the sliced vegetables including the malunggay leaves in a mixing bowl. Toss to blend."
    },
    {
      "position": 3,
      "text": "Make the batter by beating an egg on a separate bowl. Add water. Mix well. Gradually add flour and cornstarch while mixing. Add Maggi Magic Sarap. Whisk until the texture of the batter smoothens."
    },
    {
      "position": 4,
      "text": "Combine the batter with the vegetables. Fold until the vegetables are completely coated with the batter."
    },
    {
      "position": 5,
      "text": "Make the dipping sauce by combining all dipping sauce ingredient in a bowl. Stir until blended."
    },
    {
      "position": 6,
      "text": "Heat oil in a pan. Scoop around \u00bc cup of mixture and place it on a saucer or small bowl. Slide the mixture into the pan. Fry until golden brown and crispy. Flip the okoy and do the same to the opposite side. Remove from the pan and place on a plate lined with a paper towel. Perform the same step until the entire mixture is consumed."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with dipping sauce. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
