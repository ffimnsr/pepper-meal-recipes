  "id": "81927a94-0628-5ce6-ac71-8d7f22b5c8d9",
  "slug": "binagoongang-baboy-recipe-pork-in-shrimp-paste",
  "name": "Binagoongang Baboy Recipe (Pork in Shrimp Paste)",
  "recipe_type": null,
  "brief_description": "Binagoongang Baboy or Pork in Shrim Paste is a Filipino Pork dish that is perfect to eat with lots and lots of white rice. the name of this dish literally means pork in shrim paste or pork cooked with shrimp paste. \"Bagoong\" is a Filipino (Tagalog) term for Shrimp paste, while pork is called \"baboy\".",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Pan fry the sliced eggplants for 3 minutes per side. Remove the fried eggplants and place in a plate. Set aside."
    },
    {
      "position": 3,
      "text": "On the same pan, add the garlic, tomato, and onion. Saute for 5 minutes or until both onions and tomatoes are soft.Note: add more cooking oil if needed."
    },
    {
      "position": 4,
      "text": "Add the pork slices in. Cook until the color of the pork turns light brown."
    },
    {
      "position": 5,
      "text": "Pour-in the beed broth. Let boil. Cover and simmer for 45 to 60 minutes or until the pork is tender."
    },
    {
      "position": 6,
      "text": "Add the shrimp paste. Stir and cook in low to medium heat for 3 to 5 minutes. Note: there should still be some liquid in the pot. If the pot is almost dry, add 1 cup of beef broth."
    },
    {
      "position": 7,
      "text": "Add the fried eggplant."
    },
    {
      "position": 8,
      "text": "Tranfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
