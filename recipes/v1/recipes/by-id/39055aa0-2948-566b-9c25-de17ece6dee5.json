  "id": "39055aa0-2948-566b-9c25-de17ece6dee5",
  "slug": "classic-beef-morcon-recipe",
  "name": "Classic Beef Morcon Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Classic Beef Morcon",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Flatten the steak by pounding with a meat tenderizer tool."
    },
    {
      "position": 2,
      "text": "Combine steak and the steak marinade ingredients. Mix well. Make sure that the steak (beef) is coated all over. Let it stay for at least 10 minutes."
    },
    {
      "position": 3,
      "text": "Slice the steak into 6 x 5 inch pieces. Put a slice of beef frank, pickle, carrot, and wedged boiled egg in one side of the steak. Roll the steak until a cylindrical shape is formed. Secure by tying a kitchen twine. This will be your beef morcon. Set aside. Perform this step until all the steak is consumed."
    },
    {
      "position": 4,
      "text": "Heat 5 tablespoons of oil in a pan. Dredge the rolled beef morcon in all-purpose flour. Pan-fry all the sides for 1 minute or until it turns light to medium brown. Set aside."
    },
    {
      "position": 5,
      "text": "On a clean pan, heat the remaining 3 tablespoons of cooking oil."
    },
    {
      "position": 6,
      "text": "Saut\u00e9 garlic and onion"
    },
    {
      "position": 7,
      "text": "Add the diced tomato and tomato sauce."
    },
    {
      "position": 8,
      "text": "Pour-in water and add Knorr Beef Cube. Stir. Let boil."
    },
    {
      "position": 9,
      "text": "Put the pan-fried morcon in the pan. Cover and then simmer for 50 to 60 minutes. Add water if the sauce starts to dry out."
    },
    {
      "position": 10,
      "text": "Sprinkle salt and pepper. Stir."
    },
    {
      "position": 11,
      "text": "Turn the heat off. Let the beef morcon cool down. Slice into serving pieces."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Top with remaining sauce."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
