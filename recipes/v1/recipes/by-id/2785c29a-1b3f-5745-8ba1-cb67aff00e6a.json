  "id": "2785c29a-1b3f-5745-8ba1-cb67aff00e6a",
  "slug": "panlasang-pinoy-bibingkang-galapong",
  "name": "Panlasang Pinoy Bibingkang Galapong",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Bibingkang Galapong",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 370F (188C)."
    },
    {
      "position": 2,
      "text": "Combine glutionous and Jasmine rice in a bowl. Pour water into it and let it soak overnight."
    },
    {
      "position": 3,
      "text": "Drain remaining water. Pour the soaked rice into a food processor and add coconut cream. Cover and turn the unit on. Continue until the mixure becomes smooth."
    },
    {
      "position": 4,
      "text": "Add eggs, salt, sugar, baking powder, and 4 tablespoons of melted butter. Cover and activate the food processor for 1 to 2 minutes or until all the ingredients are well blended."
    },
    {
      "position": 5,
      "text": "Line a clean piece of pre-cut fresh banana leaf over a round baking pan (9\" diameter). Pour the mixture into the pan. Bake in the oven for 35 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven and let it cool down. Tranfer to a plate. Brush the remaining butter on top and sprinkle with grated cheddar cheese (you can also use shredded coconut)."
    },
    {
      "position": 7,
      "text": "Serve with a cup of coffee. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
