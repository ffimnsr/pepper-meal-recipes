  "id": "2fc44a6c-5ffb-51e7-b327-43183bf703c1",
  "slug": "easy-lechon-paksiw",
  "name": "Lechon Paksiw",
  "recipe_type": "main",
  "brief_description": "Leftover roasted pig cooked in vinegar and native Filipino gravy.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Chop the lechon into serving pieces. Place in a large cooking pot and add water. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add garlic, onion, whole peppercorn, and dried bay leaves. Cover the pot. Boil for 5 minutes."
    },
    {
      "position": 3,
      "text": "Add Knorr Pork Cube and vinegar. Cover the pot. Let boil. Adjust the heat between low to medium. Cook for 30 minutes."
    },
    {
      "position": 4,
      "text": "Pour lechon sauce into the pan. Stir. Cook for 15 minutes."
    },
    {
      "position": 5,
      "text": "Add sugar and season with salt. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve with rice."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
