  "id": "bb5daa7f-4d40-556d-a384-aebca652741c",
  "slug": "filipino-chicken-adobo-recipe",
  "name": "Chicken Adobo",
  "recipe_type": "main",
  "brief_description": "Chicken Adobo is a classic Filipino dish where chicken is marinated in soy sauce and garlic, pan-fried, then simmered with vinegar, peppercorns, and bay leaves until tender.",
  "cuisine": "Asian Filipino Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Crush the garlic using a mortar and pestle."
    },
    {
      "position": 2,
      "text": "Combine the chicken, soy sauce, and crushed garlic in a large bowl. Mix well and marinate for at least 1 hour. The longer the chicken marinates, the better the flavor."
    },
    {
      "position": 3,
      "text": "Separate the chicken from the garlic and marinade. Set the garlic and marinade aside."
    },
    {
      "position": 4,
      "text": "Heat a cooking pot and pour in 3 tablespoons of cooking oil."
    },
    {
      "position": 5,
      "text": "Once the oil gets hot, pan-fry the marinated chicken for 2 minutes per side."
    },
    {
      "position": 6,
      "text": "Remove the chicken from the pot and set it aside."
    },
    {
      "position": 7,
      "text": "Pour the remaining cooking oil into the same pot."
    },
    {
      "position": 8,
      "text": "Add the garlic from the marinade and saut\u00e9 until it starts to brown."
    },
    {
      "position": 9,
      "text": "Return the chicken to the pot."
    },
    {
      "position": 10,
      "text": "Add the remaining marinade, whole peppercorns, and dried bay leaves."
    },
    {
      "position": 11,
      "text": "Pour in the water and let it boil."
    },
    {
      "position": 12,
      "text": "Cover the pot and simmer for 30 minutes, or until the chicken becomes tender."
    },
    {
      "position": 13,
      "text": "Pour in the vinegar. Let it boil before stirring, then continue simmering for 15 minutes."
    },
    {
      "position": 14,
      "text": "Add the sugar and salt as needed. Stir, then turn the heat off."
    },
    {
      "position": 15,
      "text": "Transfer to a serving plate. Serve hot with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
