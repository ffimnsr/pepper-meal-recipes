  "id": "85d2432d-310d-53d7-aaf2-33b026130725",
  "slug": "how-to-make-potato-and-green-bean-salad",
  "name": "Potato and Green Bean Salad Recipe",
  "recipe_type": "salad",
  "brief_description": "Potato and Green Bean Salad is one of the best tasting side dish that I tried. It compliments well to steak and even grilled salmon.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Put-in the potatoes and boil for 15 to 18 minutes."
    },
    {
      "position": 3,
      "text": "Remove the potatoes and set aside to cool down. Meanwhile, place the green beans in boiling water and cook for 4 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Remove the green beans from the cooking pot and place in a bowl with cold water. This will retain the color and texture of the beans."
    },
    {
      "position": 5,
      "text": "In a large bowl, combine olive oil, Dijon mustard, dill, white wine vinegar, salt, and ground black pepper then mix well."
    },
    {
      "position": 6,
      "text": "Slice the boiled potatoes into quarters then toss them along with the green beans in the mixture."
    },
    {
      "position": 7,
      "text": "Refrigerate for at least 1 hour."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate then serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
