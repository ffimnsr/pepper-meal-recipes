  "id": "40fdb23b-12ab-52ce-9c77-9f674dbda7e0",
  "slug": "how-to-make-spaghetti-with-meat-sauce",
  "name": "Spaghetti with Meat Sauce",
  "recipe_type": "main",
  "brief_description": "Discover How to Make Spaghetti Noodles with Meat Sauce through this comprehensive recipe with instructional cooking video.",
  "cuisine": "italian",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the spaghetti noodles according to package instructions until al dente. Drain the water and arrange in a serving plate. Set aside."
    },
    {
      "position": 2,
      "text": "Start to make the meat by browning the beef. Do this by placing the meat in a deep pan. Turn-on the heat to medium. Cook the beef until brown while stirring once in awhile."
    },
    {
      "position": 3,
      "text": "Add-in the olive oil, garlic, onion, and carrots. Stir and cook until the onion turns soft."
    },
    {
      "position": 4,
      "text": "Pour-in the tomato puree. Stir and let boil. Cover and simmer for 15 to 20 minutes. Add water if the sauce starts to reduce."
    },
    {
      "position": 5,
      "text": "Remove the cover and put the heat back to medium. Add the oregano, thyme, basil, salt, and ground back pepper. Stir and cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the tomato paste. Stir and cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Top the spaghetti meat sauce over the cooked spaghetti noodles. Sprinkle Parmesan cheese on top."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
