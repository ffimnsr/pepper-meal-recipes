  "id": "4ebcf3d6-ec36-527c-bd60-69e2e2765f61",
  "slug": "oatmeal-cookies",
  "name": "Oatmeal Cookies",
  "recipe_type": "dessert",
  "brief_description": "Simple Oatmeal Cookies with raisins, ground cinnamon, and light brown sugar.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine flour, baking powder, ground cinnamon, and salt then mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Put the butter in a mixing bowl then cream using an electric mixer."
    },
    {
      "position": 3,
      "text": "Gradually add the light brown sugar while beating. Continue beating until the texture becomes fluffy."
    },
    {
      "position": 4,
      "text": "Add-in the vanilla extract then continue mixing for 2 to 3 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the egg then beat in low-speed for another minute."
    },
    {
      "position": 6,
      "text": "Gradually add the oats and mix until fully distributed."
    },
    {
      "position": 7,
      "text": "Gradually add the dry ingredient mixture (flour, baking powder, salt, ground cinnamon) then mix again."
    },
    {
      "position": 8,
      "text": "Add the raisins and incorporate with the other ingredients."
    },
    {
      "position": 9,
      "text": "Preheat the oven to 350 degrees Fahrenheit."
    },
    {
      "position": 10,
      "text": "Place a wax or parchment paper on top of the cookie sheet or baking tray. Scoop some of the mixture and arrange on top of the wax/parchment paper. Flatten the mixture to a thickness of about 1/2 inch."
    },
    {
      "position": 11,
      "text": "Bake for 10 to 12 minutes."
    },
    {
      "position": 12,
      "text": "Remove the cookie from the oven and let cool for a few minutes."
    },
    {
      "position": 13,
      "text": "Transfer to a cooling grid to completely cool."
    },
    {
      "position": 14,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 12,
