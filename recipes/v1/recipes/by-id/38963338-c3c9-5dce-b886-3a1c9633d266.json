{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "38963338-c3c9-5dce-b886-3a1c9633d266",
  "slug": "how-to-cook-mongolian-beef",
  "name": "Mongolian Beef Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Easy Mongolian Beef. It involves stir-frying pre-fried beef slices with a thick sweet sauce. You can enjoy this dish with warm white rice.",
  "cuisine": "Chinese-American",
  "instructions": [
    {
      "position": 1,
      "text": "Season beef with salt and pepper. Mix using your clean hands."
    },
    {
      "position": 2,
      "text": "Add 4 tablespoons cornstarch. Continue to mix until all ingredients are well blended. Let it sit for 12 to 15 minutes so that the meat can absorb the flavors from the seasonings."
    },
    {
      "position": 3,
      "text": "Heat oil on a wok or pan. Fry one side of the beef for a maximum of 1 minute. Turn it over to fry the other side using the same maximum time. Remove the fried beef from the wok and arrange in a plate lined with paper towels. Set aside."
    },
    {
      "position": 4,
      "text": "Start to make the Mongolian beef sweet sauce by pouring 3 tablespoons of oil used to fry beef on a wok. Quickly saute garlic and ginger."
    },
    {
      "position": 5,
      "text": "Pour soy sauce. Let boil."
    },
    {
      "position": 6,
      "text": "Add brown sugar. Stir until sugar dissolves completely."
    },
    {
      "position": 7,
      "text": "Pour water. Stir and let boil. Continue to cook in medium heat for 3 minutes."
    },
    {
      "position": 8,
      "text": "Combine 1 tablespoon of cornstarch with 1/4 cup water. Stir until well blended. Pour half of the mixture into the sauce. Stir until sauce thickens. Add the remaining cornstarch mixture if the sauce needs to be thickened more. Pour sauce into a bowl. Set aside."
    },
    {
      "position": 9,
      "text": "Heat 2 tablespoons of the oil used to fry beef on a clean wok. Stir fry the fried beef for 30 seconds. Add half of the green onions. continue to stir fry for a minute."
    },
    {
      "position": 10,
      "text": "Pour Mongolian beef sauce into the wok. Stir-fry until the beef slices are completely coated with sauce. Add remaining green onions. Continue to cook for 1 minute."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
