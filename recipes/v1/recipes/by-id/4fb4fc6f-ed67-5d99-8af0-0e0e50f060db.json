  "id": "4fb4fc6f-ed67-5d99-8af0-0e0e50f060db",
  "slug": "easy-sweet-and-sour-sauce",
  "name": "Easy Sweet and Sour Sauce",
  "recipe_type": "dessert",
  "brief_description": "Sweet and Sour Sauce is staple in Asian Cuisine. There are many ways to make this sauce and it also has many uses.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a saucepan. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add sugar, ketchup, and vinegar. Let the mixture boil once more. Stir using a small ladle."
    },
    {
      "position": 3,
      "text": "Add the pineapple, onion, and bell peppers. Cover and simmer for 12 to 15 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in the cornstarch diluted in water. Stir."
    },
    {
      "position": 5,
      "text": "Once the texture gets thick, turn off the heat. Transfer the sauce to a bowl or gravy boat. You can also let it cool down and secure in ball jars. This can be refrigerated or placed in the freezer for future use."
    },
    {
      "position": 6,
      "text": "Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
