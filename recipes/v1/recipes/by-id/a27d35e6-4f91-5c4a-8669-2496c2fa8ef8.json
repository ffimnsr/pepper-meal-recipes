  "id": "a27d35e6-4f91-5c4a-8669-2496c2fa8ef8",
  "slug": "cheesy-crab-and-corn-nachos",
  "name": "Cheesy Crab and Corn Nachos",
  "recipe_type": null,
  "brief_description": "This is a recipe for Cheesy Crab and Corn Nachos",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the cheese sauce by melting butter in a sauce pan."
    },
    {
      "position": 2,
      "text": "Stir-in flour. Cook in medium heat while gently stirring for 1 minute."
    },
    {
      "position": 3,
      "text": "Gradually pour water. Continue to stir until the texture becomes smooth."
    },
    {
      "position": 4,
      "text": "Add tomato with chilies, cheese, salt, and cayenne pepper. Stir until all ingredients are well blended. Set aside."
    },
    {
      "position": 5,
      "text": "Preheat oven to 375F"
    },
    {
      "position": 6,
      "text": "Arrange the blue corn tortilla chips over a baking dish or tray. Alternately arrange crab meat and corn. Pour the cheese sauce over and then top with cheddar cheese."
    },
    {
      "position": 7,
      "text": "Bake for 9 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven and top with green onion."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
