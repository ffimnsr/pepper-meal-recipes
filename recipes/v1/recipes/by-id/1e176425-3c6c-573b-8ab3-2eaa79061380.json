  "id": "1e176425-3c6c-573b-8ab3-2eaa79061380",
  "slug": "pickled-papaya-appetize-atsara-achara-atchara-recipe",
  "name": "Atchara (Papaya)",
  "recipe_type": "appetizer",
  "brief_description": "Pickled green papaya",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place the julienned papaya in a large bowl and combine 1/4 cup salt then mix until the salt is well distributed."
    },
    {
      "position": 2,
      "text": "Cover the bowl and place inside the refrigerator overnight (the salt will dehydrate the papaya)."
    },
    {
      "position": 3,
      "text": "Place the julienned papaya in a colander or strainer then rinse with running water."
    },
    {
      "position": 4,
      "text": "Using cheesecloth (or any cloth) as a container, put the rinsed papaya inside the cloth and squeeze until all the liquid comes out."
    },
    {
      "position": 5,
      "text": "Put the papaya back in the large bowl and combine with carrots, garlic, ginger, onions, whole peppercorn, bell pepper, and raisins."
    },
    {
      "position": 6,
      "text": "Heat the saucepan and pour-in the vinegar and bring to a boil."
    },
    {
      "position": 7,
      "text": "Add the sugar and 1 1/2 tsp salt then stir until well dissolved."
    },
    {
      "position": 8,
      "text": "Turn off the heat and allow the syrup to cool down until temperature is low enough to handle."
    },
    {
      "position": 9,
      "text": "Place the combined vegetables and spices in a sterilized airtight jar and pour-in the syrup."
    },
    {
      "position": 10,
      "text": "Seal the jar and place inside the refrigerator for a week (or 5 days minimum to achieve the expected texture and flavor)."
    },
    {
      "position": 11,
      "text": "Serve cold with fried dishes. Share and Enjoy!"
    }
  ],
  "servings": 12,
