  "id": "f35a8d7d-bc8d-5ccb-8b86-11a38845afa3",
  "slug": "asian-grilled-chicken-and-corn",
  "name": "Asian Grilled Chicken and Corn",
  "recipe_type": null,
  "brief_description": "Asian Grilled Chicken and Corn is another grilled chicken recipe that is full of Asian flavors. This dish is best served for lunch.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the soy sauce, sesame oil, grated ginger, lemon rind, sugar, ground black pepper, and salt in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Arrange the chicken leg quarters in a resealable plastic bag. Pour-in the soy sauce mixture. Let the air out of the bag and seal. Marinate for at least 6 hours."
    },
    {
      "position": 3,
      "text": "Heat-up the grill. Grill one side in low heat for 15 minutes. Flip the chicken. Baste using the leftover marinade. Continue to grill the other side for another 15 minutes. You can also grill the corn at this time and brush it with butter."
    },
    {
      "position": 4,
      "text": "Increase the heat to medium. Flip the chicken once more and then grill each side for 5 to 8 minutes while basting. Use a meat thermometer to ensure that the chicken is cooked. You know that its done if the internal temp reaches 165F."
    },
    {
      "position": 5,
      "text": "Remove the chicken and corn from the grill. Transfer to a serving plate."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 60,
  "rest_time_minutes": null,
  "difficulty": "hard",
