  "id": "00cc7919-0433-5fef-96b3-0e086c8f0fdf",
  "slug": "asian-food-dish-steamed-fish-lapu-lapu-recipe",
  "name": "Easy Steamed Fish Recipe",
  "recipe_type": "main",
  "brief_description": "Steamed Fish is a healthy and delicious way to cook your favorite fish. It is best eaten with rice or bread, Give this yummy recipe a try today.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Place the fish over an aluminum foil (the foil must be large enough to cover the entire fish)"
    },
    {
      "position": 2,
      "text": "Stuff the fish with slices of lemon and 2 tbsp ginger strips then securely close the foil."
    },
    {
      "position": 3,
      "text": "Place the foil with fish in a steamer and steam for 20 to 30 minutes (this will depend on the size of the fish)"
    },
    {
      "position": 4,
      "text": "While steaming, heat a saucepan and put-in the lemon juice."
    },
    {
      "position": 5,
      "text": "Add the sugar and stir until it fully dissolves in the lemon juice."
    },
    {
      "position": 6,
      "text": "Add water and bring to a boil."
    },
    {
      "position": 7,
      "text": "Put-in the lemon zest and 1 tbsp ginger strips then simmer until sauce becomes somewhat thick"
    },
    {
      "position": 8,
      "text": "Remove the fish from the steamer and aluminum foil cover and place in a serving plate."
    },
    {
      "position": 9,
      "text": "Pour over the sauce and garnish with cilantro"
    },
    {
      "position": 10,
      "text": "Serve hot. Share and enjoy."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
