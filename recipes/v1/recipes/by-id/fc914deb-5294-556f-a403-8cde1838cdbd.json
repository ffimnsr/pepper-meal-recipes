  "id": "fc914deb-5294-556f-a403-8cde1838cdbd",
  "slug": "turkey-reuben-sandwich",
  "name": "Turkey Reuben Sandwich",
  "recipe_type": null,
  "brief_description": "Reuben sandwich made with sliced turkey with thousand island dressing and sauerkraut",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour-in chicken stock in a bowl and then microwave for 40 seconds."
    },
    {
      "position": 2,
      "text": "Soak the turkey slices on the warm chicken stock."
    },
    {
      "position": 3,
      "text": "Spread the Thousand Island dressing on one side of both bread slices."
    },
    {
      "position": 4,
      "text": "Arrange the soaked turkey slices on top of one rye slice (make sure to let the excess liquid drip before doing this) and then put the sauerkraut on top. Spread evenly."
    },
    {
      "position": 5,
      "text": "Top with Swiss cheese and place the second rye slice on top."
    },
    {
      "position": 6,
      "text": "Grill each side of the sandwich using a grill pan for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 1,
  "cooking_time_minutes": 5,
