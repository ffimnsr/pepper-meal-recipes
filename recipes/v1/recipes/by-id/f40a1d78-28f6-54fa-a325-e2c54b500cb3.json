  "id": "f40a1d78-28f6-54fa-a325-e2c54b500cb3",
  "slug": "creamy-coconut-milk-fish-stew-ginataang-isda-with-eggplant-and-bok-choy",
  "name": "Creamy Coconut Milk Fish Stew (Ginataang Isda with Eggplant and Bok Choy)",
  "recipe_type": "main",
  "brief_description": "Fried galunggong simmered in creamy coconut milk with eggplant, bok choy, malunggay, and aromatics\u2014served hot with rice for a satisfying Filipino stew.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub Maggi Magic Sarap all over the fish. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, brush the sliced eggplants with cooking oil. Heat a pan and cook the eggplants for 2 minutes per side. Remove and set aside."
    },
    {
      "position": 3,
      "text": "Heat the remaining cooking oil in a wok. Fry the fish until both sides are golden brown and crisp. Set aside."
    },
    {
      "position": 4,
      "text": "Using around 3 tablespoons of the cooking oil used to fry the fish, saut\u00e9 ginger, garlic, and onion until the latter softens."
    },
    {
      "position": 5,
      "text": "Pour coconut milk and let it boil."
    },
    {
      "position": 6,
      "text": "Add the vinegar. Simmer for 3 minutes."
    },
    {
      "position": 7,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 8,
      "text": "Add the long green pepper and fried fish. Cover and simmer for 3 minutes."
    },
    {
      "position": 9,
      "text": "Add bok choy, fried eggplant, and malunggay leaves. Cook for 2 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve with warm rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
