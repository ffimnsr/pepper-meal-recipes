  "id": "da0db439-cef1-57b7-a5e9-65dac699d3d3",
  "slug": "loaded-nachos-with-corned-beef",
  "name": "Loaded Nachos Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Nachos with corned beef",
  "cuisine": "American Mexican",
  "instructions": [
    {
      "position": 1,
      "text": "Make the meat sauce by heating the cooking in a pan. Saut\u00e9 onion until it softens. Add CDO Home Style Corned Beef in Pasta Sauce. Cook for 2 minutes. Add taco seasoning. Stir and cook for 2 to 3 minutes. Let it cool down."
    },
    {
      "position": 2,
      "text": "Arrange tortilla chips on a wide plate. Drizzle cheese dip all over and top with meat sauce."
    },
    {
      "position": 3,
      "text": "Spread the remaining topping ingredients over the meat sauce."
    },
    {
      "position": 4,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 15,
