  "id": "38c2d25e-7985-515f-b3a9-bc595a1160e2",
  "slug": "pininyahang-manok-sa-gata",
  "name": "Pininyahang Manok sa Gata",
  "recipe_type": "main",
  "brief_description": "Chicken with pineapple, carrots, and bell pepper stewed in coconut milk.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Marinate the chicken in the pineapple juice from the canned pineapple chunks for 30 minutes to 2 hours."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 3,
      "text": "Saute the onion, tomato, and garlic."
    },
    {
      "position": 4,
      "text": "Add the ground black pepper. Stir."
    },
    {
      "position": 5,
      "text": "Add the chicken pieces one-by-one. Cook until the color turns light brown. Flip the chicken to cook the other side."
    },
    {
      "position": 6,
      "text": "Pour the pineapple juice marinade on the pan. Let boil."
    },
    {
      "position": 7,
      "text": "Add the coconut milk. Stir. Cover and simmer for 40 minutes or until the chicken is tender."
    },
    {
      "position": 8,
      "text": "Add the fish sauce and pineapple chunks. Cook for 5 minutes."
    },
    {
      "position": 9,
      "text": "Put-in the carrots. Cook for another 5 minutes."
    },
    {
      "position": 10,
      "text": "Add the bell peppers. Stir and cook for 3 minutes."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 12,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 30,
