  "id": "8c678189-e98d-595d-9281-33a083834e38",
  "slug": "deviled-egg-recipe",
  "name": "Deviled Egg Recipe",
  "recipe_type": "snack",
  "brief_description": "I had this Deviled Eggs for a snack and it was satisfying. This Simple Deviled Egg recipe will help you make your own with ease. If you are tired of just having boiled eggs, give it a little taste and style by making something like this.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Slice the eggs in half lengthwise. Remove the egg yolk and put it in a bowl."
    },
    {
      "position": 2,
      "text": "Mash the egg yolks using a fork."
    },
    {
      "position": 3,
      "text": "Add the mayonnaise and Dijon mustard. Mix well."
    },
    {
      "position": 4,
      "text": "Arrange the egg whites in a plate. Scoop equal amounts of the mixture into the center of each sliced eggs. Sprinkle some paprika on top."
    },
    {
      "position": 5,
      "text": "Garnish with chopped dill."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
