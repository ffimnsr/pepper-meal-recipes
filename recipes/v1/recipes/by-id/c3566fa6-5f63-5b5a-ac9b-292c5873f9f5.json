  "schema_version": 1,
  "id": "c3566fa6-5f63-5b5a-ac9b-292c5873f9f5",
  "slug": "filipino-skewered-pork-bbq",
  "name": "Filipino Skewered Pork BBQ",
  "recipe_type": null,
  "brief_description": "Skewered Filipino Pork BBQ or simply pork barbecue are skewered marinated pork sliced. These are grilled until the pork is cooked and it is also being basted during the process to add flavor and keep the meat moist. Pork barbecue are better if marinated overnight. This gives the dish extra flavor that makes it more enjoyable\u2026",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine soy sauce, banana ketchup, lemon juice, salt, pepper, garlic powder, and brown sugar in a bowl. Mix well. You can also microwave the mixture for 1 minute (optional). This will melt the sugar and make it easier for the other ingredients to dilute quickly."
    },
    {
      "position": 2,
      "text": "Arrange the sliced pork in a resealable bag or in a bowl. Pour-in the soy sauce mixture. Make sure that the mixture is in room temperature."
    },
    {
      "position": 3,
      "text": "Massage the pork slices and make sure that it is completely soaked in the soy sauce mixture. Seal the bag or cover the bowl. Place inside the refrigerator and marinate for at least 5 hours."
    },
    {
      "position": 4,
      "text": "Skewer the marinated pork slices in a bamboo skewer (this is also known as barbecue stick)."
    },
    {
      "position": 5,
      "text": "Heat-up the grill. Grill each skewered pork for 5 minutes per side in medium heat. Brush some basting sauce on each side before turning it over. Do this cycle twice or until the pork is fully cooked."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with vinegar dip."
    },
    {
      "position": 7,
      "text": "Share and enjoy."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
