  "id": "a3695308-a77f-5578-bd6a-2444d391388e",
  "slug": "pork-giniling-croquette-recipe",
  "name": "Pork Giniling Croquette",
  "recipe_type": "appetizer",
  "brief_description": "Pork Giniling Croquette is a simple appetizer dish made from pork giniling and mashed potato.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine mashed potato and pork giniling in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Add one egg and all-purpose flour. Mix well."
    },
    {
      "position": 3,
      "text": "Beat 2 eggs in a bowl. Arrange the panko breadcrumb in a separate bowl. Scoop around 2 tablespoons of mashed potato and pork giniling mixture and then form a ball-shaped figure using your hand. Dip in beaten egg then dredge or roll on the Panko breadcrumb. Make sure that the ball mixture is coated properly."
    },
    {
      "position": 4,
      "text": "Heat the cooking oil in a cooking pot. Once the oil gets hot, fry the pork giniling croquettes in medium heat until the color turns golden brown. Turn the croquettes over to cook the opposite side."
    },
    {
      "position": 5,
      "text": "Remove from the cooking pot and arrange in a plate lined with paper towel. This will absorb the oil."
    },
    {
      "position": 6,
      "text": "Remove the paper towel from the plate leaving the perfectly cooked pork giniling croquettes in the plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 15,
