  "id": "8fafddbd-07af-5e25-95d6-4bf8ce3eae51",
  "slug": "how-to-cook-sardines-with-misua-recipe",
  "name": "Sardines with Misua Recipe",
  "recipe_type": "soup",
  "brief_description": "Canned sardines and thin flour noodles with sponge gourd soup.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour-in oil."
    },
    {
      "position": 2,
      "text": "When the oil is hot enough, saut\u00e9 garlic and onions."
    },
    {
      "position": 3,
      "text": "Add the sardines including the sauce and cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Put-in fish sauce and ground black pepper then stir."
    },
    {
      "position": 5,
      "text": "Add water and let boil."
    },
    {
      "position": 6,
      "text": "Put-in the misua and cook for 3 to 5 minutes under medium heat."
    },
    {
      "position": 7,
      "text": "Turn-off the heat and transfer to a serving bowl."
    },
    {
      "position": 8,
      "text": "Garnish with toasted garlic and chopped scallions on top."
    },
    {
      "position": 9,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
