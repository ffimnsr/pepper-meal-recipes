  "id": "d511ec46-362c-500a-9b56-d9d01c85d00b",
  "slug": "pineapple-chicken-afritada",
  "name": "Pineapple Chicken Afritada",
  "recipe_type": "main",
  "brief_description": "Chicken stew with pineapple, potato, and carrots.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Add garlic. Continue cooking while stirring until it starts to turn golden brown in color."
    },
    {
      "position": 2,
      "text": "Add onion. Saute until it softens."
    },
    {
      "position": 3,
      "text": "Add chicken. Cook each side for 1 minute or until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Pour the tomato sauce, juice from pineapple chunks, and water into the pan. Stir. Cover the pan."
    },
    {
      "position": 5,
      "text": "Once the liquid starts to boil, add Knorr Chicken Cube and bay leaves. Cover the pan and then adjust the heat to a low setting. Continue cooking for 18 minutes."
    },
    {
      "position": 6,
      "text": "Use a kitchen tong to turn the chicken pieces over. Continue cooking the opposite side for 12 minutes."
    },
    {
      "position": 7,
      "text": "Add pineapple, potato, and carrot. Cook for 10 minutes."
    },
    {
      "position": 8,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 9,
      "text": "Add bell pepper. Cook for 3 to 5 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
