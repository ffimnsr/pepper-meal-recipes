  "id": "7eb83020-7819-5b2e-9711-9f76cdcadcb8",
  "slug": "italian-food-cheese-lasagne-lasagna-recipe",
  "name": "Homemade Lasagna",
  "recipe_type": "main",
  "brief_description": "A comforting baked pasta layered with savory beef sauce, creamy ricotta, and melted mozzarella and Parmesan cheese. The dish suits family gatherings and special meals.",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Soak the lasagna in hot water for 25 minutes. Drain the water and set the lasagna aside."
    },
    {
      "position": 2,
      "text": "Heat olive oil in a cooking pot. Add the ground beef and saut\u00e9 until browned."
    },
    {
      "position": 3,
      "text": "Add the garlic and onion, then saut\u00e9 until the onion softens."
    },
    {
      "position": 4,
      "text": "Add the crushed tomatoes, tomato sauce, chicken broth, and Italian seasoning. Stir well and simmer for 20 minutes while occasionally stirring."
    },
    {
      "position": 5,
      "text": "Add the tomato paste, basil, and half of the parsley. Continue to simmer for 10 minutes while stirring occasionally."
    },
    {
      "position": 6,
      "text": "Season with salt, ground black pepper, and 2 tablespoons of Parmesan cheese. Set aside."
    },
    {
      "position": 7,
      "text": "Make the white sauce by combining the ricotta cheese and egg in a mixing bowl. Mix until smooth, then set aside."
    },
    {
      "position": 8,
      "text": "Preheat your oven to 350\u00b0F."
    },
    {
      "position": 9,
      "text": "Arrange the lasagna in a baking pan by spreading a small amount of meat sauce at the bottom. Lay the lasagna over the sauce and top it with a good amount of meat sauce followed by a layer of white sauce. Spread mozzarella and Parmesan cheese over it. Repeat this step one more time to create 2 layers."
    },
    {
      "position": 10,
      "text": "Finish by arranging the third layer of lasagna and topping it with meat sauce. Sprinkle the remaining parsley along with a generous amount of mozzarella and Parmesan cheeses."
    },
    {
      "position": 11,
      "text": "Bake for 30 minutes."
    },
    {
      "position": 12,
      "text": "Remove from the oven and let it cool down before serving. Serve hot. Share and enjoy."
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 65,
  "preparation_time_minutes": 25,
