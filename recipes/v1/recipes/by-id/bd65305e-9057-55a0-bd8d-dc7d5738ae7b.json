  "id": "bd65305e-9057-55a0-bd8d-dc7d5738ae7b",
  "slug": "batchoy",
  "name": "Batchoy Recipe",
  "recipe_type": "soup",
  "brief_description": "A type of Filipino noodle soup composed of sliced pork, pig&#39;s innards, and fresh miki noodles.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Put-in salt, sugar, onion powder, ground black pepper, and shrimp paste. Cook for a minute."
    },
    {
      "position": 3,
      "text": "Add the pork and cook until tender (about 30 to 45 minutes)"
    },
    {
      "position": 4,
      "text": "Put-in the intestines and liver, and then cook for 6 to 10 minutes."
    },
    {
      "position": 5,
      "text": "Remove the pork, liver, and intestine from the broth (caldo). Set aside."
    },
    {
      "position": 6,
      "text": "Slice the pork into strips."
    },
    {
      "position": 7,
      "text": "Arranged the cooked miki noodles in a single serving bowl."
    },
    {
      "position": 8,
      "text": "Place the strips of pork, liver, and intestine on top of the miki noodles."
    },
    {
      "position": 9,
      "text": "Pour the broth in the bowl, and then garnish with pork cracklings (chicharon), spring onion, and toasted garlic."
    },
    {
      "position": 10,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
