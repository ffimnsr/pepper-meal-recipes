  "id": "f3ba5086-5cb5-5327-8a75-096a2c82ab67",
  "slug": "ampalaya-salad-recipe",
  "name": "Ampalaya Salad Recipe",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for ampalaya salad or bitter gourd salad.It is alaso known as ensaladang ampalaya,",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub the salt all over the sliced bitter gourd. Let it stay for 30 minutes."
    },
    {
      "position": 2,
      "text": "Remove the salt by quickly washing the gourd with running water. Drain the excess liquid."
    },
    {
      "position": 3,
      "text": "Combine vinegar, ground black pepper, sugar, and extra salt (if needed) in a bowl. Stir."
    },
    {
      "position": 4,
      "text": "Put-in the bitter gourd, onion, and tomato in a bowl. Mix well."
    },
    {
      "position": 5,
      "text": "Cover the bowl with a cling wrap and then refrigerate for about 3 hours."
    },
    {
      "position": 6,
      "text": "Serve as a side dish for fried fish."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "medium",
