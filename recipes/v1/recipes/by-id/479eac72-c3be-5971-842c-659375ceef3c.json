  "slug": "sugar-cookies-recipe",
  "name": "Sugar Cookie Recipe",
  "recipe_type": "dessert",
  "brief_description": "Baking is a good way to develop family bonding. Making this Sugar Cookie Recipe as a group will develop teamwork and will make your family sweeter.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pre-heat oven to 350 degrees Fahrenheit"
    },
    {
      "position": 2,
      "text": "Combine flour, baking soda, and salt in a mixing bowl then mix together. Set aside."
    },
    {
      "position": 3,
      "text": "Cream butter for a minute using an electric mixer then add sugar and continue creaming for another minute."
    },
    {
      "position": 4,
      "text": "Add egg and vanilla extract then continue mixing in low speed until all ingredients are well incorporated."
    },
    {
      "position": 5,
      "text": "Gradually beat-in the flour mixture and mix (in low speed) for 2 minutes."
    },
    {
      "position": 6,
      "text": "Scoop about 1 to 2 tablespoons of the mixture and roll them into balls."
    },
    {
      "position": 7,
      "text": "Arrange in a backing tray lined with parchment or wax paper."
    },
    {
      "position": 8,
      "text": "Bake for 14 to 16 minutes."
    },
    {
      "position": 9,
      "text": "Let cool using a wire rack then decorate, if desired."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 14,
  "preparation_time_minutes": 5,
