  "id": "e5dbe03d-e893-5135-951b-b4b3811b6b49",
  "slug": "how-to-cook-tender-juicy-rib-eye-steak-using-a-frying-pan",
  "name": "How to Cook Tender Juicy Rib Eye Steak Using a Frying Pan",
  "recipe_type": "side",
  "brief_description": "This recipe will give you a rare rib eye steak. Increase the time to cook each side to get less pink in the middle.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt and pepper on both sides of the steaks. Rub and make sure that all the area are completely covered. Let it stay for 10 minutes"
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 3,
      "text": "Gently fry one side of the steak for 1 minute."
    },
    {
      "position": 4,
      "text": "Turn the steak over to fry the other side. Add garlic and bay leaves and fry for 1 minute. Scoop some butter and oil over the steak while frying."
    },
    {
      "position": 5,
      "text": "Flip the steak to continue to cook the other side. For rare steaks do this step until each side is cooked for a total of 3 minutes. If you do not like some pink in your steak, cook it a little bit longer."
    },
    {
      "position": 6,
      "text": "Remove the steaks from the pan. Lay it fat over a wooden chopping board. Let it rest for 10 minutes."
    },
    {
      "position": 7,
      "text": "Slice the juicy rib eye steaks. Enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 6,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
