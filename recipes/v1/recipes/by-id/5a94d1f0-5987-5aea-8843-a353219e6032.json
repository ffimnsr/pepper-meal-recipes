  "id": "5a94d1f0-5987-5aea-8843-a353219e6032",
  "slug": "flat-rice-cake-palitaw-recipe",
  "name": "Palitaw Recipe",
  "recipe_type": "dessert",
  "brief_description": "Palitaw is a soft and chewy Filipino rice cake made from glutinous rice flour and water. The flat dough pieces are boiled until they float, then rolled in grated coconut and coated with a sweet mixture of sugar and toasted sesame seeds. Serve warm as a merienda or afternoon snack.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the glutinous rice flour and water in a bowl, then mix and knead until a smooth dough forms. The dough should pull away cleanly from the sides of the bowl."
    },
    {
      "position": 2,
      "text": "Scoop about 2 tablespoons of dough and shape it into a ball."
    },
    {
      "position": 3,
      "text": "Flatten the dough gently using the palm of your hands into a thin oval disc, about a quarter inch thick."
    },
    {
      "position": 4,
      "text": "Bring a pot of water to a boil and carefully add the flattened dough pieces, working in batches to avoid overcrowding."
    },
    {
      "position": 5,
      "text": "Once the dough floats to the surface, remove it from the pot using a slotted spoon and let the excess water drip off."
    },
    {
      "position": 6,
      "text": "In a separate bowl, combine the sugar and roasted sesame seeds, then toss to combine."
    },
    {
      "position": 7,
      "text": "Roll each warm rice cake in grated coconut, pressing gently so the coconut sticks, then coat it with the sugar and sesame seed mixture."
    },
    {
      "position": 8,
      "text": "Arrange on a serving plate and serve while still warm. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
