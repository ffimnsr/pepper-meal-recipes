  "id": "963da4fb-4dfc-5d7c-a8a9-87d74de77cfc",
  "slug": "chili-garlic-crab-and-shrimp",
  "name": "Chili Garlic Crab and Shrimp Recipe",
  "recipe_type": null,
  "brief_description": "This is a Filipino version of the classic chili crab recipe. I added shrimp so that this will have a variety of seafood ingredients.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saut\u00e9 the onion, garlic, ginger, and Thai chili pepper."
    },
    {
      "position": 2,
      "text": "Once the onion softens, add shrimp. Cook until the color of the shrimp turns orange. Remove the shrimp and place on clean plate. Set the shrimp aside."
    },
    {
      "position": 3,
      "text": "Continue cooking by adding the crab. Cook while stirring occasionally for 3 to 5 minutes. Note: I am using blue crab for this recipe."
    },
    {
      "position": 4,
      "text": "Pour water into the pot and then add Knorr Chicken Cube. Cover the pot and let the liquid boil."
    },
    {
      "position": 5,
      "text": "Add tomato paste and banana ketchup. Stir. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the shrimp back into the pot. Also add some green onions. Cover the pot and cook for 1 to 2 minutes."
    },
    {
      "position": 7,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 8,
      "text": "Add the beaten egg. Stir."
    },
    {
      "position": 9,
      "text": "Make a slurry by combining cornstarch with 3 tablespoons water. Pour the mixture into the pan. Stir until the sauce thickens."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 70,
  "rest_time_minutes": null,
  "difficulty": "hard",
