  "id": "74c00088-1207-5e5a-b17a-12e46ec074a7",
  "slug": "carne-asada-fried-rice",
  "name": "Carne Asada Fried Rice",
  "recipe_type": null,
  "brief_description": "Fried rice with chopped carne asada and parsley",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine salt and leftover rice. Gently mix until fully incorporated."
    },
    {
      "position": 2,
      "text": "Heat the oil in a wide pan."
    },
    {
      "position": 3,
      "text": "When the oil is hot, put-in the carne asada. Cook for 20 seconds (so that the oil can absorb the flavor)."
    },
    {
      "position": 4,
      "text": "Add the rice and then stir while frying. Cook for 5 to 7 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the ground cumin and dried parsley. Cook while stirring for 8 to 10 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with your main dish."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
