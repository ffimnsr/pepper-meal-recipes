  "id": "082ddf48-4d0e-5776-9ac0-1ab5cac2fef2",
  "slug": "puto-bumbong-recipe",
  "name": "Puto Bumbong Recipe",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Puto Bumbong.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all types of rice in a large mixing bowl. Pour water. Soak for 2 days."
    },
    {
      "position": 2,
      "text": "Drain the water by pouring the contents of the bowl into a large sieve."
    },
    {
      "position": 3,
      "text": "Put the soaked rice in a large food processor. Start to grind the rice until it becomes very fine. Note: It took me around 10 minutes to achieve this consistency."
    },
    {
      "position": 4,
      "text": "Fill your puto bumbong steamer with water halfway through. Apply heat and then let the water boil."
    },
    {
      "position": 5,
      "text": "Meanwhile, fill each bumbong (bamboo tube) with powdered rice. Note: Do not compress the rice so that steam can pass easily."
    },
    {
      "position": 6,
      "text": "Once the water starts to boil rapidly, arrange each bamboo tube on the steamer. Continue to cook until steam comes out of the tube."
    },
    {
      "position": 7,
      "text": "Remove the tube from the steamer. Arrange the contents over a piece of banana leaf. Spread butter all over and then top with freshly grated coconut and muscovado sugar."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 3,
