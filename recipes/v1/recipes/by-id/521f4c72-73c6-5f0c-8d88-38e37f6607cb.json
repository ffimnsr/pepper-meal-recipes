  "id": "521f4c72-73c6-5f0c-8d88-38e37f6607cb",
  "slug": "lechon-carajay-recipe",
  "name": "Lechon Carajay Recipe",
  "recipe_type": null,
  "brief_description": "This is e recipe for Lechon Carajay or Deep Fried Pork Belly",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a cooking pot, bring water to a boil."
    },
    {
      "position": 2,
      "text": "Put-in the garlic, onion, dried bay leaves, and 3 teaspoons of salt. Let boil for 3 minutes."
    },
    {
      "position": 3,
      "text": "Add the pork belly. Cover and boil in medium heat for 40 minutes."
    },
    {
      "position": 4,
      "text": "Remove the boiled pork belly from the cooking pot and place in a clean plate. Let it cool down for a few minutes."
    },
    {
      "position": 5,
      "text": "Rub the remaining salt along with the garlic powder and ground black pepper all over the belly slices. Cover the belly and refrigerate for at least 2 hours (this will let the meat absorb the flavors from the rub)."
    },
    {
      "position": 6,
      "text": "Heat cooking oil in a large cooking pot or a deep fryer. Once the oil gets hot (around 375F), start to deep fry the pork belly per batch. Cook it until the color turns golden brown and the skin gets crisp. Note: be extra careful during this step."
    },
    {
      "position": 7,
      "text": "Remove the belly from the fryer and let the excess oil drip."
    },
    {
      "position": 8,
      "text": "Slice the deep fried lechon carajay into bite sized pieces. Arrange in a serving plate and serve with a dip composed of chopped onion, soy sauce, vinegar, and chili peppers."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 120,
