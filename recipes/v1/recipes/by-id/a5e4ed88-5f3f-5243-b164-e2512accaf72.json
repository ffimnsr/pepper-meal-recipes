  "slug": "green-bean-casserole",
  "name": "Green Bean Casserole Recipe",
  "recipe_type": null,
  "brief_description": "This Green Bean Casserole Recipe is so quick and easy to prepare. This is fit for the holidays and special occasions. Get the details by reading this post.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "In a large bowl. Combine cream of mushroom, sour cream, milk, pepper, and salt.Mix well."
    },
    {
      "position": 3,
      "text": "Add-in beans and 3/4 cups of fried onions. Mix gently and arrange the mixture in a baking pan."
    },
    {
      "position": 4,
      "text": "Bake for 20 minutes."
    },
    {
      "position": 5,
      "text": "Remove from the oven and arrange the remaining fried onions on top. Bake for another 8 to 10 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven and serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
