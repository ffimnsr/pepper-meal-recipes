  "schema_version": 1,
  "id": "3c884139-9246-5322-9679-9f2fded3a54e",
  "slug": "crab-misua-patola",
  "name": "Crab with Misua and Patola",
  "recipe_type": "soup",
  "brief_description": "Crab with Misua and Patola is a simple yet flavorful Filipino soup dish. This can be prepared using any type of edible crab, some Chinese vermicelli noodles (also called misua or miswa), and young loofah (or patola). The crab and fish sauce gives this dish its distinct taste.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute the garlic and ginger."
    },
    {
      "position": 3,
      "text": "Add the onion. Cook until the onion becomes soft."
    },
    {
      "position": 4,
      "text": "Add-in the crabs. Pour-in the fish sauce and add water . Let it boil."
    },
    {
      "position": 5,
      "text": "Cover and simmer for 15 minutes."
    },
    {
      "position": 6,
      "text": "Sprinkle some ground black pepper and add the patola. Let the water reboil. Cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Put-in the misua noodles. Stir and cook for 1 minute."
    },
    {
      "position": 8,
      "text": "Add the green onions. Cook for 1 to 2 minutes more."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
