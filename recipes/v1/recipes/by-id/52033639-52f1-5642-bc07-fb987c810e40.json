  "id": "52033639-52f1-5642-bc07-fb987c810e40",
  "slug": "grilled-chicken-salad-recipe",
  "name": "Grilled Chicken Salad",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for Grilled Chicken Salad",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the dressing by combining olive oil, white wine vinegar, Dijon mustard, and salt in a mixing bowl. Stir well."
    },
    {
      "position": 2,
      "text": "Pour half of the mixture on the chicken breasts and ensure that all sides of the chicken are coated. Marinate for 30 minutes to 1 hour."
    },
    {
      "position": 3,
      "text": "Toss mixed greens, carrots, and grape tomatoes on the remaining dressing then arrange in a serving plate. Set aside."
    },
    {
      "position": 4,
      "text": "Grill the chicken for about 5 to 8 minutes per side."
    },
    {
      "position": 5,
      "text": "Remove from the grill and slice the chicken breasts lengthwise."
    },
    {
      "position": 6,
      "text": "Arrange the chicken slices on top of the salad."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "medium",
