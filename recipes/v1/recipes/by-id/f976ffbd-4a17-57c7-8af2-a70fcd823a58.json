  "id": "f976ffbd-4a17-57c7-8af2-a70fcd823a58",
  "slug": "relyenong-tahong-stuffed-mussels",
  "name": "Relyenong Tahong (Stuffed Mussels)",
  "recipe_type": "appetizer",
  "brief_description": "Relyenong Tahong or Stuffed Mussels make a great appetizer. This can also be enjoyed as a main dish with rice and ketchup.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, combine all the ingredients. Mix well until everything is blended."
    },
    {
      "position": 2,
      "text": "Scoop around 1 to 1 1/2 tablespoons of mixture and stuff it into the mussels. Do this step until all the mussels have stuffings."
    },
    {
      "position": 3,
      "text": "Arrange the stuffed mussels on a baking tray."
    },
    {
      "position": 4,
      "text": "Preheat oven to 370F."
    },
    {
      "position": 5,
      "text": "Place the tray with stuffed mussels in the oven. Bake for 30 to 40 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven and arrange in a serving plate."
    },
    {
      "position": 7,
      "text": "Serve with banana ketchup."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 15,
