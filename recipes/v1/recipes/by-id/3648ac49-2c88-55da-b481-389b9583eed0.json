  "id": "3648ac49-2c88-55da-b481-389b9583eed0",
  "slug": "roast-beef-sandwich-recipe",
  "name": "Easy Roast Beef Sandwich",
  "recipe_type": "soup",
  "brief_description": "There is nothing like a good roast beef sandwich for lunch. Some like it with a thick and rich soup while others enjoy it better with potato chips.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Toast the bread slices using a bread or oven toaster."
    },
    {
      "position": 2,
      "text": "Combine honey mustard dressing with mayonnaise. Mix well. Spread equally on one side of each toasted bread."
    },
    {
      "position": 3,
      "text": "Arrange the lettuce on top of one bread slice, side with spread facing up. Top with Swiss cheese and roast beef slices."
    },
    {
      "position": 4,
      "text": "Finish by placing the other slice of bread on top of the roast beef, side with spread facing down."
    },
    {
      "position": 5,
      "text": "Serve with your favorite fruit juice."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 1,
  "cooking_time_minutes": 2,
  "preparation_time_minutes": 5,
