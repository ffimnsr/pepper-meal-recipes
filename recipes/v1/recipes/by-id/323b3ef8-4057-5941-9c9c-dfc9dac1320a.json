  "id": "323b3ef8-4057-5941-9c9c-dfc9dac1320a",
  "slug": "bacon-and-egg-macaroni-salad-with-green-peas-ldc",
  "name": "Bacon and Egg Macaroni Salad with Green Peas",
  "recipe_type": "salad",
  "brief_description": "A classic creamy macaroni salad loaded with crispy bacon, hard-boiled eggs, sweet green peas, and crunchy vegetables in a rich mayonnaise dressing.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add 1 teaspoon salt and macaroni. Cook for 7 minutes. Drain the water and let macaroni cool down. Set aside."
    },
    {
      "position": 2,
      "text": "Combine mayonnaise, remaining salt, ground black pepper, and sugar in a large bowl. Mix well."
    },
    {
      "position": 3,
      "text": "Add onion, green peas, and celery. Mix until well blended."
    },
    {
      "position": 4,
      "text": "Add the macaroni. Gently fold until macaroni gets coated with the dressing."
    },
    {
      "position": 5,
      "text": "Add eggs and bacon. Continue to fold the mixture until all ingredients are well distributed. Note: Add more salt and pepper if needed."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 7,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
