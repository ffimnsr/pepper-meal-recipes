  "id": "cbe70f25-c009-5157-b98b-dcd5fa7cd75a",
  "slug": "nagmamantikang-pork-adobo",
  "name": "Nagmamantikang Pork Adobo",
  "recipe_type": "main",
  "brief_description": "Oily Pork Adobo Recipe.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork and pineapple juice. Mix well. Marinate pork for a minimum of 3 hours."
    },
    {
      "position": 2,
      "text": "Separate the pork from the remaining marinade. Set aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan. Add garlic. Saut\u00e9 until the garlic starts browning."
    },
    {
      "position": 4,
      "text": "Add pork. Saut\u00e9 until the outer part starts to turn light brown."
    },
    {
      "position": 5,
      "text": "Pour soy sauce and add dried bay leaves and cracked peppercorn. Stir. Continue cooking for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour vinegar and remaining pineapple juice marinade. Let boil. Stir. Cover the pan and adjust heat to low. Continue cooking until the pork tenderizes."
    },
    {
      "position": 7,
      "text": "Remove the cover of the pan. Add fish sauce. Stir and continue cooking in medium heat until the sauce completely evaporates."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve with warm rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
