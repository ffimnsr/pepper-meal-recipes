  "id": "1ca5303f-ced4-5ee3-b21e-2cfa3fd96ece",
  "slug": "ox-tripe-stew-callos-recipe",
  "name": "Callos Recipe",
  "recipe_type": "main",
  "brief_description": "Know how to make really, really good food. So it comes as no surprise, then, that this callos recipe is, frankly, fantastic.",
  "cuisine": "Spanish",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a casserole or cooking pot and bring to a boil."
    },
    {
      "position": 2,
      "text": "Put-in the onion, whole peppercorn, ox feet, and ox tripe. Simmer until the ox feet and tripe are extremely tender (you may use a slow cooker or pressure cooker for this step)."
    },
    {
      "position": 3,
      "text": "Remove the ox feet and tripe from the cooking pot and let it cool down for a few minutes. Set the stock aside for later use."
    },
    {
      "position": 4,
      "text": "Cut the ox tripe into bite size pieces and debone the ox feet. Set aside."
    },
    {
      "position": 5,
      "text": "Heat a large wok or pan then pour-in the olive oil."
    },
    {
      "position": 6,
      "text": "Add chorizo de bilbao and bacon then cook in medium heat for 5 to 8 minutes."
    },
    {
      "position": 7,
      "text": "Pour-in the tomato sauce then let boil."
    },
    {
      "position": 8,
      "text": "Add the tender ox feet and tripe and 2 cups of stock (water used to boil ox feet and ox tripe) then simmer for 10 minutes."
    },
    {
      "position": 9,
      "text": "Add salt and pepper then put-in the carrots. Simmer for 3 minutes."
    },
    {
      "position": 10,
      "text": "Put-in the chick peas and bell pepper then simmer for 10 minutes."
    },
    {
      "position": 11,
      "text": "Transfer to a serving dish."
    },
    {
      "position": 12,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 15,
