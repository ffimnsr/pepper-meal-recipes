  "id": "9552551b-32e9-50e5-b123-625dd8e1d578",
  "slug": "cheesy-corned-beef-balls",
  "name": "Cheesy Corned Beef Balls",
  "recipe_type": "breakfast",
  "brief_description": "Here is a way to put a spin on your classic corned beef. These cheesy corned beef balls are here to make your big breakfast even better!",
  "cuisine": "American Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine CDO corned beef, 1 egg, flour, salt, and ground black pepper in a bowl. Mix well until the mixture becomes less sticky. You can add more flour as needed."
    },
    {
      "position": 2,
      "text": "Scoop around 3 tablespoons of the mixture. Stuff the center with mozzarella cheese and then roll the mixture to form a ball-shaped figure."
    },
    {
      "position": 3,
      "text": "Arrange 3 bowls on your working station. Fill the first with 5 tablespoons of flour, the next with 1 beaten egg, and the third bowl with breadcrumbs."
    },
    {
      "position": 4,
      "text": "Dredge the corned beef balls in flour and dip in beaten egg. Roll it in breadcrumbs ensuring that the balls get completely coated."
    },
    {
      "position": 5,
      "text": "Heat cooking oil in a cooking pot. Deep-fry the corned beef balls in a low heat setting until the exterior of the balls turn golden brown."
    },
    {
      "position": 6,
      "text": "Arrange it on a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": null,
