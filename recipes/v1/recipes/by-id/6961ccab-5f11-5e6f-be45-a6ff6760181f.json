  "id": "6961ccab-5f11-5e6f-be45-a6ff6760181f",
  "slug": "longganisa-fried-rice",
  "name": "Longganisa Fried Rice",
  "recipe_type": "breakfast",
  "brief_description": "Longganissa Fried Rice is a fried rice version using Longganisa (Filipino Sausage). This is best eaten during breakfast.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the rice, salt, and garlic powder. Gently mash the mixture until the rice breaks apart and all the ingredients are well distributed."
    },
    {
      "position": 2,
      "text": "Heat the oil in a wide frying pan."
    },
    {
      "position": 3,
      "text": "When the oil becomes hot, put-in the chopped longganisa. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the mashed rice. Cook for 5 minutes in medium heat while stirring once in awhile."
    },
    {
      "position": 5,
      "text": "Make a space in the pan by putting the rice on one side."
    },
    {
      "position": 6,
      "text": "Crack the eggs and then put in the open space of the pan. Let the eggs cook and then chop using the tip of your spatula."
    },
    {
      "position": 7,
      "text": "Gently mix the eggs with the rest of the Ingredients."
    },
    {
      "position": 8,
      "text": "Pour-in the soy sauce. Stir and then cook for one minute."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
