  "id": "6961ccab-5f11-5e6f-be45-a6ff6760181f",
  "slug": "longganisa-fried-rice",
  "name": "Longganisa Fried Rice",
  "recipe_type": "breakfast",
  "brief_description": "Longganisa Fried Rice is a fried rice version using Longganisa (Filipino Sausage). This is best eaten during breakfast.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the rice, salt, and garlic powder. Gently mash the mixture until the rice breaks apart and all the ingredients are well distributed."
    },
    {
      "position": 2,
      "text": "Heat the oil in a wide frying pan."
    },
    {
      "position": 3,
      "text": "When the oil is hot, add the chopped longganisa. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add the mashed rice. Cook for 5 minutes over medium heat, stirring occasionally."
    },
    {
      "position": 5,
      "text": "Push the rice to one side of the pan to create a space."
    },
    {
      "position": 6,
      "text": "Crack the eggs into the open space. Let the eggs cook, then chop them using the tip of your spatula."
    },
    {
      "position": 7,
      "text": "Gently mix the eggs with the rest of the ingredients."
    },
    {
      "position": 8,
      "text": "Pour in the soy sauce. Stir and cook for one minute."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
