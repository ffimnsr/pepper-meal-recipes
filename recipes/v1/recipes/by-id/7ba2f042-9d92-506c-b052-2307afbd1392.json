  "id": "7ba2f042-9d92-506c-b052-2307afbd1392",
  "slug": "ginisang-pechay-at-giniling-with-oyster-sauce",
  "name": "Ginisang Pechay at Giniling with Oyster Sauce",
  "recipe_type": "main",
  "brief_description": "Sauteed bok choy and ground pork with oyster sauce. This simple vegetable dish is best enjoyed with warm white rice. You can also pair it with fried fish.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saute onion and garlic."
    },
    {
      "position": 2,
      "text": "Once the onion softens, add ground pork. Continue to saute until color turns light brown."
    },
    {
      "position": 3,
      "text": "Add oyster sauce and water. Stir. Cook uncovered in medium heat until water reduces to half."
    },
    {
      "position": 4,
      "text": "Put the pechay into the pan. Cover and cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 6,
      "text": "Serve with rice. Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
