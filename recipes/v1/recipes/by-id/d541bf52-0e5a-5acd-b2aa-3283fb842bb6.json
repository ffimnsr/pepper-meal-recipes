  "id": "d541bf52-0e5a-5acd-b2aa-3283fb842bb6",
  "slug": "chicken-salad-with-apples-and-grapes",
  "name": "Chicken Salad with Apples and Grapes",
  "recipe_type": "salad",
  "brief_description": "Chicken Salad with Apples and Grapes is a rich salad recipe that you can have for lunch. This can be eaten as it is or with some salad greens.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the chicken, celery, apple, and grapes in a large mixing bowl."
    },
    {
      "position": 2,
      "text": "Add the mayonnaise and lemon juice. Gently fold the mixture until every ingredient well distributed."
    },
    {
      "position": 3,
      "text": "Sprinkle salt and pepper and then fold until the salt and pepper are distributed."
    },
    {
      "position": 4,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 5,
      "text": "Refrigerate for at least 2 hours."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
