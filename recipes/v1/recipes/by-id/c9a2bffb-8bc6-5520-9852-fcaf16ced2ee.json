  "id": "c9a2bffb-8bc6-5520-9852-fcaf16ced2ee",
  "slug": "easy-porterhouse-steak-recipe",
  "name": "Easy Porterhouse Steak Recipe",
  "recipe_type": null,
  "brief_description": "Porterhouse steak is a type of steak that is cut from the short loin. There is quite a number of recipes for this cut, but the best is still the simplest.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub the olive oil over the steak slices."
    },
    {
      "position": 2,
      "text": "Combine salt and pepper and then rub all over the steak. Let it stand for 30 minutes."
    },
    {
      "position": 3,
      "text": "Heat-up the grill. Arrange the steaks and grill for 8 minutes per side. Note: going beyond 8 minutes will make your steak less juicy."
    },
    {
      "position": 4,
      "text": "Let the grilled steak rest for 5 to 7 minutes."
    },
    {
      "position": 5,
      "text": "Transfer to individual plates and then serve with mashed potato and your favorite steak sauce."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 16,
  "preparation_time_minutes": 10,
