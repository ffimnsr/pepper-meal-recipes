  "id": "e193f7a3-629b-5816-9c32-132a79821078",
  "slug": "steamed-shrimp",
  "name": "Steamed Shrimp",
  "recipe_type": "side",
  "brief_description": "Aside from Halabos na Hipon, Steamed Shrimp is probably one of the easiest and quickest shrimp dishes that you can make. Can you believe that it only takes less than 10 minutes to prepare this dish?",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt, garlic powder, and ground black pepper all over the shrimp. Toss so that the seasoning will coat the shrimp. Let it stay for 5 minutes."
    },
    {
      "position": 2,
      "text": "Arrange the shrimp in a steamer. Pour around 2 cups of water in the steamer and turn on the heat. Steam the shrimp for 3 minutes. If you are using large shrimp or prawn, you can steam for up to 5 minutes. Do not overcook the shrimp."
    },
    {
      "position": 3,
      "text": "Remove the shrimp from the steamer and arrange in a serving plate."
    },
    {
      "position": 4,
      "text": "Serve with spiced vinegar."
    },
    {
      "position": 5,
      "text": "Share and enjoy"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 3,
  "preparation_time_minutes": 5,
