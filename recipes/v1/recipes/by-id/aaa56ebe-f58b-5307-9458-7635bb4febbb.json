  "id": "aaa56ebe-f58b-5307-9458-7635bb4febbb",
  "slug": "healthy-ensaladang-talong-eggplant-salad-recipe",
  "name": "Eggplant Salad",
  "recipe_type": "salad",
  "brief_description": "Ensaladang Talong or Eggplant Salad is a Filipino side dish composed of cooked mashed eggplant, fresh tomato, and onion with vinegar. Bagoong can be added for additional flavor. This makes a great side for grilled and fried dishes.&nbsp;",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Grill the eggplant (or cook directly on stove top)"
    },
    {
      "position": 2,
      "text": "Peel the skin, cut the stem, and mash lightly using a fork."
    },
    {
      "position": 3,
      "text": "Cube the tomatoes and onion."
    },
    {
      "position": 4,
      "text": "Combine the chopped tomatoes, onion, mashed eggplant, salt, ground black pepper, and vinegar then toss to mix the ingredients."
    },
    {
      "position": 5,
      "text": "Top with shrimp paste."
    },
    {
      "position": 6,
      "text": "Serve. Share and Enjoy"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
