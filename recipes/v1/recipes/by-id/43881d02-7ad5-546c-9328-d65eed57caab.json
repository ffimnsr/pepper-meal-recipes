  "id": "43881d02-7ad5-546c-9328-d65eed57caab",
  "slug": "pancit-bato-noodle-soup",
  "name": "Pancit Bato Noodle Soup",
  "recipe_type": "soup",
  "brief_description": "One of the things that sets pancit bato noodle soup from the regular is the special noodles that originated from the province of Bicol.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a soup pot."
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot, saute the pork until the color turns light to medium brown (around 3 to 4 minutes)."
    },
    {
      "position": 3,
      "text": "Pour-in the chicken broth or chicken stock and water. Let boil."
    },
    {
      "position": 4,
      "text": "Cover the soup pot and simmer for 20 minutes or until the pork becomes tender."
    },
    {
      "position": 5,
      "text": "Add-in the snap peas and carrots. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the cabbage and noodles. Stir and cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Sprinkle salt and pepper to taste. At this point, you can add more chicken broth (or water) if necessary."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
