  "id": "0159fa91-5f78-5292-9e59-b0d4b60f10c7",
  "slug": "monggo-guisado-with-dilis-and-malunggay-balatong",
  "name": "Monggo Guisado with Dilis and Malunggay (Mung Bean Stew with Dried Anchovies)",
  "recipe_type": "main",
  "brief_description": "Monggo Guisado with Dilis and Malunggay or Balatong is a delicious Filipino dish composed of mung beans, dried anchovies, and moringa.",
  "cuisine": "filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 5 cups of water in a cooking pot. Add the mung beans and continue to boil for 35 to 40 minutes until the mung beans expand a little and become soft (Note: add more water if needed). Set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a separate cooking pot."
    },
    {
      "position": 3,
      "text": "Saute the garlic and onion. Add the tomato and continue to saute for 2 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the dried anchovies. Stir."
    },
    {
      "position": 5,
      "text": "Add the boiled mung beans. Stir. And continue to saute for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour 1 to 2 cups of water. Let boil. Turn the heat between low and medium and continue to cook for 5 to 8 minutes."
    },
    {
      "position": 7,
      "text": "Add-in the malunggay leaves. Stir."
    },
    {
      "position": 8,
      "text": "Pour-in fish sauce and put some ground black pepper. Stir and cook for 1 to 2 minutes more."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 30,
