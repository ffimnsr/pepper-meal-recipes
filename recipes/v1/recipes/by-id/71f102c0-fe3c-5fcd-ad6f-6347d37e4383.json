  "id": "71f102c0-fe3c-5fcd-ad6f-6347d37e4383",
  "slug": "cheese-pimiento-sandwich-recipe",
  "name": "Cheese Pimiento Sandwich",
  "recipe_type": "snack",
  "brief_description": "How to Make Cheese Pimiento Spread for your sandwich",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the pimiento cheese ingredients. Mix well."
    },
    {
      "position": 2,
      "text": "Trim the edges of the bread slices. Spread a generous amount of pimiento cheese mixture on one side of two bread slices."
    },
    {
      "position": 3,
      "text": "Lay one slice of bread flat on a plate with the pimiento side facing upwards. Put a slice of ham over it and then top with the other slice of bread with pimiento side facing down."
    },
    {
      "position": 4,
      "text": "Cut the bread in half into triangles. Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
