  "id": "d5fc3864-d958-54b4-b259-31ae82a9d9a4",
  "slug": "crusted-pork-chop-adobo-rice-recipe",
  "name": "Crusted Pork Chop with Adobo Rice Recipe",
  "recipe_type": "breakfast",
  "brief_description": "This Crusted Pork Chop with Adobo Rice Recipe was what I made for breakfast. Sometimes, I love having rice for breakfast on big days wherein I expecting every hour to be busy. I need the strength and energy to boost my brain and keep-up with the tasks ahead.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and pepper on the pork chops. Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a frying pan. Once the oil gets hot, adjust the heat to low."
    },
    {
      "position": 3,
      "text": "Arrange the eggs and breadcrumbs in separate bowls. Dip each pork chop into the beaten eggs and then dredge with breadcrumbs. Make sure that the entire pork chops are completely covered."
    },
    {
      "position": 4,
      "text": "Pan fry the pork chops for 6 to 9 minutes per side depending on the thickness of the pork chop. Note: you can increase the heat gradually if needed. Remember that too much heat can burn the outer part of the pork chop while leaving the center raw. Adjust the heat as necessary."
    },
    {
      "position": 5,
      "text": "Remove the fried crusted pork chop from the frying pan. Transfer to a serving plate with Adobo rice and egg."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
