  "id": "1b3a021b-6c4f-54a5-8e5c-83994d6d0277",
  "slug": "pinoy-carbonara-with-ham-and-bacon",
  "name": "Pinoy Carbonara Recipe with Ham and Bacon",
  "recipe_type": "main",
  "brief_description": "One of the most mentioned kinds is the crowd favorite among various ages\u2014 the humble, savory Pinoy Carbonara.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the spaghetti based on package instructions. Drain the water and set it aside."
    },
    {
      "position": 2,
      "text": "Heat pan. Add the bacon. Cook until crispy. Remove from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Melt butter on the same pan where the bacon was cooked. Saute garlic for 10 seconds. Add mushrooms and all-purpose flour. Cook for 30 seconds while stirring."
    },
    {
      "position": 4,
      "text": "Combine Knorr Cream of Mushroom Soup and water. Stir. Pour the mixture into the pan. Continue cooking while stirring until the sauce thickens to your desired consistency."
    },
    {
      "position": 5,
      "text": "Season with parmesan cheese and ground black pepper."
    },
    {
      "position": 6,
      "text": "Turn the heat off and toss the pasta."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate and top with bacon slices and more parmesan cheese."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
