  "id": "150275d7-c826-56b2-b5d4-3f6590cffd56",
  "slug": "ginataang-bitsuelas",
  "name": "Ginataang Bitsuelas",
  "recipe_type": null,
  "brief_description": "Sliced green beans cooked in coconut milk with pork and chili pepper.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute onion, garlic, and ginger."
    },
    {
      "position": 3,
      "text": "Add pork once the onion softens. Cook until the color of the pork turns brown."
    },
    {
      "position": 4,
      "text": "Pour coconut milk into the pot. Let boil."
    },
    {
      "position": 5,
      "text": "Add chili pepper. Stir. Cover the pot and cook between low to medium heat for 15 minutes."
    },
    {
      "position": 6,
      "text": "Add shrimp paste (bagoong alamang). Stir and cook for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Put the sliced long green beans in the pot. Stir and cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Add spinach. Cook for 1 minute."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper. Note: you can add salt if needed."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
