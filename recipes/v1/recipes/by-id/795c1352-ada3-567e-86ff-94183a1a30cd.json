  "id": "795c1352-ada3-567e-86ff-94183a1a30cd",
  "slug": "how-to-cook-gising-gising-green-beans-with-pork-knr-mm",
  "name": "Gising Gising Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Long Green Beans with Ground Pork in Coconut Milk.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the coconut milk by combining Knorr ginataang gulay mix with 2 cups water in a bowl. Stir until well blended. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Saute onion for 30 seconds."
    },
    {
      "position": 4,
      "text": "Add garlic. Continue to saute until onion softens."
    },
    {
      "position": 5,
      "text": "Add ground pork. Cook until it turns light brown."
    },
    {
      "position": 6,
      "text": "Put the chopped chili and bagoong alamang into the cooking pot. Stir and cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Pour the Knorr coconut milk mixture into the pot. Stir. Cover the pot. Let boil, and simmer for 5 to 8 minutes."
    },
    {
      "position": 8,
      "text": "Add long green beans. Stir. Continue to cook for 3 to 5 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
