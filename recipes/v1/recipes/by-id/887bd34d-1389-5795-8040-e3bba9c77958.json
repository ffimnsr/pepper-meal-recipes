  "id": "887bd34d-1389-5795-8040-e3bba9c77958",
  "slug": "ham-fried-rice",
  "name": "Ham Fried Rice",
  "recipe_type": "breakfast",
  "brief_description": "Looking for the same kind of dish? Look no further. You are in for a tasty breakfast treat. This Ham Fried Rice is perfect for you!",
  "cuisine": "Chinese Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan. Fry the eggs until done. Remove and place on a clean plate. Chop using your spatula and set it aside."
    },
    {
      "position": 2,
      "text": "Saute the ham using the remaining cooking oil for 2 minutes. Add onion, bell pepper, and white part of the green onion. Continue to saute for 1 minute."
    },
    {
      "position": 3,
      "text": "Add the cooked rice. Toss until all the ingredients are well blended."
    },
    {
      "position": 4,
      "text": "Pour the soy sauce and sesame oil into the pan. Toss."
    },
    {
      "position": 5,
      "text": "Add the cooked egg and green onions. Toss and continue cooking for 3 minutes."
    },
    {
      "position": 6,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 7,
      "text": "Serve warm. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
