  "id": "cde68dda-170c-51f1-a4a8-80b2b1ac7f47",
  "slug": "inihaw-na-pork-chop",
  "name": "Inihaw na Pork Chop",
  "recipe_type": null,
  "brief_description": "Inihaw na Pork Chop is translated in Filipino as grilled pork chops. Perfectly sliced pork chops with skin and fat on are marinated in soy sauce and lemon",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the marinade by combining the soy sauce, ketchup, garlic, salt, sugar, ground black pepper, and lemon juice in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Arrange the pork chops in a ziploc bag or resealable plastic bag. Pour the marinade inside the bag. Let the air out and seal the bag. Place in the fridge to marinate for 5 to 8 hours."
    },
    {
      "position": 3,
      "text": "Separate the pork chops with the remaining marinade. Place the marinade in a bowl and then add cooking oil. Stir."
    },
    {
      "position": 4,
      "text": "Heat-up the grill. Grill the marinated pork chops in medium heat for 3 to 4 minutes per side while basting with the remaining marinade and oil mixture. Do this step twice and add more grilling time as needed."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 60,
