  "id": "237527ad-9b30-5006-a320-8e851ebd86ec",
  "slug": "root-beer-pork-steak-bistek-tagalog",
  "name": "Root Beer Pork Steak",
  "recipe_type": null,
  "brief_description": "This is a recipe for Root Beer Pork Steak.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange pork chops in a bowl. Squeeze lime juice and pour soy sauce and root beer. Mix well. Marinate for at least 3 hours."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot. Separate the pork from the marinade. Pan fry the marinated pork chops for 2 minutes per side.Remove from the cooking pot. Set aside."
    },
    {
      "position": 3,
      "text": "Saute half of the onion. Add garlic. Continue to cook until the onion becomes soft."
    },
    {
      "position": 4,
      "text": "Pour marinade and add a cup of water. Let boil."
    },
    {
      "position": 5,
      "text": "Add the pan-fried pork chops. Cover the pot and cook between low to medium heat for 30 minutes."
    },
    {
      "position": 6,
      "text": "Turn the pork chops over. Continue to cook (covered) for 20 minutes or until the pork becomes tender."
    },
    {
      "position": 7,
      "text": "Add ground black pepper and remaining onions. Stir. Cover the pot and cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
