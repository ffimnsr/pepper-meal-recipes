  "id": "65f69f10-e8ef-5d61-9943-d6b474cdc7aa",
  "slug": "stir-fried-ginger-beef",
  "name": "Ginger Beef Stir Fry Recipe",
  "recipe_type": null,
  "brief_description": "This ginger beef stir fry recipe is quick and easy. You can prepare a delicious dish for your family's lunch. This recipe recommends tenderloin or sirloin",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the marinade by combining vinegar, soy sauce, 1 tablespoon ginger, honey, and cayenne pepper in a mixing bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Put the beef slices in the bowl with marinade. Make sure that the beef are coated properly. Cover the bowl with a cling wrap. Refrigerate for at least an hour."
    },
    {
      "position": 3,
      "text": "Remove the beef from the fridge and wait until it reaches room temperature."
    },
    {
      "position": 4,
      "text": "Heat the oil in a large frying pan or wok."
    },
    {
      "position": 5,
      "text": "Once the oil is hot, gradually put-in the beef slices one batch at a time depending on the size of your wok. Stir fry for 2 minutes."
    },
    {
      "position": 6,
      "text": "Remove the beef and set aside."
    },
    {
      "position": 7,
      "text": "Using the remaining cooking oil in the pan, saute the garlic, remaining ginger, and scallions for 40 to 60 seconds."
    },
    {
      "position": 8,
      "text": "Add the beef back in the wok and pour-in the sesame oil. Add cumin, salt and pepper.Stir."
    },
    {
      "position": 9,
      "text": "Pour-in the cornstarch diluted in water. continue to stir fry for 1 minute."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
