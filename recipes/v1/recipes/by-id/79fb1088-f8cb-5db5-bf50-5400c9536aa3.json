  "id": "79fb1088-f8cb-5db5-bf50-5400c9536aa3",
  "slug": "how-to-cook-pancit-canton-ala-corazon",
  "name": "How to Cook Special Pancit Canton ala Corazon",
  "recipe_type": null,
  "brief_description": "Most of you already know how to cook pancit canton. I bet that you even have your own version. There are a handful of recipes for pancit canton",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok or wide pan."
    },
    {
      "position": 2,
      "text": "Saute onion and garlic."
    },
    {
      "position": 3,
      "text": "Add the pork. Stir fry for 1 minute."
    },
    {
      "position": 4,
      "text": "Stir-in the chicken liver. Cook for another minute."
    },
    {
      "position": 5,
      "text": "Gently add the shredded chicken and sliced sausage. Stir fry for 2 to 3 minutes."
    },
    {
      "position": 6,
      "text": "Add soy sauce and oyster sauce. Pour-in water and bring to a boil."
    },
    {
      "position": 7,
      "text": "Add the chicken cube. Stir until all ingredients are well blended."
    },
    {
      "position": 8,
      "text": "Put-in the pancit canton. Increase the heat to high. Let the noodles absorb the liquid. Toss the noodles so that the liquid can be absorbed equally."
    },
    {
      "position": 9,
      "text": "Set the heat to medium. Add the snow peas, cabbage, bell peppers and carrots. Gently toss the noodles every 20 seconds for 3 to 5 minutes."
    },
    {
      "position": 10,
      "text": "Add salt and pepper as needed. Toss."
    },
    {
      "position": 11,
      "text": "Serve!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
