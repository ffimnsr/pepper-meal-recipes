  "id": "8676cf39-af25-5b06-a1ef-fb884eae231c",
  "slug": "tuna-macaroni-pasta",
  "name": "Tuna Macaroni Pasta",
  "recipe_type": null,
  "brief_description": "Tuna Macaroni Pasta is an easy tuna pasta recipe that you can make fast. It does not require much of your time to prepare and it tastes good too. I make this for dinner most of the time - on days when I am tired or when I need to have extra time to do other things.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the macaroni according to package instructions. Drain and set aside."
    },
    {
      "position": 2,
      "text": "Preheat oven to 350F."
    },
    {
      "position": 3,
      "text": "In a large mixing bowl, combine tuna (water drained), green peas, parmesan cheese, and alfredo sauce. Stir until well blended."
    },
    {
      "position": 4,
      "text": "Add the macaroni. Toss until the macaroni are coated with the mixture."
    },
    {
      "position": 5,
      "text": "Transfer everything to a baking dish. Top with sharp cheddar cheese."
    },
    {
      "position": 6,
      "text": "Bake for 20 to 25 minutes."
    },
    {
      "position": 7,
      "text": "Remove from the oven. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 15,
