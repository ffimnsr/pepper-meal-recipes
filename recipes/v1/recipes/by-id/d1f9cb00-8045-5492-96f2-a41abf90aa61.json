  "id": "d1f9cb00-8045-5492-96f2-a41abf90aa61",
  "slug": "pork-kaldereta-sa-gata",
  "name": "Kaldereta sa Gata",
  "recipe_type": "main",
  "brief_description": "Stewed Pork with Tomato cooked in coconut milk. This is a crossover between two popular Filipino dishes, Kaldereta and Ginataan. This mildly spicy dish is rich and delicious.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic until color turns light brown."
    },
    {
      "position": 3,
      "text": "Add chopped onion. Cook until soft."
    },
    {
      "position": 4,
      "text": "Add pork belly slices. Saut\u00e9 until outer part turns light brown."
    },
    {
      "position": 5,
      "text": "Put the chopped ripe tomatoes into the pan. Cook until soft."
    },
    {
      "position": 6,
      "text": "Pour pork broth into the pan. Let boil."
    },
    {
      "position": 7,
      "text": "Add chopped Thai chili, liver spread, and dried bay leaves."
    },
    {
      "position": 8,
      "text": "Pour coconut milk. Stir and cover and cook between low to medium heat for 45 to 60 minutes or until tender. Note: add more broth or water if needed."
    },
    {
      "position": 9,
      "text": "Put-in carrots and potato and cook for 7 minutes."
    },
    {
      "position": 10,
      "text": "Add bell peppers. Cook for 7 to 8 minutes."
    },
    {
      "position": 11,
      "text": "Season with fish sauce and crushed whole peppercorn. Continue to cook until sauce thickens."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
