  "id": "be0cce42-edeb-5e60-8f9a-02a024a35532",
  "slug": "crispy-baked-yukon-gold-potato-wedges",
  "name": "Crispy Baked Yukon Gold Potato Wedges",
  "recipe_type": null,
  "brief_description": "Crispy Baked Yukon Gold Potato Wedges is a quick and simple recipe involving Yukon Gold potato. This potato variety is just making its way to stardom, and I can see that it will be known to everyone in not far from now because it is perfect to use in most common potato dishes.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 430F."
    },
    {
      "position": 2,
      "text": "Arrange the potato wedges in a mixing bowl. Pour the olive oil over the potato. Mix well and ensure that the oil coats every potato wedge."
    },
    {
      "position": 3,
      "text": "On a separate bowl, combine bread crumbs, paprika, salt, garlic and onion powder, and oregano. Mix well."
    },
    {
      "position": 4,
      "text": "Pour the bread crumb mixture over the potato. Shake the bowl and ensure that the potato are covered with the breadcrumb mixture."
    },
    {
      "position": 5,
      "text": "Arrange an aluminum foil over a baking tray. Grease with cooking oil spray. Lay the potato over the foil. Bake for 35 to 40 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven and let it cool down. transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
