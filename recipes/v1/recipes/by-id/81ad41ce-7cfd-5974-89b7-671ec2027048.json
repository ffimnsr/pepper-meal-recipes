  "id": "81ad41ce-7cfd-5974-89b7-671ec2027048",
  "slug": "apple-snails-in-coconut-milk-ginataang-kuhol",
  "name": "Apple Snails in Coconut Milk (Ginataang Kuhol)",
  "recipe_type": "appetizer",
  "brief_description": "Apple Snails in Coconut Milk or Ginataang Kuhol is a dish that can be enjoyed either as a main dish along with warm white rice, or as an appetizer.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, saute the garlic and onion. Add the ginger and continue to cook for 1 to 2 minutes."
    },
    {
      "position": 3,
      "text": "Put the apple snails in the cooking pot. Stir and cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add the shrimp paste and chillies. Stir."
    },
    {
      "position": 5,
      "text": "Pour-in the coconut milk. Let boil. Cover and simmer for 30 minutes."
    },
    {
      "position": 6,
      "text": "Add the ground black pepper and spinach. Stir and cook for 5 minutes without covering."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve for pulutan or as a main dish with warm white rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 5,
