  "id": "981d39a8-18df-590a-ac64-cf4c13969290",
  "slug": "sweet-potato-leaves-salad",
  "name": "Sweet Potato Leaves Salad Recipe",
  "recipe_type": "salad",
  "brief_description": "This Sweet Potato Leaves Salad recipe or Ensaladang Talbos ng Kamote makes a good appetizer. This recipe is quick, simple, and delicious.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Place water in a cooking pot and let boil."
    },
    {
      "position": 2,
      "text": "Blanch the sweet potato leaves. This is done by putting the leaves in boiling water. Let it stay for about 20 to 30 seconds. Remove the leaves and submerge in a bowl of cold water for 30 seconds, and let dry."
    },
    {
      "position": 3,
      "text": "In a large bowl, combine sweet potato leaves, tomatoes, ginger, onion, sugar, salt, pepper, and vinegar. Gently toss until all the ingredients are distributed."
    },
    {
      "position": 4,
      "text": "Serve as an appetizer. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "easy",
