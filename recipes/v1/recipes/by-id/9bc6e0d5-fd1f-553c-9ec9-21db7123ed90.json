  "schema_version": 1,
  "id": "9bc6e0d5-fd1f-553c-9ec9-21db7123ed90",
  "slug": "pata-tim-recipe",
  "name": "Pata Tim Recipe",
  "recipe_type": "main",
  "brief_description": "Tender pork leg stew with mushroom and bok choy.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Set turbo broiler to 350F. Broil pata for 20 minutes."
    },
    {
      "position": 2,
      "text": "Boil water in a cooing pot. Add broiled pata. Boil for 15 minutes. Drain water and then wash the pata with running water."
    },
    {
      "position": 3,
      "text": "In a clean cooking pot, arrange the pata. Pour soy sauce, Sesame oil, cooking wine, and water. Add whole peppercorn. Boil for 1 to 2 hours or until pork gets tender. Note: you can use a pressure cooker to tenderize the pork leg quicker."
    },
    {
      "position": 4,
      "text": "Add Knorr Pork Cube, star anise, and Shitake mushrooom. Cook for 20 minutes. Note: add more water if needed. Make sure that there is at least 2 \u00bd cups of sauce in the pot."
    },
    {
      "position": 5,
      "text": "Add sugar. Stir. Pour cornstarch and water mixture. Stir and cook until sauce thickens."
    },
    {
      "position": 6,
      "text": "Add baby bok choy. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": null,
  "cooking_time_minutes": 120,
