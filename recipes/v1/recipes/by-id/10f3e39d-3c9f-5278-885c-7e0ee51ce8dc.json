  "id": "10f3e39d-3c9f-5278-885c-7e0ee51ce8dc",
  "slug": "chicken-caldereta",
  "name": "Chicken Caldereta Recipe",
  "recipe_type": "main",
  "brief_description": "Spicy Filipino Chicken stew with tomato, carrots, and potato.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Start by pan-frying the potato and carrots. Heat oil in a pan. Add potato. Fry each side for 1 minute. Remove from the pan and put in a bowl lined with paper towel. Set aside. Do the same thing with the carrots."
    },
    {
      "position": 2,
      "text": "Using the remaining oil, fry the chicken for 1 \u00bd minutes per side. Remove from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Saute onion and garlic. Add tomato. Continue to saute while stirring until tomato and onion softens."
    },
    {
      "position": 4,
      "text": "Add chicken and pour-in tomato sauce and water. Let boil."
    },
    {
      "position": 5,
      "text": "Stir and then add Knorr Chicken Cube and chili pepper. Cover the pan. Cook between low to medium heat for 15 minutes."
    },
    {
      "position": 6,
      "text": "Turn the chicken pieces over to equally cook the opposite side. Add liver spread. Stir. Cover and cook for 20 minutes."
    },
    {
      "position": 7,
      "text": "Add bell peppers and cheese. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Put the carrots and potatoes into the pan. Continue to cook for 5 to 7 minutes."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper. Serve. Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 55,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
