  "slug": "how-to-cook-bow-tie-pasta-with-vodka-sauce",
  "name": "Bow Tie Pasta with Vodka Sauce Recipe",
  "recipe_type": null,
  "brief_description": "Bow Tie Pasta with Vodka Sauce is a nice tasting Pasta Recipe. Get the details by following our step by step procedures.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the pasta according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Pour-in olive oil in a cooking pot then saut\u00e9 garlic and shallots for about 4 minutes."
    },
    {
      "position": 3,
      "text": "Add-in chicken breast and cook for 3 more minutes."
    },
    {
      "position": 4,
      "text": "Pour-in vodka then cook for about 3 to 4 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in chicken stock and crushed tomatoes and let boil. Simmer for 12 to 15 minutes."
    },
    {
      "position": 6,
      "text": "Add salt, pepper, and cream then stir. Turn-off heat immediately."
    },
    {
      "position": 7,
      "text": "Pour the sauce over the bow tie pasta and drizzle some chopped fresh basil."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
