  "slug": "slow-cook-pork-hock-stew",
  "name": "Slow Cook Pork Hock Stew",
  "recipe_type": null,
  "brief_description": "This is a recipe for slow cooked pata.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the ingredients in a slow cooker. Start with the pork hocks, tomato sauce, bell pepper, tomato, carrots, and the rest of the ingredients."
    },
    {
      "position": 2,
      "text": "Cook in a slow cooker or crock pot for at least 8 hours. Add salt to taste."
    },
    {
      "position": 3,
      "text": "Remove from the slow cooker. Transfer to a serving bowl."
    },
    {
      "position": 4,
      "text": "Serve with warm white rice."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 480,
