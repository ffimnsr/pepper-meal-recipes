  "id": "dfe9d3e5-d7f5-5927-b692-82cc67fa441c",
  "slug": "tofu-sarciado",
  "name": "Tofu Sarciado",
  "recipe_type": null,
  "brief_description": "Tofu Sarciado is a low-fat Filipino dish involving tofu. Extra-firm tofu are fried until brown and then cooked in a sarciado sauce",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a frying pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic, tomato, and onion until then onion become soft."
    },
    {
      "position": 3,
      "text": "Add water and fish sauce. Stir and let boil."
    },
    {
      "position": 4,
      "text": "Add the beaten egg. Quickly stir and then cook for 2 minutes while gradually stirring."
    },
    {
      "position": 5,
      "text": "Add the fried tofu. Sprinkle with ground black pepper. Stir and cook for a minute more."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Top with dried parsley."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
