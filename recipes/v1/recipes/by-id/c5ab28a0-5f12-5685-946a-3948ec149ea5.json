  "id": "c5ab28a0-5f12-5685-946a-3948ec149ea5",
  "slug": "tokwa-and-tuna-recipe",
  "name": "Tokwa and Tuna Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Tokwa and Tuna is an appetizer dish composed of fried extra firm tofu and grilled ahi tuna. A Filipino dish called Tokwa\u2019t Baboy, which is made up of tofu and pork, was the inspiration for this dish. I thought that using ahi tuna will compliment the fried tofu \u2013 and it did.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the vinegar, soy sauce, and sugar in a bowl. Mix well. Microwave for 15 seconds. Set aside."
    },
    {
      "position": 2,
      "text": "Rub 1/4 teaspoon salt and 1/8 teaspoon ground black pepper on the ahi tuna. Let it stay for 15 minutes."
    },
    {
      "position": 3,
      "text": "Heat-up the grill. Grill the tuna for 3 to 5 minutes per side."
    },
    {
      "position": 4,
      "text": "Remove the tuna from the grill. Slice into cubes. Set aside."
    },
    {
      "position": 5,
      "text": "Heat the oil in a deep cooking pot."
    },
    {
      "position": 6,
      "text": "Once the oil is hot, deep fry the tofu (two pieces at a time) until the color turns golden brown."
    },
    {
      "position": 7,
      "text": "Remove the tofu from the cooking pot. Let the excess oil drip. Slice the tofu into cubes. Set aside."
    },
    {
      "position": 8,
      "text": "Combine the tuna, tofu, onion, and green pepper in a mixing bowl. Toss."
    },
    {
      "position": 9,
      "text": "Pour-in the vinegar mixture. Gently toss until all the ingredients are well blended."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate or bowl."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 20,
