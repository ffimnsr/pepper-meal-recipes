  "id": "27172f54-c51d-53e2-b3e7-10a4b0ffde9b",
  "slug": "tofu-and-broccoli-stir-fry",
  "name": "Tofu and Broccoli Stir fry",
  "recipe_type": "main",
  "brief_description": "Tofu and Broccoli stir fry is a tasty dish that you can cook for lunch or dinner. The good thing about this recipe is its ease in preparation",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan and then pour-in 4 tablespoons of cooking oil."
    },
    {
      "position": 2,
      "text": "When the oil becomes hot, fry both sides of the sliced tofu until the texture becomes crisp (about 8 to 10 minutes per side)"
    },
    {
      "position": 3,
      "text": "Remove the tofu from the pan and let cool. Slice into smaller rectangular pieces. Set aside."
    },
    {
      "position": 4,
      "text": "On a clean frying pan, heat the remaining oil."
    },
    {
      "position": 5,
      "text": "Saut\u00e9 the garlic, ginger, and onion"
    },
    {
      "position": 6,
      "text": "Add the fried tofu slices along with the oyster sauce. Stir."
    },
    {
      "position": 7,
      "text": "Put-in the broccoli florets. Stir and then cook for 5 to 8 minutes."
    },
    {
      "position": 8,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 9,
      "text": "Transfer to serving plate."
    },
    {
      "position": 10,
      "text": "Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
