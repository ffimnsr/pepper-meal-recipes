  "id": "493231a3-ea62-51f6-94c4-66b5c849638b",
  "slug": "calderetang-manok",
  "name": "Calderetang Manok",
  "recipe_type": "main",
  "brief_description": "Filipio chicken stew with potatoes, carrots, and capsicum",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Marinate chicken in soy sauce, 1 \u00bd teaspoons garlic powder, \u00bd teaspoon ground black pepper, 1 lime for at least 1 hour."
    },
    {
      "position": 2,
      "text": "Fry the potatoes and carrots. Set aside."
    },
    {
      "position": 3,
      "text": "Using around 3 tablespoons of cooking oil, saut\u00e9 the onion and 4 cloves of minced garlic."
    },
    {
      "position": 4,
      "text": "Add the marinated chicken once the onion softens. Saut\u00e9 the chicken until it turns medium brown in color."
    },
    {
      "position": 5,
      "text": "Pour the tomato sauce and water into the cooking pot. Cover and let it boil and then adjust the heat to a simmer. Continue cooking for 40 minutes."
    },
    {
      "position": 6,
      "text": "Add the liver spread. Stir and add the bell peppers, potato, and carrots."
    },
    {
      "position": 7,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 8,
      "text": "Add the grated cheese."
    },
    {
      "position": 9,
      "text": "Serve warm with rice. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
