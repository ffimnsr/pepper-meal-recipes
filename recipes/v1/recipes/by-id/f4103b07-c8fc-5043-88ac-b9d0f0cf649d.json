  "id": "f4103b07-c8fc-5043-88ac-b9d0f0cf649d",
  "slug": "laing",
  "name": "Laing Recipe",
  "recipe_type": null,
  "brief_description": "Laing is a spicy vegetable dish cooked in Coconut milk. This recipe originated from the Bicol region. Laing is best when spicy and is eaten along with white rice.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "In a large pan, pour-in the coconut milk and bring to a boil"
    },
    {
      "position": 2,
      "text": "Add the garlic, onion, and ginger. Cook for 10 minutes"
    },
    {
      "position": 3,
      "text": "Add the pork meat and shrimp paste and stir continuously"
    },
    {
      "position": 4,
      "text": "Put in the Thai chili and simmer for another 10 minutes"
    },
    {
      "position": 5,
      "text": "Add the fish sauce and dried Taro leaves and simmer for 40 to 60. Add water if needed."
    },
    {
      "position": 6,
      "text": "Put the shrimps in and cook for for 5 minutes. Season with ground black pepper."
    },
    {
      "position": 7,
      "text": "Serve hot. Enjoy"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
