{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "5921f23c-cbbc-5b87-b9d2-f2a0840dfd50",
  "slug": "crispy-air-fried-liempo-pinakbet-with-ube",
  "name": "Crispy Air Fried Liempo Pinakbet with Ube",
  "recipe_type": "main",
  "brief_description": "Pinakbet Tagalog with crispy pork belly and purple yam.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Add pork belly. Continue boiling for 35 minutes."
    },
    {
      "position": 3,
      "text": "Remove pork from the pot. Let it cool down. Note: Save the pork stock (water used to boil the pork). It will be used later."
    },
    {
      "position": 4,
      "text": "Rub salt all over the pork belly. Let it stay for 10 minutes."
    },
    {
      "position": 5,
      "text": "Put the pork in an air fryer. Air-fry for 18 minutes (or until crispy) per side in 370F. Slice into serving pieces. Set aside."
    },
    {
      "position": 6,
      "text": "Heat oil in a pan. Saute onion, garlic, ginger, and tomato."
    },
    {
      "position": 7,
      "text": "Once tomato and onion softens, add ube and kalabasa. Saute for 2 minutes."
    },
    {
      "position": 8,
      "text": "Pour 1 1/4 cup pork stock into the pot. Let boil."
    },
    {
      "position": 9,
      "text": "Add Knorr Pork Cube. Stir."
    },
    {
      "position": 10,
      "text": "Add bagoong alamang. Stir. Cover the pan. Cook for 5 minutes."
    },
    {
      "position": 11,
      "text": "Add eggplant and ampalaya. Cover and cook for 2 minutes."
    },
    {
      "position": 12,
      "text": "Add okra and snake beans. Cover and cook for 7 to 10 minutes."
    },
    {
      "position": 13,
      "text": "Season with ground black pepper. Top with crispy liempo. Serve. Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
