  "id": "a4ac0af3-7b07-5d09-9c9b-12adf0d7da30",
  "slug": "baked-garlic-milkfish",
  "name": "Baked Garlic Milkfish",
  "recipe_type": null,
  "brief_description": "This Baked Garlic Milkfish recipe is really simple. The fish just needs to marinate for at least 3 hours in order to absorb the flavor of the marinade.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the chopped parsley and crushed garlic in a mortar. Pound the mixture using a pestle."
    },
    {
      "position": 2,
      "text": "Add salt, ground black pepper, and olive oil. Grind the ingredients using the pestle."
    },
    {
      "position": 3,
      "text": "Arrange the milkfish in a plate in a position wherein the open cavity faces upwards. Rub the garlic and parsley mixture over the milkfish. Let it stay for 3 hours."
    },
    {
      "position": 4,
      "text": "Cut the head and tail off the milkfish. Slice into serving pieces. Arrange in a baking tray lined with aluminum foil."
    },
    {
      "position": 5,
      "text": "Preheat the oven to 370F. Once the oven gets hot, bake the milkfish for 45 minutes or until the top turns light brown."
    },
    {
      "position": 6,
      "text": "Remove from the oven and transfer to a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 180,
