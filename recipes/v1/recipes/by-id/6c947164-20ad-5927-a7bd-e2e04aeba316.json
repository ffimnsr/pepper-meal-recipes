  "id": "6c947164-20ad-5927-a7bd-e2e04aeba316",
  "slug": "filipino-style-beef-steak",
  "name": "Filipino Style Beef Steak",
  "recipe_type": "main",
  "brief_description": "Tender beef steak stew with onions.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine beef, soy sauce, juice from \u00bd lemon, and \u00bd teaspoon cracked peppercorn in a bowl. Mix well. Refrigerate for at least 1 hour."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a pan. Fry each side of the marinated beef for 1 minute. Remove and set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil (you can add more if needed), saut\u00e9 half of the onion and add the garlic."
    },
    {
      "position": 4,
      "text": "Put the beef in the pan once the onion softens. Saut\u00e9 for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour 1 \u00bd cups of water into the pan. Cover and let the liquid boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Beef Cube. Cover the pan and then adjust the heat to a low setting. Cook for up to 40 minutes. Note: add more water as needed."
    },
    {
      "position": 7,
      "text": "Add remaining onion and season with cracked peppercorn and add brown sugar."
    },
    {
      "position": 8,
      "text": "Make the sauce thicker by pouring-in the slurry. Do this by mixing cornstarch with 3 tablespoons of water."
    },
    {
      "position": 9,
      "text": "Once the sauce gets thick enough, you may turn the heat off and transfer your Filipino Style Beef Steak to a serving bowl."
    },
    {
      "position": 10,
      "text": "Serve with warm rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
