  "id": "7d4c4659-6620-5c98-b5d4-c9a32bf300fa",
  "slug": "chicken-soup-recipe",
  "name": "Chicken Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "This chicken soup recipe is not only delicious and comforting; it also has healing and soothing properties. This post will guide you on how to cook one.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil the water in a wide cooking pot."
    },
    {
      "position": 2,
      "text": "Put-in the chicken, carrots, celery, and onion. Simmer for 1 hour."
    },
    {
      "position": 3,
      "text": "Remove the chicken and vegetables leaving the stock. Shred the meat of the chicken and discard the bones and then slice the carrots, celery, and onion."
    },
    {
      "position": 4,
      "text": "Put everything back in the cooking pot along with the chicken stock and then apply heat."
    },
    {
      "position": 5,
      "text": "Let the chicken stock re-boil (add a few cups of water, if necessary)."
    },
    {
      "position": 6,
      "text": "Add the rotini pasta. Cook for 15 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to individual bowls."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 5,
