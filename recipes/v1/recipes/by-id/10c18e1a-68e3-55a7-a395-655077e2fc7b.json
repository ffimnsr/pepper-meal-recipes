  "id": "10c18e1a-68e3-55a7-a395-655077e2fc7b",
  "slug": "chicken-and-baby-corn-stir-fry",
  "name": "Chicken and Baby Corn Stir Fry",
  "recipe_type": "main",
  "brief_description": "Quick and easy Chicken and Baby Corn Stir Fry with crisp vegetables and tender chicken in savory sauce. Ready in under 30 minutes with simple ingredients and classic stir fry technique that the whole family will love.",
  "cuisine": "American Asian Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a wok or large pan over high heat until shimmering."
    },
    {
      "position": 2,
      "text": "Add the minced ginger, minced garlic, and chopped scallions. Saut\u00e9 for about 1 minute until fragrant. The aromatics should release their flavors into the oil."
    },
    {
      "position": 3,
      "text": "Add the sliced chicken to the wok. Stir fry for 8 minutes, tossing frequently, until the chicken is cooked through and starts to turn golden brown."
    },
    {
      "position": 4,
      "text": "Pour in the oyster sauce, granulated white sugar, low sodium soy sauce, sesame oil, and chicken broth. Stir well to coat the chicken evenly with the sauce."
    },
    {
      "position": 5,
      "text": "Add the sliced carrots, snap peas, and drained baby corn to the wok. Stir fry for 5 to 8 minutes until the vegetables are tender but still crisp. The sauce should coat everything with a glossy sheen."
    },
    {
      "position": 6,
      "text": "Season with salt and pepper to taste. Adjust the seasoning based on your preference, keeping in mind that oyster sauce and soy sauce are already salty."
    },
    {
      "position": 7,
      "text": "Transfer the chicken and baby corn stir fry to a serving plate. Serve hot with steamed white rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
