  "id": "d6be00ee-d4c3-59ef-a422-3bcd66de90f9",
  "slug": "tuyo-with-rice-tomato-recipe",
  "name": "Tuyo with Rice and Tomato",
  "recipe_type": "breakfast",
  "brief_description": "Tuyo fish is a type of sun dried fish. This is best eaten with spicy vinegar dip and rice. Tuyo is usually consumed for breakfast in the Philippines",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 400F."
    },
    {
      "position": 2,
      "text": "Arrange the tuyo fish in an aluminum foil sheet. Spray both sides of the fish with cooking oil. Secure the fish inside the sheet by covering with another aluminum sheet and secure the sides."
    },
    {
      "position": 3,
      "text": "Open your vent (this is important). Bake for 6 to 10 minutes."
    },
    {
      "position": 4,
      "text": "Remove the fish from the sealed sheet and arrange in individual plates with a cup of white rice and wedged tomato."
    },
    {
      "position": 5,
      "text": "Serve with spiced vinegar."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
