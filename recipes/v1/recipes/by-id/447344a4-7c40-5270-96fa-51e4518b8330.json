  "id": "447344a4-7c40-5270-96fa-51e4518b8330",
  "slug": "shared-recipe-antonios-tuna-cream-cheese-and-onion-spread",
  "name": "Antonio's Tuna Cream Cheese and Onion Spread",
  "recipe_type": "snack",
  "brief_description": "This is a recipe for Tuna Cream Cheese and Onion Spread",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pre season chopped onions and garlic with a pinch of salt."
    },
    {
      "position": 2,
      "text": "In a skillet, heat oil over medium-low heat. Add in Red onions and the white end of spring onions. Let onions sweat but watch out that it doesn't turn brown. Add in garlic. Do not let it turn brown as well."
    },
    {
      "position": 3,
      "text": "Add in Tuna and mash it up and mix it around. Add Lemon juice then turn the heat up to medium or medium high just for a few seconds to a minute."
    },
    {
      "position": 4,
      "text": "Turn the heat off, and then add the cream cheese. Mash and mix it up until it's nice and creamy, and everything is evenly mixed together."
    },
    {
      "position": 5,
      "text": "Transfer spread into a container; let it cool; cover with cling film then stick it in the fridge. Done!"
    },
    {
      "position": 6,
      "text": "To make bruschetta, slice baguette about an inch thick, make 4-6 slices. Grill or toast slices then add Tuna-Cream Cheese and Tomato Spread. Top with diced tomatoes and chiffonade basil. Drizzle with extra virgin olive oil."
    }
  ],
  "servings": 7,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 10,
