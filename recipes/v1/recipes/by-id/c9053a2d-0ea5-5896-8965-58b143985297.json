  "id": "c9053a2d-0ea5-5896-8965-58b143985297",
  "slug": "how-to-make-the-special-siopao-sauce",
  "name": "Special Siopao Sauce Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Siopao Sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the saucepan and pour-in the beef stock. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the onions, garlic, soy sauce, Worcestershire sauce, brown sugar, salt, ground black pepper, and star anise then simmer for 8 to 10 minutes. Make sure to cover the saucepan to trap the steam. Add extra water as needed."
    },
    {
      "position": 3,
      "text": "Turn of the heat then filter the liquid using a fine-mesh kitchen strainer. This is done by pouring the simmered mixture on a strainer with an empty bowl below to hold the liquid."
    },
    {
      "position": 4,
      "text": "Heat a clean saucepan and pour-in the filtered mixture. Bring to a boil."
    },
    {
      "position": 5,
      "text": "Add the cornstarch diluted in water then stir continuously until the texture becomes thick."
    },
    {
      "position": 6,
      "text": "Turn off the heat and allow the mixture to cool down then transfer the Siopao sauce to a serving container."
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
