  "id": "b1ed82ca-86d3-578a-ae0b-19044031df51",
  "slug": "asian-fried-chicken",
  "name": "Asian Fried Chicken",
  "recipe_type": null,
  "brief_description": "Asian Fried Chicken or Five Spice Fried Chicken is a tasty fried chicken recipe that you can prepare for dinner. This dish is so good and very flavorful. It is best eaten with fried rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine 5 spice powder, salt, and ground black pepper in a bowl. Mix well and set aside."
    },
    {
      "position": 2,
      "text": "Pour water in a steamer. Bring to a boil."
    },
    {
      "position": 3,
      "text": "Arrange the chicken in the steamer. Steam for 40 to 45 minutes."
    },
    {
      "position": 4,
      "text": "Remove the chicken from the steamer and place in a plate with sliced part facing down. Let the chicken cool down."
    },
    {
      "position": 5,
      "text": "Rub the soy sauce all over the chicken."
    },
    {
      "position": 6,
      "text": "Run the 5 spice powder mixture all over the chicken. Let the chicken dry in open air for 6 hours."
    },
    {
      "position": 7,
      "text": "Heat the cooking oil in a deep cooking pot or deep fryer. Deep fry the chicken in 350F for 10 to 12 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with Yang Chow fried rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 10,
