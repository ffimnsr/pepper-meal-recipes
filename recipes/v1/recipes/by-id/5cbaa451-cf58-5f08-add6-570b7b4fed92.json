  "id": "5cbaa451-cf58-5f08-add6-570b7b4fed92",
  "slug": "utan-bisaya",
  "name": "Utan Bisaya",
  "recipe_type": null,
  "brief_description": "Utan Bisaya is a simple Filipino dish composed of different kinds of vegetables. The veggies are boiled and fish is sometimes added.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Bring the water to a boil."
    },
    {
      "position": 2,
      "text": "Add the ginger and squash. Continue to boil for 8 minutes (covered)."
    },
    {
      "position": 3,
      "text": "Stir-in the string beans, scallions, okra, and tomato. Let the liquid re-boil and then add the long green pepper and eggplant."
    },
    {
      "position": 4,
      "text": "Stir and add the fish. Cover and cook for 10 minutes."
    },
    {
      "position": 5,
      "text": "Add the patola and malunggay leaves. Cover and cook for 3 to 5 minutes. Add some salt to taste and spinach."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
