  "id": "9f6edca6-d60f-5493-bb15-fd6f44736f70",
  "slug": "adobong-tahong-recipe",
  "name": "Adobong Tahong Recipe (Mussels Adobo)",
  "recipe_type": "main",
  "brief_description": "Savory mussels cooked in soy sauce and vinegar.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Put-in the crushed garlic and whole peppercorn. Cook until the garlic turns light brown."
    },
    {
      "position": 3,
      "text": "Add the mussels. Stir and cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the bay leaves, add the soy sauce, and 1 tablespoon of toasted garlic. Let it boil. Simmer for 5 to 7 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the vinegar. Let the liquid reboil. Stir and then cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add salt to taste. Transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Top with the remaining toasted garlic. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
