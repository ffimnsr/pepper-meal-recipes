  "slug": "tartar-sauce",
  "name": "Tartar Sauce Recipe",
  "recipe_type": "condiment",
  "brief_description": "Tartar sauce is a rich and creamy sauce. It is usually used for deep fried coated fish and seafood dishes. Try this delicious tartar sauce recipe.",
  "cuisine": "french",
  "instructions": [
    {
      "position": 1,
      "text": "Combine mayonnaise and lemon juice in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Whisk in the sweet pickle relish and onion."
    },
    {
      "position": 3,
      "text": "Add salt and pepper and then continue whisking until all the ingredients are well incorporated."
    },
    {
      "position": 4,
      "text": "Cover and then chill in the fridge for a couple of hours."
    },
    {
      "position": 5,
      "text": "Serve with your favorite fried fish dishes."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
