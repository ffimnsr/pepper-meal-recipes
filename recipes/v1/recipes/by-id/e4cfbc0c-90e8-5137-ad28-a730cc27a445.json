  "id": "e4cfbc0c-90e8-5137-ad28-a730cc27a445",
  "slug": "all-out-pancit-canton",
  "name": "All Out Pancit Canton",
  "recipe_type": "main",
  "brief_description": "Special pancit canton (Filipino egg noodles) with shrimp, squid balls. and vegetables.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water and then add salt. Put the pancit canton noodles. Cook for 2 minutes. Remove the noodles and set aside."
    },
    {
      "position": 2,
      "text": "Using the remaining water, blanch the vegetable ingredients for 1 to 2 minutes. Remove from the pot and soak in ice cold water for 30 seconds. Drain the water and set the vegetables aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a clean cooking pot. Saute onion and garlic until the onion softens."
    },
    {
      "position": 4,
      "text": "Add chicken breast, squid balls, and Chinese sausage. Saute for 1 to 2 minutes."
    },
    {
      "position": 5,
      "text": "Add the shrimp. Cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Pour the soy sauce in the cooking pot and then add oyster sauce, and 1 cup water. Let the liquid boil."
    },
    {
      "position": 7,
      "text": "Add Knorr shrimp cube. Stir and gently toss-in the pancit canton noodles and add the chopped parsley. Cover the pot. Adjust the heat setting of your stove between low and medium. Cook the noodles cook for 2 to 3 minutes or until well done, but not soggy (Note: add more water if needed)."
    },
    {
      "position": 8,
      "text": "Toss the blanched vegetables in the pot. Season with salt and ground black pepper."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve with lemon wedges or calamansi. Share and enjoy!"
    }
  ],
  "servings": 6,
