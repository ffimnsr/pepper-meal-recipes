  "id": "24d78b23-8f86-5a65-b000-935ace2bd2e7",
  "slug": "pork-dinuguan-isaw-at-tenga",
  "name": "Pork Dinuguan Isaw at Tenga ng Baboy",
  "recipe_type": "main",
  "brief_description": "A version of dinuguan using large intestines and pork ears.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork ears, intestines, 4 pieces of bay leaves, salt, whole peppercorn, and water in a cooking pot. Boil for 20 minutes. Remove ears and intestines. Let it cool down, and then slice into serving pieces. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Saute garlic and onion until the onion softens."
    },
    {
      "position": 3,
      "text": "Add sliced pork ears and intestine. Saute for 15 minutes or until the fat renders. Note: Try to remove excess oil."
    },
    {
      "position": 4,
      "text": "Pour fish sauce and vinegar. Let it boil. Stir and cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add water. Let it boil. Cover the pan and cook using low to medium heat for 40 minutes or until the pork parts tenderizes."
    },
    {
      "position": 6,
      "text": "Pour the pork blood into the pan. Stir immediately. Add Serrano pepper. Continue cooking for 12 to 15 minutes. Note: add more water if needed."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper. You can adjust the flavor by adding more vinegar and fish sauce as needed."
    },
    {
      "position": 8,
      "text": "Serve hot. Share and enjoy."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
