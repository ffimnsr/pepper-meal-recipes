  "id": "171ba485-29aa-5fb8-ad12-55c0ec489c00",
  "slug": "baked-potato-parmesan-recipe",
  "name": "Baked Potato Parmesan Recipe",
  "recipe_type": "side",
  "brief_description": "This is a simple baked potato recipe that is made tasty by adding cheese and seasonings. It is good to eat as a side dish with meat or fish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 430 degrees Fahrenheit"
    },
    {
      "position": 2,
      "text": "In a bowl, coat the potato with olive oil."
    },
    {
      "position": 3,
      "text": "Sprinkle some onion soup and dip mix and dried parsley. Mix well to coat the potato."
    },
    {
      "position": 4,
      "text": "Arrange in a wide greased baking tray. Bake for 40 to 45 minutes or until the color of the potato turn light to medium brown."
    },
    {
      "position": 5,
      "text": "Remove from the oven. Sprinkle Parmesan cheese on top."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
