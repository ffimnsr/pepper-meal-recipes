  "id": "12ecffb4-ee43-521e-82e2-3396bde1e951",
  "slug": "papaitan-recip",
  "name": "Papaitan Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for beef papaitan",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour-in 4 cups of water and put-in 1 tablespoon salt. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Put-in the ox tripe and small intestines and simmer until tender. This should take approximately 35 to 50 minutes."
    },
    {
      "position": 3,
      "text": "Turn off heat. Remove the tender ox tripe and small intestines then slice. Set aside. Discard the water."
    },
    {
      "position": 4,
      "text": "Heat a clean cooking pot and pour-in cooking oil."
    },
    {
      "position": 5,
      "text": "When the oil is hot enough, saut\u00e9 garlic, onion, and ginger."
    },
    {
      "position": 6,
      "text": "Add the beef, heart, sliced intestines, and tripe then cook for about 3 to 4 minutes."
    },
    {
      "position": 7,
      "text": "Add 1 1/2 tablespoon salt and ground black pepper then stir for a minute."
    },
    {
      "position": 8,
      "text": "Pour-in remaining 4 cups of water and bring to a boil. Simmer for 40 minutes (you may add more water if needed)."
    },
    {
      "position": 9,
      "text": "Add bile then simmer for 5 minutes."
    },
    {
      "position": 10,
      "text": "Add the finger chilies and squeeze-in the lemon juice then simmer for 3 minutes."
    },
    {
      "position": 11,
      "text": "Turn off the heat and transfer to a serving bowl."
    },
    {
      "position": 12,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
