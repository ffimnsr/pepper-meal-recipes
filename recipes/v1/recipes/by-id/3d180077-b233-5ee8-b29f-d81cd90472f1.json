  "id": "3d180077-b233-5ee8-b29f-d81cd90472f1",
  "slug": "garlic-shrimp-pasta",
  "name": "Garlic Shrimp Pasta",
  "recipe_type": null,
  "brief_description": "Garlic Shrimp Pasta is the pasta dish of my choice when I want to have a quick spaghetti meal before I hit the gym or start to exercise",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the spaghetti noodles according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Melt the butter in a pan and then add the olive oil."
    },
    {
      "position": 3,
      "text": "Add the shrimp. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Put-in the garlic. Continue to cook for 1 to 2 minutes or until the garlic turns light brown."
    },
    {
      "position": 5,
      "text": "Gradually add-in the cooked spaghetti noodles. Toss until all the ingredients are incorporated."
    },
    {
      "position": 6,
      "text": "Add the oregano, parmesan cheese, and ground black pepper. Toss again until all are well distributed."
    },
    {
      "position": 7,
      "text": "Transfer to individual pasta bowls."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
