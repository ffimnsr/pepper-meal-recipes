  "id": "85dd47c5-d178-50a9-b825-e775cdea6395",
  "slug": "fudge-brownies-with-walnuts-recipe",
  "name": "Brownies with Walnuts",
  "recipe_type": "dessert",
  "brief_description": "Brownies or Chocolate Brownies refers to slices of flat baked dense chocolate cake. These are usually sliced in squares although some like it in bars.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt the chocolate chunks by placing the bowl over a saucepan with boiling water."
    },
    {
      "position": 2,
      "text": "Whisk the eggs then gradually add the granulated sugar. Mix thoroughly."
    },
    {
      "position": 3,
      "text": "Whisk-in the softened butter then continue mixing."
    },
    {
      "position": 4,
      "text": "Add the melted chocolate then mix again."
    },
    {
      "position": 5,
      "text": "Put-in the baking powder and salt then mix until fully distributed."
    },
    {
      "position": 6,
      "text": "Gradually add the flour while mixing."
    },
    {
      "position": 7,
      "text": "Pour-in the vanilla extract and coffee then mix until every ingredient is well incorporated."
    },
    {
      "position": 8,
      "text": "Fold-in the chopped walnuts. Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 9,
      "text": "Pour the chocolate mixture on a 9 x 13 greased baking pan then bake for 19 to 22 minutes or until it passes the toothpick test."
    },
    {
      "position": 10,
      "text": "Remove from the oven and allow the temperature to cool down."
    },
    {
      "position": 11,
      "text": "Slice and transfer to a serving plate."
    },
    {
      "position": 12,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 22,
  "preparation_time_minutes": 10,
