  "id": "5b75b6a2-6238-5cb5-8d8e-908133f0aeda",
  "slug": "tasty-sliders-recipe",
  "name": "Tasty Sliders Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for tasty sliders",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine ground beef and French onion soup powder; mix using your clean hands."
    },
    {
      "position": 2,
      "text": "Scoop about 2 1/2 ounces of meat and form it into a ball-like figure. Gently press the meat so that it becomes flat."
    },
    {
      "position": 3,
      "text": "Season with salt and ground black pepper"
    },
    {
      "position": 4,
      "text": "Grill each side in medium heat for 4 to 6 minutes. The thicker the patty, the longer it takes to grill"
    },
    {
      "position": 5,
      "text": "Remove from the grill and assemble. Start by spreading mayonnaise on the dinner roll, and then arrange the patty. Add cheese, sliced onion, and pickles, if you like."
    },
    {
      "position": 6,
      "text": "Serve with homemade French fries."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 10,
