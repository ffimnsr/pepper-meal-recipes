  "id": "04f34321-4776-5fbe-aa1e-532906cd7dae",
  "slug": "nilagang-baka-ala-bulalo",
  "name": "Nilagang Baka ala Bulalo",
  "recipe_type": null,
  "brief_description": "This is a recipe for Nilagang Baka ala Bulalo",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add whole peppercorn and onion. Boil for 5 minutes."
    },
    {
      "position": 3,
      "text": "Add beef chuck. Let the water re-boil and then cover the cooking pot. Continue to boil in medium heat for 2 hours."
    },
    {
      "position": 4,
      "text": "Add corn and then cover the pot. Cook for 1 hour."
    },
    {
      "position": 5,
      "text": "Add beef cube and potato. Cook for 5 to 6 minutes."
    },
    {
      "position": 6,
      "text": "Pour fish sauce into the pot. Stir."
    },
    {
      "position": 7,
      "text": "Add cabbage. Cover the pot. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 180,
  "preparation_time_minutes": 5,
