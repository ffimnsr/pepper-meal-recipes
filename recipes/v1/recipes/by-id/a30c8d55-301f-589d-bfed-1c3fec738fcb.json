  "id": "a30c8d55-301f-589d-bfed-1c3fec738fcb",
  "slug": "turkey-and-ham-sopas",
  "name": "Turkey and Ham Sopas",
  "recipe_type": "soup",
  "brief_description": "Turkey and Ham Sopas is a soup dish made from leftover thanksgiving turkey and ham. This dish is rich, flavorful, and simply delicious. I made this from our leftover turkey and ham. The soup is composed of chicken broth and fresh milk. Traditional Filipino sopas makes use of milk to make it more richer. In the\u2026",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a cooking pot. Continue to heat the butter until it gets hot enough to cook the veggies."
    },
    {
      "position": 2,
      "text": "Saute the onion, carrots, and celery for 3 minutes."
    },
    {
      "position": 3,
      "text": "Add the turkey and ham. Saute for 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in the chicken broth. Let boil. Add the pasta. Cover and cook in low to medium heat for 20 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in milk. Stir and let the liquid re-boil."
    },
    {
      "position": 6,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 7,
      "text": "Transfer to individual bowls. You can top it with French fried onions or roasted garlic."
    },
    {
      "position": 8,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
