  "id": "b8161451-7180-5092-b89b-e52030a21ca2",
  "slug": "pork-monggo-with-crispy-galunggong",
  "name": "Pork Monggo with Fried Galunggong",
  "recipe_type": "main",
  "brief_description": "Easy mung bean stew and crispy fried galunggong fish",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Start to tenderize the mung beans by boiling 4 cups of water in a cooking pot. Add the mung beans. Cover and cook in low heat setting until it softens."
    },
    {
      "position": 2,
      "text": "Meanwhile, prepare the fish by rubbing salt all over it, including the cavity. Heat 1 cups of cooking oil in a pan. Fry the fish until it gets crispy. Set aside."
    },
    {
      "position": 3,
      "text": "Cook the pork monggo by heating 3 tablespoons of cooking oil that you used to fry the fish. Saute garlic, onion, and tomato."
    },
    {
      "position": 4,
      "text": "Once the onion softens, add the pork. Cook it until it starts to brown. Pour 1 cup water. Let it boil. Cover and continue cooking for 10 minutes."
    },
    {
      "position": 5,
      "text": "Add the softened mung beans and more water as needed. Stir and cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add hot pepper leaves and season with fish sauce and ground black pepper."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve with warm rice and fried galunggong. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
