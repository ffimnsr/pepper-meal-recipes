  "id": "1d46a3f8-36bb-5979-9029-5d1e5a38c983",
  "slug": "kinamatisang-manok",
  "name": "Kinamatisang Manok",
  "recipe_type": "soup",
  "brief_description": "Filipino chicken stew with tomatoes",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saut\u00e9 garlic until it starts to brown."
    },
    {
      "position": 2,
      "text": "Add onion and ginger. Continue cooking until the onion softens."
    },
    {
      "position": 3,
      "text": "Put the chicken pieces into the pot. Cook each side for 1 minute."
    },
    {
      "position": 4,
      "text": "Stir-in half of the tomatoes. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour the water and let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Chicken Cube and 2 teaspoons of fish sauce. Cover the pot and adjust the heat to low setting. Boil the chicken for 20 minutes."
    },
    {
      "position": 7,
      "text": "Add remaining tomatoes, long green pepper, and bok choy. Cover and cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper and fish sauce as needed."
    },
    {
      "position": 9,
      "text": "Serve warm with rice. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
