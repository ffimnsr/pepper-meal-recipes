  "id": "832aa572-b592-5a45-8834-1499f33de8b7",
  "slug": "monggo-with-tuyo-recipe-mung-beans-with-salted-fish",
  "name": "Monggo with Tuyo Recipe (Mung Beans with Salted Fish)",
  "recipe_type": null,
  "brief_description": "I think that using bottled tuyo for this Monggo with tuyo recipe is just perfect because the fish has the right amount of saltiness and the fish can be eaten with the bones. Yes, you read it correctly \u2013 the fish is soft enough to the point that it can be eaten without segregating the meat from the bones.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour 5 cups of water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Put-in the mung beans. Cover and cook in low to medium heat until the mung beans completely absorb the water. Add more water if needed. Set aside."
    },
    {
      "position": 3,
      "text": "Heat the oil in a large cooking pot."
    },
    {
      "position": 4,
      "text": "Saut\u00e9 the onion, tomato, and garlic"
    },
    {
      "position": 5,
      "text": "Once the onion gets soft, add the salted fish (tuyo). Cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Add the cooked mung beans. Stir."
    },
    {
      "position": 7,
      "text": "Put-in the malunggay leaves, fish sauce, and 1 cup water. Stir and cook uncovered for 3 to 7 minutes or until the desired consistency is achieved. You can add more water if needed."
    },
    {
      "position": 8,
      "text": "Sprinkle some ground black pepper to taste."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
