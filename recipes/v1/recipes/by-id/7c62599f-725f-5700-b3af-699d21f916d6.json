  "id": "7c62599f-725f-5700-b3af-699d21f916d6",
  "slug": "bacon-and-spinach-quiche",
  "name": "Bacon and Spinach Quiche",
  "recipe_type": "breakfast",
  "brief_description": "A tender pastry shell filled with smoky bacon, fresh spinach, and sharp cheddar baked in a rich egg custard\u2014perfect anytime comfort food.",
  "cuisine": "French",
  "instructions": [
    {
      "position": 1,
      "text": "Combine beaten eggs, heavy whipping cream, salt, and ground pepper in a mixing bowl. Mix well and set aside."
    },
    {
      "position": 2,
      "text": "Alternately arrange spinach, bacon, and cheese in the pastry dough."
    },
    {
      "position": 3,
      "text": "Pour the egg and whipping cream mixture on the pastry dough (over the spinach, bacon, and cheese)."
    },
    {
      "position": 4,
      "text": "Pre-heat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 5,
      "text": "Put the pastry dough in the oven. Bake for 40 to 50 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven, and then slice."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 12,
