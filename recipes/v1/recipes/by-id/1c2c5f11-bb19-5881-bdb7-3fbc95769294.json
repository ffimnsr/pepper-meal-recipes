{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "1c2c5f11-bb19-5881-bdb7-3fbc95769294",
  "slug": "crispy-dinuguan",
  "name": "Crispy Dinuguan",
  "recipe_type": "main",
  "brief_description": "Deep-fried crispy pork belly with blood stew sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the pork by boiling until tender. Start by boiling water in a cooking pot. Add bay leaves, whole peppercorn, salt, and pork belly (liempo).Boil for 45 to 60 to 60 minutes or until pork gets tender."
    },
    {
      "position": 2,
      "text": "Remove boiled pork from the pot. Place it in a clean plate. Let it cool down for 5 minutes. Save the pork stock for later."
    },
    {
      "position": 3,
      "text": "Rub 2 teaspoons salt all over the boiled pork. Let it stay for 10 minutes."
    },
    {
      "position": 4,
      "text": "Heat oil in a deep-fryer or cooking pot. Deep-fry the boiled pork for 8 minutes. Remove from the fryer and let it rest for 5 minutes.Put the pork back into the fryer and continue to fry for 3 minutes more, or until crispy. Slice the crispy pork into bite-size pieces. Set aside."
    },
    {
      "position": 5,
      "text": "Make the dinuguan sauce by heating 3 tablespoons of cooking oil in a cooking pot. Saute onion, ginger, and garlic."
    },
    {
      "position": 6,
      "text": "Once onion softens, pour the pork stock. Note: this is the water used to boil the liempo earlier."
    },
    {
      "position": 7,
      "text": "Add lemongrass. Cover and boil in medium heat for 8 minutes. Remove lemongrass and ginger from the pot."
    },
    {
      "position": 8,
      "text": "Pour-in pork blood. Stir thoroughly while waiting for it to boil."
    },
    {
      "position": 9,
      "text": "Add Knorr Pork Cube. Stir."
    },
    {
      "position": 10,
      "text": "Add vinegar. Let the mixture boil. Stir and add sugar. Continue to cook uncovered until the mixture reduces to half."
    },
    {
      "position": 11,
      "text": "Add peppers and cook for 2 minutes. Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
