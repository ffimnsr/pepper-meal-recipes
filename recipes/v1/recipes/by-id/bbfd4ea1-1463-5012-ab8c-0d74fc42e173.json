  "id": "bbfd4ea1-1463-5012-ab8c-0d74fc42e173",
  "slug": "suam-na-mais",
  "name": "Suam na Mais",
  "recipe_type": "appetizer",
  "brief_description": "Filipino corn soup with ground pork and shrimp",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saut\u00e9 garlic and onion."
    },
    {
      "position": 2,
      "text": "Once the onion softens, add the ground pork. Saut\u00e9 It for 2 minutes or until the exterior turns light to medium brown in color."
    },
    {
      "position": 3,
      "text": "Add the white corn. Cook it for 3 minutes."
    },
    {
      "position": 4,
      "text": "Put the shrimp into the cooking pot. Saut\u00e9 it for 1 minute."
    },
    {
      "position": 5,
      "text": "Combine Knorr Crab and Corn Soup with water. Mix well. Pour the mixture into the cooking pot. Stir and let it boil. Continue cooking in low to medium heat setting for 3 minutes while stirring."
    },
    {
      "position": 6,
      "text": "Add the hot pepper leaves or spinach and season with ground white pepper and fish sauce."
    },
    {
      "position": 7,
      "text": "Serve hot with rice and pair it with fried pork chop."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
