  "id": "03f81dcb-78b8-55a2-b8dd-ed8e87dd1dd2",
  "slug": "amazing-cabbage-recipe",
  "name": "Amazing Cabbage Recipe",
  "recipe_type": "main",
  "brief_description": "Cabbage with a medley of vegetables and pork",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add pork. Continue boiling until the pork gets tender. Separate the pork and water (pork stock) using a kitchen strainer. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil on the same pot. Saut\u00e9 onion and garlic."
    },
    {
      "position": 3,
      "text": "Once the onion softens, add the pork. Cook for 30 seconds."
    },
    {
      "position": 4,
      "text": "Add carrot and soy sauce. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Put the cabbage into the pot. Stir and continue cooking for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add bell peppers and snap peas. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Pour the pork stock into the pot and add Knorr pork cube. Stir and cook for another 2 minutes."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper and salt."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
