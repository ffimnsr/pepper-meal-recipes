  "slug": "dinengdeng-na-saluyot-with-tinapa",
  "name": "Dinengdeng na Saluyot with Tinapa",
  "recipe_type": null,
  "brief_description": "This is a recipe for Dinengdeng na Saluyot with Tinapa",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a cooking pot. Add tomato and onion. Apply heat to the pot and let boil. Cover and cook for 3 minutes."
    },
    {
      "position": 2,
      "text": "Add sitaw, okra, ampalaya. Cook for 3 minutes."
    },
    {
      "position": 3,
      "text": "Add Saluyot leaves, tinapang galunggong (smoked fish), and bagoong monamon. Cover the cooking pot and continue to cook in medium heat for 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Transfer to a serving plate. Serve with warm rice."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
