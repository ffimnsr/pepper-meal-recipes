  "id": "e9bbc09b-47a7-520f-aafe-e6f7aff563f1",
  "slug": "beef-bulalo-recipe",
  "name": "Beef Bulalo Recipe",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Beef Bulalo or Boiled beef shank soup with corn and long green beans.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a pressure cooker."
    },
    {
      "position": 2,
      "text": "Add onions and whole peppercorn. Cook for 3 minutes."
    },
    {
      "position": 3,
      "text": "Add beef shank. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr pork cube. Stir. Cover the pressure cooker. Pressure cook for 40 to 45 minutes."
    },
    {
      "position": 5,
      "text": "Remove the cover once pressure is out. Add corn. Cook for 15 minutes."
    },
    {
      "position": 6,
      "text": "Put the green beans into the cooker and pour fish sauce. Stir. Continue to cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Arrange fresh Napa cabbage (pechay baguio) in a serving bowl. Transfer the contents of the pressure cooker in the same bowl. Serve hot with patis, calamansi, and siling labuyo."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
