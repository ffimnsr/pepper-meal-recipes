  "id": "d5094694-b838-5793-87d0-645aa9ac0603",
  "slug": "ginataang-papaya",
  "name": "Ginataang Papaya",
  "recipe_type": null,
  "brief_description": "Ginataang Papaya or unripe papaya cooked in coconut milk is one of my favorite ginataan dishes. Green papaya has a good distinctive taste which I really like, and food cooked in coconut milk is something that I adore \u2013 no wonder, ginataang papaya is like heaven-sent.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the garlic and ginger. Add the onion. Continue to cook until the onion becomes soft."
    },
    {
      "position": 3,
      "text": "Add the fried dried fish (daing). Stir. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour-in the coconut milk; stir. Simmer for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add the papaya. Cover and cook in medium heat for 15 minutes. Add water if necessary."
    },
    {
      "position": 6,
      "text": "Put-in the malunggay leaves. Stir and cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Pour-in the fish sauce and add the ground black pepper and chili (chili is optional). Stir. Cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
  "difficulty": "medium",
