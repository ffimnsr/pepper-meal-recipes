  "id": "38dd4c4d-9e28-59d8-b70e-5c7c7676c210",
  "slug": "healthy-asparagus-salad-recipe",
  "name": "Asparagus Salad",
  "recipe_type": "salad",
  "brief_description": "Here is another addition to our healthy salad recipes: Asparagus Salad. This is a quick and easy salad recipe that needs minimal cooking. Fresh asparagus is blanched then balsamic vinaigrette composed of balsamic vinegar, olive oil, salt, pepper, and garlic is poured over it.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour-in water. Bring to a boil"
    },
    {
      "position": 2,
      "text": "Put-in asparagus and cook for 3 minutes"
    },
    {
      "position": 3,
      "text": "Combine cold water and ice cubes in a large bowl then remove the asparagus from the cooking pot and directly immerse in cold water with ice."
    },
    {
      "position": 4,
      "text": "Drain excess water from the asparagus and place it in a serving plate."
    },
    {
      "position": 5,
      "text": "Create vinaigrette by combining balsamic vinegar, garlic, olive oil, salt, and pepper and mixing it thoroughly (this will serve as the dressing)."
    },
    {
      "position": 6,
      "text": "Pour vinaigrette over the blanched asparagus."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 3,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
