  "id": "58a3d4fb-098f-57a3-a1c0-9a877307f5eb",
  "slug": "chili-garlic-shrimp-saute",
  "name": "Chili Garlic Shrimp Saute",
  "recipe_type": null,
  "brief_description": "Chili Garlic Shrimp Saute is a quick and easy shrimp recipe to make for lunch. It is quick, easy, and delicious.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat butter and olive oil in a saute pan."
    },
    {
      "position": 2,
      "text": "Put-in the garlic and crushed red chili flakes. Cook in medium heat until the garlic turns light brown (this will take between 2 to 3 minutes)."
    },
    {
      "position": 3,
      "text": "Add the shrimp. Saute for 8 minutes."
    },
    {
      "position": 4,
      "text": "Sprinkle salt and pepper, and add the parsley flakes. Continue to cook for 2 to 4 minutes."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
