  "slug": "adobong-sitaw-at-kangkong-with-chicharon",
  "name": "Adobong Sitaw at Kangkong with Chicharon",
  "recipe_type": null,
  "brief_description": "This is a recipe for Adobong Sitaw at Kangkong with Chicharon",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onion until the onion softens and the garlic turn light brown."
    },
    {
      "position": 3,
      "text": "Pour soy sauce, vinegar, and water. Let boil."
    },
    {
      "position": 4,
      "text": "Add chicharon. Cover the pot. Continue to cook for 10 minutes medium heat."
    },
    {
      "position": 5,
      "text": "Add sitaw. Stir and cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Put the kangkong stalks into the pan. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add the kangkong leaves. Stir and cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper"
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
