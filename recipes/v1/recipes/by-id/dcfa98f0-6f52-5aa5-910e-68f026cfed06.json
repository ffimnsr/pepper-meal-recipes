  "id": "dcfa98f0-6f52-5aa5-910e-68f026cfed06",
  "slug": "spicy-honey-chicken-steamed-vegetables-recipe",
  "name": "Spicy Honey Chicken with Steamed Vegetables",
  "recipe_type": null,
  "brief_description": "This is a recipe for Spicy Honey Chicken with Steamed Vegetables",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine all chicken rub ingredients in bowl. Mix well. Rub all over the chicken breasts. Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Set the oven to broil mode."
    },
    {
      "position": 3,
      "text": "Arrange the chicken on a baking tray.Broil each side for 4 minutes."
    },
    {
      "position": 4,
      "text": "Combine honey and vinegar in a small bowl. Stir until well blended. Brush both side of the chicken with honey mixture."
    },
    {
      "position": 5,
      "text": "Put back in the oven. Continue to broil each side for 4 to 5 minutes or until done."
    },
    {
      "position": 6,
      "text": "Remove from the oven and arrange in a plate."
    },
    {
      "position": 7,
      "text": "Meanwhile pour water on and steamer. Arrange the steamed vegetable ingredients in the steamer and steam for 8 to 12 minutes."
    },
    {
      "position": 8,
      "text": "Serve with the spicy honey chicken."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 15,
