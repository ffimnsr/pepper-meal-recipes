  "id": "bad2c31a-3d98-5641-aec1-69d340792c0c",
  "slug": "chicken-adobong-puti",
  "name": "Chicken Adobong Puti Recipe",
  "recipe_type": "soup",
  "brief_description": "One of the simplest version of chicken adobo is probably chicken adobong puti. This version is also known as white adobo because of its clear broth.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange chicken in a large bowl. Add black pepper, garlic, and coconut vinegar. Mix well. Marinate for at least 30 minutes."
    },
    {
      "position": 2,
      "text": "Separate the marinade ingredients from the chicken. Heat oil in a pan. Fry each chicken piece for 1 \u00bd minutes per side. Remove from the pan, and then place on a clean plate. Set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil, saute garlic for 20 seconds. Add the pan-fried chicken. Pour the remaining marinade ingredients and add water. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Chicken Cube and bay leaves. Cover the pan and adjust heat between low and medium. Cook for 20 minutes. Add more water if needed."
    },
    {
      "position": 5,
      "text": "Flip the chicken using a pair of kitchen tongs. Season with sugar and salt as needed. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with warm rice. Share and enjoy!"
    }
  ],
