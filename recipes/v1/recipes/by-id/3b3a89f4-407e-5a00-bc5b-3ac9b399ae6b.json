  "id": "3b3a89f4-407e-5a00-bc5b-3ac9b399ae6b",
  "slug": "grilled-chicken-and-corn",
  "name": "Grilled Chicken and Corn",
  "recipe_type": null,
  "brief_description": "Grilled chicken and corn is a good meal combination. This is perfect for lunch along with coleslaw.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine 1 teaspoon salt, garlic powder, ground black pepper, and paprika. Mix well."
    },
    {
      "position": 2,
      "text": "Rub the mixture on the chicken thighs. Let stand for 3 hours to absorb the flavor. Note: Refrigerate the chicken during this process."
    },
    {
      "position": 3,
      "text": "Heat the grill and start grilling the chicken. Grill each side for about 12 minutes. Note: grilling one side for 12 minutes straight will burn the chicken. Try to rotate the chicken every 3 to 4 minutes while brushing some softened butter."
    },
    {
      "position": 4,
      "text": "Remove the chicken from the grill and arrange in a serving plate."
    },
    {
      "position": 5,
      "text": "Meanwhile, brush some butter and sprinkle salt on each corn."
    },
    {
      "position": 6,
      "text": "Grill the corn for 15 minutes while continuously rotating them to prevent from getting burnt."
    },
    {
      "position": 7,
      "text": "Remove from the grill and brush with additional butter."
    },
    {
      "position": 8,
      "text": "Arrange in a serving plate with the chicken."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
