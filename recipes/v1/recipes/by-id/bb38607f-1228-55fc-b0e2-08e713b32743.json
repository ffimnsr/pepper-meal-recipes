  "id": "bb38607f-1228-55fc-b0e2-08e713b32743",
  "slug": "sweet-and-sour-pork-recip",
  "name": "Sweet and Sour Pork Recipe",
  "recipe_type": "dessert",
  "brief_description": "This Sweet and Sour Pork Recipe is all that you need to make a good Sweet and Sour Pork dish. It is simple, straightforward, and easy to follow.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Place the pork loin in a bowl. Add soy sauce (you may also add salt if desired). Marinate for 10 minutes."
    },
    {
      "position": 2,
      "text": "Pour the cooking oil in a pan then apply heat."
    },
    {
      "position": 3,
      "text": "Combine the flour and cornstarch in a bowl then mix until both ingredients are evenly distributed."
    },
    {
      "position": 4,
      "text": "Dip the marinated pork in beaten egg then on the flour and cornstarch mixture."
    },
    {
      "position": 5,
      "text": "Deep fry the pork (coated with cornstarch and flour) for 10 minutes or until the color turns medium brown. Set aside."
    },
    {
      "position": 6,
      "text": "Heat a separate pan then pour-in the sweet and sour sauce ingredients. Let boil."
    },
    {
      "position": 7,
      "text": "Add the carrots. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Put-in the onions and bell pepper (green and red). Cook for 4 minutes (add extra water as needed)."
    },
    {
      "position": 9,
      "text": "Add the deep-fried pork loin and stir. Cook for 2 minutes. Season with salt and pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving dish and serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
