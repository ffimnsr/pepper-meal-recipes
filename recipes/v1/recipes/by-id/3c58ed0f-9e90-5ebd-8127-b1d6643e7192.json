  "id": "3c58ed0f-9e90-5ebd-8127-b1d6643e7192",
  "slug": "cheesy-garlic-butter-mussels",
  "name": "Cheesy Garlic Butter Mussels",
  "recipe_type": "appetizer",
  "brief_description": "Tender mussels tossed in buttery garlic and Maggi Savor, then blanketed with melty mozzarella and sharp cheddar. Quick, cheesy, and crowd-pleasing.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Melt the butter in a pan, then add the cooking oil."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic until light brown and fragrant."
    },
    {
      "position": 3,
      "text": "Add the onion and cook until softened."
    },
    {
      "position": 4,
      "text": "Add the mussels and saut\u00e9 for 3 minutes."
    },
    {
      "position": 5,
      "text": "Pour in the cooking wine, then add Maggi Savor. Continue cooking until the sauce reduces by half."
    },
    {
      "position": 6,
      "text": "Season with ground black pepper."
    },
    {
      "position": 7,
      "text": "Add the mozzarella and cheddar cheese. Let them melt into the sauce."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve hot and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
