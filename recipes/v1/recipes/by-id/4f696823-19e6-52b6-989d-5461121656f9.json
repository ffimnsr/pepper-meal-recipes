  "id": "4f696823-19e6-52b6-989d-5461121656f9",
  "slug": "sweet-and-sour-mahi-mahi",
  "name": "Sweet and Sour Mahi-mahi",
  "recipe_type": "dessert",
  "brief_description": "Sweet and sour Mahi-mahi is a type of sweet and sour fish recipe. It is one of the easiest and quickest fish dish that you can make.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Season Mahi mahi fillets with salt and pepper."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a frying pan."
    },
    {
      "position": 3,
      "text": "When the oil gets hot, dredge the seasoned mahi mahi fillets in all-purpose flour. Fry each side in medium heat for 3 to 5 minutes or until medium brown. Remove the fried fish from the pan. Arrange in a serving plate. Set aside."
    },
    {
      "position": 4,
      "text": "Meanwhile, make the sweet and sour sauce by combining vinegar, soy sauce, ketchup, and sugar in a bowl. Mix well."
    },
    {
      "position": 5,
      "text": "Heat a saucepan and pour-in the vinegar mixture. Let boil."
    },
    {
      "position": 6,
      "text": "Adjust the heat to medium and then add the carrots, bell peppers, and onion. Stir and cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Pour-in the cornstarch diluted in water. Stir quickly. Continue to stir gently until the texture becomes thick."
    },
    {
      "position": 8,
      "text": "Turn the heat off. Scoop some sweet and sour sauce and top over the fried Mahi mahi."
    },
    {
      "position": 9,
      "text": "Serve with warm steamed white rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
