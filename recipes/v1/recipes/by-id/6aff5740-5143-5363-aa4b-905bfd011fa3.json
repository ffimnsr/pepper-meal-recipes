  "id": "6aff5740-5143-5363-aa4b-905bfd011fa3",
  "slug": "breakfast-dish-how-to-make-crabmeat-omelette-omelet",
  "name": "Crab Meat Omelette",
  "recipe_type": null,
  "brief_description": "Crab meat Omelette is a type of beaten egg preparation with crab meat. This is lightly fried using butter or oil. This is also known as torta",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the frying pan and put-in 2 tbsp of butter then allow to melt."
    },
    {
      "position": 2,
      "text": "Add the onion, crab meat, and green onions then cook until half done"
    },
    {
      "position": 3,
      "text": "Add salt and pepper to taste then set aside."
    },
    {
      "position": 4,
      "text": "Heat the same frying pan (apply low heat) and put-in the remaining butter then allow to melt."
    },
    {
      "position": 5,
      "text": "Crack the eggs and place in a bowl then add some salt"
    },
    {
      "position": 6,
      "text": "Whisk the eggs and pour on the frying pan"
    },
    {
      "position": 7,
      "text": "Tilt the frying pan to allow the uncooked portions of the eggs (liquid form) to occupy the whole surface of the pan. You can also pull from the middle part of the pan to allow uncooked portions of the egg to occupy the space."
    },
    {
      "position": 8,
      "text": "Put the cooked crab meat and onions on top of the half side of the omelette."
    },
    {
      "position": 9,
      "text": "Cover the crab meat and onions by folding the other side of the omelette."
    },
    {
      "position": 10,
      "text": "Place in a serving plate."
    },
    {
      "position": 11,
      "text": "Serve hot with bread or rice. Share and Enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 5,
