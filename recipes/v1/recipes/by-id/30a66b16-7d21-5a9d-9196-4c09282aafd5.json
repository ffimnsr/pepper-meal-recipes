  "id": "30a66b16-7d21-5a9d-9196-4c09282aafd5",
  "slug": "how-to-cook-sotanghon-guisado",
  "name": "Sotanghon Guisado",
  "recipe_type": "main",
  "brief_description": "Garlicky sotanghon pancit recipe",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Soak sotanghon in water for 10 to 12 minutes."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a pan. Add the crushed garlic. Continue cooking until the garlic browns. Remove the garlic. Set aside."
    },
    {
      "position": 3,
      "text": "Make the annatto oil by adding annatto seeds into the pan with the garlic infused oil. Stir until the oil turns orange in color (around 10 seconds). Remove the seeds and discard."
    },
    {
      "position": 4,
      "text": "Saute the pork using the garlic infused annatto oil until it browns."
    },
    {
      "position": 5,
      "text": "Reduce the oil by removing part of it until around 3 tablespoons are left. Continue cooking by saut\u00e9ing the onion until it softens."
    },
    {
      "position": 6,
      "text": "Add carrots. Cook for 1 minute and then add soy sauce and \u00bd cup water. Let boil."
    },
    {
      "position": 7,
      "text": "Add Knorr Shrimp Cube, cabbage, snow peas, and bell pepper. Stir and cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Put the sotanghon into the pan. Gently toss until all the ingredients are well blended."
    },
    {
      "position": 9,
      "text": "Add remaining water. Cover and continue cooking in low heat for 3 minutes."
    },
    {
      "position": 10,
      "text": "Add green onions and season with fish sauce and ground black pepper."
    },
    {
      "position": 11,
      "text": "Sprinkle the toasted garlic on top."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
