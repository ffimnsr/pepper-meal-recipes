  "id": "c5bed1d5-ddac-507f-a6ab-5260db079361",
  "slug": "fried-chicken-gizzard-recipe",
  "name": "Fried Chicken Gizzard",
  "recipe_type": "appetizer",
  "brief_description": "Fried chicken gizzard is a crispy, deeply savory dish made by marinating pre-boiled gizzards in soy sauce and spices, then coating them in a seasoned flour mixture and deep frying until golden. The boiling step ensures the gizzards are tender inside while the double coating of egg and flour gives each piece a satisfying crunch. Serve with your favorite dipping sauce for a great snack or appetizer.",
  "cuisine": "American Comfort Food Filipino Southern",
  "instructions": [
    {
      "position": 1,
      "text": "Place the boiled chicken gizzards in a bowl. Add soy sauce, salt, garlic powder, and ground black pepper. Mix well to coat the gizzards evenly."
    },
    {
      "position": 2,
      "text": "Marinate the gizzards for at least 1 hour."
    },
    {
      "position": 3,
      "text": "Combine the flour and chili powder in a separate bowl. Mix well and set aside."
    },
    {
      "position": 4,
      "text": "Heat the cooking oil in a deep pot over medium-high heat."
    },
    {
      "position": 5,
      "text": "Dip each marinated chicken gizzard in the beaten eggs, then dredge in the flour mixture to coat thoroughly."
    },
    {
      "position": 6,
      "text": "Deep fry the coated gizzards until golden brown."
    },
    {
      "position": 7,
      "text": "Remove the fried gizzards from the pot and transfer to a plate lined with paper towels to absorb excess oil."
    },
    {
      "position": 8,
      "text": "Arrange on a serving plate and serve with your favorite dipping sauce."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 60,
  "difficulty": "medium",
