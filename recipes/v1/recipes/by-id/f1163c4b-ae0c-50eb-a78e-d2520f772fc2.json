  "id": "f1163c4b-ae0c-50eb-a78e-d2520f772fc2",
  "slug": "one-pan-sandwich",
  "name": "One Pan Sandwich",
  "recipe_type": "breakfast",
  "brief_description": "Whether you want something light or easy to take on the go, there\u2019s no better and simpler solution than the humble one pan sandwich.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Heat around 1 tablespoon of cooking oil in a pan. Cook one side of the CDO young Pork Bacon until it becomes crispy (Note: use low to medium heat setting). Turn the bacon over and do the same to the opposite side. Remove the bacon and chop into smaller pieces. Set aside."
    },
    {
      "position": 2,
      "text": "Beat the eggs until smooth. Note: you may add salt if you want."
    },
    {
      "position": 3,
      "text": "Heat 2 tablespoons of cooking oil in a pan. Pour the beaten egg. Cook until firm. Turn it over and continue cooking the other side."
    },
    {
      "position": 4,
      "text": "Meanwhile, spread mayonnaise on one side of each bread slice. Put both bread slices side-by-side on top of the egg with the mayonnaise side facing down."
    },
    {
      "position": 5,
      "text": "Spread butter over each bread slice."
    },
    {
      "position": 6,
      "text": "Using a wide spatula, flip the egg and bread so that the side of the bread with butter touches the pan."
    },
    {
      "position": 7,
      "text": "Arrange CDO Young Pork Bacon on top of the egg (do this only on one side). Continue cooking until the side of the bread that touches the pan turns golden brown in color."
    },
    {
      "position": 8,
      "text": "Secure sandwich by folding the bread wherein one bread slice is on top and the other is on the bottom."
    },
    {
      "position": 9,
      "text": "Remove the sandwich from the pan. Serve for breakfast. Share and enjoy!"
    }
  ],
