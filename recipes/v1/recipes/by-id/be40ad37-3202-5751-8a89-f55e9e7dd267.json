  "slug": "slow-cooked-beefsteak-bistek-tagalog",
  "name": "Slow Cooked Beefsteak (Bistek Tagalog)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Slow Cooked Beefsteak (Bistek Tagalog)",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Put the beef slices in a slow cooker."
    },
    {
      "position": 2,
      "text": "Add garlic, soy sauce, and beef broth. Stir. Set the slow cooker to cook for 4 hours."
    },
    {
      "position": 3,
      "text": "On the 2nd hour, arrange the onion slices on top. Cover and continue to slow cook."
    },
    {
      "position": 4,
      "text": "A few minutes before the slow cooker completes its 4 hour cook time, add the ground black pepper, salt, sugar, and lemon juice. Stir. Cover and cook until the slow cooker completes the cooking time."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 240,
  "preparation_time_minutes": 5,
