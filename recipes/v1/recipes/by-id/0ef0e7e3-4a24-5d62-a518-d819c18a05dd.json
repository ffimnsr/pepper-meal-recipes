  "id": "0ef0e7e3-4a24-5d62-a518-d819c18a05dd",
  "slug": "tochong-bangus-recipe",
  "name": "Tochong Bangus",
  "recipe_type": "main",
  "brief_description": "Milfish with tofu in tomato and bean curd sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the fish. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Fry both sides of the fish until the color turns light to medium brown. Remove fish from the pan and place on a clean plate. Set aside."
    },
    {
      "position": 3,
      "text": "Make the tocho sauce by heating 3 Tablespoons of cooking oil in a clean pan. Saut\u00e9 garlic, onion, ginger, and tomato."
    },
    {
      "position": 4,
      "text": "Once the onion softens, add vinegar, tahure and tausi. Cook for 30 seconds."
    },
    {
      "position": 5,
      "text": "Pour water into the pan. Let boil. Cook in a low heat setting for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add fried fish and fried tofu in the pan. Cover and continue cooking for 8 to 10 minutes. Note: add water as needed."
    },
    {
      "position": 7,
      "text": "Season with salt, ground black pepper, and sugar. Serve with warm rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
