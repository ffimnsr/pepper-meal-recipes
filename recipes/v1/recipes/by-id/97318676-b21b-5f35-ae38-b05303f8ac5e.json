  "id": "97318676-b21b-5f35-ae38-b05303f8ac5e",
  "slug": "boiled-okra-and-eggplant-with-bagoong-dipping-sauce",
  "name": "Boiled Okra and Eggplant with Bagoong Dipping Sauce",
  "recipe_type": null,
  "brief_description": "This is a simple boiled okra and eggplant recipe with bagoong. It is a budget-friendly Filipino vegetable dish that can be cooked in under 20 minutes.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour 6 cups of water in a large cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add the okra. Boil for 3 to 5 minutes. Remove from the cooking pot. Place in the bowl with ice water and let it stay for 2 minutes. Remove and arrange in a plate."
    },
    {
      "position": 3,
      "text": "Meanwhile boil the eggplants for 5 minutes. Remove from the cooking pot and place in the same bowl with cold water. It will be good if ice is added to keep the water cold. Let it stay for 2 to 3 minutes."
    },
    {
      "position": 4,
      "text": "Drain the water and arrange the eggplant in the plate where the okra was placed. Prepare a mixture of bagoong isda with onion and tomato. The recipe link is on the ingredient section above."
    },
    {
      "position": 5,
      "text": "Serve with warm rice."
    },
    {
      "position": 6,
      "text": "Share and enjoy"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
