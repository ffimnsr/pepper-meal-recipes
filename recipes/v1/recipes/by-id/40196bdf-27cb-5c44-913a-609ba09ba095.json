  "id": "40196bdf-27cb-5c44-913a-609ba09ba095",
  "slug": "spinach-tomato-and-cheese-omelette",
  "name": "Spinach Tomato and Cheese Omelette",
  "recipe_type": null,
  "brief_description": "This is a recipe for Spinach Tomato and Cheese Omelette",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt half of the butter in a pan."
    },
    {
      "position": 2,
      "text": "Once the butter starts to bubble, add tomato. Saute for 1 minute."
    },
    {
      "position": 3,
      "text": "Put the spinach in the pan. Cook for 30 seconds. Transfer everything in a clean plate."
    },
    {
      "position": 4,
      "text": "Wipe the pan clean using a paper towel. Heat the pan in a stovetop using low to medium heat. Melt the remaining butter in the pan."
    },
    {
      "position": 5,
      "text": "Beat the eggs in a bowl. Pour into the pan. Tilt the pan to distribute the beaten eggs equally."
    },
    {
      "position": 6,
      "text": "Once the eggs starts to form, pour the cooke tomato and spinach over the egg. Top with shredded cheese. Continue to cook until the eggs are done."
    },
    {
      "position": 7,
      "text": "Fold the omelet halfway to secure the filling. You can top the omelet with more cheese."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 7,
  "preparation_time_minutes": 5,
