  "slug": "chickpea-and-spinach-curry-recipe",
  "name": "Chickpea and Spinach Curry",
  "recipe_type": "side",
  "brief_description": "This is a recipe for spinach curry with chick peas",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan"
    },
    {
      "position": 2,
      "text": "Add onion, ginger powder, and tomato. Stir and cook for 2 minutes."
    },
    {
      "position": 3,
      "text": "Put-in chickpeas, curry, sugar, and vegetable broth. Stir and let boil. Simmer for 5 to 8 minutes."
    },
    {
      "position": 4,
      "text": "Add the spinach. Simmer for 2 minutes."
    },
    {
      "position": 5,
      "text": "Sprinkle salt and ground black pepper as necessary."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
