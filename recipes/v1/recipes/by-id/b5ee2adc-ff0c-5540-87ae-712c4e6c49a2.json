  "id": "b5ee2adc-ff0c-5540-87ae-712c4e6c49a2",
  "slug": "how-to-cook-asian-chicken-bbq-submarine-sandwich",
  "name": "Asian Chicken Barbecue Submarine Sandwich",
  "recipe_type": null,
  "brief_description": "Chicken barbecue sandwich in a submarine bun",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine soy sauce, salt, pepper, and lemon juice. Stir."
    },
    {
      "position": 2,
      "text": "Put-in the chicken breasts and marinate for at least 3 hours."
    },
    {
      "position": 3,
      "text": "Grill chicken until each side is done. Slice into strips, and then set aside."
    },
    {
      "position": 4,
      "text": "Heat a pan and then put-in olive oil."
    },
    {
      "position": 5,
      "text": "Add the onion and cook in medium heat until caramelized. Set aside."
    },
    {
      "position": 6,
      "text": "Combine mayonnaise and Dijon mustard. Mix and spread a reasonable amount of mixture on each side of the sliced sub bread."
    },
    {
      "position": 7,
      "text": "Arrange sliced BBQ chicken and caramelized onion in the sub bread."
    },
    {
      "position": 8,
      "text": "Wrap or put in a plate."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
  "difficulty": "medium",
