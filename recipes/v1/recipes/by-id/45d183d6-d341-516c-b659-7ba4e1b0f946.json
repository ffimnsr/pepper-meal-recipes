  "id": "45d183d6-d341-516c-b659-7ba4e1b0f946",
  "slug": "sweet-potato-casserole-recipe",
  "name": "Sweet Potato Casserole",
  "recipe_type": "dessert",
  "brief_description": "Sweet Potato Casserole is a good example of a simple and easy to make sweet potato dessert. It might be simple, but it is really good.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add the diced sweet potatoes. Continue to boil for 15 to 20 minutes or until the sweet potatoes are soft."
    },
    {
      "position": 3,
      "text": "Remove the sweet potatoes from the pot and let the water drain. Transfer to a large mixing bowl and let cool to room temperature."
    },
    {
      "position": 4,
      "text": "Meanwhile, pre-heat the oven to 350F."
    },
    {
      "position": 5,
      "text": "Mash the sweet potatoes using a potato masher or a fork. Add the milk, white sugar, vanilla and almond extracts, 2 tablespoons of butter, eggs, and 1/2 teaspoon salt. Mix well until all the ingredients are well distributed."
    },
    {
      "position": 6,
      "text": "Arrange the mixture in a baking pan."
    },
    {
      "position": 7,
      "text": "Create the topping by combining all-purpose flour, brown sugar, remaining 2 tablespoons butter, and 1/4 teaspoon salt. Mix all the ingredients well and spread over the potato mixture in the baking pan.Top with pecan chips."
    },
    {
      "position": 8,
      "text": "Place the baking pan in the oven and bake for 28 to 33 minutes."
    },
    {
      "position": 9,
      "text": "Remove the pan from the oven. Let cool."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 28,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
