  "id": "64a40d4d-16f5-51ff-858c-7ea6d0a96b54",
  "slug": "grilled-ribs-with-pico-de-gallo",
  "name": "Grilled Ribs with Pico de Gallo",
  "recipe_type": null,
  "brief_description": "Most Filipino families love to do pork barbecue, grilled pork belly, and grilled bangus. Preparing Grilled Ribs with Pico de Gallo is also a good idea",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the soy sauce, lemon juice, garlic powder, chili powder, ground black pepper, and Worcestershire sauce in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Place the spare ribs in a resealable bag. Pour-in the mixture and then marinate for at least 6 hours."
    },
    {
      "position": 3,
      "text": "Make the basting sauce by pouring the remaining marinade in a bowl. Add the ketchup. Stir."
    },
    {
      "position": 4,
      "text": "Grill the spare ribs for about 8 to 10 minutes per side. You can rotate the ribs to prevent it from getting dry or burnt. Make sure to baste the ribs when rotating."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve with pico de gallo."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 60,
