  "id": "70a2f2d1-1ffe-5efd-8ddf-8b7ee3fb2158",
  "slug": "cornbread",
  "name": "Cornbread Recipe",
  "recipe_type": "side",
  "brief_description": "This cornbread recipe is simply amazing. It is considered as a quick bread ; this type of bread can be made using different cooking methods.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 375 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Combine flour, cornmeal, baking powder, and salt in a large mixing bowl. Stir and set aside."
    },
    {
      "position": 3,
      "text": "Cream butter and sugar using an electric mixer."
    },
    {
      "position": 4,
      "text": "Gradually add the eggs and milk with the creamed butter and sugar."
    },
    {
      "position": 5,
      "text": "Gradually put-in the flour and cornmeal mixture while mixing the other ingredients."
    },
    {
      "position": 6,
      "text": "Pour the batter in a rectangular cake pan."
    },
    {
      "position": 7,
      "text": "Place inside the oven and bake for 21 to 25 minutes"
    },
    {
      "position": 8,
      "text": "Remove the cake pan from the oven and let cool."
    },
    {
      "position": 9,
      "text": "Slice the corn bread into serving pieces."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate, and then serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
