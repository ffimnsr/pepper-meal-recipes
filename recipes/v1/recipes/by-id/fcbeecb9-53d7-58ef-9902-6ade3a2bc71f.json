  "id": "fcbeecb9-53d7-58ef-9902-6ade3a2bc71f",
  "slug": "ginisang-munggo-sauteed-mung-beans",
  "name": "Ginisang Munggo (Monggo)",
  "recipe_type": "side",
  "brief_description": "Sauteed mung beans with spinach. This simple and healthy dish is perfect to have during rainy or cold weather. Serve it with rice and fried fish on side.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a pan, put-in the water and bring to a boil"
    },
    {
      "position": 2,
      "text": "Put-in the Mung beans and simmer until becomes soft (about 35 to 50 minutes)"
    },
    {
      "position": 3,
      "text": "On a separate pan, saut\u00e9 the garlic,onion, and tomato"
    },
    {
      "position": 4,
      "text": "Add the pork. Cook for 5 mins"
    },
    {
      "position": 5,
      "text": "Put-in the beef cube and fish sauce. Simmer for 10 mins or until the meat is tender. Note: If necessary, you may add water to help make the meat tender but make sure to add more time to simmer"
    },
    {
      "position": 6,
      "text": "Add the shrimp. Stir and then cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Pour the cooked Mung beans. Stir and then simmer for 10 minutes"
    },
    {
      "position": 8,
      "text": "Add the spinach and pork rinds (chicharon)"
    },
    {
      "position": 9,
      "text": "Sprinkle the ground black pepper"
    },
    {
      "position": 10,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
