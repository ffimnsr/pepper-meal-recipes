  "id": "4b06899b-aa4d-5229-9b95-46adef8cfe1c",
  "slug": "fried-chicken-breast-with-creamy-lemon-sauce-dip",
  "name": "Fried Chicken Breast with Creamy Lemon Sauce Dip",
  "recipe_type": null,
  "brief_description": "Fried Chicken Breast with Creamy Lemon Sauce Dip is a yummy fried chicken variation. This recipe involves skinless and boneless chicken breast",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and pepper on the chicken breasts. Set aside."
    },
    {
      "position": 2,
      "text": "Make the sauce by melting the butter in a sauce pan."
    },
    {
      "position": 3,
      "text": "Pour-in lemon juice. Stir."
    },
    {
      "position": 4,
      "text": "Pour-in the whipping cream and then add salt."
    },
    {
      "position": 5,
      "text": "When the mixture is about to boil, add-in the egg yolk. Continuously stir for a minute or until the texture becomes thicker. Set aside."
    },
    {
      "position": 6,
      "text": "Meanwhile, heat the cooking oil in a frying pan."
    },
    {
      "position": 7,
      "text": "When the oil becomes hot, dredge the chicken breast in flour and then dip in the beaten egg mixture."
    },
    {
      "position": 8,
      "text": "Dip the chicken in flour for the second time. Deep fry in medium heat for 7 to 9 minutes or until the color turns light to golden brown."
    },
    {
      "position": 9,
      "text": "Arrange in a serving plate along with the creamy lemon sauce."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 9,
  "preparation_time_minutes": 10,
