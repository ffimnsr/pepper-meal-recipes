  "id": "009e3d44-b0a2-54e7-84b7-eaac6a5c7133",
  "slug": "ginataang-sitaw-at-kalabasa-with-fried-tilapia",
  "name": "Ginataang Sitaw at Kalabasa with Fried Tilapia",
  "recipe_type": "main",
  "brief_description": "Ginataang sitaw at kalabasa and crispy fried tilapia served with rice",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the tilapia by washing thoroughly and patting completely dry with paper towels. Rub salt all over the fish, including the cavity. Let it rest for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a large pan over medium-high heat. Fry the tilapia until golden brown and crispy, about 4-5 minutes per side. Remove from pan and drain on paper towels. Arrange on a serving plate and set aside."
    },
    {
      "position": 3,
      "text": "In the same pan (removing excess oil, leaving about 2 tablespoons), saut\u00e9 garlic and onion until fragrant and translucent."
    },
    {
      "position": 4,
      "text": "Add the sliced calabaza squash (kalabasa). Stir-fry for 2 minutes until edges begin to soften."
    },
    {
      "position": 5,
      "text": "Add the string beans. Cook while stirring occasionally for 2 minutes."
    },
    {
      "position": 6,
      "text": "In a small bowl, dissolve the Knorr Ginataang Gulay Mix in 1 \u00bd cups water. Pour into the pan with the vegetables. Cover and bring to a boil. Reduce heat and simmer for 5 to 7 minutes until vegetables are tender and the sauce has thickened."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and additional salt to taste."
    },
    {
      "position": 8,
      "text": "Serve hot with steamed rice and the fried tilapia on the side."
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 10,
  "difficulty": "medium",
