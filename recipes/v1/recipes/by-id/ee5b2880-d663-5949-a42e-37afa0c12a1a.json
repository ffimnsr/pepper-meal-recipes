  "id": "ee5b2880-d663-5949-a42e-37afa0c12a1a",
  "slug": "sinampalukang-kambing",
  "name": "Sinampalukang Kambing",
  "recipe_type": "soup",
  "brief_description": "Sinampalukang Kambing is a sour soup made from goat meat and unripe tamarind. This is similar to sinigang and is a perfect dish to consume during cold weather.This Sinampalukang Kambing recipe makes use of goat meat, although traditional versions use the head of the goat and its feet.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Soak the goat meat in buttermilk overnight. Wash the goat meat thoroughly with running water. Set aside."
    },
    {
      "position": 2,
      "text": "Pour the water in a cooking pot. Bring to a boil."
    },
    {
      "position": 3,
      "text": "Add the goat meat, tamarind, onion, and garlic. Let boil and simmer for 60 to 90 minutes. Add more water if needed."
    },
    {
      "position": 4,
      "text": "Scoop the scums that floats on the soup. Remove the tamarind and ginger."
    },
    {
      "position": 5,
      "text": "Add the leeks and green chilies. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add-in the fish sauce. Stir. Cook for 2 minutes more."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
