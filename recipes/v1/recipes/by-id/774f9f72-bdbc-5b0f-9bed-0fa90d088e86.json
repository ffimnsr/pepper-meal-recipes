  "id": "774f9f72-bdbc-5b0f-9bed-0fa90d088e86",
  "slug": "chicken-sopas-soup-recipe",
  "name": "Chicken Sopas Recipe",
  "recipe_type": "soup",
  "brief_description": "Chicken Sopas or Chicken Macaroni Soup is a delicious creamy soup that is usually served for merienda. This recipe is awesome!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and put-in the butter. Allow the butter to melt."
    },
    {
      "position": 2,
      "text": "Add onions and cook until the texture becomes soft."
    },
    {
      "position": 3,
      "text": "Put-in the boneless chicken breasts and cook for 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Sprinkle some salt and ground black pepper and stir."
    },
    {
      "position": 5,
      "text": "Add chicken broth and bring to a boil."
    },
    {
      "position": 6,
      "text": "Pour-in water and milk and wait to re-boil. Simmer for 15 to 20 minutes."
    },
    {
      "position": 7,
      "text": "Add the elbow macaroni and cook for 8 minutes while stirring once in awhile."
    },
    {
      "position": 8,
      "text": "Put-in the carrots and celery and simmer for 3 minutes."
    },
    {
      "position": 9,
      "text": "Add the cabbage and cook for 2 minutes more."
    },
    {
      "position": 10,
      "text": "Turn-off the heat and transfer to a serving plate."
    },
    {
      "position": 11,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
