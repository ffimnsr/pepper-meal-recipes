  "id": "bce0d713-dc9b-5e8b-a2c8-c6712d8209c3",
  "slug": "bulalo-stewed-beef-shank",
  "name": "Bulalo Recipe",
  "recipe_type": "soup",
  "brief_description": "Filipino beef shank soup",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "In a big cooking pot, pour in water and bring to a boil"
    },
    {
      "position": 2,
      "text": "Put-in the beef shank followed by the onion and whole pepper corn then simmer for 1.5 hours (30 mins if using a pressure cooker) or until meat is tender."
    },
    {
      "position": 3,
      "text": "Add the corn and simmer for another 10 minutes"
    },
    {
      "position": 4,
      "text": "Add the fish sauce,cabbage, pechay, and green onion (onion leeks)"
    },
    {
      "position": 5,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 110,
