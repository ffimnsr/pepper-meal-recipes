  "id": "bbafbeef-092f-5e27-b996-3093d69125d7",
  "slug": "bibingka-muffins",
  "name": "Bibingka Muffins",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Bibingka Muffins.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 375F"
    },
    {
      "position": 2,
      "text": "Combine sweet rice flour, salt, and baking powder. Mix well. Set aside."
    },
    {
      "position": 3,
      "text": "Crack the eggs in a bowl. Beat the eggs."
    },
    {
      "position": 4,
      "text": "Gradually add the sugar while beating and then pour the vanilla extract. Continue to beat until well blended."
    },
    {
      "position": 5,
      "text": "Combine the egg mixture with the sweet rice flour mixture. Stir until the mixture becomes smooth."
    },
    {
      "position": 6,
      "text": "Arrange the muffin cups on the muffin pan. Scoop some bibingka mixture into each cup. Bake for 28 minutes."
    },
    {
      "position": 7,
      "text": "Remove from the oven. Spread some margarine over each bibingka muffins and then top with cheese and salted egg."
    },
    {
      "position": 8,
      "text": "Put the muffin tray back into the oven and continue to bake for 3 to 5 minutes."
    },
    {
      "position": 9,
      "text": "Remove the bibingka from the oven. Let it cool down. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 30,
