  "schema_version": 1,
  "id": "556b5aa4-a1c3-5681-aa45-57afbc9983c3",
  "slug": "garlic-mushroom",
  "name": "Garlic Mushroom",
  "recipe_type": "appetizer",
  "brief_description": "Mushrooms sauteed in onion with white wine and thyme and lots of garlic.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a pan and then add the olive oil."
    },
    {
      "position": 2,
      "text": "Once the butter is completely melted and the bubbling subsides, add the garlic. Saute until the garlic turns light brown."
    },
    {
      "position": 3,
      "text": "Add the onion. Cook until it softens"
    },
    {
      "position": 4,
      "text": "Add the mushrooms. Cook for 1 minute while stirring."
    },
    {
      "position": 5,
      "text": "Add Knorr liquid seasoning and pour the white wine into the pan. Add thyme. Cook until the wine reduces to a quarter."
    },
    {
      "position": 6,
      "text": "Season with salt and pepper. Top with chopped parsley."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
