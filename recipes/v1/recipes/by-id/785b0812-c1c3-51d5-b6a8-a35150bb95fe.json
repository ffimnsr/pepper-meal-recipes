  "slug": "ginisang-repolyo-with-giniling",
  "name": "Ginisang Reployo with Giniling",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginisang Reployo with Giniling",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute garlic until it turns light brown."
    },
    {
      "position": 3,
      "text": "Add the onion and tomato. Continue to cook until soft."
    },
    {
      "position": 4,
      "text": "Put the ground pork into the pot. Cook until the color turns light brown."
    },
    {
      "position": 5,
      "text": "Pour chicken broth and let boil. Cover and cook for 15 minutes."
    },
    {
      "position": 6,
      "text": "Add the bell peppers and cabbage. Cover and cook for 5 to 8 minutes."
    },
    {
      "position": 7,
      "text": "Add fish sauce and ground black pepper. Cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
