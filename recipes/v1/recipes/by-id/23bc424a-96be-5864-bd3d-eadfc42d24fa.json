  "id": "23bc424a-96be-5864-bd3d-eadfc42d24fa",
  "slug": "beer-brats-recipe",
  "name": "Beer Brats Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for beer bratwurst. It is tasty and easy to make.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour-in the beer."
    },
    {
      "position": 2,
      "text": "Add the onion, butter, garlic powder, salt, and pepper. Let boil."
    },
    {
      "position": 3,
      "text": "Put-in the bratwurst and cook in low to medium heat for about 16 minutes."
    },
    {
      "position": 4,
      "text": "Remove the bratwurst. Continue cooking the onions until the liquid reduces to about a few tablespoons."
    },
    {
      "position": 5,
      "text": "Grill the bratwurst for 8 to 10 minutes while rotating to cook all the sides. Set aside."
    },
    {
      "position": 6,
      "text": "Arrange the bratwurst in hotdog buns and top with the onion."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
