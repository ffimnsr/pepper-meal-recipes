  "id": "eec1ef8b-5d70-53f4-ab1c-f9691b1a1175",
  "slug": "dessert-peach-refrigerator-cake-recipe",
  "name": "Peach Refrigerator Cake",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Peach Refrigerator Cake.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine condensed milk and table cream and mix thoroughly. Refrigerate for 3 hours to thicken the mixture."
    },
    {
      "position": 2,
      "text": "Arrange a layer of graham crackers in a baking pan or any container of your choice."
    },
    {
      "position": 3,
      "text": "Pour half of the condensed milk and table cream mixture over the arranged graham crackers and spread until the crackers all well covered."
    },
    {
      "position": 4,
      "text": "Arrange some sliced peaches on top of the mixture (you may slice the peaches in half to make it thinner)."
    },
    {
      "position": 5,
      "text": "Place another layer of graham crackers over the peaches."
    },
    {
      "position": 6,
      "text": "Pour-in the remaining mixture over the second layer of graham crackers and spread evenly."
    },
    {
      "position": 7,
      "text": "Top the mixture with the remaining sliced peaches."
    },
    {
      "position": 8,
      "text": "Refrigerate overnight."
    },
    {
      "position": 9,
      "text": "Serve for dessert. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
