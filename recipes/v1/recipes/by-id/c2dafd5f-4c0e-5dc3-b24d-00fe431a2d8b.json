  "id": "c2dafd5f-4c0e-5dc3-b24d-00fe431a2d8b",
  "slug": "red-velvet-cupcake-recipe",
  "name": "Red Velvet Cupcake Recipe",
  "recipe_type": "dessert",
  "brief_description": "Classic red velvet cupcakes with cream cheese frosting",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine fresh milk and vinegar. Mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Arrange the paper cups in 2 cupcake trays. Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 3,
      "text": "Cream the butter until the texture becomes smooth. Put-in the sugar while continuously beating. Do this until the texture becomes cottony. Put-in the eggs and vanilla extract. Beat until it mixes well with the other ingredients. Set aside."
    },
    {
      "position": 4,
      "text": "Combine the milk and vinegar mixture with the food coloring. Mix well. Set aside."
    },
    {
      "position": 5,
      "text": "Combine the flour and baking soda. Mix well."
    },
    {
      "position": 6,
      "text": "Put-in about a few tablespoons of the cake flour mixture followed by a few tablespoons of the milk and food coloring mixture on the bowl of the butter mixture while beating. Continue this process until all the flour and food coloring mixture is used up."
    },
    {
      "position": 7,
      "text": "Pour the mixture equally on the paper cups. Bake for 16 to 22 minutes or until it passes the toothpick test"
    },
    {
      "position": 8,
      "text": "Let the cupcakes cool down by placing each in a wire rack."
    },
    {
      "position": 9,
      "text": "Apply the cream cheese frosting on top."
    },
    {
      "position": 10,
      "text": "Serve for dessert. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 16,
  "preparation_time_minutes": 10,
