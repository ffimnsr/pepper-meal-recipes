  "id": "770e0b23-0a63-501e-a61a-ea908fec6d38",
  "slug": "beer-and-cilantro-marinated-prawn",
  "name": "Beer and Cilantro Marinated Prawn",
  "recipe_type": null,
  "brief_description": "Beer and Cilantro Marinated Prawn is an easy and hassle-free way to make lunch. For extra flavor , the prawn are marinated in a mixture of ale beer and cilantro before grilling.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine beer and cilantro in a bowl. Stir and then add the prawn. Let it stay for at least 3 hours."
    },
    {
      "position": 2,
      "text": "Make the basting sauce by combining butter, salt, and garlic powder. Mix well."
    },
    {
      "position": 3,
      "text": "Heat-up the grill. Put the marinated prawn on the grill and then continue to grill one side for 4 minutes. Baste the opposite side with the butter mixture. Turn the prawn over to grill the other side. Do not forget to apply the basting sauce."
    },
    {
      "position": 4,
      "text": "Transfer the grilled prawn in a serving plate. Serve with lemon wedges."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 180,
