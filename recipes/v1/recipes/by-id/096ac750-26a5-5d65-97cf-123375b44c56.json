  "id": "096ac750-26a5-5d65-97cf-123375b44c56",
  "slug": "crispy-fried-mahi-mahi-sarciado",
  "name": "Crispy Fried Mahi Mahi Sarciado",
  "recipe_type": null,
  "brief_description": "This is a recipe for Crispy Fried Mahi Mahi Sarciado",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub garlic salt all over the Mahi Mahi fillets. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat 2 cups oil in a deep cooking pot."
    },
    {
      "position": 3,
      "text": "While the oil is heating-up, dredge the fish in all-purpose flour. Shake off any excess flour."
    },
    {
      "position": 4,
      "text": "Deep fry in medium heat until the outer part turns crispy and medium brown. Note: this can take up to 8 to 12 minutes."
    },
    {
      "position": 5,
      "text": "Remove the fish from the pot. Let the excess oil drip. Arrange in a plate."
    },
    {
      "position": 6,
      "text": "Prepare the sauce by heating olive oil in a cooking pot or saucepan."
    },
    {
      "position": 7,
      "text": "Saute onion and tomato until both becomes soft. Cover the pot. Continue to cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Pour vegetable broth (or water). Add egg and garlic salt. Stir and continue to cook until the egg starts to curdle."
    },
    {
      "position": 9,
      "text": "Pour the sauce over the fried Mahi Mahi. serve with your favorite side dish."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
