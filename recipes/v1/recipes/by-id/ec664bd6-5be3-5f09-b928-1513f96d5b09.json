  "id": "ec664bd6-5be3-5f09-b928-1513f96d5b09",
  "slug": "patotin",
  "name": "Patotin Recipe",
  "recipe_type": "main",
  "brief_description": "Braised duck with vegetables.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the duck. Let it stay for 5 minutes."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a pan. Fry the duck for 3 minutes per side. Remove the duck from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil, saute onion and garlic."
    },
    {
      "position": 4,
      "text": "Once the onion softens, pour soy sauce, pineapple juice, and lemon lime soda. Cover the pan and let the liquid boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Chicken Cube, dried bay leaves, and cracked peppercorn. Stir."
    },
    {
      "position": 6,
      "text": "Add the fried duck back into the pan. Boil for 35 minutes per side."
    },
    {
      "position": 7,
      "text": "Add brown sugar and banana ketchup. Stir. Continue cooking until the sauce thickens to your desired consistency."
    },
    {
      "position": 8,
      "text": "Steam the vegetables for 5 minutes."
    },
    {
      "position": 9,
      "text": "Arrange the duck on a serving plate and put the steamed vegetables on the side as garnish. Top with sauce. Serve and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
