  "slug": "how-to-cook-bacon-potato-and-cheese-frittata",
  "name": "Bacon Frittata Recipe",
  "recipe_type": null,
  "brief_description": "Frittata with bacon, potato, tomato, and cheese",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a frying pan and pour-in olive oil"
    },
    {
      "position": 2,
      "text": "Add the potatoes an fry until the color turns light brown."
    },
    {
      "position": 3,
      "text": "Combine eggs, salt, bacon, and milk. Whisk and pour over the potatoes.Cook in low to medium heat for 4 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Arrange cheese, tomatoes, and basil over the egg. Cover the pan and continue cooking in low heat for 4 to 6 minutes."
    },
    {
      "position": 5,
      "text": "Turn off the heat and transfer to a serving plate."
    },
    {
      "position": 6,
      "text": "Serve with toasted bread for breakfast."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
