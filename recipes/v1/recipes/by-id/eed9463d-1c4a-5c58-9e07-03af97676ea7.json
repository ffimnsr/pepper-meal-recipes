  "id": "eed9463d-1c4a-5c58-9e07-03af97676ea7",
  "slug": "chicken-and-liver-adobo",
  "name": "Chicken and Liver Adobo",
  "recipe_type": "main",
  "brief_description": "Chicken and liver cooked inadobo style with oyster sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Pan-fry chicken liver until thoroughly cooked. Remove from pan. Set aside."
    },
    {
      "position": 2,
      "text": "Using the remaining oil, saute garlic for 15 seconds. Add chicken pieces. Fry each side for 15 seconds."
    },
    {
      "position": 3,
      "text": "Pour vinegar. Let boil. Deglaze the chicken liver particles by gently scraping the bottom of the pan. Cover and cook in medium heat for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add oyster sauce, whole peppercorn, dried bay leaves, and water. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Chicken Cube. Cover the pan. Cook for 15 minutes."
    },
    {
      "position": 6,
      "text": "Mash the fried chicken liver. Add it back to the pan. Stir and cook for 15 to 20 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with warm rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
