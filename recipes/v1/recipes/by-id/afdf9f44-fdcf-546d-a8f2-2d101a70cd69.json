  "id": "afdf9f44-fdcf-546d-a8f2-2d101a70cd69",
  "slug": "barbecue-pork-chop-with-mixed-veggies",
  "name": "Barbecue Pork Chop with Mixed Veggies",
  "recipe_type": null,
  "brief_description": "Kids are picky eaters; they will choose fried food over healthy ones and often avoid vegetables. Barbecue Pork Chop with Mixed veggies might be the answer that you are looking for.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Season the pork chop with salt and pepper."
    },
    {
      "position": 2,
      "text": "Coat the pork chops with barbecue sauce. Let it stay for 3 hours."
    },
    {
      "position": 3,
      "text": "Meanwhile, melt the butter in a pan."
    },
    {
      "position": 4,
      "text": "Add the mixed vegetables. Cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Sprinkle some salt and pepper to taste. Set aside."
    },
    {
      "position": 6,
      "text": "Grill the pork chops in medium heat for about 10 to 12 minutes per side (depending on thickness). Baste with remaining BBQ sauce."
    },
    {
      "position": 7,
      "text": "Transfer on a serving plate. Serve with mixed veggies and mashed potatoes."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
