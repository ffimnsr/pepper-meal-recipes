  "id": "67fd1bc4-0a28-5629-b448-670e69dfe14d",
  "slug": "kilawin-puso-ng-saging-banana-blossoms",
  "name": "Kilawing Puso ng Saging",
  "recipe_type": "side",
  "brief_description": "Kilawing Puso ng Saging is a Filipino recipe involving banana blossoms. This is considered as a vegetable dish wherein the blossoms are sauteed with garlic and onion and cooked in vinegar.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Soak the chopped banana blossoms in the bowl with brine for 15 to 20 minutes. After soaking, squeeze tightly to release the sap from the banana blossoms. Place in a colander to drain the water. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 3,
      "text": "Saute the garlic and onion."
    },
    {
      "position": 4,
      "text": "Add the banana blossoms. Cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the fish sauce and vegetable broth, Stir and let boil."
    },
    {
      "position": 6,
      "text": "Pour-in the vinegar. Allow to re-boil, cover, and simmer for 10 to 15 minutes."
    },
    {
      "position": 7,
      "text": "Add the green chili and ground black pepper.Stir and continue to cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Turn-off the heat and transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
