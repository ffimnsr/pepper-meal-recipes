  "id": "e4502be7-b6ac-5db0-9c3e-2e9c5931db4e",
  "slug": "shrimp-fried-rice-with-sausage-vietnamese-fried-rice-recipe",
  "name": "Shrimp Fried Rice with Sausage (Vietnamese Fried Rice Recipe)",
  "recipe_type": "breakfast",
  "brief_description": "Shrimp fried rice with Chinese sausage, eggs, and vegetables. Stir-fried with garlic, onion, soy sauce, and Maggi Savor.",
  "cuisine": "Vietnamese",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a wok or large pan. Pour the beaten eggs and scramble until just set. Season with Maggi Magic Sarap. Remove and set aside."
    },
    {
      "position": 2,
      "text": "Using the same pan, fry the shrimp for 1 to 2 minutes per side or until it turns pink. Remove and set aside."
    },
    {
      "position": 3,
      "text": "Add the Chinese sausage. Cook over medium heat for 3 to 4 minutes or until the edges start to crisp. Add the butter and let it melt."
    },
    {
      "position": 4,
      "text": "Saut\u00e9 the garlic and onion until the onion softens."
    },
    {
      "position": 5,
      "text": "Add the carrots and green peas. Stir-fry for 2 to 3 minutes."
    },
    {
      "position": 6,
      "text": "Add the rice. Break it apart and toss until everything is mixed. Stir-fry over high heat for 3 to 4 minutes."
    },
    {
      "position": 7,
      "text": "Season with soy sauce, fish sauce, Maggi Savor, and ground black pepper. Mix well."
    },
    {
      "position": 8,
      "text": "Put the shrimp, sausage, and scrambled eggs back in the pan. Toss everything together."
    },
    {
      "position": 9,
      "text": "Add chopped scallions. Turn off the heat. Give it one final mix and serve."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
