  "id": "3d55ca92-10bc-544c-9b97-7111f30ac260",
  "slug": "pancit-palabok-recipe",
  "name": "Palabok Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pancit Palabok",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour 2 to 3 quarts water in a large mixing bowl or pot. Soak the palabok noodles in water for 30 minutes (or follow the package instructions)."
    },
    {
      "position": 2,
      "text": "Remove the soaked noodles from the bowl and set aside."
    },
    {
      "position": 3,
      "text": "Meanwhile, pour the water in a large cooking pot. Let boil."
    },
    {
      "position": 4,
      "text": "Put the noodles into the pot. Cook for 10 to 15 minutes or until soft. Remove noodles from the pot and drain the excess water. Place the noodles in a large bowl and cover it (this will prevent it from being exposed in air, which can eventually dry the noodles). Set aside."
    },
    {
      "position": 5,
      "text": "Add shrimp on the same pot with boiling water. Cook for 1 \u00bd minutes or until it floats; Remove from the pot and set aside."
    },
    {
      "position": 6,
      "text": "Put Napa cabbage into the pot. Boil for 1 minute. Remove and set aside."
    },
    {
      "position": 7,
      "text": "Prepare the sauce by pouring oil in a clean cooking pot."
    },
    {
      "position": 8,
      "text": "Once the oil gets hot, add the pork. Saut\u00e9 until light brown"
    },
    {
      "position": 9,
      "text": "Pour fish sauce into the pot along with the annatto water. Stir."
    },
    {
      "position": 10,
      "text": "Pour 3 \u00bd cups water into the pot and let it boil. Cover the pot and continue to cook in medium heat for 15 to 18 minutes or until the pork gets tender. Note: If needed, you can add more water to prevent the sauce from drying out."
    },
    {
      "position": 11,
      "text": "Remove the cover and Knorr Shrimp Cube and tinapa flakes. Continue to cook for 5 minutes."
    },
    {
      "position": 12,
      "text": "Combine flour with \u00bd cup water. Stir until texture becomes smooth. Pour the mixture into the pot. Stir. Continue to cook until desired thick texture is achieved."
    },
    {
      "position": 13,
      "text": "Add the ground black pepper. Stir."
    },
    {
      "position": 14,
      "text": "Assemble the palabok by placing noodles in a plate. Pour the sauce over the noodles and then top with Napa cabbage, shrimp, and sliced boiled eggs. Sprinkle crushed chicharon and chopped scallions on top."
    },
    {
      "position": 15,
      "text": "Serve with calamansi or lime. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
