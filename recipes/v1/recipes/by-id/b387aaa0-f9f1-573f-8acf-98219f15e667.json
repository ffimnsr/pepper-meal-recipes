  "id": "b387aaa0-f9f1-573f-8acf-98219f15e667",
  "slug": "pasta-olive-garden-style-fettuccine-alfredo-bacon-recipe",
  "name": "Fettuccine Alfredo Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Fettuccine Alfredo.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the fettuccine according to package instructions"
    },
    {
      "position": 2,
      "text": "Heat a saucepan or cooking pot and pour-in the milk then bring to a boil"
    },
    {
      "position": 3,
      "text": "Add the heavy whipping cream and stir then let boil."
    },
    {
      "position": 4,
      "text": "Adjust the heat to the lowest possible then add the Parmesan and Romano cheeses. Stir continuously until cheese melts and the texture of the mixture becomes fine."
    },
    {
      "position": 5,
      "text": "Whisk the egg yolks in a mixing bowl then add about 5 tablespoons of the milk-cheese mixture. Continue whisking until everything is well distributed."
    },
    {
      "position": 6,
      "text": "Add the egg yolk mixture in the saucepan/cooking pot and stir until the texture becomes thick."
    },
    {
      "position": 7,
      "text": "Add the cooked fettuccine and toss until the noodles are well covered with sauce."
    },
    {
      "position": 8,
      "text": "Add the crumbled fried bacon, salt, and pepper and mix with the other ingredients."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate then serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
