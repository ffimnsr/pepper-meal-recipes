  "id": "307eb3ef-381a-5273-99f7-0441fd6f05e3",
  "slug": "sisig-paella",
  "name": "Sisig Paella",
  "recipe_type": "main",
  "brief_description": "Paella with minced pork and chorizo",
  "cuisine": "Filipino Spanish",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil. Saut\u00e9 onion and garlic until the onion softens."
    },
    {
      "position": 2,
      "text": "Add chorizo, pork belly, and Knorr Pork Cube. Saut\u00e9 for 1 minute."
    },
    {
      "position": 3,
      "text": "Add the paella rice. Cook for 1 minute while stirring."
    },
    {
      "position": 4,
      "text": "Pour the water into the pan and add Knorr Liquid Seasoning and bell pepper. Stir. Cover the pot. Continue cooking until the rice is done."
    },
    {
      "position": 5,
      "text": "Sprinkle green onions on top. Crack the eggs and top over the rice. Add long green pepper. Cover and cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Combine the dressing ingredients and drizzle over the sisig paella. Serve with lemon wedges."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
