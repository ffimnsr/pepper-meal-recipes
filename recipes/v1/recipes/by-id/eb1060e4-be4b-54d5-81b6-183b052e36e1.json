  "id": "eb1060e4-be4b-54d5-81b6-183b052e36e1",
  "slug": "easy-beef-salpicao-recipe",
  "name": "Beef Salpicao",
  "recipe_type": null,
  "brief_description": "Marinated beef with Worcestershire and Oyster sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pound garlic using a mortar and pestle tool."
    },
    {
      "position": 2,
      "text": "Combine garlic and olive oil in a pan. Turn on your stove and set the heat to between low and medium. Cook garlic while stirring until it turns golden brown."
    },
    {
      "position": 3,
      "text": "Remove the fried garlic and oil from the pan and place these in separate bowls. Set aside."
    },
    {
      "position": 4,
      "text": "Combine beef, salt, ground black pepper, olive oil, and Worcestershire sauce. Mix well. Let it stay for 10 minutes."
    },
    {
      "position": 5,
      "text": "Heat a clean pan. Once the pan gets really hot, sear the marinated beef until the sides turn brown."
    },
    {
      "position": 6,
      "text": "Add oyster sauce and a bit of butter. Note: save the remaning butter for later. Continue cooking for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add remaining butter along with the fried garlic and parsley. Continue cooking until the liquid evaporates completely."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 40,
  "rest_time_minutes": null,
  "difficulty": "medium",
