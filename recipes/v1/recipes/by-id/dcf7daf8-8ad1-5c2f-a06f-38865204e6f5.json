  "id": "dcf7daf8-8ad1-5c2f-a06f-38865204e6f5",
  "slug": "picadillo-recipe",
  "name": "Picadillo Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Picadillo",
  "cuisine": "Filipino Spanish",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute onion and garlic until the onion becomes soft and translucent."
    },
    {
      "position": 3,
      "text": "Slowly add the ground beef. Cook until it turns light brown."
    },
    {
      "position": 4,
      "text": "Add diced tomato, beef broth, and raisins. Stir and let boil. Cover and cook for 15 minutes."
    },
    {
      "position": 5,
      "text": "Add olives, carrots, potato, and green peas. Stir and cover. Cook for 10 to 12 minutes."
    },
    {
      "position": 6,
      "text": "Season with crushed black pepper and salt. Cook for 3 minutes more."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
