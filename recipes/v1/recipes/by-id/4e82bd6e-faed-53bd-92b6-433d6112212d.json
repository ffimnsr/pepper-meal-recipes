  "id": "4e82bd6e-faed-53bd-92b6-433d6112212d",
  "slug": "shrimp-and-vegetable-fried-rice",
  "name": "Shrimp and Vegetable Fried Rice Recipe",
  "recipe_type": "side",
  "brief_description": "Shrimp and Vegetable Fried Rice is a nice way to enjoy lunch. This delicious recipe will surely be a hit. Try it today!",
  "cuisine": "American Chinese Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the broccoli, cauliflower, and carrots in a small bowl. Heat the vegetables in a microwave oven for 4 minutes. Set aside."
    },
    {
      "position": 2,
      "text": "Combine rice, garlic powder, onion powder, and salt. Mix well."
    },
    {
      "position": 3,
      "text": "Melt butter in a wide pan."
    },
    {
      "position": 4,
      "text": "Put-in shrimps and cook for a minute per side. Remove the shrimps and then set aside."
    },
    {
      "position": 5,
      "text": "Using the same pan with the remaining butter, add-in the rice. Gently stir every 30 seconds for the next 5 to 7 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in soy sauce. Stir until well distributed."
    },
    {
      "position": 7,
      "text": "Put-in shrimps and vegetables. Stir. Cook for 3 minutes more."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": null,
  "cooking_time_minutes": 15,
