  "id": "e54f7854-efcd-52fe-a5c9-7e889fcf487f",
  "slug": "ginataang-monggo-with-pork-recipe",
  "name": "Ginataang Monggo with Pork Recipe",
  "recipe_type": null,
  "brief_description": "How to Cook Ginataang Monggo with Pork.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot."
    },
    {
      "position": 2,
      "text": "Put the pork into the pot. Sear until oil is extracted."
    },
    {
      "position": 3,
      "text": "Add onion and garlic. Saute until onion becomes soft."
    },
    {
      "position": 4,
      "text": "Add the mung beans. Stir. Continue to saute for 2 to 3 minutes. Note: the texture of the monggo should be soft as a result of soaking in water overnight."
    },
    {
      "position": 5,
      "text": "Pour-in 4 cups water and then add coconut milk. Let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Pork Cube. Stir. Cover and cook between low to medium heat for 30 to 35 minutes. Note: add more water if the liquid starts to dry-up."
    },
    {
      "position": 7,
      "text": "Put the greens (ampalaya leaves and spinach) and chili pepper into the pot. Cover the pot and cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Add fish sauce (patis) and ground black pepper. Stir."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
