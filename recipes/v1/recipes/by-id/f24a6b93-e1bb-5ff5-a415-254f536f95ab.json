  "id": "f24a6b93-e1bb-5ff5-a415-254f536f95ab",
  "slug": "ginataang-alimasag-with-malunggay",
  "name": "Ginataang Alimasag with Malunggay",
  "recipe_type": null,
  "brief_description": "Ginataang alimasag with Malunggay was perfect for dinner tonight. Although the name of the dish did not include the butternut squash, this ingredient is still as important as the main ingredients.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the coconut cream, coconut milk, onion, ginger, and garlic in a cooking pot. Let boil. cover and simmer for 15 to 20 minutes."
    },
    {
      "position": 2,
      "text": "Add the shrimp paste. Stir. Cover and cook for 5 minutes."
    },
    {
      "position": 3,
      "text": "Add the butternut squash. Stir, cover, and continue to cook for 12 minutes in low to medium heat."
    },
    {
      "position": 4,
      "text": "Put-in the ground black pepper. Stir."
    },
    {
      "position": 5,
      "text": "Add the malunggay leaves. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the crabs and long green chili. Stir and continue to cook for 12 to 15 minutes or until the sauce thickens. Add fish sauce, if needed."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
