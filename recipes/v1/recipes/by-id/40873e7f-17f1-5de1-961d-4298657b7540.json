  "id": "40873e7f-17f1-5de1-961d-4298657b7540",
  "slug": "linat-an-recipe",
  "name": "Linat an Recipe (Boiled Pork Soup with Lemongrass)",
  "recipe_type": "soup",
  "brief_description": "linat an is a boiled pork soup dish that resembles Pork Nilaga. Although both dishes might sound the same, there are notable differences",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine rice washing and beef broth in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Put-in the spare ribs, lemongrass, and onion. Simmer for 45 to 60 minutes or until the pork becomes tender."
    },
    {
      "position": 3,
      "text": "Add-in the gabi. Cook for 5 to 8 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the string beans and bell pepper. Cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the green onions. Cook for a minute."
    },
    {
      "position": 6,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
