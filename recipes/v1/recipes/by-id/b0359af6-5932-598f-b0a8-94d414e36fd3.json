{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "b0359af6-5932-598f-b0a8-94d414e36fd3",
  "slug": "creamy-chicken-sopas",
  "name": "Creamy Chicken Sopas",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for a chicken macaroni soup which I name Creamy Chicken Sopas. It is rich, flavorful, and delicious.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 3 cups water in a medium pot. Add the chicken breasts."
    },
    {
      "position": 2,
      "text": "Cover and cook in medium heat for 15 to 18 minutes. You may add more water if needed."
    },
    {
      "position": 3,
      "text": "Separate the chicken from the water. Let the chicken cool down and then shred. Set both shredded chicken and water aside."
    },
    {
      "position": 4,
      "text": "Heat oil in a large soup pot. Saut\u00e9 the garlic until it turns medium brown. Add onion, celery, and carrot. Continue to saut\u00e9 for 2 to 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the shredded chicken. Stir and cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Add the hot dog. Quickly stir and then pour the water used to boil the chicken. Also pour the remaining water. Let boil."
    },
    {
      "position": 7,
      "text": "Add the Knorr Chicken Cube. Stir. Cover and cook for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Put the elbow macaroni in the pot. Cook for 10 minutes."
    },
    {
      "position": 9,
      "text": "Add the cabbage. Stir and cook for 3 to 5 minutes. Note: you can add more water if needed."
    },
    {
      "position": 10,
      "text": "Pour the evaporated milk. Stir, let boil, cover and cook for another 3 minutes."
    },
    {
      "position": 11,
      "text": "Add salt and ground black pepper to taste."
    },
    {
      "position": 12,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
