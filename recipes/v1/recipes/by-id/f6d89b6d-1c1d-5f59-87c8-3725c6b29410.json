  "id": "f6d89b6d-1c1d-5f59-87c8-3725c6b29410",
  "slug": "creamy-chicken-pasta-with-bacon",
  "name": "Creamy Chicken Pasta with Bacon",
  "recipe_type": "salad",
  "brief_description": "Chicken pasta salad with bacon",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the chicken rub ingredients in a bowl. Mix well. Rub it all over the chicken breast."
    },
    {
      "position": 2,
      "text": "Boil water in a cooking pot and add 1 teaspoon of salt. Put the pasta in. Cook according to package instructions. Drain the water and set the pasta aside."
    },
    {
      "position": 3,
      "text": "Cook bacon in a pan until bacon oil is extracted and the bacon becomes crispy. Remove the crispy bacon from the pan. Set aside."
    },
    {
      "position": 4,
      "text": "Using the bacon oil, fry the chicken breast for 5 to 8 minutes per side (note: the thicker the breast, the longer the frying time). Remove the chicken and let it cool down. Slice into serving pieces. Set aside."
    },
    {
      "position": 5,
      "text": "Combine the pasta dressing ingredients and mix well."
    },
    {
      "position": 6,
      "text": "Arrange pasta in a mixing bowl and then toss-in the dressing. Add tomato, spinach, chicken, bacon, red pepper flakes, and Parmesan cheese. Toss until all ingredients are well distributed."
    },
    {
      "position": 7,
      "text": "Transfer to a pasta bowl and serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
