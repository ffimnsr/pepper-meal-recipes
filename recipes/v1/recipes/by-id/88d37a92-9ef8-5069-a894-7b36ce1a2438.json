  "id": "88d37a92-9ef8-5069-a894-7b36ce1a2438",
  "slug": "oven-baked-crusted-pork-loin-recipe",
  "name": "Oven Baked Crusted Pork Loin",
  "recipe_type": null,
  "brief_description": "Kids love Oven Baked Crusted Pork Loin. This dish is tender, low in fat, and can be eaten with their favorite condiments.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt and pepper on the sliced pork. Gently rub and then let it stand for 30 minutes."
    },
    {
      "position": 2,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 3,
      "text": "Dredge the pork in flour and then dip in beaten egg. Place the pork in the bowl with the breadcrumbs and press a little to let the bread crumbs coat and stick."
    },
    {
      "position": 4,
      "text": "Heat olive oil in a pan."
    },
    {
      "position": 5,
      "text": "Pan-fry the crusted pork in low to medium heat for about 3 to 4 minutes per side."
    },
    {
      "position": 6,
      "text": "Transfer the pan fried pork in an oven tray. Bake for 20 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with your favorite condiment. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
