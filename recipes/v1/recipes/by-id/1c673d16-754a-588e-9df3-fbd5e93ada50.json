  "id": "1c673d16-754a-588e-9df3-fbd5e93ada50",
  "slug": "kangkong-and-tofu-stir-fry-recipe",
  "name": "Kangkong and Tofu Stir Fry",
  "recipe_type": "main",
  "brief_description": "This is a healthy recipe involving kangkong or water spinach and extra firm tofu.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a pan"
    },
    {
      "position": 2,
      "text": "Fry the tofu in medium heat for about 4 to 5 minutes per side"
    },
    {
      "position": 3,
      "text": "Turn off heat. Remove the tofu from the pan and let cool."
    },
    {
      "position": 4,
      "text": "Slice the fried tofu into small cubes. Set aside."
    },
    {
      "position": 5,
      "text": "On the same pan, remove excess cooking oil until about 1 tablespoon of oil is left."
    },
    {
      "position": 6,
      "text": "Heat the pan. Saut\u00e9 garlic and onion for about 2 minutes"
    },
    {
      "position": 7,
      "text": "Put-in the sliced tofu and cook for 2 to 3 minutes."
    },
    {
      "position": 8,
      "text": "Add the oyster sauce and ground black pepper. Stir."
    },
    {
      "position": 9,
      "text": "Put-in the kangkong. Stir fry for 4 to 5 minutes."
    },
    {
      "position": 10,
      "text": "Add salt to taste and then put-in the chilies."
    },
    {
      "position": 11,
      "text": "Turn off heat. Transfer to a serving plate"
    },
    {
      "position": 12,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
