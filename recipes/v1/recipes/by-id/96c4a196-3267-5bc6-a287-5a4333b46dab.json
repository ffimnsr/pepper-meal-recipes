  "id": "96c4a196-3267-5bc6-a287-5a4333b46dab",
  "slug": "creamy-tomato-and-spinach-pasta",
  "name": "Creamy Tomato and Spinach Pasta",
  "recipe_type": "main",
  "brief_description": "A comforting pasta dish with linguine, cherry tomatoes, fresh spinach, and a creamy sauce made with all-Purpose Cream, ricotta, and Parmesan, with just a hint of chili flakes.",
  "cuisine": "American Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the olive oil in a large pan over medium heat. Add the garlic, onion, and red chili flakes. Saute until fragrant."
    },
    {
      "position": 2,
      "text": "Add the cherry tomatoes. Cook until they soften and release their juices."
    },
    {
      "position": 3,
      "text": "Pour in the vegetable broth and bring to a boil. Add the linguine. Cover and cook, stirring occasionally, until the pasta is al dente."
    },
    {
      "position": 4,
      "text": "Stir in the spinach and cook until wilted."
    },
    {
      "position": 5,
      "text": "Lower the heat. Add the Nestle All Purpose Cream, ricotta cheese, and Parmesan cheese. Toss until the pasta is evenly coated and the sauce is creamy."
    },
    {
      "position": 6,
      "text": "Taste and season with salt and ground black pepper. Serve warm."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
