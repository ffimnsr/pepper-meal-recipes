  "id": "333ccf5e-d349-51cc-acf0-052959f84000",
  "slug": "chocolate-chip-cookie-recipe",
  "name": "Chocolate Chip Cookie Recipe",
  "recipe_type": "dessert",
  "brief_description": "This delicious Chocolate Chip Cookie Recipe has the right amount of flavor coupled by a perfect texture that will keep you coming back for more.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "In a mixing bowl, combine all-purpose flour, salt, and baking soda. Mix well and set aside."
    },
    {
      "position": 3,
      "text": "On a separate mixing bowl, put in butter and beat. Gradually add both sugars while beating."
    },
    {
      "position": 4,
      "text": "Add-in the vanilla extract and eggs (one piece at a time) while beating."
    },
    {
      "position": 5,
      "text": "Gradually add the flour, salt, and baking soda mixture and beat until all the ingredients are well mixed."
    },
    {
      "position": 6,
      "text": "Put-in the chocolate chips and chopped nuts. Fold until the chips and nuts are well incorporated."
    },
    {
      "position": 7,
      "text": "Arrange parchment paper in a baking sheet. Scoop and drop the mixture on the parchment paper. Note: try to press the mixture a little bit to make the cookie flat. This will also give you room if you want to place extra chocolate chips on top of the cookie."
    },
    {
      "position": 8,
      "text": "Place inside the oven and bake for 7 to 9 minutes."
    },
    {
      "position": 9,
      "text": "Remove from the oven and place in cooling racks."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 12,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 10,
