  "id": "92c3296e-1b22-5309-a68e-52a4669c2ceb",
  "slug": "tokneneng-filipino-street-food-recipe",
  "name": "Tokneneng Recipe",
  "recipe_type": "snack",
  "brief_description": "Boiled chicken eggs coated in a seasoned orange batter and deep-fried until golden brown. Best served with spiced vinegar or a special dipping sauce for a true Filipino street food experience.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place cornstarch in a bowl and roll the boiled eggs in it until lightly coated. Set aside."
    },
    {
      "position": 2,
      "text": "In another bowl, combine all-purpose flour, salt, and ground black pepper. Mix well."
    },
    {
      "position": 3,
      "text": "Soak annatto seeds in water until the liquid turns orange. Strain the seeds and pour the colored water into the flour mixture. Stir until smooth."
    },
    {
      "position": 4,
      "text": "Add the cornstarch-coated eggs to the batter and ensure they are fully covered."
    },
    {
      "position": 5,
      "text": "Heat cooking oil in a deep pan over medium heat."
    },
    {
      "position": 6,
      "text": "Once the oil is hot, deep-fry the eggs until golden and crispy."
    },
    {
      "position": 7,
      "text": "Remove from the pan and drain on paper towels."
    },
    {
      "position": 8,
      "text": "Serve hot with spiced vinegar or your preferred dipping sauce."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 3,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
