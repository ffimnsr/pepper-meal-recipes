  "id": "95215170-c874-51f5-b9f0-9a55207413e1",
  "slug": "meaty-spaghetti",
  "name": "Meaty Spaghetti Recipe",
  "recipe_type": "main",
  "brief_description": "Filipino style spaghetti with meaty sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make the sauce by heating oil in a cooking pot. Saute onion and garlic until onion softens."
    },
    {
      "position": 2,
      "text": "Add ground pork. Cook until light brown."
    },
    {
      "position": 3,
      "text": "Pour tomato sauce into the pot and then add water. Stir. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr pork cube. Stir and cover the pot. Cook for 30 minutes between low to medium heat."
    },
    {
      "position": 5,
      "text": "Add liver spread. Stir and let it blend with the sauce."
    },
    {
      "position": 6,
      "text": "Put-in hotdogs. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Season with sugar, ground black pepper, and salt."
    },
    {
      "position": 8,
      "text": "Prepare the spaghetti by following the package instructions."
    },
    {
      "position": 9,
      "text": "Arrange the cooked spaghetti in a serving plate. Top with meaty spaghetti sauce and shredded cheese."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
