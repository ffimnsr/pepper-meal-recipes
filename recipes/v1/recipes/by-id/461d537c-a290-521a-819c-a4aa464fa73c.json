  "id": "461d537c-a290-521a-819c-a4aa464fa73c",
  "slug": "buko-ice-candy",
  "name": "Buko Ice Candy",
  "recipe_type": "dessert",
  "brief_description": "Buko Ice Candy is a Filipino Ice Pop made from milk and young coconut. The young coconut is locally known in the Philippines as Buko.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine coconut water, fresh milk, condensed milk, and vanilla extract in a large mixing bowl or pitcher. Stir until all the ingredients are well incorporated."
    },
    {
      "position": 2,
      "text": "Add the shredded young coconut. You can also use a food processor to make the shredded coconut finer before adding it in the mixture.Give it a quick stir."
    },
    {
      "position": 3,
      "text": "Pour part of the mixture into ice candy bags using a funnel. Let the air out and secure the bag by tying a knot on the open end."
    },
    {
      "position": 4,
      "text": "Arrange in the freezer and let it stay overnight."
    },
    {
      "position": 5,
      "text": "Serve for dessert or snack. Share and enjoy!"
    }
  ],
  "servings": 10,
  "cooking_time_minutes": 1,
