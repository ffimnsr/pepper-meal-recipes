  "id": "bfb9b3a2-929b-5897-801f-72dbf0c86f9c",
  "slug": "salmon-sisig",
  "name": "Salmon Sisig",
  "recipe_type": "appetizer",
  "brief_description": "Filipino sisig version using salmon fillet flakes.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place salmon in a turbo broiler. Spray cooking oil all over the fish. Broil for 12 minutes at 390F."
    },
    {
      "position": 2,
      "text": "Let it cool down. Remove from the broiler and flake the fish. Set aside."
    },
    {
      "position": 3,
      "text": "Melt 1/3 of the butter in a pan. Add cooking oil. Continue cooking until the mixture gets hot. Add salmon flakes and cook for 30 seconds while constantly stirring."
    },
    {
      "position": 4,
      "text": "Add half of the amount of each of these ingredients: onion, chili pepper, green onion. Cook while stirring for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add garlic powder and Knorr Liquid Seasoning. Cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Add Lady's Choice Mayonnaise. Stir and cook for 30 seconds."
    },
    {
      "position": 7,
      "text": "Put chicharon into the pan. Stir. Transfer to a large bowl. Let it cool down."
    },
    {
      "position": 8,
      "text": "Add remaining onion and green onion. Toss. Season with ground black pepper."
    },
    {
      "position": 9,
      "text": "Heat a metal plate on a stovetop. Add remaining butter and let it melt. Arrage the prepared salmon sisig on the metal plate. Top with chicharon and add remaining chili pepper. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
