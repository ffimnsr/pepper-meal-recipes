  "slug": "ginataang-langka-with-dilis",
  "name": "Ginataang Langka with Dilis Recipe",
  "recipe_type": null,
  "brief_description": "Ginataang Langka with Dilis is best eaten with warm white rice. This dish is so flavorful and delicious. Give this recipe a try today!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan and then and pour-in the cooking oil."
    },
    {
      "position": 2,
      "text": "Pan-fry the dried anchovies for 2 minutes."
    },
    {
      "position": 3,
      "text": "Pour-in the coconut milk. Bring to a boil."
    },
    {
      "position": 4,
      "text": "Add the garlic and onions. Continue cooking for 4 minutes."
    },
    {
      "position": 5,
      "text": "Add-in the jack fruit and chilli. Simmer for 20 minutes while occasionally stirring."
    },
    {
      "position": 6,
      "text": "Put-in the fish sauce. Stir and continue simmering until dry."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
