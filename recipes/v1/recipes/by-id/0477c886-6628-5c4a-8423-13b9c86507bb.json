  "slug": "chili-garlic-butter-shrimp-recipe",
  "name": "Chili Garlic Butter Shrimp Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Chili Garlic Butter Shrimp.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place the shrimp in a plate. Rub salt and ground black pepper all over. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Melt butter in a pan. Add the cooking oil. Once the mixture gets hot, add the garlic and then cook in medium heat until light brown."
    },
    {
      "position": 3,
      "text": "Put the chili into the pan. Stir and continue to cook for 30 seconds."
    },
    {
      "position": 4,
      "text": "Add the shrimp. Stir-fry until it turns medium orange."
    },
    {
      "position": 5,
      "text": "Stir-in the chopped scallions and continue to stir-fry for 1 minute."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
