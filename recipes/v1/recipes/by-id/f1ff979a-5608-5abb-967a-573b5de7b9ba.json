  "id": "f1ff979a-5608-5abb-967a-573b5de7b9ba",
  "slug": "crispy-lechon-belly-recipe",
  "name": "Crispy Lechon Belly Recipe",
  "recipe_type": null,
  "brief_description": "Try this Crispy Lechon Belly Recipe recipe. Let me know what you think.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine rub ingredients in a bowl. Mix well.Rub all over the pork belly."
    },
    {
      "position": 2,
      "text": "Arrange scallions and pounded lemongrass in the middle of the slab. Roll. Use a kitchen twine to secure the rolled pork belly. Set aside."
    },
    {
      "position": 3,
      "text": "Preheat oven to 400F"
    },
    {
      "position": 4,
      "text": "Add star anise and wedged onion into the roaster. Pour 1 pint water."
    },
    {
      "position": 5,
      "text": "Arrange rolled pork belly over the roasting pan. Securely wrap the roasting pan with an aluminum foil."
    },
    {
      "position": 6,
      "text": "Bake for 2 hours."
    },
    {
      "position": 7,
      "text": "Remove the foil. Increase the heat to 475F. Roast for 1 1/2 hours."
    },
    {
      "position": 8,
      "text": "Remove from the oven. Let the meat cool down."
    },
    {
      "position": 9,
      "text": "Slice into serving pieces. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 210,
  "preparation_time_minutes": 15,
