  "id": "7f8199e8-f3fc-58b2-9a86-f23e4afd7422",
  "slug": "adobong-dilaw-recipe",
  "name": "Adobong Dilaw Recipe (Yellow Adobo)",
  "recipe_type": null,
  "brief_description": "Adobong Dilaw is a pork adobo version that does not use soy sauce. Instead, it uses turmeric which is a type of rhizome that belongs to the ginger family. It is known as \u201cluyang dilaw\u201d in Filipino.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Put-in the garlic and then cook until the color turns light brown."
    },
    {
      "position": 3,
      "text": "Add the onion. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Put-in the sliced turmeric, peppercorn, and bay leaves. Cook for 10 to 15 seconds."
    },
    {
      "position": 5,
      "text": "Add the pork slices. Cook while stirring once in a while until the pork turns light brown (about 5 minutes)."
    },
    {
      "position": 6,
      "text": "Put-in the pork or beef cube (or powder) and the pour-in the water. Let boil."
    },
    {
      "position": 7,
      "text": "Cover the pot and then simmer for 30 to 45 minutes (add additional water as necessary)."
    },
    {
      "position": 8,
      "text": "Pour-in the vinegar. Allow the liquid to re-boil."
    },
    {
      "position": 9,
      "text": "Stir and then add the sugar. Cook for a minute more."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
