  "id": "36b6d0c0-d6f4-5e1b-9f86-162c86ecdb92",
  "slug": "tuna-casserole",
  "name": "Tuna Casserole Recipe",
  "recipe_type": null,
  "brief_description": "This Tuna Casserole Recipe is perfect for ordinary days and special occasions. Experience the delightful taste that will surely capture your taste buds.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 400 degrees Fahrenheit"
    },
    {
      "position": 2,
      "text": "Combine noodles, tuna, green peas, onion, and mushrooms in a large mixing bowl. Mix well"
    },
    {
      "position": 3,
      "text": "Sprinkle salt, pour-in condensed cream of mushroom soup, and add 1 cup cheese."
    },
    {
      "position": 4,
      "text": "Toss until all the ingredients are properly distributed."
    },
    {
      "position": 5,
      "text": "Transfer the mixture to a baking dish and top with crushed french fried onions and remaining cheese."
    },
    {
      "position": 6,
      "text": "Bake for 18 to 22 minutes."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
