  "id": "8c9e688e-1fc5-5d62-ae8b-7d5c688da7dd",
  "slug": "egg-drop-soup",
  "name": "Egg Drop Soup",
  "recipe_type": "soup",
  "brief_description": "It is the time of the year when hot soups goes in high demand. It is fall this time here in Chicago and the weather is getting colder as time passes by. Having warm or hot soup can make you feel warm and comfy \u2013 this is where this egg drop soup comes into picture. I also created this blog post as a reply to a request that I got from Alex regarding an easy to make soup dish that can be made within 20 minutes.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Dilute the cornstarch in 1/4 cup water. Stir and mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Combine chicken broth and water in a cooking pot, Bring to a boil."
    },
    {
      "position": 3,
      "text": "Add the grated ginger. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in the beaten egg. Stir."
    },
    {
      "position": 5,
      "text": "Add-in the cornstarch diluted in water. Continue to stir until the texture of the soup reaches your desired texture."
    },
    {
      "position": 6,
      "text": "Add salt to taste."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Sprinkle green onions on top."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
