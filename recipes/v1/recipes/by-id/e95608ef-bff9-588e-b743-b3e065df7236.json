  "id": "e95608ef-bff9-588e-b743-b3e065df7236",
  "slug": "fried-chicken-potato-salad",
  "name": "Fried Chicken Potato Salad",
  "recipe_type": "salad",
  "brief_description": "You will find this Fried Chicken Potato Salad recipe interesting. I made this dish using leftover fried chicken in my fridge",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Flatten the chicken breasts using a meat tenderizer tool by gently pounding on the meat until it is about 1/4 inch thick. Season both sides with salt and pepper."
    },
    {
      "position": 2,
      "text": "Heat a frying pan and pour-in the cooking oil."
    },
    {
      "position": 3,
      "text": "Meanwhile, dip the chicken in beaten egg and dredge in flour."
    },
    {
      "position": 4,
      "text": "Once the oil is becomes hot, pan fry each side of the chicken in medium heat for 8 to 10 minutes."
    },
    {
      "position": 5,
      "text": "Remove the chicken in the pan. Place in a plate to cool down. Chop into bite size pieces. Set aside."
    },
    {
      "position": 6,
      "text": "In a large mixing bowl, combine mayonnaise, sweet pickle relish, salt, pepper, and garlic powder. Mix well."
    },
    {
      "position": 7,
      "text": "Add-in the potatoes and green peas. Toss."
    },
    {
      "position": 8,
      "text": "Add the chicken and scallions. Toss once again."
    },
    {
      "position": 9,
      "text": "Cover and refrigerate for 3 hours."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 12,
