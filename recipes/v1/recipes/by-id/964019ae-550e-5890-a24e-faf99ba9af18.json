  "id": "964019ae-550e-5890-a24e-faf99ba9af18",
  "slug": "kangkong-with-squid-balls-in-oyster-sauce",
  "name": "Kangkong with Squid Balls in Oyster Sauce",
  "recipe_type": null,
  "brief_description": "This is a recipe for Kangkong with Squid Balls in Oyster Sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute onion and garlic until the onion softens."
    },
    {
      "position": 3,
      "text": "Add squid balls. Stir-fry for 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour oyster sauce. Stir."
    },
    {
      "position": 5,
      "text": "Combine chicken broth and cornstarch. Stir until blended. Pour into the pan. Stir. Continue to cook in medium heat until the sauce thickens."
    },
    {
      "position": 6,
      "text": "Add kangkong leaves. Cook for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 8,
      "text": "Tranfer to serving plate. Serve!"
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
