  "id": "57b9dab6-d254-5819-a541-88346c83b45d",
  "slug": "bulalo-kare-kare",
  "name": "Bulalo Kare-Kare",
  "recipe_type": "main",
  "brief_description": "Beef shank cooked in peanut sauce with eggplant, bok choy, and snake beans. This dish is best served with sauteed shrimp paste.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saute onion and garlic until onion softens."
    },
    {
      "position": 2,
      "text": "Add beef shank. Cook each side for 30 seconds."
    },
    {
      "position": 3,
      "text": "Pour water into the pot. Let boil. Continue boiling for 10 minutes. Skim the scums on the surface. Continue boiling in low heat until meat gets tender."
    },
    {
      "position": 4,
      "text": "Prepare the annatto water by boiling 1 cup water in a saucepan. Add annatto seeds. Boil for 1 minute. Set aside."
    },
    {
      "position": 5,
      "text": "Prepare the peanut paste by placing the roasted peanuts in a food processor. Puree until the texture becomes smooth and paste-like."
    },
    {
      "position": 6,
      "text": "Once the beef shank tenderizes, add peanut paste and annatto water (filter the seeds using a kitchen strainer). Cover and cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add Knorr Beef Cube. Stir. Cover and cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Pour cornstarch mixture. Stir until sauce thickens. Season with ground black pepper."
    },
    {
      "position": 9,
      "text": "Add eggplant and sitaw. Cover and cook for 5 minutes."
    },
    {
      "position": 10,
      "text": "Add bok choy. Cover and cook for 3 minutes. Transfer to a serving plate. Serve with bagoong alamang. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 180,
  "preparation_time_minutes": 10,
