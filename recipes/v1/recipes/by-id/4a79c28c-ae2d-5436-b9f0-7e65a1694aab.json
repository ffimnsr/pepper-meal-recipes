  "id": "4a79c28c-ae2d-5436-b9f0-7e65a1694aab",
  "slug": "corn-chowder-recipe",
  "name": "Corn Chowder",
  "recipe_type": "soup",
  "brief_description": "Corn Chowder is a type of thick soup or vegetable stew. This is made from cream style corn along with some bacon or prosciutto.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a small cooking pot."
    },
    {
      "position": 2,
      "text": "Add the prosciutto or bacon. Cook until crisp."
    },
    {
      "position": 3,
      "text": "Add the onions. Cook until soft."
    },
    {
      "position": 4,
      "text": "Add the potato. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour in the water and cream-style corn. Bring to a boil, then simmer for 15 to 18 minutes."
    },
    {
      "position": 6,
      "text": "Add the half and half, salt, and pepper. Stir and cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Top with cheese."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
