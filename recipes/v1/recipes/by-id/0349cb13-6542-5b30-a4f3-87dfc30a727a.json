  "slug": "grilled-grouper-steak-in-foil-packet-inihaw-na-lapu",
  "name": "Grilled Grouper Steak in Foil Packet",
  "recipe_type": "main",
  "brief_description": "Filipino-style grilled grouper steak cooked in foil packets with lemon-garlic butter and topped with crispy toasted garlic.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine butter, salt, garlic, and lemon juice in a bowl. Stir until well blended."
    },
    {
      "position": 2,
      "text": "Arrange the grouper steaks in a piece of aluminum foil large enough to hold each piece. Top with the lemon garlic butter mixture. Seal the foil."
    },
    {
      "position": 3,
      "text": "Heat-up the grill. Start to grill the fish in foil packets for 15 to 20 minutes."
    },
    {
      "position": 4,
      "text": "Remove from the grill. Open the foil packet to make the fish steak visible."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Top with more toasted garlic."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
