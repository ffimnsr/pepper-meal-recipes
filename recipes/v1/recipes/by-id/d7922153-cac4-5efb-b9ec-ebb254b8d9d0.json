  "id": "d7922153-cac4-5efb-b9ec-ebb254b8d9d0",
  "slug": "chicken-feet-in-oyster-sauce-with-salted-black-beans",
  "name": "Chicken Feet in Oyster Sauce with Salted Black Beans",
  "recipe_type": "appetizer",
  "brief_description": "Tender dimsum chicken feet with oyster sauce and tausi",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Fry chicken feet for 3 minutes per side. Remove and set aside."
    },
    {
      "position": 2,
      "text": "Heat 3 tablespoons oil in a pressure cooker. Saute garlic and onion until onion softens."
    },
    {
      "position": 3,
      "text": "Add chicken feet. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add oyster sauce and water. Pressure cook for 18 minutes."
    },
    {
      "position": 5,
      "text": "Pour mirin (or brown sugar) and add salted black beans. Continue cooking until the sauce reduces to half."
    },
    {
      "position": 6,
      "text": "Add some chili garlic oil. Stir."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
