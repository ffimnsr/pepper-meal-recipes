  "id": "262ea32f-74c5-5146-8416-1ef4e4344bae",
  "slug": "shrimp-avocado-salad-recipe",
  "name": "Shrimp Avocado Salad Recipe",
  "recipe_type": "salad",
  "brief_description": "Shrimp avocado salad that makes use of fresh or pre-cooked chrimp along with cubed avocado, sour cream, lime, and garlic powder",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add the shrimp and cook for 1 to 2 minutes or until color turns medium orange. Remove the shrimp from the pot and discard the water. Set aside."
    },
    {
      "position": 2,
      "text": "Combine sour cream, lime juice, garlic powder, and salt in a large bowl. Mix well."
    },
    {
      "position": 3,
      "text": "Add the avocado. Fold until all ingredients are well blended."
    },
    {
      "position": 4,
      "text": "Fold-in the boiled shrimp."
    },
    {
      "position": 5,
      "text": "Transfer to a serving bowl. Top with chives."
    },
    {
      "position": 6,
      "text": "Serve chilled. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 2,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
