  "id": "c820e2b3-75e5-5b2e-898c-bb2cda92c7c9",
  "slug": "filipino-food-congee-goto-recipe",
  "name": "Goto Recipe (Rice Porridge)",
  "recipe_type": "breakfast",
  "brief_description": "This Goto Recipe is the Filipino version of Congee. Learn how to make this dish by following our cooking video.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a pot, heat the cooking oil then saut\u00e9 the garlic, onion, and ginger"
    },
    {
      "position": 2,
      "text": "Dash-in some ground black pepper"
    },
    {
      "position": 3,
      "text": "Add the ox tripe and cook for 2 minutes"
    },
    {
      "position": 4,
      "text": "Pour-in the fish sauce and water then simmer until the ox tripe is tender (you may use a pressure cooker for faster results)"
    },
    {
      "position": 5,
      "text": "Add the uncooked rice and stir"
    },
    {
      "position": 6,
      "text": "Pour-in the beef broth and bring to a boil."
    },
    {
      "position": 7,
      "text": "Stir occasionally until the rice reaches the desired consistency (about 40 minutes). Add water as needed"
    },
    {
      "position": 8,
      "text": "Put-in the hard boiled eggs then stir."
    },
    {
      "position": 9,
      "text": "Add the safflower for additional color and aroma."
    },
    {
      "position": 10,
      "text": "Serve hot with minced green onions, crushed chicharon, and lemon. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
