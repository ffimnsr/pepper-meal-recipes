  "id": "70432cc4-9373-51c6-b92b-33f92dc58c52",
  "slug": "breaded-shrimp-with-sweet-and-sour-sauce",
  "name": "Breaded Shrimp with Sweet and Sour Sauce",
  "recipe_type": "dessert",
  "brief_description": "Breaded Shrimp is a quick and easy deep fried shrimp recipe suitable for lunch or dinner. Although this dish is already good, the sauce will make it better",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt and pepper on the shrimp. Let it stand for 15 minutes."
    },
    {
      "position": 2,
      "text": "Heat the oil in a deep pan."
    },
    {
      "position": 3,
      "text": "Dredge the shrimp in flour and then dip in the beaten eggs. Quickly roll the shrimp over the breadcrumbs. Make sure that the shrimp are properly coated."
    },
    {
      "position": 4,
      "text": "Deep fry for 3 to 4 minutes or until the color turns golden brown."
    },
    {
      "position": 5,
      "text": "Arrange in a plate lined with paper towels. This will absorb the oil."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with Sweet and Sour Sauce."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 15,
