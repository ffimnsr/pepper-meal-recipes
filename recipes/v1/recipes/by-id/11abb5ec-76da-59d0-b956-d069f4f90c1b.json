  "id": "11abb5ec-76da-59d0-b956-d069f4f90c1b",
  "slug": "ube-kalamay-recipe",
  "name": "Ube Kalamay Recipe",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for ube kalamay.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine water, glutinous rice flour, and 2 cups of coconut milk in a bowl. Mix well using a wire whisk. Set aside."
    },
    {
      "position": 2,
      "text": "Heat a cooking pot. Pour 2 cups of coconut milk. Let boil."
    },
    {
      "position": 3,
      "text": "Add shredded purple yam. Stir and cook in medium heat for 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour the glutinous rice flour mixture into the cooking pot. Stir until all the ingredients are well blended."
    },
    {
      "position": 5,
      "text": "Gradually add the sugar while stirring. Continue to cook until the mixture becomes very thick."
    },
    {
      "position": 6,
      "text": "Brush coconut oil in a mold (I used a quiche mold for this recipe). Put the cooked ube kalamay in the mold. Spread it around the mold. Brush remaining coconut oil over the ube kalamay. Flatten top using a spoon. Top with latik."
    },
    {
      "position": 7,
      "text": "Let the kalamay cool down for 1 hour. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
