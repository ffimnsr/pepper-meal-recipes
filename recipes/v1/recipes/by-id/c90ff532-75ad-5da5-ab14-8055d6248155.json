  "id": "c90ff532-75ad-5da5-ab14-8055d6248155",
  "slug": "higadillo",
  "name": "Higadillo Recipe (Pork and Liver Stew)",
  "recipe_type": null,
  "brief_description": "Higadillo is a Filipino stew. This dish makes use of pork and pig's or cow's liver which are cooked in a mixture composed of vinegar and lechon sauce",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the garlic, ginger, and onion until the onion becomes soft."
    },
    {
      "position": 3,
      "text": "Add the pork strips. Cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the liver. Cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the soy sauce, lechon sauce, and water. Stir and let boil. Cover and simmer for 30 minutes. Note: add water as necessary."
    },
    {
      "position": 6,
      "text": "Pour-in the vinegar. Allow to reboil."
    },
    {
      "position": 7,
      "text": "Add the sugar, salt, and pepper. Stir and cook for 3 to 5 minutes uncovered."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
