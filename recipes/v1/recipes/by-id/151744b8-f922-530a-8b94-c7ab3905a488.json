  "id": "151744b8-f922-530a-8b94-c7ab3905a488",
  "slug": "steamed-okra-and-bagoong",
  "name": "Steamed Okra and Bagoong",
  "recipe_type": "appetizer",
  "brief_description": "Steamed Okra and Bagoong is a very simple Filipino appetizer consisting of okra and shrimp paste. This can also be considered as a main dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water in a steamer. Bring to a boil."
    },
    {
      "position": 2,
      "text": "When the water starts boiling, arrange the okra in a steaming basket. Steam for 8 to 10 minutes."
    },
    {
      "position": 3,
      "text": "Remove the okra from the steaming basket and then blanch by putting in the bowl with ice water. This will stop the cooking process and will retain the color and crisp texture of the vegetable."
    },
    {
      "position": 4,
      "text": "Remove from the ice water after 2 minutes. Le the water drip-off and then arrange in a serving plate."
    },
    {
      "position": 5,
      "text": "Serve with bagoong. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 2,
