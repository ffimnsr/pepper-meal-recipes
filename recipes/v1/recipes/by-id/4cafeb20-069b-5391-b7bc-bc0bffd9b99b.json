  "id": "4cafeb20-069b-5391-b7bc-bc0bffd9b99b",
  "slug": "sarciadong-isda-easy-fish-recipe",
  "name": "Sarciadong Isda Recipe",
  "recipe_type": "main",
  "brief_description": "Sarciadong Isda is a Filipino dish featuring fried fish simmered in sauce with garlic, onions, and eggs.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a frying pan then fry the fish. Ensure that salt has been rubbed over the fish before frying."
    },
    {
      "position": 2,
      "text": "Remove the fish from the frying pan and place in a a plate with paper towels. Set aside."
    },
    {
      "position": 3,
      "text": "Using a clean pan, heat about 2 teaspoons of cooking oil then saut\u00e9 the garlic, onions, and tomatoes"
    },
    {
      "position": 4,
      "text": "Add the fish sauce and ground black pepper then stir."
    },
    {
      "position": 5,
      "text": "Put-in the chopped green onions and water then bring to a boil."
    },
    {
      "position": 6,
      "text": "Add the fried fish and simmer for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Pour the beaten eggs on the pan. Ensure that it is distributed evenly."
    },
    {
      "position": 8,
      "text": "Once the eggs curdles or coagulates, you may start stirring the mixture."
    },
    {
      "position": 9,
      "text": "Simmer for another 2 minutes than transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
