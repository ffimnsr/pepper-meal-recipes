  "id": "e728d8e4-d0b9-59ac-ae96-ef34361e179b",
  "slug": "fudge-brownies-recipe",
  "name": "Fudge Brownies",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Fudge Brownies",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the flour, cocoa powder, sugar, and salt. Mix well and then set aside."
    },
    {
      "position": 2,
      "text": "Using a different bowl, combine the eggs, vegetable oil, and vanilla extract. Whisk until all the ingredients are incorporated."
    },
    {
      "position": 3,
      "text": "Fold-in the dry ingredients and mix until everything is well distributed."
    },
    {
      "position": 4,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 5,
      "text": "Arrange the mixture in a baking pan."
    },
    {
      "position": 6,
      "text": "Bake for 20 minutes, or until it passes the toothpick test"
    },
    {
      "position": 7,
      "text": "Melt the chocolate chips in a saucepan and then pour-in the condensed milk and vanilla extract. Mix well."
    },
    {
      "position": 8,
      "text": "Remove the brownies from the oven and then spread the chocolate mixture over. Sprinkle the top with chopped walnuts. Let cool in room temperature and then refrigerate for a couple of hours."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
