  "id": "c37185d3-b2e9-52b4-aed7-35b83efd9878",
  "slug": "baked-pork-tenderloin-with-peaches",
  "name": "Baked Pork Tenderloin with Peaches",
  "recipe_type": null,
  "brief_description": "Baked Pork Tenderloin with Peaches might be what you are looking for. If you have spent some time searching for the most tender and juicy pork dish",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 520 degrees Fahrenheit"
    },
    {
      "position": 2,
      "text": "Combine salt, pepper, thyme, and oregano. Mix well."
    },
    {
      "position": 3,
      "text": "Rub the mixture on the pork tenderloin."
    },
    {
      "position": 4,
      "text": "Heat olive oil in a pan and then pan-fry the pork tenderloin for about 5 minutes or until all the sides are brown."
    },
    {
      "position": 5,
      "text": "Arrange the pan-fried pork tenderloin in an oven rack. Bake for 18 minutes. Note: Let the tenderloin cook using the oven\u2019s residual heat. Do not open the oven door until after 1 hour of turning the oven off."
    },
    {
      "position": 6,
      "text": "Meanwhile, make the delicious peaches by placing the white wine in a sauce pan. Let it boil."
    },
    {
      "position": 7,
      "text": "Add-in the peaches. Cook for 1 minute."
    },
    {
      "position": 8,
      "text": "Put-in the cinnamon powder, nutmeg, and brown sugar. Stir and then cook some more until the liquid evaporates."
    },
    {
      "position": 9,
      "text": "After one hour of having the tenderloin in the oven. Arrange the sliced pork and peaches in a serving plate."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
