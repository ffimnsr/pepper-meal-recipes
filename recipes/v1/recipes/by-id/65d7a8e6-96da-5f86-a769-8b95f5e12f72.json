  "id": "65d7a8e6-96da-5f86-a769-8b95f5e12f72",
  "slug": "chicken-meatball-noodle-soup",
  "name": "Chicken Meatball Noodle Soup",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Chicken Meatball Noodle Soup.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the meatball ingredients in a bowl. Mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Heat olive oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Once the oil becomes hot, saute carrot, celery, and onion for 5 minutes."
    },
    {
      "position": 4,
      "text": "Add garlic. Continue to saute for 3 minutes or until the vegetables are soft."
    },
    {
      "position": 5,
      "text": "Pour water. Let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Chicken Cube. Stir."
    },
    {
      "position": 7,
      "text": "Add bay leaves. Cover the cooking pot and continue to cook in medium heat for 5 minutes."
    },
    {
      "position": 8,
      "text": "Scoop around 2 tablespoons of chicken mixture and then roll into a ball. Gently drop the chicken meatballs in boiling broth. Stir. Cover and cook in medium heat for 6 minutes."
    },
    {
      "position": 9,
      "text": "Add egg noodles. Cover and cook between low to medium heat for 15 minutes."
    },
    {
      "position": 10,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
