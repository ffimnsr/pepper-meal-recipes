  "slug": "t-bone-steak-sauteed-with-onions",
  "name": "T-Bone Steak Sauteed with Onions",
  "recipe_type": null,
  "brief_description": "T-Bone Steak Sauteed with Onions Recipe",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Slice the steak into thick strips."
    },
    {
      "position": 2,
      "text": "Heat a pan and then pour-in olive oil."
    },
    {
      "position": 3,
      "text": "When the oil becomes hot, put-in the onion and then saut\u00e9 for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add the sliced steak. Pour-in the Worcestershire sauce. Sprinkle salt and pepper. Stir and then cook for 3 minutes in medium heat."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Top with French fried onions."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
