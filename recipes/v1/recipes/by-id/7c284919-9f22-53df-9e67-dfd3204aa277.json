  "slug": "baby-corn-ham-and-jicama-stir-fry",
  "name": "Baby Corn Ham and Jicama Stir Fry",
  "recipe_type": null,
  "brief_description": "This Baby Corn, Ham, and Jicama stir fry recipe is a quick and easy. The flavor and texture of this dish is really awesome.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a wok."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and onion"
    },
    {
      "position": 3,
      "text": "Add the ham. Stir fry for 3 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the Jicama, young corn, and mixed vegetables. Stir-fry for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the cooking wine. Continue to cook for a minute."
    },
    {
      "position": 6,
      "text": "Add the chicken broth. Let boil and cook for another minute."
    },
    {
      "position": 7,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
