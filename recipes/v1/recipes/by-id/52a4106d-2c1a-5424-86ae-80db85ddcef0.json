  "id": "52a4106d-2c1a-5424-86ae-80db85ddcef0",
  "slug": "ginisang-labanos-recipe",
  "name": "Ginisang Labanos Recipe",
  "recipe_type": "main",
  "brief_description": "Sauteed daikon with carrots and pork.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onion"
    },
    {
      "position": 3,
      "text": "Once the onion becomes soft, put-in the tomato. Cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add the pork. Cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in water and let boil. Cover and simmer for 10 minutes."
    },
    {
      "position": 6,
      "text": "Add-in the daikon and carrot. Stir. Cover and cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the shrimp, fish sauce, and ground black pepper. Stir and cook for 10 minutes more."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve with hot rice. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
