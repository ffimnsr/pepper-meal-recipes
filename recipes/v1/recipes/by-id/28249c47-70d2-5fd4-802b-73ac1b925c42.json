  "id": "28249c47-70d2-5fd4-802b-73ac1b925c42",
  "slug": "shared-recipe-spiral-noodles-with-vegetables",
  "name": "Spiral Noodles with Vegetables",
  "recipe_type": null,
  "brief_description": "Spiral Noodles with Vegetables Recipe is a quick and easy pasta dish that you can prepare for lunch. Try this delicious recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a wok or big cooking pot add and heat cooking oil on medium heat."
    },
    {
      "position": 2,
      "text": "Sautee garlic, onion, tomato and add fish sauce. Cover and shimmer for 2 mins."
    },
    {
      "position": 3,
      "text": "Add ground beef, salt and pepper, cover and shimmer until beef is cooked."
    },
    {
      "position": 4,
      "text": "Now add 1 cup of water and the 2 broth cubes and let it shimmer for 1-2 mins."
    },
    {
      "position": 5,
      "text": "First add and mix beans and white cabbage. Simmer about 3 mins."
    },
    {
      "position": 6,
      "text": "Add and mix broccoli, cauliflower and carrots. Simmer for another 3mins."
    },
    {
      "position": 7,
      "text": "Add and mix chinese cabbage and simmer for 2 mins."
    },
    {
      "position": 8,
      "text": "Add salt and pepper to taste if needed. Set aside."
    },
    {
      "position": 9,
      "text": "Cook your noodles as directed in the package."
    },
    {
      "position": 10,
      "text": "Add the spiral noodles to your cooked vegetables."
    },
    {
      "position": 11,
      "text": "Mix well and check if the flavor is alright. Add a broth cube or salt and pepper if needed. Enjoy!!!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
