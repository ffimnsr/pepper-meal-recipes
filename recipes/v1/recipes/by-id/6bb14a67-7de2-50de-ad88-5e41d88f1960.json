  "id": "6bb14a67-7de2-50de-ad88-5e41d88f1960",
  "slug": "pocherong-baboy-recipe",
  "name": "Pocherong Baboy Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pocherong Baboy.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot, saute onion and garlic."
    },
    {
      "position": 3,
      "text": "Add pork belly. Continue to saute until it turns light brown."
    },
    {
      "position": 4,
      "text": "Add Chorizo de Bilbao. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Put the tomato into the pot. Stir and pour-in tomato sauce. Continue to cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour beef or pork broth into the pot. Let boil. Cover and cook in low heat for 45 to 60 minutes. Note: you can add more broth or water if needed."
    },
    {
      "position": 7,
      "text": "Add banana and potato. Cover and cook for 8 minutes."
    },
    {
      "position": 8,
      "text": "Add the long green beans. Stir. Cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Put the baby bok choy into the pot. Cover. Cook for 2 minutes."
    },
    {
      "position": 10,
      "text": "Season with fish sauce and ground white pepper. Stir,"
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 75,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
