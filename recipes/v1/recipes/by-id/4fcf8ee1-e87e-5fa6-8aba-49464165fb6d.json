  "id": "4fcf8ee1-e87e-5fa6-8aba-49464165fb6d",
  "slug": "easy-chicken-curry",
  "name": "Easy Chicken Curry",
  "recipe_type": null,
  "brief_description": "Easy Chicken Curry is a very tasty and delicious dish that you can quickly prepare any time of the day. The use of curry powder makes this dish easier to make -- compared to assembling your own curry from scratch (although nothing beats making your own curry scratch by grinding and combining spices).",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine ginger powder, turmeric powder, and 1 1/2 teaspoons salt in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Rub the mixture all over the chopped chicken pieces. Let it stay for 15 minutes."
    },
    {
      "position": 3,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 4,
      "text": "Once the oil is hot, pan fry the chicken for about 2 minutes per side."
    },
    {
      "position": 5,
      "text": "Remove the chicken and temporarily place in a plate."
    },
    {
      "position": 6,
      "text": "Meanwhile, saute the onion, tomato, and garlic in the remaining cooking oil."
    },
    {
      "position": 7,
      "text": "Put the chicken back in the cooking pot when the onion becomes soft. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Pour-in the coconut milk. Bring to a boil. Add the curry powder. Cover and simmer for 25 minutes (add a little water if needed)."
    },
    {
      "position": 9,
      "text": "Add a dash of cayenne pepper. Put-in the diced potato, cook for 10 minutes. Make sure to stir once in a while."
    },
    {
      "position": 10,
      "text": "Add the green peas. Cook for 5 minutes."
    },
    {
      "position": 11,
      "text": "Add salt to taste. Stir."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Serve over white rice."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
