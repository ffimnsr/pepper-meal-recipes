  "id": "094fa4e1-95c6-525e-b238-f3e8b3c9dfe7",
  "slug": "seared-okra-and-tomato-recipe",
  "name": "Seared Okra and Tomato Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Seared Okra and Tomato",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange sliced okra in a bowl. Add vinegar. Toss until coated."
    },
    {
      "position": 2,
      "text": "Heat a pan or a skillet. Pour cooking oil."
    },
    {
      "position": 3,
      "text": "Add okra when the oil is hot. Sear one side for 30 seconds. Stir and continue to cook the opposite side for another 30 seconds."
    },
    {
      "position": 4,
      "text": "Add tomatoes. Stir and cook for 5 to 7 minutes in medium heat while stirring every minute."
    },
    {
      "position": 5,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 8,
