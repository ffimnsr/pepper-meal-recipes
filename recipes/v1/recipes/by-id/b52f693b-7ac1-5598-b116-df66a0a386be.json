  "slug": "sta-fe-dip-recipe",
  "name": "Sta. Fe Dip Recipe",
  "recipe_type": null,
  "brief_description": "Sta. Fe Dip is a rich and tasty dip that you will enjoy with any chips. It is quick and easy to prepare too. All of the ingredients are easily available",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the ingredients in a large bowl starting with the refried beans, salsa con queso (or cheese dip), guacamole,sour cream, pico de gallo (or chunky salsa), green chiles, and black olives."
    },
    {
      "position": 2,
      "text": "Place inside the fridge for 3 hours."
    },
    {
      "position": 3,
      "text": "Serve with your favorite corn chips, tortilla chips, potato chips, or even fries."
    },
    {
      "position": 4,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 5,
