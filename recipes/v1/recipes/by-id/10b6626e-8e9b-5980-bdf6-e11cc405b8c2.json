  "id": "10b6626e-8e9b-5980-bdf6-e11cc405b8c2",
  "slug": "inun-unan-recipe",
  "name": "Inun-unan Recipe (Fish cooked in Vinegar)",
  "recipe_type": "main",
  "brief_description": "Inun unan is a Filipino fish recipe that involves fish and vinegar along with some vegetables and spices. This inun-unan recipe is easy to follow",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the onion, fish, ginger, whole peppercorn, water, and vinegar in a cooking pot. Cover the pot and turn the heat on. Let the liquid boil."
    },
    {
      "position": 2,
      "text": "Once the liquid starts to boil, adjust the heat to low. Cook for 15 minutes."
    },
    {
      "position": 3,
      "text": "Add the eggplant, bitter gourd, and chili (or pepper). Cover the pot and continue to cook until the water completely evaporates."
    },
    {
      "position": 4,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
