  "id": "69901a02-a8cb-58ba-b702-c26b0e8b5a89",
  "slug": "garlic-butter-shrimp-pancit-canton",
  "name": "Garlic Butter Shrimp Pancit Canton",
  "recipe_type": "main",
  "brief_description": "Stir-fried noodles with sauteed shrimp with garlic and butter.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a wok. Add cooking oil."
    },
    {
      "position": 2,
      "text": "Put the garlic in the wok. Stir-fry until it turns light brown."
    },
    {
      "position": 3,
      "text": "Add shrimp. Cook each side for 1 minute."
    },
    {
      "position": 4,
      "text": "Squeeze the lemon over the shrimp. Cover the wok. Continue cooking for 1 minute. Season with salt."
    },
    {
      "position": 5,
      "text": "Remove the shrimp from the wok and place in a clean plate. Leave the juices in the wok."
    },
    {
      "position": 6,
      "text": "Allow the juices to evaporate until you are only left with the fats (butter and oil mixture)."
    },
    {
      "position": 7,
      "text": "Saut\u00e9 onion until it softens and then add soy sauce and water. Let it boil."
    },
    {
      "position": 8,
      "text": "Add Knorr Shrimp cube. Stir."
    },
    {
      "position": 9,
      "text": "Put the cabbage and carrot in the wok. Cook for 30 seconds."
    },
    {
      "position": 10,
      "text": "Add the noodles. Gently toss while cooking. Cook until the noodles completely absorb the liquid."
    },
    {
      "position": 11,
      "text": "Add oyster sauce and green onion. Season with ground black pepper. Toss until all ingredients are well distributed."
    },
    {
      "position": 12,
      "text": "Arrange the pancit canton in a serving plate and then top with shrimp and fried egg."
    },
    {
      "position": 13,
      "text": "Share. Serve and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
