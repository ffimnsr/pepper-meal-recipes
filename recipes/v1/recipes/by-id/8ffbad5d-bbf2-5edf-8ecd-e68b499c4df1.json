  "id": "8ffbad5d-bbf2-5edf-8ecd-e68b499c4df1",
  "slug": "filipino-pancit",
  "name": "Pancit",
  "recipe_type": "snack",
  "brief_description": "Filipino noodle dish made with a variety of noodles, vegetables, and meat",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a large wok. Saut\u00e9 garlic and onion."
    },
    {
      "position": 2,
      "text": "Add the pork. Saut\u00e9 until it turns light brown."
    },
    {
      "position": 3,
      "text": "Pour the soy sauce and then add oyster sauce and water. Let boil. Cover the wok. simmer for 20 minutes or until the pork becomes tender. Note: add water as needed."
    },
    {
      "position": 4,
      "text": "Add Maggi Magic Chicken Cube, carrots, and cabbage. Stir and cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Add the pancit bihon and canton. Let it soak completely in the sauce. Continue cooking until the noodles are soft enough to be tossed."
    },
    {
      "position": 6,
      "text": "Gently toss the noodles until all the ingredients are well distributed."
    },
    {
      "position": 7,
      "text": "Add parsley, and then season with ground black pepper and fish sauce."
    },
    {
      "position": 8,
      "text": "Cover the wok. Simmer for 3 minutes."
    },
    {
      "position": 9,
      "text": "Turn the heat off. Transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
