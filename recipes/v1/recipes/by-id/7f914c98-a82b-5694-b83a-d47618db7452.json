  "id": "7f914c98-a82b-5694-b83a-d47618db7452",
  "slug": "bicol-express-gising-gising-recipe",
  "name": "Bicol Express Gising-gising",
  "recipe_type": "main",
  "brief_description": "Spicy Pork and green beans cooked in coconut milk and seasoned with shrimp paste.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok or pan. Add pork belly. Sear until enough oil is extracted from the fat."
    },
    {
      "position": 2,
      "text": "Add onion, garlic, ginger, and chili pepper. Continue cooking until the onion softens."
    },
    {
      "position": 3,
      "text": "Add shrimp paste (bagoong alamang). Saute for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour coconut milk into the pan. Cover and let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork Cube. Stir. Cover the pan and adjust the heat to the lowest setting. Continue cooking until the pork gets tender."
    },
    {
      "position": 6,
      "text": "Add long green beans. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper."
    },
    {
      "position": 8,
      "text": "Serve! Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 5,
