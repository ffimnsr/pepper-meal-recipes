  "id": "ba166929-4a9b-5ce3-a8bc-e0e01f3131b3",
  "slug": "sinigang-na-ulo-ng-salmon",
  "name": "Sinigang na Salmon",
  "recipe_type": "soup",
  "brief_description": "Rich salmon belly simmered in a tangy tamarind broth with miso paste, served with fresh vegetables including daikon radish, okra, and mustard greens. A soul-warming Filipino classic that delivers bold, comforting flavors in every spoonful.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saut\u00e9 the garlic until it starts to brown."
    },
    {
      "position": 2,
      "text": "Add the ginger, onion, and half of the tomatoes. Saut\u00e9 until the onion and tomatoes soften."
    },
    {
      "position": 3,
      "text": "Add the miso paste. Stir."
    },
    {
      "position": 4,
      "text": "Put the salmon belly into the pot. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour in water and let it boil."
    },
    {
      "position": 6,
      "text": "Add the daikon radish and sinigang mix. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add the okra, string beans, and remaining tomatoes. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper and fish sauce."
    },
    {
      "position": 9,
      "text": "Add the mustard leaves. Turn off the heat and cover the pot for 3 minutes before serving."
    },
    {
      "position": 10,
      "text": "Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
