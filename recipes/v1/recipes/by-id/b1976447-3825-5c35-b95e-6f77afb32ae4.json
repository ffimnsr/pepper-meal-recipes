  "id": "b1976447-3825-5c35-b95e-6f77afb32ae4",
  "slug": "pork-kilawin",
  "name": "Pork Kilawin",
  "recipe_type": "appetizer",
  "brief_description": "Grilled pork belly with cucumber and tomato in spicy vinegar sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the marinade ingredients in a bowl. Mix well. Add the pork belly. Marinate for at least 3 hours."
    },
    {
      "position": 2,
      "text": "Grill the pork belly until fully cooked. Slice it into serving pieces. Set aside."
    },
    {
      "position": 3,
      "text": "Combine all the sauce ingredients in a large mixing bowl. Add the sliced pork, cucumber, tomato, onion, and chili pepper. Toss until well blended."
    },
    {
      "position": 4,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 15,
