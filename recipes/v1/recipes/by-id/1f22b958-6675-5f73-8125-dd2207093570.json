  "id": "1f22b958-6675-5f73-8125-dd2207093570",
  "slug": "ground-beef-basil-and-tomato-frittata",
  "name": "Ground Beef Basil and Tomato Frittata",
  "recipe_type": "breakfast",
  "brief_description": "Ground Beef Basil and Tomato Frittata is another easy frittata recipe that you can cook for breakfast or lunch. This recipe is awesome.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan. Put-in the beef and then cook for 3 to 5 minutes."
    },
    {
      "position": 2,
      "text": "Add the basil. Cook for 1 minute. Turn the heat off and Let the beef cool down."
    },
    {
      "position": 3,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 4,
      "text": "In a large mixing bowl, combine eggs, cooked beef and basil, tomato, salt, and pepper. Beat."
    },
    {
      "position": 5,
      "text": "Pour the mixture into an oval baking pan."
    },
    {
      "position": 6,
      "text": "Bake for 20 to 30 minutes, or until the mixture rises and becomes solid. Do not over bake."
    },
    {
      "position": 7,
      "text": "Serve with tomato ketchup."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
