  "id": "f47e5904-867a-5bd3-b8e9-64470d304ff3",
  "slug": "leche-flan",
  "name": "Leche Flan",
  "recipe_type": "dessert",
  "brief_description": "This is a simple and easy version of a famous Filipino dessert known as Leche Flan.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Using all the eggs, separate the yolk from the egg white (only egg yolks will be used)."
    },
    {
      "position": 2,
      "text": "Place the egg yolks in a big bowl then beat them using a fork or an egg beater"
    },
    {
      "position": 3,
      "text": "Add the condensed milk and mix thoroughly"
    },
    {
      "position": 4,
      "text": "Pour-in the fresh milk and Vanilla. Mix well"
    },
    {
      "position": 5,
      "text": "Put the mold (llanera) on top of the stove and heat using low fire"
    },
    {
      "position": 6,
      "text": "Put-in the granulated sugar on the mold and mix thoroughly until the solid sugar turns into liquid (caramel) having a light brown color. Note: Sometimes it is hard to find a Llanera (Traditional flan mold) depending on your location. I find it more convenient to use individual Round Pans in making leche flan."
    },
    {
      "position": 7,
      "text": "Spread the caramel (liquid sugar) evenly on the flat side of the mold"
    },
    {
      "position": 8,
      "text": "Wait for 5 minutes then pour the egg yolk and milk mixture on the mold"
    },
    {
      "position": 9,
      "text": "Cover the top of the mold using an Aluminum foil"
    },
    {
      "position": 10,
      "text": "Steam the mold with egg and milk mixture for 30 to 35 minutes."
    },
    {
      "position": 11,
      "text": "After steaming, let the temperature cool down then refrigerate"
    },
    {
      "position": 12,
      "text": "Serve for dessert. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
