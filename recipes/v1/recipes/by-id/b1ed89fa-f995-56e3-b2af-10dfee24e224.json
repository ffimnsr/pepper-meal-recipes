  "id": "b1ed89fa-f995-56e3-b2af-10dfee24e224",
  "slug": "how-to-make-macaroni-salad-for-the-holidays",
  "name": "How to Make Macaroni Salad for the Holidays",
  "recipe_type": "salad",
  "brief_description": "Rich and sweet macaroni salad with nata de coco, kaong, and cheese.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook macaroni based on package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Combine all-purpose cream, condensed milk, and Lady\u2019s Choice Mayonnaise in a large mixing bowl. Mix well."
    },
    {
      "position": 3,
      "text": "Add kaong, nata de coco, fruit cocktail, and cheese. Mix well."
    },
    {
      "position": 4,
      "text": "Put the cooked macaroni into the bowl with the other ingredients. Toss until well blended."
    },
    {
      "position": 5,
      "text": "Cover the bowl and refrigerate for at least 1 hour."
    },
    {
      "position": 6,
      "text": "Serve chilled. Share and enjoy!"
    }
  ],
  "servings": 6,
