  "id": "a99cbb87-dad3-57ac-ab38-c0205c7ebbb0",
  "slug": "inihaw-na-isaw-ng-baboy",
  "name": "Inihaw na Isaw ng Baboy",
  "recipe_type": null,
  "brief_description": "Inihaw na Isaw ng Baboy is a Filipino bizarre street food made with sliced large intestines. These are pig's large intestines",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Clean the intestines well. Make sure to wash it with running water especially the inside part. Set aside."
    },
    {
      "position": 2,
      "text": "Pour water and vinegar in a large cooking pot. Add ginger, whole peppercorn, bay leaves, and 2 tablespoons salt. Bring to a boil."
    },
    {
      "position": 3,
      "text": "Add the intestines. Boil for 1 hour. You can repeat the process to ensure that the intestines smell less pungent. However, make sure to discard the initial water used, and add a new set of ingredients for boiling."
    },
    {
      "position": 4,
      "text": "Remove the intestine from the cooking pot. Let the excess water drip. Slice crosswise into smaller pieces."
    },
    {
      "position": 5,
      "text": "Arrange the intestines in a bowl. Add 1 tablespoon salt, cumin, garlic powder, ground black pepper, and cayenne pepper powder. Mix well. Cover the bowl and refrigerate overnight."
    },
    {
      "position": 6,
      "text": "Skewer the intestine slices using a bamboo skewer."
    },
    {
      "position": 7,
      "text": "Heat-up your grill. Grill each side for 3 minutes. Repeat the process until the isaw or intestines are fully cooked. Baste continuously with a mixture of sugar, banana ketchup, soy sauce, vinegar, and oil."
    },
    {
      "position": 8,
      "text": "Serve with spicy vinegar. Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "hard",
