  "schema_version": 1,
  "id": "925c484f-1a55-5bf6-bf9c-763567fe35c4",
  "slug": "crispy-bagnet",
  "name": "Crispy Bagnet Recipe",
  "recipe_type": "main",
  "brief_description": "Crispy pork belly cooked using the oil bath method.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 175F."
    },
    {
      "position": 2,
      "text": "Pour water into a pressure cooker. Add lemongrass, salt, whole peppercorn, and onion. Let boil."
    },
    {
      "position": 3,
      "text": "Add pork belly. Boil for 3 minutes. Cover the pressure cooker. Cook for 15 minutes."
    },
    {
      "position": 4,
      "text": "Let the pressure out completely Put the pork belly on a clean plate and let it cool-down for 10 minutes. Season the meat part with salt and ground black pepper. Turn it upside down and season the skin part with salt."
    },
    {
      "position": 5,
      "text": "Wrap the sides of the pork with an aluminum foil and then rub vinegar on the skin part."
    },
    {
      "position": 6,
      "text": "Bake it for 2 \u00bd hours to dehydrate the skin."
    },
    {
      "position": 7,
      "text": "Remove the pork from the oven. Set aside."
    },
    {
      "position": 8,
      "text": "Heat oil in a wide wok. Once the oil gets hot, add garlic and laurel leaves. Cook until the garlic floats. Remove the garlic and leaves afterwards using a strainer."
    },
    {
      "position": 9,
      "text": "Arrange a slab of pork belly over a skimmer. Pour hot oil over it using a ladle. Do this step until a crackling texture is formed on the skin. Perform the same steps until all the pork are done."
    },
    {
      "position": 10,
      "text": "Arrange on a serving plate. Serve with your favorite dipping sauce. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
