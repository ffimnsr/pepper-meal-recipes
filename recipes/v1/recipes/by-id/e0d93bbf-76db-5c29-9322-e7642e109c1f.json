  "id": "e0d93bbf-76db-5c29-9322-e7642e109c1f",
  "slug": "how-to-make-banana-catsup",
  "name": "Banana Ketchup Recipe",
  "recipe_type": null,
  "brief_description": "Banana Ketchup is a condiment similar to tomato ketchup, except that this is made from bananas. Discover more about it and learn how to make it at home",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Put water in a large pot and let boil."
    },
    {
      "position": 2,
      "text": "Put in the bananas and boil for 12 minutes. Remove from the pot and let cool."
    },
    {
      "position": 3,
      "text": "When the bananas have cooled, peel them and divide each into 3 pieces by slicing."
    },
    {
      "position": 4,
      "text": "Combine bananas, onion, bell pepper, and garlic. Place in a blender with 2 cups of water and blend for seconds. Note: this can be done by batch."
    },
    {
      "position": 5,
      "text": "Place the mixture in a large mixing bowl. Add chili, all the spices, vinegar, sugar, and salt. Mix well."
    },
    {
      "position": 6,
      "text": "Place the mixture in a large pot and cook for 60 minutes or until the mixture thickens."
    },
    {
      "position": 7,
      "text": "Put-in the food coloring and sod benzoate. Stir until well blended."
    },
    {
      "position": 8,
      "text": "Let the mixture cool and transfer to jars or containers."
    }
  ],
  "servings": 12,
  "cooking_time_minutes": 80,
  "preparation_time_minutes": 12,
