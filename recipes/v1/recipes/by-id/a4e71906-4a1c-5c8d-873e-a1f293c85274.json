  "id": "a4e71906-4a1c-5c8d-873e-a1f293c85274",
  "slug": "ilocano-pork-igado-recipe",
  "name": "Igado Recipe",
  "recipe_type": "main",
  "brief_description": "Stewed pork, liver, and kidney with green peas and bell pepper. This popular Filipino recipe is a must try.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil the kidney with 4 thumbs of ginger for at least 30 minutes. Let it cool down and slice into 2-inch strips. Set aside."
    },
    {
      "position": 2,
      "text": "Heat 2 tablespoons of cooking oil in a pan. Saut\u00e9 the pork liver for 2 minutes. Remove from the pan and set aside."
    },
    {
      "position": 3,
      "text": "Pour the remaining oil in the pan. Once hot, saut\u00e9 garlic and onion until the latter softens."
    },
    {
      "position": 4,
      "text": "Add the pork kidney. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Add the pork tenderloin. Saut\u00e9 until the outer layer turns light brown."
    },
    {
      "position": 6,
      "text": "Pour the soy sauce and vinegar into the pan. Let the liquid boil. Stir."
    },
    {
      "position": 7,
      "text": "Add the laurel leaves and pour water. Let boil. Reduce the heat between low to medium setting. Continue cooking for 40 minutes."
    },
    {
      "position": 8,
      "text": "Add Knorr Pork Cube. Cook for 8 minutes."
    },
    {
      "position": 9,
      "text": "Add the liver back into the pan. Stir and continue cooking for 3 minutes."
    },
    {
      "position": 10,
      "text": "Put the bell pepper, carrot, and green peas."
    },
    {
      "position": 11,
      "text": "Season with salt and ground black pepper. Cook for 2 minutes.Transfer to a serving bowl. Serve hot with rice."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
