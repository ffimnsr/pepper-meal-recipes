  "id": "b384e23d-7be4-51ac-b787-f3c6f9b15af5",
  "slug": "turbo-crispy-liempo",
  "name": "Turbo Crispy Liempo",
  "recipe_type": "main",
  "brief_description": "Crispy Broiled Pork Belly",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange pork belly slab in a steamer. Steam for 1 hour. Remove from the steamer and let it cool down."
    },
    {
      "position": 2,
      "text": "Poke the skin using a sharp tool such as a metal skewer or a meat tenderizer with a sharp needle blade. Rub salt all over the pork. Let it stay for 10 minutes."
    },
    {
      "position": 3,
      "text": "Combine olive oil and garlic. Rub all over the pork belly. Let it stay for at least 1 hour. Note: I usually marinate the pork overnight for best results."
    },
    {
      "position": 4,
      "text": "Remove the garlic from the pork. Arrange inside a turbo broiler. Broil in 365F for 45 minutes or until crispy."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 120,
