{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "83418532-daf3-5f41-acca-0e87df92758d",
  "slug": "cheesy-pork-caldereta",
  "name": "Cheesy Pork Caldereta",
  "recipe_type": "main",
  "brief_description": "Classic Filipino pork stew with liver spread and cheese",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt on the potatoes and carrots. Toss to distribute. Air fry these at 350F for 12 minutes. Set aside."
    },
    {
      "position": 2,
      "text": "Boil 2 cups water in a cooking pot. Add the pork ribs. Continue boiling for 3 minutes. Discard the water and set the pork aside."
    },
    {
      "position": 3,
      "text": "Heat 3 tablespoons of cooking oil in a clean cooking pot. Saut\u00e9 the garlic until it starts to brown. Add the onion and continue cooking until it softens."
    },
    {
      "position": 4,
      "text": "Add the pork ribs. Saut\u00e9 it until it turns light brown."
    },
    {
      "position": 5,
      "text": "Pour the soy sauce. Continue cooking for 1 minute."
    },
    {
      "position": 6,
      "text": "Add the tomato sauce and 2 cups of water. Let it boil."
    },
    {
      "position": 7,
      "text": "Add Knorr Pork Cube. Cover the cooking pot. Adjust the heat to a simmer. Continue cooking until the pork tenderizes. Note: this usually take between 45 to 60 minutes."
    },
    {
      "position": 8,
      "text": "Stir-in the liver spread and add tomato paste."
    },
    {
      "position": 9,
      "text": "Put-in the bell peppers, carrots, potatoes, and green peas. Add Continue cooking for 2 minutes."
    },
    {
      "position": 10,
      "text": "Add the cheese and Knorr Liquid Seasoning. Cook for 2 minutes."
    },
    {
      "position": 11,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 12,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
