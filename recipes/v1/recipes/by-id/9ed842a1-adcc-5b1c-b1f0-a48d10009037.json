{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "9ed842a1-adcc-5b1c-b1f0-a48d10009037",
  "slug": "star-anise-and-cider-brined-roast-turkey",
  "name": "Star Anise and Cider Brined Roast Turkey",
  "recipe_type": null,
  "brief_description": "Turkey soaked in a brine composed of apple cider and star anise and roasted",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine 3 quarts of apple cider, star anise, anisette liquor, and salt in a large stock pot. Bring to a boil. Make sure that the whole turkey can fit in the stock pot."
    },
    {
      "position": 2,
      "text": "Stir until the salt dissolves and then turn the heat off. Let the temperature drop to room temp."
    },
    {
      "position": 3,
      "text": "Pour-in the ice water. Stir. Place the turkey in the stock pot and then brine for 12 to 22 hours. Note: Place the stock-put inside the fridge while brining."
    },
    {
      "position": 4,
      "text": "Remove the turkey from the stock pot and then wash with cold running water. Pat dry with paper towels"
    },
    {
      "position": 5,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 6,
      "text": "Place the fresh sage and thyme inside the cavity. Combine the butter and dry sage and then brush all over the turkey."
    },
    {
      "position": 7,
      "text": "Place inside the oven and then bake for 2 hours and 45 minutes or until the internal temperature reaches 160 degrees Fahrenheit."
    },
    {
      "position": 8,
      "text": "Meanwhile, reduce 2 cups of apple cider to about less than a cup. Do this by placing it in a sauce pan and simmer until the sauce reduces. Add the brown sugar and then stir. Set aside."
    },
    {
      "position": 9,
      "text": "When the roasting time reaches 2 hours and 10 minutes, remove the turkey from the oven and then brush with apple cider and brown sugar glaze. Put the turkey back in the oven and then roast for 12 minutes. Do the glazing again 2 more times after every 12 minutes."
    },
    {
      "position": 10,
      "text": "Remove the roast turkey from the oven and then let it rest for 25 minutes."
    },
    {
      "position": 11,
      "text": "Serve with cranberry sauce and turkey gravy. Share and enjoy!"
    }
  ],
  "servings": 12,
