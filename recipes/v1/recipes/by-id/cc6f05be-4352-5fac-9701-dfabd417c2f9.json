  "id": "cc6f05be-4352-5fac-9701-dfabd417c2f9",
  "slug": "squid-stir-fry-in-oyster-sauce",
  "name": "Squid Stir-Fry in Oyster Sauce",
  "recipe_type": "main",
  "brief_description": "Tender squid stir-fried in oyster sauce",
  "cuisine": "Chinese Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the squid and baking soda in a bowl. Mix well. Let it stay for 15 to 30 minutes. Rinse the squid and drain the water. Set aside."
    },
    {
      "position": 2,
      "text": "Combine the sauce ingredients in a bowl. Stir until well blended. Set aside."
    },
    {
      "position": 3,
      "text": "Heat cooking oil in a wok. Saut\u00e9 the carrot, onion, white part of the leek, garlic, ginger, and bell peppers for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the squid. Stir-fry for 1 \u00bd minutes."
    },
    {
      "position": 5,
      "text": "Pour the cooking wine. Toss."
    },
    {
      "position": 6,
      "text": "Add the sauce. Stir and cook for 30 seconds."
    },
    {
      "position": 7,
      "text": "Season with ground white pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "medium",
