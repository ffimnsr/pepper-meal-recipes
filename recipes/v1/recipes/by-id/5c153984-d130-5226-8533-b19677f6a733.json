  "slug": "ginataang-tahong-recipe",
  "name": "Ginataang Tahong",
  "recipe_type": null,
  "brief_description": "Ginataang Tahong or Mussels cooked in Coconut Milk is a common Filipino Recipe involving Marine Mussels. Mussels are abundant in coastal areas",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic, onion, and ginger"
    },
    {
      "position": 3,
      "text": "Add the fish sauce, ground black pepper, and chili. Stir."
    },
    {
      "position": 4,
      "text": "Pour-in the coconut milk. Let boil."
    },
    {
      "position": 5,
      "text": "Let the coconut milk reduce to half and then add the spinach. Cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Put-in the mussels. Stir and then cook for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Serve with steamed rice. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
