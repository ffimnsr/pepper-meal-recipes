  "id": "aced0a3d-a365-5a28-bc14-1216a7ed635e",
  "slug": "chopsuey-with-quail-eggs",
  "name": "Chopsuey with Quail Eggs",
  "recipe_type": null,
  "brief_description": "This is a quick and easy recipe for chopsuey. This version makes use of pork and shrimp bouillon along with boiled quail eggs.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saut\u00e9 the garlic and onion"
    },
    {
      "position": 2,
      "text": "Once the onion gets soft, continue to saut\u00e9 until the pork turns light brown."
    },
    {
      "position": 3,
      "text": "Pour the oyster sauce. Stir-fry for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add the shrimp cube. Pour-in water. Let boil. Cover and cook until the water reduces to half."
    },
    {
      "position": 5,
      "text": "Add the cauliflower florets. Stir and add the carrot slices. Gently stir until the ingredients are well blended."
    },
    {
      "position": 6,
      "text": "Add the bell peppers and cabbage. Stir-fry for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Sprinkle some salt and pepper. Stir and cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Combine the cornstarch with \u00bd cup water. Stir until the cornstarch is diluted. Pour on the pan. Continue to cook while stirring until the texture of the sauce thickens."
    },
    {
      "position": 9,
      "text": "Add the quail eggs. Transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
