  "slug": "ensaladang-mangga-green-mango-salad",
  "name": "Ensaladang Mangga (Green Mango Salad)",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for green mango salad.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine mango, onion, and tomato in a bowl."
    },
    {
      "position": 2,
      "text": "Pour calamansi or lime juice and then add shrimp paste."
    },
    {
      "position": 3,
      "text": "Toss until all the ingredients are well blended."
    },
    {
      "position": 4,
      "text": "Top with more shrimp paste if desired."
    },
    {
      "position": 5,
      "text": "Serve with with your favorite fried or grilled food."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
