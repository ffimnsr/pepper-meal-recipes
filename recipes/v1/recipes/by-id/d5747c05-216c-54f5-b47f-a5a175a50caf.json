  "schema_version": 1,
  "id": "d5747c05-216c-54f5-b47f-a5a175a50caf",
  "slug": "jelly-roll",
  "name": "Jelly Roll",
  "recipe_type": "dessert",
  "brief_description": "A Jelly Roll is a cake made of thin sheets of sponge cake. Various types of Jellies or Jams are spread on this cake before it gets rolled-up.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Combine all-purpose flour and baking powder in a mixing bowl. Mix well and set aside."
    },
    {
      "position": 3,
      "text": "In a separate bowl, combine egg yolks and vanilla extract. Whisk (using an electric mixer) while gradually adding 5 \u00bd tablespoons of granulated white sugar. Set aside."
    },
    {
      "position": 4,
      "text": "In another bowl, beat the egg whites while gradually adding the remaining 8 tablespoons of granulated white sugar until soft peaks form."
    },
    {
      "position": 5,
      "text": "Fold-in the egg yolk mixture with the egg white mixture. Gradually sprinkle the flour and baking powder mixture while folding."
    },
    {
      "position": 6,
      "text": "Grease a flat baking tray, and then pour-in the mixture. Spread the mixture evenly."
    },
    {
      "position": 7,
      "text": "Put inside the oven and bake for 13 to 16 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven and allow to cool down."
    },
    {
      "position": 9,
      "text": "Sprinkle confectioners sugar on the top part and distribute evenly."
    },
    {
      "position": 10,
      "text": "Remove the cake from the tray and place in a parchment paper or cloth (the part with confectioners sugar should be facing down)."
    },
    {
      "position": 11,
      "text": "Spread Jelly over the cake (the side opposite the one coated with sugar)."
    },
    {
      "position": 12,
      "text": "Roll the cake gently starting from one of the edges."
    },
    {
      "position": 13,
      "text": "Trim both ends of the rolled cake. Transfer to a serving plate."
    },
    {
      "position": 14,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 16,
  "preparation_time_minutes": 15,
