  "id": "d44261fa-ed2e-5138-ad0d-33e532cedea3",
  "slug": "fried-noodles-with-chicken-and-shrimp",
  "name": "Fried Noodles with Chicken and Shrimp",
  "recipe_type": null,
  "brief_description": "This is a recipe for Fried Noodles with Chicken and Shrimp",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat 4 tablespoons of oil in a wide pan or wok. Once the oil gets hot, add the noodles. Pan fry for 12 to 18 seconds. Stir and continue to pan-fry until the noodles browns a bit (it took me around 10 to 12 minutes to fry all the noodles). Arrange in a clean plate. Set aside."
    },
    {
      "position": 2,
      "text": "Prepare the sauce by heating the remaining oil in a pan."
    },
    {
      "position": 3,
      "text": "Add the chicken and then stir-fry for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add the garlic and ginger. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Put the shrimp in the pan along with the mushroom, bok choy, red pepper flakes, sesame oil, and shaoxing wine. Continue to stir-fry for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add the oyster sauce, soy sauce, and chicken broth. Let boil."
    },
    {
      "position": 7,
      "text": "Pour the mixture of cornstarch and water. Stir and continue to cook until the liquid thickens to your desired consistency."
    },
    {
      "position": 8,
      "text": "Pour the sauce immediately over the fried noodles."
    },
    {
      "position": 9,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
