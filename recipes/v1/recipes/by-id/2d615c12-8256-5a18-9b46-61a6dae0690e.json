  "id": "2d615c12-8256-5a18-9b46-61a6dae0690e",
  "slug": "mung-bean-sprouts-with-shrimp",
  "name": "Mung Bean Sprouts with Shrimp",
  "recipe_type": null,
  "brief_description": "This is a recipe for Mung Bean Sprouts with Shrimp",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Add the shrimp. Saute for 1 minute. Sprinkle salt and ground black pepper. Continue to cook for 1 to 2 minutes. Remove from the pan and put in a clean plate. Set aside."
    },
    {
      "position": 3,
      "text": "Using the same pan, add the remaining oil."
    },
    {
      "position": 4,
      "text": "Saute garlic and onion until soft."
    },
    {
      "position": 5,
      "text": "Add the mung bean sprouts, carrot, and cabbage. Stir-fry for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Put the cooked shrimp back in the pan. Stir."
    },
    {
      "position": 7,
      "text": "Add the scallions. Continue to cook for 2 to 3 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
