  "id": "7d066b80-6239-5b5c-be06-b6190c8762e1",
  "slug": "bulalo-beef-mami",
  "name": "Bulalo Beef Mami",
  "recipe_type": "soup",
  "brief_description": "Bulalo Beef Mami is a version of the popular beef noodle soup dish in the Philippines that makes use of beef shank instead of the regular beef chuck. This soup dish can make you feel cozy during the cold weather. It can be eaten anytime of the day and it also goes well when paired with siopao.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a deep soup pot."
    },
    {
      "position": 2,
      "text": "Saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Put-in the beef shank. Cook each side for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour-in beef broth and water. Bring to a boil."
    },
    {
      "position": 5,
      "text": "Add star anise. Simmer for 60 to 90 minutes or until the meat is tender."
    },
    {
      "position": 6,
      "text": "Remove the star anise."
    },
    {
      "position": 7,
      "text": "Add salt and pepper to taste. You can also add water if needed."
    },
    {
      "position": 8,
      "text": "Put-in the dried egg noodles, cabbage, and carrots. Cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to individual bowls. Serve with boiled egg."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
