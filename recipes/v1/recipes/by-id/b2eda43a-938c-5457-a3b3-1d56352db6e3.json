  "id": "b2eda43a-938c-5457-a3b3-1d56352db6e3",
  "slug": "curry-noodles",
  "name": "Curry Noodles",
  "recipe_type": "main",
  "brief_description": "A quick and comforting curry noodle dish made with Maggi Kari, tofu, vegetables, and eggs simmered together for a flavorful weeknight meal.",
  "cuisine": "Asian",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a wok. Fry the tofu until golden then remove and set aside."
    },
    {
      "position": 2,
      "text": "Reduce the oil and pour in the beaten eggs. Cook until firm then remove from the wok."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 garlic, onion, and tomatoes until the tomatoes soften."
    },
    {
      "position": 4,
      "text": "Add fried tofu, pechay, and oyster sauce. Stir and cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour in water and bring to a boil. Add the Maggi Kari seasoning and stir."
    },
    {
      "position": 6,
      "text": "Add the noodles and cook for about 3 minutes while stirring occasionally."
    },
    {
      "position": 7,
      "text": "Combine water and cornstarch. Pour into the wok and cook until the sauce thickens."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper then transfer to a serving dish."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
