  "id": "7898b08d-c43e-5124-81fe-2fa42b41b7d4",
  "slug": "cranberry-apple-juice",
  "name": "Cranberry Apple Juice",
  "recipe_type": "drink",
  "brief_description": "Thanksgiving can be more enjoyable if you have some Cranberry Apple Juice along with your special turkey dinner. Happy thanksgiving!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine water and apple juice in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the cranberries and sugar. Stir and then simmer for 30 to 35 minutes."
    },
    {
      "position": 3,
      "text": "Let the temperature cool down. Transfer the cranberry and apple juice in a pitcher while filtering the whole cranberries using a sieve."
    },
    {
      "position": 4,
      "text": "Refrigerate for 3 hours or add some ice cubes."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
