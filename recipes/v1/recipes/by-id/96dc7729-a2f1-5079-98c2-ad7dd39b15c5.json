  "id": "96dc7729-a2f1-5079-98c2-ad7dd39b15c5",
  "slug": "lechon-manok-recipe",
  "name": "Lechon Manok Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for rotisserie or spit-roasted chicken. This is also known as Lechon Manok in Filipino.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine all the marinade ingredients. Mix well."
    },
    {
      "position": 2,
      "text": "Place the chicken inside a large re-sealable bag. Pour the marinade in the bag with the chicken. Put the onion and lemongrass inside the cavity. Seal and refrigerate overnight."
    },
    {
      "position": 3,
      "text": "Remove the chicken from the bag and then stuff with fresh lemongrass and green onion."
    },
    {
      "position": 4,
      "text": "Prepare to roast the chicken on the grill by skewering the entire fowl on a spit and secure both sides with a grill fork."
    },
    {
      "position": 5,
      "text": "Spit-roast (or i-litson in Tagalog) for 2 \u00bd to 3 hours or until the chicken is done"
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with lechon manok sauce and atchara."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 180,
  "preparation_time_minutes": 360,
  "rest_time_minutes": null,
  "difficulty": "expert",
