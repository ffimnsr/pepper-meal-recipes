  "id": "c0500480-cf7c-51bd-895a-01e32ee6977f",
  "slug": "inihaw-na-pusit-with-scallion",
  "name": "Inihaw na Pusit with Scallion",
  "recipe_type": null,
  "brief_description": "This is a recipe for grilled squid. It is known as Inihaw na Pusit in Filipino. This recipe makes use of scallions as stuffing for the squid.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the squid and then insert the scallions in the cavity."
    },
    {
      "position": 2,
      "text": "Skewer the squid using a long metal or bamboo skewer. Set aside."
    },
    {
      "position": 3,
      "text": "Prepare the basting sauce by combining all the ingredients for the sauce listed above. Mix well."
    },
    {
      "position": 4,
      "text": "Heat-up the grill. Brush the basting sauce on both sides of the squid. Arrange over the grill grate and grill one side for 3 minutes."
    },
    {
      "position": 5,
      "text": "Turn the squid over to grill the other side for another 3 minutes. Brush some basting sauce on the top part of the squid. Continue to grill each side for 2 minutes more or until it is cooked the way you want it. Do not forget to brush the basting sauce every time you turn it over."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
