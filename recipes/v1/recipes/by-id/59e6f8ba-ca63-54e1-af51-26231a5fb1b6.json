  "id": "59e6f8ba-ca63-54e1-af51-26231a5fb1b6",
  "slug": "pinoy-spaghetti",
  "name": "Pinoy Spaghetti Recipe",
  "recipe_type": "main",
  "brief_description": "Pinoy Spaghetti is the Filipino version of spaghetti. It is made different from regular spaghetti and is a popular dish during special occasions",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a large pot, pour the water in and bring to a boil"
    },
    {
      "position": 2,
      "text": "Put-in the salt"
    },
    {
      "position": 3,
      "text": "Add the Spaghetti Noodles and cook until tender (see package for cooking time) then set aside"
    },
    {
      "position": 4,
      "text": "Using a separate pan, saute the garlic and onions"
    },
    {
      "position": 5,
      "text": "Put-in the round meat and let cook for 5 minutes"
    },
    {
      "position": 6,
      "text": "Add the hotdogs and cook for 2 minutes"
    },
    {
      "position": 7,
      "text": "Put-in the tomato sauce, banana catsup, tomato paste, and brown sugar then simmer for 15 to 20 minutes"
    },
    {
      "position": 8,
      "text": "Place the sauce on top of the cooked noodles and add some cheese"
    },
    {
      "position": 9,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
