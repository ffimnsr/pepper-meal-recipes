  "id": "7dee0736-75f5-592b-8a1f-606a03589156",
  "slug": "ginataang-manok-na-may-luyang-dilaw",
  "name": "Ginataang Manok Na May Luyang Dilaw",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginataang Manok Na May Luyang Dilaw (Chicken in Coconut Milk with Turmeric)",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot, saut\u00e9 garlic, onion, and turmeric (luyang dilaw) until the onion softens."
    },
    {
      "position": 3,
      "text": "Add chicken. Cook until all the sides turns light to medium brown."
    },
    {
      "position": 4,
      "text": "Pour 1 \u00bd cups water. Let boil. Cover and continue to boil in medium heat for 30 minutes."
    },
    {
      "position": 5,
      "text": "Combine Knorr Ginataang Gulay mix with 1 cup water. Stir until well blended."
    },
    {
      "position": 6,
      "text": "Pour the mixture into the pan. Let boil."
    },
    {
      "position": 7,
      "text": "Add crushed peppercorn and Thai chili. Stir. Cover and continue to cook until the sauce reduces to half."
    },
    {
      "position": 8,
      "text": "Add hot pepper leaves. Stir. Note: you can also use malunggay leaves or spinach"
    },
    {
      "position": 9,
      "text": "Pour the fish sauce into the mixture. Stir and continue to cook uncovered for 5 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve as a pulutan or a main dish with a cup of rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
