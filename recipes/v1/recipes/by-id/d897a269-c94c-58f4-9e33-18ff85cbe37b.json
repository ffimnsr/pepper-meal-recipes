  "id": "d897a269-c94c-58f4-9e33-18ff85cbe37b",
  "slug": "scallop-and-zucchini-stir-fry",
  "name": "Scallop and Zucchini Stir fry",
  "recipe_type": "dessert",
  "brief_description": "Scallop and Zucchini Stir fry is a simple way to cook Zucchini. It involves saut\u00e9ing the zucchini with sweet peppers and scallops.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a wok."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and onion"
    },
    {
      "position": 3,
      "text": "Add the scallops. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Put-in the zucchini. Stir-fry for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add the sweet peppers, spinach, and fish sauce. Continue to stir-fry for 2 to 3 minutes."
    },
    {
      "position": 6,
      "text": "Sprinkle some ground black pepper to taste."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with fried rice. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 2,
