  "schema_version": 1,
  "id": "0644994f-d3c1-58b5-bacd-c6c46109b0ac",
  "slug": "pineapple-pork-stir-fry",
  "name": "Pineapple Pork Stir Fry",
  "recipe_type": null,
  "brief_description": "Pork and pineapple stir fry with bell pepper and broccoli",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Separate the juice from the pineapple chunks. Set the chunks aside."
    },
    {
      "position": 2,
      "text": "Combine the pineapple juice, pork, and 1 teaspoon salt. Mix and then marinate for 3 hours."
    },
    {
      "position": 3,
      "text": "Heat oil in a wok"
    },
    {
      "position": 4,
      "text": "When the oil becomes hot, add-in the ginger and then cook for 10 seconds."
    },
    {
      "position": 5,
      "text": "Add the garlic and onion. Cook until the onion becomes soft."
    },
    {
      "position": 6,
      "text": "Drain excess liquid from the marinated pork, and then put the pork in the wok. Stir fry for 3 minutes or until the color of the pork becomes light to medium brown."
    },
    {
      "position": 7,
      "text": "Add Hoisin sauce, soy sauce, and oyster sauce. Stir."
    },
    {
      "position": 8,
      "text": "Put-in the pineapple chunk, red bell pepper, scallions, carrots, and broccoli."
    },
    {
      "position": 9,
      "text": "Continue to stir-fry for 5 to 8 minutes. Add salt and pepper to taste."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
