  "id": "60f1b6a8-0522-5187-985b-7523f776ef35",
  "slug": "lemon-garlic-shrimp-pasta",
  "name": "Lemon Garlic Shrimp Pasta",
  "recipe_type": "main",
  "brief_description": "Fettuccine pasta with lemon, garlic, and shrimp.",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Cook pasta according to package instructions. You can add a teaspoon of salt before boiling. Set aside."
    },
    {
      "position": 2,
      "text": "Heat a pan. Pour-in olive oil. Add the shrimp once the oil gets hot. Saute for 2 minutes or until both sides of the shrimp turns orange in color. Remove the shrimp from the pan and transfer to a clean plate. Set aside."
    },
    {
      "position": 3,
      "text": "Heat the remaining oil (if applicable. Otherwise add 2 tablespoons of olive oil). Add 2 tablespoons of butter and continue cooking until the butter melts and starts to bubble."
    },
    {
      "position": 4,
      "text": "Add garlic. Cook while continuously stirring for 30 seconds."
    },
    {
      "position": 5,
      "text": "Add grape tomatoes. Continue saut\u00e9ing for 1 minute."
    },
    {
      "position": 6,
      "text": "Pour the all-purpose cream into the pan and then add \u00bc cup of pasta water (this is the water used to cook the fettuccine). Stir and then add the lemon zest. Let the mixture slowly boil (use medium heat setting). Continue cooking for 1 minute. Season with salt and ground black pepper."
    },
    {
      "position": 7,
      "text": "Toss the pasta into the pan. Add the shrimp, parsley, and remaining butter. Continue tossing until all ingredients are incorporated. Top with more parmesan cheese if desired."
    },
    {
      "position": 8,
      "text": "Serve warm. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
