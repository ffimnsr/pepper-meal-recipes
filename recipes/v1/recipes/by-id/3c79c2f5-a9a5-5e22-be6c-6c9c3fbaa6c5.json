  "id": "3c79c2f5-a9a5-5e22-be6c-6c9c3fbaa6c5",
  "slug": "bopis-pulutan-recipe",
  "name": "Bopis Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Filipino pulutan and main dish consist of minced pigs lungs and heart.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a large pot, boil 8 cups of water and then add the rest of the boiling ingredients. Put the pig\u2019s lungs into the pot and continue boiling for 1 hours. Remove the lungs, let it cool down, and then dice into small pieces. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil on a clean pot. Saut\u00e9 garlic, onion, and ginger."
    },
    {
      "position": 3,
      "text": "Add the diced lungs once the onion softens. Cook for 3 minutes while stirring."
    },
    {
      "position": 4,
      "text": "Add vinegar. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour 2 \u00bd cups of water into the pot. Let it boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Pork cube and bay leaves. Stir. Cover the pot and adjust the heat between low to medium setting. Continue cooking until the liquid reduces to half."
    },
    {
      "position": 7,
      "text": "Add the carrot, chili pepper, and annatto powder. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper and fish sauce."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
