  "id": "27ca129a-eb6b-588d-8015-b5bd67367630",
  "slug": "ginataang-langka-with-alimasag",
  "name": "Ginataang Langka with Alimasag",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginataang Langka with Alimasag",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Saute garlic, onion, and ginger."
    },
    {
      "position": 3,
      "text": "Add jackfruit. Continue to saute for 3 minutes."
    },
    {
      "position": 4,
      "text": "Combine Knorr Ginataang Gulay Recipe Mix with 1 cup water. Mix well."
    },
    {
      "position": 5,
      "text": "Add chili pepper and pour the Ginataang Gulay mixture into the pot. Stir. Let boil. Cook in medium heat for 10 to 12 minutes while stirring every 5 minutes."
    },
    {
      "position": 6,
      "text": "Add crabs. Cover and cook for 10 minutes."
    },
    {
      "position": 7,
      "text": "Put the malunggay leaves into the pot and pour-in the fish sauce. Stir and then cook for 5 minutes or until the liquid eveporates completely."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
