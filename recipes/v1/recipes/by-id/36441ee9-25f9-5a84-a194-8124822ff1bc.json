  "id": "36441ee9-25f9-5a84-a194-8124822ff1bc",
  "slug": "beef-caldereta-recipe",
  "name": "Beef Caldereta Recipe",
  "recipe_type": "main",
  "brief_description": "Special Filipino beef stew with olives, potato, and carrot.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot. Fry the carrots for 2 minutes. Make sure that all sides are cooked equally. Remove from the pot. Set aside."
    },
    {
      "position": 2,
      "text": "Fry the potato until the color of the outer part turns light brown. Remove from the pot and set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil, saut\u00e9 garlic, onion, and thyme. Continue saut\u00e9ing until the onion caramelizes."
    },
    {
      "position": 4,
      "text": "Add beef short ribs. Cook until the color of the outer part turns light brown."
    },
    {
      "position": 5,
      "text": "Pour tomato sauce and red wine. Add Knorr Beef Cube."
    },
    {
      "position": 6,
      "text": "Add soy sauce and water. Cover the pot. Continue cooking the stew in low heat setting until the beef tenderizes completely."
    },
    {
      "position": 7,
      "text": "Add liver spread and bell pepper. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Add carrot and potato. Cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Add cheddar cheese and then season with salt and ground black pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "expert",
