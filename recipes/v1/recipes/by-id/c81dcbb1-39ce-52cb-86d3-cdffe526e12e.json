  "id": "c81dcbb1-39ce-52cb-86d3-cdffe526e12e",
  "slug": "crispy-bicol-express",
  "name": "Crispy Bicol Express",
  "recipe_type": null,
  "brief_description": "This is a recipe for Crispy Bicol Express",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add pork belly. Continue to cook for 30 minutes. Remove the pork belly. Let it cool down."
    },
    {
      "position": 3,
      "text": "Meanwhile, prepare the Bicol express sauce by adding Knorr Ginataang Gulay Mix into the remaining water in the cooking pot. Stir until well blended."
    },
    {
      "position": 4,
      "text": "Add the onion, ginger, and garlic. Let boil."
    },
    {
      "position": 5,
      "text": "Add the long green chili pepper and Thai chili. Stir. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Put the alamang into the cooking pot. Stir."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper. Continue to cook until the sauce reduces to half. Set aside."
    },
    {
      "position": 8,
      "text": "Continue to prepare the pork belly by rubbing salt all over it. Let is stay for at least 10 minutes."
    },
    {
      "position": 9,
      "text": "Heat oil in a deep cooking pot or deep fryer. Once the oil reaches 330F, deep-fry the pork belly for 8 minutes. Let it rest for 5 minutes. Put it back into the pot or deep fryer and continue to deep fry for 3 to 5 minutes."
    },
    {
      "position": 10,
      "text": "Remove from the pot. Slice. Arrange in a serving plate. Top with Bicol Express sauce."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
