  "schema_version": 1,
  "id": "42f12d08-ad5b-5451-87d1-1bb099c33574",
  "slug": "grilled-lobster-tails-recipe",
  "name": "Grilled Lobster Tails",
  "recipe_type": "appetizer",
  "brief_description": "Grilled lobster tails brushed with garlic butter and cooked over medium high heat until tender and smoky. The shell protects the meat while it grills, keeping it juicy. Serve with lemon wedges and extra butter for dipping.",
  "cuisine": "American Mediterranean seafood",
  "instructions": [
    {
      "position": 1,
      "text": "Melt the butter in a small saucepan over low heat. Add the minced garlic, lemon juice, parsley, salt, and pepper. Stir to combine. Remove from heat and set half aside for dipping. Keep the other half warm for basting."
    },
    {
      "position": 2,
      "text": "Place the lobster tail on a cutting board with the top shell facing up. Use kitchen shears to cut down the center of the top shell, starting from the open end toward the tail fin. Stop before you reach the fin."
    },
    {
      "position": 3,
      "text": "Gently pull the shell apart to expose the meat. Keep the bottom shell intact. Lift the meat slightly and rest it on top of the shell. Insert a skewer lengthwise through the meat to keep it flat."
    },
    {
      "position": 4,
      "text": "Preheat your grill to medium high heat, around 400\u00b0F to 450\u00b0F. Spray the grates with cooking oil."
    },
    {
      "position": 5,
      "text": "Brush the exposed lobster meat with garlic butter. Season with a little salt and pepper."
    },
    {
      "position": 6,
      "text": "Place the tails on the grill meat side down. Cook for 4 minutes until you see light grill marks."
    },
    {
      "position": 7,
      "text": "Flip the tails shell side down. Brush with more garlic butter and grill for another 3 to 5 minutes or until the meat is opaque and the internal temperature reaches 135\u00b0F to 140\u00b0F."
    },
    {
      "position": 8,
      "text": "Remove from the grill and place on a serving plate. Brush one more layer of garlic butter on top. Garnish with chopped parsley and lemon wedges. Serve with the reserved garlic butter for dipping."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
