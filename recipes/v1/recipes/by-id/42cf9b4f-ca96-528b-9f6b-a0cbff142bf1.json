  "id": "42cf9b4f-ca96-528b-9f6b-a0cbff142bf1",
  "slug": "chicken-and-corn-soup",
  "name": "Chicken and Corn Soup",
  "recipe_type": "soup",
  "brief_description": "Chicken Soup is a comfort food that can also be a remedy to minor illness. Learn to cook this dish by following our video.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in cooking pot."
    },
    {
      "position": 2,
      "text": "Put-in ginger and cook for a minute."
    },
    {
      "position": 3,
      "text": "Add the corn and chicken stock. Stir and let boil."
    },
    {
      "position": 4,
      "text": "Put-in the chicken, soy sauce, sesame oil, salt, and pepper. Let boil and cook for 7 to 10 minutes."
    },
    {
      "position": 5,
      "text": "Combine cornstarch with cold water and mix well. Add-in the mixture and stir continuously while cooking."
    },
    {
      "position": 6,
      "text": "Stir-in the beaten eggs. Continue stirring to prevent the eggs from forming."
    },
    {
      "position": 7,
      "text": "Add the green onions and cook for another 2 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve. share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
