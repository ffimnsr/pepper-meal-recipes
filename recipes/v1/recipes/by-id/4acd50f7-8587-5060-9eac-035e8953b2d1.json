{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "4acd50f7-8587-5060-9eac-035e8953b2d1",
  "slug": "adobong-isaw-ng-baboy-tumbong-recipe",
  "name": "Adobong Isaw Ng Baboy",
  "recipe_type": "appetizer",
  "brief_description": "Pork intestines simmered in soy sauce, vinegar, and garlic with a spicy kick\u2014perfect as ulam or pulutan.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork intestines, salt, and crushed ginger in a wok. Pour in water. Cover and bring to a boil. Lower the heat and simmer for 90 minutes or until the intestines becomes tender."
    },
    {
      "position": 2,
      "text": "Remove the pork intestines from the wok. Rinse under running water and slice into serving pieces."
    },
    {
      "position": 3,
      "text": "In a clean wok, combine crushed garlic and 1/4 cup cooking oil. Cook over low heat until garlic is golden brown. Remove the toasted garlic from the pan. Separate the oil."
    },
    {
      "position": 4,
      "text": "Pour 3 tablespoons of oil (used to fry the garlic) back in to the pan. Add 2 teaspoons of toasted garlic."
    },
    {
      "position": 5,
      "text": "Heat the pan and then add the sliced intestines. Saute until it browns."
    },
    {
      "position": 6,
      "text": "Pour in soy sauce, add the cracked peppercorn, and dried bay leaves."
    },
    {
      "position": 7,
      "text": "Add vinegar. Let it boil. Stir and add beef broth. Simmer until the liquid reduces to a quarter."
    },
    {
      "position": 8,
      "text": "Add brown sugar and chopped chili peppers. Stir."
    },
    {
      "position": 9,
      "text": "Stir-in the oyster sauce and then add chopped green onions and the remaining toasted garlic Cook for 30 seconds."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
