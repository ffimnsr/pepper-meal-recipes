  "id": "bceaeb22-adf8-5d8f-9f1f-bc3fafb1a388",
  "slug": "pinsec-frito-fried-wonton-recipe",
  "name": "Pinsec Frito Recipe - Deep Fried Wonton",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pinsec Frito Recipe - Deep Fried Wonton",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine ground pork, carrots, onion, sesame oil, salt, ground black pepper, green onion, crab meat, and egg then mix thoroughly."
    },
    {
      "position": 2,
      "text": "Wrap the mixture in wonton wrapper. Place a piece of wonton wrapper in a flat surface then scoop a teaspoon of the meat mixture and place it in the middle of the wonton wrapper. Dip your finger in water and run it on the sides of the wonton wrapper. Fold the wonton wrapper in a manner where one edge meets the opposite forming a triangle. Gently press the sides to seal."
    },
    {
      "position": 3,
      "text": "Heat the oil in a frying pan."
    },
    {
      "position": 4,
      "text": "When the oil is hot enough, fry the wrapped wontons until the wrapper becomes crispy."
    },
    {
      "position": 5,
      "text": "Remove from the frying pan and place in a plate with paper towel."
    },
    {
      "position": 6,
      "text": "Serve with sweet and sour sauce or Dim Sum sauce."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 15,
