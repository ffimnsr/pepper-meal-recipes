  "id": "6f74d862-0c75-584b-890f-eec6a1dec796",
  "slug": "chopsuey-stir-fry-recipe",
  "name": "Chopsuey Stir Fry",
  "recipe_type": null,
  "brief_description": "This is a recipe for Chopsuey Stir Fry",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok or large pan."
    },
    {
      "position": 2,
      "text": "Pan-fry the shrimp for 30 seconds per side. Remove from the wok, set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil, saute the onion until it starts to loosen."
    },
    {
      "position": 4,
      "text": "Add bell peppers, cauliflower, broccoli, snow peas, and young corn. Stir-fry (in high heat) for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Add the shrimp back into the wok. Season with salt and ground black pepper. Continue to stir-fry for 1 minute."
    },
    {
      "position": 6,
      "text": "Combine chicken broth and cornstarch. Stir until well blended. Pour the mixture into the wok. Toss. Cook for 1 to 2 minutes or until the mixture slightly thickens."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
