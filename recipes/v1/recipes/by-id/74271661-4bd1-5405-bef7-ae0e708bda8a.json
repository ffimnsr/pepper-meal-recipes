  "id": "74271661-4bd1-5405-bef7-ae0e708bda8a",
  "slug": "how-to-cook-chicken-sotanghon-tinola",
  "name": "Chicken Sotanghon Tinola Recipe",
  "recipe_type": "soup",
  "brief_description": "Chicken tinola with vermicelli",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Saute garlic, onion, and ginger."
    },
    {
      "position": 2,
      "text": "Add chicken once the onion softens. Cook until the outer layer of the chicken turns light brown."
    },
    {
      "position": 3,
      "text": "Pour water. Let boil. Add Knorr Chicken Cube. Cover the pot and boil in low to medium heat for 15 minutes."
    },
    {
      "position": 4,
      "text": "Add papaya and sotanghon. Cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add malunggay leaves."
    },
    {
      "position": 6,
      "text": "Season with ground black pepper and patis. Finish by adding toasted garlic."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve hot. Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
