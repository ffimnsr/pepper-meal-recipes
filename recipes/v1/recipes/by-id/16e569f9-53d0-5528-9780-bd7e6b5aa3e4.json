  "id": "16e569f9-53d0-5528-9780-bd7e6b5aa3e4",
  "slug": "chicken-adobo-fried-rice-and-tortang-corned-beef",
  "name": "Chicken Adobo Fried Rice and Tortang Corned Beef",
  "recipe_type": "breakfast",
  "brief_description": "Quick and Easy Filipino breakfast meal from leftovers.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the omelette by combining corned beef, egg, and ground black pepper in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Heat 4 tablespoons of cooking oil in a pan. Scoop a quarter portion of the corned beef mixture and fry. Gently flatten the mixture in the pan and continue to fry in medium heat for 1 to 2 minutes. Flip the corned beef omelette and fry the opposite side until done. Remove from the pan and place in a clean plate. Perform the same steps until the mixture is completely consumed."
    },
    {
      "position": 3,
      "text": "Prepare the rice by combining rice and salt. Gently mix while trying to separate the rice with each other."
    },
    {
      "position": 4,
      "text": "Heat 3 tablespoons oil in a pan. Add crushed garlic. Continue to cook in medium heat until garlic turns light brown in color."
    },
    {
      "position": 5,
      "text": "Add chopped chicken adobo. Stir-fry for 1 minute."
    },
    {
      "position": 6,
      "text": "Add rice. Toss and stir-fry for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Transfer the chicken adobo fried rice in a plate and then top with tortang corned beef. Serve with your favorite condiment."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
