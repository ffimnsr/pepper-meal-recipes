  "id": "cac7af59-5b1b-5b39-80ea-4e3f865cb52e",
  "slug": "pinakbet-with-lechon-kawali",
  "name": "Pinakbet with Lechon Kawali",
  "recipe_type": null,
  "brief_description": "This is a recipe of pinakbet with lechon kawali. It is a dish composed of mixed vegetables with shrimp paste and chopped crispy deep fried pork belly on top.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic until it turns medium brown."
    },
    {
      "position": 3,
      "text": "Add the onion and tomato. Continue to cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add \u00bc lb. of chopped lechon kawali and stir-in the squash. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour the beef broth in the pot. Let boil."
    },
    {
      "position": 6,
      "text": "Add the shrimp paste. Stir. Cover and cook in medium heat for 5 to 7 minutes."
    },
    {
      "position": 7,
      "text": "Add the ampalaya, eggplant, okra, and sitaw. Stir and cook for 8 to 12 minutes."
    },
    {
      "position": 8,
      "text": "Sprinkle salt and pepper. Stir"
    },
    {
      "position": 9,
      "text": "Arrange the remaining lechon kawali on top."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
