  "id": "89bfeffd-404d-5c70-bd8c-2cf7d9f2ee9e",
  "slug": "how-to-cook-kare-kare-knr-bc",
  "name": "Kare Kare Recipe",
  "recipe_type": "main",
  "brief_description": "This is a Filipino Kare Kare Recipe using oxtail and beef tripe.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 1 quart water in a pressure cooker. Add oxtail and tripe. Continue to boil in medium heat for 20 minutes. Note: do not cover the cooker."
    },
    {
      "position": 2,
      "text": "Drain the water use to boil the beef. Pour 1 quart of fresh water into the pressure cooker. Cover and pressure cook for 25 minutes."
    },
    {
      "position": 3,
      "text": "Prepare annatto water by combining 1 cup of hot water with annatto seeds. Stir. Soak seeds for 10 minutes. Remove the seeds by filtering using a kitchen sieve. Set aside.&nbsp;"
    },
    {
      "position": 4,
      "text": "Heat oil in a cooking pot. Saute onion and garlic until onion softens."
    },
    {
      "position": 5,
      "text": "Pour beef stock into the pot. Note: this is the liquid used to pressure cook the oxtail and tripe. Let boil."
    },
    {
      "position": 6,
      "text": "Add peanut butter. Stir until well blended."
    },
    {
      "position": 7,
      "text": "Add Knorr Beef Cube. Stir.&nbsp;"
    },
    {
      "position": 8,
      "text": "Pour annatto water into the pot and then add oxtail and beef tripe. Let the mixture re-boil. Cook for 5 to 7 minutes."
    },
    {
      "position": 9,
      "text": "Combine cornstarch with 1/4 cup water. Stir. Pour mixture into the cooking pot. Stir."
    },
    {
      "position": 10,
      "text": "Add eggplant, banana blossom, and sitaw. Cook for 5 minutes."
    },
    {
      "position": 11,
      "text": "Add pechay. Cover the pot and cook for 3 to 4 minutes.&nbsp;"
    },
    {
      "position": 12,
      "text": "Transfer to a serving bowl. Serve!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
