  "id": "0172a205-71bb-5e25-8cde-57384afaae33",
  "slug": "sinigang-na-pata-with-gabi",
  "name": "Sinigang na Pata with Gabi",
  "recipe_type": "soup",
  "brief_description": "Pork hock soup in sour tamarind broth with taro and vegetables.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add pata. Boil for 15 minutes. Discard the water and clean the pata by washing in running water."
    },
    {
      "position": 2,
      "text": "Pour 6 cups water into a pressure cooker. Add boiled pata and salt. Pressure cook for 12 minutes."
    },
    {
      "position": 3,
      "text": "Transfer everything in a large cooking pot. Add 2 cups water. Let boil."
    },
    {
      "position": 4,
      "text": "Add onion and taro. Cover the pot and boil for 15 minutes."
    },
    {
      "position": 5,
      "text": "Put the tomato into the pot and add Knorr Pork Cube and Knorr Sinigang sa Sampaloc Recipe Mix. Stir. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add long green pepper, eggplant, okra, snake beans, and kangkong stalk. Cover and cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and fish sauce."
    },
    {
      "position": 8,
      "text": "Add kangkong leaves. Turn the heat off. Cover the pot and let the residual heat completely cook the leaves."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
