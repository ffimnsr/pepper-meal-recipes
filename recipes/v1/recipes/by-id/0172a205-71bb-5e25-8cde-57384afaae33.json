  "id": "0172a205-71bb-5e25-8cde-57384afaae33",
  "slug": "sinigang-na-pata-with-gabi",
  "name": "Sinigang na Pata with Gabi",
  "recipe_type": "soup",
  "brief_description": "Tender pork hock simmered in a tangy tamarind-based broth with taro (gabi) and fresh vegetables. Pressure-cooked for efficiency while maintaining traditional Filipino sour soup flavors.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add pork hock and boil for 15 minutes to remove impurities. Discard the blanching water and rinse the pata under running water."
    },
    {
      "position": 2,
      "text": "Pour 6 cups water into a pressure cooker. Add the blanched pata and salt. Pressure cook for 12 minutes, then allow pressure to release naturally."
    },
    {
      "position": 3,
      "text": "Transfer the contents into a large cooking pot. Add 2 cups water and bring to a boil over medium-high heat."
    },
    {
      "position": 4,
      "text": "Add onion and taro. Cover the pot and boil for 15 minutes until the taro begins to soften."
    },
    {
      "position": 5,
      "text": "Add tomatoes, pork cube, and sinigang sa sampaloc mix. Stir to dissolve. Simmer for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add long green pepper, eggplant, okra, snake beans, and kangkong stalks. Cover and cook for 5 minutes over medium heat."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and fish sauce to taste."
    },
    {
      "position": 8,
      "text": "Add kangkong leaves. Turn off the heat, cover the pot, and let residual heat wilt the leaves completely."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve hot with steamed rice and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
