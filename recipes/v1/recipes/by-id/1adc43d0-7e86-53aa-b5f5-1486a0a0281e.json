  "id": "1adc43d0-7e86-53aa-b5f5-1486a0a0281e",
  "slug": "patis-fried-chiken",
  "name": "Patis Fried Chicken",
  "recipe_type": null,
  "brief_description": "Patis Fried Chicken is a crispy and tasty fried chicken recipe that is best eaten with rice. This fried chicken dish is marinated in fish sauce",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Put the chicken in a large mixing bowl. Add the ground black pepper and fish sauce. Mix well and let it stay for 1 hour."
    },
    {
      "position": 2,
      "text": "Meanwhile, combine the flour and cornstarch in a large container. Mix well."
    },
    {
      "position": 3,
      "text": "Heat a deep cooking pot. Pour-oil and then let the oil get hot enough to fry."
    },
    {
      "position": 4,
      "text": "Dredge the marinated chicken in the flour and cornstarch mixture."
    },
    {
      "position": 5,
      "text": "Deep fry for 12 minutes per side (medium heat); flip to cook the other side for 8 to 10 minutes"
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve hot."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
