  "id": "74d377f8-f34b-51b5-9986-1b0379071161",
  "slug": "inihaw-na-tilapia-recipe",
  "name": "Inihaw na Tilapia Recipe",
  "recipe_type": null,
  "brief_description": "Inihaw na Tilapia or Grilled Tilapia is one of my favorite summer time dishes. There are many ways to prepare inihaw na Tilapia, this recipe will guide you on how to make grilled or inihaw na Tilapia in the simplest way \u2013 rubbed with salt and pepper and cooked directly over the grill.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pat the tilapia dry using a paper towel."
    },
    {
      "position": 2,
      "text": "Arrange the tilapia in a plate and rub salt and pepper all over the fish including its cavity."
    },
    {
      "position": 3,
      "text": "Spray cooking oil spray on the grill."
    },
    {
      "position": 4,
      "text": "Start to heat the grill."
    },
    {
      "position": 5,
      "text": "Grill each side of the tilapia for 10 minutes. Note: use a spatula to turn the fish over so that the sides will be intact and clean."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with lime or lemon wedges."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
