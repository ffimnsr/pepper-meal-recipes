  "id": "f7334700-f565-599e-9c69-cf48e3b61165",
  "slug": "baked-potato-skins",
  "name": "Baked Potato Skin Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Baked Potato Skins are good appetizers. This recipe makes a good tail gate food. Check out how to make this dish for you to enjoy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 450 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "In a bowl, combine olive oil, salt, garlic powder, pepper, Parmesan cheese, and paprika. Mix well. Set aside"
    },
    {
      "position": 3,
      "text": "Slice the potatoes in half (lengthwise). Scrape the pulp until the thickness reaches about a quarter of an inch."
    },
    {
      "position": 4,
      "text": "Brush the oil and spice mixture on each potato skin. Grease a baking tray, and arrange the potato skin."
    },
    {
      "position": 5,
      "text": "Place inside the oven and bake each side for 8 to 9 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven and arrange crumbled bacon and sharp cheddar cheese in each potato skin."
    },
    {
      "position": 7,
      "text": "Put-back in the oven and bake for 2 to 3 minutes more."
    },
    {
      "position": 8,
      "text": "Remove from the oven and allow to cool down."
    },
    {
      "position": 9,
      "text": "Put sour cream on top and garnish with chopped green onions."
    },
    {
      "position": 10,
      "text": "Serve as an appetizer. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
