  "id": "462c48c1-e009-582d-94a8-e6ff527219d6",
  "slug": "sous-vide-chicken-adobo",
  "name": "Sous Vide Chicken Adobo",
  "recipe_type": null,
  "brief_description": "This recipe for chicken adobo is cooked using the sous vide method of cooking.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place the chicken pieces in a resealable freezer bag. Add bay leaves, peppercorn, garlic, and soy sauce. Vacuum-seal the bag."
    },
    {
      "position": 2,
      "text": "Pour water into a heat-safe food storage container or deep pot. Preheat water using a sous vide cooker at 155F."
    },
    {
      "position": 3,
      "text": "Gently submerge the sealed bags or pouches with chicken. Let it cook for 4 hours."
    },
    {
      "position": 4,
      "text": "Remove the chicken from the bags. Transfer to a cooking pot with half of the marinade (soy sauce mixture)."
    },
    {
      "position": 5,
      "text": "Put the cooking pot in a stovetop. Let the liquid boil."
    },
    {
      "position": 6,
      "text": "Add chicken broth and vinegar. Cover and cook for 5 to 8 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 252,
  "preparation_time_minutes": 15,
