  "id": "2200c053-e367-5c19-b81a-f1edac10a9e2",
  "slug": "tuna-salad-recipe",
  "name": "Tuna Salad Recipe",
  "recipe_type": "salad",
  "brief_description": "This Tuna Salad Recipe can be used to make different dishes. It is quick, easy, and delicious. Try to make one today.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Drain the liquid from the tuna and then place the tuna in a medium mixing bowl."
    },
    {
      "position": 2,
      "text": "Add mayonnaise, parmesan and cheddar cheeses, onion, celery, garlic powder, and white sugar. Gently mix to incorporate all the ingredients."
    },
    {
      "position": 3,
      "text": "Try to taste the mixture and then add salt and pepper as needed."
    },
    {
      "position": 4,
      "text": "Serve. You can make sandwiches, wraps, and finger food out of this recipe. Enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 2,
