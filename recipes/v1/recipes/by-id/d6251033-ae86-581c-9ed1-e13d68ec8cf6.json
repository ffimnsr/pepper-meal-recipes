  "id": "d6251033-ae86-581c-9ed1-e13d68ec8cf6",
  "slug": "kung-pao-pork-recipe",
  "name": "Kung Pao Pork Recipe",
  "recipe_type": null,
  "brief_description": "Kung Pao Pork is a variation Kung Pao chicken, which is a delicious dish that I always enjoy in Chinese take-outs \u2013 especially if I have it with Yang Chow fried rice. This dish is a bit spicy, but very tasty.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine pork, 2 tablespoons soy sauce, and 2 teaspoons cornstarch. Mix well and let it stand for 1 hour."
    },
    {
      "position": 2,
      "text": "Meanwhile, let\u2019s start to make the sauce by combining the vinegar, sugar, cooking wine, 2 teaspoons cornstarch, sesame oil, and water. Stir to mix the ingredients. Set aside."
    },
    {
      "position": 3,
      "text": "Heat the cooking oil in a deep cooking pot."
    },
    {
      "position": 4,
      "text": "Once the oil is hot, deep fry the marinated pork until the color turns light to medium brown. Remove the pork from the pot and put in a plate lined with paper towel. The paper towel will absorb the oil."
    },
    {
      "position": 5,
      "text": "In a wide pan or wok, re-use 3 tablespoons of cooking by heating it up. Saute the bell pepper, zucchini, ginger, and garlic."
    },
    {
      "position": 6,
      "text": "Add the fried pork, peanuts, and chili. Continue to cook for 4 minutes."
    },
    {
      "position": 7,
      "text": "Pour-in the sauce. Stir fry to distribute the ingredients. Continue to cook until the texture becomes thick."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
