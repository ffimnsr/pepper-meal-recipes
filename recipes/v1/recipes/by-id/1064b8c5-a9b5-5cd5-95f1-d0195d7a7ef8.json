  "id": "1064b8c5-a9b5-5cd5-95f1-d0195d7a7ef8",
  "slug": "adobo-meatballs-recipe",
  "name": "Adobo Meatballs Recipe",
  "recipe_type": "main",
  "brief_description": "Adobo Meatball is a dish made using our easy meatball recipe and cooked inadobo style. Since I made a lot of meatballs for our Spaghetti and meatball dinner, there was an extra batch that I was not able to use and I thought that it will be nice to turn them into meatball adobo.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Put-in the garlic. Let the garlic cook until the color turns light brown. Make sure to keep an eye on the garlic so that it won't get burnt."
    },
    {
      "position": 3,
      "text": "Add the meatballs, peppercorn, and bay leaves. I am using cooked meatballs and the recipe link is available above."
    },
    {
      "position": 4,
      "text": "Pour-in the soy sauce and beef broth. Add the sugar. Stir and let boil."
    },
    {
      "position": 5,
      "text": "Cover and simmer for 15 minutes. Add vinegar and a little water if the liquid starts to dry-up."
    },
    {
      "position": 6,
      "text": "Try to taste your meatball adobo and add salt if necessary."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
