  "id": "eb375cd8-e43e-5c03-a5c3-1bed43c93d1d",
  "slug": "misua-with-patola-and-shrimp",
  "name": "Misua with Patola and Shrimp",
  "recipe_type": "soup",
  "brief_description": "Misua with patola and shrimp is a soothing flour noodle soup recipe that has a close resemblance to the Filipino albondigas",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a deep cooking pot."
    },
    {
      "position": 2,
      "text": "Saute onion and garlic."
    },
    {
      "position": 3,
      "text": "Pour-in the fish sauce and tomato sauce. Sprinkle about half a teaspoon of ground black pepper."
    },
    {
      "position": 4,
      "text": "Add the shrimp. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour-in the water. Let boil."
    },
    {
      "position": 6,
      "text": "Add the misua, shrimp bouillon and patola. Cook for 3 to 6 minutes."
    },
    {
      "position": 7,
      "text": "Sprinkle some salt and pepper, if needed."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Top with toasted garlic."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
