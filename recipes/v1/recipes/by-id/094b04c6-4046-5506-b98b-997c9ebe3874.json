  "id": "094b04c6-4046-5506-b98b-997c9ebe3874",
  "slug": "easy-palabok",
  "name": "Easy Palabok Recipe",
  "recipe_type": "main",
  "brief_description": "Rice noodles topped with delicious palabok sauce with shrimp, toasted garlic, crushed pork rinds, and scallions.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water. Arrange bihon (rice sticks) in a wide and deep tray. Pour water until noodles are totally submerged. Soak for 12 to 15 minutes. Drain water and set the bihon aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot. Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Add ground pork. Saute until pork turns light brown.Add tinapa flakes. Stir. Gradually add all-purpose flour. Continue to cook while stirring until all of the flour are consumed. Cook between low to medium heat for 5 minutes."
    },
    {
      "position": 4,
      "text": "Gradually pour annatto water into the pot. Stir constantly until desired consistency is desired. The sauce should not be as thick as paste."
    },
    {
      "position": 5,
      "text": "Add Knorr Shrimp Cube. Stir until it melts. Season with patis and ground white pepper."
    },
    {
      "position": 6,
      "text": "Arrange the bihon on a plate, pour palabok sauce over it. top with shrimp, chicharon, and toasted garlic, and scallions. Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": null,
  "preparation_time_minutes": null,
