  "id": "7dd73f9c-7038-580f-a91b-60609bc1db09",
  "slug": "easy-sweet-and-sour-ikea-meatball-recipe",
  "name": "Easy Sweet and Sour Ikea Meatbal",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe of sweet and sour meatball using Ikea's Swedish meatball.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan. Pour-in cooking oil"
    },
    {
      "position": 2,
      "text": "Put-in the onion, carrots, pineapple chunks, and bell peppers. Saut\u00e9 for 3 minutes"
    },
    {
      "position": 3,
      "text": "Add-in the ketchup, vinegar, sugar, and water. Stir and then let boil."
    },
    {
      "position": 4,
      "text": "Put-in the meatballs. Cook for 5 to 7 minutes in medium heat."
    },
    {
      "position": 5,
      "text": "Pour-in cornstarch diluted in water. Stir and then cook until the texture thickens."
    },
    {
      "position": 6,
      "text": "Sprinkle with salt and pepper."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
