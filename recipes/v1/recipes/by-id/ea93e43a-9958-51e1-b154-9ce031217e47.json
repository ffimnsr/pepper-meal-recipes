  "id": "ea93e43a-9958-51e1-b154-9ce031217e47",
  "slug": "oat-bran-chocolate-chip-cookie",
  "name": "Oat Bran Chocolate Chip Cookie",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Oat Bran Chocolate Chip Cookie",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pre-heat oven to 375F"
    },
    {
      "position": 2,
      "text": "In a bowl, combine all-purpose flour, salt, and baking soda. Mix well."
    },
    {
      "position": 3,
      "text": "Using a separate bowl, beat the white and brown sugars with the butter using an hand blender or an electric mixer."
    },
    {
      "position": 4,
      "text": "Pour the milk and vanilla extract and add the eggs with the butter mixture. Continue to beat."
    },
    {
      "position": 5,
      "text": "Gradually add the dry ingredient mixture (flour etc.) while beating."
    },
    {
      "position": 6,
      "text": "Fold-in the chocolate chips. Leave a few pieces of chips for later."
    },
    {
      "position": 7,
      "text": "Scoop around 1 tablespoon of mixture and arrange in a cookie sheet or baking tray. Bake for 8 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven and arrange the remaining chips on top. Put it back in the oven and continue to bake for 2 to 3 minutes."
    },
    {
      "position": 9,
      "text": "Let the oat bran cookies cool down in a wire rack."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 11,
  "preparation_time_minutes": 10,
