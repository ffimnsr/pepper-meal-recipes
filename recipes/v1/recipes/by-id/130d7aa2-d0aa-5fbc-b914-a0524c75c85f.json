  "id": "130d7aa2-d0aa-5fbc-b914-a0524c75c85f",
  "slug": "filipino-asian-dessert-cassava-pichi-pichi-recipe",
  "name": "Pichi-Pichi Recipe",
  "recipe_type": "dessert",
  "brief_description": "Pichi Pichi is a form of Filipino dessert made from grated cassava. Watch our video to learn how to cook this dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, combine cassava, sugar, and water then mix thoroughly"
    },
    {
      "position": 2,
      "text": "Add lye water while continuously stirring the mixture"
    },
    {
      "position": 3,
      "text": "Put-in the buko-pandan essence then mix again"
    },
    {
      "position": 4,
      "text": "Once the mixture is evenly distributed, pour in individual cup molds and place in a steamer"
    },
    {
      "position": 5,
      "text": "Steam the mixture for 45 minutes to 1 hour (or until the color turns translucent)"
    },
    {
      "position": 6,
      "text": "Allow the steamed pichi-pichi to cool down (at least 40 minutes to 1 hour ; you can even place it in the fridge after letting it cool down at least 15 minutes) then remove from the molds"
    },
    {
      "position": 7,
      "text": "Roll the each piece over the grated coconut"
    },
    {
      "position": 8,
      "text": "Place in a serving plate then serve. Share and Enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
