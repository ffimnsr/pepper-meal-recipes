{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "b2b4d8e1-eb38-5d75-baa1-d14bc11a0afc",
  "slug": "sinigang-na-liempo-sa-sampaloc-with-gabi",
  "name": "Sinigang na Liempo sa Sampaloc with Gabi",
  "recipe_type": "main",
  "brief_description": "Sinigang na Liempo sa Sampaloc with Gabi is a great idea for lunch. I love to have it with a condiment of fish sauce and super hot chili pepper",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil the water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Put-in the tamarind and continue to boil for 45 minutes."
    },
    {
      "position": 3,
      "text": "Meanwhile, heat the oil on another deep cooking pot."
    },
    {
      "position": 4,
      "text": "Once the oil is hot, sear the pork belly until the color turns light brown."
    },
    {
      "position": 5,
      "text": "Stir-in the tomatoes and onion. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Gently pour-in the boiling water, but do not include the tamarind. Add the beef broth and gabi afterwards."
    },
    {
      "position": 7,
      "text": "Place the tamarind on a strainer and let the remaining juice out by pushing a spoon against it. Add the tamarind juice to the cooking pot where the meat is. Simmer for 60 minutes. Add more water if necessary."
    },
    {
      "position": 8,
      "text": "Put-in the okra and long green chili. Cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Add the kangkong (onchoy) and fish sauce. Stir. Cover and turn the heat off. Let it stay covered for 5 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 11,
      "text": "Serve with warm rice."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 10,
