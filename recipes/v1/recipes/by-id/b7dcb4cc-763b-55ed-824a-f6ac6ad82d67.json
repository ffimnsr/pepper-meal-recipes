  "id": "b7dcb4cc-763b-55ed-824a-f6ac6ad82d67",
  "slug": "cucumber-tomato-salad",
  "name": "Cucumber Tomato Salad",
  "recipe_type": "salad",
  "brief_description": "This cucumber tomato salad is a no-cook side dish made with English cucumbers, tomatoes, red onion, and fresh basil tossed in a red wine vinegar dressing.",
  "cuisine": "American Italian Mediterranean",
  "instructions": [
    {
      "position": 1,
      "text": "Place the sliced cucumbers in a colander. Sprinkle with half of the kosher salt and toss gently. Let them sit for 15 minutes to draw out excess moisture, then pat dry with paper towels."
    },
    {
      "position": 2,
      "text": "In a small bowl, whisk together the olive oil, red wine vinegar, sugar, remaining salt, and black pepper until well blended."
    },
    {
      "position": 3,
      "text": "Transfer the cucumbers to a large mixing bowl. Add the red onion, halved grape tomatoes, and fresh basil. Toss to combine."
    },
    {
      "position": 4,
      "text": "Pour the dressing over the salad and toss gently until everything is evenly coated."
    },
    {
      "position": 5,
      "text": "Cover and refrigerate for 10 minutes before serving to allow the flavors to come together. Give it one final gentle toss, then transfer to a serving dish. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 0,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 15,
  "difficulty": "easy",
