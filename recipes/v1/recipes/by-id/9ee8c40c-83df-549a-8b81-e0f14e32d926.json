  "id": "9ee8c40c-83df-549a-8b81-e0f14e32d926",
  "slug": "baked-garlic-salmon-and-easy-tofu-sisig",
  "name": "Baked Garlic Salmon and Easy Tofu Sisig",
  "recipe_type": "main",
  "brief_description": "Tofu sisig with Mayo and Easy baked salmon for supper. Let&#039;s eat!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Start making the tofu sisig by air frying the tofu for 15 minutes. Set it aside once done."
    },
    {
      "position": 2,
      "text": "Make the dressing by combining all the tofu sisig dressing ingredients in a bowl. Mix well. Set aside."
    },
    {
      "position": 3,
      "text": "Heat 2 tablespoons of butter in a pan. Saute the onion until it softens. Add bell peppers and continue cooking for 1 minute. Add the air fried tofu. Cook for 30 seconds."
    },
    {
      "position": 4,
      "text": "Melt the remaining butter in a metal plate (sizzling plate). Transfer the tofu sisig and top with the dressing. Serve while its sizzling hot."
    },
    {
      "position": 5,
      "text": "Meanwhile, start making the garlic salmon by preheating the oven to 180C (around 356F). Rub salt all over the salmon and arrange on a baking pan."
    },
    {
      "position": 6,
      "text": "Make the topping by combining Lady\u2019s Choice Mayonnaise and lemon juice. Mix well and spread over the salmon fillet."
    },
    {
      "position": 7,
      "text": "Bake the salmon for 12 to 15 minutes. Top with Parmesan cheese and toasted garlic. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
