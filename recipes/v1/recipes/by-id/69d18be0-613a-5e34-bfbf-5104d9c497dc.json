  "id": "69d18be0-613a-5e34-bfbf-5104d9c497dc",
  "slug": "beef-sinigang-sa-kamias-with-gabi-beef-in-sour-broth-with-taro",
  "name": "Beef Sinigang sa Kamias with Gabi (Beef in Sour Broth with Taro)",
  "recipe_type": "soup",
  "brief_description": "sinigang na baka or beef sinigang is a type of Filipino sinigang that makes use of beef. The vegetables are blanched to retain the color and texture",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the 5 cups water and beef broth in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add the tomato, onion, and kamias.Cook for 5 to 8 minutes."
    },
    {
      "position": 3,
      "text": "Add the beef continue to boil in low to medium heat for 45 minutes."
    },
    {
      "position": 4,
      "text": "Put the taro roots in the boiling mixture. Cook for another 45 minutes or until the beef gets tender."
    },
    {
      "position": 5,
      "text": "Meanwhile, boil the remaining 4 cups of water in a second cooking pot."
    },
    {
      "position": 6,
      "text": "Once the water starts to boil, blanch the vegetables for 3 minutes (45 seconds for the spinach). (Blanching means cooking the vegetables in boiling water and then removing these quickly and place in a bowl with cold water.) Drain water and arrange the vegetables in a plate."
    },
    {
      "position": 7,
      "text": "Once the beef gets tender, add the fish sauce and stir. Note: you can add more water if needed."
    },
    {
      "position": 8,
      "text": "Transfer the beef, taro, and soup to individual bowls and arrange blanched vegetables on top."
    },
    {
      "position": 9,
      "text": "Serve warm. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
