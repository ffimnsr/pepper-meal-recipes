  "slug": "chicken-piccata-recipe",
  "name": "Chicken Piccata",
  "recipe_type": null,
  "brief_description": "The name of this dish might sound intimidating in terms of preparation, but it\u2019s not. Chicken Piccata is a good idea to prepare chicken.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine Parmesan cheese and flour in a mixing bowl. Add salt and pepper. Mix well."
    },
    {
      "position": 2,
      "text": "Dredge the flat chicken breast slices in the flour mixture."
    },
    {
      "position": 3,
      "text": "Melt half of the butter in a pan and then pour-in olive oil."
    },
    {
      "position": 4,
      "text": "When the mixture becomes hot, pan-fry the dredged chicken breasts for 3 to 4 minutes per side. Arrange the chicken in individual plates."
    },
    {
      "position": 5,
      "text": "Once all the chicken have been pan-fried, Make the sauce by pouring chicken stock on the same pan. Let boil."
    },
    {
      "position": 6,
      "text": "Add the lemon juice and capers. Stir while trying to scrape the left-over flour in the pan. Add the remaining butter and then cook for 2 minutes. Sprinkle ground black pepper to taste."
    },
    {
      "position": 7,
      "text": "Pour on top of the fried chicken breasts. Garnish with parsley flakes."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 10,
