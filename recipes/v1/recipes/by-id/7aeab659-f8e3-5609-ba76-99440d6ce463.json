  "id": "7aeab659-f8e3-5609-ba76-99440d6ce463",
  "slug": "fried-embutido-recipe",
  "name": "Fried Embutido Recipe",
  "recipe_type": null,
  "brief_description": "Fried Embutido is another way to make your delicious embutido taste better. This recipe is applicable to both pork embutido, chicken embutido, and even turkey embutido. This is one of my favorite ways to enjoy my favorite Filipino Meatloaf.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Crack the eggs in a bowl. Add salt and pepper. Beat until all ingredient are well blended. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 3,
      "text": "While the oil is starting to heat-up, dip the sliced embutido into the beaten egg mixture."
    },
    {
      "position": 4,
      "text": "Arrange the egg-coated embutido in the frying pan."
    },
    {
      "position": 5,
      "text": "Fry in medium heat for 2 to 4 minutes per side. Make sure to turn the embutido over if it starts to turn brown."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with ketchup."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 10,
