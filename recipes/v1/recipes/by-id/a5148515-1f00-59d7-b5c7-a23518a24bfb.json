  "id": "a5148515-1f00-59d7-b5c7-a23518a24bfb",
  "slug": "ginataang-tulingan",
  "name": "Ginataang Tulingan",
  "recipe_type": "main",
  "brief_description": "Bullet tuna with eggplant cooked in coconut milk with bilimbi.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Clean the fish thoroughly. Create a slit on both sides and rub salt all over. Let it stay for 10 to 15 minutes."
    },
    {
      "position": 2,
      "text": "Arrange pork fat, kamias, fish, and ginger. Pour water. Cover and let boil. Continue to cook in medium heat for 40 minutes."
    },
    {
      "position": 3,
      "text": "Pour coconut milk into the pot. Add garlic, onion, and chili. Cover and continue to boil for another 40 minutes using between low to medium heat."
    },
    {
      "position": 4,
      "text": "Add eggplant. Cook for 5 to 7 minutes. Season with patis and ground black pepper."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate and serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 100,
