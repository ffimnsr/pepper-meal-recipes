  "id": "735502b1-5091-5cfc-a026-fd7a88c5157c",
  "slug": "pochero-with-pork-and-beans",
  "name": "Pochero with Pork and Beans",
  "recipe_type": "main",
  "brief_description": "Pork belly stewed with chorizo, vegetables, saba banana, and beans.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saute onion, garlic, and tomato."
    },
    {
      "position": 2,
      "text": "Add pork once the onion softens. Saute until the color turns light brown."
    },
    {
      "position": 3,
      "text": "Add Knorr Pork Cube. Stir and then add chorizo. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour water. Let boil. Cover the pot and adjust heat between low to medium. Cook for 45 to 60 minutes or until pork gets tender. Note: add more water as needed."
    },
    {
      "position": 5,
      "text": "Put potato and saba banana into the pot. Cover and continue to boil for 5 minutes."
    },
    {
      "position": 6,
      "text": "Pour pork and beans into the pot. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add long green beans, cabbage, and pechay. Cook for 2 to 3 minutes."
    },
    {
      "position": 8,
      "text": "Season with patis and ground black pepper."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 80,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
