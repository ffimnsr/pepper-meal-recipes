  "id": "b64b2c46-6216-5d9e-8d89-6f31a70ff7dc",
  "slug": "filipino-style-spaghetti-recipe-knr-bc",
  "name": "Filipino Style Spaghetti Recipe",
  "recipe_type": "dessert",
  "brief_description": "Filipino Style Spaghetti is a spag version with a sweet and tasty sauce. Ground pork is used as the main component of the sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook Spaghetti according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Start to make the sauce by heating oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Saute onion for 30 seconds."
    },
    {
      "position": 4,
      "text": "Add garlic. Continue to cook until onion softens."
    },
    {
      "position": 5,
      "text": "Put the ground pork into the cooking pot. Continue to cook until it turns light brown."
    },
    {
      "position": 6,
      "text": "Add luncheon meat and hot dogs. Cook for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Pour Filipino style spaghetti sauce and water. Stir. Let boil."
    },
    {
      "position": 8,
      "text": "Add Knorr beef cube. Stir. Cover and cook in medium heat for 30 minutes."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 10,
      "text": "Top sauce over cooked spaghetti. Sprinkle shredded cheese on top."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
