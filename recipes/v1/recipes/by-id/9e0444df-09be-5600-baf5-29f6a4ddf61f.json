  "slug": "ginisang-pechay-with-ground-pork-and-shrimp-bok-choy",
  "name": "Ginisang Pechay with Ground Pork and Shrimp (Sauteed Bok Choy)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginisang Pechay with Ground Pork and Shrimp or Sauteed Bok Choy",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "When the oil is hot, saute garlic, onion, and tomato."
    },
    {
      "position": 3,
      "text": "Add ground pork. Cook until brown"
    },
    {
      "position": 4,
      "text": "Add shrimp and bok choy. Stir-fry for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in chicken broth (or water). Let boil. Cover and simmer for 2 to 3 minutes."
    },
    {
      "position": 6,
      "text": "Add fish sauce and ground black pepper."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
