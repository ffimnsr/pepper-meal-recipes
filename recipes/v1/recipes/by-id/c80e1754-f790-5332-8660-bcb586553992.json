  "id": "c80e1754-f790-5332-8660-bcb586553992",
  "slug": "chicken-binakol-recipe",
  "name": "Chicken Binakol",
  "recipe_type": "soup",
  "brief_description": "Chicken Binakol is a savory Filipino stew where chicken is cooked in a coconut-based broth with fresh vegetables and sometimes herbs. Its slightly sweet flavor from the coconut makes it a deliciously comforting dish.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a large cooking pot. Saut\u00e9 the garlic, onion, and ginger until the onion softens."
    },
    {
      "position": 2,
      "text": "Add the chicken and 3 tablespoons of fish sauce (note: you can add more fish sauce later as needed). Continue saut\u00e9ing until the chicken turns light brown in color (around 3 to 4 minutes)."
    },
    {
      "position": 3,
      "text": "Pour in the juice of the young coconut (buko juice), and then add the coconut meat. Let it boil."
    },
    {
      "position": 4,
      "text": "Add the green papaya and lemongrass. Cover and simmer for 20 to 30 minutes. (Note: you can also add water as needed.)"
    },
    {
      "position": 5,
      "text": "Put the long green peppers in the pot and season with ground black pepper. Continue cooking for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add the Maggi Magic Chicken Cube. Stir and turn off the heat."
    },
    {
      "position": 7,
      "text": "Add the hot pepper leaves and malunggay leaves. Stir and let the residual heat cook them for 2 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve hot. Share and enjoy!"
    }
  ],
  "servings": 10,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
