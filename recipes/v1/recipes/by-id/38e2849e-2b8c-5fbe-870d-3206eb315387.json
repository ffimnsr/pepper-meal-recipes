  "slug": "stir-fried-chicken-franks",
  "name": "Stir Fried Chicken Franks",
  "recipe_type": "appetizer",
  "brief_description": "Easy chicken frank stir fry",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saut\u00e9 garlic and onion until the onion softens."
    },
    {
      "position": 2,
      "text": "Add CDO Franks. Saut\u00e9 for 1 minute."
    },
    {
      "position": 3,
      "text": "Add ketchup and oyster sauce. Stir and cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 10,
