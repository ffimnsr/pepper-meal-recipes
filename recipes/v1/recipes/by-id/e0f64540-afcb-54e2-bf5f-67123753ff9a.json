  "id": "e0f64540-afcb-54e2-bf5f-67123753ff9a",
  "slug": "melon-cantaloupe-juice",
  "name": "Melon Juice",
  "recipe_type": "drink",
  "brief_description": "Melon Juice or Cantaloupe Juice is a simple and refreshing drink that you can prepare not only during summer time, but the whole year round",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Slice the cantaloupe into half. Remove all the seeds."
    },
    {
      "position": 2,
      "text": "Using a melon baller or special cantaloupe scraper (I got mine from the Philippines), scrape the cantaloupe and place in a large bowl. Set aside."
    },
    {
      "position": 3,
      "text": "In a large pitcher, combine water, sugar, and vanilla extract. Stir until the sugar is diluted. Add the shredded cantaloupe. Stir again."
    },
    {
      "position": 4,
      "text": "Put lots of ice. Serve."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 15,
