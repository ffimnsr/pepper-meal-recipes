  "id": "204c74b7-5814-579b-a04f-7e6bbbcec7cb",
  "slug": "jollibee-style-spaghetti-recipe",
  "name": "Jollibee Style Spaghetti",
  "recipe_type": null,
  "brief_description": "A sweet and savory Filipino-style spaghetti with a rich meat sauce made from ground pork, ham, and hotdogs, finished with grated cheese. This homemade version recreates the iconic Jollibee flavor.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the spaghetti pasta according to the package instructions. Drain and set aside."
    },
    {
      "position": 2,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Saute the garlic and onion."
    },
    {
      "position": 4,
      "text": "Add the ham. Cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the ground pork. Cook for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the tomato sauce and beef broth. Stir and let boil. Simmer for 60 minutes."
    },
    {
      "position": 7,
      "text": "Add the hotdogs and tomato paste. Stir and cook for 10 minutes or until the sauce thickens."
    },
    {
      "position": 8,
      "text": "Put-in the sugar, salt, and pepper. Stir until the ingredients are well incorporated."
    },
    {
      "position": 9,
      "text": "Arrange the spaghetti pasta in an individual plate. Pour the meat sauce over the pasta and top with cheese."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
