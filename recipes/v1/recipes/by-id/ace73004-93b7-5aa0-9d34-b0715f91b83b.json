  "slug": "marinated-grilled-shrimp",
  "name": "Marinated Grilled Shrimp",
  "recipe_type": null,
  "brief_description": "Marinated Grilled Shrimp Recipe. Get to know the exact details of this sumptuous recipe here.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Stir-in garlic, 7-up, and oil in a bowl. Add basil, cayenne pepper, and garlic salt. Stir well"
    },
    {
      "position": 2,
      "text": "Throw shrimps in to the bowl, and stir until evenly coated. Cover, put inside the refrigerator or cooler for 1 hour."
    },
    {
      "position": 3,
      "text": "Preheat grill.Arrange shrimps on a skewer."
    },
    {
      "position": 4,
      "text": "Start to grill each side until orange (2 to 4 minutes depending on the size)."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 8,
