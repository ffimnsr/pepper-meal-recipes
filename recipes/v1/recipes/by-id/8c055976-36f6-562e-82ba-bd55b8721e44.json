  "id": "8c055976-36f6-562e-82ba-bd55b8721e44",
  "slug": "mayo-brownies",
  "name": "Mayo Brownies",
  "recipe_type": "dessert",
  "brief_description": "Moist brownies with Lady's Choice Mayonnaise.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350F."
    },
    {
      "position": 2,
      "text": "Prepare the dry ingredients by sifting flour and cocoa powder in a mixing bowl. Add baking powder and sugar. Mix well using a wire whisk. Set aside."
    },
    {
      "position": 3,
      "text": "On a separate bowl, crack eggs. Beat the eggs."
    },
    {
      "position": 4,
      "text": "Add Lady's Choice Mayonnaise. Mix well until all the ingredients in the bowl are well blended. Add vanilla extract and gradually add-in sugar. Continue to mix until texture becomes smooth."
    },
    {
      "position": 5,
      "text": "Melt the chocolate chips using a double boiler (watch video below for details).Stir-in the melted chocolate with the mayonnaise mixture. Mix well."
    },
    {
      "position": 6,
      "text": "Gradually add the dry ingredients with the mayonnaise mixture. Fold until smooth. Add chopped walnuts."
    },
    {
      "position": 7,
      "text": "Pour the brownie mixture into an 8x8 baking pan. Bake for 20 to 25 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven. Let the brownies cool down."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
