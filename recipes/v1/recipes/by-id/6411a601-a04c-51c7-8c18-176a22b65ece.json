  "slug": "sauteed-brussel-sprouts-with-bacon-recipe",
  "name": "Sauteed Brussels Sprouts with Bacon Recipe",
  "recipe_type": "side",
  "brief_description": "Crispy bacon and tender Brussels sprouts saut\u00e9ed with onions for a savory, easy-to-make side dish perfect for weeknight dinners.",
  "cuisine": "american",
  "instructions": [
    {
      "position": 1,
      "text": "Heat olive oil in a pan."
    },
    {
      "position": 2,
      "text": "Put-in bacon and cook until the texture becomes crisp."
    },
    {
      "position": 3,
      "text": "Add onions and Brussels sprouts and saute for 4 to 8 minutes."
    },
    {
      "position": 4,
      "text": "Sprinkle some salt and pepper to taste."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
