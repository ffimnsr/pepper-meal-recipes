  "id": "777d6eaf-be18-534d-826e-4b9413c3277e",
  "slug": "pinangat-na-galunggong-sa-kamias",
  "name": "Pinangat na Galunggong sa Kamias",
  "recipe_type": "main",
  "brief_description": "This is a simple round scad dish, wherein the fish is stewed with bilimbi along with onion, ginger, and pepper.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the fish. Let it stay for 5 minutes."
    },
    {
      "position": 2,
      "text": "Distribute the pork fat in a cooking pot. Add kamias, onion, tomato, ginger, and long green pepper."
    },
    {
      "position": 3,
      "text": "Arrange the fish over the ingredients and season with ground black pepper."
    },
    {
      "position": 4,
      "text": "Pour water into the pot. Cover it and turn the stove on. Let the water boil. Adjust heat to low. Continue cooking for 15 minutes."
    },
    {
      "position": 5,
      "text": "Adjust the seasoning by adding salt if needed. Continue cooking without covering the pot until the sauce reduces to half."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with warm rice. Share and enjoy!"
    }
  ],
  "servings": 4,
