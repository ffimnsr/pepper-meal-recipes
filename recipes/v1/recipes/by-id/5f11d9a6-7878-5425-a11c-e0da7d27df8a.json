  "id": "5f11d9a6-7878-5425-a11c-e0da7d27df8a",
  "slug": "easy-kalderetang-kambing-goat-stew",
  "name": "Kalderetang Kambing (Goat Stew)",
  "recipe_type": null,
  "brief_description": "Kalderetang Kambing is the Filipino version of Goat Stew. This delicious dish is prepared using chevon (goat meat), tomato sauce, some vegetables, and liver spread. The use of liver spread makes kaldereta different from other tomato based stews.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Soak the goat meat in buttermilk overnight. Wash the goat meat thoroughly with running water before cooking. Make to drain all the liquid."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan or pressure cooker."
    },
    {
      "position": 3,
      "text": "Saute the onion and garlic."
    },
    {
      "position": 4,
      "text": "Add the goat meat. Cook until the color turns light brown."
    },
    {
      "position": 5,
      "text": "Add the tomato sauce, beef powder, liver spread, and water. Stir and let boil."
    },
    {
      "position": 6,
      "text": "If you are using a pressure cooker, cover and pressure cook for 20 to 25 minutes. Otherwise, cover and simmer for 1 to 1 1/2 hours."
    },
    {
      "position": 7,
      "text": "Add the bell pepper, potato, and carrot. Stir and cook for 10 minutes."
    },
    {
      "position": 8,
      "text": "Sprinkle some salt and pepper to taste."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
