  "id": "877151fe-aff1-5f1c-a8e7-d2b10c1bc38b",
  "slug": "sinigang-na-bangus-sa-bayabas",
  "name": "Sinigang na Bangus sa Bayabas",
  "recipe_type": "soup",
  "brief_description": "Sinigang na Bangus sa Bayabas is a version of sinigang that makes use of ripe guava as the souring agent. Sinigang is a Filipino sour soup dish that commonly uses unripe tamarind or bilimbi to make the sour sour.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Put-in the guava, tomato, onion, and whole peppercorn. Let it boil. Continue to boil (covered) for 15 minutes or until the guava and vegetables are soft. You may add more water if needed."
    },
    {
      "position": 3,
      "text": "Using a fork of potato masher, mash the guava and vegetables inside the cooking pot to extract the flavors. This is an optional step, be extra careful."
    },
    {
      "position": 4,
      "text": "Pour-in the fish sauce. Stir."
    },
    {
      "position": 5,
      "text": "Add the milk fish. Cook for 5 to 10 minutes in medium heat."
    },
    {
      "position": 6,
      "text": "Add the okra and Jalapeno. Continue to cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the spinach. Cover the cooking pot. Turn the heat off. Let the spinach stay in the pot for 5 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 15,
