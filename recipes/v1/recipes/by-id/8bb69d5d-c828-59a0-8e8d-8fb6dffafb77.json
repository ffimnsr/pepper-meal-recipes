  "id": "8bb69d5d-c828-59a0-8e8d-8fb6dffafb77",
  "slug": "chicken-wings-inasal-recipe",
  "name": "Chicken Wings Inasal Recipe",
  "recipe_type": null,
  "brief_description": "Chicken Wings Inasal is the Filipino version of chicken wings wherein it is marinated in a vinegar concoction and grilled to perfection. This delicious chicken wings recipe takes time and patience to prepare, but the outcome is something to anticipate.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the ground black pepper, Cayenne pepper, ginger, garlic, sugar, vinegar, 7-up, turmeric, and lemon juice in a large bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Add-in the chicken wings. Cover the bowl with a cling wrap. Marinate the chicken for 5 to 8 hours."
    },
    {
      "position": 3,
      "text": "Skewer the chicken wings in a bamboo skewer."
    },
    {
      "position": 4,
      "text": "In a small bowl, combine the margarine, annatto powder, lemon, and salt. Stir and set aside."
    },
    {
      "position": 5,
      "text": "Heat-up the grill. Start to grill the chicken while basting using margarine mixture. Grill the wings for 6 to 8 minutes per side."
    },
    {
      "position": 6,
      "text": "Transfer the grilled chicken wings to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 300,
