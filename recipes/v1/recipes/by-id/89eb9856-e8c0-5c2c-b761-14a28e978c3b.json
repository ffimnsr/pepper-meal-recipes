  "slug": "sausage-and-egg-casserole-with-hash-brown-recipe",
  "name": "Sausage and Egg Casserole with Hash Browns Recipe",
  "recipe_type": "breakfast",
  "brief_description": "Sausage and Egg Casserole with Hash Browns is perfect as a heavy breakfast. It is delicious and will provide you with all the energy that you need to start-up your day.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the sausage in a pan until it turns light to medium brown. Drain the liquid and oil. Set aside."
    },
    {
      "position": 2,
      "text": "Beat the eggs in a mixing bowl."
    },
    {
      "position": 3,
      "text": "Stir-in the milk, cheese, salt, and pepper. Mix well."
    },
    {
      "position": 4,
      "text": "Add the cooked sausage and hash browns. Stir to distribute the ingredients evenly."
    },
    {
      "position": 5,
      "text": "Pour the mixture in a baking dish."
    },
    {
      "position": 6,
      "text": "Preheat the oven to 350F"
    },
    {
      "position": 7,
      "text": "Bake for 40 to 45 minutes."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
