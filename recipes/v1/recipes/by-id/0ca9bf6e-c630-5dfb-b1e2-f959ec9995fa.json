  "id": "0ca9bf6e-c630-5dfb-b1e2-f959ec9995fa",
  "slug": "how-to-make-garlic-bihon",
  "name": "Garlic Bihon Recipe",
  "recipe_type": "main",
  "brief_description": "Easy pancit bihon with lots of garlic.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a cooking pot. Let boil. Add chicken. Boil for 35 minutes."
    },
    {
      "position": 2,
      "text": "Remove chicken from the pot. Let it cool down. Shred the chicken (separate meat from bones). Set the shredded meat aside."
    },
    {
      "position": 3,
      "text": "Add annatto seeds into the pot with chicken stock. Cover the pot, boil for 5 minutes. Set aside."
    },
    {
      "position": 4,
      "text": "Heat oil on a wide pan. Add garlic. Cook until the garlic turns golden brown in color."
    },
    {
      "position": 5,
      "text": "Remove half of the garlic from the pan. Set it aside."
    },
    {
      "position": 6,
      "text": "Continue cooking using the remaining garlic. Add onion and celery into the pan. Saut\u00e9 until the onion softens."
    },
    {
      "position": 7,
      "text": "Add shredded chicken. Saut\u00e9 for 1 minute."
    },
    {
      "position": 8,
      "text": "Pour the chicken stock into the pot while filtering the annatto seeds using a strainer or kitchen sieve. Let boil."
    },
    {
      "position": 9,
      "text": "Add Knorr Chicken Cube. Stir."
    },
    {
      "position": 10,
      "text": "Add carrot and half of the total green onions. Cook for 2 minutes."
    },
    {
      "position": 11,
      "text": "Add bihon noodles. Cover the pan. Cook for 2 to 3 minutes. Toss noodles and continue to cook until liquid gets totally absorbed."
    },
    {
      "position": 12,
      "text": "Season with ground black pepper and fish sauce (patis). Toss. Adjust heat to low. Cover the pan and cook for 1 \u00bd minutes."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 5,
