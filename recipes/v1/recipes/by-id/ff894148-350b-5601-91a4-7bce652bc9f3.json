  "id": "ff894148-350b-5601-91a4-7bce652bc9f3",
  "slug": "pork-bola-bola-soup-with-misua-and-patola",
  "name": "Pork Bola Bola Soup with Misua and Patola",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Pork Bola Bola Soup with Misua and Patola.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the meatballs by combining all meatball ingredients in a bowl. Mix well. Scoop 1 1/2 tablespoons of the mixture and form into a ball. Perform this step until the mixture is completely consumed. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot. Once the oil becomes hot, pan fry the meatballs until the outer part turns light brown. Note: the meatballs do not need to be cooked completely at this point."
    },
    {
      "position": 3,
      "text": "Remove the meatballs from the pot. Set aside."
    },
    {
      "position": 4,
      "text": "Using the remaining oil, saute garlic until golden brown. Add onion. Continue to cook until the onion softens."
    },
    {
      "position": 5,
      "text": "Pour water. Let boil. Add the pan-fried meatballs back."
    },
    {
      "position": 6,
      "text": "Add Knorr Pork Cube. Stir. Cover the pot and cook in medium heat for 15 minutes."
    },
    {
      "position": 7,
      "text": "Add misua and patola. Cover and cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Season with patis and ground black pepper. Stir."
    },
    {
      "position": 9,
      "text": "Add scallions. Transfer to a serving bowl."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
