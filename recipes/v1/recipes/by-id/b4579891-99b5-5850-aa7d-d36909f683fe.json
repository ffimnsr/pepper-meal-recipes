  "id": "b4579891-99b5-5850-aa7d-d36909f683fe",
  "slug": "hamonadong-baboy",
  "name": "Hamonadong Baboy",
  "recipe_type": "drink",
  "brief_description": "Marinated Pork Ham Hock stewed in pineapple juice and soy sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pineapple juice and soy sauce. Stir. Place the ham hock in a large resealable bag and then pour the mixture into it. Let the air out of the bag and seal. Place inside the refrigerator. Marinate overnight."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Saut\u00e9 onion and garlic."
    },
    {
      "position": 3,
      "text": "Add marinated pork once the onion softens and the garlic starts to brown. Cook one side for one minute. Turn it over and continue to cook for another minute."
    },
    {
      "position": 4,
      "text": "Pour remaining marinade into the pan. Add water. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork Cube. Stir. Cover the pan. Cook between low to medium heat for 1 hour."
    },
    {
      "position": 6,
      "text": "Turn the ham hock over. Continue to cook in a covered pan for another hour."
    },
    {
      "position": 7,
      "text": "Add brown sugar and pineapple slices."
    },
    {
      "position": 8,
      "text": "Cover and continue to cook for 15 minutes."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper. Cook until the sauce reduces to half."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 160,
