  "slug": "ginisang-sayote-recipe",
  "name": "Ginisang Sayote Recipe",
  "recipe_type": null,
  "brief_description": "Ginisang Sayote or Sauteed Chayote is a simple vegetable recipe that you can easily prepare for lunch or dinner. Making this dish does not cost much",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic, onion, and tomato"
    },
    {
      "position": 3,
      "text": "When the tomato becomes soft, add the ground pork and then cook for 6 to 8 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the chayote. Stir."
    },
    {
      "position": 5,
      "text": "Cover. Let boil and simmer for 7 to 10 minutes."
    },
    {
      "position": 6,
      "text": "Add salt and ground black pepper. Stir."
    },
    {
      "position": 7,
      "text": "Serve with hot rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
