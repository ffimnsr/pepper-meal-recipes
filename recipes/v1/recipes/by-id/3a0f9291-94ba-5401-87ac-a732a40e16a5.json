  "id": "3a0f9291-94ba-5401-87ac-a732a40e16a5",
  "slug": "how-to-cook-embutido-knr-kls",
  "name": "Embutido Recipe",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Noche Buena Pork Embutido.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine all the ingredients except for the water. Mix altogether until well blended."
    },
    {
      "position": 2,
      "text": "Wrap the mixture using aluminum foil. Cut a piece of aluminum foil to 12x8 inches. Lay it flat on a table. The shiny part of the foil should face down. Scoop 1 cup of mixture and place it on the middle top part of the foil. Mold into a cylinder. Roll the foil from top to bottom. Secure both ends of the foil. Perform this step until the mixture is consumed."
    },
    {
      "position": 3,
      "text": "Boil water in a pot. Arrange the wrapped embutido in a steamer. Steam for 1 hour."
    },
    {
      "position": 4,
      "text": "Remove from the steamer. Let it cool down. Refrigerate for at least 3 hours. Slice into serving pieces."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Share and enjoy!"
    }
  ],
  "servings": 10,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
