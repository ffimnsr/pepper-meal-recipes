  "id": "091e843d-5a7c-5111-b54b-5a8173a137c1",
  "slug": "shepherds-pie",
  "name": "Shepherds Pie",
  "recipe_type": "soup",
  "brief_description": "Ground beef cooked with vegetables and broth, topped with mashed potatoes and baked. A complete and filling main dish.",
  "cuisine": "British",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and melt the butter."
    },
    {
      "position": 2,
      "text": "Put-in the onion when the butter melts, and then cook until the onion becomes soft."
    },
    {
      "position": 3,
      "text": "Add the ground beef and cook until brown (about 5 to 10 minutes)"
    },
    {
      "position": 4,
      "text": "Put-in the Worcestershire sauce, salt, ground black pepper, and beef broth. Stir and simmer for 12 minutes."
    },
    {
      "position": 5,
      "text": "Add the mix vegetables. Stir and cook for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Turn-off heat and let it cool."
    },
    {
      "position": 7,
      "text": "Preheat oven to 375 degrees Fahrenheit."
    },
    {
      "position": 8,
      "text": "Transfer the cooked mixture to a baking tray."
    },
    {
      "position": 9,
      "text": "Arrange the mashed potato over the cooked mixture, and then bake for 25 to 30 minutes."
    },
    {
      "position": 10,
      "text": "Remove from the oven and serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
