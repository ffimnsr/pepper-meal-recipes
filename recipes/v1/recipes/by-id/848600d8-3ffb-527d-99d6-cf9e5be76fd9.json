  "id": "848600d8-3ffb-527d-99d6-cf9e5be76fd9",
  "slug": "creamy-sipo-egg-with-chicken-gizzard",
  "name": "Creamy Sipo Egg with Chicken Gizzard",
  "recipe_type": "main",
  "brief_description": "Creamy chicken gizzard with quail eggs, carrot, green peas, and corn.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 2 cups of water in a cooking pot. Add the quail eggs. Boil for 2 minutes. Let it cool down and peel off the shell. Set aside."
    },
    {
      "position": 2,
      "text": "Boil 5 cups of water in a cooking pot. Add the chicken gizzard. Cover and then continue boiling using low heat for 45 minutes or until the gizzard becomes tender. Drain the water and set the gizzards aside."
    },
    {
      "position": 3,
      "text": "Melt butter in a pan. Add cooking oil."
    },
    {
      "position": 4,
      "text": "Saut\u00e9 garlic and onion until the onion softens and the garlic browns a bit."
    },
    {
      "position": 5,
      "text": "Add the boiled chicken gizzard. Saut\u00e9 for 2 minutes."
    },
    {
      "position": 6,
      "text": "Combine Knorr Cream of Mushroom Soup with 3 cups of water. Stir. Pour the mixture into the pan. Let it boil."
    },
    {
      "position": 7,
      "text": "Add carrot, corn, jicama, and green peas. Cook uncovered for 2 minutes in a low to medium heat setting."
    },
    {
      "position": 8,
      "text": "Add all-purpose cream and boiled quail eggs."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve warm with rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
