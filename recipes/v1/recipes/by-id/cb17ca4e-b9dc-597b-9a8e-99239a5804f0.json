  "id": "cb17ca4e-b9dc-597b-9a8e-99239a5804f0",
  "slug": "lechon-pata-recipe",
  "name": "Lechon Pata Recipe",
  "recipe_type": null,
  "brief_description": "If you are one of those people who want to make lechon the easy way, then maybe you can start with this Lechon Pata Recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the leg in a large cooking pot. Pour-in water."
    },
    {
      "position": 2,
      "text": "Add the bay leaves, lemongrass, onion, garlic, salt, and whole peppercorn."
    },
    {
      "position": 3,
      "text": "Turn the heat on and bring to a boil. Cover and simmer until the leg is tender (60 to 90 minutes)."
    },
    {
      "position": 4,
      "text": "Remove the pork from the cooking pot. Let is cool down and dry (around 30 to 45 minutes minutes)."
    },
    {
      "position": 5,
      "text": "Preheat the oven to 475F."
    },
    {
      "position": 6,
      "text": "Place the pata (pig leg) in a greased baking tray. Roast/bake in the oven for 45 minutes."
    },
    {
      "position": 7,
      "text": "Remove from the oven. Brush the entire leg with fresh milk."
    },
    {
      "position": 8,
      "text": "Put it back in the oven and continue to roast for 60 to 90 minutes, or until it reaches the desired brown color and crisp texture. You can also broil it for 10 to 15 minutes to make it more crispy."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve with lechon sauce."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 180,
  "preparation_time_minutes": 10,
