  "id": "4a160a0e-f66d-58b3-909a-f5492ca99311",
  "slug": "easy-clam-chowder-recipe",
  "name": "Easy Clam Chowder Recipe",
  "recipe_type": "soup",
  "brief_description": "This is an easy recipe for clam chowder using half and half.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a cooking pot."
    },
    {
      "position": 2,
      "text": "Add onions and celery. Cook for 2 minutes, or until the vegetables soften"
    },
    {
      "position": 3,
      "text": "Drain the juice from the clam and pour in along with the extra clam juice. Let boil."
    },
    {
      "position": 4,
      "text": "Put-in potatoes and thyme. Cook for 12 to 15 minutes or until potatoes are tender"
    },
    {
      "position": 5,
      "text": "Combine half and half and flour. Mix well and pour the mixture in the cooking pot while stirring continuously. Cook until desired thickness is achieved."
    },
    {
      "position": 6,
      "text": "Put-in chopped clams and cook for 3 to 5 minutes more."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl and garnish with crumbled bacon."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
