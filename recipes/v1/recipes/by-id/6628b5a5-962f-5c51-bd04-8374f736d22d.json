  "id": "6628b5a5-962f-5c51-bd04-8374f736d22d",
  "slug": "shrimp-and-broccoli-stir-fry",
  "name": "Shrimp and Broccoli Stir Fry",
  "recipe_type": "main",
  "brief_description": "Quick and easy seafood stir fry with tender shrimp, crisp broccoli, and savory oyster sauce. Ready in under 30 minutes.",
  "cuisine": "Asian Chinese seafood",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all sauce ingredients (5 tablespoons water, soy sauce, oyster sauce, and sugar) in a bowl. Mix well and set aside."
    },
    {
      "position": 2,
      "text": "Bring 1 quart of water to a boil in a cooking pot. Add 1 1/2 teaspoons salt and the broccoli florets. Boil for 1 minute."
    },
    {
      "position": 3,
      "text": "Add broccoli stalks and sliced carrots. Continue boiling for 1 more minute."
    },
    {
      "position": 4,
      "text": "Remove vegetables from pot and immediately soak in ice-cold water for 3 minutes. Drain and set aside."
    },
    {
      "position": 5,
      "text": "Heat 3 tablespoons cooking oil in a wok or large pan over medium-high heat. Saut\u00e9 the minced garlic until it turns light brown, about 30 seconds."
    },
    {
      "position": 6,
      "text": "Add the shrimp. Stir-fry until they turn pink and opaque, about 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Pour in the Shaoxing cooking wine. Continue saut\u00e9ing until the liquid evaporates completely, about 1 minute."
    },
    {
      "position": 8,
      "text": "Add the blanched vegetables. Stir-fry for 1 minute to heat through."
    },
    {
      "position": 9,
      "text": "Pour in the sauce mixture and stir to combine. Let it bubble for 30 seconds."
    },
    {
      "position": 10,
      "text": "Season with 1/4 teaspoon ground white pepper."
    },
    {
      "position": 11,
      "text": "Drizzle with 1 1/2 teaspoons sesame oil and give everything a toss."
    },
    {
      "position": 12,
      "text": "Combine slurry ingredients (cornstarch and 1/4 cup water) and mix well. Pour into the wok and stir immediately. Continue cooking until the sauce thickens, about 1 minute."
    },
    {
      "position": 13,
      "text": "Transfer to a serving plate. Serve hot with steamed rice."
    }
  ],
  "servings": 4,
