  "id": "2997a56b-abb4-5319-aaf2-05269d45927c",
  "slug": "filipino-style-spaghetti",
  "name": "Filipino Style Spaghetti",
  "recipe_type": "main",
  "brief_description": "A sweet version of spaghetti with hotdogs and ground meat.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the Spaghetti noodles according to package instructions. Once cooked, transfer to a bowl. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the oil in a Pan."
    },
    {
      "position": 3,
      "text": "Saute the onion and garlic."
    },
    {
      "position": 4,
      "text": "Once the onions becomes soft, add the ground pork. Cook until the color turns light brown."
    },
    {
      "position": 5,
      "text": "Add the luncheon meat and hotdog. Stir and cook for 2 to 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the Spaghetti sauce and beef broth. Stir and let boil. Cover and simmer for 30 minutes."
    },
    {
      "position": 7,
      "text": "Try to taste the sauce and add salt and pepper if needed."
    },
    {
      "position": 8,
      "text": "Pour the Filipino Style Spaghetti sauce over the Spaghetti. Top with shredded cheese."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
