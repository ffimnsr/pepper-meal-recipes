  "id": "56c6c588-4adb-5e63-979e-5996e308c9b0",
  "slug": "simple-orange-chicken-tenders",
  "name": "Simple Orange Chicken Tenders",
  "recipe_type": null,
  "brief_description": "A quick and easy chicken dish featuring crispy fried chicken tenders tossed in a sweet and savory orange sauce. Ready in just 25 minutes, this dish is a hit with both children and adults.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil is hot, add the chicken tenders. Deep fry until golden brown and crispy. Work in batches to avoid overcrowding the pot."
    },
    {
      "position": 3,
      "text": "Remove the chicken from the cooking pot and place on a plate lined with paper towels. Let rest for 10 minutes to allow excess oil to drain."
    },
    {
      "position": 4,
      "text": "Put the chicken in a large bowl. Pour in the orange sauce. Toss until evenly coated."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate and top with scallions."
    },
    {
      "position": 6,
      "text": "Serve immediately."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
