  "id": "8bc3cb18-b04a-5a2e-9dc5-6b69b472a015",
  "slug": "spicy-dilis-recipe",
  "name": "Spicy Dilis",
  "recipe_type": "appetizer",
  "brief_description": "This is a recipe for spicy dilis. It is a sweet and spicy anchovy appetizer.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour-in cooking oil."
    },
    {
      "position": 2,
      "text": "When the oil becomes hot, deep-fry the dried anchovies for 2 to 3 minutes or until the color turns light brown."
    },
    {
      "position": 3,
      "text": "Turn-off heat and remove the fried anchovies from the cooking pot. Set aside."
    },
    {
      "position": 4,
      "text": "Combine fried anchovies, ketchup, and hot chili sauce then mix well."
    },
    {
      "position": 5,
      "text": "Add brown sugar and mix until all the anchovies are coated."
    },
    {
      "position": 6,
      "text": "Heat the same cooking pot with the remaining cooking oil and fry the coated anchovies for 2 minutes or until the texture becomes crunchy but not burnt."
    },
    {
      "position": 7,
      "text": "Remove the anchovies and transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 10,
