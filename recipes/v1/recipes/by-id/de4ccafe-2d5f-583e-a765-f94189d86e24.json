  "id": "de4ccafe-2d5f-583e-a765-f94189d86e24",
  "slug": "inihaw-na-bangus-recipe",
  "name": "Inihaw na Bangus Recipe (Grilled Milkfish)",
  "recipe_type": "main",
  "brief_description": "Milkfish stuffed with tomato and onions and grilled to perfection. This dish is best when served with a dipping sauce composed of soy sauce and lemon or calamansi. Enjoy it with warm white rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Wash the milk fish. Pat it dry using a paper towel."
    },
    {
      "position": 2,
      "text": "Open the incision and then rub the salt on the inside of the dish. The fish should have an incision either above or below the belly area."
    },
    {
      "position": 3,
      "text": "Meanwhile, combine tomato, onion, and ginger in a large bowl. Squeeze some lemon juice in and add the ground black pepper. Gently stir."
    },
    {
      "position": 4,
      "text": "Stuff the mixture inside the milkfish."
    },
    {
      "position": 5,
      "text": "Grill the fish in medium heat for about 10 to 12 minutes per side."
    },
    {
      "position": 6,
      "text": "Serve with toyomansi and steamed rice."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
