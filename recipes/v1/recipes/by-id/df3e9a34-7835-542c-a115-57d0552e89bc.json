  "slug": "kalabasa-soup-ampalaya-leaves",
  "name": "Kalabasa Soup with Ampalaya Leaves",
  "recipe_type": "soup",
  "brief_description": "It is the time of year wherein pumpkin gets a lot of attention. This time, we will not make the traditional pumpkin soup. Instead, I will show you how to cook a very simple soup using butternut squash with a Filipino twist -- I call this Kalabasa Soup with Ampalaya Leaves.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken broth and water in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the onion and butternut squash. Boil for 20 minutes."
    },
    {
      "position": 3,
      "text": "Put-in the garlic powder. Stir"
    },
    {
      "position": 4,
      "text": "Put-in the ampalaya leaves. Cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add salt to taste. Serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 30,
