  "id": "5a9441e1-92d8-54df-82fa-10f54b693225",
  "slug": "paksiw-na-salmon-sa-gata",
  "name": "Paksiw na Salmon sa Gata",
  "recipe_type": null,
  "brief_description": "A classic Filipino sour stew featuring salmon heads simmered in coconut cream and vinegar with ginger, chili, and bitter melon leaves.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine salmon heads, ginger, garlic, onion, chili, vinegar, and water in a pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add long green chili peppers. Cover and cook over medium heat for 5 minutes."
    },
    {
      "position": 3,
      "text": "Pour in the coconut cream and stir. Let the mixture come back to a boil. Cover and cook for 15 minutes."
    },
    {
      "position": 4,
      "text": "Add the ampalaya leaves and stir."
    },
    {
      "position": 5,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate and serve."
    },
    {
      "position": 7,
      "text": "Serve hot with steamed rice, if desired. Enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
