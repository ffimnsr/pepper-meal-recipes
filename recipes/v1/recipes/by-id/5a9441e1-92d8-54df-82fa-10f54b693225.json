  "id": "5a9441e1-92d8-54df-82fa-10f54b693225",
  "slug": "paksiw-na-salmon-sa-gata",
  "name": "Paksiw na Salmon sa Gata",
  "recipe_type": null,
  "brief_description": "This is a recipe for Paksiw na Salmon sa Gata.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine salmon, ginger, garlic, onion, chili, vinegar, and water. Let boil."
    },
    {
      "position": 2,
      "text": "Add long green pepper. Cover and continue to cook in medium heat for 5 minutes."
    },
    {
      "position": 3,
      "text": "Pour-in coconut cream. Stir. Allow the mixture to re-boil. Cover and cook for 15 minutes."
    },
    {
      "position": 4,
      "text": "Add bitter melon leaves. Stir."
    },
    {
      "position": 5,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 35,
