  "id": "446ddde2-465a-5486-87f3-80bee29aa317",
  "slug": "baked-tahong",
  "name": "Baked Tahong Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Baked Tahong or Baked Mussels with garlic and cheese is a well loved appetizer seafood dish. Mussels are very abundant in coastal areas",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 375 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Combine butter and garlic then mix well."
    },
    {
      "position": 3,
      "text": "Remove the extra shell from the mussel. Place some butter and garlic mixture on the mussels using a teaspoon or brush."
    },
    {
      "position": 4,
      "text": "Top the mussels with grated quickmelt cheese."
    },
    {
      "position": 5,
      "text": "Arrange the mussels in a baking tray lined with Aluminum foil."
    },
    {
      "position": 6,
      "text": "Bake for 15 to 18 minutes."
    },
    {
      "position": 7,
      "text": "Remove from the oven and transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve as an appetizer dish. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 10,
