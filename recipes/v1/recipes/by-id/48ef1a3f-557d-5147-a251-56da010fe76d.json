  "id": "48ef1a3f-557d-5147-a251-56da010fe76d",
  "slug": "how-to-make-garlic-parmesan-chicken-wings",
  "name": "Garlic Parmesan Chicken Wings Recipe",
  "recipe_type": null,
  "brief_description": "Garlic Parmesan chicken wings is a good chicken dinner idea for people on the go. After long hours of work, you deserve a break",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Season chicken with salt, cumin, and oregano. Let stand for 30 minutes."
    },
    {
      "position": 2,
      "text": "Combine olive oil, garlic powder, seasoning salt, basil, and parmesan cheese. Set Aside."
    },
    {
      "position": 3,
      "text": "Preheat oven to 400 degrees Fahrenheit."
    },
    {
      "position": 4,
      "text": "Bake the chicken wings for 25 to 30 minutes."
    },
    {
      "position": 5,
      "text": "Allow the chicken wings to cool then toss in the olive oil, garlic powder, salt, basil, and parmesan cheese mixture."
    },
    {
      "position": 6,
      "text": "Serve with your favorite dipping sauce."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
