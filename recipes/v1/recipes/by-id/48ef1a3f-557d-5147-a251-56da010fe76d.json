  "slug": "how-to-make-garlic-parmesan-chicken-wings",
  "name": "Garlic Parmesan Chicken Wings Recipe",
  "recipe_type": null,
  "brief_description": "Crispy baked chicken wings tossed in a savory garlic, basil, and Parmesan cheese mixture. A flavorful dinner option that is easy to prepare.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Season chicken with salt, cumin, and oregano. Let stand for 30 minutes."
    },
    {
      "position": 2,
      "text": "Combine olive oil, garlic powder, seasoning salt, basil, and parmesan cheese. Set aside."
    },
    {
      "position": 3,
      "text": "Preheat oven to 400 degrees Fahrenheit."
    },
    {
      "position": 4,
      "text": "Bake the chicken wings for 25 to 30 minutes."
    },
    {
      "position": 5,
      "text": "Allow the chicken wings to cool slightly, then toss with the prepared garlic-Parmesan mixture."
    },
    {
      "position": 6,
      "text": "Serve with your favorite dipping sauce."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
