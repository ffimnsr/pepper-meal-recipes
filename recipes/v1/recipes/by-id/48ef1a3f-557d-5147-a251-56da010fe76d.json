  "recipe_notes": [
    "For extra crispy wings, pat the chicken completely dry with paper towels before seasoning.",
    "Letting the chicken stand for 30 minutes allows the salt, cumin, and oregano to penetrate the meat for better flavor."
  ],
  "storage_notes": [
    "Store leftover wings in an airtight container in the refrigerator for up to 3 days.",
    "Reheat in a 375\u00b0F oven for 10-12 minutes to restore crispness."
  ],
