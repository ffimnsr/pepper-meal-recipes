  "slug": "lemon-garlic-butter-salmon-with-spring-salad-recipe",
  "name": "Lemon Garlic Butter Salmon with spring salad Recipe",
  "recipe_type": "salad",
  "brief_description": "Lemon garlic butter salmon is a perfect idea for a quick dinner recipe. It is easy to prepare and quick to cook. The result is fantastic",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine salt, ground black pepper, and garlic powder in a small bowl mix well."
    },
    {
      "position": 2,
      "text": "Arrange the salmon fillet in a plate. Rub the garlic powder mixture all over the salmon. Let it stay for 10 to 15 minutes."
    },
    {
      "position": 3,
      "text": "Melt the butter in a pan. Add the oil. Set the heat between low and medium."
    },
    {
      "position": 4,
      "text": "Gently add the salmon fillet and thyme in the pan. Do not use high heat when cooking with butter because it has a tendency to get burnt quickly. Cook each side of the salmon fillet for 7 to 10 minutes (in low to medium heat) or until the fish starts to brown."
    },
    {
      "position": 5,
      "text": "Remove from the frying pan. Arrange in individual plates. Squeeze lemon juice on top."
    },
    {
      "position": 6,
      "text": "Serve with white or brown rice and salad."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 15,
