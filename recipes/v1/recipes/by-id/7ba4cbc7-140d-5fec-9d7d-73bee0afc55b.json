  "id": "7ba4cbc7-140d-5fec-9d7d-73bee0afc55b",
  "slug": "chicken-sandwich",
  "name": "Chicken Sandwich",
  "recipe_type": "main",
  "brief_description": "Delicious chicken sandwich spread and crispy chicken sandwich. The choice is yours.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Make the simple chicken sandwich by combining all the chicken sandwich spread ingredients in a bowl. Mix well. Season with salt and ground black pepper as needed."
    },
    {
      "position": 2,
      "text": "Spread a generous amount of chicken sandwich spread mixture on one slice of bread and top it with the other slice. Set it aside."
    },
    {
      "position": 3,
      "text": "Prepare the crispy chicken sandwich by making incisions on both sides of the chicken breast. Rub salt all over it and let it stay for 5 minutes."
    },
    {
      "position": 4,
      "text": "Heat cooking oil in a pan."
    },
    {
      "position": 5,
      "text": "Dredge the chicken in flour and then dip in beaten egg until completely coated. Dredge it again in flour. Fry one side using between low to medium heat settings until it turns golden brown. Flip the chicken breast and continue frying the opposite side. Remove from the pan and place on a plate lined with a paper towel."
    },
    {
      "position": 6,
      "text": "Spread Lady\u2019s Choice Chicken Sandwich Spread on one side of each burger bun slice. Put the crispy fried chicken in the middle."
    },
    {
      "position": 7,
      "text": "Enjoy your chicken sandwiches."
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
