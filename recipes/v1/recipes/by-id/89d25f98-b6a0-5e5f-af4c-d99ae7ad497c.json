  "id": "89d25f98-b6a0-5e5f-af4c-d99ae7ad497c",
  "slug": "pesang-manok",
  "name": "Pesang Manok (Chicken Soup in Ginger Broth)",
  "recipe_type": "soup",
  "brief_description": "Chicken soup in ginger broth with potato and cabbage.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken, water, chicken broth, ginger, and whole peppercorn in a cooking pot. Let boil. Simmer for 30 to 45 minutes."
    },
    {
      "position": 2,
      "text": "Add the potatoes and cook for 12 minutes."
    },
    {
      "position": 3,
      "text": "Put-in the Napa cabbage and fish sauce. Cover and cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
