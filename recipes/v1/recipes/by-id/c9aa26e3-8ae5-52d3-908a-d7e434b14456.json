  "id": "c9aa26e3-8ae5-52d3-908a-d7e434b14456",
  "slug": "how-to-make-authentic-carbonara",
  "name": "How to Make Authentic Carbonara",
  "recipe_type": "main",
  "brief_description": "Authentic Roman carbonara recipe",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Crack the eggs in a bowl. Beat until the texture becomes smooth."
    },
    {
      "position": 2,
      "text": "Add Pecorino cheese. Continue mixing until cheese and eggs are well blended. Season with ground black pepper. Set aside."
    },
    {
      "position": 3,
      "text": "Cook spaghetti according to package instructions. Set aside."
    },
    {
      "position": 4,
      "text": "Sear Panceta on a clean skillet until it browns, and enough oil gets extracted."
    },
    {
      "position": 5,
      "text": "Add cooked pasta in the skillet. Toss."
    },
    {
      "position": 6,
      "text": "Combine \u00bc cup tap water and \u00bd cup pasta water and then pour into the sauce mixture. Mix well."
    },
    {
      "position": 7,
      "text": "Pour the sauce into the skillet. Toss while cooking in low heat until well distributed."
    },
    {
      "position": 8,
      "text": "Season with more ground black pepper."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
