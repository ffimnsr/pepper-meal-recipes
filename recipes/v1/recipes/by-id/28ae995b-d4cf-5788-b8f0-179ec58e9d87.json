  "id": "28ae995b-d4cf-5788-b8f0-179ec58e9d87",
  "slug": "sinigang-na-baboy-with-gabi",
  "name": "Sinigang na Baboy with Gabi",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for pork belly soup cooked in sour broth. It makes use of a variety of vegetables and is best when served hot with a cup of rice on the side.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a cooking pot. Let boil"
    },
    {
      "position": 2,
      "text": "Add onion and tomato. Boil for 5 to 8 minutes."
    },
    {
      "position": 3,
      "text": "Put the pork in the cooking pot. Boil for 25 minutes."
    },
    {
      "position": 4,
      "text": "Add the taro. Cover and continue to boil for 30 minutes."
    },
    {
      "position": 5,
      "text": "Add Knorr Sinigang sa Sampaloc mix, fish sauce, and ground black pepper; stir."
    },
    {
      "position": 6,
      "text": "Put the daikon radish in. Cook for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Add the chili peppers, okra, and snake beans. Cook for 7 minutes."
    },
    {
      "position": 8,
      "text": "Add the kangkong. Cover the cooking pot and turn off the heat. Let it stay covered for 5 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to as serving bowl. Serve with a small bowl with patis and spicy chili."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
