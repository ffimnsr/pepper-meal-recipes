  "id": "ef47a46c-bbd9-5aa2-b678-18480f5d2814",
  "slug": "monggo-with-hibi-mung-beans-with-small-dried-shrimp",
  "name": "Monggo with Hibi (Mung beans with small dried shrimp)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Monggo with Hibi which are Mung beans with small dried shrimp",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 4 cups of water in a cooking pot. Add the mung beans and continue to boil until the beans absorb all the water. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a separate pot. Saut\u00e9 garlic, onion, and tomato until soft."
    },
    {
      "position": 3,
      "text": "Add the hibi and mung beans. Stir."
    },
    {
      "position": 4,
      "text": "Pour-in remaining water into the pot. Let boil. Cover and cook for 10 minutes."
    },
    {
      "position": 5,
      "text": "Add the spinach. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add the fish sauce and ground black pepper. Stir and cook for 2 minutes more."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
