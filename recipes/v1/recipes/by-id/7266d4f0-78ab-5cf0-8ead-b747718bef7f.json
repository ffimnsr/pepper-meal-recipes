  "id": "7266d4f0-78ab-5cf0-8ead-b747718bef7f",
  "slug": "ahi-tuna-sandwich-with-wasabi-mayonnaise",
  "name": "Ahi Tuna Sandwich with Wasabi Mayonnaise",
  "recipe_type": null,
  "brief_description": "If you love tuna, Ahi Tuna Sandwich with Wasabi Mayonnaise will interest you. This is fresh, tasty, filling, and delicious",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle enough salt and pepper all over the tuna steaks. Let it stand for 5 minutes."
    },
    {
      "position": 2,
      "text": "Heat a non-stick flat pan or grill pan. Lightly spray cooking oil on the pan to prevent the steaks from sticking."
    },
    {
      "position": 3,
      "text": "Sear each side of the tuna steaks for 1 to 2 minutes per side. If you want your tuna steak to be well done, add more searing time. Remove the steaks from the pan and place in a clean plate."
    },
    {
      "position": 4,
      "text": "Meanwhile combine the mayonnaise (white mayo) with the sesame oil. Mix well. Spread 1 tablespoon of the mayonnaise mixture on both sides of the Kaiser or hamburger buns. Arrange the chopped lettuce and sliced tomato on one bun. Top with the seared ahi tuna steak."
    },
    {
      "position": 5,
      "text": "Spread the wasabi mayonnaise over the ahi tuna steak. Top with the other slice of the bun."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 5,
