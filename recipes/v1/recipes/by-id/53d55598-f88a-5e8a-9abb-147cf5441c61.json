  "id": "53d55598-f88a-5e8a-9abb-147cf5441c61",
  "slug": "filipino-chow-mein-noodle-pansit-pancit-canton-recipe",
  "name": "Pancit Canton Recipe",
  "recipe_type": "main",
  "brief_description": "Chewy egg noodles tossed with tender pork, chicken, mushrooms, and crisp vegetables in a rich soy-oyster sauce. A festive Filipino noodle dish perfect for sharing.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 1 quart of water. Add snow peas, carrot, and cabbage, and boil for 1 minute. Remove from the pot and soak the vegetables in ice water for 2 minutes. Drain well and set aside."
    },
    {
      "position": 2,
      "text": "Add the pork into the same pot used for boiling the vegetables. Boil until the pork becomes tender. Remove the pork and reserve the broth for later use."
    },
    {
      "position": 3,
      "text": "Heat 3 tablespoons of cooking oil in a wok. Saut\u00e9 garlic until it starts to brown. Add onion and celery, and continue saut\u00e9ing until the onion softens."
    },
    {
      "position": 4,
      "text": "Add the chicken and saut\u00e9 for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add shiitake mushrooms and boiled pork. Continue to saut\u00e9 for 1 minute."
    },
    {
      "position": 6,
      "text": "Pour in the soy sauce and oyster sauce."
    },
    {
      "position": 7,
      "text": "Add the reserved pork broth. Bring to a boil, cover, and simmer for 10 minutes."
    },
    {
      "position": 8,
      "text": "Add chicken powder and egg noodles. Toss and cook until the noodles fully absorb the broth."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper."
    },
    {
      "position": 10,
      "text": "Add bell peppers , chopped parsley, and blanched vegetables. Toss until well distributed."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve warm."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
