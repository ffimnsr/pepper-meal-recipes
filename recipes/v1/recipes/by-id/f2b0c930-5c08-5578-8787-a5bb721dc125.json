  "id": "f2b0c930-5c08-5578-8787-a5bb721dc125",
  "slug": "chicken-and-miswa-soup-recipe",
  "name": "Chicken and Miswa Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "Are you looking for a delicious Filipino Soup that you can quickly prepare? This Chicken and Miswa Soup Recipe is a good idea. I like Chicken and Miswa Soup because this is something that even a beginner can prepare and it is also budget friendly.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Bring water to a boil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the water starts boiling, add the chicken breast and boil for 15 to 18 minutes (add more water if needed)."
    },
    {
      "position": 3,
      "text": "Remove the chicken and let cool. Shred the chicken meat manually. Set aside."
    },
    {
      "position": 4,
      "text": "Heat the cooking oil in a clean cooking pot."
    },
    {
      "position": 5,
      "text": "Saut\u00e9 the onion and garlic"
    },
    {
      "position": 6,
      "text": "Once the onion becomes soft, add the shredded chicken meat. Continue to cook for2 minutes."
    },
    {
      "position": 7,
      "text": "Add in the annatto powder and then pour-in the remaining water from the pot where the chicken was boiled. Pour-in the chicken broth."
    },
    {
      "position": 8,
      "text": "Stir and let boil."
    },
    {
      "position": 9,
      "text": "Cover and simmer for 15 minutes. You can add more water or chicken broth if the liquid reduces."
    },
    {
      "position": 10,
      "text": "Put-in the miswa noodles. Stir and cook for 2 minutes."
    },
    {
      "position": 11,
      "text": "Add the chopped green onions, salt, and ground black pepper."
    },
    {
      "position": 12,
      "text": "Transfer to a serving bowl. You can top this with toasted garlic."
    },
    {
      "position": 13,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
