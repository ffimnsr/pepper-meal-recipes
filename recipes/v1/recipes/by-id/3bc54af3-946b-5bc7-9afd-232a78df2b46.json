  "schema_version": 1,
  "id": "3bc54af3-946b-5bc7-9afd-232a78df2b46",
  "slug": "sinigang-na-tilapia-sa-miso-recipe",
  "name": "Sinigang na Tilapia sa Miso Recipe",
  "recipe_type": "soup",
  "brief_description": "Sinigang na Tilapia sa Miso is a popular sour fish soup recipe in the Philippines. This version that we have is tastier than the usual recipes because I pan-fried the tilapia beforehand. For some reason, it adds an interesting flavor to the dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Slice the tilapia crosswise into half. Rub salt all over the fish. Let it stand for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat 1 cup of cooking oil in a pan."
    },
    {
      "position": 3,
      "text": "When the oil turns hot, pan-fry each side of the tilapia in medium heat for 5 minutes."
    },
    {
      "position": 4,
      "text": "Remove the tilapia and place in a clean plate. Set aside."
    },
    {
      "position": 5,
      "text": "Meanwhile, scoop about 2 tablespoons of cooking oil from the pan where the fish was fried and place it in a cooking pot."
    },
    {
      "position": 6,
      "text": "Heat the cooking pot. When the oil heats-up, saut\u00e9 the garlic, onion, and tomatoes"
    },
    {
      "position": 7,
      "text": "Add the miso paste and then pour-in the fish sauce and water. Let boil."
    },
    {
      "position": 8,
      "text": "Add the sinigang mix. Stir."
    },
    {
      "position": 9,
      "text": "Put the fried tilapia in the cooking pot. Cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Add the okra. Cook for 2 minutes."
    },
    {
      "position": 11,
      "text": "Turn the heat off. Sprinkle some ground black pepper and add the mustard leaves. Cover for 5 minutes."
    },
    {
      "position": 12,
      "text": "Transfer the fish into a serving bowl."
    },
    {
      "position": 13,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
