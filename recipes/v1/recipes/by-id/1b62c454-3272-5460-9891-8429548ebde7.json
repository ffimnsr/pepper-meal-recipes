  "id": "1b62c454-3272-5460-9891-8429548ebde7",
  "slug": "pastimallows",
  "name": "Pastimallows",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for pastimallows, which is a dessert made from pastillas and marshmallows.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine powdered milk, condensed milk, and butter in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Separate the mixture into half."
    },
    {
      "position": 3,
      "text": "Add 10 to 12 drops of red food coloring on one bowl and the same amount of green food coloring on the other bowl. Mix well."
    },
    {
      "position": 4,
      "text": "Scoop a tablespoon of mixture of red food coloring. Mold it into a sphere. Flatten the sphere and then wrap it on a piece of marshmallow. Roll over the bowl with sugar and then arrange in a small cup cake cup. Perform this step until all the red and green mixture are completely consumed."
    },
    {
      "position": 5,
      "text": "Share and enjoy."
    }
  ],
  "servings": 10,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 15,
