  "id": "eb292696-e2d6-5d6d-bccf-5be7ff7b2642",
  "slug": "chicken-pasta-casserole",
  "name": "Chicken Pasta Casserole",
  "recipe_type": null,
  "brief_description": "Chicken Pasta Casserole is a quick and easy chicken and pasta recipe that your kids will love. It is low in sodium and tastes great!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook pasta according to package directions. Drain."
    },
    {
      "position": 2,
      "text": "Grease baking dish with oil."
    },
    {
      "position": 3,
      "text": "Preheat oven to 350F."
    },
    {
      "position": 4,
      "text": "Heat oil in a saute pan."
    },
    {
      "position": 5,
      "text": "Brown the chicken in oil. Add tomatoes, Italian seasoning, and spaghetti sauce. Let it simmer for 8 minutes."
    },
    {
      "position": 6,
      "text": "Stir in broccoli. Cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Put pasta in baking dish. Pour chicken mixture over pasta. Toss."
    },
    {
      "position": 8,
      "text": "Top with Parmesan and mozzarella."
    },
    {
      "position": 9,
      "text": "Bake for 25 minutes (uncovered)."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 25,
