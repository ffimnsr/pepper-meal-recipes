  "id": "13140b75-d395-5338-a72d-5617f11b75a5",
  "slug": "adobong-sitaw-string-bean-recipe",
  "name": "Adobong Sitaw Recipe",
  "recipe_type": null,
  "brief_description": "Thsi is a recipe for&nbsp;Adobong Sitaw or Snake beans cooked the Filipino inadobo way.&nbsp;",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a wok and then sear the pork until enough fat is rendered."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic until it starts to brown."
    },
    {
      "position": 3,
      "text": "Add the onion. Continue saut\u00e9ing the onion with all the ingredients until it softens."
    },
    {
      "position": 4,
      "text": "Pour the soy sauce, vinegar, and water. Let boil."
    },
    {
      "position": 5,
      "text": "Cover the wok. Adjust the heat to a simmer. Continue cooking until the pork tenderizes completely. Note: You can add more water as needed."
    },
    {
      "position": 6,
      "text": "Add the string beans. Toss and cook for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Season with sugar, ground black pepper, and salt (as needed)."
    },
    {
      "position": 8,
      "text": "Continue cooking until the string beans soften to your liking."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve with rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
