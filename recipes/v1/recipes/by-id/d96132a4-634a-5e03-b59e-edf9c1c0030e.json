  "id": "d96132a4-634a-5e03-b59e-edf9c1c0030e",
  "slug": "tinolang-manok-sa-upo",
  "name": "Tinolang Manok sa Upo",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Tinolang Manok sa Upo or Chicken in Ginger Broth with Opo Squash.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Add chicken pieces. Continue to cook until all side of the chicken turns light brown."
    },
    {
      "position": 4,
      "text": "Add ginger. Stir and cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour rice washing into the pot. Let boil. Note: You can also use water, if rice washing is not available."
    },
    {
      "position": 6,
      "text": "Add Knorr chicken cube. Stir. Cover and continue to cook in medium heat for 25 to 30 minutes. Add more water if needed."
    },
    {
      "position": 7,
      "text": "Put the upo and siling pansigang into the pot. Cover and cook for 5 to 7 minutes."
    },
    {
      "position": 8,
      "text": "Add hot pepper leaves and malunggay leaves. Stir."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper and fish sauce."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve!"
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
