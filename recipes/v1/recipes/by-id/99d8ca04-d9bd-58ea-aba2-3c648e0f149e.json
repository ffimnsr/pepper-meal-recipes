  "id": "99d8ca04-d9bd-58ea-aba2-3c648e0f149e",
  "slug": "kangkong-oyster-sauce-recipe",
  "name": "Kangkong in Oyster Sauce Recipe",
  "recipe_type": null,
  "brief_description": "Kangkong in Oyster Sauce is a simple vegetable dish composed of a green leafy vegetable that is locally known in the Philippines as kangkong, oyster sauce, and some seasonings. Kangkong is also called water spinach. The Chinese variety is known as ongchoy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Separated the kangkong leaves from the stalk. Cut the stalk into 2 inch length pieces. Set aside."
    },
    {
      "position": 2,
      "text": "Prepare the toasted garlic by following this guide: How to make toasted garlic. Set aside."
    },
    {
      "position": 3,
      "text": "In a bowl, combine beef broth, oyster sauce, and corn starch. Mix well."
    },
    {
      "position": 4,
      "text": "Heat 2 tablespoons of cooking oil (preferably the one used to make toasted garlic) in a pan."
    },
    {
      "position": 5,
      "text": "When the oil gets hot, put-in the sliced kangkong stalks. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the oyster sauce, beef broth, and cornstarch mixture. Add the toasted garlic. Stir. Cook for 1 minute of until the sauce starts to thicken."
    },
    {
      "position": 7,
      "text": "Add the kangkong leaves and red pepper flakes. Let it cook for 1 to 2 minutes."
    },
    {
      "position": 8,
      "text": "Sprinkle salt and ground black pepper to taste."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Sprinkle sesame seeds on top."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
