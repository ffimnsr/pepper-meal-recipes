  "name": "Seaweed Salad Recipe (Ensaladang Lato)",
  "recipe_type": "salad",
  "brief_description": "Seaweed Salad or Ensaladang Lato is a type of Filipino salad that makes use of edible seaweed as its main ingredient. This is really good.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a bowl, combine vinegar, salt, pepper, sugar, tomato, and onion. Stir to mix."
    },
    {
      "position": 2,
      "text": "Add the lato or sea grapes. Toss. Let it stay for at least 10 minutes."
    },
    {
      "position": 3,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 4,
      "text": "Share and enjoy!"
    }
  ],
