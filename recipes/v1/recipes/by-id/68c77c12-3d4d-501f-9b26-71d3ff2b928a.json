  "id": "68c77c12-3d4d-501f-9b26-71d3ff2b928a",
  "slug": "pork-caldereta",
  "name": "Pork Caldereta Recipe",
  "recipe_type": "main",
  "brief_description": "A hearty Filipino pork stew made with tender pork cubes, potatoes, carrots, and bell peppers simmered in a rich tomato sauce with liver spread and olives.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the pork. Saute until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Pour-in the tomato sauce and water. Let boil. Cover and cook in low heat for 60 minutes."
    },
    {
      "position": 5,
      "text": "Add the liver spread. Stir and cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the potato and carrot. Cover and cook for 8 to 10 minutes."
    },
    {
      "position": 7,
      "text": "Add the olives and bell peppers. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 9,
      "text": "Turn-off the heat. Transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
