  "id": "e70ada61-63f0-558d-bac2-e5db1c52e9fd",
  "slug": "pork-stir-fry-with-scallions",
  "name": "Pork Stir Fry with Scallions",
  "recipe_type": null,
  "brief_description": "Pork Stir Fry with Scallions looks gorgeous and appetizing; it also tastes good especially when served with warm rice. I'm sure that you will love this quick and easy pork stir fry recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork, soy sauce, oyster sauce, ground black pepper, and salt in a large mixing bowl. Mix well. Let it stay for 20 minutes."
    },
    {
      "position": 2,
      "text": "Add the cornstarch into the pork mixture. Mix well."
    },
    {
      "position": 3,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 4,
      "text": "Once the cooking oil becomes hot, stir fry the pork for 8 to 12 minutes."
    },
    {
      "position": 5,
      "text": "Add the bell pepper and scallions. Stir fry for 2 to 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the cooking wine. Cook for a minute,"
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
