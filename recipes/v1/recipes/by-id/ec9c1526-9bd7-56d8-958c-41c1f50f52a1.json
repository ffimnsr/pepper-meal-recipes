  "id": "ec9c1526-9bd7-56d8-958c-41c1f50f52a1",
  "slug": "cheesy-lumpia",
  "name": "Cheesy Lumpiang Shanghai",
  "recipe_type": "appetizer",
  "brief_description": "Deep fried crispy lumpia stuffed with mozzarella.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine ground pork with the filling ingredients. Add Knorr Liquid seasoning. Mix everything together."
    },
    {
      "position": 2,
      "text": "Wrap the lumpia by laying a sheet of lumpia wrapper on a clean flat surface. Scoop around 1 \u00bd tablespoons of mixture and spread it on one side of the wrapper. Put the sliced string cheese over and cover it completely with the meat mixture. Fold the sides of the wrapper inward, roll it, and secure the ends. Perform this step until the entire meat mixture is consumed."
    },
    {
      "position": 3,
      "text": "Cook the lumpia by heating the remaining oil in a wok. Deep fry using medium heat setting until the lumpia turns golden brown."
    },
    {
      "position": 4,
      "text": "Arrange on a serving plate and serve with ketchup. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
