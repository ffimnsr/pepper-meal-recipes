  "id": "7c1467ed-530f-53d0-8338-d2cf790dccf8",
  "slug": "tinola-chicken-mami",
  "name": "Tinola Chicken Mami",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Tinola Chicken Mami",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 8 cups water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Add the fresh Miki noodles when the water starts to boil. Let it stay for 20 to 30 seconds. Remove the Miki noodles from the cooking pot, drain the water, and arrange the noodles in individual bowls."
    },
    {
      "position": 3,
      "text": "On a clean cooking pot, start to heat the oil. Add the garlic immediately while the oil is heating-up and let it brown while stirring. Continue to cook in medium heat until all the garlic pieces are medium brown. Remove the garlic from the pot. Set aside."
    },
    {
      "position": 4,
      "text": "Using the remaining cooking oil in the pot, saute onion and ginger. Add the ground black pepper. Cook until the onion is soft."
    },
    {
      "position": 5,
      "text": "Pour water. Let boil. Add the chicken breasts. Cover and cook in medium heat for 35 minutes."
    },
    {
      "position": 6,
      "text": "Remove the chicken and put in a clean plate. Let it cool down. Shred the chicken and set it aside."
    },
    {
      "position": 7,
      "text": "Add the chicken cube and green papaya into the cooking pot. Cover and cook for 10 minutes."
    },
    {
      "position": 8,
      "text": "Add the malunggay leaves and fish sauce. Cook for 3 to 5 minutes."
    },
    {
      "position": 9,
      "text": "Arrange the shredded chicken and egg on each bowl with noodles. Pour-in the soup with papaya and malunggay. Top with fried garlic."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
