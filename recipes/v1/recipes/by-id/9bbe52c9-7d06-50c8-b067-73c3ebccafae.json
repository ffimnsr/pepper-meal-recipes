  "recipe_type": "dessert",
  "brief_description": "Delicious Whole Wheat Pancakes is a whole wheat pancake version that is simple and awesome. Get the details of the recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat pan or griddle"
    },
    {
      "position": 2,
      "text": "Sift the dry ingredients together in a bowl"
    },
    {
      "position": 3,
      "text": "Beat egg in; add brown sugar, buttermilk, and butter"
    },
    {
      "position": 4,
      "text": "Pour into bowl with dry ingredients; stir but not too much"
    },
    {
      "position": 5,
      "text": "Scoop a quarter cup batter onto the pan. Flip when bubbles starts to show-up; cook for 15 to 20 seconds"
    },
    {
      "position": 6,
      "text": "Serve"
    }
  ],
