  "id": "ac3cb1bb-0511-5c95-9558-9791e524c311",
  "slug": "how-to-cook-bulalo-and-tagaytay-mahogany-market-tour",
  "name": "How to Cook Bulalo",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for bulalo or beef shank soup.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a large cooking pot."
    },
    {
      "position": 2,
      "text": "Add beef shank. Cover the pot and boil for 15 minutes."
    },
    {
      "position": 3,
      "text": "Scrape the scums out of the cooking pot. Add whole peppercorn and onion. Cover the pot. Continue to cook in low heat for 2 to 3 hours or until the beef becomes tender. Note: you can use a pressure cooker to tenderize the meat. It should only take around 45 minutes."
    },
    {
      "position": 4,
      "text": "Scoop the fats (oil) floating on top of the soup and discard."
    },
    {
      "position": 5,
      "text": "Add corn. Cover and cook for 15 minutes."
    },
    {
      "position": 6,
      "text": "Add long green beans (Baguio beans) and season with fish sauce (patis)."
    },
    {
      "position": 7,
      "text": "Arrange the fresh Napa cabbage (pechay baguio) on the serving bowl. Pour hot broth and arrange the beef shank, corn, and long green beans in the bowl."
    },
    {
      "position": 8,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 180,
  "preparation_time_minutes": 10,
