  "id": "2ae94a00-b475-5ccc-ba99-c464c8c04409",
  "slug": "how-to-cook-sinampalukang-manok",
  "name": "How to Cook Sinampalukang Manok",
  "recipe_type": null,
  "brief_description": "This is a recipe on How to Cook Sinampalukang Manok",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking pot and then sear the chicken. Continue to cook until most of the chicken fat are extracted."
    },
    {
      "position": 2,
      "text": "Remove the chicken from the pot. Set aside."
    },
    {
      "position": 3,
      "text": "Using the extracted oil, saut\u00e9 garlic, onion, and ginger."
    },
    {
      "position": 4,
      "text": "Once the onion becomes soft, add the chicken back to the pot."
    },
    {
      "position": 5,
      "text": "Pour water. Let boil. Seal the tamarind flower buds in a cheesecloth and tie using a kitchen twine."
    },
    {
      "position": 6,
      "text": "Add the cheese cloth with tamarind flower buds in the pot. Stir."
    },
    {
      "position": 7,
      "text": "Add Knorr chicken cube and long green pepper. Cover the pot. Cook in medium heat until the chicken gets tender."
    },
    {
      "position": 8,
      "text": "Remove the tamarind flower buds. Add Knorr Sinigang Mix. Stir."
    },
    {
      "position": 9,
      "text": "Add fish sauce. Cook for 5 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
