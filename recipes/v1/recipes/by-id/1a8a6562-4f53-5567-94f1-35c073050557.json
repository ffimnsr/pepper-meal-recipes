  "id": "1a8a6562-4f53-5567-94f1-35c073050557",
  "slug": "chicken-gravy",
  "name": "Chicken Gravy",
  "recipe_type": null,
  "brief_description": "This chicken gravy version is quick and easy to make. It also cost less because of the use of chicken bouillon, which is very tasty by the way. I usually make this gravy version for all my fried chicken.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Make the gravy by melting butter in a saucepan."
    },
    {
      "position": 2,
      "text": "Add all-purpose flour. Cook in medium heat while stirring for 8 minutes to make a brown roux."
    },
    {
      "position": 3,
      "text": "Add Knorr Chicken Cube. Stir until melted."
    },
    {
      "position": 4,
      "text": "Pour water into the saucepan. Stir until well blended. Add onion powder, garlic powder, and ground black pepper. Stir. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Serve with fried chicken."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 3,
  "rest_time_minutes": null,
  "difficulty": "easy",
