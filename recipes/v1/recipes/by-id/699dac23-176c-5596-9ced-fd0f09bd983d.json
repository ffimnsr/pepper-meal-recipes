  "id": "699dac23-176c-5596-9ced-fd0f09bd983d",
  "slug": "basil-beef-recipe",
  "name": "Basil Beef Recipe",
  "recipe_type": "dessert",
  "brief_description": "Basil beef is a delicious ground beef recipe. It is usually tastes somewhat sweet and spicy. It also has an appetizing aroma brought about by fresh basil",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a frying pan."
    },
    {
      "position": 2,
      "text": "Pour the oil in the frying pan."
    },
    {
      "position": 3,
      "text": "When the oil becomes hot, saut\u00e9 the garlic."
    },
    {
      "position": 4,
      "text": "Add the chili flakes and then cook for 15 seconds."
    },
    {
      "position": 5,
      "text": "Put-in the ground beef. Stir and brown for about 10 minutes."
    },
    {
      "position": 6,
      "text": "Add the fish sauce and brown sugar. Stir. Simmer for 20 minutes while letting the excess liquid evaporate."
    },
    {
      "position": 7,
      "text": "Put-in the basil leaves. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Sprinkle the ground black pepper. Stir"
    },
    {
      "position": 9,
      "text": "Turn-off heat. Transfer to a serving plate. Add fried egg on top if desired."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
