  "id": "b9e6b29e-1324-5fd2-8e1a-22e702eb47ec",
  "slug": "tuna-salad-wrap",
  "name": "Tuna Salad Wrap",
  "recipe_type": "salad",
  "brief_description": "Tuna Salad Wrap is a flour tortilla wrap with tuna salad inside. This makes a good lunch along with homemade potato chips or fries.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the tuna salad and cheddar cheese. Mix well."
    },
    {
      "position": 2,
      "text": "Arrange 2 leaf lettuces over one tortilla wrap and then put-in half of the chopped tomato."
    },
    {
      "position": 3,
      "text": "Arrange 3/4 cup of the tuna salad and cheese mixture over the chopped tomatoes."
    },
    {
      "position": 4,
      "text": "Fold 2 opposite ends of the wrap (about 3 inches). Roll starting on the unfolded side until the contents are wrapped properly."
    },
    {
      "position": 5,
      "text": "Slice half of the wrap crosswise using a knife and then arrange in a serving plate."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 15,
