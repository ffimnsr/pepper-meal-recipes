  "recipe_notes": [
    "Offal requires thorough cleaning and pre-boiling before use in this recipe.",
    "Kamias (bilimbi fruit) provides essential sourness; substitute with tamarind or additional vinegar if unavailable.",
    "Bitterness level can be adjusted by increasing or decreasing bitter melon and kamias quantities.",
    "Traditional versions may include bile for enhanced bitterness (pinapaitan).",
    "Best consumed immediately; leftovers develop stronger flavors overnight."
  ],
  "storage_notes": [
    "Refrigerate in an airtight container for up to 3 days.",
    "Freeze portions without the bitter melon for up to 2 months; add fresh bitter melon when reheating.",
    "Reheat gently over low heat to prevent liver from becoming tough."
  ],
