  "id": "48f53092-4274-550a-b577-de4d1d74bb02",
  "slug": "pinapaitan-sa-ampalaya",
  "name": "Pinapaitan sa Ampalaya",
  "recipe_type": "soup",
  "brief_description": "Traditional Filipino beef offal soup with bitter melon, featuring a complex savory-bitter flavor profile from beef tripe, heart, liver, and small intestine simmered with ampalaya and kamias.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the bitter melons by cutting them in half lengthwise and removing the seeds with a spoon. Slice into thin half-moons or chop into small pieces. Note: you can also use a food processor for best results."
    },
    {
      "position": 2,
      "text": "Bring water to a boil in a cooking pot. Add the chopped bitter melons and boil for 3 minutes to reduce bitterness. Drain and set aside, reserving the boiling liquid."
    },
    {
      "position": 3,
      "text": "Heat cooking oil in a clean wok or heavy-bottomed pot over medium heat. Saut\u00e9 minced garlic, onion, and ginger until fragrant and the onion begins to soften, about 2-3 minutes."
    },
    {
      "position": 4,
      "text": "Add the boiled and chopped beef tripe, beef heart, and beef small intestine to the pot. Cook for 5 to 7 minutes, stirring occasionally, until lightly browned and heated through."
    },
    {
      "position": 5,
      "text": "Add the sliced pork liver to the pot. Cook for 1 minute, stirring gently to avoid breaking the liver."
    },
    {
      "position": 6,
      "text": "Pour white vinegar into the wok, scraping the bottom to deglaze. Let the mixture boil uncovered for 2 minutes to cook off the sharp acidity."
    },
    {
      "position": 7,
      "text": "Pour in the reserved bitter melon boiling water through a fine strainer to remove any solids. Cover the pot, reduce heat to low, and simmer until the offal is tender, approximately 45-60 minutes."
    },
    {
      "position": 8,
      "text": "Add kamias and whole chili peppers to the soup. Continue cooking for 15 minutes to develop the sour and spicy notes."
    },
    {
      "position": 9,
      "text": "Season with fish sauce and ground black pepper to taste. Adjust bitterness and sourness as desired. Serve hot with steamed rice. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 25,
