  "id": "48f53092-4274-550a-b577-de4d1d74bb02",
  "slug": "pinapaitan-sa-ampalaya",
  "name": "Pinapaitan sa Ampalaya",
  "recipe_type": "appetizer",
  "brief_description": "Beef offal soup with bitter melon.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the bitter melons by removing the seeds. Chop the veggies into small pieces. Note: you can also use a food processor for best results."
    },
    {
      "position": 2,
      "text": "Boil water in a cooking pot. Add chopped bitter melons. Boil for 3 minutes. Set aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a clean wok or pan. Saut\u00e9 garlic, onion, and ginger."
    },
    {
      "position": 4,
      "text": "Once the onion softens, add the beef tripe, beef heart, and small intestine. Cook for 5 to 7 minutes."
    },
    {
      "position": 5,
      "text": "Add liver. Cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Pour vinegar into the wok. Let the mixture boil."
    },
    {
      "position": 7,
      "text": "Pour the water used to boil the bitter melons while straining. Cover and let the liquid boil. Set the heat to low. Continue boiling until all the ingredients gets tender."
    },
    {
      "position": 8,
      "text": "Add kamias and chili peppers. Cook for 15 minutes."
    },
    {
      "position": 9,
      "text": "Season with fish sauce and ground black pepper. Serve hot. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
