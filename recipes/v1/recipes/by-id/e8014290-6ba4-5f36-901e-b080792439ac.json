  "id": "e8014290-6ba4-5f36-901e-b080792439ac",
  "slug": "shared-recipe-victorias-cheezy-pizza-pocket",
  "name": "Victoria's Cheezy Pizza Pocket",
  "recipe_type": "snack",
  "brief_description": "This Cheezy Pizza Pocket Recipe is so good. Your kids will definitely love it.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a bowl mix flour,salt.sugar and baking powder."
    },
    {
      "position": 2,
      "text": "Add the milk and oil and mix well."
    },
    {
      "position": 3,
      "text": "Gather all ingredients and make a ball."
    },
    {
      "position": 4,
      "text": "Knead the dough 12 times in a flat surface."
    },
    {
      "position": 5,
      "text": "Put the dough in to the bowl and cover it with white cloth and let stand 15 minutes."
    },
    {
      "position": 6,
      "text": "In a cooking pan saute the onion and garlic in oil in 1 min."
    },
    {
      "position": 7,
      "text": "Add the hotdogs and bacon and cook it for 2min."
    },
    {
      "position": 8,
      "text": "Add again the peas and cook it for another 1 minute and add the shrimp put salt and pepper and sugar to taste."
    },
    {
      "position": 9,
      "text": "Turn off the heat and transfer the cooked ingredients to the empty bowl."
    },
    {
      "position": 10,
      "text": "Don't cook the pineapple,raisins and the slice onion(lengthwise)."
    },
    {
      "position": 11,
      "text": "Preheat the oven at 425 degrees F in 10 minutes."
    },
    {
      "position": 12,
      "text": "In a flat surface put the dough and divide it into 8 pcs"
    },
    {
      "position": 13,
      "text": "Get the dividing dough and roll it to form circle."
    },
    {
      "position": 14,
      "text": "All the dividing dough Spray with cooking oil and put ketchup and spread into half circle."
    },
    {
      "position": 15,
      "text": "Add the cooked ingredients and uncooked pineapple,raisins,onion and cheese."
    },
    {
      "position": 16,
      "text": "Fold dough cover filling.Turn edge of the lower dough over edge of the top,pinch edge to seal and prick he top with fork."
    },
    {
      "position": 17,
      "text": "In baking pan with cookie sheet spray with oil the sheet."
    },
    {
      "position": 18,
      "text": "Bake for 20-25 minutes or until golden brown."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
