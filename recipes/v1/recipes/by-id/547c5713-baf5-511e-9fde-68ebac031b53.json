  "id": "547c5713-baf5-511e-9fde-68ebac031b53",
  "slug": "tinolang-tahong-with-malunggay",
  "name": "Tinolang Tahong with Malunggay",
  "recipe_type": "soup",
  "brief_description": "A comforting Filipino soup of mussels and malunggay leaves simmered with ginger and lemongrass. Best enjoyed during cold weather.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Bring water to a boil."
    },
    {
      "position": 2,
      "text": "Add the onion, ginger, and lemongrass. Continue to boil over medium heat for 8 minutes."
    },
    {
      "position": 3,
      "text": "Add the mussels. Boil for 6 minutes."
    },
    {
      "position": 4,
      "text": "Gently slide in the malunggay leaves. Cook for 6 to 8 minutes."
    },
    {
      "position": 5,
      "text": "Season with salt and ground black pepper. Stir."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
