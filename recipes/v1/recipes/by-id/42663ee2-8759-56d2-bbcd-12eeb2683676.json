  "id": "42663ee2-8759-56d2-bbcd-12eeb2683676",
  "slug": "pork-with-salted-black-beans",
  "name": "Pork with Salted Black Beans",
  "recipe_type": null,
  "brief_description": "Pork with salted black beans or pork tausi is a simple tasty pork recipe that you can cook during ordinary days.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "When the onion becomes soft, add the pork slices. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Put-in the salted black beans, oyster sauce, and parsley. Stir and cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the water. Cover the pan and let the water boil. Simmer for 15 to 20 minutes (add more water if needed)."
    },
    {
      "position": 6,
      "text": "Pour-in cornstarch diluted in water. Sprinkle some ground black pepper. Stir"
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
