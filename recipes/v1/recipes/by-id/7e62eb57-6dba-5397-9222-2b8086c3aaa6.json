  "slug": "carne-asada-burrito-recipe",
  "name": "Carne Asada Burrito Recipe",
  "recipe_type": null,
  "brief_description": "Care for some Carne Asada Burrito? I know that you won\u2019t let this chance pass, so I made sure that you\u2019ll find our easy burrito recipe here.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cover the flour tortillas using a paper towel. Microwave for 30 seconds"
    },
    {
      "position": 2,
      "text": "On every flour tortilla, arrange the carne asada, rice, pico de gallo, bell pepper, guacamole, sour cream, and top with cheese."
    },
    {
      "position": 3,
      "text": "Fold 2 opposite sides of the tortilla wrap by 3 inches, and then roll the unfolded sides until it forms a cylinder and the contents are sealed."
    },
    {
      "position": 4,
      "text": "Transfer to a serving plate with lime sliced."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
