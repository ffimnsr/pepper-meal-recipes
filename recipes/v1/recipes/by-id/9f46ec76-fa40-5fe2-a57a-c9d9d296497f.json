  "id": "9f46ec76-fa40-5fe2-a57a-c9d9d296497f",
  "slug": "pork-menudo-sa-gata",
  "name": "Pork Menudo sa Gata",
  "recipe_type": "main",
  "brief_description": "Pork Menudo is a classic Filipino comfort food. It\u2019s one of those dishes one can describe as quintessentially lutong bahay;",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok. Saut\u00e9 garlic and onion until the onion softens."
    },
    {
      "position": 2,
      "text": "Add pork. Continue saut\u00e9ing until the outer part turns light brown."
    },
    {
      "position": 3,
      "text": "Add soy sauce. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour tomato sauce and coconut milk. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork Cube. Stir and then add dried bay leaves. Cover the wok. Adjust heat to a low setting. Cover the wok and continue cooking until the pork tenderizes. Note: add water if the sauce starts to dry-up while the pork is not tender yet."
    },
    {
      "position": 6,
      "text": "Add pork liver. Cook for 8 minutes."
    },
    {
      "position": 7,
      "text": "Add potato and carrot. Cook for 10 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper. Serve with warm rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
