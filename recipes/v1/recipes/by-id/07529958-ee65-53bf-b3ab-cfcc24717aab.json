  "slug": "steamed-snow-crab-legs-recipe",
  "name": "Steamed Snow Crab Legs Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Steamed Snow Crab Legs",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water on a tall steamer. Let boil."
    },
    {
      "position": 2,
      "text": "Using a grater, grate the skin of the lemon to produce lemon rinds and then add these in boiling water."
    },
    {
      "position": 3,
      "text": "Arrange the crab legs in the steamer. Steam for 4 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Prepare the vinegar dip by combining vinegar and crushed garlic in a small bowl."
    },
    {
      "position": 5,
      "text": "Arrange the snow crab legs in a plate and serve with vinegar dip."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
