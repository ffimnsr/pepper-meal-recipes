  "id": "6c9d0e85-b97e-511c-bb57-60f10620d142",
  "slug": "filipino-food-how-to-cook-beef-pares-recipe",
  "name": "Beef Pares",
  "recipe_type": "side",
  "brief_description": "Beef stewed in soy sauce with star anise. This dish is best enjoyed with garlic fried rice and a bowl of beef stock on the side.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot or pressure cooker. Saute onion, garlic, and ginger."
    },
    {
      "position": 2,
      "text": "Add the beef once onion softens. Cook until light brown."
    },
    {
      "position": 3,
      "text": "Pour soy sauce and water. Stir."
    },
    {
      "position": 4,
      "text": "Add Knorr Beef Cube and star anise. Cover the pressure cooker and pressure cook for 15 minutes."
    },
    {
      "position": 5,
      "text": "Add brown sugar and season with salt and ground black pepper. Cook for 8 to 10 minutes more or until the sauce reduces a bit."
    },
    {
      "position": 6,
      "text": "Top with chopped scallions and serve with sinangag and beef stock. Share and enjoy."
    }
  ],
  "servings": null,
