  "id": "98e27018-0dfc-549d-9dd9-ea5ebb05f394",
  "slug": "easy-grilled-vegetables-recipe",
  "name": "Easy Grilled Vegetables",
  "recipe_type": "side",
  "brief_description": "Easy Grilled Vegetables Recipe is perfect to follow when grilling. It is simple, quick, and delicious. You will never look at vegetables the same way again after trying this recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat-up your grill. Note: You can use charcoal or gas grill."
    },
    {
      "position": 2,
      "text": "Combine garlic powder and olive oil. Mix well."
    },
    {
      "position": 3,
      "text": "Arrange the vegetable on the grill, and then baste with the olive oil mixture."
    },
    {
      "position": 4,
      "text": "Sprinkle salt and pepper. Grill each side for about 3 to 5 minutes or more if needed."
    },
    {
      "position": 5,
      "text": "If necessary, slice the vegetables into smaller pieces. Arrange everything in a large plate."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
