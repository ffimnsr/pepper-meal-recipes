  "id": "8cd97b22-d8e2-5543-b52c-867c51c38635",
  "slug": "corn-soup-with-mussels-and-malunggay",
  "name": "Corn Soup with Mussels and Malunggay",
  "recipe_type": "soup",
  "brief_description": "Corn Soup with Mussels and Malunggay is a quick and easy soup recipe that you can make anytime of the day.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Drain the water from the canned corn. Process the corn using a food processor or blender. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Once the oil gets hot, saut\u00e9 the ginger and onion."
    },
    {
      "position": 4,
      "text": "Add the garlic powder, corn, and mussels. Cook for minute."
    },
    {
      "position": 5,
      "text": "Pour-in the water and chicken broth. Let boil. Simmer for 8 minutes."
    },
    {
      "position": 6,
      "text": "Add the malunggay leaves, salt, and pepper. Stir. Cook for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to as serving bowl."
    },
    {
      "position": 8,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 8,
