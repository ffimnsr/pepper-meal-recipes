  "id": "113d4ce8-01f3-5478-bc24-913cc5f6d790",
  "slug": "pork-ribs-binagoongan",
  "name": "Pork Ribs Binagoongan with Talong",
  "recipe_type": "main",
  "brief_description": "Binagoongan is one of the most classic Filipino stews. Its strong aroma and flavor, matched with the pork meat, makes it an unforgettable.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat 3 tablespoons of cooking oil in a pan. Fry eggplants for 3 minutes or until its texture softens. Remove from the pan. Set aside. Note: Make sure to flip it every minute to cook all sides evenly."
    },
    {
      "position": 2,
      "text": "Add remaining oil. Saut\u00e9 onion, garlic, and tomato until the onion softens."
    },
    {
      "position": 3,
      "text": "Add pork ribs. Continue cooking until the color of the ribs turn light brown."
    },
    {
      "position": 4,
      "text": "Add bagoong alamang. Cook for 3 minutes while stirring."
    },
    {
      "position": 5,
      "text": "Pour-in vinegar. Let boil. Stir and add water. Let it boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Pork Cube. Cover the pan and adjust heat to the lowest setting. Cook until the meat gets tender. Note: Add more water if needed."
    },
    {
      "position": 7,
      "text": "Season with sugar and ground black pepper."
    },
    {
      "position": 8,
      "text": "Add fried eggplants. Cook for 1 \u00bd minutes."
    },
    {
      "position": 9,
      "text": "Finish by adding chopped green onions."
    },
    {
      "position": 10,
      "text": "Serve with warm rice! Share and enjoy."
    }
  ],
  "servings": null,
  "cooking_time_minutes": 60,
