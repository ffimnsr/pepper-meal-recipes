  "id": "9e8761ba-eea3-5b4f-99f8-ac175046f742",
  "slug": "sizzling-tofu-sisig",
  "name": "Sizzling Tofu Sisig",
  "recipe_type": "appetizer",
  "brief_description": "Fried tofu sisig.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the tofu. Squeeze the liquid out by pressing against a flat surface. Zip it inside a resealable bag and freeze overnight. Thaw the tofu and press again to remove the remaining liquid."
    },
    {
      "position": 2,
      "text": "Heat the oil in a pan. Fry the tofu until golden brown and crispy. Do the same step on the opposite side. Remove tofu from the pan and let it cool down. Chop into small pieces."
    },
    {
      "position": 3,
      "text": "Make the dressing by combining all the dressing ingredients in a bowl. Mix well. Set aside."
    },
    {
      "position": 4,
      "text": "Saute onion until it softens. Add tofu and liver spread. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Add the bell pepper and dressing mixture. Stir until all ingredients are coated. Set aside."
    },
    {
      "position": 6,
      "text": "Heat a metal plate (sizzling plate) and add butter. Transfer the tofu sisig into the metal plate."
    },
    {
      "position": 7,
      "text": "Serve as an appetizer or a main dish. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
