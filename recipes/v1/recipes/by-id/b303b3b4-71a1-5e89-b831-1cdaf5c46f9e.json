  "id": "b303b3b4-71a1-5e89-b831-1cdaf5c46f9e",
  "slug": "chopsuey-with-chicken-and-broccoli",
  "name": "Chopsuey with Chicken and Broccoli",
  "recipe_type": null,
  "brief_description": "Saut\u00e9ed vegetables with chicken, broccoli, and boiled egg",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil on a pan. Saute onion until layers separate."
    },
    {
      "position": 2,
      "text": "Add garlic. Continue saut\u00e9ing until the onion starts to soften."
    },
    {
      "position": 3,
      "text": "Add chicken, stir fry until the outer part turns light brown."
    },
    {
      "position": 4,
      "text": "Pour soy sauce, oyster sauce, and water. Stir. Cover the pan and let the liquid boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Chicken Cube. Stir. Cover and cook using medium heat until the sauce reduces to half."
    },
    {
      "position": 6,
      "text": "Add the carrot. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Pour the cornstarch and water mixture. Stir."
    },
    {
      "position": 8,
      "text": "Add your corn, cauliflower, bell pepper, broccoli, snow peas, and cabbage. Toss. Cover and cook for 1 \u00bd minutes."
    },
    {
      "position": 9,
      "text": "Toss and season with ground black pepper and salt."
    },
    {
      "position": 10,
      "text": "Add boiled quail eggs."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
