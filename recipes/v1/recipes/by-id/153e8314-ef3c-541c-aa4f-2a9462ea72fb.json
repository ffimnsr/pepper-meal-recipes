  "id": "153e8314-ef3c-541c-aa4f-2a9462ea72fb",
  "slug": "creamy-garlic-salmon-with-tomato-and-spinach",
  "name": "Creamy Garlic Salmon",
  "recipe_type": "main",
  "brief_description": "Pan-fried Salmon fillet cooked in rich and creamy garlic sauce with tomato and spinach.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt on the salmon filet. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil. Pan-fry the salmon for 3 to 4 minutes per side. Remove from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Melt butter on a clean pan. Saute onion and garlic."
    },
    {
      "position": 4,
      "text": "Pour white wine once the onion softens. Let boil."
    },
    {
      "position": 5,
      "text": "Add cherry tomato. Cover and cook until the wine reduces to half."
    },
    {
      "position": 6,
      "text": "Pour heavy whipping cream and add Parmesan cheese. Stir. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Put the fried salmon in the pan. Cook for 3 minutes using low heat."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper and salt (if needed)."
    },
    {
      "position": 9,
      "text": "Add Spinach. Turn off heat. Let the residual heat cook the spinach."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
