  "id": "d650a741-25eb-5b55-b4bf-617680db0fc6",
  "slug": "beef-and-tripe-pochero-recipe",
  "name": "Beef and Tripe Pochero Recipe",
  "recipe_type": null,
  "brief_description": "I love kare-kare and pochero. I like the ox tripe in kare-kare and I thought that it is be a good match with beef especially when cooked pochero style. I wanted the tripe and beef simmered until both gets really tender. That is something like this pochero dish that I made for you; the tripe and beef is so tender and delicious.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in the oil."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, saut\u00e9 the onion and garlic"
    },
    {
      "position": 3,
      "text": "Add the ox tripe and cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the beef and sliced sausage. Continue to cook for 2 to 3 minutes or until the color of the beef turns light brown."
    },
    {
      "position": 5,
      "text": "Pour-in the beef broth and tomato sauce. Let boil."
    },
    {
      "position": 6,
      "text": "Cover and simmer for 90 minutes or until the tripe and beef are tender. Add water if needed."
    },
    {
      "position": 7,
      "text": "Once the meat gets tender, make sure that there is enough liquid left. If the sauce is a bit thick, add more beef broth or water. Put the chickpeas, banana, and potato in the cooking pot and continue to cook for 10 to 12 minutes."
    },
    {
      "position": 8,
      "text": "Add the ground black pepper and fish sauce. Stir and cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Put the bok choy in the cooking pot. Stir and cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
