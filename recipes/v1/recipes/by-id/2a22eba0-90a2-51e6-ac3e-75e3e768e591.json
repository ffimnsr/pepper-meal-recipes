  "id": "2a22eba0-90a2-51e6-ac3e-75e3e768e591",
  "slug": "no-grill-pork-ribs-barbecue",
  "name": "No-Grill Pork Ribs Barbecue",
  "recipe_type": "main",
  "brief_description": "No grill? No problem! This No-Grill Pork Ribs Barbecue recipe is here to save the day with mouth-watering flavor. Try it now and let us know how it turns out!",
  "cuisine": "American Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the pork ribs in a mixing bowl. Add the marinade ingredients and mix well. Marinate for at least 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a pan. Fry the marinated pork ribs for 1\u00bd minutes per side. Set aside."
    },
    {
      "position": 3,
      "text": "Arrange all the fried ribs back in the pan. Pour in 2 cups of water and let it boil. Adjust the heat to a simmer, cover the pan, and continue cooking until the water evaporates completely. Remove the pork ribs from the pan and set them aside."
    },
    {
      "position": 4,
      "text": "Add all the barbecue sauce ingredients to the pan. Turn on the heat and stir. Bring it to a simmer."
    },
    {
      "position": 5,
      "text": "Add the pork ribs back to the pan. Toss until the ribs are completely coated with the barbecue sauce. Continue cooking for 2 minutes."
    },
    {
      "position": 6,
      "text": "Transfer the ribs to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "medium",
