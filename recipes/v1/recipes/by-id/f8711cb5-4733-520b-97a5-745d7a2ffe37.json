  "id": "f8711cb5-4733-520b-97a5-745d7a2ffe37",
  "slug": "cansi-recipe-ilonggo-bulalo-and-sinigang-in-one-delicious-soup-dish",
  "name": "Cansi Recipe (Ilonggo Bulalo and Sinigang in one Delicious Soup Dish)",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Cansi. It is a beef shank soup with unripe jackfruit in sour broth.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat Annatto oil in a soup pot or pressure cooker."
    },
    {
      "position": 2,
      "text": "Put the garlic in once the oil gets hot. Cook until the garlic turns light brown."
    },
    {
      "position": 3,
      "text": "Add the beef shank. Cook one side for 30 seconds to one minute. Turn it over to cook the other side for about the same time."
    },
    {
      "position": 4,
      "text": "Pour water. Let boil."
    },
    {
      "position": 5,
      "text": "Add the onion, tomato, and beef cube. Stir."
    },
    {
      "position": 6,
      "text": "Add the lemongrass. Cover the pressure cooker and cook for 30 minutes. Note: if using a regular soup pot, cook the beef in low heat for 2 to 3 hours. Add more water if needed."
    },
    {
      "position": 7,
      "text": "Safely remove the cover of the pressure cooker. Apply heat and bring the mixture to a boil."
    },
    {
      "position": 8,
      "text": "Stir-in the jackfruit and cook for 5 minutes."
    },
    {
      "position": 9,
      "text": "Add the peppers. Cook for 2 to 3 minutes."
    },
    {
      "position": 10,
      "text": "Pour the contents of the sinigang mix package. Stir. Add fish sauce. Cook for 3 to 5 minutes."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
