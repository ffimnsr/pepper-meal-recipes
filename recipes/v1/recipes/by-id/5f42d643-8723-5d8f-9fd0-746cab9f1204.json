  "id": "5f42d643-8723-5d8f-9fd0-746cab9f1204",
  "slug": "japanese-curry-recipe-battleship-curry",
  "name": "Japanese Curry Recipe",
  "recipe_type": "main",
  "brief_description": "Battleship curry is a type of Japanese beef curry served b the Japanese Navy during WWII",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Season beef with salt and pepper. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot. Add the butter and let it melt."
    },
    {
      "position": 3,
      "text": "Put the beef slices and stir-fry until it turns light brown in color."
    },
    {
      "position": 4,
      "text": "Add onion and garlic. Saut\u00e9 for 1 minute."
    },
    {
      "position": 5,
      "text": "Add the carrot and cook it for 2 minutes while stirring occasionally."
    },
    {
      "position": 6,
      "text": "Pour the water into the cooking pot. Let it boil."
    },
    {
      "position": 7,
      "text": "Add the Knorr Beef Cube, Curry Powder, Ketchup. Worcestershire sauce, and honey. Cover and Simmer for 15 minutes."
    },
    {
      "position": 8,
      "text": "Add the potato and continue to simmer for 12 minutes."
    },
    {
      "position": 9,
      "text": "Combine cornstarch with 3 tablespoons of water. Stir and pour into the pot. Stir."
    },
    {
      "position": 10,
      "text": "Add cheese and coffee."
    },
    {
      "position": 11,
      "text": "Season with salt and ground black pepper as needed."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
