  "id": "6d328e39-a799-54ed-b5fa-97c2d1f32115",
  "slug": "filipino-foodpork-fried-tofu-tokwat-baboy-recipe",
  "name": "Tokwat Baboy Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Filipino appetizer composed of fried tofu, boiled pork meat and ears, onion, and chili pepper, soaked in spiced vinegar.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour-in water in a pot and bring to a boil"
    },
    {
      "position": 2,
      "text": "Add salt and whole peppercorn"
    },
    {
      "position": 3,
      "text": "Put-in the pig's ears and pork belly then simmer until tender (about 30 mins to 1 hour)"
    },
    {
      "position": 4,
      "text": "Pour cooking oil on a separate pan and allow to heat"
    },
    {
      "position": 5,
      "text": "When the oil is hot enough, deep-fry the tofu until color turns golden brown and outer texture is somewhat crispy"
    },
    {
      "position": 6,
      "text": "Cube the fried tofu and slice the boiled pig's ears and pork belly into bite-sized pieces then set aside"
    },
    {
      "position": 7,
      "text": "Combine the vinegar sauce ingredients starting with sugar, salt, soy sauce, and vinegar. Stir."
    },
    {
      "position": 8,
      "text": "Microwave for 1 minute."
    },
    {
      "position": 9,
      "text": "Add the ground black pepper, onions, green onions, and chili pepper. Transfer the sauce in a serving bowl."
    },
    {
      "position": 10,
      "text": "Place the sliced meat and tofu in a serving plate with the bowl of sauce by the side"
    },
    {
      "position": 11,
      "text": "Serve hot! Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
  "difficulty": "hard",
