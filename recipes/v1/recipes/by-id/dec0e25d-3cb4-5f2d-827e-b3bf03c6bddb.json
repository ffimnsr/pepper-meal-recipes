  "slug": "sausage-peppers-and-onion-skillet",
  "name": "Sausage Peppers and Onion Skillet",
  "recipe_type": null,
  "brief_description": "This is a recipe for Sausage Peppers and Onion Skillet",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a skillet. Add oil."
    },
    {
      "position": 2,
      "text": "Pan fry both sides of the sliced bratwurst until fully cooked."
    },
    {
      "position": 3,
      "text": "Add peppers and onion. Cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add garlic powder and white wine. Stir. Continue to cook until wine evaporates."
    },
    {
      "position": 5,
      "text": "Sprinkle salt and ground black pepper."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
