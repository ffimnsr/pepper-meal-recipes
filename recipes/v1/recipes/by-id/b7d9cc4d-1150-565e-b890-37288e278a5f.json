  "id": "b7d9cc4d-1150-565e-b890-37288e278a5f",
  "slug": "cheese-fries-recipe",
  "name": "Cheese Fries",
  "recipe_type": "snack",
  "brief_description": "Baked cheese fries make a perfect snack or side dish. This is also a good way to give life to your homemade fries without frying it",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 370 degrees Fahrenheit"
    },
    {
      "position": 2,
      "text": "Arrange an aluminum foil on top of a baking tray. Spray with cooking oil."
    },
    {
      "position": 3,
      "text": "Arrange the frozen fries evenly on top of the foil. Bake the fries for about 30 minutes or until the outer part becomes crisp. Arrange in a plate. Set aside."
    },
    {
      "position": 4,
      "text": "Make the cheese sauce by melting butter in a sauce pan."
    },
    {
      "position": 5,
      "text": "Put-in the flour. Stir and cook until the color turns light brown."
    },
    {
      "position": 6,
      "text": "Pour-in milk. Stir and let boil."
    },
    {
      "position": 7,
      "text": "Add the Worcestershire sauce and shredded cheese. Stir and then cook until the cheese melts and the texture becomes smooth."
    },
    {
      "position": 8,
      "text": "Pour the cheese sauce on top of the baked fries. Sprinkle some bacon bits and green onions on top."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
