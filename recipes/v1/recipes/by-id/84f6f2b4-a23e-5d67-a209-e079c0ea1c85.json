  "id": "84f6f2b4-a23e-5d67-a209-e079c0ea1c85",
  "slug": "sausage-and-egg-waffle-sandwich",
  "name": "Sausage and Egg Waffle Sandwich",
  "recipe_type": "dessert",
  "brief_description": "Sausage and Egg Waffle Sandwich is very nice to have for breakfast. It will tastes even better with pancake syrup and butter.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine baking powder, all-purpose flour, salt, and sugar in a mixing bowl. Mix using a wire whisk."
    },
    {
      "position": 2,
      "text": "Beat the egg in another bowl while gradually pouring-in the milk, butter, and vanilla extract."
    },
    {
      "position": 3,
      "text": "Combine the egg mixture with the dry ingredients and mix well to incorporate."
    },
    {
      "position": 4,
      "text": "Preheat the waffle iron. When it becomes hot, scoop the mixture into it"
    },
    {
      "position": 5,
      "text": "Continue cooking until the waffles becomes crisp and golden brown. Set aside."
    },
    {
      "position": 6,
      "text": "Arrange the cooked sausage patty and egg in between 2 waffles. Place a slice of butter on top of the waffle and pour-in a little pancake syrup."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
