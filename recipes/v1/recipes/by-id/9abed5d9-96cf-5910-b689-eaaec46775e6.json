  "slug": "ginisang-okra-with-fish-flakes-recipe",
  "name": "Ginisang Okra with Fish Flakes Recipe",
  "recipe_type": null,
  "brief_description": "Most Filipino dishes are simple and easy to prepare. Ginisang Okra with Fish Flakes is one of these dishes. It is simply delicious.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Separate the fish from the bones using your fingers. Shred the fish and set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking in a large wok of frying pan."
    },
    {
      "position": 3,
      "text": "Once the oil gets really hot, saute the garlic and onion."
    },
    {
      "position": 4,
      "text": "Add the tomato and shredded fish. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Stir-in the sliced okra. Cook in high heat for 5 to 10 minutes."
    },
    {
      "position": 6,
      "text": "Add fish sauce and ground black pepper. Stir and cook for a 2 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
