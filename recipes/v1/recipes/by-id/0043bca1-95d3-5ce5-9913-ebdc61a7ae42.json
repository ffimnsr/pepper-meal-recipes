  "id": "0043bca1-95d3-5ce5-9913-ebdc61a7ae42",
  "slug": "bacon-and-cheese-breakfast-casserole-recipe",
  "name": "Bacon and Cheese Breakfast Casserole",
  "recipe_type": "breakfast",
  "brief_description": "A hearty breakfast casserole loaded with crispy bacon, melted Monterey Jack cheese, and fresh green onions. Easy to prepare and perfect for weekend brunches or holiday mornings.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350\u00b0F (175\u00b0C)."
    },
    {
      "position": 2,
      "text": "Arrange bacon in a large skillet and cook over medium heat until crisp. Transfer to a paper towel-lined plate to drain, then crumble and set aside."
    },
    {
      "position": 3,
      "text": "In a large mixing bowl, whisk together eggs, milk, salt, and pepper until well combined. Stir in the shredded cheese."
    },
    {
      "position": 4,
      "text": "Add the crumbled bacon and chopped green onions to the egg mixture, stirring to distribute evenly."
    },
    {
      "position": 5,
      "text": "Pour the mixture into a greased 9x13 inch baking dish. Cover tightly with aluminum foil that has been lightly greased on the underside (to prevent sticking)."
    },
    {
      "position": 6,
      "text": "Bake for 40 minutes, or until the eggs are set and a knife inserted in the center comes out clean."
    },
    {
      "position": 7,
      "text": "Remove from oven and let cool for 5 minutes before serving. Cut into portions and serve warm."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 5,
