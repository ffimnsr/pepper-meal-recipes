  "id": "0043bca1-95d3-5ce5-9913-ebdc61a7ae42",
  "slug": "bacon-and-cheese-breakfast-casserole-recipe",
  "name": "Bacon and Cheese Breakfast Casserole Recipe",
  "recipe_type": "breakfast",
  "brief_description": "This is one of my favorite breakfast casserole recipe. Bacon and Cheese Breakfast Casserole is easy to prepare and is really good",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the bacon in a pan. Cook until crisp. Set Aside."
    },
    {
      "position": 2,
      "text": "In a mixing bowl, combine eggs, milk, salt, pepper, and cheese. Mix well."
    },
    {
      "position": 3,
      "text": "Crumble the bacon strips and add to the egg mixture along with the green onions. Stir."
    },
    {
      "position": 4,
      "text": "Preheat oven to 350 Fahrenheit."
    },
    {
      "position": 5,
      "text": "Pour the mixture into a baking dish. Cover the dish with a greased aluminum foil (greased side down)."
    },
    {
      "position": 6,
      "text": "Bake for 40 minutes or until the eggs are done."
    },
    {
      "position": 7,
      "text": "Remove from the oven. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
