  "id": "1d012557-5cc9-5bc3-b74b-93f53f76b3bd",
  "slug": "pork-giniling-quail-eggs",
  "name": "Pork Giniling with Quail Eggs",
  "recipe_type": null,
  "brief_description": "Got any idea for a simple and delicious meal for lunch yet? How about checking out this Pork Giniling with Quail Eggs recipe? This is another version of our popular pork giniling.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute the onion."
    },
    {
      "position": 3,
      "text": "Once the onion becomes soft, add the ground pork. Saute until the pork turns light brown."
    },
    {
      "position": 4,
      "text": "Add the garlic powder and raisins. Stir."
    },
    {
      "position": 5,
      "text": "Pour the tomato sauce and beef broth in the cooking pot. Stir. Cover and cook in low to medium heat for 25 to 30 minutes."
    },
    {
      "position": 6,
      "text": "Add the carrots and green peas. Stir. Cover and cook for 7 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the salt and pepper. Add the quail eggs and then gently stir. Cook for a minute more."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
