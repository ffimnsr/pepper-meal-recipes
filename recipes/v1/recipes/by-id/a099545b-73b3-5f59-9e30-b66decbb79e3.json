  "id": "a099545b-73b3-5f59-9e30-b66decbb79e3",
  "slug": "how-to-make-grilled-chicken-and-spinach-salad",
  "name": "Grilled Chicken and Spinach Salad Recipe",
  "recipe_type": "salad",
  "brief_description": "This Grilled Chicken and Spinach Salad Recipe is a healthy option for lunch. It is low on fat and high in vitamins, protein, and nutrients.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine baby spinach, parmesan cheese, and 1 tablespoon olive oil then toss."
    },
    {
      "position": 2,
      "text": "Arrange spinach in a serving plate. Set aside."
    },
    {
      "position": 3,
      "text": "Season chicken with thyme, salt, and ground black pepper. Let stand for at least 30 minutes"
    },
    {
      "position": 4,
      "text": "Grill the chicken for 5 minutes per side."
    },
    {
      "position": 5,
      "text": "While grilling, pour remaining olive oil in a pan and caramelize the onion. Set aside."
    },
    {
      "position": 6,
      "text": "Arrange the grilled chicken strips over the spinach and top with caramelized onions."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 10,
