  "id": "3ff89a6a-4901-5942-b9f4-d38d6bb82aa5",
  "slug": "scotch-eggs",
  "name": "Scotch Eggs Recipe",
  "recipe_type": null,
  "brief_description": "Scotch Eggs are hard boiled eggs covered with a ground pork mixture (usually sausage meat mixture) that are dredged in bread crumbs and fried until golden brown.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine ground pork, salt, pepper, sugar, garlic powder, sherry, Worcestershire sauce, and flour. Mix well."
    },
    {
      "position": 2,
      "text": "Scoop an ample amount of ground pork mixture and shape around the hard boiled egg until the egg is fully covered."
    },
    {
      "position": 3,
      "text": "Dip the egg with ground pork in the beaten egg mixture, and then roll on the Panko bread crumbs until fully coated."
    },
    {
      "position": 4,
      "text": "Heat a deep cooking pot and pour-in cooking oil."
    },
    {
      "position": 5,
      "text": "When the oil becomes hot, deep fry the coated eggs until the color turns golden brown. Note: Do not wait for the oil to smoke before deep frying. This will easily burn the bread crumbs. Fry using medium heat."
    },
    {
      "position": 6,
      "text": "Transfer the cooked eggs in a plate lined with paper towels. Let excess oil drip."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
