  "id": "000a3a92-fc5f-51d0-8a32-0dc27fc278f4",
  "slug": "chili-oil",
  "name": "Chili Oil",
  "recipe_type": "condiment",
  "brief_description": "A fragrant, spicy oil-based condiment made with minced Thai chili peppers, garlic, and aromatic spices. Perfect as a dipping sauce or for adding heat to dishes.",
  "cuisine": "Chinese-Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine Thai chili peppers and garlic in a food processor. Blitz for 1 minute or until the ingredients are finely chopped."
    },
    {
      "position": 2,
      "text": "Pour the canola oil into a wok, then add the chili and garlic mixture. Turn on the stove and adjust the heat to maintain a gentle simmer. Continue cooking the mixture for 10 minutes, stirring occasionally."
    },
    {
      "position": 3,
      "text": "Add the star anise and dried bay leaves. Continue cooking the mixture for 30 minutes, stirring every 2 minutes to prevent burning."
    },
    {
      "position": 4,
      "text": "Remove the bay leaves and star anise from the wok."
    },
    {
      "position": 5,
      "text": "Pour in the rice vinegar, stir well, and continue simmering for 10 minutes."
    },
    {
      "position": 6,
      "text": "Turn off the heat. Add the brown sugar, oyster sauce, and Maggi Magic Sarap. Stir until dissolved and let the chili oil cool completely."
    },
    {
      "position": 7,
      "text": "Transfer to clean mason jars or airtight containers. Store at room temperature for up to a few weeks, or refrigerate to extend the shelf life."
    },
    {
      "position": 8,
      "text": "Serve as a condiment or use as an ingredient to spice up your dishes. Enjoy!"
    }
  ],
  "servings": 10,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
