  "id": "000a3a92-fc5f-51d0-8a32-0dc27fc278f4",
  "slug": "chili-oil",
  "name": "Chili Oil",
  "recipe_type": null,
  "brief_description": "Oil based minced chili pepper condiment",
  "cuisine": "Chinese Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Combine Thai chili pepper and garlic in a food processor. Blitz for 1 minute or until the ingredients are finely chopped."
    },
    {
      "position": 2,
      "text": "Pour the canola oil in a wok and then add the chili and garlic mixture. Turn on the stove. Adjust the heat to a simmer. Continue cooking the mixture for 10 minutes while occasionally stirring."
    },
    {
      "position": 3,
      "text": "Add star anise and dried bay leaves. Continue cooking the mixture for 30 minutes. Note: Stir the mixture every 2 minutes."
    },
    {
      "position": 4,
      "text": "Remove the bay leaves and star anise."
    },
    {
      "position": 5,
      "text": "Pour the rice vinegar. Stir and continue simmering for 10 minutes."
    },
    {
      "position": 6,
      "text": "Turn off the stove. Add brown sugar, oyster sauce, and Maggi Magic Sarap. Stir and let the chili oil cool down."
    },
    {
      "position": 7,
      "text": "Transfer it to individual mason jars. You can let keep it in room temperature for a few weeks or refrigerate to extend the shelf life."
    },
    {
      "position": 8,
      "text": "Serve as a condiment or use as an ingredient to spice-up your dish. Enjoy!"
    }
  ],
  "servings": 10,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
