  "id": "a667bc8d-ede5-536b-be1b-c57351c3556c",
  "slug": "bulanglang",
  "name": "Bulanglang Recipe",
  "recipe_type": null,
  "brief_description": "This is a healthy bulanglang recipe.it is a dish composed of different types of vegetables that are boiled together.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour-in rice washing. Let boil."
    },
    {
      "position": 2,
      "text": "Add garlic, ginger, and lemongrass. Boil for 5 to 7 minutes."
    },
    {
      "position": 3,
      "text": "Remove the lemongrass. Add papaya and calabaza squash. Boil for 6 minutes."
    },
    {
      "position": 4,
      "text": "Add tomatoes, okra, and loofah. Cook for 3 to 4 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the malunggay and salt. Stir. Turn the heat off."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl and serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
