  "slug": "yang-chow-fried-rice",
  "name": "Yang Chow Fried Rice Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Yang Chow Fried Rice",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil and saut\u00e9 ginger and garlic."
    },
    {
      "position": 2,
      "text": "Add shrimps and cook for a minute. Remove the shrimps and set aside."
    },
    {
      "position": 3,
      "text": "Pour-in the beaten egg mixture and cook."
    },
    {
      "position": 4,
      "text": "When the egg is cooked, divide into small pieces. Add the rice and mix well."
    },
    {
      "position": 5,
      "text": "Put-in the soy sauce, sugar, and salt. Mix with the other ingredients."
    },
    {
      "position": 6,
      "text": "Add barbecued pork. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add green peas and shrimp. Cook for another 3 minutes."
    },
    {
      "position": 8,
      "text": "Put-in the green onions. Cook for 2 minutes while mixing with the other ingredients."
    },
    {
      "position": 9,
      "text": "Turn the heat off and then transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
