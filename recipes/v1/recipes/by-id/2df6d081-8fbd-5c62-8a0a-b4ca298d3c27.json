  "id": "2df6d081-8fbd-5c62-8a0a-b4ca298d3c27",
  "slug": "how-to-cook-chicken-fajita",
  "name": "Chicken Fajita Recipe",
  "recipe_type": null,
  "brief_description": "This Delicious Sizzling Chicken Fajita Recipe is worth your try. You will surely enjoy eating this dish. Get the free recipe and try it today!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, combine all the marinade ingredients then mix."
    },
    {
      "position": 2,
      "text": "Put the chicken breast slices in the mixing bowl then cover with marinade. Let stand for at least 1 hour."
    },
    {
      "position": 3,
      "text": "Grill the chicken for 3 to 4 minutes."
    },
    {
      "position": 4,
      "text": "Heat a cooking pan and pour-in 1 tablespoon of olive oil."
    },
    {
      "position": 5,
      "text": "When the oil becomes hot, put-in the onion and bell peppers then stir. Cook for a minute."
    },
    {
      "position": 6,
      "text": "Add the grilled chicken and cook for 2 to 4 minutes more."
    },
    {
      "position": 7,
      "text": "Meanwhile, heat a fajita plate (sizzling plate) then transfer the cooked Chicken Fajitas."
    },
    {
      "position": 8,
      "text": "Serve with hot flour tortillas, sour cream, and salsa."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 10,
