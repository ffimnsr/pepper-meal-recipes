  "id": "7beed90e-e065-52c5-87d7-7a54102afbce",
  "slug": "sotanghon-overload",
  "name": "Sotanghon Overload",
  "recipe_type": "main",
  "brief_description": "Filipino Pancit Sotanghon with loaded toppings",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil the pork belly in 1 quart of water for 40 minutes. Remove the pork belly and let it cool down. Slice it into serving pieces and set it aside, along with the pork stock."
    },
    {
      "position": 2,
      "text": "Soak the vermicelli in 1 quart of water for 8 minutes. Drain the water and set the vermicelli aside."
    },
    {
      "position": 3,
      "text": "Prepare the toasted garlic by combining \u00bd cup of cooking oil and 1 head of minced garlic in a wok. Heat the wok and slowly fry the garlic while stirring occasionally until it turns golden brown. Separate the toasted garlic from the oil using a kitchen strainer and set both the toasted garlic and the garlic-infused oil aside."
    },
    {
      "position": 4,
      "text": "Heat 3 \u00bd tablespoons of garlic-infused oil in a wok. Saut\u00e9 the onion and the white part of the scallion until they soften."
    },
    {
      "position": 5,
      "text": "Add the chicken and saut\u00e9 for 40 seconds or until it turns light brown."
    },
    {
      "position": 6,
      "text": "Add the chorizo and sliced pork, and continue saut\u00e9ing for 2 minutes."
    },
    {
      "position": 7,
      "text": "Pour in the soy sauce, oyster sauce, and 1 \u00bd cups of pork stock. Let it boil."
    },
    {
      "position": 8,
      "text": "Remove the meat from the wok. Add the annatto powder, carrots, bell peppers, and cabbage. Cook for 30 seconds."
    },
    {
      "position": 9,
      "text": "Add the soaked vermicelli to the wok and toss until all ingredients are well blended."
    },
    {
      "position": 10,
      "text": "Cover and continue cooking on low heat for 5 minutes."
    },
    {
      "position": 11,
      "text": "Toss the noodles, then add half of the chopped scallions and season with fish sauce and ground black pepper."
    },
    {
      "position": 12,
      "text": "Add the boiled quail eggs and half of the meat ingredients. Toss to combine."
    },
    {
      "position": 13,
      "text": "Transfer to a serving plate. Top with the remaining meat and chopped scallions, and sprinkle the toasted garlic on top."
    },
    {
      "position": 14,
      "text": "Serve with calamansi, and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 15,
