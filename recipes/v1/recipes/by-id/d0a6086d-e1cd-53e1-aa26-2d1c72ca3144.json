  "id": "d0a6086d-e1cd-53e1-aa26-2d1c72ca3144",
  "slug": "lasagna-roll-ups",
  "name": "Lasagna Roll-Ups",
  "recipe_type": "main",
  "brief_description": "Meaty lasagna with 3 cheese filling rolled and baked to perfection",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 6 cups water in a cooking pot. Add salt and put-in the lasagna sheets. Cook it according to package instructions. Drain the water and set aside the lasagna."
    },
    {
      "position": 2,
      "text": "Make the meat sauce by browning the ground beef in a cooking pot. Add onion and garlic. Continue cooking until the onion softens."
    },
    {
      "position": 3,
      "text": "Pour the marinara sauce into the pot. Stir and let the mixture boil. Add Knorr beef cube. Reduce the heat to a simmer and cook for 8 to 10 minutes. Season with salt and ground black pepper. Set aside."
    },
    {
      "position": 4,
      "text": "Combine all the cheese filling ingredient in a bowl. Mix well. Set aside."
    },
    {
      "position": 5,
      "text": "Arrange the lasagna on a flat surface. Scoop around 3 to 4 tablespoons of cheese filling mixture and spread it over each lasagna sheet. Spread around 2 tablespoons of meat mixture over it."
    },
    {
      "position": 6,
      "text": "Spread \u00bd cup of meat sauce on your baking pan. Roll each lasagna sheet and arrange it on the pan. Top with remaining meat sauce and sprinkle 1 cup mozzarella cheese over it. Cover the pan with aluminum foil. Bake in 375F for 30 minutes."
    },
    {
      "position": 7,
      "text": "Take the foil out and broil until cheese browns a bit. Remove from the oven and sprinkle parsley on top."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 15,
