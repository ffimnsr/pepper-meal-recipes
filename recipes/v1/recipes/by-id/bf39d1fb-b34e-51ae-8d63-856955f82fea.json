  "id": "bf39d1fb-b34e-51ae-8d63-856955f82fea",
  "slug": "chili-crab-with-snake-beans",
  "name": "Chili Crab with String Beans",
  "recipe_type": null,
  "brief_description": "Chili Crab with Snake Beans is my version of the famous chili crab dish with one of my favorite vegetable: Sitaw also known as string beans and snake beans",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken broth, soy sauce, ketchup, and cornstarch in a bowl. Stir to mix. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the oil in a wok or large pan. Once the oil gets hot, saute the garlic, onion, and ginger."
    },
    {
      "position": 3,
      "text": "Once the onion gets soft, add the chili and snake beans. Stir fry in high heat for 2 to 3 minutes."
    },
    {
      "position": 4,
      "text": "Add the crab. Continue to stir fry for 5 minutes."
    },
    {
      "position": 5,
      "text": "Sprinkle salt and ground black pepper. Pour-in the chicken broth mixture and then toss to coat. Cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Pour the beaten egg and stir fry for 3 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with warm white rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
