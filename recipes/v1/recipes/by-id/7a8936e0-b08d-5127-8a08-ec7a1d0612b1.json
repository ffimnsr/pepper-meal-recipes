  "id": "7a8936e0-b08d-5127-8a08-ec7a1d0612b1",
  "slug": "kilawing-labanos",
  "name": "Kilawing Labanos Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Daikon radish marinated in vinegar with pork and pork liver.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the daikon radish into thin pieces. Arrange in a bowl and then add 2 tablespoons salt. Rub salt all over the radish slices and let is stay for 15 minutes. Squeeze the juice out of the radish. Rinse with water until all the salt goes off. Squeeze to release water."
    },
    {
      "position": 2,
      "text": "Combine prepared radish, pork, pork liver, sugar, onion, and white vinegar in a large bowl. Toss until well blended. Marinate for 20 minutes."
    },
    {
      "position": 3,
      "text": "Heat oil in a cooking pot. Saute garlic until golden brown."
    },
    {
      "position": 4,
      "text": "Add the marinated mixture. Let boil. Stir and then adjust the heat between low to medium. Cover the pot and continue to cook for 20 to 25 minutes."
    },
    {
      "position": 5,
      "text": "Season with salt and ground black pepper. Serve with warm white rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
