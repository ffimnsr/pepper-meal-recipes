  "id": "bf892a4d-9cba-5ef2-88bb-94da6a823c56",
  "slug": "grilled-calamari-recipe",
  "name": "Grilled Calamari",
  "recipe_type": null,
  "brief_description": "Grilled Calamari are marinated squid which are skewered and grilled to perfection. This is a good recipe to try that involves the grill.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine soy sauce, Sriracha sauce, sugar, lemon juice, salt, and pepper in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Place the squid inside a freezer bag and then pour-in the soy sauce mixture. Marinate for 1 hour."
    },
    {
      "position": 3,
      "text": "Skewer the squid in bamboo skewers. Grill for about 3 to 5 minutes per side. Baste with remaining marinade."
    },
    {
      "position": 4,
      "text": "Transfer to a serving plate"
    },
    {
      "position": 5,
      "text": "Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 60,
