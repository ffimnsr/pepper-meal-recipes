  "id": "cc95bfa0-6743-52f8-a2d0-0d2480db45b0",
  "slug": "easy-beef-stroganoff",
  "name": "Beef Stroganoff",
  "recipe_type": null,
  "brief_description": "Beef strips with mushroom cooked in a creamy sauce with sour cream",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Season beef with salt and ground black pepper. Mix well. Add flour and continue to mix until the beef gets completely coated. Let it stand for 10 minutes."
    },
    {
      "position": 2,
      "text": "Melt butter in a pan. Add olive oil. Pan-fry beef until color turns light brown. Remove beef from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Saute onion in the remaining oil and butter. Add mushroom. Continue to cook until mushroom softens."
    },
    {
      "position": 4,
      "text": "Add beef. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour cream of mushroom soup and beef broth. Stir. Continue cooking in medium heat until the sauce reduces to half."
    },
    {
      "position": 6,
      "text": "Season with more ground black pepper. Add sour cream. Stir until all ingredients are well distributed."
    },
    {
      "position": 7,
      "text": "Top over rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
