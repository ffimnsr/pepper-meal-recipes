{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "bf4b3ec6-21eb-54b3-bb5c-ca7b1b272170",
  "slug": "pork-dinakdakan-recipe-knr_kls",
  "name": "Pork Dinakdakan Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for pork dinakdakan using pork belly.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Add pork belly. Cover and continue to boil in medium heat for 30 to 35 minutes."
    },
    {
      "position": 3,
      "text": "Remove the pork belly from the pot. Let it cool. Note: you may use the pork stock (water used to boil liempo) to cook other dishes."
    },
    {
      "position": 4,
      "text": "Rub 1 teaspoon salt and \u00bd teaspoon ground black pepper over the pork belly. Let it stay for 10 minutes."
    },
    {
      "position": 5,
      "text": "Heat-up the grill. Grill each side for a total of 6 minutes. Note: I usually grill one side for 2 minutes, turn the belly over and grill the opposite side for the same time. The process is repeated 2 to 3 times. This will prevent the pork belly from being burnt."
    },
    {
      "position": 6,
      "text": "Slice the pork belly into thin pieces and arrange in a large mixing bowl."
    },
    {
      "position": 7,
      "text": "Prepare the dressing by combining mayonnaise, Knorr Liquid Seasoning, lime juice, and onion powder in a small bowl. Stir until well blended. Set aside."
    },
    {
      "position": 8,
      "text": "Put the onion and chili peppers on the bowl with the sliced pork belly. Toss."
    },
    {
      "position": 9,
      "text": "Add the dressing. Continue to toss until well blended. Add Salt and pepper to taste."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve!"
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
