  "id": "aff74b25-cc95-5bb0-add3-8307eb0dfc09",
  "slug": "how-to-make-crispy-fried-chicken-spicy-version",
  "name": "Crispy Fried Chicken (Spicy Version)",
  "recipe_type": "side",
  "brief_description": "Crispy fried chicken that is tender and moist in the inside. This is simply delicious.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the brine by boiling 2 cups water. Add salt. Stir until diluted. Add rosemary. Boil for 1 minute. Turn the heat off. Add ice cubes."
    },
    {
      "position": 2,
      "text": "Arrange chicken in a large bowl. Pour-in brine solution. Cover the bowl. Refrigerate for 8 hours."
    },
    {
      "position": 3,
      "text": "Drain the brine solution and rinse the chicken by washing with water. Pat dry using a paper towel. Set aside."
    },
    {
      "position": 4,
      "text": "Make the breading by sifting the following ingredients in a large bowl: flour, cornstarch, baking powder, garlic powder, ground white pepper, onion powder, and cayenne pepper powder. Mix well using a wire whisk. Set aside."
    },
    {
      "position": 5,
      "text": "Make the batter by whisking 2 pieces of eggs on a separate bowl. Add \u00bd cup water. Continue whisking until well blended."
    },
    {
      "position": 6,
      "text": "Scoop around 35% of the breading mixture to the bowl where the eggs are. Whisk until the texture becomes smooth. Set aside."
    },
    {
      "position": 7,
      "text": "Dredge the chicken pieces in the breading mixture. Dip in batter and dredge once again on the breading. Arrange on a clean plate. Set aside. We are now ready to fry."
    },
    {
      "position": 8,
      "text": "Heat 3 cups of oil in a cooking pot. Once the temperature reaches 350F, deep fry the chicken pieces for 12 to 15 minutes or until the internal temperature reaches 165F. Note: it is best to fry in batches of 2 to 3 pieces at a time."
    },
    {
      "position": 9,
      "text": "Remove the fried chicken from the pot and place on a wire rack. Let excess oil drip."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve! Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 14,
  "preparation_time_minutes": 480,
