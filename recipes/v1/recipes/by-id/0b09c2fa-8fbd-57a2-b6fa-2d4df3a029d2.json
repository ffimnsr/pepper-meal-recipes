  "id": "0b09c2fa-8fbd-57a2-b6fa-2d4df3a029d2",
  "slug": "egg-foo-young-recipe",
  "name": "Egg Foo Young Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Egg Foo Young",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Make the sauce. Heat a saucepan and pour-in the chicken broth then let boil. Add the soy sauce and oyster sauce then stir. Pour-in the cornstarch diluted in water then cook until the texture becomes thick. Turn-off heat and transfer to a bowl. Set aside."
    },
    {
      "position": 2,
      "text": "Spray or pour a little cooking oil in a frying pan and turn on heat."
    },
    {
      "position": 3,
      "text": "When the oil is hot enough, saut\u00e9 the ground pork for 5 minutes"
    },
    {
      "position": 4,
      "text": "Add the minced shrimps and saut\u00e9 for 2 minutes more."
    },
    {
      "position": 5,
      "text": "Turn of the heat and transfer the ground pork and minced shrimps in a bowl. Let cool."
    },
    {
      "position": 6,
      "text": "In a large mixing bowl, beat the eggs then add the cooking rice wine, salt, ground black pepper, onion, leeks, mushrooms, mung bean sprouts, red bell pepper, cooked ground pork, and cooked minced shrimps. Mix thoroughly."
    },
    {
      "position": 7,
      "text": "Heat a cooking pot then pour-in the cooking oil."
    },
    {
      "position": 8,
      "text": "When the oil is hot enough, pour about 1/2 to 3/4 cups of the mixture using a ladle. Cook each side for about 3 to 4 minutes or until the color turns brown. Flip to cook the other side."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate then top with the sauce and some chopped leeks."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
