  "id": "a2b5d897-7a46-531c-9643-89fa89d1e65a",
  "slug": "sous-vide-strip-steak-recipe",
  "name": "Sous Vide Strip Steak Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Sous Vide New York Strip Steak",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour enough water in a heat-safe food storage container or a pot. Set the sous vide cooker and the preheat to 133F."
    },
    {
      "position": 2,
      "text": "Arrange strip steak in a resealable freezer bag. Take all the air out of the bag using the water displacement method. Seal the bag."
    },
    {
      "position": 3,
      "text": "Soak the freezer bag with steak into the container. Sous vide cook it for 3 hours."
    },
    {
      "position": 4,
      "text": "Remove the steaks from the bag. Let it cool down. Rub salt and pepper all over it. Let it stay for 5 minutes."
    },
    {
      "position": 5,
      "text": "Heat the grill (set it to high preferably). Quickly grill one side of the steak until it turns brown. Turn it over and do the same step on the opposite side. Note: It only takes a few minutes to grill the steaks since these were already cooked"
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with mashed potato or any side dishes that you like."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 190,
