  "id": "226fe1b7-5674-581a-bfe7-352489205a4e",
  "slug": "tuna-jaw-sinigang",
  "name": "Sinigang na Panga ng Tuna Recipe (Tuna jaw cooked in sour broth)",
  "recipe_type": "soup",
  "brief_description": "Sour Filipino tuna jaw soup simmered in tamarind broth with okra, eggplant, string beans, water spinach, and fresh chilies.",
  "cuisine": "Asian Filipino Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour-in the water. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Put-in the onions and tomatoes and cook until tender."
    },
    {
      "position": 3,
      "text": "Put-in the tuna jaw and simmer for 15 minutes"
    },
    {
      "position": 4,
      "text": "Add the sinigang mix, chilies, and eggplant.Simmer for 3 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the okra and string beans and cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Mix-in the water spinach. Season with fish sauce. Turn the heat off, cover the pot, and allow residual heat to completely cook the water spinach."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl and serve hot."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
