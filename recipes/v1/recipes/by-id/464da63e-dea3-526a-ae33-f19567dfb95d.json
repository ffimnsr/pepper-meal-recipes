  "id": "464da63e-dea3-526a-ae33-f19567dfb95d",
  "slug": "ampalaya-con-carne-beef-stir-fry-bitter-gourd",
  "name": "Ampalaya Con Carne Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for stir-fried beef with bitter melon.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Combine beef sirloin, ground black pepper, soy sauce, sesame oil, and oyster sauce. Mix well. Add cornstarch and then continue to mix until all ingredients are well distributed. Marinate for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot. Add the marinated beef sliced. Cook both sides for 30 seconds. Stir-fy the beef for 3 minutes. Set aside."
    },
    {
      "position": 3,
      "text": "Saute the ginger and garlic using the remaing oil. Add onion and continue to cook until it softens."
    },
    {
      "position": 4,
      "text": "Put the ampalaya into the pan. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Add the beef back into the pan. Add water. Cover and let boil. Cook in medium heat for 5 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
