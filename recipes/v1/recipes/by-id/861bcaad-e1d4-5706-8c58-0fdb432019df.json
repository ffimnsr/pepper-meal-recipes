  "id": "861bcaad-e1d4-5706-8c58-0fdb432019df",
  "slug": "hoisin-glazed-salmon-recipe",
  "name": "Hoisin Glazed Salmon",
  "recipe_type": null,
  "brief_description": "Hoisin Glazed Salmon is a type of baked salmon dish that was marinated in a mixture of hosing sauce, Sriracha sauce, and other seasonings.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine Hoisin sauce, lemon juice, soy sauce, garlic powder, Sriracha sauce, ginger, and EV olive oil in a bowl. Stir until the mixture is well incorporated."
    },
    {
      "position": 2,
      "text": "Arrange the salmon fillets inside a resealable freezer bag. Pour-in the mixture inside the bag. Make sure that the mixture coats the salmon."
    },
    {
      "position": 3,
      "text": "Place the bag in a flat surface then gently push the air out of the bag and seal it. Refrigerate for 1 hour."
    },
    {
      "position": 4,
      "text": "Preheat the oven to 350 degrees Fahrenheit."
    },
    {
      "position": 5,
      "text": "Grease a baking tray by spraying or spreading a small amount of cooking oil. Arrange the marinated salmon on the tray.Scoop the remaining marinade and pour it over each salmon fillet."
    },
    {
      "position": 6,
      "text": "Bake for about 28 to 32 minutes."
    },
    {
      "position": 7,
      "text": "Remove from the oven. Let the temperature cool down."
    },
    {
      "position": 8,
      "text": "Arrange in a serving plate along with your favorite salad side dish."
    },
    {
      "position": 9,
      "text": "Serve. share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 28,
  "preparation_time_minutes": 5,
