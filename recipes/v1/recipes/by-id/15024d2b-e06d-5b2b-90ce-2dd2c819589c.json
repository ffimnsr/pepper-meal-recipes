  "id": "15024d2b-e06d-5b2b-90ce-2dd2c819589c",
  "slug": "kare-kare-tripas-recipe",
  "name": "Kare Kare Tripas",
  "recipe_type": null,
  "brief_description": "Kare Kare Tripas is a variation of the delicous Filipino Kare Kare (peanut stew) using ox tripe or tripas.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the tripe, onion, crushed peanuts, annatto water, 1cup water (or beef broth), and beef powder in a pressure cooker or cooking pot."
    },
    {
      "position": 2,
      "text": "Apply heat then stir to mix the ingredient. If using a pressure cooker, cover the pressure cooker and pressure-cook the tripe for 35 to 40 minutes. If using an ordinary cooking pot, you will need to simmer the tripe for 120 to 150 minutes or until tender."
    },
    {
      "position": 3,
      "text": "While cooking the tripe, prepare the vegetables by boiling 4 cups of water in a separate cooking pot. Blanch the eggplant and string beans followed by the bok choy. Boil the banana blossoms for 3 to 5 minutes. Strain and then place in a plate; set aside."
    },
    {
      "position": 4,
      "text": "Once the tripe is tender, add the peanut butter and glutinous rice flour (diluted). Stir and continue to cook until the texture of the sauce reaches the desired texture."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Arrange the blanched vegetables on the side."
    },
    {
      "position": 6,
      "text": "Serve with bagoong. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
