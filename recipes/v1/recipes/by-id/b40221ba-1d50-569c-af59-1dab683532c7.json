  "id": "b40221ba-1d50-569c-af59-1dab683532c7",
  "slug": "lutong-bahay-atay-liver-steak-recipe",
  "name": "Liver Steak Recipe",
  "recipe_type": null,
  "brief_description": "Liver Steak is marinated fried liver in soy sauce, lemon, and onion sauce. The method of cooking this dish is similar to that of Bistek tagalog.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Marinate the liver in lemon juice, soy sauce, salt, and ground black pepper for a minimum of 1 hour"
    },
    {
      "position": 2,
      "text": "Pour the cooking oil in a pan and apply heat"
    },
    {
      "position": 3,
      "text": "Put-in the garlic and fry until color turns golden brown. Set aside."
    },
    {
      "position": 4,
      "text": "On the same pan with the remaining cooking oil, fry the both sides of the liver (do not overcook ) then set aside."
    },
    {
      "position": 5,
      "text": "Put the onions in the pan where the liver was fried and cook until texture becomes soft"
    },
    {
      "position": 6,
      "text": "Add the marinade and simmer for 5 to 7 minutes or until sauce becomes thick"
    },
    {
      "position": 7,
      "text": "Pour the sauce with onions over the fried liver and garnish with fried garlic"
    },
    {
      "position": 8,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
