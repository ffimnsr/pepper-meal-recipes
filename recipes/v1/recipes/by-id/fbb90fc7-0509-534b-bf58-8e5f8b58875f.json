  "id": "fbb90fc7-0509-534b-bf58-8e5f8b58875f",
  "slug": "chop-suey",
  "name": "Chop Suey",
  "recipe_type": null,
  "brief_description": "This is a perfect dish for vegetable lovers. Chop suey is a dish made using a variety of veggies including snow peas, young corn, cabbage, and bell peppers. There is also a protein and seafood component in it. I went the extra mile by adding boiled and cute quail eggs. It was so good.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok or pan."
    },
    {
      "position": 2,
      "text": "Pan fry the shrimp for 1 minute per side. Remove from the wok. Set aside."
    },
    {
      "position": 3,
      "text": "Saute onion. Add garlic and continue to saute until the onion becomes soft."
    },
    {
      "position": 4,
      "text": "Add pork and chicken. Stir fry until light brown."
    },
    {
      "position": 5,
      "text": "Add soy sauce and oyster sauce. Stir."
    },
    {
      "position": 6,
      "text": "Pour water. Let boil. Cover and cook in medium heat for 15 minutes."
    },
    {
      "position": 7,
      "text": "Add cauliflower, carrots, bell peppers, snow peas, and young corn. Stir."
    },
    {
      "position": 8,
      "text": "Add cabbage. Toss. Cover and cook for 5 to 7 minutes."
    },
    {
      "position": 9,
      "text": "Put the pan-fried shrimp into the pot and add ground black pepper."
    },
    {
      "position": 10,
      "text": "Add the boiled quail eggs and cornstarch diluted in water. Toss."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
