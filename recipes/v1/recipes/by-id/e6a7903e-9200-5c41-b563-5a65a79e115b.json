  "id": "e6a7903e-9200-5c41-b563-5a65a79e115b",
  "slug": "ginataang-bangus",
  "name": "Ginataang Bangus",
  "recipe_type": "main",
  "brief_description": "Ginataang Bangus is a classic Filipino dish featuring crispy pan-fried milkfish simmered in rich coconut milk with string beans, Thai chili peppers, and shrimp paste. This savory and creamy recipe comes together quickly and pairs perfectly with steamed white rice.",
  "cuisine": "Asian Filipino Southeast Asian",
  "instructions": [
    {
      "position": 1,
      "text": "Season the bangus with Maggi Magic Sarap."
    },
    {
      "position": 2,
      "text": "Dredge the fish in all-purpose flour, making sure it is evenly coated. Set aside."
    },
    {
      "position": 3,
      "text": "Heat the cooking oil in a pan. Fry the bangus until both sides turn light to medium brown. Remove from the pan and set aside."
    },
    {
      "position": 4,
      "text": "Using 2 tablespoons of the oil from frying the fish, stir-fry the string beans for about 90 seconds. Remove and set aside."
    },
    {
      "position": 5,
      "text": "Add another 2 tablespoons of oil to the pan. Saut\u00e9 the garlic until it starts to brown, then add the onion and ginger. Continue cooking until the onion softens."
    },
    {
      "position": 6,
      "text": "Add the shrimp paste and Thai chili peppers. Saut\u00e9 for 30 seconds."
    },
    {
      "position": 7,
      "text": "Pour in the coconut milk and let it come to a boil."
    },
    {
      "position": 8,
      "text": "Add the fried bangus and string beans. Lower the heat and simmer for 5 minutes."
    },
    {
      "position": 9,
      "text": "Season with fish sauce and ground black pepper to taste."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate and serve with rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
