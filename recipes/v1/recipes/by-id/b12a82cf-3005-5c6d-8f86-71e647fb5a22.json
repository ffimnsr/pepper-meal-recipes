  "id": "b12a82cf-3005-5c6d-8f86-71e647fb5a22",
  "slug": "pinoy-pork-cheeseburger",
  "name": "Pork Cheeseburger",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pinoy pork cheeseburger. It makes use of our tried and tested pork burger patty recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the pork burger patties based on the recipe link above. Once the burger patties are formed, heat a wide pan and then pour oil."
    },
    {
      "position": 2,
      "text": "Pan-fry the burger patties in medium heat for 2 \u00bd minutes per side. Do this twice so that each side is fried for around 5 minutes. Remove from the pan and place in a plate."
    },
    {
      "position": 3,
      "text": "Prepare the buns by spreading mayonnaise on the inner part of both sliced."
    },
    {
      "position": 4,
      "text": "Arrange the bottom slice of bun in a plate and then top with cheese. Put a piece of pork burger over the cheese and then top coleslaw. Cover with the top bun."
    },
    {
      "position": 5,
      "text": "Serve with ketchup. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 15,
