  "id": "34cc5a37-cac5-5fa9-9e08-12b1ac15669a",
  "slug": "ukoy-dulong-recipe",
  "name": "Ukoy Dulong Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for fish fritters. It is also known as Ukoy Dulong.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a large mixing bowl, combine all batter ingredients in a bowl starting with the dry ingredients and ending by adding water and egg. Mix well."
    },
    {
      "position": 2,
      "text": "Add the dulong and mung bean sprouts. Gently stir until all ingredients are well blended."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan."
    },
    {
      "position": 4,
      "text": "Arrange 1/2 cup of mixture in a saucer. Note: make sure the there is enough batter in the mixture."
    },
    {
      "position": 5,
      "text": "Once the oil gets hot, Slide the mixture into the pan. Cook one side in medium het until it turns golden brown and crisp. Turn over using a spatula. Cook the other side the same way."
    },
    {
      "position": 6,
      "text": "Remove the dulong okay from the pan. Stack in a plate with paper towels."
    },
    {
      "position": 7,
      "text": "Serve with spicy vinegar such as pinakurat or sinamak."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 8,
