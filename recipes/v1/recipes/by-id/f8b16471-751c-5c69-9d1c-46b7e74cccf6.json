  "id": "f8b16471-751c-5c69-9d1c-46b7e74cccf6",
  "slug": "stuffed-burger-patties",
  "name": "Stuffed Beef and Pork Burger Patties",
  "recipe_type": null,
  "brief_description": "This is a recipe for Stuffed Beef and Pork Burger Patties",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine ground pork, ground beef, parsley, garlic powder, salt. and ground black pepper in a large bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Scoop around 1/4 cup mixture from the bowl and roll it into a ball shaped figure using your hands."
    },
    {
      "position": 3,
      "text": "Put it in a middle of a burger stuffer tool. Press. Arrange a decent amount of bell peppers and cheese in the middle. Top with 2 to 3 tablespoons of meat mixture to secure the opening. Perform this step until all ingredients are consumed."
    },
    {
      "position": 4,
      "text": "Heat-up the grill or grilling pan. Start to grill the first side for 3 minutes. Turn it over and continue to grill the other side for 5 minutes."
    },
    {
      "position": 5,
      "text": "Arrange in a plate. Serve as it is or place it in between two buns."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 12,
