  "instructions": [
    {
      "position": 1,
      "text": "Make the chicken nuggets by following the recipe on the link in the ingredients section. Set Aside."
    },
    {
      "position": 2,
      "text": "Make the sweet and sour sauce by following the sweet and sour sauce recipe link in the ingredients section. Make half amount of what is written in the recipe."
    },
    {
      "position": 3,
      "text": "Arrange the chicken nuggets in a serving plate. Pour the sweet and sour sauce over the chicken nuggets. Garnish with chopped parsley."
    },
    {
      "position": 4,
      "text": "Serve. Share and enjoy!"
    }
