  "id": "8a0c9f94-103e-522b-ac0c-f862582d0d89",
  "slug": "beef-and-baby-corn-stir-fry-recipe",
  "name": "Beef and Baby Corn Stir Fry Recipe",
  "recipe_type": null,
  "brief_description": "Beef and Baby Corn Stir Fry is composed of beef in soy and oyster sauce, and cornstarch - stir fried with baby corn, snap peas, and red bell pepper.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange beef in a bowl. Add 1/4 teaspoon ground black pepper, soy sauce, and oyster sauce. Mix well."
    },
    {
      "position": 2,
      "text": "Add the cornstarch. Make sure all the ingredients are well blended. Set aside."
    },
    {
      "position": 3,
      "text": "Meanwhile, heat a wok or a pan. Pour-in the cooking oil. Once the oil gets hot, stir-fry the baby corn, snap peas, and red bell pepper for 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Add salt and remaining pepper. Pour the cooking wine in the wok and stir-fry for 3 minutes."
    },
    {
      "position": 5,
      "text": "Transfer the vegetables to a plate. Set aside."
    },
    {
      "position": 6,
      "text": "Using the remaining cooking oil (add a tablespoon of cooking oil if needed), stir fry the marinated beef for 3 to 4 minutes. Add the stir-fried vegetables and continue to stir-fry for another 2 to 4 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 15,
