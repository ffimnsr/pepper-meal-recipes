  "id": "4ecb5c16-c558-50f6-bd05-d1e0668d8e67",
  "slug": "creamy-pasta-carbonara",
  "name": "Pasta Carbonara Filipino Style",
  "recipe_type": "main",
  "brief_description": "Creamy Filipino style carbonara with white sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook fettuccine according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Make the creamy pasta sauce by mixing Knorr Cream of Mushroom and water. Stir until completely diluted. Set aside."
    },
    {
      "position": 3,
      "text": "Heat a pan and add chopped bacon. Cook until the bacon becomes crispy."
    },
    {
      "position": 4,
      "text": "Add butter. Let it melt and then add mushrooms. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour cream of mushroom mixture into the pan. Stir and continue cooking until the sauce thickens."
    },
    {
      "position": 6,
      "text": "Add heavy cream and Parmesan cheese. Stir."
    },
    {
      "position": 7,
      "text": "Combine the cooked fettuccine with the pasta sauce. Toss until the pasta gets coated completely."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
