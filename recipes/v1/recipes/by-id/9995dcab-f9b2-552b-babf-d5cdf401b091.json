  "id": "9995dcab-f9b2-552b-babf-d5cdf401b091",
  "slug": "apple-pie-recipe",
  "name": "Apple Pie Recipe",
  "recipe_type": "dessert",
  "brief_description": "This Apple Pie Recipe is simple and straightforward. New cooks can make this apple pie as long as the recipe is followed step by step. Enjoy!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 425 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "In a mixing bowl, combine apples, sugars, flour, nutmeg, and cinnamon then mix well."
    },
    {
      "position": 3,
      "text": "Set 1 pastry dough on a round cake or pie pan then put-in the apple mixture and arrange."
    },
    {
      "position": 4,
      "text": "Distribute butter on top of the apple mixture."
    },
    {
      "position": 5,
      "text": "Cover with the second pie crust then seal the edges."
    },
    {
      "position": 6,
      "text": "Bake for 15 minutes then reduce heat to 300 degrees Fahrenheit and bake for another 40 to 45 minutes."
    },
    {
      "position": 7,
      "text": "Remove from the oven and serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
