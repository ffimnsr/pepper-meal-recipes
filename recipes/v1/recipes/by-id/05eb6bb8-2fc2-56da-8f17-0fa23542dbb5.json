  "id": "05eb6bb8-2fc2-56da-8f17-0fa23542dbb5",
  "slug": "paella-negra-arroz-negre-recipe",
  "name": "Paella Negra (Arroz Negre) Recipe",
  "recipe_type": "main",
  "brief_description": "A dramatic Spanish rice dish tinted black with squid ink, featuring tender seafood and sweet bell peppers. This one-pan meal creates a striking presentation with deep oceanic flavors.",
  "cuisine": "spanish",
  "instructions": [
    {
      "position": 1,
      "text": "Heat olive oil in a paellera or wide pan."
    },
    {
      "position": 2,
      "text": "Pan fry shrimp in medium heat for 1 minute per side. Remove and set aside."
    },
    {
      "position": 3,
      "text": "Stir-fry the sliced squid for 1 to 2 minutes. Set aside."
    },
    {
      "position": 4,
      "text": "Saute garlic and onion for 30 seconds. Add tomato. Continue to cook until onion starts to get translucent and soft. Note: you can add more olive oil if needed."
    },
    {
      "position": 5,
      "text": "Add half of the bell pepper and 2 cups of Calasparra rice. Stir. Cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Pour the wine and fish broth into the pan. Add the squid ink (tinta de calamar). Stir and let boil."
    },
    {
      "position": 7,
      "text": "Cover and continue to cook between low to medium heat for 15 to 20 minutes. Note: add water if needed."
    },
    {
      "position": 8,
      "text": "Top with pan-fried shrimp, squid, lemon wedges, and remaining bell peppers. Cover the pan and continue to cook for 5 minutes or until the rice is cooked perfectly."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 15,
  "rest_time_minutes": 5,
  "difficulty": "medium",
