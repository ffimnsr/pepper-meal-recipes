  "slug": "pico-de-gallo-recipe",
  "name": "Pico de Gallo",
  "recipe_type": "salad",
  "brief_description": "Pico de Gallo is a fresh, chunky side dish made from diced tomatoes, onions, cilantro, and lime juice, often with a kick of jalape\u00f1o. It\u2019s a vibrant, flavorful mix commonly used as a topping or dip in Mexican cuisine.",
  "cuisine": "Mexican",
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine tomatoes and onion. Gently toss to mix."
    },
    {
      "position": 2,
      "text": "Add the chopped cilantro and jalapeno."
    },
    {
      "position": 3,
      "text": "Squeeze-in the lemon and sprinkle the salt and ground black pepper. Toss"
    },
    {
      "position": 4,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
