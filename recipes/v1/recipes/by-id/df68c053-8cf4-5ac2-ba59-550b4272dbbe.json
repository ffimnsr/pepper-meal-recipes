  "id": "df68c053-8cf4-5ac2-ba59-550b4272dbbe",
  "slug": "squid-ball-pancit-canton-recipe-chow-mein",
  "name": "Squid Ball Pancit Canton Recipe",
  "recipe_type": null,
  "brief_description": "Squid Ball Pancit Canton Recipe or Chow Mein with Squid Balls is an easy-to-prepare dish that you can make within 30 minutes.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a wok. Saute the garlic, onion, and parsley. Add the ground black pepper."
    },
    {
      "position": 2,
      "text": "Add the squid and lobster balls. Stir fry for 2 to 3 minutes."
    },
    {
      "position": 3,
      "text": "Add the chopped cabbage and carrots. Toss. Cook for 5 minutes or until the vegetables starts to soften."
    },
    {
      "position": 4,
      "text": "Pour-in the soy sauce and chicken broth. Let boil."
    },
    {
      "position": 5,
      "text": "Lay the flour noodles over. Cover the wok. Let it stay for 1 to 2 minutes. This will let the flour noodles absorb the steam, which will make it soft and easy to handle."
    },
    {
      "position": 6,
      "text": "Remove the cover and gently toss the noodles. Makes sure that all the ingredients are well incorporated. Cook until the liquid dries up."
    },
    {
      "position": 7,
      "text": "Squeeze some lime, and then toss some more."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
