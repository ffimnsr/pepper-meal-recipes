  "id": "e5a2fcac-9910-5b43-9906-78a8836b57e5",
  "slug": "filipino-shrimp-curry-recipe",
  "name": "Filipino Shrimp Curry Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Filipino Shrimp Curry.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange shrimp in a large bowl. Squeeze lemon over it, season with ground black pepper and cayenne pepper powder. Mix well. Marinate for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Once the oil becomes hot, saute onion for 30 seconds."
    },
    {
      "position": 4,
      "text": "Add garlic, ginger, and tomato. Cook until the onion becomes tender."
    },
    {
      "position": 5,
      "text": "Pour coconut milk into the pot. Stir and let boil. Cover the cooking pot. Continue to cook in medium heat for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add curry powder. Stir until it dilutes in coconut milk."
    },
    {
      "position": 7,
      "text": "Add Knorr Shrimp Cube. Stir. Continue to cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Add turmeric powder and bell peppers (red and green). Stir. Cover and continue to cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Put the marinated shrimp into the pot. Stir. Continue to cook in medium heat for 3 to 4 minutes."
    },
    {
      "position": 10,
      "text": "Season with patis (fish sauce). Add parsley. Stir. Cook for 2 minutes."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
