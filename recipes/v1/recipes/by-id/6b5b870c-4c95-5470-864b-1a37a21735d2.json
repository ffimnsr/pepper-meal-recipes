  "id": "6b5b870c-4c95-5470-864b-1a37a21735d2",
  "slug": "hashbrown-casserole",
  "name": "Hashbrown Casserole",
  "recipe_type": "breakfast",
  "brief_description": "Hashbrown Casserole makes a perfect breakfast especially if there are a couple of sausage links or even bacon strips. This recipe is awesome.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350F."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan. Once the oil gets hot, add the onion. Continue to cook the onion in medium heat while stirring until caramelized."
    },
    {
      "position": 3,
      "text": "Meanwhile, combine shredded hash brown, cream of chicken, butter, cheese, salt, and pepper."
    },
    {
      "position": 4,
      "text": "Add sour cream and caramelized onion."
    },
    {
      "position": 5,
      "text": "Mix well then arrange in a baking pan."
    },
    {
      "position": 6,
      "text": "Bake for 35 minutes."
    },
    {
      "position": 7,
      "text": "Remove from the oven and it cool down. Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
