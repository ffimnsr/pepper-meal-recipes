  "id": "3fd7e4dd-8b71-5d93-a019-e380ab06b439",
  "slug": "bananacue",
  "name": "Bananacue",
  "recipe_type": "dessert",
  "brief_description": "Bananacue is a popular Filipino street food snack made by deep-frying saba bananas coated in caramelized brown sugar, then skewered on bamboo sticks. A classic merienda treat often paired with cold soda.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a deep pot or frying pan over medium heat."
    },
    {
      "position": 2,
      "text": "When the oil is hot, carefully deep fry the bananas for 2 minutes."
    },
    {
      "position": 3,
      "text": "Gradually add the brown sugar, reduce heat to medium-low, and continue cooking until the melted sugar coats the bananas. Stir gently to ensure even coating."
    },
    {
      "position": 4,
      "text": "Remove the cooked bananas one by one and immediately skewer using a bamboo skewer. 2 pieces per skewer is recommended."
    },
    {
      "position": 5,
      "text": "Let cool slightly before serving. Traditionally enjoyed with cold soda."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 7,
  "preparation_time_minutes": 5,
