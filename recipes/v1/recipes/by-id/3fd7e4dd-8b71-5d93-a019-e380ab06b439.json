  "id": "3fd7e4dd-8b71-5d93-a019-e380ab06b439",
  "slug": "bananacue",
  "name": "Bananacue Recipe",
  "recipe_type": "dessert",
  "brief_description": "Bananacue is a nutritious and popular snack in the Philippines. Get to know how to cook this through our cooking video.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in cooking oil."
    },
    {
      "position": 2,
      "text": "When the oil becomes hot, deep fry the bananas for 2 minutes."
    },
    {
      "position": 3,
      "text": "Gradually put-in the brown sugar, adjust the heat to medium-low and continue cooking until the melted brown sugar coats the bananas. Note: Gently stir the bananas so that it can get coated with melted brown sugar easily."
    },
    {
      "position": 4,
      "text": "Remove the cooked bananas one by one and immediately skewer using a bamboo skewer. Note: 2 pieces per skewer is recommended."
    },
    {
      "position": 5,
      "text": "Let cool then serve with cold soda."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 7,
  "preparation_time_minutes": 5,
