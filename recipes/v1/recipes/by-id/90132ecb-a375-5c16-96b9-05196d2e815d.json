  "id": "90132ecb-a375-5c16-96b9-05196d2e815d",
  "slug": "pork-and-tofu-in-oyster-sauce",
  "name": "Pork and Tofu in Oyster Sauce Recipe",
  "recipe_type": null,
  "brief_description": "This Pork and Tofu in Oyster Sauce Recipe is so delicious. You can make this dish in any occassion. Have lots of white rice ready because you will enjoy it.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in cooking oil."
    },
    {
      "position": 2,
      "text": "When the oil is hot, saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Put-in the pork and cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Add parsley, soy sauce, and oyster sauce then stir."
    },
    {
      "position": 5,
      "text": "Pour-in water and let boil. Simmer for 30 minutes or until the pork becomes tender."
    },
    {
      "position": 6,
      "text": "Put-in the salted black beans and fried tofu and cook for 5 to 8 minutes."
    },
    {
      "position": 7,
      "text": "Add sugar, salt, and ground black pepper then stir. Cook for a minute more"
    },
    {
      "position": 8,
      "text": "Turn-off heat then transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
