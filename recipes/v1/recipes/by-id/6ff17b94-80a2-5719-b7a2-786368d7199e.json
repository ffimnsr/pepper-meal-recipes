  "id": "6ff17b94-80a2-5719-b7a2-786368d7199e",
  "slug": "monggo-pinakbet",
  "name": "Monggo Pinakbet Recipe",
  "recipe_type": "main",
  "brief_description": "Ginisang monggo and pinakbet combination",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Soak the mung beans in water overnight. Drain the water and set the mung beans aside."
    },
    {
      "position": 2,
      "text": "Heat 2 tablespoons of cooking oil in a pan. Saute half of the total amount of garlic, onion, and tomatoes. Once the onion and tomato soften, add the mung beans. Saute for 2 minutes."
    },
    {
      "position": 3,
      "text": "Pour the water into the pot. Let boil."
    },
    {
      "position": 4,
      "text": "Add the Knorr Pork Cube. Stir. Cover the pot and boil the mung beans using low to medium heat for 45 minutes. Note: Add water as needed. Set this aside."
    },
    {
      "position": 5,
      "text": "On a separate pan, saut\u00e9 the remaining garlic, onion, and tomato. Add the ginger. Continue saut\u00e9ing until the onion and tomato softens."
    },
    {
      "position": 6,
      "text": "Add the sliced pork. Saute until the color of the pork turns light brown."
    },
    {
      "position": 7,
      "text": "Pour \u00be cup water. Let it boil. Cover the pot and continue boiling the pork until the water evaporates completely."
    },
    {
      "position": 8,
      "text": "Add the shrimp paste. Saute for 1 minute."
    },
    {
      "position": 9,
      "text": "Add calabaza squash. Cook for 2 minutes."
    },
    {
      "position": 10,
      "text": "Add eggplant, bitter melon, okra, and string beans. Saute for 2 minutes."
    },
    {
      "position": 11,
      "text": "Add \u00bd cup water. Let it boil."
    },
    {
      "position": 12,
      "text": "Pour the cooked mung beans into the pot. Stir and continue cooking for 3 to minutes."
    },
    {
      "position": 13,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 14,
      "text": "Transfer to a serving bowl. Serve with rice."
    },
    {
      "position": 15,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
