  "id": "caeaaae1-3a8e-52e5-bf28-9fb99043d740",
  "slug": "dried-squid-in-coconut-milk",
  "name": "Dried Squid in Coconut Milk",
  "recipe_type": null,
  "brief_description": "This version of Dried Squid in Coconut Milk Recipe (which is also known as \"ginataang pusit\") was discovered by accident.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat-up the grill. Once the grill gets hot, grill one side of the squid for 3 minutes. The squid will curl-up, try to straighten the other side (if possible) and grill for 1 to 2 minutes. Set aside."
    },
    {
      "position": 2,
      "text": "Arrange the coconut cream, ginger, onion, garlic, green chillies, squid, ground black pepper, and fish sauce in a slow cooker. Set the slow cooker to high, cover and slow cook the squid for 8 hours."
    },
    {
      "position": 3,
      "text": "Add the spinach. Cook for 10 to 15 minutes."
    },
    {
      "position": 4,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
