  "id": "e7c08351-d533-56a2-af10-c3e48b40d237",
  "slug": "creamy-beef-with-mushroom",
  "name": "Creamy Beef with Mushroom",
  "recipe_type": "main",
  "brief_description": "Because we know that beef works so well with mushrooms, this delightful and delicious creamy beef with mushroom recipe is here for you",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a pan. Add cooking oil."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic until it browns. Add onion and cook until it softens."
    },
    {
      "position": 3,
      "text": "Add the beef. Cook while stirring until the sides turn brown."
    },
    {
      "position": 4,
      "text": "Pour 1 cup water. Cover the pan. Adjust to a simmer and continue cooking for 35 minutes."
    },
    {
      "position": 5,
      "text": "Add button mushrooms. Stir."
    },
    {
      "position": 6,
      "text": "Combine 1 cup water and Knorr Cream of Mushroom in a bowl. Mix well."
    },
    {
      "position": 7,
      "text": "Pour the mixture into the pan. Let it boil. Continue cooking uncovered for 10 to 15 minutes using low heat setting."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 9,
      "text": "Top with parsley. Serve warm with rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
