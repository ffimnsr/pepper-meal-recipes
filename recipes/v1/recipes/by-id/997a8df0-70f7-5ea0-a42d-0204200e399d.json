  "id": "997a8df0-70f7-5ea0-a42d-0204200e399d",
  "slug": "monggo-guisado-recipe",
  "name": "Monggo Guisado Recipe",
  "recipe_type": null,
  "brief_description": "Monggo Guisado is another version of Ginisang Monggo; this time using fish flakes from left over fried fish. I think that I cooked more than enough fried galunggong the previous day and I don't want it to go to waste.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the onion and garlic."
    },
    {
      "position": 3,
      "text": "Once the onion becomes soft, add the fish flakes and continue to cook in medium heat for 1 to 2 minutes."
    },
    {
      "position": 4,
      "text": "Add the tomatoes. Stir and cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Put-in the mung beans. Stir, add the bagoong isda, and 1 cup water. Cover and cook for 15 to 18 minutes. Add more water if necessary."
    },
    {
      "position": 6,
      "text": "Sprinkle some ground black pepper and then add the spinach. Stir."
    },
    {
      "position": 7,
      "text": "Add more water (around 1 cup or more as needed). Let boil and cook for 5 minutes more."
    },
    {
      "position": 8,
      "text": "Adjust the taste by adding more bagoong isda (only of needed)."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Serve and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
