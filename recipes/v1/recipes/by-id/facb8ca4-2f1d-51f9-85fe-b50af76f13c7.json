  "id": "facb8ca4-2f1d-51f9-85fe-b50af76f13c7",
  "slug": "oven-roasted-broccoli",
  "name": "Oven Roasted Broccoli",
  "recipe_type": "side",
  "brief_description": "Oven roasted broccoli with garlic and olive oil. The florets get crispy edges and a nutty flavor after 18 minutes at 400\u00b0F. A quick, hands-off side dish that pairs with almost anything.",
  "cuisine": "American Italian Mediterranean",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 400 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Place the broccoli florets in a mixing bowl. Add the salt and minced garlic, then toss to combine."
    },
    {
      "position": 3,
      "text": "Pour in the olive oil and toss until the florets are evenly coated."
    },
    {
      "position": 4,
      "text": "Arrange the broccoli in a single layer on a baking tray."
    },
    {
      "position": 5,
      "text": "Roast for 18 minutes or until the edges start to brown."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
