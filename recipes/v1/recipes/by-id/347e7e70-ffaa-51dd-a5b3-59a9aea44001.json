  "id": "347e7e70-ffaa-51dd-a5b3-59a9aea44001",
  "slug": "dessertchocolate-cupcake-recipe",
  "name": "Chocolate Cupcake Recipe",
  "recipe_type": "dessert",
  "brief_description": "Chocolate Cupcake Recipe: Learn how to make amazing cupcakes by following our cooking video and step by step procedure.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine flour, baking powder, and salt in a mixing bowl and whisk thoroughly until the ingredients are evenly distributed. Set aside."
    },
    {
      "position": 2,
      "text": "Put the cocoa powder in the bowl where the hot water is and stir until the cocoa powder is diluted. Set aside."
    },
    {
      "position": 3,
      "text": "Combine the butter and sugar in a separate mixing bowl then cream (electric mixer is needed) until texture become fluffy"
    },
    {
      "position": 4,
      "text": "Add the eggs while mixing continuously then put-in the vanilla essence."
    },
    {
      "position": 5,
      "text": "Put in half of the flour-baking powder-salt mixture then mix well."
    },
    {
      "position": 6,
      "text": "Add the other half of the flour-baking powder-salt mixture then continue mixing until all the ingredients are well distributed."
    },
    {
      "position": 7,
      "text": "Pour the cocoa mixture and continue mixing until texture becomes smooth."
    },
    {
      "position": 8,
      "text": "Preheat the oven to 375 degrees Fahrenheit"
    },
    {
      "position": 9,
      "text": "Fill the cupcake pan with cupcake paper cups."
    },
    {
      "position": 10,
      "text": "Put the batter in each paper cup then bake for 18 minutes (insert toothpick in the cupcakes, if it comes out clean then the cupcakes are done)."
    },
    {
      "position": 11,
      "text": "Remove the cupcake from the oven and allow to cool down over a wire rack."
    },
    {
      "position": 12,
      "text": "Melt the chocolate by placing it in a bowl over boiling water."
    },
    {
      "position": 13,
      "text": "Once melted, set aside and allow to cool down to room temperature"
    },
    {
      "position": 14,
      "text": "Put the butter in a mixing bowl then cream (use electric mixer)"
    },
    {
      "position": 15,
      "text": "Add the sugar and continue mixing until the texture becomes fluffy."
    },
    {
      "position": 16,
      "text": "Put-in the vanilla essence and chocolate then mix thoroughly until texture becomes smooth."
    },
    {
      "position": 17,
      "text": "Place the frosting over the cupcakes. (I use a pipe so that the frosting can easily be swirled. If you don't have any tools, you may use a spoon or spatula to spread the frosting."
    },
    {
      "position": 18,
      "text": "Serve with a smile. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 18,
