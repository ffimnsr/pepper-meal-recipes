  "id": "d543f996-324f-5e7c-996b-306aff8d6eb3",
  "slug": "orange-crispy-burger",
  "name": "Orange Crispy Burger",
  "recipe_type": "dessert",
  "brief_description": "This Orange Crispy Burger is the perfect dinner dish to serve for when you are craving something that\u2019s got a sweetness to its savor.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan. Fry both sides of the CDO Crispy burger patties using medium heat until crispy. Set aside."
    },
    {
      "position": 2,
      "text": "Make the orange glaze by heating oil in a pan. Saute garlic and ginger"
    },
    {
      "position": 3,
      "text": "Add sugar and let it melt."
    },
    {
      "position": 4,
      "text": "Pour sesame oil, orange juice, soy sauce, and vinegar. Let boil."
    },
    {
      "position": 5,
      "text": "Add red pepper flakes. Cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Combine water and cornstarch in a bowl. Stir until blended. Pour mixture into the pan. Continuously stir until the sauce thickens."
    },
    {
      "position": 7,
      "text": "Arrange CDO Crispy Burger on a plate with a cup of rice on the side. Drizzle the orange over the patties. Garnish with chopped green onions."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
