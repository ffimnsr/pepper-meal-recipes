  "id": "c6f8d9f4-e368-569f-af90-224d92baf1eb",
  "slug": "fish-sinigang-recipe",
  "name": "Fish Sinigang Recipe",
  "recipe_type": "soup",
  "brief_description": "Salmon head sinigang with mustard leaves",
  "cuisine": "Fiipino Philippines",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a cooking pot. Saute onion, garlic, and ginger."
    },
    {
      "position": 2,
      "text": "Add the salmon once the onion softens. Pour the water and let it boil."
    },
    {
      "position": 3,
      "text": "Add Knorr sinigang sa Sampaloc with Miso and daikon radish. Cover and continue cooking in low heat for 5 minutes."
    },
    {
      "position": 4,
      "text": "Add okra, long green pepper, and tomatoes. Cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Season with ground black pepper and fish sauce."
    },
    {
      "position": 6,
      "text": "Add the mustard leaves. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve hot."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
