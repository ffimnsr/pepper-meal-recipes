  "id": "ba3d4946-ba3b-5aef-ad55-a841ff146f6d",
  "slug": "baked-salmon-with-lemon-garlic-and-butter",
  "name": "Baked Salmon with Lemon Garlic and Butter",
  "recipe_type": null,
  "brief_description": "This is a recipe for Baked Salmon with Lemon Garlic and Butter",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 400F."
    },
    {
      "position": 2,
      "text": "Arrange the salmon fillet over an aluminum foil."
    },
    {
      "position": 3,
      "text": "Rub salt and garlic powder all over the salmon."
    },
    {
      "position": 4,
      "text": "Squeeze half of the lemon on the salmon fillet and rub the juice all-throughout the fish. Top with crushed garlic and butter."
    },
    {
      "position": 5,
      "text": "Slice the other half of the lemon thinly crosswise. Arrange on top of the salmon and add some dill weed."
    },
    {
      "position": 6,
      "text": "Seal the fish in foil. Bake for 15 to 18 minutes."
    },
    {
      "position": 7,
      "text": "Remove from the oven. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
