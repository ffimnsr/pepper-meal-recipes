  "id": "2ea3aa9b-91ba-5c92-9ad8-7f11282b4320",
  "slug": "perfect-chicken-adobo-on-a-budget",
  "name": "Perfect Chicken Adobo on a Budget",
  "recipe_type": "main",
  "brief_description": "Filipino chicken adobo",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken, soy sauce, vinegar, and 5 cloves garlic. Mix well until all ingredients are well incorporated. Marinate for 30 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, boil the eggs for 10 minutes. Let the eggs cool down afterwards and peel off the shell."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan. saut\u00e9 the remaining garlic until it starts to turn brown."
    },
    {
      "position": 4,
      "text": "Add the marinated chicken (do not include the marinade yet). Cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Pour the remaining marinade into the pan and add water. Let boil."
    },
    {
      "position": 6,
      "text": "Add bay leaves, whole peppercorn, and Knorr Chicken Cube. Stir. Cover the pan and continue cooking using low to medium heat for 15 to 20 minutes."
    },
    {
      "position": 7,
      "text": "Add the sugar and put the eggs into the pan. Gently stir. Cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate and serve along with a huge bowl of newly cooked rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 14,
