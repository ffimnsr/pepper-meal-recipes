  "id": "cc357768-0ee9-5116-b97d-cf2fc194cd96",
  "slug": "oriental-lemon-chicken-recipe",
  "name": "Oriental Lemon Chicken Recipe",
  "recipe_type": null,
  "brief_description": "Oriental Lemon Chicken Recipe is an Asian chicken version that resembles orange chicken. This Lemon Chicken Recipe tastes amazing.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken slices and soy sauce. Mix well and marinate for at least 15 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil. Meanwhile, dredge the chicken strips in 4 1/2 tablespoons of cornstarch."
    },
    {
      "position": 3,
      "text": "Put in the coated chicken and fry until color turns light brown. Do not overcook."
    },
    {
      "position": 4,
      "text": "Remove the chicken from the pan, place in a plate, and set aside."
    },
    {
      "position": 5,
      "text": "Drain excess oil until about 1 tablespoon is left. Saute garlic and put-in the celery leaves."
    },
    {
      "position": 6,
      "text": "Pour-in chicken broth and sherry. Add sugar, salt, lemon rind, lemon juice, salt, and pepper. Stir and let boil."
    },
    {
      "position": 7,
      "text": "Pour-in the cornstarch diluted in water. Stir until the sauce thickens."
    },
    {
      "position": 8,
      "text": "Put-in the fried chicken slices. Stir and cook for another minute."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
