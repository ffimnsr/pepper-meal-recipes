  "id": "f6b3f01e-dee9-50e6-9258-5e4012ad9397",
  "slug": "sigarilyas-gising-gising-recipe",
  "name": "Sigarilyas Gising gising Recipe",
  "recipe_type": null,
  "brief_description": "Sigarilyas Gising gising is a Filipino vegetable stew composed of winged beans, ground pork, and green chillies. These are cooked in coconut milk.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a deep pan."
    },
    {
      "position": 2,
      "text": "Once the oil is hot, saute the garlic and onion. Continue to cook until the onion starts to soften."
    },
    {
      "position": 3,
      "text": "Add the ground pork. Saute for 5 minutes or until the pork turns brown."
    },
    {
      "position": 4,
      "text": "Pour the coconut milk in the pan and let boil. Stir and add the sigarilyas and long green peppers. Cover and adjust the heat to low. cook for 30 to 35 minutes or until the liquid reduces in half."
    },
    {
      "position": 5,
      "text": "Remove the cover and add fish sauce and ground black pepper. Stir and cook for a few more minutes until the coconut milk reduces, but do not let the liquid evaporate totally."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
