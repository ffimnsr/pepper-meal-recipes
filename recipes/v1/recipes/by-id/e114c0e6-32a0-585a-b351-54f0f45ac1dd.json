  "id": "e114c0e6-32a0-585a-b351-54f0f45ac1dd",
  "slug": "quick-and-easy-fried-chicken",
  "name": "Quick and Easy Fried Chicken",
  "recipe_type": "main",
  "brief_description": "Tasty and delicious fried chicken marinated and cooked in under 25 minutes.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Create slits on the chicken drumsticks by slicing all the way to the bone."
    },
    {
      "position": 2,
      "text": "Place the chicken inside a resealable bag. Add soy sauce, calamansi juice, Knorr SavorRich, and ground black pepper. Seal the bag and then shake until all ingredients are well blended. Push the air out of the bag and seal again. Marinate for 10 minutes."
    },
    {
      "position": 3,
      "text": "Heat oil in a pot."
    },
    {
      "position": 4,
      "text": "Place the flour in a container with cover. Put the marinated chicken in the container (one to two pieces at a time). Cover and shake until the chicken get completely coated with flour. Shake-off excess flour."
    },
    {
      "position": 5,
      "text": "Deep-fry the chicken for 14 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the pot and let the chicken rest for 5 minutes."
    },
    {
      "position": 7,
      "text": "Serve with rice or any of your favorite side dishes."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 14,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
