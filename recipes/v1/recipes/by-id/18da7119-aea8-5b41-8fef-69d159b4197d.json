  "id": "18da7119-aea8-5b41-8fef-69d159b4197d",
  "slug": "sinigang-na-bangus-sa-miso",
  "name": "Sinigang na Bangus sa Miso",
  "recipe_type": "soup",
  "brief_description": "Sinigang is probably the most popular soup in the Philippines. This recipe makes use of milk fish and miso paste. A truly awesome Filipino Recipe to try.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and then pour-in cooking oil."
    },
    {
      "position": 2,
      "text": "Put the onions in when the oil becomes hot, and then saut\u00e9 for 2 minutes."
    },
    {
      "position": 3,
      "text": "Add the miso and cook for another 2 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the fish sauce and water, and then stir. Bring to a boil."
    },
    {
      "position": 5,
      "text": "Add the tomatoes and tamarind soup mix. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the long green chilies and milk fish. Cook for 15 to 18 minutes in low heat."
    },
    {
      "position": 7,
      "text": "Finally, add the mustard leaves and turn off the heat. Cover the pot and let the residual heat cook the greens."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl, and then serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
