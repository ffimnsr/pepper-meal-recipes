  "id": "53a600d5-7bdb-53ca-891c-7042197f76a5",
  "slug": "crispy-crablets",
  "name": "Crispy Crablets Recipe",
  "recipe_type": null,
  "brief_description": "Crispy Crablets are seasoned small crabs that were dredged in cornstarch and deep-fried until crispy. These types of crabs are usually found in riverbanks while some are cultured in fish ponds. In some cases, these small crabs can be caught in rice fields.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Place the crablets in a bowl then pour-in gin or sherry. Mix gently."
    },
    {
      "position": 2,
      "text": "Sprinkle salt and ground black pepper then mix well."
    },
    {
      "position": 3,
      "text": "Heat a frying pan or cooking pot and pour-in cooking oil."
    },
    {
      "position": 4,
      "text": "Dredge the crablets in cornstarch then deep fry until the texture becomes crispy."
    },
    {
      "position": 5,
      "text": "Remove from the pan and place in a plate lined with paper towel."
    },
    {
      "position": 6,
      "text": "Once excess oil drips-off completely, arrange in a serving plate and serve with spicy vinegar dip."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 15,
