  "slug": "arugula-salad-with-chopped-walnuts",
  "name": "Arugula Salad with Chopped Walnuts",
  "recipe_type": "salad",
  "brief_description": "Arugula salad is composed of arugula with cherry tomato and walnuts with a dressing of white wine vinegar and olive oil.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine salt and olive oil. Mix well and then set aside."
    },
    {
      "position": 2,
      "text": "In a large salad bowl, combine arugula, cherry tomato, and walnuts. Gently toss the ingredients."
    },
    {
      "position": 3,
      "text": "Add the olive oil mixture and white wine vinegar. Toss once more to incorporate all the ingredients."
    },
    {
      "position": 4,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 1,
