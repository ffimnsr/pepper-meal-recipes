  "id": "e777fb96-1b07-5fb1-a5b7-0279da0a9508",
  "slug": "japanese-shumai",
  "name": "Japanese Shumai",
  "recipe_type": "appetizer",
  "brief_description": "Shumai recipe with ground pork, shrimp and crab sticks, wrapped in nori",
  "cuisine": "Japanese",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the filling ingredients in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Cut 1 whole nori sheet into 4 equal pieces. Do this step on all your nori sheets."
    },
    {
      "position": 3,
      "text": "Scoop 1 \u00bd tablespoon of the filling ingredient. Place it on a piece of nori, wrap it just like how you will do with regular siomai. Top with a sliced piece of kani in the middle."
    },
    {
      "position": 4,
      "text": "Arrange the wrapped Japanese siomai in a steamer. Steam for 20 to 25 minutes."
    },
    {
      "position": 5,
      "text": "Make the sauce by combining all the sauce ingredients in a bowl. Mix well."
    },
    {
      "position": 6,
      "text": "Serve the Japanese Siomai with the dipping sauce."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 20,
