  "id": "f155cdac-5046-5137-b59d-ce80aede351a",
  "slug": "ginataang-alimasag",
  "name": "Ginataang Alimasag Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for ginataang alimasag. These are blue crabs with spinach cooked in coconut milk.&nbsp;",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a large pot, saut\u00e9 the garlic, onion, and ginger"
    },
    {
      "position": 2,
      "text": "Add the ground black pepper and coconut milk then bring to a boil"
    },
    {
      "position": 3,
      "text": "Put-in the shrimp paste and fish sauce and cook until the coconut milk\u2019s texture is thick and natural oil comes out of it (approximately 20 ++ minutes)"
    },
    {
      "position": 4,
      "text": "Add the Thai chili and simmer for 5 minutes"
    },
    {
      "position": 5,
      "text": "Put the crabs in the pot and mix until evenly covered with coconut milk. Simmer for 5 to 20 minutes. (Note: If crabs were steamed prior to cooking, 5 to 8 minutes is enough)"
    },
    {
      "position": 6,
      "text": "Add the spinach and simmer for 5 minutes"
    },
    {
      "position": 7,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
