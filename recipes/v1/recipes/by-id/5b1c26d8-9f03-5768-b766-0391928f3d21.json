  "id": "5b1c26d8-9f03-5768-b766-0391928f3d21",
  "slug": "coconut-shrimp",
  "name": "Coconut Shrimp",
  "recipe_type": "appetizer",
  "brief_description": "Crispy coconut breaded shrimp with sweet and spicy dipping sauce.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Make the sweet chili sauce by combining minced garlic, Thai chili pepper, and water in a food processor or blender. Blitz for 10 seconds. Set aside."
    },
    {
      "position": 2,
      "text": "Pour the vinegar into a saucepan and bring to a boil."
    },
    {
      "position": 3,
      "text": "Pour in the garlic, chili, and water mixture. Stir and cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add the sugar. Stir until completely dissolved. Season with salt and add the ketchup."
    },
    {
      "position": 5,
      "text": "Combine the cornstarch and 1 \u00bd tablespoons of water. Stir until a slurry forms. Pour the slurry into the saucepan and stir immediately. Continue cooking over medium heat, stirring constantly, until the sauce reaches your desired consistency. Set aside."
    },
    {
      "position": 6,
      "text": "Season the shrimp with salt and ground black pepper. Let sit for 5 minutes."
    },
    {
      "position": 7,
      "text": "Make the batter by combining all batter ingredients in a bowl. Stir until smooth. Set aside."
    },
    {
      "position": 8,
      "text": "Combine bread crumbs and desiccated coconut in a bowl. Mix well. Set aside."
    },
    {
      "position": 9,
      "text": "Dredge the shrimp in flour one piece at a time. Dip in the batter and let excess drip off. Roll in the bread crumb and coconut mixture, making sure both sides are completely coated. Arrange the coated shrimp on a clean plate. Repeat until all shrimp are coated."
    },
    {
      "position": 10,
      "text": "Heat oil in a pan. Fry the coconut shrimp in batches, flipping as needed, until both sides are golden brown."
    },
    {
      "position": 11,
      "text": "Transfer the fried shrimp to a plate lined with paper towels."
    },
    {
      "position": 12,
      "text": "Arrange on a serving plate and serve with sweet chili sauce."
    },
    {
      "position": 13,
      "text": "Serve immediately and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 7,
