  "recipe_notes": [
    "For extra crispy shrimp, ensure the oil is hot (around 350\u00b0F/175\u00b0C) before frying.",
    "The sweet chili sauce can be made ahead and stored in the refrigerator for up to one week."
  ],
  "storage_notes": [
    "Store leftover shrimp in an airtight container in the refrigerator for up to 2 days. Reheat in an oven or air fryer to restore crispiness.",
    "Store sweet chili sauce separately in the refrigerator for up to 1 week."
  ],
