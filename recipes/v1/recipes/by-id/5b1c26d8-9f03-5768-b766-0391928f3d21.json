  "id": "5b1c26d8-9f03-5768-b766-0391928f3d21",
  "slug": "coconut-shrimp",
  "name": "Coconut Shrimp",
  "recipe_type": "appetizer",
  "brief_description": "Crispy coconut breaded shrimp with sweet and spicy dipping sauce.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Make the Sweet chili sauce by combining Good Life Minced Garlic, Thai chili pepper, and water in a food processor or blender. Blitz for 10 seconds. Set aside."
    },
    {
      "position": 2,
      "text": "Pour vinegar in a saucepan. Let boil."
    },
    {
      "position": 3,
      "text": "Pour the garlic, chili, and water mixture. Stir and cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add sugar. Stir until sugar dilutes completely. Season with salt and add ketchup."
    },
    {
      "position": 5,
      "text": "Combine cornstarch and 1 \u00bd tablespoons of water. Stir until a slurry is formed. Pour the slurry into the saucepan. Stir right away. Continue cooking in medium heat while stirring until the sauce thickens to your desired consistency. Set the sauce aside."
    },
    {
      "position": 6,
      "text": "Prepare the shrimp by seasoning with salt and ground black pepper. Let it stay for 5 minutes."
    },
    {
      "position": 7,
      "text": "Make the batter by combining all batter ingredients in a bowl. Stir until the mixture smoothens. Set aside."
    },
    {
      "position": 8,
      "text": "Combine Good Life Bread Crumbs and desiccated coconut in a bowl. Mix well. Set aside."
    },
    {
      "position": 9,
      "text": "Dredge shrimp in flour one piece at a time. Dip it in the batter afterwards. Let the excess batter drip. Roll it next in bread crumb and desiccated coconut mixture. Arrange the coated shrimp on a clean plate. Note: Make sure that both sides get coated completely. Perform this step until all the shrimp are coated."
    },
    {
      "position": 10,
      "text": "Heat oil in a pan. Fry the coconut shrimp by batch. You can flip the shrimp multiple times while frying until both sides turn golden brown in color."
    },
    {
      "position": 11,
      "text": "Place the coconut shrimp on a plate lined with a paper towel after frying."
    },
    {
      "position": 12,
      "text": "Arrange on a serving plate and serve with sweet chili sauce."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
