  "slug": "apan-apan-recipe-adobong-kangkong-with-fried-pork",
  "name": "Apan - Apan Recipe (Adobong Kangkong with Fried Pork)",
  "recipe_type": "side",
  "brief_description": "Apan - apan can be considered as a version of Adobong kangkong. This yummy concoction (which I really enjoyed) is an Ilonggo dish.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a large wok or pan."
    },
    {
      "position": 2,
      "text": "Add the garlic and cook until brown."
    },
    {
      "position": 3,
      "text": "Stir-in the onion; continue to cook until soft."
    },
    {
      "position": 4,
      "text": "Add the crispy fried pork. Saute for a minutes."
    },
    {
      "position": 5,
      "text": "Stir-in the bagoong"
    },
    {
      "position": 6,
      "text": "Pour-in vinegar and let boil. Stir."
    },
    {
      "position": 7,
      "text": "Add the soy sauce. Stir."
    },
    {
      "position": 8,
      "text": "Add the kangkong leaves. Toss."
    },
    {
      "position": 9,
      "text": "Sprinkle salt and pepper. Toss and make sure that all ingredients are well blended. Cook for 2 to 3 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
