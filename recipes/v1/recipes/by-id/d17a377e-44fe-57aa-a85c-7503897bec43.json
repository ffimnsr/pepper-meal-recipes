  "id": "d17a377e-44fe-57aa-a85c-7503897bec43",
  "slug": "breaded-butterfly-shrimp-recipe",
  "name": "Breaded Butterfly Shrimp Recipe",
  "recipe_type": "appetizer",
  "brief_description": "This is a recipe for deep fried breaded shrimp",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Butterfly the shrimp by running a knife lengthwise more than halfway through the back or front of the shrimp. Gently open the cut to form a butterfly-like figure. Make sure that the tail of the shrimp is still on."
    },
    {
      "position": 2,
      "text": "Season the shrimp with salt, pepper, paprika, and garlic powder."
    },
    {
      "position": 3,
      "text": "Heat the oil in a deep cooking pot."
    },
    {
      "position": 4,
      "text": "Dredge the shrimp in flour and then dip in the egg mixture."
    },
    {
      "position": 5,
      "text": "Put the shrimp back on the flour mixture and shake a bit for the flour to coat."
    },
    {
      "position": 6,
      "text": "Dip the flour coated shrimp back to the egg mixture and then place in the container where the Panko breadcrumbs are. Shake to coat."
    },
    {
      "position": 7,
      "text": "Deep fry for about 3 to 5 minutes or until the color of the outer part turns golden brown."
    },
    {
      "position": 8,
      "text": "Arrange in a plate lined with paper towel."
    },
    {
      "position": 9,
      "text": "Serve with sweet and sour sauce."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 10,
