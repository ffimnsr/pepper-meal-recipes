  "id": "7f47b75b-4031-5d46-9dfa-4c5d6b0f2b88",
  "slug": "sinigang-na-buto-buto-with-gabi-recipe",
  "name": "Sinigang na Buto buto with Gabi Recipe",
  "recipe_type": "soup",
  "brief_description": "Sinigang na Buto buto with Gabi Recipe is a vaiation of the traditional sinigang. Pork neck bones are cooked with taro. The taro makes the soup thicker.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in cooking oil."
    },
    {
      "position": 2,
      "text": "When the oil is hot enough, saut\u00e9 garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the pork neck bones and fish sauce."
    },
    {
      "position": 4,
      "text": "Pour-in water then bring to a boil."
    },
    {
      "position": 5,
      "text": "Add tomatoes and simmer for 40 minutes or until pork is tender."
    },
    {
      "position": 6,
      "text": "Add the sinigang mix, radish, long green chilies, and taro root (gabi) and simmer for 8 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the eggplant and okra then simmer for another 5 minutes."
    },
    {
      "position": 8,
      "text": "Put-in the water spinach and stir. Turn off heat and cover the cooking pot for at least 5 minutes (this will cook the water spinach)."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate then serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
