  "id": "fff50977-9b46-5455-8264-150dce46acff",
  "slug": "lechon-manok-sauce-recipe",
  "name": "Lechon Manok Sauce Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Lechon Manok Sauce. It is a perfect dip for rotisserie chicken.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Bake the chicken liver fin 350F for 15 minutes. Remove from the oven and let cool. Chop into smaller pieces and then set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the garlic and onion when the oil starts to get hot. Cook for 2 minutes"
    },
    {
      "position": 4,
      "text": "Add the baked chicken liver. Cook for another 3 minutes."
    },
    {
      "position": 5,
      "text": "Pour the water in the pot. Let boil."
    },
    {
      "position": 6,
      "text": "Using a hand blender, puree the mixture. You can also pour the mixture in a regular blender and puree until the texture becomes smooth."
    },
    {
      "position": 7,
      "text": "Let the mixture boil. Pour the vinegar in and then let the mixture boil once more."
    },
    {
      "position": 8,
      "text": "Stir and add the brown sugar."
    },
    {
      "position": 9,
      "text": "Add salt and pepper. You may add more if needed. Stir."
    },
    {
      "position": 10,
      "text": "Stir-in the bread crumbs. Continue to cook in medium heat while stirring using a wire whisk until the desired consistency is achieved."
    },
    {
      "position": 11,
      "text": "Add the chicken cube (optional). Continue to cook for 3 minutes."
    },
    {
      "position": 12,
      "text": "Transfer to a sauce bowl. Serve with lechon manok."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
  "difficulty": "hard",
