  "slug": "filipino-pinoy-food-tomato-sauce-beef-mechado-recipe",
  "name": "Beef Mechado Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for beef mechado.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a pan then saute the garlic and onion."
    },
    {
      "position": 2,
      "text": "Put-in the beef and saute for about 3 minutes or until color turns light brown"
    },
    {
      "position": 3,
      "text": "Add the tomato sauce and water then simmer until the meat is tender. Add water as needed. Note this can take 60 to 120 minutes depending on the quality of the beef."
    },
    {
      "position": 4,
      "text": "Add the soy sauce, ground black pepper, lemon rind, laurel leaves, and salt then simmer until excess liquid evaporates"
    },
    {
      "position": 5,
      "text": "Put-in the potatoes and cook until the potatoes are soft"
    },
    {
      "position": 6,
      "text": "Place in a serving plate then serve hot with rice. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
