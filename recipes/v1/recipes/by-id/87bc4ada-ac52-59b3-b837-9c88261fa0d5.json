  "id": "87bc4ada-ac52-59b3-b837-9c88261fa0d5",
  "slug": "arroz-caldo",
  "name": "Arroz Caldo",
  "recipe_type": "snack",
  "brief_description": "Filipino rice porridge made with chicken and rice",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a pot, heat the cooking oil, then saut\u00e9 the garlic, onion, and ginger."
    },
    {
      "position": 2,
      "text": "Add the chicken. Saut\u00e9 until the outer layer turns golden brown."
    },
    {
      "position": 3,
      "text": "Add the uncooked rice. Saut\u00e9 for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour in the water and bring to a boil."
    },
    {
      "position": 5,
      "text": "Add the Maggi Magic Chicken Cube. Stir. Simmer until the rice is fully cooked (about 30 to 40 minutes). Note: Make sure to occasionally stir the mixture to prevent the ingredients from sticking to the bottom of the pan."
    },
    {
      "position": 6,
      "text": "Add the safflower and season with fish sauce. Stir."
    },
    {
      "position": 7,
      "text": "Add the hard-boiled eggs."
    },
    {
      "position": 8,
      "text": "Transfer to a bowl. Top with garlic, green onions, and squeeze some calamansi. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
