  "slug": "sauteed-bottle-gourd-with-ground-pork-and-shrimp",
  "name": "Sauteed Bottle Gourd with Ground Pork and Shrimp",
  "recipe_type": null,
  "brief_description": "This is a recipe for Sauteed Bottle Gourd with Ground Pork and Shrimp",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute garlic, onion, and tomato."
    },
    {
      "position": 3,
      "text": "Once the texture of the tomato and onion becomes soft, add the ground pork. Cook until light brown."
    },
    {
      "position": 4,
      "text": "Add the sliced bottle gourd. Cook for 3 to 5 minutes while stirring."
    },
    {
      "position": 5,
      "text": "Pour the beef broth into the pan (you can also use chicken broth or just water). Let the liquid boil. Cover and cook for 10 minutes."
    },
    {
      "position": 6,
      "text": "Add shrimp. Cook for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 8,
