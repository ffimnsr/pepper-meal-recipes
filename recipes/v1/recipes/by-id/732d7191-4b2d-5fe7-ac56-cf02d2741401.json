  "id": "732d7191-4b2d-5fe7-ac56-cf02d2741401",
  "slug": "anghang-sarap-laing-shrimp",
  "name": "Anghang Sarap Laing",
  "recipe_type": null,
  "brief_description": "This is recipe for Anghang Sarap Laing or ginataang gabi with shrimp.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the gata mixture by combining Knorr Ginataang Gulay Recipe Mix with 4 1/2 cups water. Mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a pot."
    },
    {
      "position": 3,
      "text": "Pan-fry the shrimp for 1 minute per side. Remove and set aside."
    },
    {
      "position": 4,
      "text": "Pour the gata mixture into the cooking pot. Let boil."
    },
    {
      "position": 5,
      "text": "Add pork, onion, ginger, garlic, and chili. Cover the pot. Boil in medium heat for 30 minutes or until the pork becomes tender."
    },
    {
      "position": 6,
      "text": "Add the shrimp paste. Stir."
    },
    {
      "position": 7,
      "text": "Add the dried taro leaves. Cover the cooking pot and continue to cook for 20 minutes in low heat. This will allow the taro to absorb the gata mixture well."
    },
    {
      "position": 8,
      "text": "Stir. Continue to cook for 12 to 15 minutes."
    },
    {
      "position": 9,
      "text": "Add the pan-fried shrimp back into the pot. Stir."
    },
    {
      "position": 10,
      "text": "Transfer immediately to a serving plate. Serve with warm rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
