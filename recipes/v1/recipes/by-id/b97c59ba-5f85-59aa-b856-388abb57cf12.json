  "id": "b97c59ba-5f85-59aa-b856-388abb57cf12",
  "slug": "how-to-cook-roasted-cauliflower",
  "name": "Roasted Cauliflower Recipe",
  "recipe_type": null,
  "brief_description": "This Roasted Cauliflower Recipe is Healthy and Tastes really Awesome. Time to try it for yourself.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large mixing bowl, combine cauliflower florets, olive oil, garlic, salt, parsley, and ground black pepper. Toss until all the ingredients are evenly distributed."
    },
    {
      "position": 2,
      "text": "Preheat oven to 425 degrees Fahrenheit."
    },
    {
      "position": 3,
      "text": "Transfer the cauliflower in a greased baking tray then bake for 25 minutes. Note: you need to stir each floret in the middle of the roasting time."
    },
    {
      "position": 4,
      "text": "Sprinkle some Parmesan cheese on top and roast for 4 minutes more."
    },
    {
      "position": 5,
      "text": "Remove from the oven and transfer on a serving plate."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
