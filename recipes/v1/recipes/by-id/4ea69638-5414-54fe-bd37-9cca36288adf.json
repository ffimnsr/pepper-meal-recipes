  "id": "4ea69638-5414-54fe-bd37-9cca36288adf",
  "slug": "steamed-fish-with-mayonnaise",
  "name": "Steamed Fish with Mayonnaise",
  "recipe_type": "main",
  "brief_description": "Steamed large fish stuffed with scallions and ginger and topped with mayonnaise dressing. The fish is then topped with colorful toppings. This holiday and fiesta dish is best served cold.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Clean the fish by removing the innards, gills, and scales (if necessary)."
    },
    {
      "position": 2,
      "text": "Rub salt on the inner and outer parts of the fish. Stuff fish with scallion and ginger."
    },
    {
      "position": 3,
      "text": "Pour-in about 1 to 1 1/2 quart water in a wide steamer. Let boil. Put the fish in and"
    },
    {
      "position": 4,
      "text": "steam for 35 to 45 minutes depending on the size of the fish. The large the fish, the longer the steaming time."
    },
    {
      "position": 5,
      "text": "Remove the fish from the steamer and then arrange on a serving plate. Let the excess water drip."
    },
    {
      "position": 6,
      "text": "Meanwhile, combine Lady's Choice Mayonnaise with the other mayo dressing ingredients. Mix well."
    },
    {
      "position": 7,
      "text": "When the fish reaches room temperature, spread the mayonnaise mixture over the fish."
    },
    {
      "position": 8,
      "text": "Separate the egg white from the yolk. Mince the eggs. Arrange the topping ingredients over the mayo mixture."
    },
    {
      "position": 9,
      "text": "Refrigerate the fish for 3 hours."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
