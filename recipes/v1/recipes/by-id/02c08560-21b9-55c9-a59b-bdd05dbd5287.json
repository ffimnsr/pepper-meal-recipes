{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "02c08560-21b9-55c9-a59b-bdd05dbd5287",
  "slug": "crispy-fried-chicken-recipe",
  "name": "Crispy Fried Chicken",
  "recipe_type": "side",
  "brief_description": "Crispy Fried Chicken cooked until golden brown with a crunchy coating and juicy meat inside. A simple, delicious dish that brings out the best in home cooking.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the chicken. Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Prepare the batter. Start by pressing a fork on the chicken cube until it is completely squashed. Combine it with warm milk. Stir until well blended. Set aside."
    },
    {
      "position": 4,
      "text": "Combine flour, baking powder, garlic powder, salt, and ground black pepper. Mix well using a fork or a wire whisk. Set aside."
    },
    {
      "position": 5,
      "text": "Beat the eggs in a large mixing bowl. Add the milk mixture. Continue to beat until all the ingredients are all incorporated. Add half of flour mixture. Whisk. Add the remaining half and whisk until the texture of the batter becomes smooth."
    },
    {
      "position": 6,
      "text": "Dredge the chicken in flour and then dip in batter. Roll it again in flour until completely covered. Fry in medium heat for 7 minutes per side."
    },
    {
      "position": 7,
      "text": "Remove from the pot and put in a plate lined with paper towel. This will absorb the oil."
    },
    {
      "position": 8,
      "text": "Serve with ketchup or gravy."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 20,
