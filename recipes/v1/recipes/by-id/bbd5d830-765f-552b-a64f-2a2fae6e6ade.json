{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "bbd5d830-765f-552b-a64f-2a2fae6e6ade",
  "slug": "pasta-noodles-spaghetti-and-meatballs-recipe",
  "name": "Spaghetti and Meatballs",
  "recipe_type": "side",
  "brief_description": "Homecooked Spaghetti and Meatballs with meaty marina sauce. Now, that is a winner! Serve this with more Parmesan cheese and put a slice of garlic bread on the side to have one of the best meals that you ever had.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the meatballs by combining ground beef and pork in a mixing bowl. Add bread crumbs, half of the minced garlic, egg, Parmesan cheese, salt, and ground black pepper. Mix everything together until all ingredients are well distributed."
    },
    {
      "position": 2,
      "text": "Scoop around 3 tablespoons of meat mixture. Put a cube of cheese in the middle. Roll into a ball. Do the same procedure until all the mixture is completely consumed."
    },
    {
      "position": 3,
      "text": "Heat olive oil in a pan. Fry the meatballs until brown. Remove from the pan. Set aside."
    },
    {
      "position": 4,
      "text": "Prepare the meaty marinara sauce. Saute onion and garlic on the remaining olive oil used to fry the meatballs."
    },
    {
      "position": 5,
      "text": "Add stewed tomato and tomato sauce. Stir. Cover and cook between low to medium heat for 20 minutes."
    },
    {
      "position": 6,
      "text": "Add Knorr Pork Cube. Stir. Put the fresh basil into the pot. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Put the meatballs back into the cooking pot. Cover and cook for 10 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt and pepper. Set aside."
    },
    {
      "position": 9,
      "text": "Cook the spaghetti according to package instructions."
    },
    {
      "position": 10,
      "text": "Arrange the cooked spaghetti on a pasta bowl or a plate. Top with sauce and meatballs. Add more Parmesan cheese on top. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
