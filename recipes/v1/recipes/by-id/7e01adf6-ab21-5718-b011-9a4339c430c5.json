  "id": "7e01adf6-ab21-5718-b011-9a4339c430c5",
  "slug": "sushi-bake-recipe",
  "name": "Sushi Bake",
  "recipe_type": "main",
  "brief_description": "Sushi Bake is just the type of irresistible recipe that\u2019s gotten a lot of people trying on their chef hats.",
  "cuisine": "American Japanese",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 400F."
    },
    {
      "position": 2,
      "text": "Combine rice vinegar, sugar, and salt in a bowl. Pop in the microwave for 15 seconds. Stir until the vinegar completely dilutes."
    },
    {
      "position": 3,
      "text": "Put the cooked rice in a large bowl. Combine with the vinegar mixture. Gently toss until the rice gets coated completely."
    },
    {
      "position": 4,
      "text": "Spread the rice mixture evenly in a baking dish. Lightly top with furikake. Set aside."
    },
    {
      "position": 5,
      "text": "Make the creamy topping by combining all the cream topping ingredients in a bowl. Mix well. Spread over the rice."
    },
    {
      "position": 6,
      "text": "Top with remaining furikake. Bake for 18 minutes."
    },
    {
      "position": 7,
      "text": "Make the sriracha mayo topping by combining 5 Tablespoons of Lady\u2019s Choice Mayonnaise with 1 Tablespoon sriracha sauce. Mix well and then transfer into a condiment squeeze bottle. Set aside."
    },
    {
      "position": 8,
      "text": "Remove the sushi bake from the oven. Top it with masago and avocado slices. Drizzle sriracha mayonnaise on top."
    },
    {
      "position": 9,
      "text": "Slice a portion of the sushi bake and place over a small piece of Nori sheet. Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
