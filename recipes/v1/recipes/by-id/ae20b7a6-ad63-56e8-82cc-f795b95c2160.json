  "id": "ae20b7a6-ad63-56e8-82cc-f795b95c2160",
  "slug": "grilled-stuffed-tilapia-recipe",
  "name": "Grilled Stuffed Tilapia Recipe",
  "recipe_type": "side",
  "brief_description": "Grilled Stuffed Tilapia is like your typical grilled whole fish except that it is stuffed with delicious veggies inside. It is simple, easy-to-cook, delicious, and totally Filipino. I enjoyed having it with a dip of spicy toyomansi (ponzu).",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub 1 1/2 teaspoons salt all over the fish. Set aside."
    },
    {
      "position": 2,
      "text": "Combine the tomato, onion, scallions, garlic powder, ginger, lemon juice, pepper, and remaining salt in a bowl. Mix well."
    },
    {
      "position": 3,
      "text": "Stuff the mixture in the cavity of the tilapia."
    },
    {
      "position": 4,
      "text": "Heat-up the grill. Once the grill is ready, spray a little cooking oil on both sides of the tilapia. This will prevent the skin of the fish from sticking on the grill."
    },
    {
      "position": 5,
      "text": "Grill each side of the tilapia for 10 to 12 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the grill and arrange in a serving plate. Serve with your favorite dipping sauce."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 24,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
