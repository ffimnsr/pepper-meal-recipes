  "id": "704236f7-498f-52be-8d91-1da20ffcd3e4",
  "slug": "adobo-pork-chops",
  "name": "Adobo Pork Chops",
  "recipe_type": null,
  "brief_description": "Adobo Pork Chops is a simple pork adobo variation using one of the most favorite pork cuts: pork chops. This adobo pork chops recipe is awesome!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a wide and deep pan."
    },
    {
      "position": 2,
      "text": "Once the oil is hot, pan fry the pork chops turning them over once each side turns light to medium brown (this will take around 3 to 5 minutes per side depending on the thickness of your pork chops)."
    },
    {
      "position": 3,
      "text": "Put-in the garlic, peppercorns, and bay leaves. Continue to cook until the garlic turns light brown (2 to 3 minutes)."
    },
    {
      "position": 4,
      "text": "Pour-in water and soy sauce. Bring to a boil."
    },
    {
      "position": 5,
      "text": "Cover and simmer until the liquid reduces to half (around 40 to 50 minutes). You can add more water if needed."
    },
    {
      "position": 6,
      "text": "Pour-in the vinegar. Let the liquid boil. Stir and continue to cook (uncovered) for 10 minutes."
    },
    {
      "position": 7,
      "text": "Add salt if needed. The soy sauce alone gives this dish enough saltiness. You can add salt according to your preference."
    },
    {
      "position": 8,
      "text": "Serve with steamed white rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
