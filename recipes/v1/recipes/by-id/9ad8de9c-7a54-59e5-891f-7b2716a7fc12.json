  "id": "9ad8de9c-7a54-59e5-891f-7b2716a7fc12",
  "slug": "ginataang-pusit-squid-recipe",
  "name": "Ginataang Pusit Recipe (squid in coconut milk)",
  "recipe_type": null,
  "brief_description": "Ginataang Pusit or Squid cooked in coconut milk is a quick, easy, and delicious Filipino dish that I love to eat with warm rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pan."
    },
    {
      "position": 2,
      "text": "Saute the garlic and onion until the onion becomes soft."
    },
    {
      "position": 3,
      "text": "Put-in the squid. Cook for 1 minute. Remove the squid, place in a clean plate, and set aside."
    },
    {
      "position": 4,
      "text": "Pour-in the coconut milk. Let boil."
    },
    {
      "position": 5,
      "text": "Add the fish sauce and green chili pepper. Simmer uncovered for 12 to 18 minutes or until the coconut milk becomes thick."
    },
    {
      "position": 6,
      "text": "Put the squid back in the pan. Add the malunggay leaves. Stir and cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add the ground black pepper. Stir."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
