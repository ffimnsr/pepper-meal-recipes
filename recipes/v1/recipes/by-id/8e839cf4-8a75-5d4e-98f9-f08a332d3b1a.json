  "id": "8e839cf4-8a75-5d4e-98f9-f08a332d3b1a",
  "slug": "how-to-make-tom-yum-goong-recipe",
  "name": "How to Make Tom Yum Goong",
  "recipe_type": null,
  "brief_description": "This is a recipe for Tom Yum Goong",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot and bring to a boil."
    },
    {
      "position": 2,
      "text": "Put-in galangal, lime leaves, lemon grass, tamarind paste, and fish sauce. Stir well and simmer for 5 minutes."
    },
    {
      "position": 3,
      "text": "Add the shrimps and simmer for 3 to 4 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the onion, straw mushrooms, and chili paste then simmer for another 5 minutes."
    },
    {
      "position": 5,
      "text": "Add chili and tomato then simmer for one minute."
    },
    {
      "position": 6,
      "text": "Put-in the lime juice and cilantro then turn off the heat."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 8,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
