  "id": "a8e44890-ed4e-5b83-a090-be269dfae578",
  "slug": "batangas-bulalo-recipe",
  "name": "Batangas Bulalo Recipe",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Batangas Bulalo or beef shank soup.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Add the beef shank and bones. Cover and then continue to boil in low to medium heat for 1 hour."
    },
    {
      "position": 3,
      "text": "Scoop away the floating scums and oil from the water. Add the onion, whole peppercorn, salt, and fish sauce. Cover and continue to boil for 3 hours."
    },
    {
      "position": 4,
      "text": "Arrange the cabbage and bok choy leaves on a large serving bowl. Put the bones and meat over the vegetables. Scoop the hot soup over the meat."
    },
    {
      "position": 5,
      "text": "Serve with a dipping sauce composed of chili peppers, fish sauce, and lemon or calamansi."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 240,
