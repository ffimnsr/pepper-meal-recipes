  "id": "d9ad892b-cc0f-5e7e-a851-73184af18c6f",
  "slug": "corn-soup-with-quail-eggs",
  "name": "Corn Soup with Quail Eggs",
  "recipe_type": "soup",
  "brief_description": "Corn Soup with Quail Eggs is a tasty soup dish that can be prepared real quick. This yummy recipe is intended for beginners.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken broth and water in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Pour-in the cream style sweet corn. Stir and allow to re-boil. Cover and simmer for 15 minutes. Add water as necessary."
    },
    {
      "position": 3,
      "text": "Add the green onions, salt, and pepper. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in the water with cornstarch. Stir and continue to cook for a minute."
    },
    {
      "position": 5,
      "text": "Drop-in the chicken egg. Quickly stir until until the egg is distributed."
    },
    {
      "position": 6,
      "text": "Add the boiled quail eggs. Cover and turn the heat off. Let it stay covered for 5 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
