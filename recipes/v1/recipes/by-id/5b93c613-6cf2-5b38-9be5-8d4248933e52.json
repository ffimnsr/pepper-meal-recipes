{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "5b93c613-6cf2-5b38-9be5-8d4248933e52",
  "slug": "how-to-make-baked-pork-chops-with-italian-seasoning-recipe",
  "name": "Baked Pork Chops with Italian Seasoning",
  "recipe_type": "main",
  "brief_description": "Juicy bone-in pork chops coated in a savory blend of Italian seasoning, garlic powder, and paprika, then seared to golden perfection and baked until tender. The butter-rosemary basting creates an incredibly flavorful finish that pairs beautifully with mashed potatoes or roasted vegetables.",
  "cuisine": "American Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the water and kosher salt in a bowl. Stir until the salt dissolves completely. Submerge the pork chops in the brine and refrigerate for 1 hour."
    },
    {
      "position": 2,
      "text": "Remove the pork chops from the brine and pat them completely dry with paper towels."
    },
    {
      "position": 3,
      "text": "Combine the ground black pepper, Italian seasoning, garlic powder, paprika, and brown sugar in a small bowl. Drizzle olive oil over the pork chops and rub to coat. Sprinkle the seasoning mixture evenly over both sides and gently press it into the meat."
    },
    {
      "position": 4,
      "text": "Let the seasoned pork chops sit at room temperature for 30 minutes."
    },
    {
      "position": 5,
      "text": "Preheat the oven to 375\u00b0F."
    },
    {
      "position": 6,
      "text": "Heat a cast iron skillet over medium-high heat until very hot. Place the pork chops in the skillet and sear without moving for 2 to 3 minutes until a golden-brown crust forms. Flip and sear the other side for 2 minutes."
    },
    {
      "position": 7,
      "text": "Reduce the heat to medium. Add the butter, smashed garlic, and rosemary to the skillet. Once the butter melts, tilt the pan slightly and use a spoon to baste the pork chops with the melted butter for about 1 minute."
    },
    {
      "position": 8,
      "text": "Transfer the skillet to the oven and bake for 8 minutes or until the internal temperature reaches 140\u00b0F."
    },
    {
      "position": 9,
      "text": "Remove from the oven and transfer the pork chops to a serving plate. Let rest for 5 minutes. Spoon the pan juices over the pork chops before serving."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
  "rest_time_minutes": 5,
