  "id": "2a6b4446-a385-5c1c-959c-b3688d25eb0e",
  "slug": "chicken-embutido-recipe",
  "name": "Chicken Embutido",
  "recipe_type": "main",
  "brief_description": "This is the chicken version of Steamed Filipino Meatloaf",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a large mixing bowl, combine the ground chicken, carrots, bell peppers, onion, raisins, sweet relish, cheese, and tomato sauce. Mix well."
    },
    {
      "position": 2,
      "text": "Pour-in the olive oil. Add the salt and pepper. Continue to stir until all the ingredients are well blended."
    },
    {
      "position": 3,
      "text": "Put the eggs and bread crumbs in the mixing bowl. Continue to mix with the other ingredients."
    },
    {
      "position": 4,
      "text": "Wrap the mixture (around 1 to 1 1/4 cup) in aluminum foil. Do this step until all the mixture are consumed."
    },
    {
      "position": 5,
      "text": "Arranged the chicken embutido in a steamer. Steam for 45 to 60 minutes."
    },
    {
      "position": 6,
      "text": "Remove the steamed embutido from the steamer. Let it cool down. You can also place it in the fridge."
    },
    {
      "position": 7,
      "text": "Slice the embutido and arrange in a serving plate."
    },
    {
      "position": 8,
      "text": "Serve chilled. Share and enjoy!"
    }
  ],
  "servings": 12,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
