  "id": "bfe30829-e017-5b54-a9da-54fefb7107b7",
  "slug": "special-chicken-afritada",
  "name": "Special Chicken Afritada",
  "recipe_type": "main",
  "brief_description": "Special Chicken Afritada is a flavorful Filipino stew made with chicken simmered in a rich tomato sauce and a mix of vegetables for a deliciously unique dish.",
  "cuisine": "Flipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a wok. Pan-fry the potatoes and carrots until they brown a bit (about 3 to 4 minutes). Set aside."
    },
    {
      "position": 2,
      "text": "Reduce the oil to 3 tablespoons. Pan-fry the chicken livers for 30 seconds on each side. Remove the liver and set aside."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the onion and garlic until the onion softens. Add the chicken pieces and continue saut\u00e9ing until the outer part turns light brown."
    },
    {
      "position": 4,
      "text": "Pour the soy sauce into the wok and cook for 30 seconds. Add the hotdogs and cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour the tomato sauce into the wok, add 1 cup of water, stir, and bring it to a boil."
    },
    {
      "position": 6,
      "text": "Add the chicken liver and dried bay leaves. Simmer for 30 minutes."
    },
    {
      "position": 7,
      "text": "Add the green peas and bell peppers, and cook for 2 minutes. Then, add the fried potatoes and carrots and stir."
    },
    {
      "position": 8,
      "text": "Season with the Maggi Magic Chicken Cube, stirring and cooking for 1 minute. Adjust seasoning with fish sauce and ground black pepper to taste. Top with grated cheese."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
