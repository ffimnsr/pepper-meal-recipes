  "id": "5ba383c4-515e-56a5-b247-40318297505f",
  "slug": "cook-pork-bagnet-crispy-fried-pork-belly",
  "name": "How to Cook Pork Bagnet",
  "recipe_type": null,
  "brief_description": "This is a recipe for crispy pork bagnet,",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a deep cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add pork fat or bacon grease and then put the pork belly into the pot. Cover and boil in medium heat for 2 to 2 \u00bd hours or until the pork belly becomes very tender."
    },
    {
      "position": 3,
      "text": "Remove the pork belly from the cooking pot. Let the temperature cool down to a point wherein you can handle it with your hands. Tap the pork dry with a piece of paper towel. Set aside."
    },
    {
      "position": 4,
      "text": "Heat oil in a deep fryer or a deep cooking pot (until it reaches around 350F)."
    },
    {
      "position": 5,
      "text": "Deep-fry the boiled pork belly for 15 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the pot or deep fryer. Let excess oil drip."
    },
    {
      "position": 7,
      "text": "Cut into serving pieces. Serve with spicy vinegar or you can also use this as an ingredient to other dishes such as pinakbet and sinigang na may bagnet."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 190,
