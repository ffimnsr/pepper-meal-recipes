  "id": "dc32055c-5bcd-5050-968e-77cae51fa8f0",
  "slug": "fish-in-ginger-soup-recipe",
  "name": "Fish in Ginger Soup",
  "recipe_type": "soup",
  "brief_description": "This Fish in Ginger Soup Recipe can make you feel warm and comfortable during cold weather. Try this delicious soup today.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a deep pot"
    },
    {
      "position": 2,
      "text": "Saute the ginger and onions for 1 minute"
    },
    {
      "position": 3,
      "text": "Put-in the ground black pepper and lemongrass. Cook for another minute."
    },
    {
      "position": 4,
      "text": "Pour-in water. Let boil."
    },
    {
      "position": 5,
      "text": "Add-in the fish and fish sauce. Let the liquid re-boil and then simmer for 5 to 8 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the malunggay leaves and the juice from half a lemon. Gently stir and cook in low to medium heat for 3 minutes."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
