  "id": "593d90ef-c06e-5fe5-9d21-2fc5df159b5c",
  "slug": "orange-chicken-recipe",
  "name": "Orange Chicken Recipe",
  "recipe_type": null,
  "brief_description": "I love this Orange Chicken Recipe; it is absolutely delicious! Before we start cooking, did you know that Orange Chicken is a dish of American-Chinese origin?",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a container, put-in the flour, salt, and ground black pepper then mix well"
    },
    {
      "position": 2,
      "text": "Dip the chicken on the beaten egg mixture and place inside the container (where the flour, salt, and pepper are)"
    },
    {
      "position": 3,
      "text": "Close the container and shake until the chicken is evenly coated with the flour mixture"
    },
    {
      "position": 4,
      "text": "Deep fry the chicken for about 7 minutes or until the color turns golden brown. Set aside"
    },
    {
      "position": 5,
      "text": "In a pan, put-in the water, soy sauce, vinegar, and orange juice then bring to a boil"
    },
    {
      "position": 6,
      "text": "Add the garlic and simmer for 5 minutes"
    },
    {
      "position": 7,
      "text": "Add the sugar and and simmer for 3 to 5 minutes"
    },
    {
      "position": 8,
      "text": "Put-in the green onions and cornstarch (diluted in 2 tbsp of water) then mix well"
    },
    {
      "position": 9,
      "text": "Add the deep-fried chicken on pan and cook until sauce nearly evaporates"
    },
    {
      "position": 10,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 15,
