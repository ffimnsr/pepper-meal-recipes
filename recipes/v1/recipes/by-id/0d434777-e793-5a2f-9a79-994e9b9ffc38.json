  "id": "0d434777-e793-5a2f-9a79-994e9b9ffc38",
  "slug": "teriyaki-bistek-recipe",
  "name": "Teriyaki Bistek Recipe",
  "recipe_type": null,
  "brief_description": "Teriyaki Bistek is the result of combining Bistek Tagalog and Beef Teriyaki. This is the counterpart of crossovers in the automobile world",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine soy sauce, sugar and juice from 1 lemon. Mix well."
    },
    {
      "position": 2,
      "text": "Marinate the skirt steak in the soy sauce mixture for 30 minutes."
    },
    {
      "position": 3,
      "text": "Segregate the beef with the marinade."
    },
    {
      "position": 4,
      "text": "Heat the cooking oil and then sear the marinated beef for 3 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the remaining marinade, water, and sesame oil. Stir and then let boil. Simmer for 30 minutes Add water as necessary."
    },
    {
      "position": 6,
      "text": "Let the liquid reduce to half. Pour-in cornstarch diluted in water. Stir until the sauce thickens."
    },
    {
      "position": 7,
      "text": "Add salt and pepper."
    },
    {
      "position": 8,
      "text": "Add the onion. Cover and cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Sprinkle sesame seeds on top."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "hard",
