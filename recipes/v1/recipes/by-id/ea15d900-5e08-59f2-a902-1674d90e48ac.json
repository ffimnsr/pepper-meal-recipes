  "id": "ea15d900-5e08-59f2-a902-1674d90e48ac",
  "slug": "pinoy-fried-chicken",
  "name": "Pinoy Fried Chicken Recipe",
  "recipe_type": "main",
  "brief_description": "This simple Filipino Fried Chicken Recipe is quick and easy to make. Make this a part of your daily menu.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Squeeze the lemon over the chicken. Make sure that every area is coated. Let it stay for 30 minutes."
    },
    {
      "position": 2,
      "text": "Combine salt, pepper, and garlic and then rub all over the chicken leg quarters. Place inside the fridge for an hour to absorb the seasonings."
    },
    {
      "position": 3,
      "text": "Heat the oil in a frying pan."
    },
    {
      "position": 4,
      "text": "When the oil becomes hot, pan fry each side in medium heat for about 15 minutes. The skin should be a bit crisp."
    },
    {
      "position": 5,
      "text": "Arrange in a plate lined with paper towel to absorb excess oil."
    },
    {
      "position": 6,
      "text": "Serve with banana ketchup. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
