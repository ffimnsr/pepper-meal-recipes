  "id": "e6f106a4-32b9-534c-88e8-43aabdfb4f2f",
  "slug": "pata-kare-kare-recipe",
  "name": "Pata Kare-Kare",
  "recipe_type": "main",
  "brief_description": "Pork Kare-Kare is a Filipino stew featuring tender pork cooked in a rich, savory peanut sauce, often accompanied by vegetables and served with bagoong alamang.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil the pata in 1 quart of water for 10 minutes. Let it cool down. Discard the water and wash the pata thoroughly. Set it aside."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a wok. Saut\u00e9 the garlic and onion until the onion softens."
    },
    {
      "position": 3,
      "text": "Add the boiled pata. Saut\u00e9 for 30 seconds, then pour in the remaining water. Cover and let it boil."
    },
    {
      "position": 4,
      "text": "Add the beef powder, annatto powder, and turmeric powder. Stir well. Cover and simmer until the pork pata is completely tender. Note: Add water as needed."
    },
    {
      "position": 5,
      "text": "Stir in the peanut butter."
    },
    {
      "position": 6,
      "text": "Season with Maggi Magic Sarap and thicken the sauce by adding the slurry. Note: Make the slurry by combining 1 tablespoon of cornstarch with 3 tablespoons of water."
    },
    {
      "position": 7,
      "text": "Add the eggplant, string beans, and banana blossoms. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Add the baby bok choy and cook for an additional 2 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve with bagoong alamang (shrimp paste)."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
