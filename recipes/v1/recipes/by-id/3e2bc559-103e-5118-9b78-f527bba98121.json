  "id": "3e2bc559-103e-5118-9b78-f527bba98121",
  "slug": "ginataang-hipon-sitaw-at-kalabasa",
  "name": "Ginataang Hipon, Sitaw, at Kalabasa",
  "recipe_type": "main",
  "brief_description": "Shrimp with string beans and calabaza squash cooked in coconut milk.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute the garlic and onion until the onion becomes soft."
    },
    {
      "position": 3,
      "text": "Put-in the shrimp. Cook for 1 to 2 minutes. Remove from the pot and set aside."
    },
    {
      "position": 4,
      "text": "Meanwhile, put-in the bagoong alamang and pour-in the coconut milk. Stir and let boil."
    },
    {
      "position": 5,
      "text": "Add the kalabasa. Cook for 8 to 12 minutes or until tender."
    },
    {
      "position": 6,
      "text": "Put the shrimp back in the pot. Stir and cook for a minute."
    },
    {
      "position": 7,
      "text": "Add the string beans (sitaw) and malunggay leaves. Cook for 2 to 3 minutes."
    },
    {
      "position": 8,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
