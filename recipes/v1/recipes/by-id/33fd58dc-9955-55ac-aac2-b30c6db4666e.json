  "id": "33fd58dc-9955-55ac-aac2-b30c6db4666e",
  "slug": "ukoy-shrimp-fritters-recipe",
  "name": "Ukoy Recipe (Shrimp Fritter)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ukoy Recipe (Shrimp Fritter)",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine cornstarch, flour, baking powder, egg, water, salt, and ground black pepper then stir until diluted."
    },
    {
      "position": 2,
      "text": "Add the shrimps and mung bean sprouts in the mixture and lightly stir to distribute."
    },
    {
      "position": 3,
      "text": "Heat a frying pan or small cooking pot and pour-in the cooking oil."
    },
    {
      "position": 4,
      "text": "When the oil is hot enough, scoop about 2 to 3 tablespoons of the mixture and quickly (but cautiously) drop it in hot oil."
    },
    {
      "position": 5,
      "text": "Cook each side for 2 to 3 minutes or until the color turns golden brown. Please note that cooking time may vary. Repeat this step until the entire mixture is consumed."
    },
    {
      "position": 6,
      "text": "Remove the deep-fried ukoy from the pan and place in a plate lined with paper towel to absorb the oil."
    },
    {
      "position": 7,
      "text": "Remove the paper towel and serve with sinamak."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 6,
  "preparation_time_minutes": 5,
