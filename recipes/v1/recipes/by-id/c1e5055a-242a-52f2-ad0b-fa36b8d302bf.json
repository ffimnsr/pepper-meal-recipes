  "id": "c1e5055a-242a-52f2-ad0b-fa36b8d302bf",
  "slug": "grilled-liempo-with-barbecue-sauce",
  "name": "Grilled Liempo with Barbecue Sauce",
  "recipe_type": "main",
  "brief_description": "Grilled marinated pork belly with BBQ sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine marinade ingredients in a large bowl. Stir until well blended."
    },
    {
      "position": 2,
      "text": "Add pork belly. Make sure that the pork gets coated with the marinade. Cover the bowl and marinate for at least 3 hours. Note: the longer the time, the more flavorful the mixture gets."
    },
    {
      "position": 3,
      "text": "Heat-up the grill. Grill one side of the pork for 2 minutes. Baste the top part by brushing the remaining marinade. Turn the pork belly over and do the same procedure on the opposite side. Note: Continue this step until the pork is cooked completely."
    },
    {
      "position": 4,
      "text": "Transfer to a serving plate. Serve with warm rice along with your favorite condiments. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 18,
