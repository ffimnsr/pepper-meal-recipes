  "slug": "java-rice-recipe",
  "name": "Java Rice Recipe",
  "recipe_type": null,
  "brief_description": "This Java Rice Recipe caters to the Filipino taste. This recipe is so simple and does not involve cooking. All you need to do is mix hot steamed white rice with all the ingredients.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt margarine by using the microwave oven (about 10 seconds)."
    },
    {
      "position": 2,
      "text": "Combine turmeric and annatto powder. Mix well."
    },
    {
      "position": 3,
      "text": "Put-in garlic powder, onion powder, and salt. Stir until everything is distributed."
    },
    {
      "position": 4,
      "text": "Pour-in mixture on warm steamed rice. Gently mix so that the rice is coated by the mixture."
    },
    {
      "position": 5,
      "text": "Serve with Fried Pork Chop and Atchara."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 2,
  "preparation_time_minutes": 10,
