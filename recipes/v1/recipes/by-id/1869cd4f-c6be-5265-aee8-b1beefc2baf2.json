  "id": "1869cd4f-c6be-5265-aee8-b1beefc2baf2",
  "slug": "angel-food-cake-with-strawberries",
  "name": "Angel Food Cake with Strawberries",
  "recipe_type": "dessert",
  "brief_description": "Angel food cake with fresh strawberries",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 300 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Combine 1/4 cup sugar, flour, and salt. Sift. Set aside."
    },
    {
      "position": 3,
      "text": "Using an electric mixer, beat the egg whites until foams form (use low speed)."
    },
    {
      "position": 4,
      "text": "Put-in salt, vanilla extract, and cream of tartar. Continue beating in a faster speed until soft peaks form."
    },
    {
      "position": 5,
      "text": "Gradually add the remaining 1/2 cup of sugar while mixing. Continue mixing (in high speed this time) for 1 to 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the mixture in a mixing bowl, and then Fold in the flour mixture one part at a time."
    },
    {
      "position": 7,
      "text": "Pour the mixture in a round cake pan. Place inside the oven and bake for 30 to 40 minutes."
    },
    {
      "position": 8,
      "text": "Remove the cake from the oven and let cool in a wire rack."
    },
    {
      "position": 9,
      "text": "Transfer to a serving tray. Top with whipped cream and arrange the sliced strawberries on top."
    },
    {
      "position": 10,
      "text": "Serve for dessert."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
