  "id": "596d6235-bebb-5f87-ab8a-f2f1e9d8d38d",
  "slug": "chili-garlic-shrimp-stir-fry",
  "name": "Chili Garlic Shrimp Stir Fry",
  "recipe_type": "main",
  "brief_description": "A quick and flavorful Filipino shrimp dish cooked in butter with garlic, banana ketchup, and Sriracha. Similar to the chili shrimp served in Dampa seafood markets, but easy to make at home.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a pan."
    },
    {
      "position": 2,
      "text": "Once the butter melts, continue to heat until hot."
    },
    {
      "position": 3,
      "text": "Add the garlic. Cook for 1 to 2 minutes or until light brown."
    },
    {
      "position": 4,
      "text": "Put-in the shrimp. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the sherry. Continue to cook until the liquid completely evaporates."
    },
    {
      "position": 6,
      "text": "Add ketchup and Sriracha sauce. Continue to stir fry for 1 minute."
    },
    {
      "position": 7,
      "text": "Put-in the green onions. Add salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
