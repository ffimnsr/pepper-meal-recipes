  "id": "c33143cb-1880-5359-ace9-ce5a79c26900",
  "slug": "embutido",
  "name": "Embutido",
  "recipe_type": "main",
  "brief_description": "Embutido is a type of meatloaf prepared Filipino style. Though a well known dish for the holidays, Embutido can be enjoyed everyday",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place the ground pork in a large container"
    },
    {
      "position": 2,
      "text": "Add the bread crumbs then break the raw eggs and add it in. Mix well"
    },
    {
      "position": 3,
      "text": "Put-in the carrots, bell pepper (red and green), onion, pickle relish, and cheddar cheese. Mix thoroughly"
    },
    {
      "position": 4,
      "text": "Add the raisins, tomato sauce, salt, and pepper then mix well."
    },
    {
      "position": 5,
      "text": "Place the meat mixture in an aluminum foil and flatten it. (see video for guidance)"
    },
    {
      "position": 6,
      "text": "Put in the sliced vienna sausage and sliced boiled eggs alternately on the middle of the flat meat mixture."
    },
    {
      "position": 7,
      "text": "Roll the foil to form a cylinder \u2014 locking the sausage and egg in the middle if the meat mixture. Once done, lock the edges of the foil."
    },
    {
      "position": 8,
      "text": "Place in a steamer and let cook for 1 hour."
    },
    {
      "position": 9,
      "text": "Place inside the refrigerator until temperature turns cold"
    },
    {
      "position": 10,
      "text": "Slice and serve. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
