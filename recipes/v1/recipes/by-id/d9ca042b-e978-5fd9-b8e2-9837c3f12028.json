  "id": "d9ca042b-e978-5fd9-b8e2-9837c3f12028",
  "slug": "fried-fish-sandwich",
  "name": "Fried Fish Sandwich",
  "recipe_type": null,
  "brief_description": "Fried fish sandwich is a delicious sandwich recipe involving mahi-mahi fillets. The fish is dredged in flour, dipped in egg, and coated with crumbs",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt and pepper on the mahi-mahi fillets."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a frying pan."
    },
    {
      "position": 3,
      "text": "Dredge the mahi-mahi in flour and then dip in beaten egg."
    },
    {
      "position": 4,
      "text": "Roll the fish fillet in Panko breadcrumbs while pressing a little to ensure that the crumbs stick."
    },
    {
      "position": 5,
      "text": "Pan-fry each side in low to medium heat for about 4 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the pan and place in a plate lined with paper towel."
    },
    {
      "position": 7,
      "text": "Assemble the sandwich by arranging the tomato and lettuce. Put the fried fish fillet in and then top with tartar sauce."
    },
    {
      "position": 8,
      "text": "Serve with sweet potato fries."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
