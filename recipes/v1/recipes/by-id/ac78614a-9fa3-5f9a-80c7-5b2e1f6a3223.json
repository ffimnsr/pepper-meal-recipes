  "id": "ac78614a-9fa3-5f9a-80c7-5b2e1f6a3223",
  "slug": "mushroom-and-spinach-omelet",
  "name": "Mushroom and Spinach Omelet",
  "recipe_type": "breakfast",
  "brief_description": "Mushroom and Spinach Omelet is a good meal idea for breakfast. This healthy dish involves spinach, mushrooms, and beaten egg.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat 1 tablespoon of olive oil in a pan."
    },
    {
      "position": 2,
      "text": "When the oil is hot, put-in the mushroom. Cook for 2 minutes."
    },
    {
      "position": 3,
      "text": "Add the spinach. Sprinkle salt and pepper. Stir and then cook for 1 to 2 minutes. Remove from the pan. Set aside."
    },
    {
      "position": 4,
      "text": "Crack the eggs and place in a bowl. Add salt and pepper. Beat the eggs until the texture becomes soft."
    },
    {
      "position": 5,
      "text": "Wipe the pan with clean paper towel. Heat it again and then pour-in half of the remaining olive oil."
    },
    {
      "position": 6,
      "text": "When the oil starts to get hot, pour half of the beaten egg mixture in the pan. Spread the egg so that it will be cooked evenly."
    },
    {
      "position": 7,
      "text": "When the eggs are cooked halfway, scoop half of the cooked spinach and mushroom and then arrange on one end of the egg."
    },
    {
      "position": 8,
      "text": "Fold the other end of the egg using a spatula to cover the spinach and mushroom."
    },
    {
      "position": 9,
      "text": "Gently slide the omelet to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 3,
