  "id": "9dd8146a-1302-51d0-8368-995b8721d30d",
  "slug": "danggit-fried-rice",
  "name": "Danggit Fried Rice",
  "recipe_type": null,
  "brief_description": "This is a recipe for danggit fried rice. Danggit is a variety of dried fish.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok."
    },
    {
      "position": 2,
      "text": "Once the oil starts to get hot, add the garlic. Cook for 10 to 15 seconds."
    },
    {
      "position": 3,
      "text": "Add the chopped danggit. Stir-fry until the garlic turns light brown."
    },
    {
      "position": 4,
      "text": "Put the rice in the wok and stir-fry. Make sure that all ingredients are well blended. Continue to stir-fry for 5 to 8 minutes."
    },
    {
      "position": 5,
      "text": "Transfer the danggit fried rice in a plate. Top with chopped green onions."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
