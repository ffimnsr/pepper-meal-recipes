  "id": "b65cd558-f213-5f89-8525-ac12b92d39fd",
  "slug": "liempo-estofado",
  "name": "Liempo Estofado Recipe",
  "recipe_type": "dessert",
  "brief_description": "Liempo Estofado is a sweet stew composed of pork belly (liempo), saba banana, and carrots. The components are cooked in mixture of soy sauce, vinegar, and sugar.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic."
    },
    {
      "position": 3,
      "text": "Add the pork and cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in the soy sauce and water. Add the bay leaves and ground black pepper. Let boil and then simmer for 30 minutes."
    },
    {
      "position": 5,
      "text": "Add the vinegar and sugar. Cook for 15 minutes. Note: add water if needed"
    },
    {
      "position": 6,
      "text": "Put-in the banana and carrots. Cook for 10 minutes."
    },
    {
      "position": 7,
      "text": "Add salt to taste."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
