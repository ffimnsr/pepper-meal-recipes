  "id": "ed92ca42-3924-5ac4-b6ef-8589b1a6aed9",
  "slug": "spicy-camaron-rebosado-deep-fried-beer-battered-shrimp",
  "name": "Spicy Camaron Rebosado (Deep Fried Beer Battered Shrimp)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Spicy Camaron Rebosado (Deep Fried Beer Battered Shrimp)",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Beat the egg in a bowl."
    },
    {
      "position": 3,
      "text": "Add ground black pepper, garlic powder, salt, and cayenne pepper."
    },
    {
      "position": 4,
      "text": "Pour the beer. Whisk until the ingredients are well blended."
    },
    {
      "position": 5,
      "text": "Add half of the flour. Continue to whisk until the texture becomes smooth. Add the remaining flour and whisk some more."
    },
    {
      "position": 6,
      "text": "Put the baking powder in the bowl. Stir until well blended."
    },
    {
      "position": 7,
      "text": "Dip the shrimp in the batter. Gently drop on the pot with oil and then deep fry for 2 minutes. Roll the shrimp over and continue to deep fry for 1 minute. Remove the fried beer battered shrimp and place in a plate topped with a paper towel. Perform this step until all the shrimp are cooked."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with ponzu or sweet and sour sauce."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 4,
  "preparation_time_minutes": 5,
