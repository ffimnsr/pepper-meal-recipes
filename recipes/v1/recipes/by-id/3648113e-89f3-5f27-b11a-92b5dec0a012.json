  "id": "3648113e-89f3-5f27-b11a-92b5dec0a012",
  "slug": "crawfish-in-coconut-milk-with-spinach",
  "name": "Crawfish in Coconut Milk with Spinach",
  "recipe_type": null,
  "brief_description": "This is a recipe involving crayfish. It is also known as crawfish and freshwater lobster. The dish is called Crawfish in Coconut Milk with Spinach.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 onion and garlic until the onion turns translucent"
    },
    {
      "position": 3,
      "text": "Add the shrimp paste. Stir and cook for 30 seconds."
    },
    {
      "position": 4,
      "text": "Pour the coconut milk in the pot. Let boil. Cover and cook in medium heat until it reduces to half."
    },
    {
      "position": 5,
      "text": "Add the chili and crawfish. Stir and cook for 5 minutes while stirring every minute."
    },
    {
      "position": 6,
      "text": "Slide-in the spinach and add the pepper powder. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve with warm white rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
