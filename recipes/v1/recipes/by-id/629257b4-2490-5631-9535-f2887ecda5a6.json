  "id": "629257b4-2490-5631-9535-f2887ecda5a6",
  "slug": "buffalo-chicken-wings",
  "name": "Buffalo Chicken Wings Recipe",
  "recipe_type": "snack",
  "brief_description": "This Buffalo Chicken Wings Recipe is really good. It is nice to serve this during gameday or even as a snack during ordinary days.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine flour, chili powder, salt, and paprika in a mixing bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Put the chicken in the mixing bowl and coat with the flour mixture."
    },
    {
      "position": 3,
      "text": "Heat a cooking pot and pour-in cooking oil."
    },
    {
      "position": 4,
      "text": "Deep fry the chicken wings until golden brown. Set aside."
    },
    {
      "position": 5,
      "text": "Melt the butter in a sauce pan."
    },
    {
      "position": 6,
      "text": "Put-in hot sauce, ground black pepper, and garlic powder. Stir."
    },
    {
      "position": 7,
      "text": "Pour-in the butter mixture over the fried chicken wings. Mix to distribute the sauce evenly."
    },
    {
      "position": 8,
      "text": "Transfer on a serving plate."
    },
    {
      "position": 9,
      "text": "Serve with your favorite dip. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
