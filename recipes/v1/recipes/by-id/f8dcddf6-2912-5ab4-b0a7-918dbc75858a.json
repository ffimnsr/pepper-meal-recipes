  "id": "f8dcddf6-2912-5ab4-b0a7-918dbc75858a",
  "slug": "creamy-seafood-pasta-recipe",
  "name": "Creamy Seafood Pasta Recipe",
  "recipe_type": null,
  "brief_description": "Creamy Seafood Pasta is a delicious creamy pasta dish that makes use of linguine, shrimp, bay scallops, mussels, and clams.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the cooked linguine in a serving plate."
    },
    {
      "position": 2,
      "text": "Make the white sauce by melting the butter in a sauce pan."
    },
    {
      "position": 3,
      "text": "Add the flour, stir and then cook for 1 minute in low heat."
    },
    {
      "position": 4,
      "text": "Pour-in the milk and continuously stir until the texture becomes soft. Set Aside."
    },
    {
      "position": 5,
      "text": "Heat olive oil in a pan."
    },
    {
      "position": 6,
      "text": "Saut\u00e9 onion and garlic"
    },
    {
      "position": 7,
      "text": "Add the shrimp and bay scallops. Cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Put-in the mussels and clams. Cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Pour-in the white wine and let boil."
    },
    {
      "position": 10,
      "text": "Pour-in the white sauce. Stir and then add the parmesan cheese. Continue cooking for 1 minute."
    },
    {
      "position": 11,
      "text": "Top the sauce and seafood over the linguine. Garnish with chopped parsley."
    },
    {
      "position": 12,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
