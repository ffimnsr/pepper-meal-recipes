  "id": "0e7febfa-e076-5a04-914c-0e19cade065f",
  "slug": "spicy-sotanghon-chicken-soup",
  "name": "Spicy Sotanghon Chicken Soup",
  "recipe_type": "soup",
  "brief_description": "Anyone who has tried the classic chicken soup might agree when I say that the simplest appeal might be found in this bowl of pure comfort.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine garlic, onion, ginger, lemongrass, and chili. Crush the ingredients using a mortar and pestle tool or a food processor. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot. Saute the crushed ingredients for 1 minute."
    },
    {
      "position": 3,
      "text": "Add chicken. Saute until outer part turns light brown."
    },
    {
      "position": 4,
      "text": "Pour-in water. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Chicken Cube. Cover the pot. Continue cooking using low to medium heat for 30 minutes."
    },
    {
      "position": 6,
      "text": "Add sotanghon. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add green onions and season with patis and ground white pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
