{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "36cf6ba8-88fe-5c10-b8cb-30dc30338600",
  "slug": "tofu-steak-fried-in-honey-and-rosemary-with-tuna-tomato-sauce",
  "name": "Tofu Steak Fried in Honey and Rosemary with Tuna & Tomato Sauce",
  "recipe_type": null,
  "brief_description": "Tofu Steak Fried in Honey and Rosemary with Tuna & Tomato Sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make sure that your block of tofu is dried by wiping it with a tissue paper. This will make it easier to fry later on."
    },
    {
      "position": 2,
      "text": "Put a dash of salt, pepper and rosemary on all sides of your tofu. Set it aside."
    },
    {
      "position": 3,
      "text": "Slice all your vegetables."
    },
    {
      "position": 4,
      "text": "Open your cans of tuna and mushrooms."
    },
    {
      "position": 5,
      "text": "Prepare one pan and one casserole."
    },
    {
      "position": 6,
      "text": "Heat your pan and pour about 2 tbsps. of oil and 4 tbsps. of honey."
    },
    {
      "position": 7,
      "text": "Once the oil and honey are hot, put your block of tofu. Make sure that each side is fried equally."
    },
    {
      "position": 8,
      "text": "While waiting for each side to be fried, you can now heat your casserole and pour about 4 tbsps. of oil."
    },
    {
      "position": 9,
      "text": "Put all the rest of the ingredients (tomatoes, bell pepper, garlic, onion, tuna, mushrooms including the herbs and mix them all together.)"
    },
    {
      "position": 10,
      "text": "After about 2 mins., pour the packet of ketchup and spaghetti sauce. Mix."
    },
    {
      "position": 11,
      "text": "Let everything boil."
    },
    {
      "position": 12,
      "text": "If you can multitask like I usually do (coz I'm always in such a hurry), after about 10 minutes, both your dishes should be pretty much done. Put the fried tofu on a shallow bowl then pour the Tuna and Tomato Sauce around it."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
