  "id": "cf619c9f-7c63-53ff-b010-a4b8329450a6",
  "slug": "tinapa-fried-rice-smoked-fish-fried-rice",
  "name": "Tinapa Fried Rice (Smoked Fish Fried Rice)",
  "recipe_type": null,
  "brief_description": "Tinapa Fried Rice is a fried rice version that makes use of smoked fish flakes. This ingredient is locally known in Manila as Tinapa",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine salt and leftover rice. Toss to mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a large pan. Add the garlic and cook until light brown. Add the tinapa flakes. Cook for 3 minutes."
    },
    {
      "position": 3,
      "text": "Slowly add the rice. Stir fry for 2 to 5 minutes or until all the ingredients are well blended."
    },
    {
      "position": 4,
      "text": "Add the ground black pepper and chopped green onions. Toss and stir fry for another 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Transfer to serving plate. Top with sliced salted eggs and cubed tomatoes."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
