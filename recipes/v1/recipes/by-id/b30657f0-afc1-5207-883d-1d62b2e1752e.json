  "id": "b30657f0-afc1-5207-883d-1d62b2e1752e",
  "slug": "tinumis-recipe",
  "name": "Tinumis Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Tinumis. It is a blood stew dish from the province Nueva Ecija in the Philippines.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic until it turns medium brown."
    },
    {
      "position": 3,
      "text": "Add the onion. Saut\u00e9, and then add the tomato. Cook until both onion and tomato gets soft."
    },
    {
      "position": 4,
      "text": "Stir-in the pork and then cook until the pork gets light brown. Continue to cook in low to medium heat while constantly stirring for 5 to 7 minutes. Add the Sinigang sa Sampaloc mix. Stir."
    },
    {
      "position": 5,
      "text": "Pour the pork blood in the pan. Stir and cook for 10 to 15 minutes."
    },
    {
      "position": 6,
      "text": "Pour water. Stir. Continue to cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add the Knorr pork cube. Stir. Cover the pot. Cook in low heat for 15 to 25 minutes. Add more water if needed."
    },
    {
      "position": 8,
      "text": "Sprinkle some salt and ground black pepper and add the long green peppers. Stir and cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl, Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
