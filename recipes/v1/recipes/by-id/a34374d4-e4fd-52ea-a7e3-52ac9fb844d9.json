  "id": "a34374d4-e4fd-52ea-a7e3-52ac9fb844d9",
  "slug": "maja-blanca-recipe",
  "name": "Maja Blanca",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Maja Blanca.&nbsp;",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Pour the coconut milk in a cooking pot and bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the sugar, condensed milk, and whole sweet kernel corn then stir until all the ingredients are evenly distributed."
    },
    {
      "position": 3,
      "text": "Simmer for 8 minutes"
    },
    {
      "position": 4,
      "text": "Combine the milk and cornstarch then whisk until the cornstarch is diluted"
    },
    {
      "position": 5,
      "text": "Pour the fresh milk and cornstarch mixture in the cooking pot and stir thoroughly."
    },
    {
      "position": 6,
      "text": "Allow to cook while stirring until the mixture reaches your desired thickness"
    },
    {
      "position": 7,
      "text": "Pour the mixture in a serving tray then arrange and flatten the top using a flat tool such as a wooden spatula"
    },
    {
      "position": 8,
      "text": "Allow to cool down then refrigerate for at least 1 hour"
    },
    {
      "position": 9,
      "text": "Garnish with toasted grated coconut (or latik if available)"
    },
    {
      "position": 10,
      "text": "Serve cold. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 8,
