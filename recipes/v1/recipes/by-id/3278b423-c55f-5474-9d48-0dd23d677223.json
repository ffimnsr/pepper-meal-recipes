  "id": "3278b423-c55f-5474-9d48-0dd23d677223",
  "slug": "how-to-make-meatloaf",
  "name": "How to Make Meatloaf",
  "recipe_type": "main",
  "brief_description": "A quick tutorial on how to make meatloaf at home using a combination of ground beef and ground pork along with canned diced tomato and onions.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oven to 375F while you prepare the meatloaf mixture."
    },
    {
      "position": 2,
      "text": "Combine ground beef, ground pork, onions, egg, tomatoes and breadcrumbs or oats, sugar, salt, and pepper in a large bowl. Mix all the ingredients until well blended. If necessary, use hands to make sure all ingredients are mixed well."
    },
    {
      "position": 3,
      "text": "Transfer your meatloaf mixture into a bread pan or baking dish to shape like a loaf. Rub a little cool water on the top of the loaf and bake for 50 min. to 1 hour. Meatloaf is ready when it reaches an internal temperature of 170 F. Pork meatloaf is ready at 185F."
    },
    {
      "position": 4,
      "text": "Cool and serve."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
