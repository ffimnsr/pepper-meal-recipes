  "slug": "cioppino-recipe",
  "name": "Cioppino Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Cioppino.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil starts to get hot, add the chopped fennel bulb. Saute for 1 minute."
    },
    {
      "position": 3,
      "text": "Add onion and garlic. Continue to saute until onion becomes soft and translucent."
    },
    {
      "position": 4,
      "text": "Pour canned diced tomato, water, and Pinot Grigio wine. Let boil. Continue to boil in medium heat for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add the fish steaks, shrimp, and scallops. Cook for 1 to 2 minutes."
    },
    {
      "position": 6,
      "text": "Remove the fish and seafood from the pot using a slotted spoon. Set aside."
    },
    {
      "position": 7,
      "text": "Add basil, bell pepper, and parsley. Stir."
    },
    {
      "position": 8,
      "text": "Add crab, clams, and mussels. Cover the pot. Cook for 3 to 5 minutes."
    },
    {
      "position": 9,
      "text": "Put the fish, shrimp, and scallops back into the pot. Gently stir."
    },
    {
      "position": 10,
      "text": "Add Cayenne pepper, salt and ground black pepper."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 12,
      "text": "Serve with toasted sour dough bread."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
