  "id": "0070db64-a3a9-53d5-9ca8-eab891bd7aba",
  "slug": "cioppino-recipe",
  "name": "Cioppino",
  "recipe_type": "main",
  "brief_description": "A hearty Italian-American seafood stew featuring a medley of fish, shrimp, scallops, crab, clams, and mussels in a rich tomato and wine broth, served with crusty bread.",
  "cuisine": "italian-american",
  "instructions": [
    {
      "position": 1,
      "text": "Heat olive oil in a large pot or Dutch oven over medium heat."
    },
    {
      "position": 2,
      "text": "Add the chopped fennel bulb and saut\u00e9 for 1 minute."
    },
    {
      "position": 3,
      "text": "Add the onion and garlic. Continue to saut\u00e9 until the onion becomes soft and translucent."
    },
    {
      "position": 4,
      "text": "Pour in the canned diced tomatoes, water, and Pinot Grigio wine. Bring to a boil, then reduce to medium heat and simmer for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add the fish steaks, shrimp, scallops, and squid rings. Cook for 1 to 2 minutes."
    },
    {
      "position": 6,
      "text": "Remove the fish, shrimp, scallops, and squid from the pot using a slotted spoon. Set aside."
    },
    {
      "position": 7,
      "text": "Add the basil, bell pepper, and parsley. Stir to combine."
    },
    {
      "position": 8,
      "text": "Add the crab, clams, and mussels. Cover the pot and cook for 3 to 5 minutes, until the clams and mussels open."
    },
    {
      "position": 9,
      "text": "Return the fish, shrimp, scallops, and squid to the pot. Gently stir to combine."
    },
    {
      "position": 10,
      "text": "Season with cayenne pepper, salt, and ground black pepper to taste."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 12,
      "text": "Serve immediately with toasted sourdough bread."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
