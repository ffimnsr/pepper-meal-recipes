  "id": "07b1a079-64fb-5316-a150-a37355a9b6e4",
  "slug": "sweet-chicken-asado-recipe",
  "name": "Sweet Chicken Asado Recipe",
  "recipe_type": "dessert",
  "brief_description": "Just like my favorite chicken adobo, I always enjoy eating Sweet Chicken Asado for either lunch or dinner -- I don\u2019t even mind having the leftovers the next day for breakfast. This Sweet Chicken Asado was inspired by the pork asado recipe that I published back then when I was starting this food blog.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the chicken. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a wide cooking pot."
    },
    {
      "position": 3,
      "text": "Pan-fry both sides of the chicken in medium heat for 5 minutes per side."
    },
    {
      "position": 4,
      "text": "Scoop out the excess oil. Add the garlic and cook until light brown."
    },
    {
      "position": 5,
      "text": "Pour-in the soy sauce and chicken broth. Stir and let boil."
    },
    {
      "position": 6,
      "text": "Put-in the 5 spice powder and star anise. Cover and simmer for 30 to 35 minutes. Note: Add water if needed."
    },
    {
      "position": 7,
      "text": "Add-in the sugar and ground black pepper. Stir."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
