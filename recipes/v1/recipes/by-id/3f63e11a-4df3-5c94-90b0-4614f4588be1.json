  "id": "3f63e11a-4df3-5c94-90b0-4614f4588be1",
  "slug": "lechon-sisig-recipe",
  "name": "Lechon Sisig Recipe",
  "recipe_type": null,
  "brief_description": "Lechon Sisig is a dish made from left over lechon or roasted pig. This can be enjoyed as a main dish with rice, along with calamansi and hot sauce.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt the margarine in a frying pan."
    },
    {
      "position": 2,
      "text": "Put-in onion and then cook for 2 minutes or until soft."
    },
    {
      "position": 3,
      "text": "Add the lechon. Stir."
    },
    {
      "position": 4,
      "text": "Put-in garlic powder, soy sauce, salt, and pepper. Stir. Cook for 5 to 6 minutes in high heat."
    },
    {
      "position": 5,
      "text": "Add the mayonnaise. Stir and then cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. You can squeeze lime or calamansi and add hot sauce if desired."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
