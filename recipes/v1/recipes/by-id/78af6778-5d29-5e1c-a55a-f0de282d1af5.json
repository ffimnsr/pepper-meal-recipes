  "id": "78af6778-5d29-5e1c-a55a-f0de282d1af5",
  "slug": "fish-adobo",
  "name": "Fish Adobo",
  "recipe_type": null,
  "brief_description": "Fish Adobo is a Filipino fish dish wherein fish such as galunggong is cooked inadobo style. This recipe shows how it is prepared",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub sea salt all over the fish including the inner cavity."
    },
    {
      "position": 2,
      "text": "Arrange the fish in a cooking pot."
    },
    {
      "position": 3,
      "text": "Pour-in water and soy sauce. Bring to a boil."
    },
    {
      "position": 4,
      "text": "Put-in garlic, pepper corn, and bay leaves. Cook uncovered for 5 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in vinegar. Cover and allow to re-boil. Cook for 10 to 15 minutes in low to medium heat or until the liquid reduces."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve with steamed white rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
