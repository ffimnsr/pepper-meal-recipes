  "id": "58c5c593-c423-5497-9874-8247631a8b60",
  "slug": "seafood-fried-shrimp-camaron-rebosado-recipe",
  "name": "Camaron Rebosado Recipe",
  "recipe_type": "drink",
  "brief_description": "Camaron Rebosado (translated in English as Overflowed Shrimp) is an easy seafood dish that makes use of shrimps as the primary component. Shelled shrimps are marinated in lemon juice and dipped in a batter before deep frying.This style of cooking shrimp nearly resembles the Japanese tempura and shrimp croquettes; however, some ingredients and preparation steps vary.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Marinate the shrimp in lemon juice for 30 minutes."
    },
    {
      "position": 2,
      "text": "Combine flour, cornstarch, and salt in a mixing bowl then mix well."
    },
    {
      "position": 3,
      "text": "Add the eggs and milk stir until all the ingredients are well distributed."
    },
    {
      "position": 4,
      "text": "Heat a pan and pour-in the cooking oil."
    },
    {
      "position": 5,
      "text": "When the oil is hot enough, dip a piece of shrimp in the batter (leave the tail uncovered) then deep-fry until the color of the outer part turns dark yellow and the texture becomes crispy."
    },
    {
      "position": 6,
      "text": "Remove from the pan or fryer then place in a plate with paper towel (this will absorb excess oil)."
    },
    {
      "position": 7,
      "text": "Serve with sweet and sour sauce. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "medium",
