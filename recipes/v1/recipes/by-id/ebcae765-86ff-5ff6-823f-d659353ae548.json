  "id": "ebcae765-86ff-5ff6-823f-d659353ae548",
  "slug": "ginataang-kalabasa-at-sitaw",
  "name": "Ginataang Kalabasa at Sitaw",
  "recipe_type": "main",
  "brief_description": "Calabaze squash and string beans cooked in coconut milk",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Add pork. Cook until brown and crispy."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic, onion, and ginger."
    },
    {
      "position": 3,
      "text": "Once the onion softens, pour the coconut milk into the pan. Stir. Cover the pan and let the liquid boil. Once boiling, adjust the heat to medium and continue boiling for 5 minutes."
    },
    {
      "position": 4,
      "text": "Add Knorr Pork Cube and squash. Continue cooking for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add string beans. Cook for 5 to 8 minutes."
    },
    {
      "position": 6,
      "text": "Season with ground black pepper and fish sauce as needed."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with warm rice."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
