  "id": "d0b111b6-ed8b-5fc1-aea9-18266fbc0847",
  "slug": "sweet-pusit-adobo",
  "name": "Sweet Pusit Adobo",
  "recipe_type": "dessert",
  "brief_description": "This is the favorite ulam of my kids. I always cook this for them if I get fresh squid in the market. They like to partner this with ginataang langka. I hope that you enjoy this recipe that I am sharing.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil."
    },
    {
      "position": 2,
      "text": "Add the garlic, onion, and tomato. Cook it for 3 minutes."
    },
    {
      "position": 3,
      "text": "Add water, laurel, and soy sauce. Boil"
    },
    {
      "position": 4,
      "text": "Add squid. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Add sugar and vinegar. Wait for it to boil."
    },
    {
      "position": 6,
      "text": "Put salt and pepper."
    },
    {
      "position": 7,
      "text": "Serve with rice."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 30,
