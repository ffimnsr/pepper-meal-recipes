  "id": "5383bca2-e219-5877-95a3-eb4a4479ee9a",
  "slug": "paklay-recipe",
  "name": "Paklay",
  "recipe_type": "drink",
  "brief_description": "Paklay is a stew featuring a mix of pig and cow innards, popular in the southern regions of the Philippines. It is commonly enjoyed as a main dish or served as pulutan, a type of food to accompany drinks.",
  "cuisine": "Philippines",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 5 cups of water in a large cooking pot."
    },
    {
      "position": 2,
      "text": "Once the water starts to boil, add 1 tablespoon of salt, pig stomach, and ox tripe. Boil over medium heat for 60 minutes."
    },
    {
      "position": 3,
      "text": "Add the kidney and heart. Continue to boil for another 60 minutes or until all the innards are tender. Discard the water and let the innards cool down. Chop the innards and set aside."
    },
    {
      "position": 4,
      "text": "Meanwhile, heat the cooking oil in a large clean pot."
    },
    {
      "position": 5,
      "text": "Saut\u00e9 the onion, garlic, and ginger until the onion becomes soft."
    },
    {
      "position": 6,
      "text": "Add the chopped innards, bay leaves, and liver. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add the pineapple chunks, bell pepper, and beef cube."
    },
    {
      "position": 8,
      "text": "Pour in 2 cups of water and add the annatto powder. Stir and let it boil."
    },
    {
      "position": 9,
      "text": "Add the bamboo shoots, cover, and simmer for 25 minutes. Add more water if needed."
    },
    {
      "position": 10,
      "text": "Season with salt and pepper to taste."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 12,
      "text": "Serve, share, and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 130,
