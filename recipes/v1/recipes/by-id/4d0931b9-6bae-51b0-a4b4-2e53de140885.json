  "id": "4d0931b9-6bae-51b0-a4b4-2e53de140885",
  "slug": "crispy-shrimp-adobo-recipe",
  "name": "Crispy Shrimp Adobo Recipe",
  "recipe_type": null,
  "brief_description": "Crispy Shimp Adobo or Adobong Hipon is a variation to the original Shrimp Adobo Recipe. This requires deep frying marinated shrimp to make it crisp.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine vinegar, rum, minced garlic, and soy sauce, and ground black pepper in a large bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Combine AP flour and cornstarch. Mix well and then set aside."
    },
    {
      "position": 3,
      "text": "Put the shrimp in the same bowl. Marinade for at least 30 minutes."
    },
    {
      "position": 4,
      "text": "Heat the cooking oil in a deep cooking pot."
    },
    {
      "position": 5,
      "text": "Add the dried bay leaves and whole peppercorn in the hot oil."
    },
    {
      "position": 6,
      "text": "Remove the shrimp from the marinade and then dredge in the flour and cornstarch mixture."
    },
    {
      "position": 7,
      "text": "Deep fry the shrimp for about 5 to 7 minutes or until the texture becomes crisp."
    },
    {
      "position": 8,
      "text": "Arrange in a serving plate lined with paper towels to absorb excess oil."
    },
    {
      "position": 9,
      "text": "Serve with adobo dipping sauce (which is 2 parts vinegar and 1 part soy sauce with whole peppercorn and minced garlic). Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
