  "id": "2f7a25b9-8110-5bab-a35a-e5dd064db6dd",
  "slug": "laing-na-gabi-recipe",
  "name": "Laing na Gabi Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Filipino Laing (taro leaves cooked in coconut milk)",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the gata by combining Knorr Ginataang Gulay Recipe Mix with 5 cups water. Stir until the powder completely dilutes."
    },
    {
      "position": 2,
      "text": "Arrange pork, garlic, onion, and ginger in a pot. Pour 3 \u00bd cups gata. Put on a stovetop and apply heat. Continue to cook for 10 minutes after the liquid boils."
    },
    {
      "position": 3,
      "text": "Add dried taro leaves. Cover the pot and continue to cook until the liquid is almost gone."
    },
    {
      "position": 4,
      "text": "Add chili peppers and then pour remaining coconut milk. Stir and continue to cook until the liquid completely evaporates."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve with rice!"
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
