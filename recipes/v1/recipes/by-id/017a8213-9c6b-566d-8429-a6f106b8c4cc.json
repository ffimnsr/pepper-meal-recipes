  "id": "017a8213-9c6b-566d-8429-a6f106b8c4cc",
  "slug": "caramelized-butternut-squash",
  "name": "Caramelized Butternut Squash",
  "recipe_type": "dessert",
  "brief_description": "Caramelized Butternut Squash is a simple dessert that you can make this autumn or anytime of the year. It is easy to make and simply delicious. I enjoy this as a dessert. Sometimes, I make this dish to snack on. Butternut Squash is an amazing ingredient. There are lots of dishes that you can make using this\u2026",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 410F"
    },
    {
      "position": 2,
      "text": "Combine squash, brown sugar, salt, and butter in a bowl. Toss to coat the squash with the rest of the ingredients."
    },
    {
      "position": 3,
      "text": "Arrange the coated butternut squash on a baking tray lined with an aluminum sheet. Bake for 35 to 45 minutes."
    },
    {
      "position": 4,
      "text": "Remove from the oven and transfer to a serving bowl."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 50,
