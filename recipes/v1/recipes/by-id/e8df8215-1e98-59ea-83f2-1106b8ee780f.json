  "id": "e8df8215-1e98-59ea-83f2-1106b8ee780f",
  "slug": "easy-chicken-adobo-recipe",
  "name": "Easy Chicken Adobo Recipe",
  "recipe_type": "main",
  "brief_description": "A simple way of preparing delicious Filipino chicken adobo.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken, 1/4 of the total amount of garlic, whole peppercorn, dried bay leaves, soy sauce, vinegar, and water in a cooking pot. Cover and let boil. Stir and make sure that all ingredients are well blended."
    },
    {
      "position": 2,
      "text": "Add Knorr Chicken Cube and sugar. Stir. Cover the pot and cook for 10 minutes."
    },
    {
      "position": 3,
      "text": "Turn the chicken over and cook the opposite side for another 10 minutes. Set aside."
    },
    {
      "position": 4,
      "text": "Heat oil in a clean pan. Saute remaining garlic until it turns light brown."
    },
    {
      "position": 5,
      "text": "Pan fry the chicken for 1 minute per side. Pour the adobo sauce into the pan. Boil until it reduces to half."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with warm rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 3,
  "rest_time_minutes": null,
  "difficulty": "medium",
