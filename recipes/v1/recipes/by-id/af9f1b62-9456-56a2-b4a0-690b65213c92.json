  "id": "af9f1b62-9456-56a2-b4a0-690b65213c92",
  "slug": "pinoy-style-chicken-macaroni-salad",
  "name": "Pinoy Style Chicken Macaroni Salad",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for Pinoy Style Chicken Macaroni Salad.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 5 cups water in a cooking pot. Add chicken breasts. Cover the pot and continue to boil for 20 to 25 minutes."
    },
    {
      "position": 2,
      "text": "Remove the chicken from the pot. Let it cool down."
    },
    {
      "position": 3,
      "text": "Boil remaining water in a clean pot. Add 2 teaspoons salt. Put-in the elbow macaroni and then cook according to package instructions. Drain the water. Set the macaroni aside."
    },
    {
      "position": 4,
      "text": "Meanwhile, manually shred the chicken breasts. Set aside."
    },
    {
      "position": 5,
      "text": "Prepare the dressing by combining all the Salad dressing ingredients (see above). Mix well."
    },
    {
      "position": 6,
      "text": "Add macaroni. Toss until well blended."
    },
    {
      "position": 7,
      "text": "Add pineapple tidbits, carrots, raisins, shredded chicken, and cheese. Continue to toss."
    },
    {
      "position": 8,
      "text": "Adjust the flavor by adding more salt, garlic powder, and ground black pepper, only if needed."
    },
    {
      "position": 9,
      "text": "Top with more cheese. Cover the bowl and chill inside the refrigerator for 3 hours."
    },
    {
      "position": 10,
      "text": "Serve! Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
