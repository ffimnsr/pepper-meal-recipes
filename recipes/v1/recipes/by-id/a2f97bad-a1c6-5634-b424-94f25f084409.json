  "id": "a2f97bad-a1c6-5634-b424-94f25f084409",
  "slug": "chicken-pasta-alfredo-recipe",
  "name": "Chicken Pasta Alfredo Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for easy chicken alfredo with broccoli",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook pasta according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Season the chicken with salt and pepper. Let stay for 10 minutes"
    },
    {
      "position": 3,
      "text": "Heat olive oil in a pan."
    },
    {
      "position": 4,
      "text": "Put-in the chicken and pan fry for about 8 to 10 minutes per side. Remove from the pan and let the temperature cool down. Slice and set aside."
    },
    {
      "position": 5,
      "text": "Melt-in butter on the same pan."
    },
    {
      "position": 6,
      "text": "Pour-in wine or sherry. Stir."
    },
    {
      "position": 7,
      "text": "Add heavy cream. Cook in medium heat while stirring for 5 minutes."
    },
    {
      "position": 8,
      "text": "Put-in the parmesan cheese, garlic powder, and steamed broccoli. Stir constantly and cook for 6 to 10 minutes."
    },
    {
      "position": 9,
      "text": "Arrange the pasta, Alfredo sauce, and chicken in a serving plate."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
