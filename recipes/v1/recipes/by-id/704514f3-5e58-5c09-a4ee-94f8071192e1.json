  "id": "704514f3-5e58-5c09-a4ee-94f8071192e1",
  "slug": "tortang-dulong-fish-omelet-recipe",
  "name": "Tortang Dulong",
  "recipe_type": null,
  "brief_description": "Tortang Dulong or silverfish omelet is simple yet tasty fish omelet dish. If you read our post on Kinilaw na Dulong, silverfish might be familiar to you now.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine eggs, salt, and ground black pepper then beat until everything is well incorporated."
    },
    {
      "position": 2,
      "text": "Add-in the silverfish and mix well."
    },
    {
      "position": 3,
      "text": "Heat a frying pan and pour-in cooking oil."
    },
    {
      "position": 4,
      "text": "Once the oil heats-up, scoop about half a cup of the mixture using a kitchen ladle and gently pour it in the frying pan."
    },
    {
      "position": 5,
      "text": "Cook the first side for about 3 to 5 minutes then flip to cook the other side."
    },
    {
      "position": 6,
      "text": "Turn-off the heat and transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve for breakfast. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
