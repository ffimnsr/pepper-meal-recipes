{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "da14a015-e8aa-5e5d-9b72-44ceced0a583",
  "slug": "extremely-spicy-pork-adobo-na-tuyo",
  "name": "Extremely Spicy Pork Adobo na Tuyo",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Extremely Spicy Pork Adobo na Tuyo (dry pork adobo)",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork, soy sauce, whole peppercorn, and garlic in a bowl. Mix well. Cover the bowl with a clear plastic wrap. Place inside the refrigerator and marinate for at least 3 hours."
    },
    {
      "position": 2,
      "text": "Heat a pan on a stovetop. Once the pan is hot enough, pour the marinated pork along with the marinade. Cook until the pork browns."
    },
    {
      "position": 3,
      "text": "Pour beef broth into the pan. Let boil."
    },
    {
      "position": 4,
      "text": "Add the ghost pepper and Thai chilies. Cover the pan and continue to cook in medium heat for 15 minutes."
    },
    {
      "position": 5,
      "text": "Add bay leaves and vinegar. Let the liquid boil. Stir and then cover the pan. Continue to cook for 40 to 60 minutes or until the pork becomes tender. Note: you can add more broth or water if the liquid starts to dry while the pork is not that tender enough."
    },
    {
      "position": 6,
      "text": "Remove the cover from the pan. Continue to cook until the liquid totally evaporates. Cook a little bit longer in low to medium heat until oil gets extracted from the pork."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve for pulutan or as a main dish with warm rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
