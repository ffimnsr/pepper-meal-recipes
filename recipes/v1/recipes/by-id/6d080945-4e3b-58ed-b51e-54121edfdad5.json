  "id": "6d080945-4e3b-58ed-b51e-54121edfdad5",
  "slug": "cilantro-lime-rice",
  "name": "Cilantro Lime Rice",
  "recipe_type": "side",
  "brief_description": "Cilantro Lime Rice is a fresh tasting side for dishes like Carne Asada. This can also be a component for burrito.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine cilantro, garlic, lime juice, and olive oil in a food processor."
    },
    {
      "position": 2,
      "text": "Shred the mixture for 20 seconds."
    },
    {
      "position": 3,
      "text": "Combine the shredded mixture with the cooked white rice along with the salt. Mix well."
    },
    {
      "position": 4,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
