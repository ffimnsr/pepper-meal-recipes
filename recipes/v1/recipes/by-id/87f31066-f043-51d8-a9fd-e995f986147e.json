  "slug": "corned-beef-saute",
  "name": "Corned Beef Saute",
  "recipe_type": "main",
  "brief_description": "Corned beed sauteed in butter with carrot, corn, and peas",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a pan. Saute garlic and onion until the onion softens."
    },
    {
      "position": 2,
      "text": "Add CDO Home Style Corned Beef. Saute for 1 minute."
    },
    {
      "position": 3,
      "text": "Add carrot, corn, and green peas. Continue cooking for 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Season with salt and ground black pepper. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
