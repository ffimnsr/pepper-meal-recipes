  "slug": "sinigang-na-liempo-sa-sampaloc",
  "name": "Sinigang na Liempo sa Sampaloc",
  "recipe_type": "soup",
  "brief_description": "Warm Sinigang na Liempo or sour pork belly soup makes a good meal when eaten with rice during the cold weather. Get the details of this recipe.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Put the water and onion, tomato, and tamarind in a casserole. Let it boil for 20 minutes."
    },
    {
      "position": 2,
      "text": "Remove the tamarind."
    },
    {
      "position": 3,
      "text": "Mix the pork belly in the boiling water and cook it for 45 minutes."
    },
    {
      "position": 4,
      "text": "Add the taro root and pepper. Cook it for 10 minutes."
    },
    {
      "position": 5,
      "text": "Add the kangkong and patis. Cook it for 2 minutes."
    },
    {
      "position": 6,
      "text": "Serve this with rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 80,
  "preparation_time_minutes": 12,
