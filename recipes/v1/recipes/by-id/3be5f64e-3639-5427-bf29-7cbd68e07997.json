  "id": "3be5f64e-3639-5427-bf29-7cbd68e07997",
  "slug": "bangus-sisig-recipe",
  "name": "Bangus Sisig",
  "recipe_type": "main",
  "brief_description": "This Bangus Sisig Recipe is really good. This dish has lower fat and cholesterol compared to pork sisig and it is delicious",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Melt-in butter in a large pan"
    },
    {
      "position": 2,
      "text": "Add the onion and cook for 3 minutes"
    },
    {
      "position": 3,
      "text": "Put-in the ginger. Stir and cook for 2 minutes in low to medium heat."
    },
    {
      "position": 4,
      "text": "Add the bangus and then stir."
    },
    {
      "position": 5,
      "text": "Put-in the garlic powder, salt,ground black pepper, and soy sauce. Stir and cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add the chicharon, scallions, and chili. Stir and cook for 3 minutes more."
    },
    {
      "position": 7,
      "text": "Put-in the mayonnaise. Stir."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
