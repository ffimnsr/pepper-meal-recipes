  "id": "c2e2d50f-03b3-53a9-995f-035035015379",
  "slug": "slow-cooker-beef-stew",
  "name": "Slow Cooker Beef Stew",
  "recipe_type": null,
  "brief_description": "Slow Cooker Beef Stew. Using a slow cooker in preparing dishes makes your task easier. It might take a while to cook, but it is worth it",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the onion and celery until the texture becomes soft. Set aside."
    },
    {
      "position": 3,
      "text": "Dredge the beef in flour. Make sure that all sides are coated."
    },
    {
      "position": 4,
      "text": "Using the remaining cooking oil pan fry the beef cubes until the color turns light brown (about 5 minutes). Set aside."
    },
    {
      "position": 5,
      "text": "Combine the water and onion soup mix. Mix well."
    },
    {
      "position": 6,
      "text": "Combine the pan-fried beef, saut\u00e9ed onions and celery, potatoes, carrots, red wine, salt, pepper, and water with onion soup mix in a slow cooker. Stir once and slow cook for 5 to 7 hours."
    },
    {
      "position": 7,
      "text": "Serve with biscuits, garlic toast, rice, or French bread."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 300,
  "preparation_time_minutes": 10,
