  "id": "f150d56e-28ed-550b-b916-dd0e96e78f40",
  "slug": "air-fryer-longganisa-frittata-recipe",
  "name": "Air Fryer Longganisa Frittata",
  "recipe_type": "dessert",
  "brief_description": "Breakfast frittata with Sweet Filipino Sausage",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the longganisa in half. Set aside."
    },
    {
      "position": 2,
      "text": "Beat the eggs in a large bowl. Season with salt."
    },
    {
      "position": 3,
      "text": "Add bell pepper, green peas, and cheddar cheese. Mix well."
    },
    {
      "position": 4,
      "text": "Scoop a portion of the egg mixture into a silicon air fryer cup. Top with two slices of longganisa."
    },
    {
      "position": 5,
      "text": "Air fry in 190C for 15 minutes or until the eggs gets cooked completely."
    },
    {
      "position": 6,
      "text": "Remove the frittata from the silicon cups and arrange it on a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
