  "id": "01357aac-d194-519d-8627-89eee029368e",
  "slug": "turon",
  "name": "Turon (Banana Lumpia with Caramel)",
  "recipe_type": "dessert",
  "brief_description": "Deep fried banana and ripe jackfruit lumpia. This is a popular Filipino street food.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Roll the banana on the sugar plate and ensure that the banana is coated with enough sugar"
    },
    {
      "position": 2,
      "text": "Place the banana with sugar coating on the lumpia wrapper. Add a slice of ripe jackfruit on top."
    },
    {
      "position": 3,
      "text": "Fold and lock the spring roll wrapper, use water to seal the edge"
    },
    {
      "position": 4,
      "text": "In a pan, heat the oil and put-in some sugar.Wait until the brown sugar floats"
    },
    {
      "position": 5,
      "text": "Put-in the wrapped banana and fry until the wrapper turns golden brown and the extra sugar sticks on wrapper"
    },
    {
      "position": 6,
      "text": "Serve hot as a dessert or snack. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
