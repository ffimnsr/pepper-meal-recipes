  "id": "09e264ac-ebbd-5794-926c-de27638236c4",
  "slug": "ginataang-santol-sinantolan-recipe",
  "name": "Ginataang Santol (Sinantolan) Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for sinantolan or ginataang santol.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Mince (cut into very small pieces) the santol using a food processor. Note: you can also do it manually, if preferred."
    },
    {
      "position": 2,
      "text": "Place the minced santol in the middle of a cheese cloth. Secure the santol inside the cloth and then wring until all the liquid comes out. Set aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan. Saute garlic and onion."
    },
    {
      "position": 4,
      "text": "Once the onion starts to get translucent, add the ground pork. Continue to cook until the pork turns light brown."
    },
    {
      "position": 5,
      "text": "Add the minced santol. Cook for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Pour coconut milk into the pan. Let boil. Stir and cover the pan. Continue to cook in medium heat until the liquid reduces to half."
    },
    {
      "position": 7,
      "text": "Add shrimp paste, siling pansigang, ang Thai chili. Stir. Continue to cook until the liquid completely evaporates."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
  "difficulty": "medium",
