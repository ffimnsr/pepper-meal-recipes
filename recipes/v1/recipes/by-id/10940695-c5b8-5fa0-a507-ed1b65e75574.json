  "id": "10940695-c5b8-5fa0-a507-ed1b65e75574",
  "slug": "sauteed-green-beans-with-ground-beef",
  "name": "Sauteed Green Beans with Ground Beef",
  "recipe_type": null,
  "brief_description": "This is a recipe for Sauteed Green Beans with Ground Beef",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Add ground beef. Cook until brown."
    },
    {
      "position": 3,
      "text": "Add onion, tomato, and soy sauce. Stir."
    },
    {
      "position": 4,
      "text": "Add Napa cabbage. Cover and continue to cook for 5 to 8 minutes in medium heat."
    },
    {
      "position": 5,
      "text": "Add the sliced long green beans. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add garlic powder and ground black pepper. Stir and cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with warm rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
