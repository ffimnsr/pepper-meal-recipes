  "id": "a5827a77-a2e5-5c87-925e-824e2446dde1",
  "slug": "pancit-cabagan-recipe",
  "name": "Pancit Cabagan Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pansit Cabagan. It is a famous version of pancit that came from the town of Cabagan in Isabela, Philippines.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a wok or pan."
    },
    {
      "position": 2,
      "text": "Saute the garlic until it starts to turn light brown."
    },
    {
      "position": 3,
      "text": "Add the pork slices. Stir-fry until for 2 minutes or until it starts to turn brown."
    },
    {
      "position": 4,
      "text": "Pour-in the soy sauce, fish sauce, and 3 cups beef broth. Let boil. Cover and cook in low heat for 12 minutes or until the pork becomes tender."
    },
    {
      "position": 5,
      "text": "Add the miki noodles. Toss. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the carrot, parsley, bell pepper, and cabbage. Continue to cook for 5 minutes. You can add more beef broth if needed."
    },
    {
      "position": 7,
      "text": "Sprinkle some ground black pepper. Toss."
    },
    {
      "position": 8,
      "text": "Put the boiled quail eggs in the wok and top with lechon carajay and igado."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 30,
  "cooking_time_minutes": 4,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
