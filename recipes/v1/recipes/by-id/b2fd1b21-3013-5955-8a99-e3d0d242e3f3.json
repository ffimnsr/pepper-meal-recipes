  "id": "b2fd1b21-3013-5955-8a99-e3d0d242e3f3",
  "slug": "tasty-ginisang-sayote",
  "name": "Ginisang Sayote",
  "recipe_type": "main",
  "brief_description": "Sauteed chayote with carrots and pork. This dish is easy to prepare. Yum!",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot. Sear pork until brown and oil is extracted."
    },
    {
      "position": 2,
      "text": "Add onion and garlic. Saute until onion softens."
    },
    {
      "position": 3,
      "text": "Pour 1 \u00bd cups water. Let boil. Cover the pot and continue to boil in low heat until liquid completely evaporates."
    },
    {
      "position": 4,
      "text": "Add chayote and saute for 2 to 3 minutes."
    },
    {
      "position": 5,
      "text": "Add carrots. Saute for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour Knorr Pork SavorRich Liquid Seasoning. Stir."
    },
    {
      "position": 7,
      "text": "Add ground black pepper (optional). Pour \u00bc cup water. Cover the pot. Cook for 1 minute."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
