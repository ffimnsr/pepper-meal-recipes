{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "befef45c-b283-50a2-9390-7ba1b1b12f8e",
  "slug": "crispy-pata-kare-kare",
  "name": "Crispy Pata Kare Kare",
  "recipe_type": "main",
  "brief_description": "Crispy pork hock cooked in peanut sauce and served with steamed vegetables",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the boiling ingredients in a large cooking pot. Add pork hock. Boil for 1 hour. Remove the pork hock from the cooking pot. Let it cool down and then rub salt all over. Air dry for 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Saut\u00e9 garlic and onion. Once the onion softens, add the peanut paste. Stir and cook for 1 minute. Pour water and then stir until the mixture becomes smooth. Let the liquid boil. Add Knorr Pork Cube and annatto powder. Cover the pot. Reduce the heat to a simmer. Continue cooking until your desired consistency is achieved. Season with salt and ground black pepper. Set aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a wide and deep pot. Fry the pork hock until the bottom side turns golden brown and crispy. Turn it over and do the same thing on the opposite side. Remove from the pot. Let it cool down. Debone the pork hock. Set aside."
    },
    {
      "position": 4,
      "text": "Arrange the vegetable ingredients on a steamer. Steam for 3 to 5 minutes. Set aside."
    },
    {
      "position": 5,
      "text": "Assemble your crispy pata kare-kare by pouring half of the sauce on a serving bowl. Arrange the steamed vegetables all around. Top with crispy pata. Distribute the remaining sauce by pouring onto the bowl. Serve with shrimp paste (bagoong alamang) as a condiment. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
