  "id": "d1d70ef4-4cb0-53dd-b5c6-f6805ffa7b94",
  "slug": "paksiw-na-lechon-kawali",
  "name": "Paksiw na Lechon Kawali",
  "recipe_type": null,
  "brief_description": "This is a recipe for Paksiw na Lechon Kawali.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Once the onion gets soft, add the lechon kawaii. Saute for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add soy sauce and beef broth. Let boil."
    },
    {
      "position": 5,
      "text": "Add whole peppercorn and dried bay leaves. Cover the pot and cook in medium heat for 25 to 30 minutes."
    },
    {
      "position": 6,
      "text": "Pour vinegar into the pot. Let the liquid re-boil."
    },
    {
      "position": 7,
      "text": "Add lechon sauce. Stir. Cover and cook for 10 minutes."
    },
    {
      "position": 8,
      "text": "Add sugar and salt. Continue to cook until the liquid reduces to half."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 55,
  "preparation_time_minutes": 5,
