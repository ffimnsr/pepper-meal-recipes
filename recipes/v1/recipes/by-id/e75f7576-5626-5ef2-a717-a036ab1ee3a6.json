  "id": "e75f7576-5626-5ef2-a717-a036ab1ee3a6",
  "slug": "sotanghon-with-sayote-and-giniling",
  "name": "Sotanghon with Sayote and Giniling",
  "recipe_type": "soup",
  "brief_description": "Sotanghon soup with ground pork",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make the annatto oil by combining 4 tablespoons of cooking oil and 1 teaspoon annatto seeds in a pan. Start heating the pan while gently stirring the oil. Turn the heat off once the oil shimmers. Continue to stir until the oil turns orangey. Remove the annatto seeds."
    },
    {
      "position": 2,
      "text": "Using the annatto oil, saut\u00e9 garlic until it browns."
    },
    {
      "position": 3,
      "text": "Add the onion and the bottom part of the green onions. Continue to saut\u00e9 until it softens."
    },
    {
      "position": 4,
      "text": "Add the ground pork. Saut\u00e9 until it browns."
    },
    {
      "position": 5,
      "text": "Add 2 teaspoons fish sauce. Stir."
    },
    {
      "position": 6,
      "text": "Pour 2 cups water. Cover the pot and let it boil. Reduce the heat to low setting. Boil the pork for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add the remaining water and let it boil."
    },
    {
      "position": 8,
      "text": "Stir-in the chayote, and sotanghon noodles. Cook for 8 minutes."
    },
    {
      "position": 9,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl and garnish with chopped green onion."
    },
    {
      "position": 11,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
