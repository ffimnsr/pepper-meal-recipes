  "id": "8d041dd9-ffce-5733-a3f5-00c64c3281e2",
  "slug": "filipino-pork-fried-rice-recipe",
  "name": "Filipino Pork Fried Rice Recipe",
  "recipe_type": "breakfast",
  "brief_description": "Filipino Pork Fried Rice is another Fried Rice Recipe that I love having for breakfast. This recipe is almost like garlic fried rice",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork slices and soy sauce. Mix and let stand for 30 minutes."
    },
    {
      "position": 2,
      "text": "Combine salt and rice. Gently mix using your hands. Set aside."
    },
    {
      "position": 3,
      "text": "Heat a wide pan and then pour-in the cooking oil."
    },
    {
      "position": 4,
      "text": "Put-in the garlic. Cook until medium brown."
    },
    {
      "position": 5,
      "text": "Remove the garlic and then set aside."
    },
    {
      "position": 6,
      "text": "Put-in the pork (including the marinade). Cook in low to medium heat for 5 minutes."
    },
    {
      "position": 7,
      "text": "Increase the heat to med-high. Put-in the rice. Cook for 5 to 7 minutes while stirring almost continuously to prevent the rice from sticking at the bottom."
    },
    {
      "position": 8,
      "text": "Add half of the fried garlic. Stir and then cook for a minute more."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Top with remaining fried garlic."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
