  "id": "fb8c209a-6cbe-5791-aafd-696b9a769c86",
  "slug": "cripsy-nilasing-na-hipon-fried-shrimp-marinated-wine",
  "name": "Nilasing na Hipon",
  "recipe_type": null,
  "brief_description": "This Crispy Nilasing na Hipon recipe is another variation of the popular shrimp pulutan dish. This version is crispier and tastier",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Wash the shrimp with running water. Drain the water and place the shrimp in a bowl."
    },
    {
      "position": 2,
      "text": "Add garlic salt and ground black pepper. Mix the ingredients either by tossing using your hands."
    },
    {
      "position": 3,
      "text": "Add the cooking wine. Toss and ensure that all the ingredients are well blended. Let the mixture stand for 10 minutes."
    },
    {
      "position": 4,
      "text": "In another bowl, combine flour, cornstarch, and ground cayenne red pepper. Mix well."
    },
    {
      "position": 5,
      "text": "Heat a cooking pot or a deep frying pan or wok. Pour cooking oil. Let the oil get hot until it reaches 325F."
    },
    {
      "position": 6,
      "text": "Dredge the marinated shrimp in the flour mixture. Make sure that the shrimp is coated all throughout."
    },
    {
      "position": 7,
      "text": "Fry one side of the shrimp for 1 to 2 minutes or until it turns dark orange and the texture gets crispy. Turn it over and do the same with the other side."
    },
    {
      "position": 8,
      "text": "Remove the crispy nilasing na hippo from the cooking pot and place in a plate lined with paper towel."
    },
    {
      "position": 9,
      "text": "Arrange in a serving plate and serve with spicy vinegar."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 4,
  "preparation_time_minutes": 15,
