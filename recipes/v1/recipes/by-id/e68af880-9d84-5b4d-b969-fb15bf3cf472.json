  "id": "e68af880-9d84-5b4d-b969-fb15bf3cf472",
  "slug": "mamon-sponge-cake-recipe",
  "name": "Mamon Recipe",
  "recipe_type": "dessert",
  "brief_description": "Mamon is a popular sponge cake in the Philippines and is considered to be among the top 10 pastries in the country. Learn how to make it through this recipe",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine cake flour and baking powder then mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Combine egg whites and cream of tartar then beat until the mixture becomes somewhat fluffy."
    },
    {
      "position": 3,
      "text": "Gradually add sugar then continue beating until the texture becomes fluffier. Use high speed for this process; this should take around 4 to 8 minutes."
    },
    {
      "position": 4,
      "text": "Add lemon juice and egg yolks then mix again."
    },
    {
      "position": 5,
      "text": "Put-in vegetable oil then mix for a few seconds then gradually add cake flour-baking powder mixture. Continue mixing until the texture becomes smooth."
    },
    {
      "position": 6,
      "text": "Heat the oven to 350 degrees Fahrenheit"
    },
    {
      "position": 7,
      "text": "Grease the molds using cooking spray then scoop some of the mixture into the mold. Continue doing this process until all the mixture is used-up."
    },
    {
      "position": 8,
      "text": "Bake for 13 to 16 minutes or until it passes the toothpick test."
    },
    {
      "position": 9,
      "text": "Remove from the oven and let cool."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 16,
  "preparation_time_minutes": 12,
