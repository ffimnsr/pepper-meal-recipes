  "id": "9bbeb000-4f89-537e-bd12-da99fd57f5aa",
  "slug": "bulanglang-na-gulay-batangas_knr_fc",
  "name": "Bulanglang na Gulay (Batangas)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Bulanglang na Gulay",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add garlic, ginger, and onion. Cover and cook for 5 minutes."
    },
    {
      "position": 3,
      "text": "Put the tomato, unripe papaya, and kalabasa into the pot. Cover and cook in medium heat for 3 to 4 minutes."
    },
    {
      "position": 4,
      "text": "Add eggplant, okra, and patola. Cook for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Add Knorr Fish Cube. Stir. Continue to cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Put the malunggay leaves and spinach in the pot. Season with ground black pepper and salt."
    },
    {
      "position": 7,
      "text": "Tranfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
