  "id": "44420a1c-42c1-5e25-8600-67b30c58f7cd",
  "slug": "crispy-eggplant-fries",
  "name": "Crispy Eggplant Fries",
  "recipe_type": "appetizer",
  "brief_description": "Crispy fried eggplant strips served with a tangy dipping sauce.",
  "cuisine": "filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the eggplant into thick strips. Place in a bowl and set aside."
    },
    {
      "position": 2,
      "text": "Crack the egg into a clean bowl and whisk until smooth. Arrange the flour and panko breadcrumbs in separate bowls. Set aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a cooking pot over medium heat. Dredge the eggplant strips in flour, dip in beaten egg, then coat with panko breadcrumbs."
    },
    {
      "position": 4,
      "text": "Fry over medium heat until golden brown. Work in batches until all eggplant strips are cooked. Transfer to a plate lined with paper towels to drain excess oil."
    },
    {
      "position": 5,
      "text": "Make the dipping sauce by combining all sauce ingredients in a bowl. Mix well."
    },
    {
      "position": 6,
      "text": "Arrange the eggplant fries on a serving plate. Serve with the dipping sauce."
    },
    {
      "position": 7,
      "text": "Serve as an appetizer. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
