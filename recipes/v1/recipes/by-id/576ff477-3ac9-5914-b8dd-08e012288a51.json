  "id": "576ff477-3ac9-5914-b8dd-08e012288a51",
  "slug": "chicken-sotanghon-soup-with-patola",
  "name": "Chicken Sotanghon Soup with Patola",
  "recipe_type": "soup",
  "brief_description": "A warm and savory noodle soup with tender chicken, sotanghon noodles, and fresh patola, finished with roasted garlic and green onions.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat annatto oil in a pot over medium heat. Saut\u00e9 garlic until lightly golden, then add onion and cook until soft and fragrant."
    },
    {
      "position": 2,
      "text": "Add chicken pieces and cook while stirring until they turn light brown on all sides."
    },
    {
      "position": 3,
      "text": "Pour in water and bring to a boil. Add chicken powder and simmer for 20 minutes or until chicken becomes tender. Skim any foam for a clear broth."
    },
    {
      "position": 4,
      "text": "Add sotanghon noodles and cook for about 3 minutes, stirring gently to prevent clumping."
    },
    {
      "position": 5,
      "text": "Add patola slices and cook for 2 minutes until tender but not mushy."
    },
    {
      "position": 6,
      "text": "Season with fish sauce and ground black pepper to taste. Ladle into bowls and top with roasted garlic and chopped green onions before serving."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
