  "id": "45064e6d-bf75-5d0f-9e92-3780fdd219ff",
  "slug": "saucy-pancit-canton",
  "name": "Saucy Pancit Canton",
  "recipe_type": null,
  "brief_description": "This is a recipe for Saucy Pancit Canton",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok or cooking pot"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic, onion, and then add ground black pepper. Cook until onion gets soft"
    },
    {
      "position": 3,
      "text": "Put the pork and chicken slices into the wok. Stir fry for 3 to 4 minutes or until the meat browns"
    },
    {
      "position": 4,
      "text": "Add cabbage, snap peas, bell pepper, and carrot. Stir fry for 4 minutes."
    },
    {
      "position": 5,
      "text": "Add soy sauce and oyster sauce. Stir."
    },
    {
      "position": 6,
      "text": "Pour chicken broth and let boil"
    },
    {
      "position": 7,
      "text": "Add the flour sticks (pancit canton). Cover and cook for 2 minutes. Toss the noodles and make and let it absorb the broth. Continue to cook until all the noodles absorb the liquid."
    },
    {
      "position": 8,
      "text": "Pour cornstarch diluted in water. Stir and cook until the sauce gets thick."
    },
    {
      "position": 9,
      "text": "Serve with calamansi or lime."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
