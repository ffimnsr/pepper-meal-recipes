  "id": "3c7dc4fd-71f0-53b4-91f2-71472cfeb14c",
  "slug": "adobong-hipon-sa-gata",
  "name": "Adobong Hipon sa Gata",
  "recipe_type": null,
  "brief_description": "Adobong Hipon sa Gata is a delicious and flavorful shrimp dish which is cooked using two methods: inadobo and ginataan.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Add the garlic and whole peppercorn once the oil becomes hot. Cook until the garlic turns medium brown."
    },
    {
      "position": 3,
      "text": "Put-in the Shrimp. Cook for 3 minutes or until the color of the shrimp turns orangey."
    },
    {
      "position": 4,
      "text": "Pour-in the soy sauce and water. Stir and let boil. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add the dried bay leaves and vinegar. Cover. Let boil. Cook for 2 to 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the coconut milk. Let boil and continue to cook for 2 minutes. Add salt to taste."
    },
    {
      "position": 7,
      "text": "Remove the shrimp from the pan and arrange in a serving bowl."
    },
    {
      "position": 8,
      "text": "Meanwhile continue to cook the sauce until it becomes thick. Pour the sauce over the shrimp in the serving bowl."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
