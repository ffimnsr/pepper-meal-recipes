  "id": "e70cb1d3-b868-548a-b2f1-fcd676b61bcd",
  "slug": "creamy-baked-spaghetti",
  "name": "Creamy Baked Spaghetti",
  "recipe_type": null,
  "brief_description": "Creamy baked spaghetti is one of the comfort foods that I regularly prepare to pamper myself. I indulge in its rich creamy sauce and excellent taste.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the spaghetti according to package instructions. Drain and set aside."
    },
    {
      "position": 2,
      "text": "Make the meat sauce by following the link to the recipe above. Use the exact amount of ingredients indicated in the recipe."
    },
    {
      "position": 3,
      "text": "Add the cream cheese to the meat sauce and stir until well blended. Turn the heat to off."
    },
    {
      "position": 4,
      "text": "Make the mornay sauce by melting butter in a saucepan. Once the butter melts, add the flour. Quickly stir until the flour absorbs the butter (it will look like a big lump, that is fine though). Pour-in the milk and then stir until all the ingredients are well blended. Continue to stir until the milk starts to get thicker. Add Parmesan cheese and stir until the texture gets thick enough (like soft pudding). turn the heat off and set aside."
    },
    {
      "position": 5,
      "text": "Pre-heat the oven to 350F."
    },
    {
      "position": 6,
      "text": "Meanwhile, combine the cooked spaghetti with the meat sauce in a large mixing bowl. Toss to blend the ingredients. Arrange the mixture in a baking pan. Pour the mornay sauce on top and then spread all over. Sprinkle cheddar cheese on top."
    },
    {
      "position": 7,
      "text": "Bake the spaghetti for 18 to 20 minutes."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
