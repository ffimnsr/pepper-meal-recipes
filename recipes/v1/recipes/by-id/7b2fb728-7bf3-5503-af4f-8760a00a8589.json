  "id": "7b2fb728-7bf3-5503-af4f-8760a00a8589",
  "slug": "paksiw-na-bangus-recipe",
  "name": "Paksiw na Bangus Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Paksiw na Bangus.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange ginger, garlic, okra, onion, long green pepper, peppercorn, and eggplant on the pot."
    },
    {
      "position": 2,
      "text": "Top with bangus slices."
    },
    {
      "position": 3,
      "text": "Pour water and vinegar. Apply heat and let boil. Cover and continue to cook in low to medium heat for 15 minutes."
    },
    {
      "position": 4,
      "text": "Add salt to taste."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
