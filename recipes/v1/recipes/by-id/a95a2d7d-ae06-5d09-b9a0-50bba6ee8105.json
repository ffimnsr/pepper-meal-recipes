  "id": "a95a2d7d-ae06-5d09-b9a0-50bba6ee8105",
  "slug": "pork-adobo-with-tokwa-and-tausi-and-garlic-fried-rice-adobo",
  "name": "Pork Adobo with Tokwa and Tausi and Garlic Fried Rice Adobo",
  "recipe_type": "side",
  "brief_description": "Filipino pork adobo with salted black beans and fried tofu and a side of garlic fried rice with adobo sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the toasted garlic by heating oil in a pan. Add crushed garlic while oil is heating up. Cook in low heat until garlic turns golden brown. Set aside. Note: the oil used to cook the garlic turns to garlic oil."
    },
    {
      "position": 2,
      "text": "Heat half of the garlic oil in a pan. Saute pork until light brown."
    },
    {
      "position": 3,
      "text": "Pour soy sauce and vinegar. Let boil."
    },
    {
      "position": 4,
      "text": "Add salted black beans and water. Cover and cook for 40 minutes or until pork gets tender."
    },
    {
      "position": 5,
      "text": "Add fried tofu and sugar. Stir and cook for 3 minutes. Transfer to a serving plate."
    },
    {
      "position": 6,
      "text": "Prepare the fried rice by combining salt and rice. Mix gently."
    },
    {
      "position": 7,
      "text": "Heat the remaining toasted garlic and oil in a pan. Add rice. Pour-in adobo sauce. Stir-fry for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Serve with pork adobo. Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
