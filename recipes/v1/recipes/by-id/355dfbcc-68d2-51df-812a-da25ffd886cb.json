  "id": "355dfbcc-68d2-51df-812a-da25ffd886cb",
  "slug": "how-to-cook-round-steak-in-criolla-sauce",
  "name": "Round Steak in Criolla Sauce Recipe",
  "recipe_type": "main",
  "brief_description": "Tender round steak simmered with aromatics and served with a vibrant Criolla sauce made with fresh tomatoes, bell peppers, onions, and vinegar. A flavorful make-ahead dish perfect for family dinners.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot and let boil."
    },
    {
      "position": 2,
      "text": "Put-in the halved onion, leeks, 1/2 tablespoon salt and whole peppercorns."
    },
    {
      "position": 3,
      "text": "Add-in the round steak and allow the water to re-boil. Simmer for 45 to 60 minutes or until the beef is tender."
    },
    {
      "position": 4,
      "text": "Remove the beef from the cooking pot and let the meat rest for 15 minutes. Slice thinly, and set aside."
    },
    {
      "position": 5,
      "text": "Make the Criolla Sauce by combining all the ingredients in a mixing bowl."
    },
    {
      "position": 6,
      "text": "Arrange the meat and the sauce in a serving plate by alternately layering the meat and the sauce."
    },
    {
      "position": 7,
      "text": "Refrigerate for at least 4 hours."
    },
    {
      "position": 8,
      "text": "Serve. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
