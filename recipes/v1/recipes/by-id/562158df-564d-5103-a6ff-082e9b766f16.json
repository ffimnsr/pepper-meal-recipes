  "id": "562158df-564d-5103-a6ff-082e9b766f16",
  "slug": "cornbread-muffins-recipe",
  "name": "Cornbread Muffin Recipe",
  "recipe_type": "dessert",
  "brief_description": "This Cornbread Muffin Recipe is the best that I have. It closely resembles the muffins found in Kenny Rogers restaurant. Try this recipe today to believe it.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the dry ingredients (flour, cornmeal, baking powder, and salt) in a large mixing bowl then mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Place the butter in a mixing bowl then beat until the texture becomes creamy."
    },
    {
      "position": 3,
      "text": "Gradually add the granulated sugar and continue beating until the butter and sugar are mixed thoroughly."
    },
    {
      "position": 4,
      "text": "Gradually add the dry ingredients (mixture of flour, cornmeal, baking powder, and salt) while beating."
    },
    {
      "position": 5,
      "text": "Add honey, eggs, and milk then continue mixing until every ingredient is well incorporated."
    },
    {
      "position": 6,
      "text": "Put-in the corn and mix with the other ingredients."
    },
    {
      "position": 7,
      "text": "Preheat oven to 400 degrees Fahrenheit."
    },
    {
      "position": 8,
      "text": "Grease a muffin or cupcake pan and pour-in the mixture."
    },
    {
      "position": 9,
      "text": "Bake for 18 to 22 minutes or until the muffin passes the toothpick test."
    },
    {
      "position": 10,
      "text": "Remove from the oven and let cool."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 22,
  "preparation_time_minutes": 10,
