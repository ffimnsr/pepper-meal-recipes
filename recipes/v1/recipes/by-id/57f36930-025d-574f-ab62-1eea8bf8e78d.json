  "id": "57f36930-025d-574f-ab62-1eea8bf8e78d",
  "slug": "filipino-style-pork-bbq",
  "name": "Filipino Style Pork BBQ",
  "recipe_type": null,
  "brief_description": "This is a recipe for Filipino Style Pork BBQ",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the pork slices in a large bowl."
    },
    {
      "position": 2,
      "text": "Add all the marinade ingredients. Mix well. Cover the bowl and marinate for at least 3 hours. Note: I strongly suggest marinating overnight for best results."
    },
    {
      "position": 3,
      "text": "Fasten the marinated pork together using bamboo skewers."
    },
    {
      "position": 4,
      "text": "Heat-up the grill. Start to grill your Filipino Style pork BBQ for 3 to 5 minutes per side until the meat is thoroughly cooked. Make sure to always baste the BBQ when flipping it over. Note: the basting sauce ingredients are the same as the marinade ingredients minus the lemon soda."
    },
    {
      "position": 5,
      "text": "Serve with spicy vinegar."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 180,
