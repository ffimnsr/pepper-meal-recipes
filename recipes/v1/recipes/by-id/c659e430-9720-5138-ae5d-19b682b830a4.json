  "id": "c659e430-9720-5138-ae5d-19b682b830a4",
  "slug": "ginisang-repolyo",
  "name": "Ginisang Repolyo",
  "recipe_type": "main",
  "brief_description": "Sauteed cabbage with bell pepper and ground pork",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot, saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Put-in the pork and then cook for 5 minutes or until color turns medium brown."
    },
    {
      "position": 4,
      "text": "Pour-in half of the beef broth. Let boil and simmer until the liquid totally evaporate."
    },
    {
      "position": 5,
      "text": "Put-in the cabbage. Cook for 1 to 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the red bell pepper. Stir and cook for 1 minute more."
    },
    {
      "position": 7,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Pour-in remaining beef broth. Let boil. Stir."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
