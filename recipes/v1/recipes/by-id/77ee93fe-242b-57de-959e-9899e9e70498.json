  "id": "77ee93fe-242b-57de-959e-9899e9e70498",
  "slug": "oxtail-stew-recipe",
  "name": "Oxtail Stew",
  "recipe_type": null,
  "brief_description": "This is a recipe for oxtail stew",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat olive oil in a pressure cooker. Once the oil starts to get hot, add the butter. Continue to heat until the butter and oil mixture starts to bubble."
    },
    {
      "position": 2,
      "text": "Saute the onion until tender."
    },
    {
      "position": 3,
      "text": "Add the oxtail. Cook each side for 1 minute."
    },
    {
      "position": 4,
      "text": "Add tomato paste. Saute the it in tomato paste for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour the beef broth into the pressure cooker. Cover and pressure cook for 30 to 40 minutes."
    },
    {
      "position": 6,
      "text": "Add thyme and red wine. Let boil."
    },
    {
      "position": 7,
      "text": "Add cubes potato. Continue to cook for 8 to 10 minutes. Note: you can add more beef broth if the liquid starts to dry-up."
    },
    {
      "position": 8,
      "text": "Add salt and ground black pepper to taste."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bow. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
