  "id": "7893fb06-a1cb-5051-aaeb-0565598a2d62",
  "slug": "pork-estofado-recipe",
  "name": "Pork Estofado Recipe",
  "recipe_type": "dessert",
  "brief_description": "Pork with plantains and carrots cooked with sweet Filipino adobo sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a frying pan and pour 3/4 cups of cooking oil."
    },
    {
      "position": 2,
      "text": "When the oil is hot enough, fry the sliced plantains until the color of each side turns medium to dark brown. Set aside."
    },
    {
      "position": 3,
      "text": "Pour 1/4 cup of cooking oil in a separate cooking pot then apply heat."
    },
    {
      "position": 4,
      "text": "When the oil is hot enough, put-in the garlic and saut\u00e9 until the color turns light brown."
    },
    {
      "position": 5,
      "text": "Add the cubed pork and cook for 7 to 10 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the soy sauce, water, whole peppercorns, and dried bay leaves then bring to a boil. Simmer until pork is tender."
    },
    {
      "position": 7,
      "text": "Add vinegar and wait for the liquid to re-boil. Simmer for 5 minutes."
    },
    {
      "position": 8,
      "text": "Add brown sugar and carrots. Stir then simmer for 10 minutes more."
    },
    {
      "position": 9,
      "text": "Turn off the heat and transfer the contents of the cooking pot to a serving plate."
    },
    {
      "position": 10,
      "text": "Garnish with fried bananas then serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
