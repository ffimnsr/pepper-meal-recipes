  "id": "440c1249-5065-5560-aff9-8b01847da098",
  "slug": "betamax-recipe",
  "name": "Betamax Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Air Fried Marinated Coagulated Chicken Blood",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cut the chicken blood into cubes."
    },
    {
      "position": 2,
      "text": "Arrange the cubed blood in a cooking pot. Add soy sauce, vinegar, and water. Let boil. Baste the blood with the mixture (pour the mixture onto the blood by gently scooping with a spoon)."
    },
    {
      "position": 3,
      "text": "Add garlic powder, ground black pepper, and Knorr Chicken Cube. Cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Transfer the chicken blood (without the sauce) to a clean plate. Let it cool down. Gently skewer using a bamboo stick."
    },
    {
      "position": 5,
      "text": "Brush garlic oil all over. Arrange in an air fryer. Cook for 5 minutes per side at 200 degrees Celsius."
    },
    {
      "position": 6,
      "text": "Make the dipping sauce by combining all the dipping sauce ingredients. Stir until well blended."
    },
    {
      "position": 7,
      "text": "Serve the Betamax along with the spicy dipping sauce."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "medium",
