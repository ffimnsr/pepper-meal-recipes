  "id": "19f72fa6-2c06-5343-be43-d6991c8e805a",
  "slug": "how-to-make-yema",
  "name": "How to Make Yema",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Yema.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine egg yolks and condensed milk. Mix well."
    },
    {
      "position": 2,
      "text": "Add chopped walnuts. Whisk until well blended."
    },
    {
      "position": 3,
      "text": "Melt butter in a cooking pot or pan. Pour the egg yolk mistuxe into the pan."
    },
    {
      "position": 4,
      "text": "Continue to cook until the consistency becomes very thick to the point that it can easily form a shape when molded."
    },
    {
      "position": 5,
      "text": "Transfer the mixture to a bowl. Let it cool down."
    },
    {
      "position": 6,
      "text": "Cut the cellophane into 3x3 inch pieces. Scoop 1 tablespoons of mixture and place at the middle of the cellophane. Wrap the yema while molding to form a pyramid shape piece (note: watch the video for details). Continue to wrap the yema until all the mixture are consumed."
    },
    {
      "position": 7,
      "text": "Serve . Share and enjoy."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
