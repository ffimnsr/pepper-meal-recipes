  "id": "a2f3a050-f98b-5288-933f-25e4ab0588be",
  "slug": "tornado-franks",
  "name": "Tornado Franks",
  "recipe_type": "snack",
  "brief_description": "Chicken franks with spiral dough fried to perfection",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Make the dough by combining all the dough ingredients in a bowl. Mix well. Knead until the texture becomes smooth."
    },
    {
      "position": 2,
      "text": "Divide the dough into 4 to 6 equal parts. Roll until strings are formed. Set aside."
    },
    {
      "position": 3,
      "text": "Skew each of the chicken franks with bamboo skewers and create a spiral incision. Fill each incision with dough strings. Set aside."
    },
    {
      "position": 4,
      "text": "Heat cooking oil in a pan. Fry each skewed chicken franks for 3 minutes while turning over occasionally."
    },
    {
      "position": 5,
      "text": "Remove from the pan. Let it cool down."
    },
    {
      "position": 6,
      "text": "Serve with your favorite dipping sauce. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 12,
