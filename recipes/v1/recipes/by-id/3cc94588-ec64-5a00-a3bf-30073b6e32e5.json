  "id": "3cc94588-ec64-5a00-a3bf-30073b6e32e5",
  "slug": "pork-parmesan",
  "name": "Pork Parmesan",
  "recipe_type": null,
  "brief_description": "This Pork Parmesan Recipe is a crowd pleaser. It tastes great; takes a little time to prepare; and it is perfect for any occasion.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and pepper on the pork loin chops. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat the oil in a frying pan."
    },
    {
      "position": 3,
      "text": "Dredge pork loin in flour and then dip in beaten egg. Dredge in Panko breadcrumbs. Make sure that the pork is properly coated."
    },
    {
      "position": 4,
      "text": "Fry each side for 3 minutes. Set aside."
    },
    {
      "position": 5,
      "text": "Meanwhile, preheat the oven to 350 degrees Fahrenheit."
    },
    {
      "position": 6,
      "text": "Arrange the fried pork loin in a greased baking tray. Bake for 15 to 20 minutes."
    },
    {
      "position": 7,
      "text": "While baking the pork, make the sauce by boiling the diced tomatoes in a saucepan."
    },
    {
      "position": 8,
      "text": "Add oregano, basil, Italian seasoning, plus salt and pepper to taste. Stir and simmer for 10 to 12 minutes or until the sauce thickens."
    },
    {
      "position": 9,
      "text": "Remove the baking tray from the oven. Pour about 2 tablespoons of tomato based sauce over the baked pork and sprinkle cheese on top."
    },
    {
      "position": 10,
      "text": "Put the baking tray back in the oven. Bake for 5 minutes more."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
