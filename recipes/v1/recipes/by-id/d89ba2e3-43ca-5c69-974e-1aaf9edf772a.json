  "id": "d89ba2e3-43ca-5c69-974e-1aaf9edf772a",
  "slug": "pork-tapsilog-recipe",
  "name": "Pork Tapsilog",
  "recipe_type": "breakfast",
  "brief_description": "Pork tapa with garlic fried rice and egg",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a medium resealable bag, combine pork, soy sauce, garlic, sugar, salt, and pepper. Mix well and then marinate overnight inside the fridge."
    },
    {
      "position": 2,
      "text": "Heat the frying pan and then pour-in the cooking oil."
    },
    {
      "position": 3,
      "text": "When the oil becomes hot, fry the marinated pork pieces in low to medium heat until the color turns medium brown. Flip as necessary to cook the opposite side."
    },
    {
      "position": 4,
      "text": "Arrange the fried marinated pork, a cup of garlic rice, and a piece of fried egg in individual plates."
    },
    {
      "position": 5,
      "text": "Serve with spicy vinegar and ketchup. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
