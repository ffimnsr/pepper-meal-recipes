  "id": "5120a9cb-6e5a-5cb8-803b-48805f304558",
  "slug": "pork-and-kangkong-guisado",
  "name": "Pork and Kangkong Guisado",
  "recipe_type": null,
  "brief_description": "Pork and Kangkong Guisado is a simple dish that you can serve during ordinary days. I like this because it is delicious, easy to prepare, and budget friendly.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a wok or pan."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, add the pork Cook until both sides of the pork are brown. Also make sure that oil is extracted out of the pork."
    },
    {
      "position": 3,
      "text": "Add garlic. Stir and cook for 20 seconds."
    },
    {
      "position": 4,
      "text": "Add onion, stir and cook until the onion gets soft."
    },
    {
      "position": 5,
      "text": "Stir-in the chopped kangkong stalk. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in soy sauce. Add the ground black pepper. Continue to cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add the kangkong leaves. Cover the wok or pan for 1 minute."
    },
    {
      "position": 8,
      "text": "Remove the cover, stir. Add the beef broth. Let boil. Stir and cook for 1 minute."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
