  "id": "c3eb217f-d300-593f-8b59-1ce6134805a7",
  "slug": "ginataang-langka-utan-recipe",
  "name": "Ginataang Langka Recipe",
  "recipe_type": "side",
  "brief_description": "Ginataang langka recipe results in a delicious Filipino vegetable dish involving young jackfruit and coconut milk. This is considered as a main dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a wok or a cooking pot and pour-in the coconut milk. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the garlic and onions and cook for 3 to 5 minutes while continuously stirring the mixture."
    },
    {
      "position": 3,
      "text": "Put-in the tomatoes and red chilies. Continue stirring to prevent lumps from forming."
    },
    {
      "position": 4,
      "text": "Add the fried dried fish and cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in water and allow re-boiling."
    },
    {
      "position": 6,
      "text": "Add the chopped jackfruit then mix with the other ingredients. Simmer for 5 to 8 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the shrimp cube then stir to ensure that the ingredients are properly distributed. Simmer until the liquid dries up."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate then serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
