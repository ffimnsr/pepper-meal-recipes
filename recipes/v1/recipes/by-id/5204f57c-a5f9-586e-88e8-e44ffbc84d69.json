  "id": "5204f57c-a5f9-586e-88e8-e44ffbc84d69",
  "slug": "cassava-cake-recipe-creamy-and-cheesy-version",
  "name": "Cassava Cake Recipe Creamy and Cheesy Version",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for creamy cassava cake.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350F."
    },
    {
      "position": 2,
      "text": "Combine the wet ingredients in a mixing bowl starting by cracking the eggs. Beat until smooth. Pour the evaporated milk, condensed milk, butter, and coconut milk. Whisk everything together until the mixture smoothens."
    },
    {
      "position": 3,
      "text": "Add the grated cassava and \u00bd cup cheese in the bowl where the wet ingredients are at. Mix well."
    },
    {
      "position": 4,
      "text": "Transfer the mixture into a greased baking pan. Bake for 1 hour."
    },
    {
      "position": 5,
      "text": "Prepare the topping by mixing all the topping ingredients in a clean bowl. Mix everything together. Set aside."
    },
    {
      "position": 6,
      "text": "Pour the topping mixture over the baked cassava. Put the baking pan back in the oven. Continue baking at 350F until the topping thickens. Note: You will notice that it will burn a bit, that is normal."
    },
    {
      "position": 7,
      "text": "Remove the baking pan from the oven. Let the cassava cake cool down."
    },
    {
      "position": 8,
      "text": "Slice the cake into serving pieces. Serve for dessert."
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
