  "id": "a6bd9129-71f0-5c84-9d82-c725f7e6f7d6",
  "slug": "improved-kfc-fried-chicken-recipe",
  "name": "KFC Fried Chicken Recipe",
  "recipe_type": "main",
  "brief_description": "Fried Chicken done better than KFC.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Combine Knorr Liquid Seasoning and buttermilk in a large bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Add chicken pieces. Marinate for at least 3 hours."
    },
    {
      "position": 3,
      "text": "Combine the breading ingredients in a separate bowl. Mix well."
    },
    {
      "position": 4,
      "text": "Remove the chicken from the marinade bowl letting excess liquid drip. Dredge the chicken pieces into the breading mixture making sure that each piece is completely coated. Let it stay for at least 5 minutes."
    },
    {
      "position": 5,
      "text": "Heat cooking oil in a deep cooking pot (Note: I cooked mine using a pressure cooker. This is called pressure frying). Deep fry the chicken pieces until the internal temperature reads 165F. Note: You may decide to pressure fry the chicken but be extra careful. If doing so, make sure that the oil is more than 350F before adding the chicken. Deep fry for 1 minute uncovered before sealing the pressure cooker. Pressure-cook at not more than 350F between 7 to 8 minutes only (do not cook it longer). Release the pressure from the cooker and remove the chicken."
    },
    {
      "position": 6,
      "text": "Arrange the fried chicken on a wire rack for the oil to drip. Serve with chicken gravy and your favorite sides. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
