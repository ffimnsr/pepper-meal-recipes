  "id": "d81b2329-563d-598f-9592-334ac95a89f2",
  "slug": "spareribs-kaldereta",
  "name": "Spareribs Kaldereta",
  "recipe_type": "main",
  "brief_description": "Pork spare ribs stewed in a tomato based sauce with potato, carrot, capsicum, and peas.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute onion and garlic."
    },
    {
      "position": 3,
      "text": "Once the onion softens, add spareribs. Saute until the ribs turns light brown in color."
    },
    {
      "position": 4,
      "text": "Pour tomato sauce and water. Stir and let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork Cube. Cover the pan and then cook for 1 hour or until the meat gets tender."
    },
    {
      "position": 6,
      "text": "Add liver spread and chili pepper. Stir."
    },
    {
      "position": 7,
      "text": "Add carrot and potato and more water, as needed. Cover and cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Stir-in bell peppers and green peas. Cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper and salt."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl and serve along with warm rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
