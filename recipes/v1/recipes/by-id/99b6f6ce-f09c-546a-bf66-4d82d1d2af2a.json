  "id": "99b6f6ce-f09c-546a-bf66-4d82d1d2af2a",
  "slug": "kakaibang-chicken-adobo",
  "name": "Kakaibang Filipino Chicken Adobo",
  "recipe_type": "main",
  "brief_description": "Chicken adobo marinated in yogurt",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the marinade ingredients in a large bowl. Mix well. Add the chicken pieces and coat it with the marinade mixture. Cover the bowl and put inside the refrigerator. Let it stay for at least 3 hours."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a pan. Fry both sides of the chicken liver until it browns. Remove from the pan. Set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil, fry the marinated chicken for 1 minute per side. Remove from the pan."
    },
    {
      "position": 4,
      "text": "Melt the butter with the remaining oil. Add garlic. Cook until it starts to brown."
    },
    {
      "position": 5,
      "text": "Put the chicken back into the pan. Add soy sauce, vinegar, lemon lime soda, water. Let boil."
    },
    {
      "position": 6,
      "text": "Add \u00bd Knorr Chicken Cube, cracked peppercorn, and bay leaves. Cover the pot and reduce the heat to low setting. Cook for 20 to 25 minutes."
    },
    {
      "position": 7,
      "text": "Add the fried chicken livers back into the pan. Stir."
    },
    {
      "position": 8,
      "text": "Combine cornstarch with \u00bc cup water to make a slurry. Mix well. Pour into the cooking pot and stir right away. Add boiled eggs. Continue cooking until the sauce thickens."
    },
    {
      "position": 9,
      "text": "Arrange on a serving plate and garnish with chopped green onions."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
