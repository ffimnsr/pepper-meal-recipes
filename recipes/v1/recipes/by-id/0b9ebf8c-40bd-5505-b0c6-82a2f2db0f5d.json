  "id": "0b9ebf8c-40bd-5505-b0c6-82a2f2db0f5d",
  "slug": "pinatuyong-pork-hamonado-recipe",
  "name": "Pinatuyong Pork Hamonado",
  "recipe_type": null,
  "brief_description": "Pork belly in soy and pineapple reduction. This is a tasty dish best served with rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Fry pork belly until color turns light brown. Flip it over to cook the opposite side."
    },
    {
      "position": 3,
      "text": "Add onion and garlic. Stir and saute until onion softens."
    },
    {
      "position": 4,
      "text": "Pour soy sauce into the pan. Stir and continue cooking for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour-in juice from the canned pineapple chunk and add 1 cup water. Let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Pork Cube. Cover and cook using low heat until pork tenderizes."
    },
    {
      "position": 7,
      "text": "Add brown sugar and half of the pineapple chunks in the can. Stir and cook until sauce thickens."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper as needed. Continue cooking until sauce evaporates completely."
    },
    {
      "position": 9,
      "text": "Add remaining pineapple. Stir."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 11,
      "text": "Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
