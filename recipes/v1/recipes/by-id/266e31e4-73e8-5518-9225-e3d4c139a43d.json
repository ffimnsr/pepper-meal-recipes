  "id": "266e31e4-73e8-5518-9225-e3d4c139a43d",
  "slug": "creamy-lengua-in-white-sauce-with-mushroom",
  "name": "Creamy Lengua in White Sauce",
  "recipe_type": "main",
  "brief_description": "Tender ox tongue in rich and creamy white sauce with mushroom.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Tenderize the lengua by boiling water in a pot. Add ox tongue and boil for 1 to 1 \u00bd hours. Remove tongue from the pot. Let it cook down. Peel the skin off and then slice the ox tongue into thin pieces. Set aside."
    },
    {
      "position": 2,
      "text": "Melt butter in a pan. Saut\u00e9 onion."
    },
    {
      "position": 3,
      "text": "Add sliced lengua. Saut\u00e9 for 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour water. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Beef Cube. Stir. Boil until liquid reduces in half."
    },
    {
      "position": 6,
      "text": "Add button mushroom. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Pour heavy whipping cream. Add garlic powder. Stir and cook in low to medium heat for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Add Lady\u2019s Choice Mayonnaise. Stir until sauce is smooth."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper and salt. Cook until sauce thickens."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 2925,
