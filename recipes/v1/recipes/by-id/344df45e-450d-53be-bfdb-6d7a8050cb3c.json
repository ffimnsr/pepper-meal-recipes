  "id": "344df45e-450d-53be-bfdb-6d7a8050cb3c",
  "slug": "lightly-breaded-fried-pork-chop",
  "name": "Lightly Breaded Fried Pork Chop",
  "recipe_type": null,
  "brief_description": "Lightly Breaded Fried Pork Chop is a simple Fried Pork Chop recipe that is perfect for lunch. This dish goes well with mashed potatoes",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine 1/2 teaspoon salt, and 1/4 teaspoon ground black pepper. Rub all over the pork chops. Let it stay for 15 minutes for the flavors to get absorbed."
    },
    {
      "position": 2,
      "text": "Meanwhile, combine the flour, garlic powder, and paprika in a large resealable Ziploc or freezer bag. Mix well."
    },
    {
      "position": 3,
      "text": "Heat the cooking oil in a wide pan."
    },
    {
      "position": 4,
      "text": "While the oil is heating up, lightly dredge the pork chops in the flour mixture until the entire slice is completely covered."
    },
    {
      "position": 5,
      "text": "Pan fry each side for 5 to 7 minutes in low to medium heat. Note: do not fry in high heat to avoid the pork chops from getting burnt easily. It can also quickly cook the outer part, but the inside might still be uncooked."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 15,
