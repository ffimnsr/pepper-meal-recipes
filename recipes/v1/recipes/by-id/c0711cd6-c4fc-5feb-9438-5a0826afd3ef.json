  "id": "c0711cd6-c4fc-5feb-9438-5a0826afd3ef",
  "slug": "odong-recipe",
  "name": "Odong Recipe",
  "recipe_type": "soup",
  "brief_description": "Odong is a soup dish composed of canned sardines in tomato sauce, flour noodles (known as odong), and vegetables such as loofah or bottle gourd.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute the garlic and onion when the oil becomes hot. Cook until the onion is soft."
    },
    {
      "position": 3,
      "text": "Put in sliced bottle gourd. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the sardines including the sauce and pour-in water. Let boil."
    },
    {
      "position": 5,
      "text": "Put-in the noodles. Cook for for 5 to 8 minutes or until the noodles are done."
    },
    {
      "position": 6,
      "text": "Add salt and pepper to taste. Stir."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 8,
      "text": "Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
