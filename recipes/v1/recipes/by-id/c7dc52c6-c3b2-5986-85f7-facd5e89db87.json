  "id": "c7dc52c6-c3b2-5986-85f7-facd5e89db87",
  "slug": "basic-tortang-talong-recipe",
  "name": "Basic Tortang Talong",
  "recipe_type": null,
  "brief_description": "This is a Basic Tortang Talong Recipe (Eggplant Omelet)",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the eggplant directly over fire in a stovetop until the skin of the eggplant turns brown to black, Rotate after a few minutes until all parts of are almost burnt."
    },
    {
      "position": 2,
      "text": "Let the eggplant cooldown and then peel the skin off using your fingers. The inside part of the eggplant should be steamed just right at this point."
    },
    {
      "position": 3,
      "text": "Arrange the peeled eggplant in a plate and then flatten using a fork. Set aside."
    },
    {
      "position": 4,
      "text": "Beat the egg in a bowl and add salt and pepper. Continue beating until the salt and pepper are well blended."
    },
    {
      "position": 5,
      "text": "Dip the eggplant in the egg mixture."
    },
    {
      "position": 6,
      "text": "Heat oil in a pan. Once the oil gets hot, start to fry one side of the eggplant until it gets medium brown."
    },
    {
      "position": 7,
      "text": "Pour the remaining egg mixture on top of the eggplant. Turn it over and fry the other side until it gets light to medium brown."
    },
    {
      "position": 8,
      "text": "Remove from the pan and arrange in a wide plate. Serve with banana ketchup."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 1,
  "cooking_time_minutes": 6,
  "preparation_time_minutes": 5,
