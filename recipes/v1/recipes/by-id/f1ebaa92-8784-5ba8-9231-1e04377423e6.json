  "id": "f1ebaa92-8784-5ba8-9231-1e04377423e6",
  "slug": "easy-fish-with-tausi-recipe",
  "name": "Easy Fish with Tausi",
  "recipe_type": "appetizer",
  "brief_description": "Crispy fried fish fillet cubes tossed in a thick and savory sauce made with salted black beans, ginger, garlic, and green onions. The fish is marinated in sherry cooking wine and sesame oil before frying, giving it a clean flavor that pairs perfectly with the salty fermented bean sauce. Serve over steamed white rice.",
  "cuisine": "Asian Chinese Filipino seafood",
  "instructions": [
    {
      "position": 1,
      "text": "Combine 3 tablespoons of sherry cooking wine, salt, and 1 teaspoon of sesame oil in a bowl. Mix well. Add the fish cubes and marinate for 30 minutes."
    },
    {
      "position": 2,
      "text": "Soak the salted black beans in warm water for 15 minutes. Drain and set aside."
    },
    {
      "position": 3,
      "text": "Heat the cooking oil in a pot over medium high heat. Remove the fish from the marinade and coat each piece evenly with 3 tablespoons of cornstarch. Fry the fish in batches until light brown and crispy. Remove from the pot and set aside on a plate lined with paper towels."
    },
    {
      "position": 4,
      "text": "In a bowl, combine the chicken stock, remaining sesame oil, remaining sherry cooking wine, ground black pepper, remaining cornstarch, and sugar. Mix well and set aside."
    },
    {
      "position": 5,
      "text": "Heat 3 tablespoons of oil in a separate pan, preferably from the oil used to fry the fish. Saut\u00e9 the garlic, ginger, and drained salted black beans for 30 to 60 seconds."
    },
    {
      "position": 6,
      "text": "Add the fried fish cubes back into the pan and gently stir to combine."
    },
    {
      "position": 7,
      "text": "Pour in the sauce mixture and continue cooking while stirring gently until the sauce thickens and coats the fish."
    },
    {
      "position": 8,
      "text": "Sprinkle the chopped green onions on top. Transfer to a serving plate and serve warm."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 15,
  "rest_time_minutes": 30,
  "difficulty": "medium",
