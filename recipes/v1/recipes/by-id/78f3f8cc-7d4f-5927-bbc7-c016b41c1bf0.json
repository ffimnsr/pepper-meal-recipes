  "id": "78f3f8cc-7d4f-5927-bbc7-c016b41c1bf0",
  "slug": "crispy-pork-belly-chicharon",
  "name": "Crispy Pork Belly Chicharon",
  "recipe_type": "snack",
  "brief_description": "Crunchy deep-fried pork belly that tastes even better when dipped in spicy vinegar. Snack on it or consume it as a main dish with rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add salt, bay leaves, whole peppercorn, and pork. Cover and continue to boil for 60 minutes."
    },
    {
      "position": 2,
      "text": "Remove from the pot and let pork cool down. Poke holes on the skin using a toothpick. Slice the pork in half for a thinner piece."
    },
    {
      "position": 3,
      "text": "Rub salt all over the pork belly. Air dry for 1 hour. Note: placing the pork in front of an electric fan is a good idea."
    },
    {
      "position": 4,
      "text": "Heat oil on a cooking pot. Deep fry pork belly until crispy and golden brown. Note: be extra careful when doing this step. Use of splatter screen is recommended."
    },
    {
      "position": 5,
      "text": "Remove crispy pork belly from the cooking pot and place over a wire rack. Let it cool down."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with spicy vinegar."
    },
    {
      "position": 7,
      "text": "Serve! Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 80,
