  "id": "513787dd-573d-5c42-9f28-fadb6d1e4cac",
  "slug": "beef-pot-roast",
  "name": "Beef Pot Roast",
  "recipe_type": null,
  "brief_description": "This is a recipe for Beef Pot Roast",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 320F."
    },
    {
      "position": 2,
      "text": "Rub salt and ground black pepper all over the beef chuck. Let it stay for 10 minutes."
    },
    {
      "position": 3,
      "text": "Heat a Dutch oven and then pour canola oil into it."
    },
    {
      "position": 4,
      "text": "Once the oil becomes hot, sear one part of the beef chuck for 5 minutes. Turn it over and sear the opposite side for the same amount of time."
    },
    {
      "position": 5,
      "text": "Remove the seared beef chuck from the Dutch oven. Set aside."
    },
    {
      "position": 6,
      "text": "Meanwhile, saut\u00e9 onion and carrot using the remaining oil for 2 minutes"
    },
    {
      "position": 7,
      "text": "Deglaze by pouring red wine."
    },
    {
      "position": 8,
      "text": "Put the seared beef chuck back into the Dutch oven and then pour-in the beef broth. Add bay leaves, thyme and rosemary. Cover and place inside the oven. Continue to cook for 2 hours."
    },
    {
      "position": 9,
      "text": "Remove from the oven and add the potato. Cover and place back in the oven. Continue to cook for 60 to 80 minutes. Add more broth if needed."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve with mashed potato."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 180,
  "preparation_time_minutes": 10,
