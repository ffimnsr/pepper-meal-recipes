  "id": "8109a492-d220-5692-a8b7-21fbf53f6a0a",
  "slug": "filipino-bbq-pork-chop-recipe",
  "name": "Filipino BBQ Pork Chop Recipe",
  "recipe_type": null,
  "brief_description": "Filipino BBQ Pork Chop is my definition of a good grilled pork chop. This has an awesome taste which you will find interesting.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the marinade by combining the soy sauce, Worcestershire sauce, ketchup, lemon juice, salt, sugar, garlic powder, and pepper in a bowl. Mix until the sugar is diluted."
    },
    {
      "position": 2,
      "text": "Place the pork chop in a large reseal able bag. Pour-in the marinade mixture in the bag. Let the air out and then seal."
    },
    {
      "position": 3,
      "text": "Marinate the pork chop overnight or for at least 3 hours. Make sure to place the bag in the fridge while doing this."
    },
    {
      "position": 4,
      "text": "Make the basting sauce by transferring the remaining marinade in a bowl and then add the cooking oil and about 3 tablespoons of banana ketchup."
    },
    {
      "position": 5,
      "text": "Grill each side of the pork chop for 10 to 12 minutes in low to medium heat while basting both sides."
    },
    {
      "position": 6,
      "text": "Arrange the BBQ Pork chop over warm white rice, in a plate covered with fresh banana leaf."
    },
    {
      "position": 7,
      "text": "Serve with salted eggs, chopped tomato, and onion. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 180,
