  "id": "97a49ffd-0059-52e4-a459-ea0b5e0dfe4b",
  "slug": "salted-egg-prawn",
  "name": "Salted Egg Prawns",
  "recipe_type": null,
  "brief_description": "This is a recipe for Salted Egg Prawns.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the prawn by diluting Knorr Shrimp Cube in a cooking wine. Pour the mixture onto the prawn. Marinate for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Discard the marinade. Dredge the marinated prawn in cornstarch."
    },
    {
      "position": 4,
      "text": "Deep fry in medium heat until the prawn turns light to golden brown. Remove from the pot and set aside."
    },
    {
      "position": 5,
      "text": "Prepare the salted egg yolk sauce by mashing the egg yolks in a bowl. Pour heavy whipping cream. Stir until all ingredients are well blended."
    },
    {
      "position": 6,
      "text": "Melt butter in a pan. Put-in garlic, curry leaves, and chili pepper. Cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Add the salted egg yolk mixture. Stir and continue to cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Add the deep fried prawn in the pan. Toss to coat with sauce."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
