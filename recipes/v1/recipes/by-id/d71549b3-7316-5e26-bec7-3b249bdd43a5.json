  "id": "d71549b3-7316-5e26-bec7-3b249bdd43a5",
  "slug": "tofu-vegetable-stir-fry",
  "name": "Tofu Vegetable Stir Fry",
  "recipe_type": "main",
  "brief_description": "Letting ingredients sizzle until the flavors meld together can be pleasant to watch. I whipped up this Tofu Vegetable Stir Fry recipe",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat 1 cup of oil in a small cooking pot. Deep fry the tofu until it turns golden brown. Set aside."
    },
    {
      "position": 2,
      "text": "Heat 3 tablespoons of the same oil in a wok. Saut\u00e9 onion and garlic."
    },
    {
      "position": 3,
      "text": "Add mushrooms and carrot once the onion softens."
    },
    {
      "position": 4,
      "text": "Pour the soy sauce. Saut\u00e9 for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add snow peas, Knorr Chicken Cube, and water. Let boil."
    },
    {
      "position": 6,
      "text": "Put the oyster sauce along with the cabbage, bok choy, and green peas into the wok. Toss. Cover. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add the fried tofu and season with sugar, salt, and ground black pepper."
    },
    {
      "position": 8,
      "text": "Combine cornstarch with 3 tablespoons water. Mix well and then pour into the wok. Stir and continue cooking until the sauce thickens."
    },
    {
      "position": 9,
      "text": "Finish by adding sesame oil."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve with rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
