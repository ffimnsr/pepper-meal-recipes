  "id": "9170762f-4af3-5702-8f3b-7eaacbb592e0",
  "slug": "grilled-ahi-tuna-recipe",
  "name": "Grilled Ahi Tuna Recipe",
  "recipe_type": null,
  "brief_description": "I like to have Grilled Ahi Tuna for lunch on a sunny day. Having it with mango salsa compliments well with the dish and provides it with a refreshing taste",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the soy sauce, sugar, garlic powder, and ground black pepper in a bowl. Stir to mix."
    },
    {
      "position": 2,
      "text": "Place the ahi tuna in a resealable bag. Pour the soy sauce mixture into the bag. Release the air and seal.Refrigerate and Let the tuna marinate for at least 3 hours."
    },
    {
      "position": 3,
      "text": "Remove the tuna from the fridge. Spray high heat cooking oil grill spray on the grill and start to grill the ahi tuna for 4 to 5 minutes per side. Use a spatula to turn the tuna over so that the meat will not get damaged."
    },
    {
      "position": 4,
      "text": "Arrange in a serving plate. Serve with mango salsa."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 180,
