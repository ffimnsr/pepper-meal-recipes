  "id": "07dcc443-7413-59b3-a7d5-2b6c706d3196",
  "slug": "beef-kare-kare-recipe",
  "name": "Beef Kare-Kare Recipe",
  "recipe_type": null,
  "brief_description": "This is a kare-kare recipe that makes use of beef chuck, instead of the traditional oxtail. It is also known as peanut stew and is best eaten with bagoong alamang.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil. Saut\u00e9 the onion and add the garlic. Continue to saut\u00e9 until the onion gets soft."
    },
    {
      "position": 2,
      "text": "Sprinkle some ground black pepper. Stir. Add the beef and cook until the color turns light brown."
    },
    {
      "position": 3,
      "text": "Put the ground peanuts in with the beef. Stir and cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour the beef broth in the pan. Let boil. Cover and simmer until the beef gets tender (around 60 to 90 minutes.). You can add water or beef broth if needed."
    },
    {
      "position": 5,
      "text": "Meanwhile, prepare to blanch the string beans, eggplant, and bok choy. Boil 4 cups of water in a pot. Put the vegetables in boiling water by batches. Boil the string beans for 2 minutes. Remove from boiling water and immediately put in a bowl with cold water and ice. Remove from the bowl with cold water and put in a clean plate. Do the same steps for the remaining vegetables."
    },
    {
      "position": 6,
      "text": "Once the beef gets tender. Add the fish sauce and the mixture of annatto powder, \u00bd cup water, and glutinous rice flour. Stir. Continue to cook until the texture of the sauce thickens (3 to 5 minutes in medium heat)."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Arrange the blanched vegetables on the side and top with shrimp paste (bagoong alamang)."
    },
    {
      "position": 8,
      "text": "Serve with warm rice. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
