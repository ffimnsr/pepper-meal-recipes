  "id": "47d426b2-3d28-5eca-b766-e5052eca38e5",
  "slug": "how-to-make-tarragon-chicken-salad",
  "name": "Tarragon Chicken Salad",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for Tarragon Chicken Salad.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 400 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Arrange the chicken in a baking dish and pour-in chicken stock."
    },
    {
      "position": 3,
      "text": "Bake the chicken for about 40 to 45 minutes."
    },
    {
      "position": 4,
      "text": "Turn off the oven and remove the chicken. Let cool."
    },
    {
      "position": 5,
      "text": "Drain excess liquid then cut the chicken into cubes."
    },
    {
      "position": 6,
      "text": "In a mixing bowl, combine sour cream, mayonnaise, tarragon, salt, and ground black pepper. Mix well."
    },
    {
      "position": 7,
      "text": "Add in celery, apple, grapes, walnuts, and chicken then stir to distribute the ingredients."
    },
    {
      "position": 8,
      "text": "Refrigerate for at least 1 hour."
    },
    {
      "position": 9,
      "text": "Transfer to a salad plate the serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 15,
