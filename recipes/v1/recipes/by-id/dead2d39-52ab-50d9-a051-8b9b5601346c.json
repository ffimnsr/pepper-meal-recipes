  "id": "dead2d39-52ab-50d9-a051-8b9b5601346c",
  "slug": "asian-chinese-filipino-food-stir-fry-cashewed-chicken-recipe",
  "name": "Cashew Chicken Recipe",
  "recipe_type": null,
  "brief_description": "This Cashew Chicken Recipe is a version of the original Oriental dish tailored to fit the Filipino Palate. Thinly sliced chicken breast is coated with egg and cornstarch then stir fried until crispy and golden brown.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Beat the egg and pour-over the chicken then mix well until properly distributed"
    },
    {
      "position": 2,
      "text": "Heat the pan and pour the cooking oil"
    },
    {
      "position": 3,
      "text": "Dip the chicken (coated with egg) in corn starch and stir fry until the color of the chicken turns golden brown. Set aside"
    },
    {
      "position": 4,
      "text": "In the same pan, add some cooking oil and allow to heat-up"
    },
    {
      "position": 5,
      "text": "Stir-fry the onion, red bell pepper, and broccoli"
    },
    {
      "position": 6,
      "text": "Add the cooking rice wine, soy sauce, and oyster sauce then allow to cook for a few minutes"
    },
    {
      "position": 7,
      "text": "Add the stir-fried chicken and cook for 2 minutes while mixing with the rest of the ingredients"
    },
    {
      "position": 8,
      "text": "Add the cashew nuts,green onion, salt, and ground black pepper"
    },
    {
      "position": 9,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
