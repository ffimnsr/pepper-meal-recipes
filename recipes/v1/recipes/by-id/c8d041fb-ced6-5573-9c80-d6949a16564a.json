  "id": "c8d041fb-ced6-5573-9c80-d6949a16564a",
  "slug": "ginisang-sardinas-recipe",
  "name": "Ginisang Sardinas Recipe (Saut\u00e9ed Sardines)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginisang Sardinas.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and onion"
    },
    {
      "position": 3,
      "text": "When the onion becomes soft, add the tomato and cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in the sardines in tomato sauce and chili. Stir and let boil."
    },
    {
      "position": 5,
      "text": "Cook for 5 minutes in low to medium heat. You may add a little water if needed."
    },
    {
      "position": 6,
      "text": "Add-in the lemon juice, ground black pepper, and salt or fish sauce. Stir and cook for a minute more."
    },
    {
      "position": 7,
      "text": "Turn off heat and then transfer to a serving bowl. Garnish with chopped flat leaf parsley."
    },
    {
      "position": 8,
      "text": "Serve with steamed rice. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
