  "id": "0f1c056b-9199-5c65-a6b7-4e3767c3be0c",
  "slug": "tipid-sarap-monggo-na-may-kangkong-at-hibi",
  "name": "Tipid Sarap Monggo",
  "recipe_type": "main",
  "brief_description": "A delicious version of Filipino mung bean stew with water spinach and dried shrimp.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute onion, garlic, and tomato. Continue until tomato softens."
    },
    {
      "position": 3,
      "text": "Add mung beans. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour water. Let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Shrimp Cube. Stir. Cover the pot and then continue cooking until mung beans gets very tender and the texture of the soup thickens."
    },
    {
      "position": 6,
      "text": "Add hibi and kangkong stalks. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 8,
      "text": "Add kangkong leaves. Continue cooking for 2 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve with rice. Share and enjoy."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 130,
  "preparation_time_minutes": 5,
