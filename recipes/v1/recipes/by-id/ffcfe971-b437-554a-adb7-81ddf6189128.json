  "id": "ffcfe971-b437-554a-adb7-81ddf6189128",
  "slug": "creamy-mushroom-chicken",
  "name": "Creamy Mushroom Chicken",
  "recipe_type": "main",
  "brief_description": "Creamy garlic chicken with mushrooms and vegetables.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and ground black pepper all over the chicken pieces. Let it stay for 5 minutes."
    },
    {
      "position": 2,
      "text": "Heat 2 tablespoons oil in a pan. Saut\u00e9 carrot and long green beans for 2 minutes. Season with salt. Remove from the pan and set aside."
    },
    {
      "position": 3,
      "text": "Add remaining oil in the pan. Once the oil gets hot, pan fry the chicken for 1 to 2 minutes per side. Remove the chicken and place in a clean plate. Set aside."
    },
    {
      "position": 4,
      "text": "Melt the butter in the pan. Saut\u00e9 the garlic until it starts to turn light brown."
    },
    {
      "position": 5,
      "text": "Add the onion. Continue cooking until the onion softens."
    },
    {
      "position": 6,
      "text": "Put the chicken back into the pan. Saut\u00e9 for 2 minutes."
    },
    {
      "position": 7,
      "text": "Pour the water in the pan and let it boil."
    },
    {
      "position": 8,
      "text": "Add the Knorr Chicken cube. Cover the pan and continue cooking for 15 minutes."
    },
    {
      "position": 9,
      "text": "Pour the all-purpose cream, add the mushroom, and roasted garlic. Cook for 1 minute."
    },
    {
      "position": 10,
      "text": "Add the carrot and long green beans. Season with salt and ground black pepper as needed."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve warm with rice."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
