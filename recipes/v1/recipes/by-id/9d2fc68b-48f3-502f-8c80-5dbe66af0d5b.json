  "id": "9d2fc68b-48f3-502f-8c80-5dbe66af0d5b",
  "slug": "how-to-make-lengua-a-la-vinagreta",
  "name": "How to Make Lengua a la Vinagreta",
  "recipe_type": null,
  "brief_description": "Lengua a la Vinagreta Recipe",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in water and let boil."
    },
    {
      "position": 2,
      "text": "Put-in the ox tongue and 3 tablespoons of salt then simmer until tender (usually about an hour)."
    },
    {
      "position": 3,
      "text": "Remove the tongue from the cooking pot and let cool. Scrape the skin-off using a paring knife and thinly slice the tongue. Set aside."
    },
    {
      "position": 4,
      "text": "Make the marinade by combining garlic, onion, parsley, bell pepper, olive oil, white whine vinegar, eggs, salt, and pepper."
    },
    {
      "position": 5,
      "text": "Place the sliced tongue in a mixing bowl then mix-in the marinade."
    },
    {
      "position": 6,
      "text": "Refrigerate overnight."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate with or without the marinade (I prefer serving the tongue without the marinade, but it\u2019s your choice)."
    },
    {
      "position": 8,
      "text": "Serve cold as an appetizer. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 30,
