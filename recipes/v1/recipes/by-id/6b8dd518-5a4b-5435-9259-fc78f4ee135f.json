  "id": "6b8dd518-5a4b-5435-9259-fc78f4ee135f",
  "slug": "easy-meatballs",
  "name": "Easy Meatballs Recipe",
  "recipe_type": null,
  "brief_description": "This easy meatballs recipe holds true to its same. It is simple, easy, and delicious. Use it for spaghetti, for a meatball sandwich, or eat it by itself",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Combine all the ingredients in a bowl."
    },
    {
      "position": 3,
      "text": "Gently mix the ingredients either by using your hands or by using a stand mixer. Make sure the the ingredients are well blended."
    },
    {
      "position": 4,
      "text": "Arrange an aluminum foil on a baking tray. Grease the foil using a cooking spray."
    },
    {
      "position": 5,
      "text": "Scoop a small portion of the mixture and mold it into a ball-shaped figure. Arrange the balls on the greased sheet."
    },
    {
      "position": 6,
      "text": "Place the tray with the meatballs in the oven. Bake for 28 to 35 minutes or until the inside part of the meatballs are fully cooked."
    },
    {
      "position": 7,
      "text": "Remove from the oven and arrange in a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with your favorite sauce."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 28,
  "preparation_time_minutes": 10,
