  "id": "d0509e62-e4c2-57b7-8b9b-c67d23587f69",
  "slug": "pork-guisantes",
  "name": "Pork Guisantes Recipe",
  "recipe_type": "main",
  "brief_description": "Tender pork slices simmered in a rich tomato sauce with green peas and bell peppers, creating a hearty and comforting stew best enjoyed with steamed rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan and pour-in cooking oil"
    },
    {
      "position": 2,
      "text": "Add the pork. Sear until it browns (around 3 to 5 minutes)."
    },
    {
      "position": 3,
      "text": "Add garlic and onion. Saute until the onion softens."
    },
    {
      "position": 4,
      "text": "Add the soy sauce, tomato sauce, and beef broth. Simmer until the pork gets tender (usually 30 to 45 minutes)"
    },
    {
      "position": 5,
      "text": "Add the red bell pepper and green peas. Continue cooking for 3 minutes."
    },
    {
      "position": 6,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
