  "id": "0f51af63-2226-5662-aebf-96f611ca32f0",
  "slug": "sticky-asian-fried-chicken-wings",
  "name": "Sticky Asian Fried Chicken Wings",
  "recipe_type": "appetizer",
  "brief_description": "Sticky Asian Fried Chicken Wings makes a delicious appetizer; this can also be eaten as a main dish with fried rice. Contrary to most people think, making your own Sticky Asian Fried Chicken Wings is quick and easy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and ground black pepper all over the chicken wings. Let it stand for 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a deep cooking pot."
    },
    {
      "position": 3,
      "text": "Dredge the chicken wings in cornstarch. Deep fry for 8 to 10 minutes or until the chicken is cooked and the texture becomes crisp. Place the chicken in a plate lined with paper towels."
    },
    {
      "position": 4,
      "text": "Meanwhile, make the glaze by heating a wok or wide pan."
    },
    {
      "position": 5,
      "text": "Pour-in water, honey, ketchup, ginger, garlic, sesame oil, cooking wine. Stir to mix well. Let boil."
    },
    {
      "position": 6,
      "text": "Add the soy sauce and cornstarch mixture. Stir."
    },
    {
      "position": 7,
      "text": "Once the mixture becomes thick, add the fried chicken wings. Toss until the wings are coated."
    },
    {
      "position": 8,
      "text": "Sprinkle toasted sesame seeds and chopped scallions."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
