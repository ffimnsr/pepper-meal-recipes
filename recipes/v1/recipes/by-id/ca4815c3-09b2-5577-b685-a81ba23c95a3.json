  "id": "ca4815c3-09b2-5577-b685-a81ba23c95a3",
  "slug": "sinabawang-corned-beef-recipe",
  "name": "Sinabawang Corned Beef",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Sinabawang Corned Beef. It can also be referred to as soupy corned beef.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onion until the texture gets soft"
    },
    {
      "position": 3,
      "text": "Add the corned beef. Stir and continue to cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Slide the potato into the pan. Cook for 5 minutes while stirring once in a while."
    },
    {
      "position": 5,
      "text": "Pour water. Let boil. Adjust the heat to low and then continue cooking until the liquid reduces to half."
    },
    {
      "position": 6,
      "text": "Stir-in half the parsley. Note: you can add more water if you want your dish to be soupy."
    },
    {
      "position": 7,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Top with remaining parsley."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
