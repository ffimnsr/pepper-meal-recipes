  "id": "5bfb7d2a-90a2-5b98-b12a-5f9dc0444b61",
  "slug": "shared-recipe-maja-blanca",
  "name": "Maja Blanca",
  "recipe_type": "dessert",
  "brief_description": "This Filipino sweet / dessert is super easy and no baking required.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place cornstarch, corn kernels, coconut milk, evaporated milk, and sugar in a medium saucepan and blend well with a whisk until all lumps are gone. Turn the heat to medium-low and bring to a boil, stirring constantly to prevent lumps. You must continue stirring or the bottom will burn and lump up. Stir for 5 to 7 minutes until you reach a firm pudding consistency."
    },
    {
      "position": 2,
      "text": "Pour the hot mixture into a prepared dish and add the crushed peanuts or raisins. If you like both, you can add both."
    },
    {
      "position": 3,
      "text": "Cool completely and cover. Place in the refrigerator if you like it cold, or you can leave it at room temperature (covered) for a day or two."
    },
    {
      "position": 4,
      "text": "Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 10,
