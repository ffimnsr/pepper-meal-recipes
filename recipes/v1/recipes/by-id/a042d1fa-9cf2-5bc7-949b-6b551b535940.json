  "id": "a042d1fa-9cf2-5bc7-949b-6b551b535940",
  "slug": "pancit-bato-guisado",
  "name": "Pancit Bato Guisado",
  "recipe_type": null,
  "brief_description": "Camarines Sur, Bicol Pancit Recipe",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot or deep pan."
    },
    {
      "position": 2,
      "text": "Once the oil is hot, saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the sliced pork. Cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in the soy sauce, fish sauce, and chicken broth. Let boil. Simmer covered for 20 minutes. Add water if needed."
    },
    {
      "position": 5,
      "text": "Add the ground black pepper. Stir."
    },
    {
      "position": 6,
      "text": "Put-in the shrimp, snap peas, and carrots. Cook for a minute."
    },
    {
      "position": 7,
      "text": "Add the cabbage. Cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Put-in the noodles (pancit bato). Stir and cook until all the liquid is absorbed. The noodles should be soft . Otherwise, add a little water to soften the noodles."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
