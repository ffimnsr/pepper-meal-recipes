  "id": "20763a42-ab87-553e-8e6c-bc01e66c46a5",
  "slug": "pork-nilaga-recipe",
  "name": "Pork Nilaga Recipe",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Pork Nilaga. It is a type of soup in clear broth.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add onion and whole peppercorn. Continue to boil until the onion becomes tender."
    },
    {
      "position": 3,
      "text": "Put the pork belly into the cooking pot. Let the water re-boil."
    },
    {
      "position": 4,
      "text": "Add the pork cube. Stir. Cover the pot and continue to cook in low heat for 45 to 60 minutes or until the pork gets tender."
    },
    {
      "position": 5,
      "text": "Add potato and saba banana. Cook for 5 to 7 minutes."
    },
    {
      "position": 6,
      "text": "Add the fish sauce and pechay or bok choy. Stir. Cook for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
