  "id": "89db8cb8-94eb-5c85-a229-8eba5d450a13",
  "slug": "easy-kilawing-kambing",
  "name": "Kilawing Kambing",
  "recipe_type": "appetizer",
  "brief_description": "Boiled goat skin soaked in vinegar with spices",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add the crushed ginger and goat skin. Continue boiling for 1 hour or until the skin tenderizes. Remove the skin from the pot and let it cool down."
    },
    {
      "position": 2,
      "text": "Chop the skin into small pieces. Set aside."
    },
    {
      "position": 3,
      "text": "In a large bowl, combine vinegar and sugar. Mix well until the sugar gets diluted. Add fish sauce, minced ginger, onion, chili pepper, and ground black pepper. Stir."
    },
    {
      "position": 4,
      "text": "Put the chopped goat skin into the same bowl and then add onion powder and Knorr Liquid seasoning. Mix until all the ingredients are well blended."
    },
    {
      "position": 5,
      "text": "Cover the bowl and refrigerate for at least 1 hour before serving."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
