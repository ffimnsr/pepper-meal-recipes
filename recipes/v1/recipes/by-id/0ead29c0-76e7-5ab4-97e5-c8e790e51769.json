  "id": "0ead29c0-76e7-5ab4-97e5-c8e790e51769",
  "slug": "how-to-make-pork-tocino",
  "name": "Homemade Pork Tocino",
  "recipe_type": "dessert",
  "brief_description": "Sweet cured red pork is a Filipino favorite. This is a popular breakfast dish served with fried rice and eggs. This recipe shows you how to make tocino at home.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Slice the pork ham to about \u00bc inch thickness"
    },
    {
      "position": 2,
      "text": "Dissolve the sodium phosphate in 5 tablespoons of water."
    },
    {
      "position": 3,
      "text": "Except for the meat, combine all ingredients in a large bowl and mix well"
    },
    {
      "position": 4,
      "text": "Apply the combined mixture to the meat by rubbing. Make sure that the mixture is evenly distributed across the meat"
    },
    {
      "position": 5,
      "text": "Place the mixed ingredients in a covered container"
    },
    {
      "position": 6,
      "text": "Store the covered container (with meat and mixture) in room temperature for 14 hours. It may also be refrigerated but would take at least 3.5 days to complete."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
