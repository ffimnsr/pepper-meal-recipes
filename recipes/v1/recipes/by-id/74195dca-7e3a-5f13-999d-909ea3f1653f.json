  "schema_version": 1,
  "id": "74195dca-7e3a-5f13-999d-909ea3f1653f",
  "slug": "pinoy-breakfast-omelet-and-bacon-garlic-fried-rice",
  "name": "Pinoy Breakfast Omelet and Bacon Garlic Fried Rice",
  "recipe_type": "breakfast",
  "brief_description": "Filipino breakfast omelet recipe and garlic fried rice (sinangag na kanin) with bacon",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make the fried rice by searing the bacon until the fat gets extracted and the bacon becomes crispy. Note: You will only need around 3 tablespoons of bacon fat. Remove the excess fat for later use."
    },
    {
      "position": 2,
      "text": "Once the bacon gets crispy, add the minced garlic. Cook until it starts to brown."
    },
    {
      "position": 3,
      "text": "Put the rice into the pan (using leftover rice is ideal for this recipe). Stir-fry for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add Knorr Liquid Seasoning, salt, and ground black pepper, and green onions. Toss and cook for 2 minutes. Transfer to a serving plate. Set aside."
    },
    {
      "position": 5,
      "text": "Make the breakfast omelet by heating 3 tablespoons of cooking oil in a pan. Saute the onion until tender. Remove and set aside."
    },
    {
      "position": 6,
      "text": "Using the same pan with remaining oil, arrange the sliced tomatoes in a way that it covers the pan."
    },
    {
      "position": 7,
      "text": "Add the butter. Let it melt. Cook the tomato for 1 minute."
    },
    {
      "position": 8,
      "text": "Add green onions and put the sauteed onion back into the pan while distributing it evenly."
    },
    {
      "position": 9,
      "text": "Beat the eggs and add Knorr Liquid Seasoning. Pour the mixture over the onions. Top with grated cheese."
    },
    {
      "position": 10,
      "text": "Cover the pan. Adjust the heat to the lowest setting. Continue cooking until the eggs get stiff and the cheese is completely melted. Transfer to a serving plate. Serve with fried rice for breakfast."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
