  "id": "2313b327-67f4-5efc-82b4-8e9a3b7ee224",
  "slug": "fish-sinigang",
  "name": "Fish Sinigang",
  "recipe_type": "soup",
  "brief_description": "This is a Filipino fish soup with vegetables cooked in sour broth.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the fish as needed. Sprinkle salt all over the fish slices and then rub all over. Let it stay for at least 15 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Fry the fish slices until golden brown. Turn it over and perform the same step on the opposite side. Remove fish from the pan. Place in a clean plate. Set aside."
    },
    {
      "position": 3,
      "text": "Boil water in a large cooking pot. Add tomato, onion, and radish. Continue boiling for 5 minutes."
    },
    {
      "position": 4,
      "text": "Add Knorr Sinigang sa Sampaloc Mix. Stir."
    },
    {
      "position": 5,
      "text": "Put the fried fish slices into the pot. Let the liquid boil. Adjust the heat between low to medium. Continue boiling for 7 minutes."
    },
    {
      "position": 6,
      "text": "Add eggplant and long green peppers. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add okra. Cook for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper and fish sauce."
    },
    {
      "position": 9,
      "text": "Put the fresh spinach into the pot. Cook for 1 to 2 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve warm. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
