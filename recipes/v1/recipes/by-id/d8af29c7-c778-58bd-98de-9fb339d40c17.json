  "id": "d8af29c7-c778-58bd-98de-9fb339d40c17",
  "slug": "sinabawang-isda-at-gulay",
  "name": "Sinabawang Isda at Gulay",
  "recipe_type": "dessert",
  "brief_description": "Sinabawang Isda at Gulay is a simple dish composed of mahi-mahi fillets and fresh sweet potato tops (known as talbos ng kamote in Filipino).",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pan.Let boil."
    },
    {
      "position": 2,
      "text": "Add the tomatoes, ginger, and onion. Cover and boil for 5 to 8 minutes."
    },
    {
      "position": 3,
      "text": "Add the fresh mahi-mahi. Cover and cook for 8 to 10 minutes in medium heat."
    },
    {
      "position": 4,
      "text": "Stir-in the salt and add the kamote tops. Cover and cook for 1 to 2 minutes."
    },
    {
      "position": 5,
      "text": "Transfer to a serving bowl. Serve with warm white rice."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 2,
