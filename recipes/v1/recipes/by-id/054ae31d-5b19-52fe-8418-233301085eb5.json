  "id": "054ae31d-5b19-52fe-8418-233301085eb5",
  "slug": "how-to-make-marinara-sauce",
  "name": "Marinara Sauce Recipe",
  "recipe_type": null,
  "brief_description": "This Marinara Sauce Recipe is best for pasta and bread sticks. Learn how to make this through our tried and tested procedure.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in olive oil."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onions."
    },
    {
      "position": 3,
      "text": "When the onions gets soft, add crushed tomatoes and tomato sauce and let boil."
    },
    {
      "position": 4,
      "text": "Put-in dried oregano, parsley, chili, bay leaves, and parmesan cheese. Stir."
    },
    {
      "position": 5,
      "text": "Reduce heat to low and simmer for 3 minutes or until the mixture thickens."
    },
    {
      "position": 6,
      "text": "Turn-off heat and let the marinara sauce cool down."
    },
    {
      "position": 7,
      "text": "Transfer to a container and store in the fridge or cook as an ingredient, right away."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
