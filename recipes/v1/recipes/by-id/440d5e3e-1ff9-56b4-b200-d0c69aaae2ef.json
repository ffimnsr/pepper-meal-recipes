  "schema_version": 1,
  "id": "440d5e3e-1ff9-56b4-b200-d0c69aaae2ef",
  "slug": "pancit-batil-patung-recipe",
  "name": "Pancit Batil Patung Recipe",
  "recipe_type": null,
  "brief_description": "Pancit Batil Patung is a popular noodle dish in Tuguegarao City, Cagayan. It is composed of two parts: the noodles with toppings, and the sauce",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the stock (or batil) by boiling water in a cooking pot. Add the beef bones. Let boil for 5 minutes."
    },
    {
      "position": 2,
      "text": "Hold the chopped celery, carrot, and onion together using a cheese cloth and secure using a kithen thread. This will be the mirepoix. Add the mirepoix in the cooking pot and let boil."
    },
    {
      "position": 3,
      "text": "Add the beef cube. Continue to boil in low heat for 3 hours or until the beef gets tender. You may add more water if needed. Once the stock is ready, set aside."
    },
    {
      "position": 4,
      "text": "Heat the cooking oil in a wide pan or wok. Saute the onion until soft."
    },
    {
      "position": 5,
      "text": "Add the minced beef. Saute for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Stir-in the sliced liver. Saute for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add the mung bean sprouts, green onion, cabbage, and carrots. Continue to saute for 2 to 3 minutes."
    },
    {
      "position": 8,
      "text": "Scoop-in 4 to 5 cups of beef stock. Let boil."
    },
    {
      "position": 9,
      "text": "Push the meat and vegetables on one side of the pan. Arrange the Miki noodles on the other side. Toss the noodles while cooking. Add soy sauce and ground black pepper. cook for 2 to 3 minutes."
    },
    {
      "position": 10,
      "text": "Push the noodles on one side to create an opening. Crack one egg and gently let it slide into the broth. Poach until cooked. Remove the poached egg and set aside."
    },
    {
      "position": 11,
      "text": "Remove the noodles from the pan and arrange in a plate."
    },
    {
      "position": 12,
      "text": "Scoop out the remaining stock and place in a small sauce pan. Turn off the heat and transfer the cooked meat and vegetables in a clean plate. Set aside."
    },
    {
      "position": 13,
      "text": "Meanwhile, heat the saucepan with the stock from the pan. Once it starts to boil, crack a piece of egg and add it to the pot. Quickly stir and continue to cook while constantly stirring for 1 to 2 minutes or until an egg drop soup consistency is formed. Transfer to a bowl."
    },
    {
      "position": 14,
      "text": "Start to assemble the Pancit Batil Patung by topping the miki noodles with poached egg. Add the saut\u00e9ed meat and vegetables over the egg and top with lechon carajay."
    },
    {
      "position": 15,
      "text": "Serve with a bowl of batil on the side along with a dip that consists of chopped onion, soy sauce, and vinegar."
    },
    {
      "position": 16,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 20,
