  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "cb4c10ac-83e7-5652-a2f0-f4dce5472f9d",
  "slug": "beef-pho-noodle-soup",
  "name": "Beef Pho Noodle Soup",
  "recipe_type": "soup",
  "brief_description": "I personally love this Beef Pho Noodle Soup Recipe. I think that this is very comforting and full of fresh flavors. I highly recommend this to everyone.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the noodles according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Preheat the oven to 450 degrees Fahrenheit."
    },
    {
      "position": 3,
      "text": "Arrange the bones in a baking tray. Cover with aluminum foil. Roast in the oven for 25 minutes."
    },
    {
      "position": 4,
      "text": "Put the onion and ginger in the oven. Remove the foil from the bones. Continue to roast for 20 minutes."
    },
    {
      "position": 5,
      "text": "Meanwhile, boil the water in large cooking pot."
    },
    {
      "position": 6,
      "text": "Once the bones, onion, and ginger are ready, add them in the boiling water. Let it boil for 12 minutes in medium to high heat. This is the part where scum from the meat will float."
    },
    {
      "position": 7,
      "text": "Scrape the scum floating on the beef stock. Reduce the heat to a simmer."
    },
    {
      "position": 8,
      "text": "Meanwhile, heat a saute pan. When the saute pan gets hot. Put in the cinnamon, fennel, clove, coriander, star anise, and cardamom. Roast in the pan while gently shaking the pan for 5 to 6 minutes. Make sure that you do not over roast the spices as it will taste bitter, so reduce the time as necessary."
    },
    {
      "position": 9,
      "text": "Add the roasted spices on the cooking pot where the bones are in. Continue to simmer for 2 to 3 hours. Add more water if needed."
    },
    {
      "position": 10,
      "text": "Add some fish sauce to taste. Stir."
    },
    {
      "position": 11,
      "text": "Arrange the noodles and sliced sirloin (raw) in a bowl. Pour in the beef broth. (Note: the hot broth will cook the thinly sliced sirloin). Top with cilantro and jalapeno. Add some hoisin sauce and Sriracha sauce to taste (and additional fish sauce as needed)."
    },
    {
      "position": 12,
      "text": "Serve with lime wedges. Serve!"
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 10,
