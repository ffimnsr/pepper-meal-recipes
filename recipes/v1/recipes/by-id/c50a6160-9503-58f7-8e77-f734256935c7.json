  "id": "c50a6160-9503-58f7-8e77-f734256935c7",
  "slug": "bagnet-pancit-canton",
  "name": "Bagnet Pancit Canton",
  "recipe_type": null,
  "brief_description": "Egg noodles with shrimp and crispy pork",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the egg noodles by boiling 6 cups of water in a cooking pot. Add Knorr Pork Cube. Stir until diluted. Put the egg noodles into the pot and toss. Continue cooking until the noodles are soft but not mushy. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a clean pot. Saut\u00e9 onion and garlic."
    },
    {
      "position": 3,
      "text": "Once the onion softens, add mushrooms, carrot, cabbage, snow peas, bell peppers and parsley. Cook for 30 seconds."
    },
    {
      "position": 4,
      "text": "Add shrimp. Toss and cook until the shrimp turns orange in color."
    },
    {
      "position": 5,
      "text": "Add Napa cabbage, soy sauce, oyster sauce, and \u00bc cup water. Toss and cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Put the egg noodles back into the pot. Toss until all the ingredients are well blended."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and top with bagnet slices."
    },
    {
      "position": 8,
      "text": "Serve warm. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
