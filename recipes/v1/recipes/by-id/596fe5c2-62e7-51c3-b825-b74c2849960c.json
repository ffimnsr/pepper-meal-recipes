  "id": "596fe5c2-62e7-51c3-b825-b74c2849960c",
  "slug": "spaghetti-with-meatballs",
  "name": "Spaghetti with Meatballs",
  "recipe_type": null,
  "brief_description": "Spaghetti with Meatballs sounds like a perfect idea for lunch or dinner. Preparing this dish is simple and does not involve complex tasks. Save time by preparing a large batch of marinara sauce and meatballs and keeping them in the freezer until needed.",
  "cuisine": "Italian-American",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the spaghetti noodles according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the homemade marinara sauce in a saucepan. If you are using the bottled spaghetti sauce purchased from the grocery store, you can saut\u00e9 1 small onion (minced) before adding the sauce to make it more flavorful."
    },
    {
      "position": 3,
      "text": "Add the meatballs. Let boil and continue to cook over low heat for 10 to 15 minutes. Add salt and pepper to taste."
    },
    {
      "position": 4,
      "text": "Arrange the spaghetti noodles on a plate. Top with spaghetti sauce and meatballs. Sprinkle some Parmesan cheese on top."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
