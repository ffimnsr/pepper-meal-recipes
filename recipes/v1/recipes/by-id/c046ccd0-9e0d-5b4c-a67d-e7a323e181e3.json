  "id": "c046ccd0-9e0d-5b4c-a67d-e7a323e181e3",
  "slug": "fried-bangus-sinigang-recipe",
  "name": "Fried Bangus Sinigang sa Miso",
  "recipe_type": "soup",
  "brief_description": "Sinigang sa miso na Bangus is a popular sour soup in the Philippines. This is prepared using fresh slices of milkfish which is locally known as bangus.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Wash the milkfish and then let the water drip. Pat dry using a paper towel."
    },
    {
      "position": 2,
      "text": "Slice the milkfish diagonally crosswise about one and a quarter inch thick."
    },
    {
      "position": 3,
      "text": "Rub the seasalt all over the sliced fish. Let it stay for 15 minutes."
    },
    {
      "position": 4,
      "text": "Meanwhile, heat the cooking oil in a pan."
    },
    {
      "position": 5,
      "text": "When the oil becomes hot, pan fry the milkfish for about 3 to 4 minutes per side. There will be lots of splatter action so make sure that you cover the pan while frying."
    },
    {
      "position": 6,
      "text": "After the fish has been fried, scoop about 2 tablespoons of cooking oil from the frying pan. Pour it in a clean cooking pot and then heat."
    },
    {
      "position": 7,
      "text": "Saute the garlic, onion, and tomatoes until the tomatoes are soft."
    },
    {
      "position": 8,
      "text": "Put-in the ground black pepper and miso paste. Stir and then pour-in the water. Let boil."
    },
    {
      "position": 9,
      "text": "Add the sinigang mix and then put-in the fried milkfish. Simmer for 15 to 18 minutes."
    },
    {
      "position": 10,
      "text": "Pour-in the fish sauce. Stir and then add the spinach."
    },
    {
      "position": 11,
      "text": "Cover and then turn the heat off. Do not remove the cover for at least 8 minutes to cook the spinach."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
