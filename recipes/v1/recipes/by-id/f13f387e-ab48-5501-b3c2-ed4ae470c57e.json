  "id": "f13f387e-ab48-5501-b3c2-ed4ae470c57e",
  "slug": "shrimp-scampi-with-linguine",
  "name": "Shrimp Scampi with Linguine",
  "recipe_type": null,
  "brief_description": "This is a recipe for Shrimp Scampi with Linguine",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine olive oil and minced garlic in a pot. Heat the oil and then continue to cook until the moment that the garlic starts to turn light brown."
    },
    {
      "position": 2,
      "text": "Add the butter and let it melt."
    },
    {
      "position": 3,
      "text": "Pour the moscato, chicken broth, and lemon juice into the pot. Let boil. Cook until the liquid reduces to half."
    },
    {
      "position": 4,
      "text": "Add the shrimp, red pepper flakes, salt, parsley, and ground black pepper. Stir. Cover and then cook for 4 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Arrange the linguine in a plate. Top with shrimp scampi."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
