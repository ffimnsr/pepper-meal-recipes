  "id": "56fa8fa4-908d-55e6-a938-8a0305c42b05",
  "slug": "galbi",
  "name": "Galbi Recipe",
  "recipe_type": "main",
  "brief_description": "Galbi (or Kalbi) is a classic Korean grilled beef dish featuring marinated beef short ribs sliced thin across the bone. The meat is marinated in a sweet and savory sauce, then grilled until caramelized and tender.",
  "cuisine": "Korean",
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, whisk together the soy sauce, garlic, brown sugar, white sugar, rice wine, sesame oil, and chili powder until the sugars are completely dissolved."
    },
    {
      "position": 2,
      "text": "Place the sliced beef short ribs in a large resealable plastic bag."
    },
    {
      "position": 3,
      "text": "Pour the marinade over the beef, seal the bag, and massage gently to coat evenly. Remove as much air as possible from the bag before sealing completely."
    },
    {
      "position": 4,
      "text": "Refrigerate for at least 4 hours, preferably overnight (8-12 hours), to allow the flavors to penetrate the meat."
    },
    {
      "position": 5,
      "text": "Preheat the grill to medium-high heat. Grill the short ribs for 4 to 8 minutes per side, depending on heat intensity, basting occasionally with the remaining marinade until nicely charred and cooked to desired doneness."
    },
    {
      "position": 6,
      "text": "Transfer to a serving platter and let rest for 2 minutes before serving."
    },
    {
      "position": 7,
      "text": "Serve hot with steamed rice and Korean side dishes (banchan). Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 16,
  "preparation_time_minutes": 180,
