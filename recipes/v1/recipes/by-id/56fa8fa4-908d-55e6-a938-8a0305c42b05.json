  "id": "56fa8fa4-908d-55e6-a938-8a0305c42b05",
  "slug": "galbi",
  "name": "Galbi Recipe",
  "recipe_type": "main",
  "brief_description": "Galbi or Kalbi is a grilled Korean beef dish. This makes use of beef short ribs. Get the details of the recipe here. This is beef recipe is simple to make.",
  "cuisine": "Korean",
  "instructions": [
    {
      "position": 1,
      "text": "Make the marinade by combining soy sauce, garlic, sugars, rice wine, sesame oil, and chili powder in a bowl. Stir."
    },
    {
      "position": 2,
      "text": "Place the beef short ribs in a heavy duty freezer bag and pour in the marinade."
    },
    {
      "position": 3,
      "text": "Secure the freezer bag by sealing the edges. Make sure to release all the air inside the bag before closing."
    },
    {
      "position": 4,
      "text": "Place the bag in the fridge and marinate overnight."
    },
    {
      "position": 5,
      "text": "Grill the short ribs for about 4 to 8 minutes per side (depending on the heat) while basting with the remaining marinade."
    },
    {
      "position": 6,
      "text": "Place in a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 16,
