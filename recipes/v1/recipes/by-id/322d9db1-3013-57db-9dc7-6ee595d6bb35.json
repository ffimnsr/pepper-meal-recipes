  "id": "322d9db1-3013-57db-9dc7-6ee595d6bb35",
  "slug": "baked-turkey-breast-recipe",
  "name": "Baked Turkey Breast",
  "recipe_type": null,
  "brief_description": "This is a recipe for baked turkey breast",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 degrees Fahrenheit"
    },
    {
      "position": 2,
      "text": "In a medium bowl, combine butter, garlic, rosemary, thyme, lime juice, and salt. Mix well."
    },
    {
      "position": 3,
      "text": "Loosen the skin in such a way that you can insert your fingers in between the skin and meat. Insert about half of the mixture in the space that you created. Make sure that you covered the whole turkey breast."
    },
    {
      "position": 4,
      "text": "Place the turkey breast in a roasting pan. Roast for 45 minutes."
    },
    {
      "position": 5,
      "text": "Combine white wine with the remaining butter mixture. Baste the turkey breast and then put back in the oven again to roast for another hour."
    },
    {
      "position": 6,
      "text": "Remove from the oven and let rest for 10 minutes. Note: you can use the drippings to make the gravy."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Do a couple or more thin slices."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
