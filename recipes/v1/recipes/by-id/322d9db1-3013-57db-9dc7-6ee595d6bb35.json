{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "322d9db1-3013-57db-9dc7-6ee595d6bb35",
  "slug": "baked-turkey-breast-recipe",
  "name": "Baked Turkey Breast",
  "recipe_type": "main",
  "brief_description": "Juicy turkey breast roasted with herb butter, garlic, rosemary, thyme, and white wine. Perfect for holiday meals or special Sunday dinners.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350\u00b0F (175\u00b0C)."
    },
    {
      "position": 2,
      "text": "In a medium bowl, combine butter, garlic, rosemary, thyme, lime juice, and salt. Mix well to form a compound butter."
    },
    {
      "position": 3,
      "text": "Gently loosen the skin from the turkey breast meat using your fingers, creating a pocket. Spread half of the butter mixture evenly under the skin, covering the entire breast."
    },
    {
      "position": 4,
      "text": "Place the turkey breast in a roasting pan. Roast for 45 minutes."
    },
    {
      "position": 5,
      "text": "Combine white wine with the remaining butter mixture. Baste the turkey breast with the wine mixture and return to the oven. Roast for an additional hour (60 minutes) until the internal temperature reaches 165\u00b0F (74\u00b0C)."
    },
    {
      "position": 6,
      "text": "Remove from the oven and let rest for 10 minutes before slicing. Reserve the drippings for gravy if desired."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate and slice thinly against the grain."
    },
    {
      "position": 8,
      "text": "Serve immediately. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 105,
  "preparation_time_minutes": 10,
