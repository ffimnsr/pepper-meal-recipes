  "id": "dd487ffb-0ac1-5702-8321-9b0904994f77",
  "slug": "ginataang-alimasag-with-sitaw-at-kalabasa",
  "name": "Ginataang Alimasag with Sitaw at Kalabasa",
  "recipe_type": "main",
  "brief_description": "Blue crabs cooked in coconut milk with snake beans and calabaza squash.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute garlic, onion, and ginger until onion turns translucent."
    },
    {
      "position": 3,
      "text": "Combine water and Knorr Ginataang Gulay Mix. Stir until well blended. Pour mixture into the pan. Let boil."
    },
    {
      "position": 4,
      "text": "Add crab and kalabasa. Cover and boil for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add snake beans. Continue cooking for 8 minutes."
    },
    {
      "position": 6,
      "text": "Season with salt and pepper if desired. Note: this is an optional step."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 4,
  "rest_time_minutes": null,
