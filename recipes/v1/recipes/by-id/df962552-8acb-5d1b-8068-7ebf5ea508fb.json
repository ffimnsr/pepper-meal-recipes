{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "df962552-8acb-5d1b-8068-7ebf5ea508fb",
  "slug": "inihaw-na-liempo-at-pusit",
  "name": "Inihaw na Liempo at Pusit",
  "recipe_type": "main",
  "brief_description": "Grilled pork belly, squid, and other seafood.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork belly and crushed pineapple in a resealable bag. Refrigerate overnight. Note: this will add flavor to the meat and will help tenderize it. Separate the crushed pineapple afterwards and discard it."
    },
    {
      "position": 2,
      "text": "Combine the marinade/basting sauce ingredients in a bowl. Pour three quarters of the mixture in the resealable bag with the pork belly. Marinate for at least 3 hours."
    },
    {
      "position": 3,
      "text": "Prepare the squid by peeling off its skin. Combine it with sugar, baking soda, and juice of half of a lemon. Mix well and let it stay for 1 hour. Note: this will tenderize the squid. Rinse with running water."
    },
    {
      "position": 4,
      "text": "Make the squid filling by combining tomato, onion, ground black pepper, and Knorr Liquid Seasoning. Mix well. Stuff the mixture inside the squid and secure the head using toothpicks."
    },
    {
      "position": 5,
      "text": "Heat-up the grill and then start grilling the pork belly while brushing with basting sauce after every turn. Grill-up the squid. Remember not to overcook it as it can get tough."
    },
    {
      "position": 6,
      "text": "Serve with spicy vinegar or your favorite dipping sauce. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 60,
  "rest_time_minutes": null,
  "difficulty": "hard",
