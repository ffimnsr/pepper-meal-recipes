  "id": "1eaa8801-2b1f-56ba-8693-57afafc45771",
  "slug": "tuna-frittata-recipe",
  "name": "Tuna Frittata Recipe",
  "recipe_type": "breakfast",
  "brief_description": "Tuna Frittata is a baked egg dish. This is composed of canned tuna, beaten eggs, and cheese. I love to have his for breakfast along with toast or muffins.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Grease a 9\" inch pie dish by pouring-over cooking oil and rubbing it on the surface."
    },
    {
      "position": 2,
      "text": "Combine eggs, tuna, salt, and pepper. Mix well."
    },
    {
      "position": 3,
      "text": "Pour-mixture on the pie dish."
    },
    {
      "position": 4,
      "text": "Preheat oven to 370 degrees Fahrenheit"
    },
    {
      "position": 5,
      "text": "Bake for 12 to 14 minutes."
    },
    {
      "position": 6,
      "text": "Sprinkle the cheese on top. Set the oven to broil and then continue broiling for 3 minutes."
    },
    {
      "position": 7,
      "text": "Serve with toasted bread. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 14,
  "preparation_time_minutes": 5,
