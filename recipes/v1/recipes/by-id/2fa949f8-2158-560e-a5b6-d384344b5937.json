  "slug": "shrimp-with-butter-and-taba-ng-talangka-recipe-bisita-kusina-episode-2",
  "name": "Shrimp with Butter and Taba ng Talangka Recipe",
  "recipe_type": "main",
  "brief_description": "Filipino-style shrimp saut\u00e9ed in butter with crab fat (taba ng talangka), calamansi, and vinegar.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter or margarine in a pan."
    },
    {
      "position": 2,
      "text": "Add shrimp. Continue to cook for 3 to 5 minutes or until the shrimp turns orange."
    },
    {
      "position": 3,
      "text": "Add garlic. Stir fry for 30 seconds."
    },
    {
      "position": 4,
      "text": "Put the salt into the pan. Stir."
    },
    {
      "position": 5,
      "text": "Season with cracked peppercorn (or ground black pepper)."
    },
    {
      "position": 6,
      "text": "Add the crab fat (taba ng talangka). Stir. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Pour calamansi and vinegar. Stir. Cook for 3 to 4 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
