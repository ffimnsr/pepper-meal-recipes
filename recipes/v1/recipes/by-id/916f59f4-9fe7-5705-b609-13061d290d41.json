  "id": "916f59f4-9fe7-5705-b609-13061d290d41",
  "slug": "bibingkang-malagkit-recipe",
  "name": "Bibingkang Malagkit Recipe",
  "recipe_type": "dessert",
  "brief_description": "Bibingkang Malagkit is a Filipino dessert made with sweet rice, coconut milk and cream, and brown sugar and baked in a pan with a layer of banana leaf.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine glutinous rice and 4 cups of coconut milk in a cooking pot. Heat and let boil, then reduce heat and cook while stirring until the texture thickens. This process can range from 18 to 20 minutes, or even more."
    },
    {
      "position": 2,
      "text": "Add 1 1/4 cups of sugar and salt. Continuously stir and cook for 10 more minutes or until the rice is completely done. The texture should be very sticky."
    },
    {
      "position": 3,
      "text": "Meanwhile, arrange banana leaves in a 9 by 13 inches baking pan. Transfer the cooked sticky rice to the baking pan. Set aside."
    },
    {
      "position": 4,
      "text": "Make the topping by heating a sauce pan and combining 2 cups of coconut cream and remaining 1 cup of brown sugar.Let boil and simmer while stirring once in a while until the texture thickens."
    },
    {
      "position": 5,
      "text": "Preheat oven to 400 degrees Fahrenheit."
    },
    {
      "position": 6,
      "text": "Spread the topping equally over the cooked sticky rice. Bake for 12 to 18 minutes or until the topping becomes a little firm."
    },
    {
      "position": 7,
      "text": "Remove from the oven and let cool."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
