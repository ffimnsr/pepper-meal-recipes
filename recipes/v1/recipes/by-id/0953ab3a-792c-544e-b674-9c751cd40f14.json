  "id": "0953ab3a-792c-544e-b674-9c751cd40f14",
  "slug": "creamy-tuyo-pesto-pasta-recipe",
  "name": "Creamy Tuyo Pesto",
  "recipe_type": "main",
  "brief_description": "A Filipino-Italian fusion pasta dish featuring salty tuyo (dried herring) flakes in a rich, creamy pesto sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pan then pour-in water. Let boil."
    },
    {
      "position": 2,
      "text": "Cook the spaghetti noodles according to package instructions. Set aside."
    },
    {
      "position": 3,
      "text": "Combine garlic and olive oil in a blender or food processor then blend until finely chopped."
    },
    {
      "position": 4,
      "text": "Add salt, ground black pepper, basil leaves, and half of the parmesan cheese then blend until the texture becomes fine. You may add extra olive oil as needed. Set aside."
    },
    {
      "position": 5,
      "text": "Heat a cooking pot and pour-in water and heavy whipping cream. Stir."
    },
    {
      "position": 6,
      "text": "When the mixture is hot enough, put-in butter and stir until melted."
    },
    {
      "position": 7,
      "text": "Add-in the tuyo flakes and pesto then stir."
    },
    {
      "position": 8,
      "text": "Put-in the remaining parmesan cheese and stir. Simmer until the texture thickens."
    },
    {
      "position": 9,
      "text": "Turn off heat. Top noodles with sauce."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
