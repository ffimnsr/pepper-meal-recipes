  "id": "991f2aa7-f8bc-532e-bc4c-a95a71662219",
  "slug": "porknigang-sinigang-na-baboy-ribs",
  "name": "Porknigang (Sinigang na Baboy)",
  "recipe_type": "soup",
  "brief_description": "Pork baby back ribs soup in sour broth with okra and bok choy.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a large pot. Saute onion and tomato until the layers of the onion starts to separate."
    },
    {
      "position": 2,
      "text": "Add pork spare ribs. Continue saut\u00e9ing until the pork turns light brown in color."
    },
    {
      "position": 3,
      "text": "Pour water. Cover the pot. Let the water boil. Adjust heat to low setting and continue boiling for 30 minutes."
    },
    {
      "position": 4,
      "text": "Add Knorr Sinigang sa Sampaloc with Gabi recipe mix and daikon radish. Stir and cover the pot. Continue cooking until the pork gets tender."
    },
    {
      "position": 5,
      "text": "Add chili pepper, string beans, okra, and eggplant. Cook for 12 minutes."
    },
    {
      "position": 6,
      "text": "Add pechay. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
