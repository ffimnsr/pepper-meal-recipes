  "id": "cb61b8b8-1833-5565-bd9e-7643b064363f",
  "slug": "ground-pork-kaldereta-omelet",
  "name": "Ground Pork Kaldereta Omelet",
  "recipe_type": null,
  "brief_description": "Ground Pork Kaldereta Omelet is an interesting dish that I made from left over Pork Giniling Kaldereta. There will be days wherein you will have left overs.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Crack eggs in a bowl. Whisk using a wire whisk of fork."
    },
    {
      "position": 2,
      "text": "Add the salt, pepper, and onion powder. Continue to whisk until all the ingredients are well blended."
    },
    {
      "position": 3,
      "text": "Add the Pork Giniling Kaldereta. Stir until it is incorporated with the mixture. Set aside"
    },
    {
      "position": 4,
      "text": "Heat the oil in a frying pan. Once the oil gets hot, scoop half of the mixture and pour it on the pan. Cook in medium heat for 3 minutes."
    },
    {
      "position": 5,
      "text": "Using a wide spatula, turn the omelet over. Cook the opposite side for 2 to 3 minutes or until it is done. Do the same steps for the remaining mixture."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with Ketchup."
    },
    {
      "position": 7,
      "text": "Enjoy with toast for breakfast or with white rice for lunch."
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 6,
  "preparation_time_minutes": 5,
