  "id": "5619f170-6570-5b72-a2fd-ef31040d8fc9",
  "slug": "roasted-chicken-quarter-recipe",
  "name": "Roasted Chicken Quarter Recipe",
  "recipe_type": null,
  "brief_description": "Roasted chicken quarter is an easy roasted chicken recipe that anyone can prepare. It only involves a simple marinade mixture and a conventional oven. The result of this recipe is simply awesome.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine lemon juice, thyme, rosemary, parsley, garlic, poultry seasoning, salt, pepper, and olive oil. Mix well"
    },
    {
      "position": 2,
      "text": "Rub the mixture on the chicken quarters. Let stand for 1 hour (place inside the fridge to avoid contamination)."
    },
    {
      "position": 3,
      "text": "Preheat oven to 370 degrees Fahrenheit."
    },
    {
      "position": 4,
      "text": "Arrange the chicken in a roasting pan."
    },
    {
      "position": 5,
      "text": "Roast for 60 to 80 minutes (time will depend on the thickness). Baste with remaining mixture every 20 minutes while roasting."
    },
    {
      "position": 6,
      "text": "Chop into serving pieces."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 60,
