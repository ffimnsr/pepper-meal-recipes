  "id": "4dc1aebc-449f-5eb1-a7e6-59ae4911925f",
  "slug": "ginataang-kalabasa",
  "name": "Ginataang Kalabasa",
  "recipe_type": "main",
  "brief_description": "Squash cooked in coconut milk with the flavor of simmered pork",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the wok and then sear the pork until enough fat renders. Move the pork aside, and saut\u00e9 garlic, onion, and ginger in the pork fat."
    },
    {
      "position": 2,
      "text": "Once the onion softens, pour the coconut milk. Cover and simmer for 40 to 50 minutes."
    },
    {
      "position": 3,
      "text": "Add shrimp paste and water. Let boil."
    },
    {
      "position": 4,
      "text": "Add the kalabasa. Cover the wok. Cook for 8 minutes."
    },
    {
      "position": 5,
      "text": "Put the string beans in. Stir. Continue cooking for 5 minutes."
    },
    {
      "position": 6,
      "text": "Season with Maggi Magic Sarap."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 15,
