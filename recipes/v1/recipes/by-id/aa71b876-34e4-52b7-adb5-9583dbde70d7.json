  "id": "aa71b876-34e4-52b7-adb5-9583dbde70d7",
  "slug": "delicious-oven-baked-potatoes",
  "name": "Delicious Oven Baked Potatoes",
  "recipe_type": null,
  "brief_description": "Your meals will never be boring again. Delicous Oven Baked Potatoes are the answer to your bland lunch and dinner meals.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 450F"
    },
    {
      "position": 2,
      "text": "Get a baking pan; line with foil. Apply cooking oil spray on the aluminum foil."
    },
    {
      "position": 3,
      "text": "Place the potatoes in a deep bowl."
    },
    {
      "position": 4,
      "text": "Add olive oil, garlic salt and rosemary. Toss."
    },
    {
      "position": 5,
      "text": "Line the potatoes in the baking pan with aluminum foil."
    },
    {
      "position": 6,
      "text": "Bake for 40 minutes. Turn the potatoes for the other side to brown."
    },
    {
      "position": 7,
      "text": "Adjust the heat to broil. Broil for an additional 12 minutes."
    }
  ],
