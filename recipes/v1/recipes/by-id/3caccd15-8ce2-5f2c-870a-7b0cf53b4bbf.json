  "schema_version": 1,
  "id": "3caccd15-8ce2-5f2c-870a-7b0cf53b4bbf",
  "slug": "ginisang-munggo-with-tinapa-and-fried-red-snapper",
  "name": "Ginisang Munggo with Tinapa and Fried Red Snapper",
  "recipe_type": null,
  "brief_description": "Ginisang Munggo with Tinapa and Fried Red Snapper was the perfect combination for lunch; all it needed was a cup of warm rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour 4 cups water in a bowl. Add the Mung beans and soak overnight. Discard the water. Set aside."
    },
    {
      "position": 2,
      "text": "Rub salt all over the Red snapper. Heat a frying pan and pour-in 10 tablespoons of cooking oil. Once the oil gets hot, fry both sides of the fish until it turns crispy. Set aside."
    },
    {
      "position": 3,
      "text": "Heat the remaining oil in a pan. Saute onion, garlic, and tomato."
    },
    {
      "position": 4,
      "text": "Add the smoked fish flakes. Cook for a minute."
    },
    {
      "position": 5,
      "text": "Add the soaked Mung beans. Stir fry for 1 to 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in 1 1/2 to 2 cups water. Let boil. Cook low to medium heat until the Mung beans gets very tender to the point that you can mush it easily. You may add more water if needed."
    },
    {
      "position": 7,
      "text": "Add fish sauce, ground black pepper and Malunggay leaves. Continue to cook for 2 to 3 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Place the crisp fried red snapper on the side."
    },
    {
      "position": 9,
      "text": "Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 180,
