  "id": "d0a4a74d-1a33-5254-a5bc-800d24dc5b18",
  "slug": "pinoy-chicken-sopas",
  "name": "Pinoy Chicken Sopas",
  "recipe_type": "soup",
  "brief_description": "Filipino style chicken noodles soup",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a cooking pot. Saut\u00e9 onion, garlic, and celery for 1 minute."
    },
    {
      "position": 2,
      "text": "Add the shredded chicken, hot dogs, and 1 tablespoon of fish sauce. Cook for 1 minute."
    },
    {
      "position": 3,
      "text": "Pour the water and let it boil."
    },
    {
      "position": 4,
      "text": "Add Knorr chicken cube. Cover the cooking pot. Adjust the heat of your stove to the lowest setting. Cook for 10 minutes."
    },
    {
      "position": 5,
      "text": "Add elbow macaroni. Continue cooking for 18 minutes."
    },
    {
      "position": 6,
      "text": "Add cabbage and evaporated milk."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and fish sauce if needed."
    },
    {
      "position": 8,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
