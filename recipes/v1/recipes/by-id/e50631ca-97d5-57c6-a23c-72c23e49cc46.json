  "id": "e50631ca-97d5-57c6-a23c-72c23e49cc46",
  "slug": "lechon-belly-pork-adobo-recipe",
  "name": "Lechon Belly Pork Adobo Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Lechon Belly Pork Adobo Recipe",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Once the onion starts to get translucent and soft, and the garlic turns brown, add the sliced lechon belly. Continue to saute for 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour beef broth. Let boil."
    },
    {
      "position": 5,
      "text": "Add whole peppercorn and dried bay leaves. Cover and cook in low heat for 45 to 50 minutes. Note: add more broth or water if needed."
    },
    {
      "position": 6,
      "text": "Pour vinegar. Let boil."
    },
    {
      "position": 7,
      "text": "Add sugar. Stir. Cook until there is only a little bit of sauce left. Do not let the pork adobo to get dry."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
