  "id": "1ae4fc07-0143-5cb7-8473-0111dfeb468c",
  "slug": "beef-chop-suey",
  "name": "Beef Chop Suey",
  "recipe_type": "main",
  "brief_description": "Stir fried beef with cabbage, carrot, and capsicum.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the sliced beef and all the marinade ingredients in a bowl. After that, mix everything well. Set aside for 12 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, start to partially cook the vegetables. Heat 2 tablespoons of oil in a wide pan. Stir fry the cabbage, snap peas, carrot, and bell pepper for 1 minute. Sprinkle some salt to flavor it and then pour \u00bc cup of beef broth. Cover the pan and let the liquid boil. Continue steaming for 1 minute. Then remove the cover of the pan. Let the remaining liquid evaporate. Set the vegetables aside."
    },
    {
      "position": 3,
      "text": "Heat the remaining oil on the same pan. Once the oil gets hot, stir-fry the marinated beef until the outside part turns light brown."
    },
    {
      "position": 4,
      "text": "Add the minced garlic, white part of the green onion, and sliced onions. Continue to stir-fry until the onion softens."
    },
    {
      "position": 5,
      "text": "Add the stir-fried vegetables. Then toss to distribute the ingredients evenly."
    },
    {
      "position": 6,
      "text": "Pour 1 tablespoon soy sauce and remaining beef broth. Stir and continue cooking until the sauce thickens."
    },
    {
      "position": 7,
      "text": "Season with Maggi Magic Sarap as needed."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Share and enjoy!"
    }
  ],
  "servings": 4,
