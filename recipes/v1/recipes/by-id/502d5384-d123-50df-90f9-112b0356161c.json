  "id": "502d5384-d123-50df-90f9-112b0356161c",
  "slug": "pork-binagoongan-recipe",
  "name": "Pork Binagoongan Recipe",
  "recipe_type": "main",
  "brief_description": "Pork Belly cooked in tomato and shrimp paste with eggplant. This dish is a winner!",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute onion, garlic, and tomato. Once the onion becomes soft, add the pork belly. Cook until the belly turns light brown.&nbsp;"
    },
    {
      "position": 3,
      "text": "Add shrimp paste (bagoong alamang). Stir. Cook for 5 minutes.&nbsp;"
    },
    {
      "position": 4,
      "text": "Pour vinegar. Let the mixture boil. Stir and cook for 2 minutes.&nbsp;"
    },
    {
      "position": 5,
      "text": "Pour the pork stock into the pot. Cover and let boil. Adjust the heat to medium and continue to cook for 40 minutes or until the pork gets tender. Note: add water or pork stock as needed.&nbsp;"
    },
    {
      "position": 6,
      "text": "Add eggplant. Stir. Cover the pot and cook for 3 minutes.&nbsp;"
    },
    {
      "position": 7,
      "text": "Season with sugar and ground black pepper.&nbsp;&nbsp;"
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!&nbsp;"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
