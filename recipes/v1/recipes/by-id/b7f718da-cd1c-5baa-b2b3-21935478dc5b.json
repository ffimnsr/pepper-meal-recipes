  "id": "b7f718da-cd1c-5baa-b2b3-21935478dc5b",
  "slug": "sinabawang-manok-recipe",
  "name": "Sinabawang Manok",
  "recipe_type": "soup",
  "brief_description": "Step-by-step guide on how to make an easy chicken soup",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saut\u00e9 the onion, garlic, ginger, and tomato for 2 minutes."
    },
    {
      "position": 2,
      "text": "Add the chicken. Saut\u00e9 for 3 minutes or until the outer part starts to turn light brown."
    },
    {
      "position": 3,
      "text": "Pour water into the cooking pot. Cover it. Let the water boil."
    },
    {
      "position": 4,
      "text": "Adjust the heat to a simmer. Continue simmering for 20 minutes."
    },
    {
      "position": 5,
      "text": "Add Maggi Magic Chicken Cube and chayote. Cook for 4 minutes. (see notes below)"
    },
    {
      "position": 6,
      "text": "Add the long green beans. Season with fish sauce and ground black pepper. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add the baby spinach. Stir. Cook for 1 minute."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve while its hot."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
