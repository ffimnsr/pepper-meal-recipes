  "id": "42c6bad5-353b-5fdc-a874-cc0aa8fd9bbf",
  "slug": "beef-bicol-express",
  "name": "Beef Bicol Express",
  "recipe_type": null,
  "brief_description": "Beef Bicol Express is the beef version of the popular Bicol express dish. The latter uses pork (usually pork belly) as the main ingredient. I got some gorgeous fresh beef chuck from the supermarket and I decided to consume it for this dish. I was attracted with the nice looking marbled fat. This adds a nice flavor to the meat and maintains moisture",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic, ginger and onion"
    },
    {
      "position": 3,
      "text": "Once the onion becomes soft, add the shrimp paste. Stir."
    },
    {
      "position": 4,
      "text": "Put-in the beef. Cook for 3 to 5 minutes or until medium brown."
    },
    {
      "position": 5,
      "text": "Pour-in the coconut milk. Stir. You can also add some of the pepper, if desired. Bring the mixture to a boil. Simmer for 40 minutes or until the beef is tender. Add water as needed."
    },
    {
      "position": 6,
      "text": "Sprinkle some salt and pepper to taste. Stir. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
