  "id": "fcad61e9-e8ac-50dc-9cb6-1198c891e2c1",
  "slug": "delicious-holiday-dessert-date-bar-food-for-the-gods-recipe",
  "name": "Food for the Gods Recipe",
  "recipe_type": "dessert",
  "brief_description": "Food for the Gods or date bar is a very rich and tasty dessert fit for the holidays. I have no idea as to where the name was derived from until I tasted one. The flavor is really heavenly and you can feel a lot of love in it.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, combine the flour, baking soda, baking powder, and salt then mix well."
    },
    {
      "position": 2,
      "text": "Cream the butter in a separate mixing bowl and add the sugar (white and brown) while continously mixing until texture becomes fluffy."
    },
    {
      "position": 3,
      "text": "Beat-in the eggs on the mixing bowl with butter and sugar then continue mixing until everything is well distributed."
    },
    {
      "position": 4,
      "text": "Gradually add the flour-baking soda-baking powder-salt mixture while continously mixing (don't forget to scrape the sides with a silicon spatula)."
    },
    {
      "position": 5,
      "text": "Put-in the dates and walnuts then mix until well distributed."
    },
    {
      "position": 6,
      "text": "Preheat oven to 350 degrees Fahrenheit"
    },
    {
      "position": 7,
      "text": "Grease the baking pan and pour-in the batter."
    },
    {
      "position": 8,
      "text": "Bake for 10 minutes then pull down the temperature to 300 and continue baking for 35 minutes or until done (you may use the toothpick technique)"
    },
    {
      "position": 9,
      "text": "Remove from the oven and allow to cool down"
    },
    {
      "position": 10,
      "text": "Slice and wrap individually if desired."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
