  "slug": "halabos-na-hipon-recipe",
  "name": "Halabos na Hipon Recipe",
  "recipe_type": null,
  "brief_description": "Halabos na Hipon is one of the simplest shrimp recipe that I know. It is simply cooking shrimp using salt and a little water. However, I added a little twist in this recipe: lemon soda such as 7-Up, Sprite, or Sierra Mist is required instead of water.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a wide pan or wok."
    },
    {
      "position": 2,
      "text": "Once the pot is hot, put-in the shrimp. Gently toss every few seconds."
    },
    {
      "position": 3,
      "text": "Add the salt. Continue to toss for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour-in the lemon soda; stir and continue to cook until the liquid evaporates."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
