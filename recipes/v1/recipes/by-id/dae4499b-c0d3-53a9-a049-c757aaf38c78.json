  "id": "dae4499b-c0d3-53a9-a049-c757aaf38c78",
  "slug": "tuna-salad-sandwich-recipe",
  "name": "Tuna Salad Sandwich Recipe",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for Tuna Salad Sandwich.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Remove the liquid from the canned tuna."
    },
    {
      "position": 2,
      "text": "Combine tuna, cheddar cheese, onion, mayonnaise, pickle relish, sugar, and celery. Mix well."
    },
    {
      "position": 3,
      "text": "Taste the mixture and then add salt and pepper as needed."
    },
    {
      "position": 4,
      "text": "Toast the hamburger buns or loaf slices"
    },
    {
      "position": 5,
      "text": "Arrange the tuna salad in between the buns. You may add vegetables such as sliced tomato and lettuce, if desired. You can also slice the bread in half."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 3,
