{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "42379f83-4dd2-5dc9-a26b-7a33271b382e",
  "slug": "salisbury-steak-with-mashed-potato-knr-bc",
  "name": "Salisbury Steak with Mashed Potato",
  "recipe_type": "main",
  "brief_description": "Delicious and easy-to-make burger patties with brown gravy topped over homemade classic mashed potato. This is a perfect meal for a romantic dinner.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the mashed potato by boiling 6 cups of water in a cooking pot. Add 1 teaspoon salt."
    },
    {
      "position": 2,
      "text": "Put the tomatoes in boiling water and boil for 15 to 20 minutes or until very tender. Remove from the pot. Set aside."
    },
    {
      "position": 3,
      "text": "Melt butter in a sauce pan. Add milk. Stir. Cook until milk starts to boil."
    },
    {
      "position": 4,
      "text": "Mash the potato and then pour the milk and butter mixture. Add Salt and pepper. Mix well. Set aside."
    },
    {
      "position": 5,
      "text": "Make the Salisbury steak by combining the steak ingredient listed above in a bowl, except for oil and butter. Freeze the beef cube and grate using a cheese grater. Mix everything together. Scoop around 4 tablespoons of mixture and roll into a ball. Flatten and place in a clean plate."
    },
    {
      "position": 6,
      "text": "Melt butter in a pan. Add olive oil. Pan-fry each side for 4 minutes. Place in a clean plate. Set aside."
    },
    {
      "position": 7,
      "text": "Prepare the gravy by pouring the oil used to cook the burger patty into a sauce pan."
    },
    {
      "position": 8,
      "text": "Saute the onion until soft. Add ketchup, Worcestershire sauce, and water. Let boil. Add Knorr beef cube. Stir and continue to cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Combine cornstarch with 3 to 4 tablespoons water. Stir and pour into the pot. Stir until the gravy thickens."
    },
    {
      "position": 10,
      "text": "Arrange the mashed potato on a plate. Top with Salisbury Steak and Gravy. Serve!"
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
