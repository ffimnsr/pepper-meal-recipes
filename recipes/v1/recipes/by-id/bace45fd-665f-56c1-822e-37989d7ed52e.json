  "id": "bace45fd-665f-56c1-822e-37989d7ed52e",
  "slug": "ube-pichi-pichi-recipe",
  "name": "Ube Pichi Pichi Recipe",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Ube Pichi Pichi",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the ingredients in a large mixing bowl, except for the coconut. Stir thoroughly until the mixture gets well blended."
    },
    {
      "position": 2,
      "text": "Pour the cassava mixture in a small mold such as a silicone cup. Arrange the molds in a steamer."
    },
    {
      "position": 3,
      "text": "Steam for 60 minutes."
    },
    {
      "position": 4,
      "text": "Remove from the steamer. Let it cool down completely until the texture gets close to sticky tikoy."
    },
    {
      "position": 5,
      "text": "Roll each piece of pich pichi over shredded /grated coconut."
    },
    {
      "position": 6,
      "text": "Arrange in a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
