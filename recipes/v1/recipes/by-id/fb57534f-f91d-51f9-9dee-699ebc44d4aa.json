  "id": "fb57534f-f91d-51f9-9dee-699ebc44d4aa",
  "slug": "grilled-chicken-breast-inasal",
  "name": "Beer Marinated Grilled Chicken Breast Inasal",
  "recipe_type": null,
  "brief_description": "Filipino Grilled Chicken Inasal is a tasty grilled chicken breast dish. This recipe makes use of beer as an marinade ingredient.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Lay the boneless chicken breasts flat on a chopping board. Cover with a cling wrap. Flatten by pounding with a meat tenderizer tool. Set aside."
    },
    {
      "position": 2,
      "text": "Make the marinade by combining the marinade ingredients in a large bowl, Mix well. Add the pounded chicken breasts. Marinate for at least 3 hours (I usually marinate overnight). Don't forget to cover the bowl and place inside the fridge."
    },
    {
      "position": 3,
      "text": "Prepare the basting sauce by combining 3 tablespoons of soy sauce, 2 tablespoons of margarine, and the remaining marinade. Mix well and then microwave for 1 minute."
    },
    {
      "position": 4,
      "text": "Heat the grill. Start to cook the beer marinated chicken. Baste with the basting sauce and grill one side in medium heat for 3 to 4 minutes. Flip the chicken breast to cook the other side.Baste the top part with the basting sauce, Continue to do this step one more time or more until the chicken breasts are done."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve with papaya atchara and sinamak."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 60,
  "rest_time_minutes": null,
