  "id": "2e8ac587-0bcd-5d8d-8638-36b676a574c6",
  "slug": "how-to-make-sushi-summer-roll",
  "name": "Sushi Summer Roll Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Sushi summer roll is a type of fresh vegetable, shrimp, and crabmeat roll that makes use of rice paper. It is simply delicious.",
  "cuisine": "Asian",
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water in a big bowl and soak the tapioca paper until it softens."
    },
    {
      "position": 2,
      "text": "Remove the softened tapioca paper and place on a kitchen towel and let it rest for half a minute."
    },
    {
      "position": 3,
      "text": "Align two shrimps in the middle of the softened tapioca paper. The outer part of the shrimp should be facing down."
    },
    {
      "position": 4,
      "text": "Arrange a leaf of lettuce on top the shrimp then top with slices of avocado, carrots, cucumber, and imitation crabmeat."
    },
    {
      "position": 5,
      "text": "Press down the filling using your fingers then fold the bottom end of the tapioca paper over the top of the filling. Roll halfway."
    },
    {
      "position": 6,
      "text": "Fold the edges of the tapioca paper inwards and continue rolling until the fillings are secured. Folding the ends will close both edges ensuring that the fillings are securely wrapped."
    },
    {
      "position": 7,
      "text": "If desired, slice each roll in the middle then transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with your favorite dip. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
  "difficulty": "medium",
