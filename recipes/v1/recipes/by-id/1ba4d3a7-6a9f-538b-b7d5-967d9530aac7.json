  "id": "1ba4d3a7-6a9f-538b-b7d5-967d9530aac7",
  "slug": "chocolate-biko-recipe",
  "name": "Chocolate Biko Recipe",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Chocolate Biko",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour coconut milk in a pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the tablea. Stir until it dissolves completely."
    },
    {
      "position": 3,
      "text": "Add the rice, sugar, and salt. Stir and cover. Continue to cook in low to medium heat until the rice absorbs half of the liquid."
    },
    {
      "position": 4,
      "text": "Stir the mixture making sure that no rice sticks on the pot (this will require a little effort). Continue to cook until the liquid is completely absorbed. Note: you may add more coconut milk or water when the liquid starts to dry out and the rice is not completely done yet."
    },
    {
      "position": 5,
      "text": "Arrange in a greased baking dish. Let it cool down and serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
