  "id": "ec638013-8ed7-58d5-ae50-57d9fb743824",
  "slug": "tapa-and-egg-fried-rice",
  "name": "Tapa and Egg Fried Rice",
  "recipe_type": "breakfast",
  "brief_description": "Tapa made from horse meat and easy egg fried rice with pickled papaya on the side. This dish is perfect for breakfast or lunch.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Start making the tapa by combining garlic, soy sauce, salt, and ground black pepper in a bowl. Stir. Add the meat and mix well. Cover the bowl and refrigerate for at least 3 hours."
    },
    {
      "position": 2,
      "text": "Slice the meat into thinner and smaller pieces as needed. Arrange it in a pan and pour-in water and cooking oil. Let boil."
    },
    {
      "position": 3,
      "text": "Add the lemon lime soda. Continue cooking uncovered until the liquid completely evaporates."
    },
    {
      "position": 4,
      "text": "Fry the tapa in remaining oil for 2 minutes. Remove from the pan and set aside."
    },
    {
      "position": 5,
      "text": "Make the egg fried rice by frying the eggs in the remaining oil."
    },
    {
      "position": 6,
      "text": "Once completely cooked, cut the eggs into smaller pieces using your spatula."
    },
    {
      "position": 7,
      "text": "Add onion, half of the green onions, and bell pepper. Cook for 2 minutes while continuously stirring."
    },
    {
      "position": 8,
      "text": "Put the leftover rice into the pan and then toss until all the ingredients are well distributed."
    },
    {
      "position": 9,
      "text": "Add soy sauce and sesame oil. Continue to stir fry for 3 to 5 minutes. Note: You may add salt if needed."
    },
    {
      "position": 10,
      "text": "Top with remaining green onions. Transfer to a serving plate and serve with the fried tapa. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 60,
  "rest_time_minutes": null,
  "difficulty": "hard",
