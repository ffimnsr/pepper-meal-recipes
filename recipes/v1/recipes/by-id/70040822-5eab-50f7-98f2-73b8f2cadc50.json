  "id": "70040822-5eab-50f7-98f2-73b8f2cadc50",
  "slug": "ketchup-fried-chicken",
  "name": "Ketchup Fried Chicken",
  "recipe_type": "main",
  "brief_description": "Chicken boiled with soy sauce, vinegar, and banana sauce then fried to perfection.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the ingredients in a cooking pot, except for the oil. Stir until well blended. Cover the pot and let the liquid boil. Adjust heat between low to medium. Continue boiling for 10 minutes."
    },
    {
      "position": 2,
      "text": "Turn the chicken over. Continue boiling the opposite for another 10 minutes while leaving the pot uncovered."
    },
    {
      "position": 3,
      "text": "Remove chicken and let it cool down. Save the remaining liquid as a sauce."
    },
    {
      "position": 4,
      "text": "Rub salt all over the chicken. Let it air dry for 30 minutes."
    },
    {
      "position": 5,
      "text": "Heat oil in a pan. Fry the chicken on medium heat until brown. Turn the chicken over and do the same to the other side."
    },
    {
      "position": 6,
      "text": "Remove chicken from the pan. Arrange on a serving plate. Serve with rice and ketchup sauce (remaining liquid used to boil the chicken). Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
