  "id": "1d39c334-8269-568c-bb93-e4736aad28f6",
  "slug": "spicy-eggplant-stir-fry",
  "name": "Spicy Eggplant Stir Fry Recipe",
  "recipe_type": "main",
  "brief_description": "One bite of this spicy eggplant stir fry will have everything you could ever want in a healthy, meatless dish",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Brush the eggplants with oil. Pan fry until it softens. Remove from the pan and set aside."
    },
    {
      "position": 2,
      "text": "Combine all the sauce ingredients in a bowl. Mix well. Set aside."
    },
    {
      "position": 3,
      "text": "Heat the remaining oil in a pan. Saut\u00e9 the garlic, onion, and chili pepper."
    },
    {
      "position": 4,
      "text": "Add the string beans once the onion softens. Stir fry for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour the sauce into the pan. Cook while stirring until it thickens."
    },
    {
      "position": 6,
      "text": "Add the fried eggplant. Continue stir-frying until the string beans get cooked completely."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
