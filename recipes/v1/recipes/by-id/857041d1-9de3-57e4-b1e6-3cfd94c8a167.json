  "id": "857041d1-9de3-57e4-b1e6-3cfd94c8a167",
  "slug": "kbl-kadyos-baboy-at-langka",
  "name": "KBL (Kadyos, Baboy, at Langka) Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for KBL or Kadios, Baboy, at Langka. It is an Ilonggo stew composed of pork, pigeon pea, and unripe jackfruit.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot (first batch) and add a little salt. Add pork hocks. Let boil and simmer for 5 minutes."
    },
    {
      "position": 2,
      "text": "Throw away the liquid. Pour-in second batch of water and let boil."
    },
    {
      "position": 3,
      "text": "Put-in lemon grass and beef cube. Simmer for 40 to 45 minutes of until pork is tender."
    },
    {
      "position": 4,
      "text": "Add the pigeon peas. Cook for 20 to 25 minutes. Note: For dried pigeon peas, you need to soak it in water overnight."
    },
    {
      "position": 5,
      "text": "Put-in the sinigang mix, salt, pepper, and jack fruit. Cook for 10 minutes."
    },
    {
      "position": 6,
      "text": "Add the sweet potato leaves. Cover the cooking pot and turn the heat off."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
  "difficulty": "hard",
