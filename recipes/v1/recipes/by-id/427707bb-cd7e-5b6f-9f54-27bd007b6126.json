  "id": "427707bb-cd7e-5b6f-9f54-27bd007b6126",
  "slug": "crispy-katsu-sando",
  "name": "Crispy Katsu Sando",
  "recipe_type": null,
  "brief_description": "Easy Japanese sandwich with crispy burger",
  "cuisine": "Japanese",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan. Fry both sides of the CDO Crispy burger patties using medium heat until crispy. Set aside"
    },
    {
      "position": 2,
      "text": "Grab 2 slices of bread. Spread butter on one side of the first slice of bread and mayonnaise on one side of the second bread slice."
    },
    {
      "position": 3,
      "text": "Lay down the bread slice with butter on a flat surface (butter side up). Top with shredded cabbage and tonkatsu sauce."
    },
    {
      "position": 4,
      "text": "Arrange 2 CDO Crispy Burgers over it and then top with more shredded cabbage and tonkatsu sauce. Finish by topping with the other bread slice (mayo side facing down)."
    },
    {
      "position": 5,
      "text": "Arrange Crispy Burger Sando on a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
