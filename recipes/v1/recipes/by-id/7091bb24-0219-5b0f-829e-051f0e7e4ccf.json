  "id": "7091bb24-0219-5b0f-829e-051f0e7e4ccf",
  "slug": "tanigue-fish-steak-ala-bistek",
  "name": "Tanigue Fish Steak ala Bistek",
  "recipe_type": null,
  "brief_description": "This is a recipe for tanigue fish steak ala bistek. It is composed of fried fish steaks cooked in soy sauce and lemon.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the fish steaks. Let it stay for 20 minutes."
    },
    {
      "position": 2,
      "text": "Heat 1/2 cup oil in a pan. Fry the fish for 3 to 5 minutes per side or until golden brown. Set aside."
    },
    {
      "position": 3,
      "text": "Heat 3 to 4 tablespoons oil in a cooking pot. Saute garlic until light brown."
    },
    {
      "position": 4,
      "text": "Add 1/3 of the total onions. continue to saute until soft."
    },
    {
      "position": 5,
      "text": "Pour soy sauce and add lemon juice into the cooking pot."
    },
    {
      "position": 6,
      "text": "Pour water and let boil."
    },
    {
      "position": 7,
      "text": "Add sugar and ground black pepper. Stir."
    },
    {
      "position": 8,
      "text": "Put the fried fish steaks into the pot. Cover and cook in medium heat for 3 minutes."
    },
    {
      "position": 9,
      "text": "Turn the fish over in a way that the opposite side faces the bottom of the pot. Add the remaining onion. Cover and continue to cook for 3 to 5 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve with rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 20,
