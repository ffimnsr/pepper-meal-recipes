  "slug": "how-to-make-homemade-crispy-french-fries-recipe",
  "name": "Crispy Homemade French Fries",
  "recipe_type": null,
  "brief_description": "This Crispy Homemade French Fries Recipe is the best and easiest that I've tried by far. The crisp texture will definitely make you a believer.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Peel the potatoes. Use a vegetable peeler to save time."
    },
    {
      "position": 2,
      "text": "Slice the potatoes into long thin pieces."
    },
    {
      "position": 3,
      "text": "Soak the potatoes in ice water for 30 minutes."
    },
    {
      "position": 4,
      "text": "Drain the water and dry the potatoes using a paper towel."
    },
    {
      "position": 5,
      "text": "Deep fry the potatoes for 10 minutes or until the color turns light brown. Do not put too many potatoes in a batch as it will take more time for it to be cooked."
    },
    {
      "position": 6,
      "text": "Remove the potatoes from the deep fryer or cooking pot and allow to cool for 5 minutes."
    },
    {
      "position": 7,
      "text": "Put the fried potatoes back in the fryer and fry for another 3 minutes."
    },
    {
      "position": 8,
      "text": "Remove the fried potatoes and transfer to a plate with paper towels. Sprinkle some salt to taste."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 15,
