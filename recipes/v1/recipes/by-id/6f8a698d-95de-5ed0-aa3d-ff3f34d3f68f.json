  "schema_version": 1,
  "id": "6f8a698d-95de-5ed0-aa3d-ff3f34d3f68f",
  "slug": "asian-chicken-stir-fry",
  "name": "Asian Chicken Stir Fry",
  "recipe_type": "main",
  "brief_description": "This Asian chicken stir fry features tender marinated chicken pieces tossed with colorful bell peppers, broccoli, and carrots in a savory honey-soy sauce. Ready in under 30 minutes, it's perfect served over steamed rice for a quick and satisfying weeknight dinner.",
  "cuisine": "Asian Chinese Thai",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the chicken and soy sauce in a bowl. Marinate for 15 minutes."
    },
    {
      "position": 2,
      "text": "Combine all the sauce ingredients in a separate bowl. Mix well and set aside."
    },
    {
      "position": 3,
      "text": "Heat 2 tablespoons of cooking oil in a wok over medium-high heat. Stir fry the chicken for about 3 minutes or until light to medium brown. Remove from the wok and set aside."
    },
    {
      "position": 4,
      "text": "Heat the remaining oil in the same wok. Saut\u00e9 the onion, garlic, and ginger for about 1 minute or until the onion softens."
    },
    {
      "position": 5,
      "text": "Add the broccoli and stir fry for 30 seconds. You can also pour 2 tablespoons of water and cover the wok to steam the broccoli. Do this for 60 to 90 seconds."
    },
    {
      "position": 6,
      "text": "Add the carrots and bell peppers. Continue to stir fry for about 1 minute."
    },
    {
      "position": 7,
      "text": "Return the chicken to the wok and toss to combine with the vegetables."
    },
    {
      "position": 8,
      "text": "Pour in the sauce. Stir and continue cooking until the sauce thickens and coats the chicken evenly."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate and serve with steamed rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 20,
  "rest_time_minutes": 15,
  "difficulty": "hard",
