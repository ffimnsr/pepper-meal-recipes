  "id": "36091d1a-f49c-58e2-b572-b3acdf313595",
  "slug": "fried-ham-and-cheese-roll",
  "name": "Fried Ham and Cheese Roll",
  "recipe_type": "appetizer",
  "brief_description": "Fried Ham and Cheese Roll is an easy snack or appetizer recipe. This recipe is simple and inexpensive because you can use leftover bread slices and leftover ham.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Remove the dark ends of the sliced bread."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Place the bread slices in a zip lock bag. Flatten using a rolling pin."
    },
    {
      "position": 4,
      "text": "Spread mayonnaise on the flatten piece of bread"
    },
    {
      "position": 5,
      "text": "Arrange the ham, cheese, and pimento strips on the bread. Roll the bread until the filling is covered. Secure with a toothpick."
    },
    {
      "position": 6,
      "text": "Dip the rolled bread in beaten egg. Place the Panko bread crumbs in a large Ziploc bag and then put the dipped rolls in. Shake until everything is covered with crumbs."
    },
    {
      "position": 7,
      "text": "Fry in low to medium heat until the color turns golden brown (about 5 to 7 minutes)."
    },
    {
      "position": 8,
      "text": "Arrange the fried rolls in a plate line with paper towels."
    },
    {
      "position": 9,
      "text": "Serve as a snack or slice into pieces and serve as an appetizer."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 7,
  "preparation_time_minutes": 10,
