  "id": "3a7051e4-7d8d-5eca-b0b7-eae06a7cd5e5",
  "slug": "pork-bbq-fried-rice",
  "name": "Pork Fried Rice",
  "recipe_type": null,
  "brief_description": "Pork Fried Rice is something that I wish to have when craving for fried rice. Yes, I also love Yang Chow Fried Rice because it is also good.",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Put the leftover rice in a large mixing bowl. Make sure that the grains are not sticking to each other."
    },
    {
      "position": 2,
      "text": "Add the salt, garlic powder, and onion powder in the mixing bowl. Gently mix all the ingredients using a large spoon until well blended."
    },
    {
      "position": 3,
      "text": "Meanwhile, heat half of the cooking oil in a wide pan."
    },
    {
      "position": 4,
      "text": "Once the oil gets hot, pour the beaten eggs on the pan. Cook each side for 1 minute. Remove the egg from the pan and place in a plate. Set aside."
    },
    {
      "position": 5,
      "text": "Add the remaining cooking oil. Once the oil gets hot, add the sliced char siu (pork bbq) in the pan. Cook for 30 seconds to 1 minute."
    },
    {
      "position": 6,
      "text": "Add the rice mixture. Try to fold the rice once in a while using a spatula. Continue to cook for 5 to 8 minutes."
    },
    {
      "position": 7,
      "text": "Pour the soy sauce and sesame oil over the rice. Quickly fold the rice to distribute the liquid ingredients evenly. Cook for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Put the cooked egg over the rice. Using the tip of a spatula, divide the eggs into multiple pieces by slicing into it. Continue to fold so that the egg gets distributed equally."
    },
    {
      "position": 9,
      "text": "Add the green onions. Stir and cook for 2 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
