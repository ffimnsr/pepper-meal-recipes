  "id": "0fb2e41b-871a-5d07-bab9-dd09c6308c3b",
  "slug": "beef-holiday-christmas-new-year-food-menu-morcon-recipe",
  "name": "Morcon",
  "recipe_type": null,
  "brief_description": "This is a recipe for beef morcon",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Marinate the beef in soy sauce and lemon juice for at least 1 hour"
    },
    {
      "position": 2,
      "text": "Place the beef in a flat surface and arrange the hotdogs, pickle, carrot, cheese, and egg on one side"
    },
    {
      "position": 3,
      "text": "Roll the beef enclosing the fillings and tie with a cooking string to ensure that the meat will not open-up"
    },
    {
      "position": 4,
      "text": "Place cooking oil in a pan and apply heat"
    },
    {
      "position": 5,
      "text": "Dredge the rolled beef in flour and fry until the color of the outer part turns medium brown"
    },
    {
      "position": 6,
      "text": "Transfer the fried rolled beef in a casserole and pour-in the beef broth then bring to a boil"
    },
    {
      "position": 7,
      "text": "Pour-in half of the soy sauce-lemon juice marinade,salt and simmer until the beef is tender (about 2 hours using ordinary casserole or 30 minutes if a pressure cooker is used)"
    },
    {
      "position": 8,
      "text": "Optional: Fry the simmered meat for at least 2 minutes"
    },
    {
      "position": 9,
      "text": "Remove the strings and slice into serving pieces"
    },
    {
      "position": 10,
      "text": "Place in a serving dish and add the sauce."
    },
    {
      "position": 11,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
