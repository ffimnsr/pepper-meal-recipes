  "id": "bc4b0db9-4808-5f6d-986a-f6c34ca4d631",
  "slug": "beef-stroganoff-lasagna",
  "name": "Beef Stroganoff Lasagna",
  "recipe_type": "main",
  "brief_description": "Rich and creamy lasagna made with beef stroganoff.",
  "cuisine": "Italian Russian",
  "instructions": [
    {
      "position": 1,
      "text": "Cook lasagna based on package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Make the sauce by melting the butter in a pan. Add beef sirloin and then cook until it turns light brown."
    },
    {
      "position": 3,
      "text": "Add onion and mushroom. Continue sauteeing for 3 minutes."
    },
    {
      "position": 4,
      "text": "Combine Knorr Cream of Mushroom with 2 \u00bd cups water. Stir until well blended. Pour the mixture into the pan. Stir and cook until the sauce thickens."
    },
    {
      "position": 5,
      "text": "Add paprika. Cook for another 3 minutes."
    },
    {
      "position": 6,
      "text": "Turn the heat off and then add sour cream. Stir to mix all the ingredients."
    },
    {
      "position": 7,
      "text": "Preheat the oven to 350F. Assemble the lasagna in the baking pan starting with the stroganoff followed by the lasagna. Top with mozzarella. Continue with the pattern until all ingredients are used up."
    },
    {
      "position": 8,
      "text": "Bake for 30 minutes."
    },
    {
      "position": 9,
      "text": "Remove from the oven and serve warm with garlic bread. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": null,
