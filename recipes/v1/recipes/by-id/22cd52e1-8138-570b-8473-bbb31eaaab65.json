  "id": "22cd52e1-8138-570b-8473-bbb31eaaab65",
  "slug": "sinigang-na-sardinas",
  "name": "Sinigang na Sardinas",
  "recipe_type": "soup",
  "brief_description": "A light, tamarind-based Filipino soup using canned fish and loaded with vegetables",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Separate the mackerel from the oil using a kitchen strainer. Set both aside."
    },
    {
      "position": 2,
      "text": "Heat cooking oil and then saut\u00e9 the onions until the layers separate."
    },
    {
      "position": 3,
      "text": "Add ginger and garlic. Continue to saut\u00e9 until the garlic starts to brown."
    },
    {
      "position": 4,
      "text": "Add the tomatoes. Saut\u00e9 for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour the oil from the canned mackerel into the cooking pot. Add 1 tablespoon of fish sauce and \u00bd teaspoon of ground black pepper. Stir."
    },
    {
      "position": 6,
      "text": "Add miso paste and pour 1 \u00bd quarts of water. Let it boil."
    },
    {
      "position": 7,
      "text": "Add the daikon radish. Continue cooking in medium heat setting for 5 minutes."
    },
    {
      "position": 8,
      "text": "Add Maggi Magic Sinigang with Gabi. Stir."
    },
    {
      "position": 9,
      "text": "Add the eggplant. Boil for 2 minutes."
    },
    {
      "position": 10,
      "text": "Add the okra, long green peppers, and string beans."
    },
    {
      "position": 11,
      "text": "Pour the remaining water, cover the pot, and let it re-boil. Continue cooking for 2 minutes."
    },
    {
      "position": 12,
      "text": "Put the mackerel into the pot. Gently stir."
    },
    {
      "position": 13,
      "text": "Add the water spinach (kangkong). Cook for 2 to 3 minutes."
    },
    {
      "position": 14,
      "text": "Season with more fish sauce and ground black pepper as needed."
    },
    {
      "position": 15,
      "text": "Transfer to a serving bowl. Serve hot."
    },
    {
      "position": 16,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
