  "id": "5ca1fa1a-4426-5246-b424-d542dffdf706",
  "slug": "ginataang-baka-beef-in-coconut-milk-with-green-beans-and-spinach",
  "name": "Ginataang Baka \u2013 Beef in Coconut Milk with Green Beans and Spinach",
  "recipe_type": null,
  "brief_description": "A comforting Filipino beef stew simmered in rich coconut milk with tender beef chunks, crisp green beans, and nutritious spinach. Aromatic ginger, garlic, and Thai chilies add warmth and depth to this hearty ginataan dish traditionally served with steamed rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot over medium heat."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 onion, garlic, and ginger until fragrant and the onion becomes soft."
    },
    {
      "position": 3,
      "text": "Add the beef and saut\u00e9 until it turns light brown on all sides."
    },
    {
      "position": 4,
      "text": "Pour in the coconut milk and add water. Stir to combine. Cover the pot and simmer over low to medium heat for 1 hour."
    },
    {
      "position": 5,
      "text": "Add the chili peppers. Continue cooking for 30 minutes to 1 hour until the beef is fork-tender."
    },
    {
      "position": 6,
      "text": "Add the green beans. Cover and cook for 3 minutes until tender-crisp."
    },
    {
      "position": 7,
      "text": "Season with fish sauce and ground black pepper to taste."
    },
    {
      "position": 8,
      "text": "Stir in the spinach and cook for 1 minute until just wilted."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate and serve hot with steamed rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 10,
