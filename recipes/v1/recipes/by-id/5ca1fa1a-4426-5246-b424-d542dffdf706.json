  "id": "5ca1fa1a-4426-5246-b424-d542dffdf706",
  "slug": "ginataang-baka-beef-in-coconut-milk-with-green-beans-and-spinach",
  "name": "Ginataang Baka \u2013 Beef in Coconut Milk with Green Beans and Spinach",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginataang Baka \u2013 Beef in Coconut Milk with Green Beans and Spinach",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil on a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute onion, garlic and ginger."
    },
    {
      "position": 3,
      "text": "Once the onion becomes soft, saute beef until it turns light brown."
    },
    {
      "position": 4,
      "text": "Pour coconut milk and add water. Stir. Cover the pot and continue to cook between low to medium heat for 1 hour."
    },
    {
      "position": 5,
      "text": "Add chili peppers. Cook for 30 minutes to 1 hour until the beef gets tender."
    },
    {
      "position": 6,
      "text": "Add green beans. Cover the pot and cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 8,
      "text": "Put the spinach into the pot and cook for 1 minute."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 10,
