  "id": "8d170602-6115-5d04-af5a-b3d7d0ee45f4",
  "slug": "chicken-ala-king-recipe-knr_cc",
  "name": "Chicken ala King Recipe",
  "recipe_type": null,
  "brief_description": "This is a Recipe for Chicken ala King",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add chicken breast. Cover and cook in medium heat for 20 to 25 minutes. Remove the chicken from the pot. Let it cool down. Slice into cubes. Set aside."
    },
    {
      "position": 2,
      "text": "Melt butter in a pan. Continue to cook in low to medium heat until butter gets hot."
    },
    {
      "position": 3,
      "text": "Saute onion, green bell pepper, and mushroom."
    },
    {
      "position": 4,
      "text": "Add Knorr Chicken cube. Continue to stir until all ingredients are well blended."
    },
    {
      "position": 5,
      "text": "Add all-purpose flour. Stir."
    },
    {
      "position": 6,
      "text": "Pour milk into the pot. Stir. Let boil."
    },
    {
      "position": 7,
      "text": "Add cubed chicken and pimiento. Season the chicken ala king with salt and ground black pepper. Continue to cook while stirring for 2 minutes or until the sauce thickens."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
