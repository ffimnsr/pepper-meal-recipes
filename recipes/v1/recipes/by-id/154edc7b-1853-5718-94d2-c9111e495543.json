  "id": "154edc7b-1853-5718-94d2-c9111e495543",
  "slug": "general-tsos-chicken-recipe",
  "name": "General Tso Chicken Recipe",
  "recipe_type": null,
  "brief_description": "General Tso Chicken is a popular Asian chicken recipe that goes well with Yang Chow fried rice. This version will tickle your taste buds.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the marinade ingredients in a large bowl. Stir."
    },
    {
      "position": 2,
      "text": "Add the chicken. Marinate for 1 hour."
    },
    {
      "position": 3,
      "text": "Meanwhile, combine the sauce ingredients in a bowl. Mix well and then set aside."
    },
    {
      "position": 4,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 5,
      "text": "Dredge the marinated chicken in cornstarch and then dip into the beaten egg mixture."
    },
    {
      "position": 6,
      "text": "Roll the chicken back in the cornstarch and then deep fry until the color turns light brown (about 5 to 7 minutes). Do not overcook. Set aside."
    },
    {
      "position": 7,
      "text": "On a clean pan, saut\u00e9 onion in 2 tablespoons cooking oil."
    },
    {
      "position": 8,
      "text": "Add the sauce mixture and then stir until the mixture starts to thicken."
    },
    {
      "position": 9,
      "text": "Put-in the deep fried chicken and stir until the sauce coats each piece."
    },
    {
      "position": 10,
      "text": "Add the chopped scallions. Transfer to a serving plate."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
