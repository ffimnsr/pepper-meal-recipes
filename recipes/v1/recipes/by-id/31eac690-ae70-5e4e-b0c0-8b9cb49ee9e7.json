  "id": "31eac690-ae70-5e4e-b0c0-8b9cb49ee9e7",
  "slug": "onion-rings",
  "name": "Onion Rings",
  "recipe_type": null,
  "brief_description": "This is a recipe for onion rings.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cooking procedure:"
    },
    {
      "position": 2,
      "text": "Break up the onion slices into rings. Set aside."
    },
    {
      "position": 3,
      "text": "Combine flour, baking powder, and salt, in a small bowl and mix well."
    },
    {
      "position": 4,
      "text": "Dredge the onions on the flour mixture and set aside."
    },
    {
      "position": 5,
      "text": "Meanwhile, make the batter by adding the egg and milk on the flour mixture and whisk."
    },
    {
      "position": 6,
      "text": "Dip the onions on the batter and allow the extra batter to drip."
    },
    {
      "position": 7,
      "text": "Place the breadcrumbs in a plastic bag or container and put-in the onions rings."
    },
    {
      "position": 8,
      "text": "Heat a cooking pot and pour-in cooking oil."
    },
    {
      "position": 9,
      "text": "When the oil is hot, deep-fry the onion until the color turns golden brown (usually 2 minutes or so)."
    },
    {
      "position": 10,
      "text": "Remove the onion rings from the cooking pot and place in a plate lined with paper towels, to absorb the excess oil."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate and serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 5,
