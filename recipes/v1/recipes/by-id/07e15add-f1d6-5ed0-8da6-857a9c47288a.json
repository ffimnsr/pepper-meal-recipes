{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "07e15add-f1d6-5ed0-8da6-857a9c47288a",
  "slug": "killer-crispy-sinigang",
  "name": "Killer Crispy Sinigang",
  "recipe_type": "main",
  "brief_description": "Filipino sinigang with crispy liempo",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat 3 tablespoons of cooking oil in a cooking pot. Saute garlic, onion, and tomato."
    },
    {
      "position": 2,
      "text": "Add the pork belly once the onion softens. Cook until the outside of the pork turns light brown."
    },
    {
      "position": 3,
      "text": "Pour the water into the pot. Let it boil. Add Knorr Sinigang sa Sampaloc Recipe mix (save 1 tablespoon for later use). Cover the pot and boil the pork in low heat setting until the pork tenderizes (around 45 minutes)."
    },
    {
      "position": 4,
      "text": "Remove the pork belly from the cooking pot. Let it cool down. Rub the remaining sinigang mix all over the pork and then add Knorr Liquid Seasoning. Air dry the pork for at least 3 hours (note: it is better to soak it under the sun for best results)."
    },
    {
      "position": 5,
      "text": "Heat the remaining cooking oil. Deep- fry the pork belly until crispy (note: you can double fry it too)."
    },
    {
      "position": 6,
      "text": "Boil the soup on more time and then add the remaining vegetables. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and fish sauce. Arrange the soup and vegetables in a bowl and then top with crispy pork."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 80,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
