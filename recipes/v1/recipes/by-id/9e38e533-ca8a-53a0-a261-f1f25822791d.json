  "id": "9e38e533-ca8a-53a0-a261-f1f25822791d",
  "slug": "sauteed-tuna-flakes",
  "name": "Simple Tuna Recipe",
  "recipe_type": "salad",
  "brief_description": "Simple tuna recipe is a quick and easy recipe that makes use of tuna flakes in can. This is a quick dinner dish that goes well with vegetable salad",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the onion until it becomes soft."
    },
    {
      "position": 3,
      "text": "Put-in the tuna. Cook for 3 minutes in medium heat."
    },
    {
      "position": 4,
      "text": "Add the lemon juice, salt, and pepper. Cook for an additional 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. top with French fried onions and dried parsley flakes."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
