{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "d317ef94-fc95-5e72-8204-2410782e7673",
  "slug": "special-holiday-food-dish-roast-beef-recipe",
  "name": "Roast Beef",
  "recipe_type": "drink",
  "brief_description": "Roast Beef is a beef dish cooked by roasting in an oven. The beef is simply coated with olive oil and sprinkled with salt and pepper before roasting. Natural juices from the meat is the main source of flavor ; drippings are also used to make the sauce (or gravy).",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 375 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Make some slit on the meat using a knife and insert each sliced garlic clove"
    },
    {
      "position": 3,
      "text": "Spread the olive oil on the meat then sprinkle some salt and pepper."
    },
    {
      "position": 4,
      "text": "Place the meat on a roasting rack (with dripping tray/pan) and bake for 30 minutes."
    },
    {
      "position": 5,
      "text": "Reduce the heat to 250 degrees Fahrenheit then continue baking for 2 to 2.5 hours (or until the inner temperature of the meat reaches 140 degrees Fahrenheit). Note: Do not remove from the oven right away. Let the juices from the meat drip some more so that you will have enough drippings for the gravy."
    },
    {
      "position": 6,
      "text": "Remove the roasted meat from the oven and allow it to rest for at least 15 minutes."
    },
    {
      "position": 7,
      "text": "Slice the meat into serving pieces and transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "We also need to prepare the sauce. The following steps will help you make a good one."
    },
    {
      "position": 9,
      "text": "Take the dripping pan out of the oven and place it on the stove then apply heat."
    },
    {
      "position": 10,
      "text": "Pour-in the red wine and deglaze the drippings then transfer to a saucepan."
    },
    {
      "position": 11,
      "text": "Add water and bring to a boil."
    },
    {
      "position": 12,
      "text": "Add the beef cube and cook until well diluted then put-in the cornstarch. Stir continuously."
    },
    {
      "position": 13,
      "text": "Transfer the sauce to a serving bowl."
    },
    {
      "position": 14,
      "text": "Serve the Roast beef with the sauce on the side."
    },
    {
      "position": 15,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
