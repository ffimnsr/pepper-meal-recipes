  "id": "ec715c58-85eb-5dc1-8920-c70827d4a1b2",
  "slug": "chicken-with-broccoli-oyster-sauce-recipe",
  "name": "Chicken with Broccoli Recipe",
  "recipe_type": null,
  "brief_description": "Chicken with broccoli is an easy to prepare recipe that you can cook for your family during ordinary days. This dish is delicious",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt and pepper on the sliced chicken. Let it stand for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 3,
      "text": "Dip the chicken slices in beaten egg and then dredge in cornstarch."
    },
    {
      "position": 4,
      "text": "Fry the coated chicken for about 2 minutes per side or until the color turns light to medium brown. Remove from the pan and place in a plate lined with paper towel."
    },
    {
      "position": 5,
      "text": "Clean the pan and save about 2 tablespoons of cooking oil."
    },
    {
      "position": 6,
      "text": "Heat the clean pan with the remaining cooking oil."
    },
    {
      "position": 7,
      "text": "Add the onion and ginger. Cook for a minute."
    },
    {
      "position": 8,
      "text": "Put-in the fried chicken slices. Stir."
    },
    {
      "position": 9,
      "text": "Put-in the oyster sauce, soy sauce, garlic powder, and water (with cornstarch). Stir and continue cooking for 3 minutes in medium heat."
    },
    {
      "position": 10,
      "text": "Add the broccoli florets. Cook for 2 to 3 minutes more."
    },
    {
      "position": 11,
      "text": "Sprinkle salt and pepper to taste."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
