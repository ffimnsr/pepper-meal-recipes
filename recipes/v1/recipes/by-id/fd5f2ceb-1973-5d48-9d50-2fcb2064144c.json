  "id": "fd5f2ceb-1973-5d48-9d50-2fcb2064144c",
  "slug": "paella-marinara-arroz-recipe",
  "name": "Paella Marinera Recipe",
  "recipe_type": "main",
  "brief_description": "Seafood paella recipe",
  "cuisine": "Spanish",
  "instructions": [
    {
      "position": 1,
      "text": "Combine seasoned yellow rice and water and soak for 3 hours."
    },
    {
      "position": 2,
      "text": "Heat a Paellera or large pan then pour-in olive oil."
    },
    {
      "position": 3,
      "text": "When the oil is hot, saute the garlic and onions."
    },
    {
      "position": 4,
      "text": "Put-in the crabs, mussels, shrimps, clams, squid, Tabasco sauce, salt, and ground black pepper. Cover the pan and cook for 3 minutes or until the juices come out."
    },
    {
      "position": 5,
      "text": "Add tomato sauce then cover the pan. Cook for a minute."
    },
    {
      "position": 6,
      "text": "Stir then simmer for 4 to 6 minutes. Transfer the cooked seafoods on a clean plate."
    },
    {
      "position": 7,
      "text": "With the remaining juices and tomato sauce on the pan, put-in the rice soaked in water and stir well. Simmer for 5 minutes."
    },
    {
      "position": 8,
      "text": "Add the Spanish saffron then gently stir. Cover the pan and continue cooking in low heat until the rice are done."
    },
    {
      "position": 9,
      "text": "Top the cooked yellow rice with pimiento then arrange the cooked seafoods over it."
    },
    {
      "position": 10,
      "text": "Serve with some lemon or lime wedges."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 12,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 15,
