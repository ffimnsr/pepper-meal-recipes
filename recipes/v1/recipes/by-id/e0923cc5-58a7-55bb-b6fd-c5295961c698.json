  "id": "e0923cc5-58a7-55bb-b6fd-c5295961c698",
  "slug": "healthy-roast-chicken-recipe",
  "name": "Shared Recipe. Roast Chicken",
  "recipe_type": null,
  "brief_description": "I love to eat chicken but I don\u2019t have the energy to do some fancy stuff on it. I only cook after my shift and this is often for dinner which is also my lunch for the next day. This Roast Chicken recipe is my favorite because it is simple yet flavorful. I also like this recipe because it gives me time to relax while cooking. All I do is sit on the couch until the timer sounds. - John H.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Clean the chicken and pat dry. Rub salt and pepper."
    },
    {
      "position": 2,
      "text": "Boil water and add salt, whole lemon, and garlic. Set aside the lemon and garlic."
    },
    {
      "position": 3,
      "text": "Pull the chicken breast skin and pour a little olive oil between skin and breast."
    },
    {
      "position": 4,
      "text": "Get the lemon and pierce for the juice to have an outlet."
    },
    {
      "position": 5,
      "text": "Place the lemon, garlic, and thyme inside the cavity of the chicken"
    },
    {
      "position": 6,
      "text": "Get a roasting pan and place the chicken in. Roast for 1 hour and 20 minutes at 350F."
    },
    {
      "position": 7,
      "text": "Serve. Store the leftovers in the fridge so that you can make some healthy chicken salad for tomorrow."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 80,
  "preparation_time_minutes": 15,
