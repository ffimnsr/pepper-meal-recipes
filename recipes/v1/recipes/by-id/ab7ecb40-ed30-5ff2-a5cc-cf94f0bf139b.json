  "id": "ab7ecb40-ed30-5ff2-a5cc-cf94f0bf139b",
  "slug": "dusty-fried-chicken-recipe",
  "name": "Dusty Fried Chicken Recipe",
  "recipe_type": null,
  "brief_description": "This simple fried chicken recipe is yummy. Chicken pieces were marinated in soy sauce and lemon and then dusted with flour before frying. It is a winner.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine soy sauce, juice of 1 lemon, salt, sugar, and ground black pepper. Mix well."
    },
    {
      "position": 2,
      "text": "Pour-in mixture on the chicken pieces and then make sure that each piece is coated. Marinate for 1 hour."
    },
    {
      "position": 3,
      "text": "Heat the cooking oil in a frying pan."
    },
    {
      "position": 4,
      "text": "Dust each chicken piece with flour and then pan-fry each side for 12 to 15 minutes in low to medium heat."
    },
    {
      "position": 5,
      "text": "Transfer to a plate line with paper towel."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
