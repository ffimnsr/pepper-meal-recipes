  "id": "ecdeafaa-15ec-57f4-bb5f-b89062c51cc5",
  "slug": "corned-beef-potato-casserole",
  "name": "Corned Beef and Potato Casserole",
  "recipe_type": "breakfast",
  "brief_description": "Corned Beef and Potato Casserole is a simple breakfast corned beef recipe that makes use of canned chunky corned beef and baking potatoes. It is quite similar to saut\u00e9ed corned beef or corned beef guisado except that this particular dish is cooked a bit longer.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat 1 tablespoon of cooking oil in a casserole."
    },
    {
      "position": 2,
      "text": "Add the garlic and onion. Saute until the onion becomes soft."
    },
    {
      "position": 3,
      "text": "Put-in the chunky corned beef. Stir and continue to cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in the beef broth; let boil. Cover and reduce the heat to a simmer. Continue to simmer for 20 minutes. Add more water or beef broth if needed."
    },
    {
      "position": 5,
      "text": "Meanwhile, heat the remaining 2 tablespoons of cooking oil in a pan."
    },
    {
      "position": 6,
      "text": "Once the oil becomes hot, pan-fry the cubed potatoes for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add the pan-fried potato on the casserole where the corned beef is cooking. Make sure that the liquid in the cooking pot is almost dry. Stir. Add salt and pepper and cook for 3 minutes more."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Sprinkle the chopped parsley on top."
    },
    {
      "position": 9,
      "text": "Serve for breakfast with toast or steamed rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
