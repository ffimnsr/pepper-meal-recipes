  "id": "b246c1e4-5281-5950-b481-b6168f67e38a",
  "slug": "stir-fried-pepper-steak",
  "name": "Stir Fried Pepper Steak",
  "recipe_type": null,
  "brief_description": "This is a recipe for Stir Fried Pepper Steak.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour Knorr liquid seasoning and oyster sauce over the beef sliced. Add the ground black pepper. Mix well."
    },
    {
      "position": 2,
      "text": "Add the cornstarch. Mix until all the ingredients are distributed. Let is stay for 5 minutes."
    },
    {
      "position": 3,
      "text": "Heat 3 tablespoons oil in a pan."
    },
    {
      "position": 4,
      "text": "Stir-fry the bell peppers for 3 minutes."
    },
    {
      "position": 5,
      "text": "Remove the bell peppers and set aside."
    },
    {
      "position": 6,
      "text": "Add 1 to 2 tablespoons of oil in the same cooking pot. Add the marinated beef. Stir fry for 8 minutes or until the beef is completely cooked."
    },
    {
      "position": 7,
      "text": "Add the bell peppers back and then stir-in the scallions. Stir-fry for 3 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve over rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
