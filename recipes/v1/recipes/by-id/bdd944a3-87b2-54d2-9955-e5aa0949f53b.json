  "id": "bdd944a3-87b2-54d2-9955-e5aa0949f53b",
  "slug": "chimichurri-recipe",
  "name": "Chimichurri Recipe",
  "recipe_type": null,
  "brief_description": "Fresh, garlicky, and a little spicy, this chimichurri is great over grilled steak, chicken, or fish. Chop everything by hand for the best texture, then let it rest before serving.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Finely chop the parsley by hand on a cutting board. Do not use a food processor because it can bruise the herbs and change the texture of the sauce."
    },
    {
      "position": 2,
      "text": "Mince the garlic and finely chop the Thai chili peppers. Remove the seeds if you want the chimichurri less spicy. Set them aside."
    },
    {
      "position": 3,
      "text": "Pour the extra virgin olive oil and red wine vinegar into a mixing bowl. Stir until combined."
    },
    {
      "position": 4,
      "text": "Add the dried oregano, fine sea salt, freshly ground black pepper, and minced garlic to the bowl. Stir well to combine."
    },
    {
      "position": 5,
      "text": "Add the chopped parsley and Thai chili peppers. Mix until everything is well blended. The sauce should be loose and easy to spoon, not thick or pasty. Add a little more olive oil if needed."
    },
    {
      "position": 6,
      "text": "Let the chimichurri sit at room temperature for at least 20 minutes before serving. This gives the flavors time to come together."
    },
    {
      "position": 7,
      "text": "Stir again, then spoon it over grilled steak, chicken, or fish."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 0,
  "preparation_time_minutes": 10,
  "rest_time_minutes": 20,
