  "id": "c1f3d524-24b3-5ace-b3e3-83a26e661201",
  "slug": "gluten-free-banana-bread-recipe",
  "name": "Gluten Free Banana Bread with Almonds Recipe",
  "recipe_type": null,
  "brief_description": "This Gluten Free Banana Bread with Almonds is for those of you who are searching for gluten free bread recipes. I realized that gluten free foods and recipes should be regularly added to this food blog for the sake of our friends and readers who are sensitive with gluten.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 Fahrenheit."
    },
    {
      "position": 2,
      "text": "In a mixing bowl, combine gluten-free flour, sugar, baking soda, and salt. Mix well."
    },
    {
      "position": 3,
      "text": "Stir-in the mashed bananas, eggs, vanilla extract, canola oil, and almonds. Whisk until all the ingredients are well distributed."
    },
    {
      "position": 4,
      "text": "Pour the mixture in a loaf pan."
    },
    {
      "position": 5,
      "text": "Bake for 50 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven. Let cool."
    },
    {
      "position": 7,
      "text": "Slice into individual servings."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
