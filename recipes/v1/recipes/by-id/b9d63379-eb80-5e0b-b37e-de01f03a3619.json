  "id": "b9d63379-eb80-5e0b-b37e-de01f03a3619",
  "slug": "tofu-with-mushroom-gravy",
  "name": "Tofu with Mushroom Gravy",
  "recipe_type": null,
  "brief_description": "Making Tofu with Mushroom Gravy is a nice way to prepare tofu. The procedure is simple; the ingredients are readily available in supermarkets",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the olive oil in a frying pan."
    },
    {
      "position": 2,
      "text": "Pan-fry the sliced tofu in medium heat for about 7 to 10 minutes per side. Set aside."
    },
    {
      "position": 3,
      "text": "Heat a saucepan. Add the butter and melt."
    },
    {
      "position": 4,
      "text": "When the butter becomes hot, gradually add the flour while stirring. Continue cooking while stirring gradually until the color of the mixture turns light brown."
    },
    {
      "position": 5,
      "text": "Pour-in the vegetable broth. Stir until the texture becomes smooth."
    },
    {
      "position": 6,
      "text": "Add the mushrooms. Simmer while stirring once in a while until the texture thickens and the desired consistency is achieved."
    },
    {
      "position": 7,
      "text": "Arrange the fried tofu on a serving plate. Top with mushroom gravy."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
