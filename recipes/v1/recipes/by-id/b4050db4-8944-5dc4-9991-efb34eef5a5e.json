  "id": "b4050db4-8944-5dc4-9991-efb34eef5a5e",
  "slug": "stir-fried-crabs-with-ginger-and-scallions",
  "name": "Stir Fried Crabs with Ginger and Scallion",
  "recipe_type": "appetizer",
  "brief_description": "Crispy deep-fried crabs tossed in a savory ginger and scallion sauce made with oyster sauce and sesame oil. This quick stir fry is bold, aromatic, and perfect served over steamed rice.",
  "cuisine": "Asian Chinese Filipino seafood",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the oyster sauce, sesame oil, salt, ground black pepper, sugar, garlic, cornstarch, and water in a bowl. Stir until well blended, then set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a wok or deep pan over medium-high heat."
    },
    {
      "position": 3,
      "text": "Deep fry the crabs for 3 minutes. Remove them from the wok and let the excess oil drip off."
    },
    {
      "position": 4,
      "text": "Remove most of the oil from the wok, leaving about 2 tablespoons. Saut\u00e9 the ginger and scallions for 2 minutes."
    },
    {
      "position": 5,
      "text": "Return the fried crabs to the wok. Pour in the sauce mixture, then toss to combine and cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Turn off the heat and transfer to a serving plate. Serve and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
