  "id": "c0c48898-2f8f-5b26-9f98-d3153db30465",
  "slug": "chicken-mami",
  "name": "Chicken Mami",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Filipino chicken noodle soup , which is popularly known as Chicken Mami.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken broth and water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add salt and chicken breasts. Cover and boil between low to medium heat for 30 to 35 minutes."
    },
    {
      "position": 3,
      "text": "Remove the chicken from the pot. Let it cool down. Shred the meat from the bone. Set aside. Save the broth used for boiling. It will be used later."
    },
    {
      "position": 4,
      "text": "Slice the carrot into thin strips (julienne) and then chop the Napa cabbage. Also chop the scallions. Set aside."
    },
    {
      "position": 5,
      "text": "Prepare the fresh noodles by boiling 4 cups water. Once the water starts to boil, add the noodles. Let the water boil once more, and then continue to cook the noodles for 3 minutes. Remove from the pot and arrange in a serving bowl."
    },
    {
      "position": 6,
      "text": "Top the noodles in the bowl with shredded chicken, julienne carrot, chopped cabbage, and slices of boiled eggs."
    },
    {
      "position": 7,
      "text": "Pour the hot broth into the bowl. Sprinkle with scallions and roasted or toasted garlic."
    },
    {
      "position": 8,
      "text": "Serve with a condiment composed of patis (fish sauce) and calamansi."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
