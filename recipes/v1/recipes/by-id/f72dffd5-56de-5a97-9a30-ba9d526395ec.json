  "id": "f72dffd5-56de-5a97-9a30-ba9d526395ec",
  "slug": "how-to-cook-ginataang-langka-with-tinapa-flakes",
  "name": "How to Cook Ginataang Langka with Tinapa Flakes",
  "recipe_type": null,
  "brief_description": "This Ginataang Langka with Tinapa flakes is no exception. I want to give a shout out to my mom who prepared this dish. This time, I am the food taster",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saute garlic and onion until the onion gets soft."
    },
    {
      "position": 2,
      "text": "Add the chopped unripe jackfruit. Cook for 3 to 5 minutes."
    },
    {
      "position": 3,
      "text": "Put-in the tinapa flakes (smoked fish flakes). Stir and cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the ground black pepper and chili peppers."
    },
    {
      "position": 5,
      "text": "Pour-in the coconut milk. Let boil. Add the shrimp paste and vinegar. Stir. Cover and cook in medium heat for 15 minutes while stirring occasionally."
    },
    {
      "position": 6,
      "text": "Add the malunggay leaves. Stir and continue to cook for 5 to10 minutes."
    },
    {
      "position": 7,
      "text": "Sprinkle some salt only if needed. Stir."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve with a cup of warm steamed white rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
