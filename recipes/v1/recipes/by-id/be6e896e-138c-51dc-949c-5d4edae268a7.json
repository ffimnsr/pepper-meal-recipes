  "id": "be6e896e-138c-51dc-949c-5d4edae268a7",
  "slug": "milk-candy-pastillas-de-leche-recipe",
  "name": "Pastillas de leche",
  "recipe_type": "dessert",
  "brief_description": "Pastillas de leche are sweet milk candies that are usually served for dessert. An authentic recipe will require the use of Carabao\u2019s (water buffalo) milk and cooking is also necessary.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Place the condensed milk in a large mixing bowl."
    },
    {
      "position": 2,
      "text": "Gradually fold-in the powdered milk. The texture of the mixture will be similar to dough once all the powdered milk is completely added."
    },
    {
      "position": 3,
      "text": "Scoop some of the mixture and mold into cylinders."
    },
    {
      "position": 4,
      "text": "Roll each molded cylindrical mixture on granulated sugar."
    },
    {
      "position": 5,
      "text": "Wrap in paper or cellophane."
    },
    {
      "position": 6,
      "text": "Serve for dessert. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 10,
