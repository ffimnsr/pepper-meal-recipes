  "slug": "thai-basil-chicken-recipe",
  "name": "Basil Chicken Recipe",
  "recipe_type": null,
  "brief_description": "Basil Chicken is a popular spicy Asian recipe. This is usually prepared using ground chicken \u2013 although there are some recipes that call for finely chopped chicken breasts.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the garlic and then add the chili flakes"
    },
    {
      "position": 3,
      "text": "Put-in the ground chicken. Cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in the fish sauce and then add the brown sugar. Cook I medium heat for 5 to 10 minutes or until the liquid evaporates."
    },
    {
      "position": 5,
      "text": "Add the basil and ground black pepper. Stir and cook for 1 to 2 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
