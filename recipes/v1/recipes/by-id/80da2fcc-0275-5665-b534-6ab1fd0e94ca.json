  "id": "80da2fcc-0275-5665-b534-6ab1fd0e94ca",
  "slug": "lengua-con-setas-recipe",
  "name": "Lengua Con Setas Recipe",
  "recipe_type": null,
  "brief_description": "Lengua Con Setas or Ox Tongue with mushroom is a delicious stew that you can cook at home. This recipe will guide you through the process.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil the Ox tongue in about 1 quart of water for 90 minutes or until tender (you can use a pressure cooker to quickly tenderize it)."
    },
    {
      "position": 2,
      "text": "Let the tongue cool down, and then scrape out the skin."
    },
    {
      "position": 3,
      "text": "Slice the tongue into serving pieces."
    },
    {
      "position": 4,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 5,
      "text": "Saute onion and garlic."
    },
    {
      "position": 6,
      "text": "When the onion becomes soft, put-in the Ox tongue. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add oyster sauce, soy sauce, sugar, and Worcestershire sauce. Stir and then simmer for a minute."
    },
    {
      "position": 8,
      "text": "Add the mushrooms and Pour-in water. Let boil and then simmer until the liquid reduces."
    },
    {
      "position": 9,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 10,
      "text": "Put-in the cornstarch and water mixture. Stir. Cook until the sauce thickens."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Sprinkle parsley flakes on top."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 150,
  "preparation_time_minutes": 10,
