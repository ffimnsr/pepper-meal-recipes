  "id": "c34f4956-301e-58b8-aa6d-ebd11b1b26f3",
  "slug": "pancit-malabon-recipe",
  "name": "Pancit Malabon Recipe",
  "recipe_type": null,
  "brief_description": "Pansit Malabon is a flavorful noodle dish that originated in the City of Malabon. This dish resembles the Pancit Palabok but the array of seafood toppings and the traditional tough and thick rice noodles distinguishes this dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the noodles according to package instructions. If you are using the traditional Pancit Malabon noodles, you will need to soak it in water overnight before cooking. Set aside."
    },
    {
      "position": 2,
      "text": "Start making the sauce by saut\u00e9ing the minced garlic and onion."
    },
    {
      "position": 3,
      "text": "Add chopped boiled pork and cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add fish sauce and ground black pepper then stir."
    },
    {
      "position": 5,
      "text": "Pour-in shrimp juice and annatto water and let boil."
    },
    {
      "position": 6,
      "text": "Add pounded pork rinds (chicharon) then stir."
    },
    {
      "position": 7,
      "text": "Simmer for 2 to 3 minutes then turn off heat."
    },
    {
      "position": 8,
      "text": "Place the cooked noodles in a large bowl then pour-in the sauce and mix well."
    },
    {
      "position": 9,
      "text": "Transfer the sauce and noodle mixture in a wide serving plate and arrange the tinapa flakes, eggs, parsley, garlic, and cabbage on top."
    },
    {
      "position": 10,
      "text": "Serve with lemon or calamansi and a lot of love. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
  "difficulty": "hard",
