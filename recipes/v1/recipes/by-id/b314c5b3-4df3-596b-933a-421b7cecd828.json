  "id": "b314c5b3-4df3-596b-933a-421b7cecd828",
  "slug": "ginisang-sigarilyas-recipe",
  "name": "Ginisang Sigarilyas",
  "recipe_type": null,
  "brief_description": "Sauteed Winged Bean with Pork",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic, onion and tomato."
    },
    {
      "position": 3,
      "text": "Add pork once the onion and tomato soften. Continue cooking until the color of the pork turns light brown."
    },
    {
      "position": 4,
      "text": "Pour water into the pan. Cover and continue cooking until the water completely evaporates."
    },
    {
      "position": 5,
      "text": "Add winged beans. Saute for 3 minutes."
    },
    {
      "position": 6,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 7,
      "text": "Serve hot with warm rice. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": null,
