  "slug": "simple-sun-dried-tomato-and-basil-spaghetti",
  "name": "Simple Sun-Dried Tomato and Basil Spaghetti",
  "recipe_type": null,
  "brief_description": "Pasta dishes are fast and easy to prepare. Simple Sun-Dried Tomato and Basil Spaghetti is no exception. This delicious and simple spaghetti can be done in less than 30 minutes. It is also budget friendly.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the spaghetti according to package instructions. Arrange in a large mixing bowl."
    },
    {
      "position": 2,
      "text": "Drizzle the olive oil. Toss."
    },
    {
      "position": 3,
      "text": "Add the tomato and basil. Toss and make sure that all the ingredients are well blended. Note: you can also use chopped fresh basil. If you are using fresh basil, use at least 8 leaves."
    },
    {
      "position": 4,
      "text": "Mix-in the Parmesan cheese. Transfer to a pasta bowl."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 10,
