  "id": "0739f8c6-f04a-53e4-9150-7f8597813af0",
  "slug": "royal-bibingka",
  "name": "Royal Bibingka",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for special royal bibingka.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350F."
    },
    {
      "position": 2,
      "text": "Combine the glutinous rice flour, sweet rice flour, and sugar in a bowl. Whisk until well blended. Set aside."
    },
    {
      "position": 3,
      "text": "In a clean bowl, beat the eggs, pour the evaporated milk and coconut milk and then continue to beat until all the ingredients are well incorporated."
    },
    {
      "position": 4,
      "text": "Gradually add the rice flour mixture to the bowl with wet ingredients and continue to whisk until the texture becomes soft."
    },
    {
      "position": 5,
      "text": "Brush margarine into the aluminum molds and then pour the mixture equally between all molds. Temporarily cover the molds with foil."
    },
    {
      "position": 6,
      "text": "Bake for 18 minutes."
    },
    {
      "position": 7,
      "text": "Remove the cover. Brush with more margarine and sprinkle cheese on top. Put back in the oven and continue to bake in 350F for 22 minutes. Set the oven to broil and broil for 8 minutes."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
