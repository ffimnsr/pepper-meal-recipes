  "id": "61fffa7b-b324-5a42-82e8-82b6cbd314a3",
  "slug": "fruit-cocktail-float",
  "name": "Fruit Cocktail Float",
  "recipe_type": "dessert",
  "brief_description": "Fruit Cocktail Float is a quick and easy dessert dish that you can whip-up anytime. It does not involve baking and it is so easy to make.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Drain the fruit cocktail by pouring each can in a strainer. Set aside."
    },
    {
      "position": 2,
      "text": "Prepare the whipping cream mixture by pouring the heavy whipping cream in a mixing bowl. Whisk in medium speed using an electric mixer. Set to high speed after 2 minutes and continue to whisk until soft peaks form (around 5 more minutes)."
    },
    {
      "position": 3,
      "text": "Stir-in the table cream, condensed milk, and vanilla extract. Continue to whisk for 1 to 2 minutes."
    },
    {
      "position": 4,
      "text": "Arrange a layer of Graham crackers at the bottom of a wide 8x8 baking pan."
    },
    {
      "position": 5,
      "text": "Pour-in half of the whipping cream mixture. Spread."
    },
    {
      "position": 6,
      "text": "Create another layer by adding half of the fruit cocktail. Spread."
    },
    {
      "position": 7,
      "text": "Make another layer of Graham crackers. Top with the remaining heavy cream mixture."
    },
    {
      "position": 8,
      "text": "Arrange the remaining fruit cocktail on top and add some cherries."
    },
    {
      "position": 9,
      "text": "Sprinkle the crushed Graham on top."
    },
    {
      "position": 10,
      "text": "Refrigerate for 3 to 5 hours. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 20,
