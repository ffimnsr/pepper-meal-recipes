  "id": "75e926bf-16d6-53d9-91a5-9e4aaafcec19",
  "slug": "how-to-cook-baked-tilapia-with-grilled-pineapple-salsa",
  "name": "Baked Tilapia with Grilled Pineapple Salsa",
  "recipe_type": null,
  "brief_description": "Baked Tilapia with Grilled Pineapple Salsa is a delicous Tilapia Recipe to prepare during summer. It is fresh tasting and delicious!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Grill the pineapple slices for about 3 minutes per side."
    },
    {
      "position": 2,
      "text": "Cube the grilled pineapple and combine with tomato, cilantro, jalapeno pepper, and lime juice. Set aside."
    },
    {
      "position": 3,
      "text": "Preheat oven to 400 degrees Fahrenheit."
    },
    {
      "position": 4,
      "text": "Brush tilapia fillets with cooking oil then sprinkle some salt, pepper, chili powder, and garlic powder."
    },
    {
      "position": 5,
      "text": "Place an aluminum foil over a baking tray and coat with cooking oil."
    },
    {
      "position": 6,
      "text": "Arrange the tilapia over the baking tray then bake for 5 to 7 minutes."
    },
    {
      "position": 7,
      "text": "Transfer the baked tilapia to a serving dish then place the pineapple salsa mixture on the side."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 7,
  "preparation_time_minutes": 5,
