  "id": "1c5a9fbc-6061-50ee-a799-359e7392bda3",
  "slug": "dinuguan-laman-loob",
  "name": "Dinuguan Laman-Loob Recipe (Blood Stew)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Dinuguan Lamang loob. It is basically a type of blood stew with pork innards.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a large cooking pot and pour-in oil."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onion."
    },
    {
      "position": 3,
      "text": "Add pig\u2019s heart, liver, and small intestine then cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Add cooking wine, fish sauce, ground black pepper, and water. Simmer for 30 to 35 minutes."
    },
    {
      "position": 5,
      "text": "Add the powdered tamarind soup base mix, long green chili, and vinegar. Allow to re-boil."
    },
    {
      "position": 6,
      "text": "Stir continuously while pouring-in pork blood. Cook for 15 minutes more under low to medium heat while stirring once in awhile."
    },
    {
      "position": 7,
      "text": "Turn-off heat and transfer to a serving bowl."
    },
    {
      "position": 8,
      "text": "Serve hot with buttered puto. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
