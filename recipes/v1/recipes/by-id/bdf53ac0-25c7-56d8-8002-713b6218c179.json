  "id": "bdf53ac0-25c7-56d8-8002-713b6218c179",
  "slug": "batangas-kaldereta",
  "name": "Batangas Kaldereta",
  "recipe_type": "main",
  "brief_description": "Batangas Kaldereta is a tasty Filipino stew with a rich, flavorful sauce made from liver spread and spices, giving it a savory and slightly spicy kick. It&#039;s usually made with beef that&#039;s simmered until tender and is packed with garlic, onions, and chili peppers, making it perfect to enjoy with rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the beef and soy sauce in a bowl. Mix well. Marinate for 30 minutes."
    },
    {
      "position": 2,
      "text": "Melt the margarine in a pan. Add the annatto powder and stir."
    },
    {
      "position": 3,
      "text": "Add the garlic and saut\u00e9 until it starts to brown. Add the onion and continue to saut\u00e9 until it becomes soft."
    },
    {
      "position": 4,
      "text": "Add the marinated beef. Saut\u00e9 until the outer part turns light brown. Make sure to stir frequently while cooking to ensure that all sides are cooked evenly."
    },
    {
      "position": 5,
      "text": "Add the Worcestershire sauce and pickle relish. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour in the water and let it boil."
    },
    {
      "position": 7,
      "text": "Add the beef powder. Stir and cover the pan. Simmer until the beef becomes tender."
    },
    {
      "position": 8,
      "text": "Add the liver spread, peanut butter (optional), cheese, and chili peppers. Stir until the sauce smoothens. The sauce will thicken partially after a few minutes."
    },
    {
      "position": 9,
      "text": "Continue cooking on low heat for 5 minutes. Make sure to stir occasionally to prevent the sauce and meat from sticking to the bottom of the pan."
    },
    {
      "position": 10,
      "text": "Add the breadcrumbs. This ingredient will make the sauce thicker."
    },
    {
      "position": 11,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 12,
      "text": "Serve and dig in!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 75,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
