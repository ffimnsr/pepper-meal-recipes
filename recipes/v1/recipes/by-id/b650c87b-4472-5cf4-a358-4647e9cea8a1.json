  "slug": "filipino-food-kakanin-cuchinta-kutsinta-recipe",
  "name": "Kutsinta Recipe",
  "recipe_type": "dessert",
  "brief_description": "Kutsinta or Kutchinta is a sticky rice cake. This is one of the most popular Filipino Snacks. Watch the cooking video to learn the recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, combine all the dry ingredients starting from the rice flour, all-purpose flour, and brown sugar then mix all the ingredients."
    },
    {
      "position": 2,
      "text": "While mixing, add water gradually and continue to mix until all ingredients are completely distributed."
    },
    {
      "position": 3,
      "text": "Add lye water and anatto water (soak the anatto seed in 3 tbsp water) then continue mixing."
    },
    {
      "position": 4,
      "text": "Place the mixture into individual molds and steam for 40 minutes to an hour."
    },
    {
      "position": 5,
      "text": "Serve with grated or shredder coconut on top. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 20,
