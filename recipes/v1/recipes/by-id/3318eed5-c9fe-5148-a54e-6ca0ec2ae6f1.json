  "id": "3318eed5-c9fe-5148-a54e-6ca0ec2ae6f1",
  "slug": "pansit-miki-guisado",
  "name": "Pancit Miki Guisado Recipe",
  "recipe_type": null,
  "brief_description": "Pancit Miki are fresh thick egg noodles. These noodles are thicker than the egg noodles used in beef mami, and a little thinner compared to Lomi noodles.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok."
    },
    {
      "position": 2,
      "text": "Put-in chicken and cook for 3 minutes."
    },
    {
      "position": 3,
      "text": "Add pork belly. Stir and cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add sherry and onions. Cook until onions becomes soft."
    },
    {
      "position": 5,
      "text": "Add salt, pepper, soy sauce, and oyster sauce. Stir and cook for 6 to 8 minutes. Note: Add a little water as necessary."
    },
    {
      "position": 6,
      "text": "Put-in the cabbage and carrots. Cook until vegetables are tender."
    },
    {
      "position": 7,
      "text": "Put-in the miki noodles, and then stir. Cook for another 3 minutes."
    },
    {
      "position": 8,
      "text": "Turn-off heat and transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
