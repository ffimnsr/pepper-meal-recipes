  "id": "374c3ceb-c8ae-5012-92f8-36122f7f3e95",
  "slug": "chicken-carbonara",
  "name": "Chicken Carbonara",
  "recipe_type": null,
  "brief_description": "Chicken Carbonara is a rich and delicious pasta dish that I always enjoy with a glass of wine. This dish makes use of spaghetti noodles.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the spaghetti noodles according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "In a large bowl, combine the egg yolk, heavy cream, Parmesan cheese, basil, and parsley. Whisk and set aside."
    },
    {
      "position": 3,
      "text": "Heat the oil in a wide cooking pot or casserole."
    },
    {
      "position": 4,
      "text": "Add-in the pancetta. Cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the garlic and cook until it turns light brown."
    },
    {
      "position": 6,
      "text": "Add-in the shredded baked chicken. Stir. Cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Put-in the cooked spaghetti noodles. Toss."
    },
    {
      "position": 8,
      "text": "Adjust the heat to low and add the heavy cream and egg mixture. Toss until all the ingredients are well distributed."
    },
    {
      "position": 9,
      "text": "Season with salt and pepper"
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Garnish with some grated lemon peel on top."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
