  "id": "a59701d2-d7ff-5623-aea2-661b1aad992f",
  "slug": "kinamatisang-baka",
  "name": "Kinamatisang Baka",
  "recipe_type": "soup",
  "brief_description": "Beef neck bones cooked with snake beans, sweet potato leaves, and tomato.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Add beef. Let boil. Continue boiling for 60 to 890 minutes or until the meat tenderizes."
    },
    {
      "position": 2,
      "text": "Remove the beef from the pot. Set aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan. Saute onion and garlic. Add tomato. Cook until onion and tomato softens."
    },
    {
      "position": 4,
      "text": "Put the beef neck bones into the pot. Saute for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in beef stock (water used to tenderize beef). Let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Beef Cube. Stir. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Season with patis and ground black pepper."
    },
    {
      "position": 8,
      "text": "Add sitaw. Cook for 5 minutes."
    },
    {
      "position": 9,
      "text": "Add sweet potato leaves (dahon ng kamote). Cover and cook for 2 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve hot with rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 105,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
