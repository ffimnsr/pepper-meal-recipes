  "slug": "how-to-make-homemade-potato-chips",
  "name": "Homemade Potato Chips Recipe",
  "recipe_type": "snack",
  "brief_description": "This Tried and Tested Homemade Potato Chips Recipe tastes perfect. Eat it along with your favorite sandwich or plainly as a snack.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Slice the potatoes as thinly as possible then place in an open container"
    },
    {
      "position": 2,
      "text": "Pour the water in the container with sliced potatoes (you may add additional water as needed)."
    },
    {
      "position": 3,
      "text": "Add the salt and stir a little to completely dilute in water. Let the potatoes soak for a minimum of 2 hours."
    },
    {
      "position": 4,
      "text": "Deep fry the potatoes until the color turn golden brown and the texture become crispy."
    },
    {
      "position": 5,
      "text": "Remove from the deep-fryer and place in a container (don't forget to place paper towels on the container to absorb oil; add a dash of salt if desired)."
    },
    {
      "position": 6,
      "text": "Serve. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 120,
