  "id": "6a1d31a1-4b56-520f-bff6-3ddc1bb8b9a4",
  "slug": "chicken-inasal-bbq-recipe",
  "name": "Chicken Inasal BBQ",
  "recipe_type": null,
  "brief_description": "Filipino-style grilled chicken marinated in lemongrass, ginger, coconut vinegar, and annatto oil, then skewered and basted with margarine while grilling.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange chicken slices in a bowl. Add all the marinade ingredients with the chicken. Toss until well blended. Cover the bowl and refrigerate for at least 3 hours."
    },
    {
      "position": 2,
      "text": "Skewer the chicken slices into a bamboo skewer (also known as barbecue stick). Set aside."
    },
    {
      "position": 3,
      "text": "Heat-up the grill."
    },
    {
      "position": 4,
      "text": "Prepare the basting sauce by combining the annatto oil, margarine, and salt. Mix well. Microwave for 12 seconds."
    },
    {
      "position": 5,
      "text": "Grill the chicken for 2 to 4 minutes per side, brushing basting sauce on top each time, until fully cooked."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with a dip of soy sauce and calamansi with chili pepper."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 180,
