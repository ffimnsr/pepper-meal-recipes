  "id": "1eb0fefb-fa24-5b95-ac16-cdda801f7de9",
  "slug": "braised-pork-ribs-recipe",
  "name": "Braised Pork Ribs Recipe",
  "recipe_type": null,
  "brief_description": "Braised Pork Ribs is a delicious rib recipe that you can easily prepare for your family. This dish is tender, delightful, it is best served with white rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat olive oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "When the oil becomes hot, saute the onion."
    },
    {
      "position": 3,
      "text": "Put-in the pork ribs. Cook for about 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in red wine and beef broth. Let boil."
    },
    {
      "position": 5,
      "text": "Add the carrots and thyme. Simmer for 45 minutes."
    },
    {
      "position": 6,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
