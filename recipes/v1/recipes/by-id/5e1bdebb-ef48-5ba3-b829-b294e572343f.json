  "id": "5e1bdebb-ef48-5ba3-b829-b294e572343f",
  "slug": "orange-glazed-pork-recipe",
  "name": "Orange Glazed Pork",
  "recipe_type": "dessert",
  "brief_description": "Crispy bite-sized pork coated with sweet and tangy orange sauce",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt and ground black pepper all over the pork. Toss the pork to distribute the seasoning. Let it stay for 20 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, heat the oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Once the oil becomes hot, dredge the pork in cornstarch then deep fry for 5 to 8 minutes or until the color turns golden brown and the texture becomes crisp."
    },
    {
      "position": 4,
      "text": "Remove the cooked pork from the cooking pot. Place in a large mixing bowl. Set aside."
    },
    {
      "position": 5,
      "text": "Make the orange glaze by combining water, vinegar, and soy sauce in a saucepan. Stir and let boil."
    },
    {
      "position": 6,
      "text": "Add the garlic powder and brown sugar. Stir and cook until the liquid reduces in half."
    },
    {
      "position": 7,
      "text": "Pour the glaze all over the pork. Toss to coat the pork completely."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Sprinkle the chopped green onions on top."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 20,
