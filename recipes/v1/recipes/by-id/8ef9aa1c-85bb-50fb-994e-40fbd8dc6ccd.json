{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "8ef9aa1c-85bb-50fb-994e-40fbd8dc6ccd",
  "slug": "maxs-style-fried-chicken-with-kamote-fries",
  "name": "Max\u2019s Style Fried Chicken with Kamote Fries",
  "recipe_type": "dessert",
  "brief_description": "Filipino style fried chicken with sweet potato fries.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add onion, peppercorns, and Knorr chicken cube."
    },
    {
      "position": 2,
      "text": "Prepare chicken by inserting green onion and lemongrass into cavity."
    },
    {
      "position": 3,
      "text": "Add chicken into the pot. Boil between low to medium heat for 35 minutes. Turn the chicken over and continue boiling the opposite side for 15 minutes. Remove from the pot and let it cool down."
    },
    {
      "position": 4,
      "text": "Start preparing the kamote fries by boiling sliced kamote in the remaining stock used to cook the chicken for 3 minutes. Remove from the pot. Let dry and set aside."
    },
    {
      "position": 5,
      "text": "Clear the cavity of the chicken and rub Knorr Liquid Seasoning all over . Air dry for at least 3 hours. Slice the chicken in half."
    },
    {
      "position": 6,
      "text": "Pour oil in a pot and heat to 360F. Deep-fry chicken for 5 minutes (skin part down). Turn it over and deep-fry opposite side for 3 minutes. Remove from the pan and perform the same steps on the other half chicken."
    },
    {
      "position": 7,
      "text": "Put the first half chicken that was fried earlier back into the pot, skin side down. Fry for 3 minutes. Do the same to the remaining half. Remove from the pot and set aside."
    },
    {
      "position": 8,
      "text": "Deep-fry kamote in remaining oil until golden brown and crispy."
    },
    {
      "position": 9,
      "text": "Arrange fried chicken with kamote fries on a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": null,
