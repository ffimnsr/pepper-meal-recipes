  "id": "111bdcec-eb12-5f27-bc26-09f2920663b0",
  "slug": "spicy-chicken-in-coconut-milk-ginataang-manok",
  "name": "Spicy Chicken in Coconut Milk (Ginataang Manok)",
  "recipe_type": null,
  "brief_description": "Spicy Chicken in Coconut Milk or Spicy Ginataang Manok is a Filipino Chicken dish that makes use of coconut cream or coconut milk and lots of spicy chili.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and then pour-in the coconut cream."
    },
    {
      "position": 2,
      "text": "Add ginger, garlic, and onion. Stir and let boil."
    },
    {
      "position": 3,
      "text": "Put-in the chicken. Let the liquid reboil."
    },
    {
      "position": 4,
      "text": "Add the chili and turmeric powder. Stir. Cover and simmer for 35 minutes."
    },
    {
      "position": 5,
      "text": "Add the mooring leaves (malunggay). Stir and cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add the fish sauce. Stir and cook for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
