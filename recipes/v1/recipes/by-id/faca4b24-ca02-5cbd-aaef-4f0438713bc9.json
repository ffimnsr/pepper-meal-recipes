  "id": "faca4b24-ca02-5cbd-aaef-4f0438713bc9",
  "slug": "pocherong-manok",
  "name": "Pocherong Manok",
  "recipe_type": "soup",
  "brief_description": "Pocherong Manok is a Filipino chicken stew simmered in a light tomato-based broth with vegetables and saba bananas, creating a comforting balance of savory and naturally sweet flavors.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a wok. Fry the bananas and potatoes until it starts to brown. Set aside."
    },
    {
      "position": 2,
      "text": "Leave around 3 tablespoons of oil in the wok. Pan-fry the chicken for 2 minutes on each side. Remove the chicken and set aside."
    },
    {
      "position": 3,
      "text": "Add 2 tablespoons more of cooking oil. Saut\u00e9 the onion for 1 minute."
    },
    {
      "position": 4,
      "text": "Stir-in the garlic. Continue saut\u00e9ing until it starts to brown and then add the tomatoes. Saut\u00e9 it for 1 minute."
    },
    {
      "position": 5,
      "text": "Add the chorizo. Stir and then add back the chicken. Continue to saut\u00e9 this for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the tomato paste and pour 2 cups of water into the wok. Let it boil."
    },
    {
      "position": 7,
      "text": "Add Maggi Magic Chicken Cube. Stir,"
    },
    {
      "position": 8,
      "text": "Add the chickpeas, potatoes, and bananas. Cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Put the long green beans and cabbage. Cover and continue cooking for 3 minutes."
    },
    {
      "position": 10,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 11,
      "text": "Add the bok choy. Cover the wok. Turn the heat off and let the residual heat cook it for 2 minutes."
    },
    {
      "position": 12,
      "text": "Transfer to a serving bowl. Serve with rice."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 25,
