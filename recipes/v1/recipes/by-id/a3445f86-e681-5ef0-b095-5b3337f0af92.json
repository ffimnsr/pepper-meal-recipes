  "id": "a3445f86-e681-5ef0-b095-5b3337f0af92",
  "slug": "luncheon-meat-mac-salad-with-cheese",
  "name": "Luncheon Meat Mac Salad with Cheese",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for Luncheon Meat Mac Salad with Cheese",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add \u00bd teaspoon salt. Put the macaroni into the pot. Cover and let the liquid re-boil. Continue to cook for 7 minutes. Drain water from the pot and around 4 to 5 cups of water in room temperature. Drain one more time. Set the macaroni aside."
    },
    {
      "position": 3,
      "text": "Prepare the dressing by combining Lady\u2019s Choice Mayonnaise, onion, sweet pickle relish, salt, ground black pepper, and cheese. Mix well."
    },
    {
      "position": 4,
      "text": "Add luncheon meat and macaroni. Fold until well blended."
    },
    {
      "position": 5,
      "text": "Season with additional salt and ground black pepper, if needed"
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve right away or chill inside the fridge before serving."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
