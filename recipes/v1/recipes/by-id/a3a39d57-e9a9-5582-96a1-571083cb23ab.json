  "id": "a3a39d57-e9a9-5582-96a1-571083cb23ab",
  "slug": "tortang-talong-crabmeat-eggplant-omelet-crab",
  "name": "Tortang Talong with Crabmeat (Eggplant Omelet with Crab)",
  "recipe_type": "main",
  "brief_description": "Tortang Talong with Crab Meat is a tasty Filipino dish where tender eggplant is mixed with crabmeat and a fluffy beaten eggs. Give it a try and enjoy a new favorite meal!",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan and pour-in 3 to 4 tablespoons of oil."
    },
    {
      "position": 2,
      "text": "Saute the onion until soft."
    },
    {
      "position": 3,
      "text": "Add the crabmeat. Stir fry for 2 to 3 minutes."
    },
    {
      "position": 4,
      "text": "Add salt, ground black pepper, and garlic powder.Cook for 1 minute. Transfer to a bowl and then set aside."
    },
    {
      "position": 5,
      "text": "Peel the eggplants. Make sure to completely remove the skin."
    },
    {
      "position": 6,
      "text": "Lay a piece of eggplant flat in a plate and then flatten it using a fork."
    },
    {
      "position": 7,
      "text": "Heat a clean pan and pour-in remaining oil."
    },
    {
      "position": 8,
      "text": "Dip the flattened eggplant in beaten egg. Put in the pan with oil to fry. Scoop some of the cooked crabmeat and spread on top of the eggplant. Pour 2 to 3 tablespoons of beaten eggs over the meat.Push or scoop hot oil over the eggplant to partially cook the egg. This will hold the crabmeat and prevent it from falling."
    },
    {
      "position": 9,
      "text": "After 3 minutes, turn over the eggplant using a spatula. Cook the other side for 3 to 5 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 8,
