  "id": "c3bb0c5c-e3d2-5364-ad5b-72a980613bec",
  "slug": "laing-recipe",
  "name": "Laing Recipe",
  "recipe_type": "main",
  "brief_description": "Taro leaves with chili peppers and pork cooked in coconut milk with bagoong alamang.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the coconut milk, pork, shrimp paste, ginger, onion, and garlic in a cooking pot. Heat the pot and let boil."
    },
    {
      "position": 2,
      "text": "Once the mixture starts to boil, gently stir to mix the ingredients. Cover the pot and simmer for 15 to 20 minutes. Make sure to stir once in a while to prevent the ingredients from sticking on the bottom of the cooking pot."
    },
    {
      "position": 3,
      "text": "Add the dried taro leaves. Do not stir. Let it stay until the leaves absorb the coconut milk. This takes about 20 to 30 minutes. You can gently push the leaves down so that it can absorb more coconut milk."
    },
    {
      "position": 4,
      "text": "Once the leaves absorb the coconut milk, stir the leaves and then continue to cook for to 10 minutes."
    },
    {
      "position": 5,
      "text": "Pour the coconut cream into the cooking pot. Add the red chilies. Stir. Cook for 10 to 12 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 10,
