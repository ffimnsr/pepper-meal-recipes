  "id": "17a7b5ac-9d81-507b-b627-77a2b7dd6720",
  "slug": "masarsang-menudo-recipe",
  "name": "Masarsang Menudo",
  "recipe_type": "main",
  "brief_description": "Saucy Filipino menudo. This recipe is timely for the holidays!",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot. Saute half of the onion and garlic. Add liver once the onion softens and continue cooking for 1 \u00bd minutes while stirring. Remove all ingredients from the pot. Set aside."
    },
    {
      "position": 2,
      "text": "Using the remaining oil, saute remaining garlic and onion. Add pork slices. Continue sauteeing until the outer part of the pork turns light brown."
    },
    {
      "position": 3,
      "text": "Pour soy sauce and tomato sauce. Stir."
    },
    {
      "position": 4,
      "text": "Add Knorr Pork Cube and water. Let boil."
    },
    {
      "position": 5,
      "text": "Add laurel leaves. Cover the pot and adjust heat to low. Continue cooking for 30 minutes."
    },
    {
      "position": 6,
      "text": "Add the cooked liver back into the pot along with the hotdog, potato and carrot. Stir. Cook for 10 minutes."
    },
    {
      "position": 7,
      "text": "Add bell pepper and green peas. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt, ground black pepper, and sugar."
    },
    {
      "position": 9,
      "text": "Finish by adding the cheese."
    },
    {
      "position": 10,
      "text": "Serve warm over rice. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
