  "id": "888352e9-2be8-5234-bd9c-a5dc1232f80d",
  "slug": "sizzling-crispy-sisig",
  "name": "Sizzling Crispy Sisig",
  "recipe_type": "main",
  "brief_description": "Sizzling Crispy Sisig is a great dish to prepare during Christmas dinner or in any special occasion. It has a nice texture and the flavor is awesome.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a deep cooking pot or deep fryer. Fry the boiled pork belly until golden brown and crispy. Chop the crispy pork belly into small pieces. Set aside."
    },
    {
      "position": 2,
      "text": "Heat half of the margarine in a pan. Saut\u00e9 half of the onions until soft. Add chopped pork. Saute for 30 seconds."
    },
    {
      "position": 3,
      "text": "Add Knorr SavorRich. Stir and then add chili peppers and season with ground black pepper and soy sauce. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add Lady\u2019s Choice Mayonnaise. Stir and add remaining onion. Set aside."
    },
    {
      "position": 5,
      "text": "Heat a metal plate (sizzling plate) on a stovetop. Melt remaining margarine. Transfer the crispy pork sisig into the metal plate. Let it stay for 30 seconds."
    },
    {
      "position": 6,
      "text": "Serve with warm rice and your favorite beverage. Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 60,
