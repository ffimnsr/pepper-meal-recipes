  "id": "97b4adcc-0d63-5fd3-8f67-7de1373c3e4a",
  "slug": "fruit-salad-recipe",
  "name": "Fruit Salad Recipe",
  "recipe_type": "salad",
  "brief_description": "This Fresh and Sweet Fruit Salad Recipe is the best dessert that you can have. This is high in antioxidants which makes you healthy and feel good.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Drain the juice from the fruit cocktail and transfer the canned fruits in a bowl."
    },
    {
      "position": 2,
      "text": "Combine the fruit cocktail, strawberries, blueberries, kiwi, and nata de coco then toss lightly."
    },
    {
      "position": 3,
      "text": "Add the condensed milk then mix lightly. Be extra careful so that the fruits will remain intact."
    },
    {
      "position": 4,
      "text": "Add the table cream / medium cream then mix again. Make sure that the cream is properly distributed amongst the fruits."
    },
    {
      "position": 5,
      "text": "Refrigerate for at least 3 hours."
    },
    {
      "position": 6,
      "text": "Serve Chilled. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 30,
