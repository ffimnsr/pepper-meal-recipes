{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "1dfe71c1-5fa6-5cab-94ff-59cae78d1fa5",
  "slug": "pork-tinola",
  "name": "Pork Tinola Recipe",
  "recipe_type": "soup",
  "brief_description": "Pork Tinola is a delicious Filipino soup dish. Cubed pork butt or pork belly are cooked and tenderized in a stock with ginger and beef broth.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a deep cooking pot."
    },
    {
      "position": 2,
      "text": "When the oil is hot, saute the garlic, ginger, and onion. Cook until the onion is soft."
    },
    {
      "position": 3,
      "text": "Put-in the pork and then cook for 5 minutes or until it browns."
    },
    {
      "position": 4,
      "text": "Add-in the ground black pepper. Stir."
    },
    {
      "position": 5,
      "text": "Pour-in the beef broth. Let boil."
    },
    {
      "position": 6,
      "text": "Pour 1 cup of rice washing. Allow the liquid to reboil. Cover and simmer for 45 to 60 minutes or until the pork becomes tender. Add the remaining rice washing once the pork is tender. Allow to re-boil."
    },
    {
      "position": 7,
      "text": "Add the chayote wedges. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Pour the fish sauce and stir."
    },
    {
      "position": 9,
      "text": "Add the spinach. Cover the cooking pot and then turn the heat-off. Let the residual heat cook the spinach."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve with white rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
