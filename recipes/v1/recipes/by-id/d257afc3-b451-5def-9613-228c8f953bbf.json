  "id": "d257afc3-b451-5def-9613-228c8f953bbf",
  "slug": "pandesal-and-sardines-pizza",
  "name": "Pandesal and Sardines Pizza",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pandesal and Sardines Pizza",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 370F"
    },
    {
      "position": 2,
      "text": "Slice the pandesal in half. Set aside"
    },
    {
      "position": 3,
      "text": "Open the cans of sardines. Separate the fish from the tomato sauce."
    },
    {
      "position": 4,
      "text": "Combine tomato paste, 2 tablespoons of sauce from the sardines, and Italian seasoning. Stir."
    },
    {
      "position": 5,
      "text": "Spread the tomato paste mixture over every slice of pandesal. Arrange 1 to 2 pieces of sardines over each pandesal. Top with a generous amount of cheese."
    },
    {
      "position": 6,
      "text": "Arrange on a baking tray. Bake for 5 to 8 minutes."
    },
    {
      "position": 7,
      "text": "Remove from the oven. Top with parsley and red pepper flakes.Serve as snack."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 10,
