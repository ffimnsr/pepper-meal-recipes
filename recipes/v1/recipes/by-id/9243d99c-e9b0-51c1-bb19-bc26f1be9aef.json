  "id": "9243d99c-e9b0-51c1-bb19-bc26f1be9aef",
  "slug": "chicken-sotanghon-soup-recipe",
  "name": "Chicken Sotanghon Soup",
  "recipe_type": "soup",
  "brief_description": "A Filipino version of chicken noodle soup. This dish is composed of shredded chicken breast and vermicelli with carrots and cabbage.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the chicken by boiling water ina cooking pot. Add bay leaf. Put the chicken breast in the pot. Cover and boil in medium heat for 20 minutes. Remove chicken from the pot and put in a clean plate. Let it cool down. Save the chicken stock. Shred the chicken and set aside.&nbsp;"
    },
    {
      "position": 2,
      "text": "Heat oil in a large pot. Saute garlic until light brown. Add onion and celery. Saute until onion softens.&nbsp;"
    },
    {
      "position": 3,
      "text": "Put the shredded chicken in the pot and then saute for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour chicken stock and let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Chicken Cube. Stir."
    },
    {
      "position": 6,
      "text": "Add annatto water and sotanghon noodles. Cover and cook for 10 minutes."
    },
    {
      "position": 7,
      "text": "Put carrots and cabbage into the pot. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 9,
      "text": "Put some roasted garlic and chopped scallions. Stir."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
