  "id": "42433fcc-d63a-5f1a-aa9d-7e60d27b2e77",
  "slug": "spicy-daing-na-bangus",
  "name": "Spicy Daing na Bangus",
  "recipe_type": null,
  "brief_description": "Filipino breakfast staple featuring butterflied milkfish marinated in vinegar, garlic, chili, and spices, then pan-fried until crispy and golden brown. Traditionally served with garlic fried rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the fish in a large plate belly part facing upwards."
    },
    {
      "position": 2,
      "text": "Pour Knorr Liquid Seasoning all over the fish. Distribute equally using your hands. Let it stay for 5 minutes."
    },
    {
      "position": 3,
      "text": "Rub ground black pepper, chili, and garlic. Pour the vinegar. Flip the fish over so that the belly part faces downward. This will let the meat absorb the seasoning and spices better."
    },
    {
      "position": 4,
      "text": "Cover the fish with a clear plastic wrap. Refrigerate overnight."
    },
    {
      "position": 5,
      "text": "Heat oil in a wide pan. Once the oil gets hot, pan fry the fish until golden brown. Turn the fish over using a wide spatula to cook the opposite side. Note: Use a splatter screen to protect yourself from hot oil."
    },
    {
      "position": 6,
      "text": "Remove the fish from the pan. Arrange in a plate."
    },
    {
      "position": 7,
      "text": "Serve with garlic fried rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy."
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
