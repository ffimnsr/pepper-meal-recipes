  "id": "0d1a2de0-905c-52ec-938c-19ec6323be38",
  "slug": "spicy-ginataang-baboy-with-papaya-and-malunggay",
  "name": "Spicy Ginataang Baboy with Papaya and Malunggay",
  "recipe_type": null,
  "brief_description": "This is a recipe for Spicy Ginataang Baboy with Papaya and Malunggay",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic, onion, and ginger until the onion gets soft."
    },
    {
      "position": 3,
      "text": "Add the pork and ground black pepper. Continue to saut\u00e9 until it turns brown."
    },
    {
      "position": 4,
      "text": "Pour the coconut cream and water into the pot. Let boil."
    },
    {
      "position": 5,
      "text": "Add the Knorr pork cube. Set the heat to low. Cover the pot and then continue to cook for 40 minutes or until the pork gets tender."
    },
    {
      "position": 6,
      "text": "Add the papaya and chili peppers. Stir and then cook for 10 minutes."
    },
    {
      "position": 7,
      "text": "Add the malunggay leaves and fish sauce. Continue to cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with warm rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
