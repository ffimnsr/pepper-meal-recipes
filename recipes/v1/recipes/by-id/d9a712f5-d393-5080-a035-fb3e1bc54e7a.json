  "id": "d9a712f5-d393-5080-a035-fb3e1bc54e7a",
  "slug": "easy-meatloaf-recipe",
  "name": "Easy Meatloaf Recipe",
  "recipe_type": null,
  "brief_description": "This Easy Meatloaf Recipe is the simplest and easiest guide that you can use to prepare your own meatloaf. It is one of the best that we have.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the olive oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the onion for 3 minutes. Transfer the onion in a small plate and let cool."
    },
    {
      "position": 3,
      "text": "Meanwhile, combine ground beef, ground pork, Worcestershire sauce, egg, evaporated milk, bread crumbs, salt, ground black pepper, and onion.Mix well."
    },
    {
      "position": 4,
      "text": "Arrange the mixture in a greased loaf pan."
    },
    {
      "position": 5,
      "text": "Combine ketchup, sugar, and mustard powder in a bowl.Mix well and then pour over the meat mixture. Spread to ensure that the top is covered."
    },
    {
      "position": 6,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 7,
      "text": "Bake for 50 to 65 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven and let the temperature cool down."
    },
    {
      "position": 9,
      "text": "Slice and serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
