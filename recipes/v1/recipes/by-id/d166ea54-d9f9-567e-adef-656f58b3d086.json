  "slug": "grilled-st-louis-style-ribs-with-ensaladang-talong-and-bagoong",
  "name": "Grilled St. Louis Style Ribs with Ensaladang Talong and Bagoong",
  "recipe_type": "salad",
  "brief_description": "Grilled St. Louis Style Ribs with Ensaladang Talong and Bagoong is a Filipino meal wherein St. Louis-style ribs is rubbed with Asian inspired spices",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the rub ingredients. Mix well."
    },
    {
      "position": 2,
      "text": "Rub the mixture all over the spare ribs. Let is stay for 10 minutes."
    },
    {
      "position": 3,
      "text": "Heat the grill to 250F (we need to grill this in low heat for best results). Grill one side for 1 1/2 hours. Turn the ribs over to grill the other side. continue to grill for 1 hour."
    },
    {
      "position": 4,
      "text": "Remove from the grill. Let it rest for 15 minutes. Slice the ribs."
    },
    {
      "position": 5,
      "text": "Serve with eggplant salad and shrimp paste -- and rice, of course."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 150,
  "preparation_time_minutes": 15,
