  "slug": "poached-tilapia-in-sour-broth",
  "name": "Poached Tilapia in Sour Broth",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Poached Tilapia in Sour Broth",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Bring to a simmer."
    },
    {
      "position": 2,
      "text": "Add the tomato, tamarind, and scallions. Cover and continue to simmer for 35 minutes."
    },
    {
      "position": 3,
      "text": "Squeeze the tamarind and discard the pulp."
    },
    {
      "position": 4,
      "text": "Remove the tomato and scallions. Set aside."
    },
    {
      "position": 5,
      "text": "Add the tilapia fillet. Poach the fish for 6 to 8 minutes."
    },
    {
      "position": 6,
      "text": "Add the green pepper and some salt to taste.Simmer for 3 minutes."
    },
    {
      "position": 7,
      "text": "Arrange the fish in a serving bowl. Add the tomato and scallions."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
