  "name": "Healthy Frozen Blueberry Yogurt Recipe",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Healthy Frozen Blueberry Yogurt",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine all ingredients in a food processor. Turn the unit on and start to puree for 1 minute or until all the ingredients are well blended and the texture starts to get smoother."
    },
    {
      "position": 2,
      "text": "Remove the blueberry yogurt mixture from the processor and transfer to container with cover. Place inside the frezer for at least 3 hours."
    },
    {
      "position": 3,
      "text": "Scoop some Healthy Frozen Blueberry Yogurt and arrange in a serving bowl. Have this for dessert or during snacktime."
    },
    {
      "position": 4,
      "text": "Share and enjoy!"
    }
  ],
