  "id": "c1f3e867-2318-5d1b-85f6-6e0d75c27acd",
  "slug": "sinigang-na-sugpo-recipe-knr_sg",
  "name": "Sinigang na Sugpo Recipe",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Sinigang na Sugpo or Prawn in Sour Broth Soup",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add onion and tomato. Cook for 3 minutes."
    },
    {
      "position": 3,
      "text": "Add Knorr Sinigang sa Sampaloc Recipe Mix. Stir."
    },
    {
      "position": 4,
      "text": "Put the Labanos and siling pansigang into the pot. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add the Sugpo. Gently stir. Continue to cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Put Okra and Sitaw into the pot. Cook for 2 1/2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Season with patis and ground black pepper. Stir."
    },
    {
      "position": 8,
      "text": "Add Kangkong. Cover the pot. Turn the heat off. Let it stay for at least 5 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve!"
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 10,
