  "id": "87d4188f-1933-5b61-b3c0-c82f61d07acc",
  "slug": "sinuglaw-recipe",
  "name": "Sinuglaw",
  "recipe_type": "appetizer",
  "brief_description": "A Filipino dish from Mindanao that combines grilled pork and tuna fish marinated in vinegar",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place the tuna meat in a bowl then pour-in 1/2 cup of vinegar. Soak for 8 minutes."
    },
    {
      "position": 2,
      "text": "Using a spoon of fork, press the tuna meat lightly."
    },
    {
      "position": 3,
      "text": "Drain the vinegar then combine cucumber, onion, ginger, finger chili, Thai or Bird\u2019s eye chili, and salt. Mix well."
    },
    {
      "position": 4,
      "text": "Squeeze the lemon until all the juices are extracted then pour-in the remaining 3/4 cup vinegar. Mix well and soak for 10 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the Grilled pork belly and mix thoroughly. Let the mixture stand for at least 1 hour (you may place this inside the refrigerator)."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate then serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
  "difficulty": "medium",
