  "id": "8977e9b2-e386-519b-97fe-c33d5d732b67",
  "slug": "chicknigang-recipe",
  "name": "Chicknigang Recipe",
  "recipe_type": "soup",
  "brief_description": "Filipino chicken soup with sour broth. This dish is cooked with string beans, tomatoes, spinach, and okra.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a pot. Saute garlic, onion, and ginger."
    },
    {
      "position": 2,
      "text": "Add the chicken once the onion softens. Cook one side for 2 minutes. Turn it over and do the same on the opposite side."
    },
    {
      "position": 3,
      "text": "Pour water. Let boil."
    },
    {
      "position": 4,
      "text": "Add daikon radish and Knorr Sinigang sa Sampaloc Mix. Cover the pot and continue cooking using low to medium heat for 35 minutes."
    },
    {
      "position": 5,
      "text": "Add tomato, long green pepper, okra, and string beans. Cook for 8 to 12 minutes."
    },
    {
      "position": 6,
      "text": "Season with ground black pepper and fish sauce."
    },
    {
      "position": 7,
      "text": "Add spinach. Cook for 1 minute."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
