  "schema_version": 1,
  "id": "dc0e6155-63a2-5b8d-87da-e38774d03d74",
  "slug": "pinaputok-na-tilapia-recipe",
  "name": "Pinaputok na Tilapia Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for pinaputok na tilapia (oven baked tilapia)",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make about 2 to 3 slits on each side of the tilapia deep enough to reach the bones."
    },
    {
      "position": 2,
      "text": "Rub about 1 teaspoon of salt per side. Let the fish absorb the flavor for about 15 minutes."
    },
    {
      "position": 3,
      "text": "Combine the tomato, onion, mango, ginger, lemon juice, salt, and ground black pepper in a medium bowl. Mix well."
    },
    {
      "position": 4,
      "text": "Scoop the tomato and onion mixture and stuff inside the cavity of the tilapia. Try to stuff all the mixture, if possible. Note that the tilapia should have a cut under the body due to removal of the innards."
    },
    {
      "position": 5,
      "text": "Wrap the tilapia in an aluminum foil. Make sure that everything is covered."
    },
    {
      "position": 6,
      "text": "Preheat oven to 370 degrees Fahrenheit."
    },
    {
      "position": 7,
      "text": "Bake the tilapia for 20 minutes. (or grill each side of the fish for 10 minutes)"
    },
    {
      "position": 8,
      "text": "Remove the tilapia from the oven and then open the top so that the fish is exposed. Brush the cooking oil over the fish."
    },
    {
      "position": 9,
      "text": "Change the settings of the oven to broil (about 510 degrees Fahrenheit). Put the fish back-in with the exposed top. Broil for 15 minutes."
    },
    {
      "position": 10,
      "text": "Remove the fish from the oven and serve with toyomansi."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
