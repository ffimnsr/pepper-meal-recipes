  "id": "af2e236d-4e3d-5c91-9778-466249eb324a",
  "slug": "crab-and-corn-chopsuey",
  "name": "Crab and Corn Chopsuey",
  "recipe_type": "soup",
  "brief_description": "Easy chopsuey hack using Knorr Crab and Corn Soup.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok. Saut\u00e9 onion and garlic until the onion softens."
    },
    {
      "position": 2,
      "text": "Add carrot , cauliflower, and broccoli. Cook for 2 minutes."
    },
    {
      "position": 3,
      "text": "Add cabbage, bell pepper, and snow peas. Toss."
    },
    {
      "position": 4,
      "text": "Add soy sauce and oyster sauce and continue cooking for 2 minutes."
    },
    {
      "position": 5,
      "text": "Combine water and Knorr Crab and Corn Soup Mix. Stir and pour into the wok. Let it boil."
    },
    {
      "position": 6,
      "text": "Add fried tofu and quail eggs. Continue cooking until the sauce reduces and thickens."
    },
    {
      "position": 7,
      "text": "Season with salt and ground black pepper as needed."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
