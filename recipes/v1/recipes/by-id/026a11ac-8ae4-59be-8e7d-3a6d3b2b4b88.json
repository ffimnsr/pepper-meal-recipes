  "id": "026a11ac-8ae4-59be-8e7d-3a6d3b2b4b88",
  "slug": "pinoy-burger-steak",
  "name": "Pinoy Burger Steak Recipe",
  "recipe_type": "main",
  "brief_description": "Filipino style steak burger with gravy served with rice",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Fry the CDO Ulam Burger Patties until both sides are completely cooked. Set aside."
    },
    {
      "position": 2,
      "text": "Make the mushroom gravy by melting the butter in a saucepan. Add the mushrooms and saut\u00e9 for 1 minute. Add flour and stir until the texture becomes lumpy. Pour water. Stir until the gravy smoothens. Add beef bouillon and season with Worcestershire sauce, salt, and ground black pepper."
    },
    {
      "position": 3,
      "text": "Arrange 3 burger patties on each plate with 1 cup cooked rice. Top with mushroom gravy and garnish with toasted garlic and chopped parsley. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "easy",
