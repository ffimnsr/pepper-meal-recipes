  "id": "23aa7284-96f3-58f3-9e1a-70e0c8b95968",
  "slug": "chicken-potato-salad-recipe",
  "name": "Chicken Potato Salad",
  "recipe_type": "salad",
  "brief_description": "Easy chicken and potato salad with carrots and green peas.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a pot. Add potato. Boil for 5 minutes."
    },
    {
      "position": 2,
      "text": "Add carrot. Boil for 10 minutes. Remove potato and carrot from the pot. Place in a clean bowl and let it cool down."
    },
    {
      "position": 3,
      "text": "Add frozen green peas into the pot with boiling water. Boil for 1 minute. Remove and set aside."
    },
    {
      "position": 4,
      "text": "Add chicken into the pot. Boil for 15 minutes. Set aside."
    },
    {
      "position": 5,
      "text": "Slice potato, carrot, and chicken into cubes. Set aside."
    },
    {
      "position": 6,
      "text": "Make the salad dressing by combining Lady's Choice Mayonnaise, pickle relish, onion powder, ground black pepper, sugar, and salt in a bowl. Mix well."
    },
    {
      "position": 7,
      "text": "Combine potato, carrot, peas, and chicken with the salad dressing and then add shredded cheddar cheese. Toss until well blended."
    },
    {
      "position": 8,
      "text": "Refrigerate for at least one hour. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
