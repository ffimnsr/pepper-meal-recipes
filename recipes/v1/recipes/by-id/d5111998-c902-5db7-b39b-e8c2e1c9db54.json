  "slug": "ginataang-manok-with-sitaw-at-kalabasa",
  "name": "Ginataang Manok with Sitaw at Kalabasa",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginataang Manok with Sitaw at Kalabasa",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onion"
    },
    {
      "position": 3,
      "text": "Add the chicken and then continue to cook until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Pour 2 cups water. Let boil. Cover and cook in medium heat for 40 minutes. Note: add more water if needed."
    },
    {
      "position": 5,
      "text": "Add the kalabasa into the pot. Stir and then cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Prepare the gata by combining \u00be cup lukewarm water with Knorr Ginataang Gulay Mix. Stir and pour into the pot. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add the sitaw (snake beans). Cover the pot and cook for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Sprinkle some ground black pepper into the pot and pour the fish sauce in. Stir and cook for 1 minute."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
