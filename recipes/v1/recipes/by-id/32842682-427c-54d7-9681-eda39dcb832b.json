  "id": "32842682-427c-54d7-9681-eda39dcb832b",
  "slug": "how-to-make-kale-chips",
  "name": "How to Make Kale Chips",
  "recipe_type": "snack",
  "brief_description": "Crispy, healthy baked kale chips marinated in apple cider vinegar and seasonings for a tangy, savory snack.",
  "cuisine": "american",
  "instructions": [
    {
      "position": 1,
      "text": "Tear the kale leaves from the stems and place them in a zip-top bag."
    },
    {
      "position": 2,
      "text": "Add the salt, pepper, and vinegar to the bag, then seal."
    },
    {
      "position": 3,
      "text": "Shake the bag until all the ingredients are evenly distributed, then refrigerate overnight."
    },
    {
      "position": 4,
      "text": "Preheat the oven to 350 degrees Fahrenheit."
    },
    {
      "position": 5,
      "text": "Arrange the marinated kale leaves in a single layer on a baking sheet and bake for 20 to 25 minutes until crispy."
    },
    {
      "position": 6,
      "text": "Remove from the oven and transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve immediately. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
