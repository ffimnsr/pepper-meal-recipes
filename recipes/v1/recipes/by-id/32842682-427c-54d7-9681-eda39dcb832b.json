  "slug": "how-to-make-kale-chips",
  "name": "How to Make Kale Chips",
  "recipe_type": null,
  "brief_description": "How to Make Kale Chips",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Tear the leaves from the stalk and place in a ziplock bag."
    },
    {
      "position": 2,
      "text": "Put-in the salt, pepper, and vinegar in the bag then seal."
    },
    {
      "position": 3,
      "text": "Shake the bag until all the ingredients are well distributed then refrigerate overnight."
    },
    {
      "position": 4,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 5,
      "text": "Arranged the marinated kale leaves in a baking tray and bake for 20 to 25 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven and transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
