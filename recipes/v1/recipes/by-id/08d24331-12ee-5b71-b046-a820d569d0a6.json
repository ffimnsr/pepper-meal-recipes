  "id": "08d24331-12ee-5b71-b046-a820d569d0a6",
  "slug": "spicy-beef-noodle-soup",
  "name": "Spicy Beef Noodle Soup",
  "recipe_type": "soup",
  "brief_description": "Beef Noodle Soup has always been a favorite especially during cold weather. This Spicy Beef Noodle Soup Recipe will surely make you feel warm",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot"
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot, saut\u00e9 the garlic, ginger, and scallions for 30 seconds to a minute"
    },
    {
      "position": 3,
      "text": "Add the beef. Cook for 3 minutes or until the color browns."
    },
    {
      "position": 4,
      "text": "Add the soy sauce, cooking wine, beef broth, and water. Bring to a boil."
    },
    {
      "position": 5,
      "text": "Put-in the star anise, sugar, and chili. Stir and simmer for 60 to 90 minutes."
    },
    {
      "position": 6,
      "text": "Soak the noodles in hot water for 10 minutes. Drain and arrange in individual bowls."
    },
    {
      "position": 7,
      "text": "Add the bok choy, salt, and pepper. Stir and cover the pot. Turn the heat to off."
    },
    {
      "position": 8,
      "text": "Let the residual heat cook the bok choy for 5 minutes."
    },
    {
      "position": 9,
      "text": "Pour the soup with beef slices and vegetables on the bowls where the noodle are arranged."
    },
    {
      "position": 10,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
