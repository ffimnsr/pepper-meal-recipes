  "id": "12c12e3e-abf4-5783-a429-5032166fecb3",
  "slug": "sauteed-flank-steak-with-bok-choy-and-string-beans",
  "name": "Sauteed Flank Steak with Bok Choy and String Beans",
  "recipe_type": null,
  "brief_description": "Have you tried ginisang sitaw (sauteed string beans) or ginisang pechay (sauteed bok choy)? Sauteed Flank Steak with Bok Choy and String Beans is a cross between the two dishes. All these dishes share the same characteristics -- they are all delicious and easy to prepare.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a skillet."
    },
    {
      "position": 2,
      "text": "Once the oil is hot, stir fry the flank steak for 2 minutes."
    },
    {
      "position": 3,
      "text": "Add the beef broth. Cover and bring to a boil.Simmer for 10 to 15 minutes."
    },
    {
      "position": 4,
      "text": "Remove the cover and let the liquid completely evaporate."
    },
    {
      "position": 5,
      "text": "Put-in the garlic and onion. Cook for 1 to 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the tomato. Cook for another 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the string beans, bok choy, and soy sauce. Stir and cook for 4 to 6 minutes."
    },
    {
      "position": 8,
      "text": "Add sugar, salt and pepper to taste."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
