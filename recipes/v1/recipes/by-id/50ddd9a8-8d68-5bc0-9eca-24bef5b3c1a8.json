  "id": "50ddd9a8-8d68-5bc0-9eca-24bef5b3c1a8",
  "slug": "miso-soup-recipe",
  "name": "Miso Soup",
  "recipe_type": "soup",
  "brief_description": "A traditional Japanese soup made with dashi, miso paste, tofu, and wakame seaweed. Simple, comforting, and ready in minutes.",
  "cuisine": "Japanese",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot."
    },
    {
      "position": 2,
      "text": "Pour-in water. Add the dashi. Stir and let boil."
    },
    {
      "position": 3,
      "text": "Put-in the miso paste. Stir and cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the tofu and Wakame seaweed. Cook for 8 to 15 minutes in low to medium heat."
    },
    {
      "position": 5,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 3,
