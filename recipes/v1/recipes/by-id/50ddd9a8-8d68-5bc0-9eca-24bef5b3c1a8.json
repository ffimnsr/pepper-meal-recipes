  "slug": "miso-soup-recipe",
  "name": "Miso Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "Miso soup or Misoshiru is a customary soup of Japanese origin. This soup is made of the following: fermented soy beans called miso.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot."
    },
    {
      "position": 2,
      "text": "Pour-in water. Add the dashi. Stir and let boil."
    },
    {
      "position": 3,
      "text": "Put-in the miso paste. Stir and cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the tofu and Wakame seaweed. Cook for 8 to 15 minutes in low to medium heat."
    },
    {
      "position": 5,
      "text": "Tranfser to a serving bowl. Serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
