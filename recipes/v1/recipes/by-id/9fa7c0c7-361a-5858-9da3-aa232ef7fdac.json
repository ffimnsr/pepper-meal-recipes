  "id": "9fa7c0c7-361a-5858-9da3-aa232ef7fdac",
  "slug": "seafood-boil-recipe",
  "name": "Seafood Boil",
  "recipe_type": null,
  "brief_description": "Seafood boil is an easy-to-prepare seafood dish composed of mussels, crab legs, shrimp, potato, and corn. It is delicious",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water on a large stockpot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the cloves, salt, pepper, ginger, garlic, and crab boil. Continue to boil for 5 minutes."
    },
    {
      "position": 3,
      "text": "Slowly add the potato and corn. Cook for 4 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Add the crab and mussels. Boil for 3 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the shrimps and cook for 3 to 5 minutes more."
    },
    {
      "position": 6,
      "text": "Remove the seafood along with the potatoes and corn from the pot. Let the water drip."
    },
    {
      "position": 7,
      "text": "Transfer to a serving tray. Serve with lemon butter sauce."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
