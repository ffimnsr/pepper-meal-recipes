  "id": "9308c6af-44a6-52af-ba0f-68d78cb45295",
  "slug": "beef-curry",
  "name": "Beef Curry Recipe",
  "recipe_type": null,
  "brief_description": "Enjoy the delicious taste of this Beef Curry Recipe. Our cooking video and procedures will guide you to easily learn to cook this dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute onions and garlic."
    },
    {
      "position": 3,
      "text": "Add beef and cook until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Put-in crushed red pepper/chili, bay leaf, cloves, cinnamon sticks, and curry powder. Stir."
    },
    {
      "position": 5,
      "text": "Pour-in fresh milk (or coconut milk). Let boil."
    },
    {
      "position": 6,
      "text": "Add tomato, ginger, lemon juice, and salt. Stir and simmer until the sauce thickens and the beef becomes tender."
    },
    {
      "position": 7,
      "text": "Turn the heat off and transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with steamed rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
