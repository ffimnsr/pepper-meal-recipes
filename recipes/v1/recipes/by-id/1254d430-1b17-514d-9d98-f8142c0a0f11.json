  "id": "1254d430-1b17-514d-9d98-f8142c0a0f11",
  "slug": "sinigang-na-baboy-sa-kamias",
  "name": "Pork Sinigang sa Kamias Recipe",
  "recipe_type": "main",
  "brief_description": "Pork Sinigang sa Kamias is a version of Filipino Pork Sinigang using pork belly and bilimbi \u2013 which is locally known in the Philippines as kamias",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the water, tomato, onion, and kamias in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add the pork slices. Let the water re-boil. Cover and simmer for 30 minutes."
    },
    {
      "position": 3,
      "text": "Add the gabi (eddo) and green peppers. Cover and continue to simmer for another 30 minutes or until the pork is tender."
    },
    {
      "position": 4,
      "text": "Add the fish sauce. Stir."
    },
    {
      "position": 5,
      "text": "Put-in the okra, string beans, and eggplant. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add the kangkong. Cover the cooking pot and turn the heat off. Let the residual heat cook the kangkong."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
  "difficulty": "medium",
