  "id": "690425a5-a71d-50f5-b79b-4887eedb402a",
  "slug": "asian-chicken-lettuce-wrap",
  "name": "Asian Chicken Lettuce Wrap",
  "recipe_type": "appetizer",
  "brief_description": "Easy lettuce wrap using CDO Chicken Flakes in oil",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Wash the lettuce with running water and peel the leaves apart. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a wok. Saute onion for 35 seconds."
    },
    {
      "position": 3,
      "text": "Add Chicken Flakes. Continue cooking until the liquid evaporates completely."
    },
    {
      "position": 4,
      "text": "Add carrot and jicama. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Add soy sauce, vinegar, sesame oil, and hoisin sauce. Stir."
    },
    {
      "position": 6,
      "text": "Put the green onions into the wok and season with salt and ground black pepper as needed."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve with fresh lettuce."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
