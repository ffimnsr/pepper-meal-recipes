  "id": "b4331cf2-dfa0-57bf-8891-69ea9392e167",
  "slug": "chicken-kare-kare-recipe",
  "name": "Chicken Kare Kare Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Filipino Chicken Kare Kare.&nbsp;",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute onion and garlic until onion softens"
    },
    {
      "position": 3,
      "text": "Add chicken slices. Cook each side for 1 to 1 \u00bd minutes. Continue to cook saut\u00e9 the chicken for 2 more minutes."
    },
    {
      "position": 4,
      "text": "Pour chicken broth. Let boil."
    },
    {
      "position": 5,
      "text": "Add annatto paste. Stir until the paste dilutes completely. Cover the pot. Boil in medium heat for 30 to 35 minutes."
    },
    {
      "position": 6,
      "text": "Add peanut butter. Stir until well blended. Pour a portion of the cornstarch mixture. Stir. Note: add more if the sauce needs to be thickened further"
    },
    {
      "position": 7,
      "text": "Put the eggplant and snake beans into the pot. Cover and cook for 5 minutes. Add bok choy. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve with bagoong alamang. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
