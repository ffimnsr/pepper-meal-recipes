  "id": "e8b4dcb0-3bb4-54b8-bbb5-f2d0ae8c2fcb",
  "slug": "sarsa-ng-lechon-sauce-recipe",
  "name": "Lechon Sauce Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe on how to make lechon sauce from scratch. This is perfect for lechon baboy or roasted pig, lechon kawali, and lechon manok.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and ground black pepper all over the pork liver. Let it stay for 5 minutes."
    },
    {
      "position": 2,
      "text": "Grill the liver until fully cooked. Let it cool down and then slice into small pieces. Set aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a wok. Saut\u00e9 garlic and onion until the latter softens."
    },
    {
      "position": 4,
      "text": "Add the grilled liver. Saut\u00e9 for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour the vinegar. Let it boil."
    },
    {
      "position": 6,
      "text": "Stir and then add the brown sugar and water. Let the mixture boil."
    },
    {
      "position": 7,
      "text": "Add the breadcrumbs. Stir and simmer for 2 minutes."
    },
    {
      "position": 8,
      "text": "Transfer the mixture into a blender. Blitz until the mixture smoothens."
    },
    {
      "position": 9,
      "text": "Pour the mixture back into the wok. Continue cooking until it starts to boil."
    },
    {
      "position": 10,
      "text": "Season with ground black pepper, salt, and onion powder."
    },
    {
      "position": 11,
      "text": "Transfer to a sauce bowl. Serve. Share and enjoy as a condiment."
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
