  "recipe_notes": [
    "Marinate pork for at least 3 hours or overnight in the refrigerator for best flavor.",
    "Maintain low to medium heat while grilling to prevent burning the marinade.",
    "Let the grilled pork rest for 5 minutes before slicing to retain juices.",
    "Prepare the dipping sauce (sawsawan) just before serving for freshest flavor."
  ],
  "storage_notes": [
    "Store leftover grilled pork in an airtight container in the refrigerator for up to 3 days.",
    "Reheat on a grill or skillet over medium heat to maintain texture and flavor.",
    "Do not freeze once grilled as the texture may become tough upon thawing."
  ],
