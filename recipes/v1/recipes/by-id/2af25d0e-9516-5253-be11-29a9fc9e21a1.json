  "id": "2af25d0e-9516-5253-be11-29a9fc9e21a1",
  "slug": "inihaw-na-baboy",
  "name": "Inihaw na Baboy",
  "recipe_type": null,
  "brief_description": "This is a recipe for Inihaw na Baboy or Grilled Pork",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the marinade ingredients in a bowl. Stir until all ingredients are well blended."
    },
    {
      "position": 2,
      "text": "Put the pork in the bowl with the marinade. Make sure to coat the pork. Cover and marinate the pork for at least 3 hours. Note: you can place this inside the refrigerator to avoid contamination."
    },
    {
      "position": 3,
      "text": "Prepare the basting sauce by mixing all the basting sauce ingredients."
    },
    {
      "position": 4,
      "text": "Heat-up the grill. Start to grill one side of the pork in low to medium heat for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Brush the basting sauce over the pork and then turn it over to grill the opposite side. continue to grill for another 3 to 5 minutes. Repeat this step 2 to 3 times more (do not forget to baste the pork every time you turn it) until its completely cooked."
    },
    {
      "position": 6,
      "text": "Remove from the grill and let it cool down. Slice into serving pieces."
    },
    {
      "position": 7,
      "text": "Serve with a dip composed of vinegar, soy sauce, chili peppers, chopped onion, and ground black pepper."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
