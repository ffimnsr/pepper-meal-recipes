  "slug": "how-to-make-spaghetti-with-tomato-and-basil",
  "name": "Spaghetti with Tomato and Basil",
  "recipe_type": null,
  "brief_description": "Spaghetti with Tomato and Basil. Who doesn\u2019t want pasta? Even if pasta is not an authentic Filipino food, we still learned to love and enjoy it. In fact, there are some Filipino variations of some Italian pasta dishes that we really enjoy",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the pasta according to package instruction."
    },
    {
      "position": 2,
      "text": "Heat a skillet or pan then pour-in the olive oil."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the garlic until color turns medium yellow."
    },
    {
      "position": 4,
      "text": "Add the cherry tomatoes and cook for another 3 minutes"
    },
    {
      "position": 5,
      "text": "Drain the pasta then put it in the skillet or pan and toss."
    },
    {
      "position": 6,
      "text": "Add the fresh basil, salt, and pepper then toss the pasta once more."
    },
    {
      "position": 7,
      "text": "Turn off the heat then transfer the pasta to a serving dish."
    },
    {
      "position": 8,
      "text": "Sprinkle some parmesan cheese on top then serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
