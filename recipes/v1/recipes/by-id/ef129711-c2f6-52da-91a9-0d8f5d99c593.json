  "id": "ef129711-c2f6-52da-91a9-0d8f5d99c593",
  "slug": "tangy-shrimp-tacos-recipe",
  "name": "Tangy Shrimp Tacos",
  "recipe_type": null,
  "brief_description": "Tangy Shrimp Tacos is a quick and easy shrimp tacos recipe that you will surely love. This baby is nice because it has both rich and spicy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the lemon juice over the shrimp. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "In a bowl, combine the cumin, chili powder, ground black pepper, garlic powder, and salt. Mix well."
    },
    {
      "position": 3,
      "text": "Combine the spice mixture and shrimp. Gently toss to coat and then let it stay for 30 minutes."
    },
    {
      "position": 4,
      "text": "Heat a nonstick frying pan. Apply a little cooking oil spray."
    },
    {
      "position": 5,
      "text": "Once the pan is hot, put enough shrimp in the pan and then cook each side in medium to high heat for 3 to 4 minutes. Note: do not overcook the shrimp."
    },
    {
      "position": 6,
      "text": "Remove the shrimp and place in a clean plate."
    },
    {
      "position": 7,
      "text": "Meanwhile, heat a grill pan. Warm the flour tortillas by placing it on the grill pan for 40 seconds."
    },
    {
      "position": 8,
      "text": "Place the warm tortilla in a plate and then start to assemble the shrimp tacos. You can start by arranging the cubed tomatoes and chopped cilantro followed by the shrimp. Add some guacamole and top with sour cream. you can even add hot sauce if you want."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 10,
