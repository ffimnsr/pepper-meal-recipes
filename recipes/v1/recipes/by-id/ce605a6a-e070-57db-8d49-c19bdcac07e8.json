  "id": "ce605a6a-e070-57db-8d49-c19bdcac07e8",
  "slug": "tilapia-with-salted-black-beans-tausi",
  "name": "Tilapia with Salted Black Beans",
  "recipe_type": null,
  "brief_description": "Tilapia with Salted Black Beans is also known as tilapia with tausi. This is a delicious dish involving the St. Bernard fish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and pepper all over the sliced tilapia. Let it stand for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat 1 cup of cooking oil in a frying pan."
    },
    {
      "position": 3,
      "text": "Pan-fry the sliced tilapia in medium heat for about 5 minutes per side or until the color turns medium brown. Remove the fried tilapia and place in a plate lined with paper towel."
    },
    {
      "position": 4,
      "text": "In a clean cooking pan, heat about 2 tablespoons of cooking oil."
    },
    {
      "position": 5,
      "text": "Saute the garlic and onion."
    },
    {
      "position": 6,
      "text": "When the onion softens,add the parsley and salted black beans."
    },
    {
      "position": 7,
      "text": "Put the fried tilapia in the pan. Add the soy sauce, oyster sauce, and cornstarch diluted in water. Stir gently and let boil. Cover and simmer for 10 to 15 minutes."
    },
    {
      "position": 8,
      "text": "Add pepper to taste. Note: you can add more water to make it taste less salty."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 10,
      "text": "Serve. share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
