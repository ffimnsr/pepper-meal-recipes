  "id": "6eec2889-c816-5133-b0ad-af761f085bfa",
  "slug": "saucy-beef-with-broccoli",
  "name": "Saucy Beef with Broccoli",
  "recipe_type": "main",
  "brief_description": "Beef with broccoli cooked with lots of yummy sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine beef, soy sauce, cooking wine, and cornstarch in a bowl. Mix well. Marinate for 15 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Saut\u00e9 ginger and onion until the later softens."
    },
    {
      "position": 3,
      "text": "Add marinated beef into the pan. Stir-fry until the beef browns."
    },
    {
      "position": 4,
      "text": "Add oyster sauce. Stir-fry for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour-in beef broth. Stir. Cover the pan and then continue cooking in low heat for 10 to 12 minutes."
    },
    {
      "position": 6,
      "text": "Add broccoli. Stir and cover the pan. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve! Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
