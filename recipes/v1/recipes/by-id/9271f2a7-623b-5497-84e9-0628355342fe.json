  "id": "9271f2a7-623b-5497-84e9-0628355342fe",
  "slug": "bangus-bicol-express-recipe",
  "name": "Bangus Bicol Express",
  "recipe_type": "main",
  "brief_description": "A pescatarian-friendly option to traditional Bicol express",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the bangus into serving pieces. Sprinkle salt all over it. Let it stay for 3 minutes."
    },
    {
      "position": 2,
      "text": "Heat cooking oil in a pan."
    },
    {
      "position": 3,
      "text": "Meanwhile, dredge the sliced fish in flour, coat it as lightly as possible."
    },
    {
      "position": 4,
      "text": "Fry the bangus for 3 minutes per side. Remove from the pan and set aside."
    },
    {
      "position": 5,
      "text": "Save 3 tablespoons of cooking oil in the pan. Saute the onion for up to 1 minute."
    },
    {
      "position": 6,
      "text": "Add the garlic. Saut\u00e9 for 30 seconds and then add the ginger. Continue saut\u00e9ing until the onion softens."
    },
    {
      "position": 7,
      "text": "Add the shrimp paste. Cook for 30 seconds."
    },
    {
      "position": 8,
      "text": "Pour the coconut milk into the pan. Let it boil and then reduce the heat to a simmer. Cover the pan and continue to simmer for 1 to 2 minutes."
    },
    {
      "position": 9,
      "text": "Add the chili peppers and season with ground black pepper."
    },
    {
      "position": 10,
      "text": "Put the fried bangus into the pan. Continue cooking for a maximum of 2 \u00bd minutes."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve with rice."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
