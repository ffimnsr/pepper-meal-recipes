  "id": "0db020ab-b13b-50cf-9b22-865f8d7f81b3",
  "slug": "grilled-filipino-sweet-sausage",
  "name": "Grilled Filipino Sweet Sausage",
  "recipe_type": "dessert",
  "brief_description": "This recipe is another way of cooking sweet sausage and I personally like it since it melts more fat and gives the sausage a nice smokey flavor.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a medium cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add the longganisa (Filipino sweet sausages). Cover and boil for 20 minutes or until the water evaporates."
    },
    {
      "position": 3,
      "text": "Heat-up the grill. Grill the sausages for 15 minutes while turning it every 3 minutes until all the sides are cooked completely."
    },
    {
      "position": 4,
      "text": "Remove from the grill. Serve for breakfast with fried eggs and spicy vinegar."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 35,
