  "id": "27c628e8-fdc7-5bad-ba07-f9aecd34cc32",
  "slug": "chicken-giniling-with-green-peas",
  "name": "Chicken Giniling with Green Peas",
  "recipe_type": null,
  "brief_description": "Chicken Giniling with Green Peas is a Filipino stew that makes use of ground chicken meat. This dish is usually made using ground pork",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a wide pan."
    },
    {
      "position": 2,
      "text": "When the oil is hot, saut\u00e9 the garlic and onion until the onion softens."
    },
    {
      "position": 3,
      "text": "Add the ground chicken. Cook for 5 minutes in medium heat."
    },
    {
      "position": 4,
      "text": "Pour-in the tomato sauce and chicken broth. Let boil."
    },
    {
      "position": 5,
      "text": "Add the dried bay leaves. Simmer for 35 minutes covered. Note: add water or chicken broth as needed."
    },
    {
      "position": 6,
      "text": "Put-in the carrots and potato. Stir and cook for 8 to 10 minutes."
    },
    {
      "position": 7,
      "text": "Add the green peas. Cook for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Add salt and pepper to taste. Stir and turn-off heat"
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
