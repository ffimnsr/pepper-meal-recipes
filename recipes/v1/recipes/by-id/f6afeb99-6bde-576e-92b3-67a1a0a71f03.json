  "id": "f6afeb99-6bde-576e-92b3-67a1a0a71f03",
  "slug": "beef-ribs-sinigang",
  "name": "Beef Ribs Sinigang",
  "recipe_type": null,
  "brief_description": "This is a recipe for Sinigang na Baka using beef ribs.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine water and beef ribs in a pressure cooker. Pressure cook for 25 to 30 minutes. Note: you can transfer this later to a larger cooking pot once the beef gets tender, if needed."
    },
    {
      "position": 2,
      "text": "Add onion and tomato. Cook for 3 minutes."
    },
    {
      "position": 3,
      "text": "Add Knorr Sinigang sa Sampaloc Mix. Stir."
    },
    {
      "position": 4,
      "text": "Put the daikon radish (labanos) into the pot, Cover and cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add long green pepper, okra, snake beans, eggplant, and the kangkong stalks. Cover and cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Season with patis and ground black pepper."
    },
    {
      "position": 7,
      "text": "Add kangkong leaves. Cover the pot and turn the stovetop off. Let t stay for 5 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
