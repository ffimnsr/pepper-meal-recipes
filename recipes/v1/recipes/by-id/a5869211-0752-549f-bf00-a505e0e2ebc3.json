  "id": "a5869211-0752-549f-bf00-a505e0e2ebc3",
  "slug": "fried-pork-belly-liempo",
  "name": "Fried Pork Belly",
  "recipe_type": "main",
  "brief_description": "Crispy seasoned fried pork belly, dredged in a light coating, and served with a bold garlic chili dipping sauce. Best paired with steamed rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the sliced pork belly in a pan. Season with Maggi Magic Sarap and ground black pepper."
    },
    {
      "position": 2,
      "text": "Add the garlic and then pour water into the pan. Boil for 10 minutes."
    },
    {
      "position": 3,
      "text": "Flip the pork over and continue boiling until the water completely evaporates."
    },
    {
      "position": 4,
      "text": "Remove the pork. Let it cool down."
    },
    {
      "position": 5,
      "text": "Combine all-purpose flour and cornstarch in a bowl. Mix well. Dredge the boiled pork belly and shake-off excess flour. Set aside."
    },
    {
      "position": 6,
      "text": "Heat the oil in a clean pan. Once hot, start to fry the pork belly until it brown. Turn it over and do the same thing on the other side."
    },
    {
      "position": 7,
      "text": "Remove from the pan and arrange on a serving plate."
    },
    {
      "position": 8,
      "text": "Combine all the dipping sauce ingredients in a bowl. Mix well."
    },
    {
      "position": 9,
      "text": "Serve the fried pork belly with the dipping sauce and steamed white rice. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
