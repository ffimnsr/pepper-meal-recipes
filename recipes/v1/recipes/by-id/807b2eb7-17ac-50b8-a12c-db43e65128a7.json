  "id": "807b2eb7-17ac-50b8-a12c-db43e65128a7",
  "slug": "pork-chop-suey-recipe",
  "name": "Pork Chop Suey Recipe",
  "recipe_type": null,
  "brief_description": "Chop Suey is a delicious dish composed of different kinds of vegetables and meat. If you are Filipino (or if your spouse is), you might have an idea on what this dish is all about. I first thought that Chop Suey is an authentic Chinese dish, but I learned that it was Chinese-American in nature.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour-in the cooking oil."
    },
    {
      "position": 2,
      "text": "Saute the onion and garlic."
    },
    {
      "position": 3,
      "text": "Add the pork and continue to saut\u00e9 for 5 to7 minutes."
    },
    {
      "position": 4,
      "text": "Add the parsley and soy sauce. Put-in the carrot and then cook for 3 to 5 minutes more."
    },
    {
      "position": 5,
      "text": "Add the bell pepper and cabbage. Stir-fry for 3 minutes. Cover the cooking pot and continue to cook in medium heat for 8 minutes while stirring every 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the diluted cornstarch. Stir and cook until the texture of the dish thickens."
    },
    {
      "position": 7,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
