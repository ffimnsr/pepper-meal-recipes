  "id": "ff39ec8b-7bd4-5fd3-b765-65b686ba68ff",
  "slug": "kinamatisang-isda-red-snapper-with-tomato",
  "name": "Kinamatisang Isda (Red Snapper with Tomatoes)",
  "recipe_type": null,
  "brief_description": "Kinamatisang isda is a Filipino dish wherein fish is cooked with tomato, onion, and water. Red snapper was used for this recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add the tomato and onion. Cover and continue to cook in medium heat for 12 to 15 minutes. You can add more water if needed."
    },
    {
      "position": 3,
      "text": "Remove the cover. Mash the tomato and onion to extract the flavor."
    },
    {
      "position": 4,
      "text": "Add the fish. Cover and cook in low to medium heat for 15 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the fish sauce. Stir and cook for 3 minutes or until the liquid reduces to your desired amount."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
