  "id": "87236da5-938c-58f6-80cb-2663fc338dfc",
  "slug": "filipino-food-pork-humba-recipe",
  "name": "Humba Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pork Humba",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking pot then brown the pork belly"
    },
    {
      "position": 2,
      "text": "Add the onions and garlic and cook until the onions are soft"
    },
    {
      "position": 3,
      "text": "Put-in the soy sauce, peppercorn, bay leaves"
    },
    {
      "position": 4,
      "text": "Pour-in the pineapple juice and let boil. Simmer until the pork is tender (add water as needed)"
    },
    {
      "position": 5,
      "text": "Add the vinegar and wait for the mixture to re-boil. Simmer for 3 minutes"
    },
    {
      "position": 6,
      "text": "Spoon-in the salted black beans and brown sugar then simmer for 5 minutes"
    },
    {
      "position": 7,
      "text": "Add the dried banana blossoms and simmer for 5 to 8 minutes"
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate and serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
