  "slug": "dinengdeng-recipe",
  "name": "Dinengdeng Recipe",
  "recipe_type": null,
  "brief_description": "Dinengdeng or inabraw is a Filipino vegetable dish that originated from the Ilocos region in the Philippines. It is composed of different vegetables that are usually grown in one\u2019s backyard. This dish has a similarity with bulanglang and laswa; the obvious difference of Dinengdeng is the use of fried or grilled fish. Another notable difference is the addition of \u201cbagoong isda\u201d.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Bring water to a boil in a large cooking pot."
    },
    {
      "position": 2,
      "text": "Add the ginger, onion, and tomato. Cook covered for 5 minutes."
    },
    {
      "position": 3,
      "text": "Pour-in the bagoong isda. Stir."
    },
    {
      "position": 4,
      "text": "Add okra and string beans. Stir and add the ampalaya. Cook in medium heat for 7 to 10 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the squash flower and malunggay leaves. Cook for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Add the grilled milk fish. Let it stay for 3 to 5 minutes to add flavor to the dish."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
