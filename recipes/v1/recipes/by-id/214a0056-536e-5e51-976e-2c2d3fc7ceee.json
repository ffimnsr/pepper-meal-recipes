  "id": "214a0056-536e-5e51-976e-2c2d3fc7ceee",
  "slug": "pork-afritada-recipe",
  "name": "Pork Afritada",
  "recipe_type": "main",
  "brief_description": "A hearty Filipino pork stew with vegetables and hot dogs simmered in a rich tomato sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, saute onion and garlic until onion softens."
    },
    {
      "position": 3,
      "text": "Add pork. Saute until brown."
    },
    {
      "position": 4,
      "text": "Pour tomato sauce and water. Stir and let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork Cube. Stir. Add dried bay leaves. Cover and cook in medium heat for 30 minutes. Note: Add more water if needed."
    },
    {
      "position": 6,
      "text": "Add hotdogs. Cook for 10 minutes."
    },
    {
      "position": 7,
      "text": "Add carrot and potato. Cover and cook for 8 minutes."
    },
    {
      "position": 8,
      "text": "Add green peas. Cook for 3 to 5 minutes."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
