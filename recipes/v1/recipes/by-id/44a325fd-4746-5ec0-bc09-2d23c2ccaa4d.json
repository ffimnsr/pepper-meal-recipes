  "id": "44a325fd-4746-5ec0-bc09-2d23c2ccaa4d",
  "slug": "pancit-canton-at-bihon-recipe",
  "name": "Pancit Canton at Bihon Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Filipino Pancit Canton at Bihon",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Soak the bihon noodles in water for 10 minutes. Drain the water and set the soaked bihon aside."
    },
    {
      "position": 2,
      "text": "Heat a cooking pot and then pour 3 tablespoons of cooking oil."
    },
    {
      "position": 3,
      "text": "Once the oil becomes hot, pan fry the shrimp for 1 minute per side. Remove the shrimp from the pot after pan-frying, and then set aside."
    },
    {
      "position": 4,
      "text": "Add 1 to 2 tablespoons cooking oil. Saute onion and garlic until the onion becomes soft and translucent."
    },
    {
      "position": 5,
      "text": "Add sliced pork. Continue to saut\u00e9 until it turns light brown."
    },
    {
      "position": 6,
      "text": "Add shredded chicken. Saute for 3 minutes."
    },
    {
      "position": 7,
      "text": "Pour soy sauce and water. Stir. Let boil."
    },
    {
      "position": 8,
      "text": "Add Knorr Shrimp Cube. Stir. Cover the pot and continue to cook in low heat for 20 minutes. Note: you can add more water, if needed."
    },
    {
      "position": 9,
      "text": "Add carrots, green beans, and cabbage. Stir. Cover and cook for 2 minutes."
    },
    {
      "position": 10,
      "text": "Put the pancit canton in the pot. Cover. Let the noodles absorb the steam from the boiling liquid for 3 minutes."
    },
    {
      "position": 11,
      "text": "Toss the pancit canton with the other ingredients."
    },
    {
      "position": 12,
      "text": "Add the pancit bihon. Toss some more until all ingredients are well blended."
    },
    {
      "position": 13,
      "text": "Put the pan-fried shrimp into the pot and sprinkle with ground black pepper. Toss and cook until the liquid has been absorbed completely."
    },
    {
      "position": 14,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 15,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
