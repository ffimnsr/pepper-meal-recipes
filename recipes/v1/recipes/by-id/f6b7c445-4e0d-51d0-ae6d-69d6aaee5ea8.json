  "id": "f6b7c445-4e0d-51d0-ae6d-69d6aaee5ea8",
  "slug": "filipino-food-budget-friendly-meal-cheese-sticks-recipe",
  "name": "Cheese Sticks",
  "recipe_type": null,
  "brief_description": "Filipino Pinoy Food Cheese Sticks wrapped in lumpia wrapper",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Wrap the cheeses in spring roll wrapper"
    },
    {
      "position": 2,
      "text": "Heat the pan and pour-in the cooking oil. Let the oil heat-up for a few minutes. (use a smaller pan to save oil)"
    },
    {
      "position": 3,
      "text": "Deep-fry the cheese in spring roll wrapper (uncooked cheese sticks) for 4 minutes or until the color of the spring roll wrapper turns golden brown."
    },
    {
      "position": 4,
      "text": "Remove from the pan and place in a plate with paper towel. Let stand for a few minutes for the oil to drain."
    },
    {
      "position": 5,
      "text": "Serve with mayonnaise and ketchup dip. Share and enjoy!"
    }
  ],
  "servings": 6,
