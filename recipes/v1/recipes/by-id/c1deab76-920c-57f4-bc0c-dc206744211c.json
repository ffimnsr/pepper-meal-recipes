  "id": "c1deab76-920c-57f4-bc0c-dc206744211c",
  "slug": "hotsilog-hotdog-sinangang-at-itlog",
  "name": "Hotsilog (Hotdog Sinangang at Itlog)",
  "recipe_type": "breakfast",
  "brief_description": "This is a recipe for Hotsilog",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a small cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add hotdogs and then pour 2 tablespoons cooking oil. Continue to cook until the water evaporates."
    },
    {
      "position": 3,
      "text": "Once the water is gone, fry the hotdogs in the remaining oil for 1 to 2 minutes while slowly rolling it back and forth to prevent it from getting burnt. Set aside."
    },
    {
      "position": 4,
      "text": "Prepare the eggs by heating 4 tablespoons of cooking oil in a pan."
    },
    {
      "position": 5,
      "text": "Once the oil gets hot, crack a piece of egg and start to fry it. As the egg is frying, grab a spoon and scoop the oil from the bottom of the pot. Pour the oil over the egg. Do this until the yolk gets a white covering. Remove the egg and set aside. Do the same step on the other piece of egg."
    },
    {
      "position": 6,
      "text": "Arrange the garlic fried rice, hotdogs, and fried eggs in a plate. Put the slices of tomato on the side."
    },
    {
      "position": 7,
      "text": "Serve with ketchup. Share and enjoy!"
    }
  ],
  "servings": 1,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
