{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "390a0ceb-6e3c-569a-8e72-8ce97f19254a",
  "slug": "eggplant-parmigiana",
  "name": "Eggplant Parmesan Recipe",
  "recipe_type": "main",
  "brief_description": "Baked eggplant with marinara sauce and cheeses",
  "cuisine": "italian",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "In a bowl, combine bread crumbs, salt, pepper, and garlic powder. Mix well."
    },
    {
      "position": 3,
      "text": "Dip the sliced eggplant on beaten eggs, and then on the bread crumb mixture. Place on a clean plate and set aside."
    },
    {
      "position": 4,
      "text": "Heat the olive oil in a pan, and then fry both sides of the coated eggplants until the color turns medium brown. Set aside."
    },
    {
      "position": 5,
      "text": "Spread 1/2 cup of marinara sauce on a rectangular baking pan."
    },
    {
      "position": 6,
      "text": "Arrange the fried eggplants over the marinara sauce. Sprinkle some parmesan and Romano cheeses, and mozzarella cheese on top of the eggplants."
    },
    {
      "position": 7,
      "text": "Create the second layer by spreading marinara sauce on top of the cheeses, and then arrange the remaining eggplants. Pour the remaining marinara sauce over the eggplants and sprinkle the remaining cheeses evenly."
    },
    {
      "position": 8,
      "text": "Place in the oven and bake for 18 to 22 minutes."
    },
    {
      "position": 9,
      "text": "Remove from the oven and let cool."
    },
    {
      "position": 10,
      "text": "Serve. share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
