  "slug": "how-to-make-green-bean-salad-with-feta-and-dill",
  "name": "Green Bean Salad with Feta and Dill Recipe",
  "recipe_type": "salad",
  "brief_description": "Green Bean Salad with Feta and Dill is a quick and easy vegetable salad Recipe. Make this dish by following our tested recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot then put-in the green beans and cook for 5 minutes."
    },
    {
      "position": 2,
      "text": "Turn-off heat and transfer the green beans in a bowl with ice water. This will retain the color and texture of the green beans."
    },
    {
      "position": 3,
      "text": "Make the dressing by combining olive oil, white wine vinegar, Spanish onion, salt, and ground black pepper in a bowl then mix well."
    },
    {
      "position": 4,
      "text": "Toss the green beans on the dressing while adding Feta cheese."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate and serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 12,
