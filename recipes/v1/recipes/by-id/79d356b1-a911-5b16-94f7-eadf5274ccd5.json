  "slug": "how-to-make-bilo-bilo-recipe",
  "name": "How to Make Bilo-bilo",
  "recipe_type": null,
  "brief_description": "Learn how to make Bilo-bilo (glutinous rice balls) from this simple step-by-step tutorial. These rice balls are perfect for binignit.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine glutinous rice flour and water."
    },
    {
      "position": 2,
      "text": "Mix the mixture thoroughly. A soft yet sticky mixture should be formed."
    },
    {
      "position": 3,
      "text": "Scoop about 1 1/2 to 2 teaspoons of the mixture and roll it into a ball shaped figure using your hands. Tip: Try to wet your hands a little to prevent the mixture from sticking."
    },
    {
      "position": 4,
      "text": "Place the mixture in a plate or any flat container and do the same steps until all the mixture is used up."
    },
    {
      "position": 5,
      "text": "Use as ingredient for Filipino Dessert recipes that require them. You can also cover the container and freeze the glutinous rice balls for future use."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 10,
