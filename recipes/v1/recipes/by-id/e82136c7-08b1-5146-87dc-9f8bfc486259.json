  "id": "e82136c7-08b1-5146-87dc-9f8bfc486259",
  "slug": "moist-banana-bread-with-raisins-recipe",
  "name": "Moist Banana Bread with Raisins",
  "recipe_type": null,
  "brief_description": "This is a recipe for moist banana bread with raisins",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 340F"
    },
    {
      "position": 2,
      "text": "Beat eggs in a mixing bowl"
    },
    {
      "position": 3,
      "text": "Add the bananas and oil. Continue to mix until the ingredients are well blended. Set aside."
    },
    {
      "position": 4,
      "text": "On a separate bowl, combine flour, sugar, baking soda, salt, and raisins. Mix well."
    },
    {
      "position": 5,
      "text": "Gradually add the flour mixture to the banana mixture. Continue to fold until all the ingredients are well incorporated."
    },
    {
      "position": 6,
      "text": "Add the vanilla extract. Mix."
    },
    {
      "position": 7,
      "text": "Grease a loaf pan and then pour the mixture on it."
    },
    {
      "position": 8,
      "text": "Bake for 50 minutes or until it passes the toothpick test"
    },
    {
      "position": 9,
      "text": "Remove from the oven and let it cool down. Refrigerate for 2 hours."
    },
    {
      "position": 10,
      "text": "Slice the banana bread with raisins and arrange in a serving plate."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy with a cup of coffee or tea."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
