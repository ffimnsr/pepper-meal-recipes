  "id": "9c633478-ff4a-534d-bff5-f9da08228d12",
  "slug": "pork-mechado-recipe",
  "name": "Pork Mechado Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for pork mechado.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork, soy sauce, and juice of 1 lime in a bowl. Mix well and let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Saute the garlic and onion until the onion gets soft."
    },
    {
      "position": 4,
      "text": "Add the marinated pork (include the remaining marinade). Cook until it pork turns light brown."
    },
    {
      "position": 5,
      "text": "Pour tomato sauce and water. Let boil."
    },
    {
      "position": 6,
      "text": "Add the Knorr Pork Cube. Stir. Cover and cook in low heat for 35 to 40 minutes."
    },
    {
      "position": 7,
      "text": "Add the potato and green peas. Cook for 10 minutes."
    },
    {
      "position": 8,
      "text": "Stir-in the bell peppers. Continue to cook for 5 minutes."
    },
    {
      "position": 9,
      "text": "Add salt and ground black pepper to taste."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 12,
