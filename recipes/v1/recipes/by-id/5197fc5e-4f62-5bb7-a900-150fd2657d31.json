  "id": "5197fc5e-4f62-5bb7-a900-150fd2657d31",
  "slug": "crispy-tofu-sisig-vegan-recipe",
  "name": "Crispy Tofu Sisig",
  "recipe_type": "appetizer",
  "brief_description": "Crispy double-fried tofu tossed in a creamy, spicy sisig dressing.",
  "cuisine": "Asian Filipino Mediterranean",
  "instructions": [
    {
      "position": 1,
      "text": "Make the sisig dressing by combining the Maggi Savor Hot Chili, mayonnaise, soy sauce, calamansi juice, ground black pepper, and liver spread in a bowl. Stir until well blended, then set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a wok over medium-high heat. Deep fry the tofu cubes until golden brown. Remove them using a skimmer and place on a plate lined with paper towels. Let the tofu rest for 5 minutes."
    },
    {
      "position": 3,
      "text": "Return the tofu to the hot oil and fry again for 2 minutes or until very crispy. Remove from the wok, drain the excess oil, and set aside."
    },
    {
      "position": 4,
      "text": "Leave 1 tablespoon of oil in the wok, then add 1 tablespoon of butter. Once the butter melts, add half of the chopped onions, bell peppers, and green chili peppers. Cook until the vegetables soften slightly."
    },
    {
      "position": 5,
      "text": "Add the crispy tofu to the wok and toss gently. Continue cooking for 30 seconds."
    },
    {
      "position": 6,
      "text": "Transfer everything to a mixing bowl. Pour in the sisig dressing, then add the remaining raw onions. Toss until all the ingredients are coated evenly."
    },
    {
      "position": 7,
      "text": "To serve on a sizzling plate, heat the plate over medium heat, then add the remaining 2 tablespoons of butter. Once the butter starts to sizzle, transfer the tofu sisig onto the plate. Serve immediately with steamed rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
