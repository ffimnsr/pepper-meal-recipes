{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "e061c651-24de-5b64-a7c7-25bda8abe949",
  "slug": "buko-pandan-dessert-recipe",
  "name": "Buko Pandan",
  "recipe_type": "dessert",
  "brief_description": "Made with young coconut and pandan leaves, known for its creamy texture and vibrant green color.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a saucepan, then add pandan leaves."
    },
    {
      "position": 2,
      "text": "Cover and continue boiling for 15 minutes."
    },
    {
      "position": 3,
      "text": "Remove the leaves, then add sugar, powdered gelatin, and buko pandan flavoring. Stir until the powder is completely dissolved in water."
    },
    {
      "position": 4,
      "text": "Turn off the heat and transfer the mixture to a mold. Allow the temperature to cool."
    },
    {
      "position": 5,
      "text": "The texture of the mixture should be firm once cooled. You may also place this inside the refrigerator for faster results (Note: allow the temperature to go down before putting it in the refrigerator)."
    },
    {
      "position": 6,
      "text": "Combine young coconut strips, Nestl\u00e9 Carnation Condensada, Nestl\u00e9 All Purpose Cream, and cooked sago pearls."
    },
    {
      "position": 7,
      "text": "Allow the texture to thicken by chilling in the refrigerator or freezer for a few hours."
    },
    {
      "position": 8,
      "text": "Slice the firm gelatin into \u00bd inch cubes and combine it with the creamy mixture."
    },
    {
      "position": 9,
      "text": "Transfer to individual serving platters or cups. You can also top it with a scoop of vanilla ice cream. Serve, share, and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "medium",
