  "id": "75ebaee9-ce3c-5a03-8325-97a526bc5bd5",
  "slug": "killer-pork-sinigang",
  "name": "Killer Pork Sinigang Recipe",
  "recipe_type": "soup",
  "brief_description": "Saut\u00e9ed Pork Sinigang with taro and vegetables.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saute onion until layers separate. Add half of the tomato. Saute for 2 minutes."
    },
    {
      "position": 2,
      "text": "Add pork belly. Continue sauteeing until the pork browns while adding around 1 tablespoon fish sauce."
    },
    {
      "position": 3,
      "text": "Pour water. Cover the pot and let the liquid boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Sinigang sa Sampaloc with Gabi. Cover and adjust heat between low to medium. Cook for 30 minutes or until the pork gets tender."
    },
    {
      "position": 5,
      "text": "Add labanos. Cover and continue cooking for 30 minutes."
    },
    {
      "position": 6,
      "text": "Add eggplant, string beans, and okra. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add kangkong stalks and remaining tomato. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Season with fish sauce (as needed) and ground black pepper."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
