  "id": "7caf6418-5617-5594-8c60-7046eee438a6",
  "slug": "paella-mixta-recipe",
  "name": "Paella Mixta Recipe",
  "recipe_type": null,
  "brief_description": "Paella Mixta or Mixed Paella is another delicious Paella Variation that I enjoy eating. This recipe involves both seafood and meat.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the clam juice by boiling the mussels and clams in 1 1/2 cups water for 5 minutes. Separate the clams from the liquid. Set aside."
    },
    {
      "position": 2,
      "text": "Make the paste by combining the garlic, parsley, and paprika. Pound until the texture becomes smooth. Pour-in 1 1/2 teaspoons olive oil. Mix well and then set aside."
    },
    {
      "position": 3,
      "text": "Heat 1/4 cup olive oil in a paellera."
    },
    {
      "position": 4,
      "text": "Pan-fry the shrimp for about 1 minute per side. Remove the shrimp and then set aside."
    },
    {
      "position": 5,
      "text": "Saut\u00e9 the onion and tomato until the texture becomes soft."
    },
    {
      "position": 6,
      "text": "Put-in the chicken, rabbit meat, and chorizo. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Pour-in the chicken broth and clam juice. Let boil. Cover and simmer for 15 minutes. Add water as necessary."
    },
    {
      "position": 8,
      "text": "Put-in the garlic paste mixture and the saffron. Stir. Add salt and pepper as needed."
    },
    {
      "position": 9,
      "text": "Put-in the Calasparra rice and green peas. Let the liquid re-boil and then lower the heat. Cook for 20 to 25 minutes covered."
    },
    {
      "position": 10,
      "text": "Arrange the mussels, clams, red bell pepper strips, and shrimp on top."
    },
    {
      "position": 11,
      "text": "Serve with lemon wedges."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
  "difficulty": "hard",
