  "id": "617834eb-5e1f-5dce-82ca-0ee6cc70402f",
  "slug": "easy-chicken-teriyaki-recipe",
  "name": "How to Cook Easy Chicken Teriyaki",
  "recipe_type": "dessert",
  "brief_description": "This Chicken Teriyaki recipe makes use of boneless chicken breasts. It is marinated in special homemade Teriyaki sauce and then grilled while being basted with a sweet basting sauce.",
  "cuisine": "Japanese",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the marinade ingredients. Mix well."
    },
    {
      "position": 2,
      "text": "Combine the basting sauce ingredients. Set aside."
    },
    {
      "position": 3,
      "text": "Place the chicken breasts in a re-sealable Ziploc bag and then pour-in the marinade."
    },
    {
      "position": 4,
      "text": "Seal the bag and then place it in the fridge to marinate for 2 hours."
    },
    {
      "position": 5,
      "text": "Grill both sides of the chicken for 7 to 10 minutes while basting using the basting sauce. You may flip the chicken once in a while keep them from being burnt."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate and then garnish with sesame seeds."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 60,
  "rest_time_minutes": null,
  "difficulty": "hard",
