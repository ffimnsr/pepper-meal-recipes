  "id": "d84cd4f6-33e2-5a1d-862d-4a2f10d92ce2",
  "slug": "pork-belly-with-boiled-eggs-in-oyster-sauce",
  "name": "Pork Belly with Boiled Eggs in Oyster Sauce",
  "recipe_type": "main",
  "brief_description": "Mixing in some flavors like Worcestershire sauce can bring your meal from good to great, that is what we achieved with this Pork Belly with Boiled Eggs in Oyster Sauce recipe",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saut\u00e9 1 onion and garlic."
    },
    {
      "position": 2,
      "text": "Add the pork belly. Continue saut\u00e9ing until it browns. Note: this can take up to 5 minutes."
    },
    {
      "position": 3,
      "text": "Add the soy sauce, oyster sauce, and Worcestershire sauce. Stir and cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour the water into the pan. Cover it and let boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork cube. Cover and simmer for 60 to 80 minutes."
    },
    {
      "position": 6,
      "text": "Add the brown sugar and squeeze the lime. Cook until the sauce evaporates almost completely."
    },
    {
      "position": 7,
      "text": "Add the remaining onions. Stir and continue cooking until the onion softens."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper."
    },
    {
      "position": 9,
      "text": "Add the boiled quail eggs and gently toss. Cook for 1 minute."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
