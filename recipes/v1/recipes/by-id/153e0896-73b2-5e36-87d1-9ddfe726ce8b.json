  "id": "153e0896-73b2-5e36-87d1-9ddfe726ce8b",
  "slug": "mixed-seafood-in-coconut-milk",
  "name": "Mixed Seafood in Coconut Milk Recipe",
  "recipe_type": null,
  "brief_description": "Seafood such as shrimp, crab, squid cooked in coconut milk",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking pot, and then pour-in cooking oil."
    },
    {
      "position": 2,
      "text": "Saute garlic and onions."
    },
    {
      "position": 3,
      "text": "Pour-in coconut milk, stir, and let boil."
    },
    {
      "position": 4,
      "text": "Sprinkle ground black pepper. Add dried chilies and shrimp paste. Stir and simmer until the liquid reduces to half."
    },
    {
      "position": 5,
      "text": "Add mixed seafood and cook for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Turn off heat. Transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
