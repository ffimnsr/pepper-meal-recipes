  "id": "e68525c1-ba72-5ae8-aabe-d72e1ca85356",
  "slug": "chicken-satay-with-peanut-sauce-recipe",
  "name": "Chicken Satay Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for chicken satay.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine soy sauce, fish sauce, ginger powder, turmeric powder, chili powder, lemongrass,peanut butter, sugar, curry powder, lemon, and garlic. Stir and set aside."
    },
    {
      "position": 2,
      "text": "Put the chicken in bowl with the mixture and marinate overnight."
    },
    {
      "position": 3,
      "text": "Soak the skewers in water for 10 to 15 minutes."
    },
    {
      "position": 4,
      "text": "Skewer the marinated chicken strips."
    },
    {
      "position": 5,
      "text": "Make the peanut sauce by combining all the ingredients for the sauce in a saucepan. Stir. Turn-on heat and let the mixture boil.Lower the heat and simmer until the sauce thickens."
    },
    {
      "position": 6,
      "text": "Grill each side for 6 to 7 minutes. Note: use the leftover marinade as the basting sauce."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with Peanut Sauce."
    },
    {
      "position": 8,
      "text": "Share and enjoy"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 60,
