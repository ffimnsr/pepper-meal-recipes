  "id": "f8607d30-baee-5a80-8eda-11c8c255cd6b",
  "slug": "easy-champorado-recipe",
  "name": "Easy Champorado Recipe",
  "recipe_type": null,
  "brief_description": "Easy Champorado Recipe is a chocolate rice pudding variation that uses pure chocolate known as tablea. You will find this real simple and quick.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Put-in the tablea and then stir. Let it dissolve in boiling water."
    },
    {
      "position": 3,
      "text": "Add-in the rice. Let the water re-boil. Set the heat to low-medium and then stir almost constantly to avoid sticking. The rice should be ready when it absorbs the water (about 15 to 25 minutes)."
    },
    {
      "position": 4,
      "text": "Add the sugar. Stir until the sugar dissolves."
    },
    {
      "position": 5,
      "text": "Transfer the champorado in individual serving bowls. Top with condensed milk."
    },
    {
      "position": 6,
      "text": "Serve with tuyo. Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
