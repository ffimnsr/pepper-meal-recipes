  "id": "0331f43f-45f4-5f65-9261-59618ce58090",
  "slug": "chicken-hamonado-recipe",
  "name": "Chicken Hamonado",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for hamonadong manok or sweet chicken hamonado.&nbsp;",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken, pineapple juice from the pineapple tidbits can, and soy sauce in a bowl. Mix well. Cover and refrigerate overnight."
    },
    {
      "position": 2,
      "text": "Arrange a colander over a large bowl. Pour the chicken mixture. Let the it stay for 10 minutes or until the marinade completely drips-off the chicken. Set the marinade aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a cooking pot. Pan-fry chicken for 2 to 3 minutes per side. Remove from the pot. Set aside."
    },
    {
      "position": 4,
      "text": "Using the remaining oil, saute onion and garlic until onion softens."
    },
    {
      "position": 5,
      "text": "Add chicken pieces,. Pour marinade. Let boil. Cover and cook in low heat for 30 to 35 minutes. Note: add water as needed."
    },
    {
      "position": 6,
      "text": "Add sugar and pineapple tidbits. Stir. Cover and continue to cook for 10 minutes."
    },
    {
      "position": 7,
      "text": "Season with salt and pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "medium",
