  "slug": "slow-cooked-asian-pork-chops",
  "name": "Slow Cooked Asian Pork Chop Recipe",
  "recipe_type": null,
  "brief_description": "This Slow Cooked Asian Pork Chop Recipe is highly recommended. The pork is so delicious and literally melts in your mouth.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the pork chops in the slow cooker."
    },
    {
      "position": 2,
      "text": "Add the other ingredients and stir a little bit to distribute."
    },
    {
      "position": 3,
      "text": "Turn-on the slow cooker to low heat settings and cook for 6 to 7 hours."
    },
    {
      "position": 4,
      "text": "Remove from the slow cooker and transfer to a serving plate."
    },
    {
      "position": 5,
      "text": "Garnish with sesame seeds and serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 420,
