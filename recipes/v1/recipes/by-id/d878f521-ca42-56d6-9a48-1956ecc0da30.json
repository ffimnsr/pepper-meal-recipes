  "slug": "inihaw-na-pusit-grilled-squid",
  "name": "Inihaw na Pusit Recipe (Grilled Squid)",
  "recipe_type": "main",
  "brief_description": "Grilled stuffed squid.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a large container, combine onion and tomato"
    },
    {
      "position": 2,
      "text": "Add some salt and pepper and mix well."
    },
    {
      "position": 3,
      "text": "Stuff the squid with the onion and tomato mixture. Add more if necessary."
    },
    {
      "position": 4,
      "text": "Grill the squid for 6 to 8 minutes per side."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 6,
      "text": "Make the dipping sauce by combining soy sauce, chili pepper, and lemon. Stir."
    },
    {
      "position": 7,
      "text": "Serve with the dipping sauce. Share and Enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 18,
