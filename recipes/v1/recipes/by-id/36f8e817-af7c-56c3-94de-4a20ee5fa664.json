{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "36f8e817-af7c-56c3-94de-4a20ee5fa664",
  "slug": "siomai-pork-and-shrimp-with-chili-garlic-oil",
  "name": "Pork and Shrimp Siomai with Chili Garlic Oil",
  "recipe_type": "appetizer",
  "brief_description": "This is a recipe for pork and shrimp shumai with a topping of chili garlic oil.",
  "cuisine": "Chinese Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the shumai by combining pork, shrimp, onion, carrot, green onion, and egg in a bowl. Mix well and then add Knorr Liquid Seasoning, sesame oil, salt, and ground black pepper. Continue mixing until the ingredients are well distributed."
    },
    {
      "position": 2,
      "text": "Gradually add the cornstarch as needed. Note: this is a binding ingredient that helps absorb moisture from the mixture."
    },
    {
      "position": 3,
      "text": "Put steamer liners on your steamer. Arrange the siomai on top. Steam for 20 to 30 minutes."
    },
    {
      "position": 4,
      "text": "Make the chili garlic oil by mincing the garlic and Thai chili pepper in a food processor."
    },
    {
      "position": 5,
      "text": "Pour 1 1/2 cups of cooking oil in a wok and then add the minced garlic and chili peppers along with star anise and dried bay leaves. Turn on the heat of the stove to the lowest setting. Gradually stir the mixture while cooking for 30 to 45 minutes."
    },
    {
      "position": 6,
      "text": "Add vinegar, brown sugar, salt, and oyster sauce unto the mixture. Continue cooking for 3 minutes."
    },
    {
      "position": 7,
      "text": "Remove the star anise and dried bay leaves."
    },
    {
      "position": 8,
      "text": "Arrange the siomai on a serving plate and top with chili garlic oil then serve with a dipping sauce composed of soy sauce and calamansi."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 30,
