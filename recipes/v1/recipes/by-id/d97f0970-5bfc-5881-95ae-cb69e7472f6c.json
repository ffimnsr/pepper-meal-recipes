  "id": "d97f0970-5bfc-5881-95ae-cb69e7472f6c",
  "slug": "pinoy-spaghetti-recipe",
  "name": "Pinoy Spaghetti Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pinoy Spaghetti.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the spaghetti according to package instructions. Drain the water. Set the spaghetti aside."
    },
    {
      "position": 2,
      "text": "Make the sauce by heating oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Saute garlic and onions until the onions starts to soften."
    },
    {
      "position": 4,
      "text": "Add ground pork. Cook until light brown."
    },
    {
      "position": 5,
      "text": "Add ham and hotdogs. Cook for 2 to 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour the tomato sauce into the pot. Stir. Add water and let boil."
    },
    {
      "position": 7,
      "text": "Add Knorr Pork Cube. Stir. Cover the pot and continue to cook for 30 to 35 minutes."
    },
    {
      "position": 8,
      "text": "Put the liver spread into the pot. Stir."
    },
    {
      "position": 9,
      "text": "Add the bell peppers and sugar. Stir."
    },
    {
      "position": 10,
      "text": "Add the tomato paste. Stir and continue cook until the desired consistency is achieved."
    },
    {
      "position": 11,
      "text": "Add salt and ground black pepper. Cook for 1 minute."
    },
    {
      "position": 12,
      "text": "Arrange the spaghetti in a plate. Top with spaghetti sauce and grated cheese."
    },
    {
      "position": 13,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
