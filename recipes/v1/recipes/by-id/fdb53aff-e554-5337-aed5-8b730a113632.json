  "id": "fdb53aff-e554-5337-aed5-8b730a113632",
  "slug": "drunken-mussels-recipe",
  "name": "Drunken Mussels Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Drunken Mussels makes a good appetizer. This is best eaten with warm toast bread or with croutons. I tried to make the recipe as simple as possible so that you can follow easily.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a pan."
    },
    {
      "position": 2,
      "text": "Once the butter melts and starts to get hot, add the garlic. Continue to cook in low to medium heat until the garlic turns light brown. Do not cook in high heat because the butter can get burnt."
    },
    {
      "position": 3,
      "text": "Pour-in the white wine. Let boil. Continue to cook and liquid evaporate until it reduces to half."
    },
    {
      "position": 4,
      "text": "Add the mussels. Stir. Cover and cook for 10 minutes in medium heat."
    },
    {
      "position": 5,
      "text": "Add salt and chopped parsley. Stir. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with lime wedges."
    },
    {
      "position": 7,
      "text": "Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
