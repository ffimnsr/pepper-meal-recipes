  "id": "8aaf184e-69a3-503d-b097-5c009823570c",
  "slug": "octopus-sa-kamatis",
  "name": "Octopus sa Kamatis",
  "recipe_type": null,
  "brief_description": "This is the first time that we'll feature an octopus recipe and I'm pretty much excited. By looking at the ingredients and procedure, this seems to be a quick and healthy one.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cooking Procedure:"
    },
    {
      "position": 2,
      "text": "Heat a pan and pour-in the cooking oil"
    },
    {
      "position": 3,
      "text": "When the oil is hot enough; saute the garlic, onions, and tomatoes"
    },
    {
      "position": 4,
      "text": "Put-in the octopus and cook until the natural juices from the octopus comes out (since octopus are already salty, there is no need to add salt)"
    },
    {
      "position": 5,
      "text": "After the juices starts to boil, simmer for a minute (do not overcook)"
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl and serve."
    },
    {
      "position": 7,
      "text": "Share and Enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
