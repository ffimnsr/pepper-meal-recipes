  "id": "d356b955-70d2-549f-b853-bdd578e38877",
  "slug": "snails-spinach-coconut-milk",
  "name": "Snails with Spinach in Coconut Milk Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Snails with Spinach in Coconut Milk Recipe is a good way to prepare snails. I like this recipe because it produces a perfectly delicious appetizer dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute the garlic, ginger, and onion when the oil becomes hot."
    },
    {
      "position": 3,
      "text": "Add-in the ground black pepper and crushed red pepper. Stir."
    },
    {
      "position": 4,
      "text": "Pour-in the coconut milk. Let boil. Simmer (cook in low heat) for 10 minutes."
    },
    {
      "position": 5,
      "text": "Add-in the sea snails. Increase the heat to medium. Stir and cover. Cook for 15 to 20 minutes while gently stirring every 3 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the spinach. Stir and continue to cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
