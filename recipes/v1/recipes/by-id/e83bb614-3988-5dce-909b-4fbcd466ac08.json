  "id": "e83bb614-3988-5dce-909b-4fbcd466ac08",
  "slug": "how-to-cook-longsilog",
  "name": "Longsilog Recipe",
  "recipe_type": "dessert",
  "brief_description": "Filipino sweet sausage with garlic fried rice and fried egg. This complete meal is perfect for breakfast.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat 2 tablespoons of oil in a pan. Once the oil gets hot, fry the eggs. Remove from the pan. Set aside."
    },
    {
      "position": 2,
      "text": "Add remaining oil in the pan. Fry the longanisa until the outer part turns light brown (around 1 1/2 minutes)."
    },
    {
      "position": 3,
      "text": "Pour-in water. Let boil. Continue boiling until the water evaporates. Fry the longanisa in remaining oil until fully cooked. Remove from the pan and set aside."
    },
    {
      "position": 4,
      "text": "Using the remaining oil, cook garlic until it starts to turn light brown."
    },
    {
      "position": 5,
      "text": "Add rice. Stir-fry for 3 minutes. Season with salt and ground black pepper."
    },
    {
      "position": 6,
      "text": "Assemble the fried eggs, longanisa, and sinangag on a plate. Serve with spicy vinegar as a dipping sauce for the longanisa."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
