  "id": "54249b09-3cd5-5059-8686-4eb29880eec0",
  "slug": "sarciadong-itlog-recipe",
  "name": "Sarciadong Itlog Recipe",
  "recipe_type": "main",
  "brief_description": "Sarciadong Itlog is a simple and easy-to-prepare dish that can be eaten with warm rice. It is composed of hard boiled eggs and vegetables. This dish can be good recipe for lent since the recipe does not require meat.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the onion, garlic, tomato, and bell peppers for 3 to 5 minutes."
    },
    {
      "position": 3,
      "text": "Pour-in the chicken (or vegetable) broth. Let boil."
    },
    {
      "position": 4,
      "text": "Add the fish sauce and ground black pepper. Stir."
    },
    {
      "position": 5,
      "text": "Pour-in the beaten egg. Stir until the egg is distributed. Continue to cook for 3 minutes more."
    },
    {
      "position": 6,
      "text": "Add the chopped scallions and boiled eggs. Cook for 2 minutes,"
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Sprinkle chopped parsley on top."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
