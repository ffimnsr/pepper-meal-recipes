  "slug": "vegetable-stir-fry-pasta-recipe",
  "name": "Vegetable Stir-fry Pasta Recipe",
  "recipe_type": null,
  "brief_description": "This Vegetable Stir-fry Pasta Recipe is quick and easy to prepare. Checkout this post for the complete details. Happy cooking.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a wok and put-in the cooking oil."
    },
    {
      "position": 2,
      "text": "When the oil becomes hot, put-in the onion and cook for 2 minutes."
    },
    {
      "position": 3,
      "text": "Add the bell peppers and white mushrooms then stir. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add salt, pepper, and yellow squash then stir and cook for 3 to 5 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the rotini pasta and cook for 2 to 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in the marinara sauce and mix well. Cook for a minute."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
