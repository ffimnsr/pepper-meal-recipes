  "id": "ce81d0c2-ade0-5ea8-830a-5e1ad90f344d",
  "slug": "beef-in-oyster-sauce-stir-fry-with-ampalaya",
  "name": "Beef Stir Fry in Oyster Sauce with Ampalaya",
  "recipe_type": null,
  "brief_description": "Beef in Oyster Sauce Stir Fry with Ampalaya is a perfect dish with a bowl of rice. It is tasty, delicious, and easy to prepare",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine beef, soy sauce, cooking wine, Sesame oil, and ground black pepper. Mix well."
    },
    {
      "position": 2,
      "text": "Add cornstarch to the mixture. Continue to mix until all the ingredients are well blended. Set aside."
    },
    {
      "position": 3,
      "text": "Heat 3 tablespoons of cooking oil in a pan or wok. Once the oil gets hot, stir-fry the beef slices for 4 to 6 minutes or until the beef turns brown. Remove the stir fried beef from the pan and place in a clean plate."
    },
    {
      "position": 4,
      "text": "Using the same pan, add the remaining cooking oil. Add the bitter gourd (ampalaya) slices and stir-fry for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the oyster sauce. Continue to stir-fry for 30 seconds."
    },
    {
      "position": 6,
      "text": "Add the stir-fried beef. Cook for 1 minute more."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with warm rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
