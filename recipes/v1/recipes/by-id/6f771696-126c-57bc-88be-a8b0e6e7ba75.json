  "id": "6f771696-126c-57bc-88be-a8b0e6e7ba75",
  "slug": "ginataang-bilo-bilo-langka-recipe",
  "name": "Ginataang Bilo bilo with Langka",
  "recipe_type": "dessert",
  "brief_description": "Ginataang Bilo-bilo with Langka is a Filipino meryenda dish composed of glutinous rice balls \u2013 locally known as bilo-bilo, coconut cream, sugar, sago pearls, and ripe jackfruit.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the coconut cream. Stir and cook until the mixture starts to boil again."
    },
    {
      "position": 3,
      "text": "Gradually stir-in the sugar."
    },
    {
      "position": 4,
      "text": "Add the ripe jackfruit. Cover and cook in low heat for 15 minutes."
    },
    {
      "position": 5,
      "text": "Add-in the bilo-bilo. Continue to cook for another 15 minutes while stirring every 3 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the sago. Cook for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 5,
