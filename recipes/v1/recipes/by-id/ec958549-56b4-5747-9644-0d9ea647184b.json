  "id": "ec958549-56b4-5747-9644-0d9ea647184b",
  "slug": "dinengdeng-with-fried-fish-recipe",
  "name": "Dinengdeng with Fried Fish Recipe",
  "recipe_type": "soup",
  "brief_description": "Dinengdeng with Fried Fish is a traditional Filipino dish featuring a savory vegetable stew cooked in a flavorful broth, paired with crispy, golden-brown fried fish. It combines a hearty mix of vegetables and fish, creating a delicious and nutritious meal that&#39;s perfect with a side of white rice.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the fish. Heat oil in a pan. Once the oil gets hot, fry the fish until the side turns golden brown. Turn the fish over and continue to fry the other side until the same color is achieved. Remove the fried fish from the cooking pot. Place in a plate and set aside."
    },
    {
      "position": 2,
      "text": "Pour water in a clean cooking pot. Let boil."
    },
    {
      "position": 3,
      "text": "Add onion, ginger, and tomato. Cover and boil in medium heat for 5 minutes."
    },
    {
      "position": 4,
      "text": "Stir-in the bagoong. Add okra, bitter gourd, and snake beans. Cover and cook for 7 to 12 minutes."
    },
    {
      "position": 5,
      "text": "Add the hot pepper leaves and squash flower. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Put the fried fish top. Cover. Cook for 1 minute. Transfer to a serving bowl."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
