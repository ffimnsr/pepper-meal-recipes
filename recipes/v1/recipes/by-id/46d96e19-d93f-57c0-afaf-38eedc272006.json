  "id": "46d96e19-d93f-57c0-afaf-38eedc272006",
  "slug": "baked-garlic-parmesan-french-fries",
  "name": "Baked Garlic Parmesan French Fries",
  "recipe_type": "side",
  "brief_description": "This is a recipe for baked cheese fries using Parmesan cheese.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 400 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "In a large bowl, combine potato, 1/2 teaspoon salt, garlic powder, and olive oil. Gently mix the all the ingredients."
    },
    {
      "position": 3,
      "text": "Arrange the potatoes in a baking tray. Place inside the oven. Bake for 35 minutes. Note: try to flip the fries in the process to so cook then evenly."
    },
    {
      "position": 4,
      "text": "Put the fries back into the bowl. Sprinkle Parmesan cheese, parsley, and remaining salt. Toss."
    },
    {
      "position": 5,
      "text": "Arrange in the same baking tray, and then bake for another 8 to 12 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the oven. Transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
