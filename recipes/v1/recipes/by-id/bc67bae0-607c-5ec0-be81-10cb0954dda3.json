  "id": "bc67bae0-607c-5ec0-be81-10cb0954dda3",
  "slug": "tofu-tokwa-tausi-straw-mushrooms",
  "name": "Tofu with Tausi and Straw Mushrooms",
  "recipe_type": null,
  "brief_description": "Tofu with Tausi and Straw Mushroom is a dish that I enjoy eating occasionally. This dish is made-up of deep fried tofu, tausi or salted black beans, and straw mushroom \u2013- as the title of the dish says. I just want to point out that this recipe makes use of extra firm tofu;",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the chicken powder and 1 cup water. Stir and set aside."
    },
    {
      "position": 2,
      "text": "Heat a wok or pan. Pour-in the cooking oil."
    },
    {
      "position": 3,
      "text": "When the oil turns hot, saut\u00e9 the ginger and green onions for 30 seconds."
    },
    {
      "position": 4,
      "text": "Add the deep fried tofu, salted black beans, and straw mushrooms. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add the sherry wine and oyster sauce . Stir."
    },
    {
      "position": 6,
      "text": "Pour-in the water and chicken powder mixture. Let the liquid boil. Continue to cook for 2 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Pour-in the cornstarch and water mixture. Stir and cook for a minute or until the sauce thickens."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
