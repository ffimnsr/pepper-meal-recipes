  "id": "20791c61-b71a-580b-a289-e90f791e9b6b",
  "slug": "paella-de-marisco-recipe",
  "name": "Paella de Marisco",
  "recipe_type": "main",
  "brief_description": "Paella with mussels, shrimp, and clams",
  "cuisine": "Spanish",
  "instructions": [
    {
      "position": 1,
      "text": "Crush the garlic and pound until smooth."
    },
    {
      "position": 2,
      "text": "Add the parsley and continue to pound until desired smooth consistency is reached."
    },
    {
      "position": 3,
      "text": "Pour-in olive oil and add paprika. Mix well and then set aside."
    },
    {
      "position": 4,
      "text": "Heat the olive oil in a paellera (paella pan) using medium to high heat."
    },
    {
      "position": 5,
      "text": "Pan-fry the fish fillet until both sides turn light brown."
    },
    {
      "position": 6,
      "text": "Remove the fish from the pan and then chop into small pieces. Set aside."
    },
    {
      "position": 7,
      "text": "Fry both sides of the shrimp until the color turns orange."
    },
    {
      "position": 8,
      "text": "Remove the shrimp from the pan. Set aside."
    },
    {
      "position": 9,
      "text": "Saut\u00e9 the onion, scallion, and red bell pepper."
    },
    {
      "position": 10,
      "text": "Add the tomato and cook until it becomes soft."
    },
    {
      "position": 11,
      "text": "Pour-in the clam juice. Let boil."
    },
    {
      "position": 12,
      "text": "Add the garlic, parsley, and paprika mixture and the Spanish saffron. Stir."
    },
    {
      "position": 13,
      "text": "Put-in the paella rice. Allow the liquid to re-boil."
    },
    {
      "position": 14,
      "text": "Add the chopped pan fried fish fillet and salt. Stir."
    },
    {
      "position": 15,
      "text": "Adjust the heat to low. Let the rice cook for 20 to 25 minutes (you can cover the pan if the rice is taking too long to cook)."
    },
    {
      "position": 16,
      "text": "Arrange the mussels, clams, shrimp, and roasted red bell pepper on top of the rice."
    },
    {
      "position": 17,
      "text": "Cover the paellera with aluminum foil and then turn the heat off."
    },
    {
      "position": 18,
      "text": "Serve with lemon wedges on the side."
    },
    {
      "position": 19,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 15,
