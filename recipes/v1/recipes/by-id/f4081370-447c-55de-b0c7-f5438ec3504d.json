  "id": "f4081370-447c-55de-b0c7-f5438ec3504d",
  "slug": "pesang-isda-recipe",
  "name": "Pesang Isda Recipe",
  "recipe_type": null,
  "brief_description": "Pesang Isda is a Fish Recipe. It is also called fish in ginger stew. Watch our cooking video to learn how to cook this dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt on the fish and set aside."
    },
    {
      "position": 2,
      "text": "Heat a frying pan then pour-in 6 tablespoons of cooking oil."
    },
    {
      "position": 3,
      "text": "Fry the fish until the color of one side turns golden brown. Flip to fry the other side then turn off the heat and set the fish aside."
    },
    {
      "position": 4,
      "text": "Heat a cooking pot and pour-in 2 tablespoons of cooking oil."
    },
    {
      "position": 5,
      "text": "When the oil is hot enough, saut\u00e9 garlic, ginger and onion."
    },
    {
      "position": 6,
      "text": "Put-in the fish sauce and whole peppercorn then stir."
    },
    {
      "position": 7,
      "text": "Pour-in the rice washing then let boil,"
    },
    {
      "position": 8,
      "text": "Put-in the fried fish then simmer for 10 minutes in low heat."
    },
    {
      "position": 9,
      "text": "Add the chopped green onions and bok choy and simmer for 3 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate then serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
