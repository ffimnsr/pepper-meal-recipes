  "id": "25e911b6-1ec0-5c09-84c9-2c8f8479a64d",
  "slug": "beef-nilaga",
  "name": "Beef Nilaga Recipe",
  "recipe_type": "soup",
  "brief_description": "A traditional Filipino boiled beef soup prepared with tender brisket, potatoes, cabbage, and saba bananas simmered in a flavorful clear broth. A simple and hearty dish that captures the comforting essence of Filipino home cooking.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Saute the onion until texture becomes soft"
    },
    {
      "position": 2,
      "text": "Add-in the beef brisket and cook for about 5 minutes"
    },
    {
      "position": 3,
      "text": "Add the fish sauce and whole peppercorn then mix well"
    },
    {
      "position": 4,
      "text": "Pour the water and bring to a boil. Simmer for 1 to 2 hours (or 30 minutes if using pressure cooker)"
    },
    {
      "position": 5,
      "text": "Add the potato, saba banana, and carrots. Simmer for 5 to 7 minutes"
    },
    {
      "position": 6,
      "text": "Add the bok choy. Cover the pot and turn off the heat. Let it stay for 5 minutes."
    },
    {
      "position": 7,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 130,
  "preparation_time_minutes": 10,
