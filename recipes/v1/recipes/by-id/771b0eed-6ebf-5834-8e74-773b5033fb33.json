  "id": "771b0eed-6ebf-5834-8e74-773b5033fb33",
  "slug": "deep-fried-breaded-pork-chops",
  "name": "Deep Fried Breaded Pork Chops",
  "recipe_type": null,
  "brief_description": "Deep Fried Breaded Pork Chop is a quick dish to prepare for lunch. It works well with mashed potato, steamed veggies, and even rice. I like mine with gravy",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and pepper all over the pork chops. Let it rest for 10 minutes."
    },
    {
      "position": 2,
      "text": "Pour cooking in a wide cooking pot and then apply heat."
    },
    {
      "position": 3,
      "text": "Meanwhile combine flour and cornstarch in a wide plate. Mix well."
    },
    {
      "position": 4,
      "text": "Crack the eggs in a bowl. Beat until the texture becomes smooth."
    },
    {
      "position": 5,
      "text": "Dredge a piece of pork chop in the flour mixture. Dip it on the bowl with egg making sure that every inch is covered with beaten egg. Dredge it back in the flour mixture. Once the oil is hot, slowly put the piece of pork chop in the cooking pot. Cook in medium heat for 12 to 15 minutes. Remove from the cooking pot. Let the oil drip-off and then arrange in a plate. Perform this step until all the pork chops are consumed."
    },
    {
      "position": 6,
      "text": "Serve with gravy or ketchup. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
