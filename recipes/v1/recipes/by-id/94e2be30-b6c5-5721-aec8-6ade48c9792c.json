{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "94e2be30-b6c5-5721-aec8-6ade48c9792c",
  "slug": "pork-adobo-in-pineapple-juice-with-boiled-egg-knr-pc",
  "name": "Pork Adobo in Pineapple Juice with Boiled Eggs",
  "recipe_type": "drink",
  "brief_description": "Pork belly cooked in pineapple juice with soy sauce and vinegar and served with boiled eggs.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork, pineapple juice, and soy sauce in a bowl. Mix well. Cover the bowl and marinate the pork for at least 1 hour."
    },
    {
      "position": 2,
      "text": "Start to boil the eggs by placing in a cooking pot with water. Turn on the heat and bring to a rapid boil. Turn the heat off when the water starts to boil rapidly. Let the egg stay submerged in hot water for 10 minutes. Discard the hot water and pour-in cold water right away to stop the eggs from cooking through residual heat. Add ice cubes and let it stay for 10 minutes. Peel and set aside."
    },
    {
      "position": 3,
      "text": "Cook the pork adobo by heating oil in a cooking pot. Add crushed garlic. Cook until light brown."
    },
    {
      "position": 4,
      "text": "Separate the marinade from the pork belly. Set it aside. Put pork in the pan. Cook until light to medium brown."
    },
    {
      "position": 5,
      "text": "Pour marinade into the pan. Add water. Let the mixture boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Pork Cube, whole peppercorn, and dried bay leaves. Cover and cook between low to medium heat for 1 hour or until the pork is tender."
    },
    {
      "position": 7,
      "text": "Pour vinegar and add brown sugar into the pan. Stir. Turn the heat off. You can add the peeled eggs or serve it separately with the pork adobo."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
