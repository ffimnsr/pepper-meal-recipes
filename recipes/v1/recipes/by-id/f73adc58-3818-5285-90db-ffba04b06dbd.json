  "id": "f73adc58-3818-5285-90db-ffba04b06dbd",
  "slug": "pork-adobo-with-tofu",
  "name": "Pork Adobo with Tofu Recipe",
  "recipe_type": null,
  "brief_description": "Pork Adobo with Tofu is a good way to twist the traditional Filipino Adobo recipe. It tastes good and it has a wonderful texture.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic until color turns light brown."
    },
    {
      "position": 3,
      "text": "Add pork and cook for 3 to 5 minutes or until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Pour-in soy sauce, oyster sauce, and water. Let boil and simmer for 45 minutes or until the pork becomes tender."
    },
    {
      "position": 5,
      "text": "Add vinegar and wait until the liquid re-boils. Stir."
    },
    {
      "position": 6,
      "text": "Put-in sugar and fried tofu. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add salt, and pepper. Stir."
    },
    {
      "position": 8,
      "text": "Turn off heat. Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
