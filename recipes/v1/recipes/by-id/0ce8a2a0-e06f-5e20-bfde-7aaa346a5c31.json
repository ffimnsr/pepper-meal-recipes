  "id": "0ce8a2a0-e06f-5e20-bfde-7aaa346a5c31",
  "slug": "rellenong-pusit-stuffed-squid-recipe",
  "name": "Rellenong Pusit",
  "recipe_type": "main",
  "brief_description": "Squid stuffed with ground meat and then fried until crispy.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine squid, soy sauce, and juice from 1 piece lemon and marinade for 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat a pan and pour-in 3 tablespoons cooking oil."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 garlic, onion, celery, and tomato."
    },
    {
      "position": 4,
      "text": "Put-in the ground pork and cook until the color turns light brown (about 5 minutes)."
    },
    {
      "position": 5,
      "text": "Add carrots, salt and ground black pepper then stir. Cook for 10 to 15 minutes. Turn-off heat and let cool."
    },
    {
      "position": 6,
      "text": "Stuff the marinated squid with the cooked ground pork. Insert toothpicks at the opening of the squid to secure the filling."
    },
    {
      "position": 7,
      "text": "Dip the stuffed squid in beaten egg then dredge in flour. Set aside."
    },
    {
      "position": 8,
      "text": "Heat another pan and pour-in 7 tablespoons of cooking oil."
    },
    {
      "position": 9,
      "text": "Pan-fry the squid. Cook each side for 3 to 5 minutes. Note: Do not overcook the squid so that it will remain tender."
    },
    {
      "position": 10,
      "text": "Transfer the cooked squid in a serving plate and serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
