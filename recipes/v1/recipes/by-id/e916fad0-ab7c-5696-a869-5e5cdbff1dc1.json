{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "e916fad0-ab7c-5696-a869-5e5cdbff1dc1",
  "slug": "ghostly-dark-chocolate-cupcake",
  "name": "Ghostly Dark Chocolate Cupcake",
  "recipe_type": "dessert",
  "brief_description": "This Dark Chocolate Cupcake is perfect for halloween. Its cute ghostly design is interesting for the kids and fits the season, while its rich dark chocolate can make both kids and adults happy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine AP flour, baking soda, cocoa powder, and salt in a mixing bowl. Whisk to incorporate the ingredients. Set aside."
    },
    {
      "position": 2,
      "text": "Cream the butter using an electric or sand mixer."
    },
    {
      "position": 3,
      "text": "Gradually whisk-in the sugars (white and brown) and egg."
    },
    {
      "position": 4,
      "text": "Slowly add the milk while whisking and then gradually put-in the flour mixture. Continue whisking until a homogeneous mixture is formed."
    },
    {
      "position": 5,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 6,
      "text": "Pour the cupcake batter in cupcake colds arranged in cupcake trays."
    },
    {
      "position": 7,
      "text": "Bake for 14 to 18 minutes, or until it passes the toothpick test"
    },
    {
      "position": 8,
      "text": "Remove from the oven to cool down. Frost using the instant orange colored frosting and top with a ghost candy."
    },
    {
      "position": 9,
      "text": "Serve during your Halloween party. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 12,
