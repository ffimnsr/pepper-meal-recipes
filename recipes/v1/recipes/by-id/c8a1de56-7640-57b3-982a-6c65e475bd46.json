  "id": "c8a1de56-7640-57b3-982a-6c65e475bd46",
  "slug": "chicken-galantina-recipe",
  "name": "Chicken Galantina Recipe",
  "recipe_type": null,
  "brief_description": "Chicken Galantina is a popular Filipino Holiday Stuffed Chicken recipe. This dish is best enjoyed cold and can be eaten with either bread or rice. Preparing this dish takes some time and patience.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine ground pork, ham, Vienna sausage, bell pepper, carrot, onion, raisins, sweet pickle relish, salt, and pepper. Mix well."
    },
    {
      "position": 2,
      "text": "Add the bread crumbs and then continue mixing. Set aside."
    },
    {
      "position": 3,
      "text": "Combine lemon juice and soy sauce in a large container. Stir."
    },
    {
      "position": 4,
      "text": "Marinate the whole chicken in the lemon and soy sauce mixture for 30 minutes."
    },
    {
      "position": 5,
      "text": "Remove the chicken from the mixture and then stuff with half of the meat and vegetable mixture."
    },
    {
      "position": 6,
      "text": "Arrange the boiled eggs and Chinese sausage inside the chicken and then continue to put-in the rest of the meat mixture."
    },
    {
      "position": 7,
      "text": "Secure the chicken by wrapping it in a cheese cloth and tying both ends of the cloth with a kitchen twine."
    },
    {
      "position": 8,
      "text": "Meanwhile, boil about 1 to 1 1/2 quarts of water in a steamer."
    },
    {
      "position": 9,
      "text": "Steam the chicken for 90 minutes."
    },
    {
      "position": 10,
      "text": "Let the chicken cool down and then refrigerate for 3 to 6 hours."
    },
    {
      "position": 11,
      "text": "Slice into serving pieces."
    },
    {
      "position": 12,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
