  "id": "514b076c-b012-5321-a600-69abecc8ec6e",
  "slug": "how-to-cook-pumpkin-soup",
  "name": "Pumpkin Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "This Pumpkin Soup Recipe is rich and hearty, and it is so good. Get to know the simple steps on how to cook this soup through our recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Place the calabaza in a baking tray, and then sprinkle ground black pepper and garlic powder on the calabaza."
    },
    {
      "position": 2,
      "text": "Preheat oven to 350 degrees Fahrenheit and bake the calabaza for 18 to 20 minutes."
    },
    {
      "position": 3,
      "text": "Remove the calabaza from the oven and set aside until it cools down."
    },
    {
      "position": 4,
      "text": "Place the calabaza in a blender along with onions and chicken broth, and then blend until smooth."
    },
    {
      "position": 5,
      "text": "Heat a cooking pot and pour-in the calabaza puree. Let boil."
    },
    {
      "position": 6,
      "text": "Add salt and heavy whipping cream, and then cook for 15 minutes."
    },
    {
      "position": 7,
      "text": "Turn the heat off, and then transfer to a serving bowl."
    },
    {
      "position": 8,
      "text": "Garnish with dried parsley."
    },
    {
      "position": 9,
      "text": "Serve hot."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
