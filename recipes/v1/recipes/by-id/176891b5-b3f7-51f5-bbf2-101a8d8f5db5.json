  "id": "176891b5-b3f7-51f5-bbf2-101a8d8f5db5",
  "slug": "butter-garlic-whole-fried-chicken",
  "name": "Butter Garlic Fried Chicken",
  "recipe_type": "main",
  "brief_description": "Crispy whole fried chicken deep fried in garlic oil and drizzled with butter sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Spatchcock the chicken. Rub Knorr liquid seasoning all over. Let it stay for 30 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, combine garlic and 1 cup cooking oil in a small pot. Cook in low heat setting until the garlic turns golden brown. Filter the garlic using a kitchen strainer. Set both the toasted garlic and garlic oil aside."
    },
    {
      "position": 3,
      "text": "Crack the egg in a bowl and add milk. Whisk until well blended. Spread the mixture all over the chicken."
    },
    {
      "position": 4,
      "text": "Dredge the chicken in flour. Make sure that the chicken gets completely coated with flour. Let it stay for 10 minutes. This will ensure that the flour sticks will stick well."
    },
    {
      "position": 5,
      "text": "Combine garlic oil with 2 cups cooking oil. Heat to 325F."
    },
    {
      "position": 6,
      "text": "Deep-fry the chicken for 13 to 16 minutes. Set aside."
    },
    {
      "position": 7,
      "text": "Make the butter mixture by melting 2 tablespoons of butter in a saucepan. Add salt, ground black pepper, parsley, and water. Turn off heat."
    },
    {
      "position": 8,
      "text": "Arrange the chicken on a serving plate. Spoon the butter mixture and top with lots of toasted garlic. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
