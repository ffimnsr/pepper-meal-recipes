  "id": "405a89cc-bda4-5b17-a477-b0b392620fd0",
  "slug": "hawaiian-pizza-no-bake",
  "name": "Hawaiian Pizza (No Bake)",
  "recipe_type": null,
  "brief_description": "There is perhaps no other dish that has caused an uproar quite like Hawaiian Pizza. However, you have to admit that it tastes good.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the pizza dough by combining flour, baking powder, sugar, and salt. Mix well"
    },
    {
      "position": 2,
      "text": "Add oil and beer. Continue mixing until all the ingredients are fully incorporated."
    },
    {
      "position": 3,
      "text": "Knead the dough until smooth. Form it into a ball. Wrap the dough loosely with plastic wrap. Let it rest for 10 minutes."
    },
    {
      "position": 4,
      "text": "Roll dough out into a 10-inch circle."
    },
    {
      "position": 5,
      "text": "Place the pan over medium-high heat for 30 seconds."
    },
    {
      "position": 6,
      "text": "Transfer the pizza dough in the pan and cover with a lid. Set the stove to medium low heat Cook it until you see large bubbles forming on top, for about 3 minutes. Poke the pizza crust with a fork to deflate the bubbles."
    },
    {
      "position": 7,
      "text": "Flip the pizza crust. Continue cooking for 2 minutes."
    },
    {
      "position": 8,
      "text": "Spread the pizza sauce over the dough. Top with cheese, CDO Sweet Ham sliced, and pineapple tidbits."
    },
    {
      "position": 9,
      "text": "Cover and cook the pizza for another 4 to 5 minutes or until the cheese has melted."
    },
    {
      "position": 10,
      "text": "Remove the pizza from the pan and lay on a wide chopping board. Slice. Serve and enjoy."
    }
  ],
