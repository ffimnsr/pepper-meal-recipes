  "id": "2b245847-7fd8-5b03-885f-9416788fb8e7",
  "slug": "sinigang-na-lapu-lapu-sa-miso",
  "name": "Sinigang na Lapu lapu sa Miso",
  "recipe_type": "soup",
  "brief_description": "Sinigang na Lapu lapu sa Miso is a Filipino sour fish soup dish. This recipe makes use of grouper along with tamarind, radish, okra, and mustard leaves",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add the tamarind.Cover and continue to boil in medium heat for 40 minutes. Let it cool down."
    },
    {
      "position": 2,
      "text": "Using a sieve, strain the boiled tamarind towards a clean cooking pot."
    },
    {
      "position": 3,
      "text": "Boil the liquid and then add tomato, onion and miso. Cover and cook for 15 minutes."
    },
    {
      "position": 4,
      "text": "Add the fish, daikon radish, okra, and peppers. Cover and cook for 12 to 15 minutes in low to medium heat."
    },
    {
      "position": 5,
      "text": "Pour-in the fish sauce. Stir."
    },
    {
      "position": 6,
      "text": "Add the mustard leaves.Cover and cook for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
