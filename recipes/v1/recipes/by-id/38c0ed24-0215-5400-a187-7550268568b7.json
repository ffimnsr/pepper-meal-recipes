  "slug": "sarciadong-daing",
  "name": "Sarciadong Daing",
  "recipe_type": null,
  "brief_description": "Sarciadong Daing or Sarciadong Buwad is a quick and easy recipe involving daing (salted dried fish). Fried daing is quickly cooked with a tomato-based sauce.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Once the oil is hot, saut\u00e9 the garlic and onion."
    },
    {
      "position": 3,
      "text": "Add the diced tomato. Cook for 5 to 7 minutes."
    },
    {
      "position": 4,
      "text": "Add the chili peppers, ground black pepper, and fish sauce. Stir and cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Put the dating in the mixture. Cook for 1 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
