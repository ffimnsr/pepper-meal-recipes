  "id": "e76ff0d9-868e-58cc-9d0a-55c0548b8b22",
  "slug": "tuna-in-can-sarciado",
  "name": "Tuna in Can Sarciado",
  "recipe_type": null,
  "brief_description": "This is a recipe for Tuna in Can Sarciado.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute garlic, onion, and tomato until soft."
    },
    {
      "position": 3,
      "text": "Add the canned tuna (including the water from the can). Stir. Cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour the water into the pan. Let boil."
    },
    {
      "position": 5,
      "text": "Beat the egg and then pour into the pan. Let it cook for a few minutes until it starts to form. Stir."
    },
    {
      "position": 6,
      "text": "Add ground black pepper and scallions. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Pour the fish sauce into the pan. Add more water if preferred."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
