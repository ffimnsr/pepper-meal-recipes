  "id": "97d203c1-5bd6-5c8a-86d7-c3944e7a5fa3",
  "slug": "sizzling-pork-chop-recipe",
  "name": "Sizzling Pork Chop Recipe",
  "recipe_type": null,
  "brief_description": "This Sizzling Pork Chop Recipe will surely make your meal more enjoyable. Watch our cooking video and follow our tested recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt, ground black pepper, and garlic powder on the pork tenderloin chop. Let it stay for at least 30 minutes."
    },
    {
      "position": 2,
      "text": "Make the gravy by melting 1 tablespoon butter in a saucepan. When the butter melts, gradually add the flour and whisk until the color turns light brown. Pour-in the beef broth and stir. Add salt and pepper according to taste. Continue cooking until the texture becomes thick. Set aside."
    },
    {
      "position": 3,
      "text": "Heat a skillet of frying pan then put-in 2 tablespoons of butter and let melt."
    },
    {
      "position": 4,
      "text": "Pan-fry the pork loin chop in medium heat until the color of each side turns light brown (approximately 7 to 8 minutes per side). Set aside."
    },
    {
      "position": 5,
      "text": "Heat a sizzling plate or fajita plate then put-in 1 tablespoon butter."
    },
    {
      "position": 6,
      "text": "Distribute the butter around the plate then arrange rice, mixed vegetables, and pork loin chop."
    },
    {
      "position": 7,
      "text": "Pour gravy over the pork loin chop then turn-off heat."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 30,
