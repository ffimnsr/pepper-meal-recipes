  "id": "4cd9e071-1015-5e20-884f-5070dccc090b",
  "slug": "pancit-habhab-recipe",
  "name": "Pancit Habhab",
  "recipe_type": "main",
  "brief_description": "Pancit Habhab features miki Lucban noodles tossed with pork, shrimp, and vegetables in a savory soy and oyster sauce base. Serve it on banana leaves and finish with a light splash of vinegar for the classic Lucban street food experience.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok over medium heat. Add pork belly and cook until light brown. Add shrimp and cook until it turns pink. Remove pork and shrimp from the wok and set aside."
    },
    {
      "position": 2,
      "text": "In the same wok, saut\u00e9 garlic until fragrant. Add onion and cook until it softens."
    },
    {
      "position": 3,
      "text": "Pour in soy sauce and oyster sauce. Stir to combine and let the mixture bubble briefly to deepen the flavor."
    },
    {
      "position": 4,
      "text": "Add chayote, carrot, snow peas, and cabbage. Toss to coat with the sauce."
    },
    {
      "position": 5,
      "text": "Pour in beef broth and bring to a gentle boil."
    },
    {
      "position": 6,
      "text": "Add miki Lucban noodles. Toss until the noodles absorb the liquid and become soft and flavorful."
    },
    {
      "position": 7,
      "text": "Return pork and shrimp to the wok. Season with ground black pepper and adjust soy sauce to taste. Toss to combine and heat through."
    },
    {
      "position": 8,
      "text": "Serve hot on banana leaves and drizzle with a little vinegar before eating for the classic style."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
  "difficulty": "medium",
