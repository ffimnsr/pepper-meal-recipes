  "schema_version": 1,
  "id": "070cde33-4eca-50ae-9acd-d746c93b0dfd",
  "slug": "veggie-balls-with-manong-sauce",
  "name": "Veggie Balls with Manong Sauce",
  "recipe_type": "dessert",
  "brief_description": "Crispy fried vegetable balls with sweet and spicy dipping sauces",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make the manong sauce by boiling water in a cooking pot. Add star anise, brown sugar, Knorr Liquid Seasoning, garlic powder, chili pepper, and onion powder. Stir until well blended. Simmer for 5 minutes."
    },
    {
      "position": 2,
      "text": "Combine cornstarch and 1/4 cup water. Stir and pour into the pot. Continue cooking while constantly stirring the mixture until your desired consistency is achieved. Transfer to a sauce bottle and let it cool down. Set aside."
    },
    {
      "position": 3,
      "text": "Make the spicy vinegar dipping sauce by combining all the ingredients as listed above in a jar or bowl. Mix well. Set aside."
    },
    {
      "position": 4,
      "text": "Make the veggie balls by combining flour and cornstarch in a bowl. Mix well and then gradually add water while mixing."
    },
    {
      "position": 5,
      "text": "Add carrot, green onion, kalabasa, and green peas. Mix well."
    },
    {
      "position": 6,
      "text": "Season with Knorr Liquid Seasoning. Mix until all ingredients are well blended."
    },
    {
      "position": 7,
      "text": "Heat cooking oil in a deep cooking pot. Mold the mixture into balls and then fry in medium heat until it floats, and the exterior part turns golden brown in color."
    },
    {
      "position": 8,
      "text": "Remove from the pot and skewer using bamboo sticks. Dip in manong sauce or spicy vinegar before eating."
    },
    {
      "position": 9,
      "text": "Make the eggplant balls by boiling the peeled eggplant until it gets tender. Cut it into smaller pieces and then mash. Combine with egg, all-purpose flour, onion, garlic, salt, and ground black pepper. Mix well. Form into balls and roll it over the panko breadcrumbs. Deep fry in low to medium heat until the color turns golden brown. Remove from the pot and let it cool down. Dip in manong sauce or spicy vinegar before eating."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
