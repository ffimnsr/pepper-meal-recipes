  "id": "efee668a-ac48-5bc6-a823-71716bd50666",
  "slug": "stir-fried-beef",
  "name": "Beef Stir Fry",
  "recipe_type": "main",
  "brief_description": "Quick and easy beef tenderloin stir fry with bell peppers.",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Combine beef, oyster sauce, soy sauce, and ground black pepper. Mix well. Let it stand for 5 minutes."
    },
    {
      "position": 2,
      "text": "Add cornstarch into the bowl. Mix until all ingredients are well distributed. Set aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan. Fry bell peppers for 1 minute. Stir once in a while. Remove bell peppers from the pan. Set aside."
    },
    {
      "position": 4,
      "text": "Using the remaining oil, stir fry marinated beef until it starts to brown."
    },
    {
      "position": 5,
      "text": "Add fried bell peppers and toss until all ingredients are distributed."
    },
    {
      "position": 6,
      "text": "Transfer beef stir fry to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve with rice. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 9,
