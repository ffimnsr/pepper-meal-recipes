  "id": "12d23dff-4591-5bc9-a319-c130a1613c83",
  "slug": "beef-stroganoff",
  "name": "Beef Stroganoff",
  "recipe_type": "main",
  "brief_description": "Beef Stroganoff is a dish consisting of thin slices of beef that are pan-fried and cooked with a rich sour tasting sauce.",
  "cuisine": "Russian",
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine beef, salt, ground black pepper, and garlic powder. Mix thoroughly and let stand for at least 30 minutes."
    },
    {
      "position": 2,
      "text": "Add 3 tablespoons of all-purpose flour and mix well."
    },
    {
      "position": 3,
      "text": "Heat a cooking pot or pan then melt-in the butter."
    },
    {
      "position": 4,
      "text": "Pan fry the strips of beef for about 2 minutes per side. Remove from the pan and set aside."
    },
    {
      "position": 5,
      "text": "Saut\u00e9 onion and mushroom in remaining butter until the texture becomes soft."
    },
    {
      "position": 6,
      "text": "Add-in the remaining flour and stir."
    },
    {
      "position": 7,
      "text": "Put-in the pan-fried beef, the condensed cream of mushroom, and the beef broth. Stir and let boil. Simmer for 30 to 40 minutes. Note: add water if necessary."
    },
    {
      "position": 8,
      "text": "Put-in some salt and pepper to taste then stir-in the sour cream. Cook for 2 minutes more."
    },
    {
      "position": 9,
      "text": "Arrange egg noodles on a serving plate then top with Beef Stroganoff."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "hard",
