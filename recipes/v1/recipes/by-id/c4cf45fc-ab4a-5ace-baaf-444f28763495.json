  "id": "c4cf45fc-ab4a-5ace-baaf-444f28763495",
  "slug": "coconut-macaroons",
  "name": "Coconut Macaroon Recipe",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Coconut Macaroon",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Place the butter in a big bowl and cream using a fork"
    },
    {
      "position": 2,
      "text": "Add-in the brown sugar and mix well"
    },
    {
      "position": 3,
      "text": "Add the eggs and condensed milk then stir/beat until all ingredients are blended"
    },
    {
      "position": 4,
      "text": "Put-in the Sweetened Shredded Coconut and distribute evenly with the other ingredient in the mixture"
    },
    {
      "position": 5,
      "text": "In a mold (with paper cups if possible), place 1 tablespoon of the mixture on each of the cups"
    },
    {
      "position": 6,
      "text": "Pre-heat oven at 370 degrees Fahrenheit for 10 minutes"
    },
    {
      "position": 7,
      "text": "Bake the Coconut Macaroon mixture for 20 to 30 minutes or until color turns golden brown."
    },
    {
      "position": 8,
      "text": "Serve during dessert or snack time. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 15,
