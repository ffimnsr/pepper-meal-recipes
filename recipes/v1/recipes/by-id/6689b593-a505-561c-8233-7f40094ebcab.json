  "id": "6689b593-a505-561c-8233-7f40094ebcab",
  "slug": "chicken-curry-pinoy-style",
  "name": "Pinoy Chicken Curry Recipe",
  "recipe_type": "main",
  "brief_description": "This is a Filipino version of Chicken Curry. It is rich and tasty. Delicious!",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Fry potato for 1 minute per side. Remove from the pan. Set aside."
    },
    {
      "position": 2,
      "text": "Using the remaining oil, saute garlic, onion, celery, and ginger until onion softens."
    },
    {
      "position": 3,
      "text": "Add the chicken pieces. Saute until the outer part of the chicken turns light brown."
    },
    {
      "position": 4,
      "text": "Add 1 tablespoon fish sauce. Continue saut\u00e9ing for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour-in coconut milk and water. Let boil."
    },
    {
      "position": 6,
      "text": "Add curry powder. Stir until the powder is completely diluted. Cover the pot and continue cooking between low to medium heat until the liquid reduces to half."
    },
    {
      "position": 7,
      "text": "Add the red bell pepper and pan fried-potato. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Season with fish sauce and ground black pepper as needed. You can also add all-purpose cream if desired."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
