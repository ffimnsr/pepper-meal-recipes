  "id": "87505786-8a5c-5e82-ac29-b7afd30d53bb",
  "slug": "adobong-isaw-recipe",
  "name": "Adobong Isaw Recipe",
  "recipe_type": null,
  "brief_description": "This Adobong Isaw Recipe is not new nor is it the best selling bar food (some bars in the Philippines serve this though); however, the mere simplicity of this recipe makes this special \u2013 in my opinion.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour 4 cups water in a cooking pot, apply heat, and let boil."
    },
    {
      "position": 2,
      "text": "Add 2 teaspoons salt, 2 pieces dried bay leaves, and cooking wine."
    },
    {
      "position": 3,
      "text": "Put-in the small intestine and simmer until tender."
    },
    {
      "position": 4,
      "text": "Remove the tender intestines, turn-off heat, and cut the intestines into 2 inches length. Set aside."
    },
    {
      "position": 5,
      "text": "Heat a wok or frying pan then pour-in cooking oil."
    },
    {
      "position": 6,
      "text": "Saut\u00e9 garlic and dried chili."
    },
    {
      "position": 7,
      "text": "Put in the intestine and cook for a minute."
    },
    {
      "position": 8,
      "text": "Add whole pepper corn, bay leaves, soy sauce, vinegar, and 1/2 cup water then let boil."
    },
    {
      "position": 9,
      "text": "Stir the mixture then add salt and sugar. Cover and simmer for 15 minutes or until the liquid evaporates."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate and serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 60,
