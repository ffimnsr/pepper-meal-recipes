  "id": "fee412cb-ea00-5a74-bd02-bd2b47f0db01",
  "slug": "stew-goat-meat-kalderetang-kambing-recipe",
  "name": "Kalderetang Kambing",
  "recipe_type": null,
  "brief_description": "Kalderetang Kambing is goat meat stewed in tomato sauce. The goat meat which is known as Chevon is commonly used for this dish",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the vinegar, salt, and ground black pepper in a large bowl then marinate the goat meat for at least an hour (This should eliminate the gamey smell and taste of the meat) then separate the meat from the marinade."
    },
    {
      "position": 2,
      "text": "Pour the cooking oil in a cooking pot or casserole and apply heat."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the garlic, onion, and tomatoes"
    },
    {
      "position": 4,
      "text": "Add the marinated goat meat then cook until the color of the outer part turns light brown"
    },
    {
      "position": 5,
      "text": "Put-in the tomato sauce and crushed chili then allow to cook for 2 minutes"
    },
    {
      "position": 6,
      "text": "Add the water and allow to boil. Simmer for at least 45 minutes or until the meat is tender."
    },
    {
      "position": 7,
      "text": "Add the liver spread and cook for 5 minutes (You may add water if the sauce seems to dry up)"
    },
    {
      "position": 8,
      "text": "Put-in the potatoes and carrots then simmer for 8 minutes."
    },
    {
      "position": 9,
      "text": "Add the olives and bell pepper then simmer for another 5 minutes."
    },
    {
      "position": 10,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 11,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
