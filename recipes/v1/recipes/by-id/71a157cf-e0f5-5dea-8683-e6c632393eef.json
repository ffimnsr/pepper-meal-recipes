  "id": "71a157cf-e0f5-5dea-8683-e6c632393eef",
  "slug": "creamed-spinach-recipe",
  "name": "Creamed Spinach Recipe",
  "recipe_type": "side",
  "brief_description": "Tender spinach in a rich garlic cream sauce, served warm as a smooth and flavorful side for any main course.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in a pan."
    },
    {
      "position": 2,
      "text": "Add garlic and then cook until the color turns light brown."
    },
    {
      "position": 3,
      "text": "Put-in spinach. Stir."
    },
    {
      "position": 4,
      "text": "Sprinkle salt, pepper, and nutmeg. Cook for 3 minutes while stirring."
    },
    {
      "position": 5,
      "text": "Pour-in heavy whipping cream. Continue cooking for 5 to 7 minutes in medium heat while stirring every 2 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
