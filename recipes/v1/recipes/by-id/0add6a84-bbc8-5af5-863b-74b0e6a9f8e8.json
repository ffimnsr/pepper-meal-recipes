  "id": "0add6a84-bbc8-5af5-863b-74b0e6a9f8e8",
  "slug": "buttermilk-waffles-recipe",
  "name": "Buttermilk Waffles",
  "recipe_type": "breakfast",
  "brief_description": "This is a recipe for simple buttermilk waffles",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat waffle maker."
    },
    {
      "position": 2,
      "text": "Combine all dry ingredients in a bowl starting with flour, sugar, baking powder, baking soda, and salt. Mix well using a wire whisk."
    },
    {
      "position": 3,
      "text": "Add eggs, butter, and vanilla extract. Whisk until texture becomes smooth."
    },
    {
      "position": 4,
      "text": "Pour batter into the waffle maker. Close and secure and cook for 2 minutes or a little bit more if you want it crisp on the outside."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Top with whipped butter and syrup."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 2,
  "preparation_time_minutes": 10,
