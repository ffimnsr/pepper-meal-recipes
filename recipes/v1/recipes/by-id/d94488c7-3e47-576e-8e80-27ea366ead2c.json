  "id": "d94488c7-3e47-576e-8e80-27ea366ead2c",
  "slug": "pork-and-chicken-adobo",
  "name": "Pork and Chicken Adobo Recipe",
  "recipe_type": "side",
  "brief_description": "Pork and Chicken Adobo is a version of Filipino adobo using the combination of chicken and pork. It is considered as the signature dish of the Philippines.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan"
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot, add the garlic. Cook until the color turns golden brown."
    },
    {
      "position": 3,
      "text": "Remove the garlic and set aside. Add pork and chicken. Cook for 5 minutes or until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Add whole peppercorn, bay leaves, oyster sauce, soy sauce, and water. Let boil and simmer until the meat gets tender."
    },
    {
      "position": 5,
      "text": "Add the sugar and stir."
    },
    {
      "position": 6,
      "text": "Pour-in vinegar and let boil.Simmer until most of the liquid evaporates."
    },
    {
      "position": 7,
      "text": "Add salt to taste. Put-in the fried garlic, stir, and cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
