  "id": "dab8e45d-bd4e-52fc-b45b-c60fb3f4fa68",
  "slug": "ginataang-tilapia",
  "name": "Ginataang Tilapia",
  "recipe_type": "main",
  "brief_description": "Fried fish sauteed in aromatics and cooked in coconut milk with spinach. This delicious fish recipe is a must try. Cook it for your family and share the love.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the onion, garlic, and ginger in the hot oil"
    },
    {
      "position": 3,
      "text": "Once the onion become soft, pour the coconut milk into the pot. Let boil and cover. Cook for 5 minutes between low to medium heat."
    },
    {
      "position": 4,
      "text": "Add the chili peppers and tilapia. Cover and simmer for 12 minutes."
    },
    {
      "position": 5,
      "text": "Add long green chili peppers and season with fish sauce and ground black pepper. Stir. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add the spinach. Cover and cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
