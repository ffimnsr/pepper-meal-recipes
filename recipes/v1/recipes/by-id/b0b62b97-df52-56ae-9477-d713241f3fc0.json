  "slug": "sauteed-onion-and-hotdog-with-ketchup",
  "name": "Sauteed Onion and Hotdog with Ketchup",
  "recipe_type": null,
  "brief_description": "Sauteed Onion and Hotdog with Ketchup is a dish that makes use of Filipino style red hotdogs,yellow onion, and banana ketchup.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a frying pan."
    },
    {
      "position": 2,
      "text": "Saute the onion once the oil is hot."
    },
    {
      "position": 3,
      "text": "Once the onion becomes soft, put-in the sliced hotdog. Cook for 2 minutes in medium heat."
    },
    {
      "position": 4,
      "text": "Add the garlic powder and ketchup. Stir and cook for 2 minutes more."
    },
    {
      "position": 5,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 10,
