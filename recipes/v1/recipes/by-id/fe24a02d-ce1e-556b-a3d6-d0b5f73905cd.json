  "id": "fe24a02d-ce1e-556b-a3d6-d0b5f73905cd",
  "slug": "grilled-lamb-chops",
  "name": "Grilled Lamb Chops",
  "recipe_type": null,
  "brief_description": "Grilled Lamb Chops is a quick and simple way to prepare lamb chops for lunch. We will be using fresh ingredients that can be bought in your local grocer",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Place the rosemary, garlic, thyme, salt, and red pepper flakes in a food processor. Hit the pulse button until the ingredients are fine and mixed well."
    },
    {
      "position": 2,
      "text": "Pour the olive oil in the food processor with the rest of the ingredients. Push the pulse button for 3 to 5 seconds."
    },
    {
      "position": 3,
      "text": "Arrange the lamb chops in a Ziploc bag. Pour-in the olive oil mixture and add the cracked whole peppercorn. Make sure that the lamb chops are fully coated. Seal the bag and refrigerate for 4 hours."
    },
    {
      "position": 4,
      "text": "Remove the bag from the fridge. Let the lamb chops reach room temperature."
    },
    {
      "position": 5,
      "text": "Heat-up the grill. Grill each side for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Serve with your favorite vegetable side dish."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 60,
