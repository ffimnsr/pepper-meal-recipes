  "id": "22b6acd5-bb21-535f-84b8-ef525086f5b0",
  "slug": "grilled-potato-salad-recipe",
  "name": "Grilled Potato Salad",
  "recipe_type": "salad",
  "brief_description": "Grilled Potato Salad is a tangy potato salad variation made from parboiled and grilled red potatoes. This tastes really awesome",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Parboil potatoes and then blanch in cold water. Slice into quarters."
    },
    {
      "position": 2,
      "text": "In a large bowl, combine salt, pepper, red pepper flakes, and olive oil. Mix well."
    },
    {
      "position": 3,
      "text": "Add in the potatoes and then mix until the olive oil mixture coats."
    },
    {
      "position": 4,
      "text": "Grill the potatoes for about 5 minutes per side."
    },
    {
      "position": 5,
      "text": "Transfer back to the mixing bowl. Add the crumbled bacon and sliced onions."
    },
    {
      "position": 6,
      "text": "Combine mayonnaise, mustard, and Worcestershire sauce. Mix well and then pour-in the bowl with the potatoes. Gently toss."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Top with chopped parsley."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
