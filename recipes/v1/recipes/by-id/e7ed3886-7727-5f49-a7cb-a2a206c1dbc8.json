  "id": "e7ed3886-7727-5f49-a7cb-a2a206c1dbc8",
  "slug": "pork-sinigang-na-baboy-recipe",
  "name": "Sinigang",
  "recipe_type": "soup",
  "brief_description": "Filipino sour soup with pork and vegetables",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil the young tamarind in 2 quarts of water for 40 minutes. Filter the tamarind broth using a kitchen sieve or a strainer. Squeeze the tamarind afterwards to extract its remaining juices."
    },
    {
      "position": 2,
      "text": "Pour the tamarind broth into a cooking pot. Let it boil and then add the onion, pork belly, and half the amount of the tomatoes."
    },
    {
      "position": 3,
      "text": "Skim-off the floating scums, pour 1 tablespoon fish sauce, cover and continue to simmer for 1 hour."
    },
    {
      "position": 4,
      "text": "Add daikon radish and eggplants. Cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add the long green pepper, string beans, remaining tomatoes, and okra. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add the chopped water spinach stalks and season with fish sauce and ground black pepper. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Put the water spinach leaves. Cover and turn the heat off. Let the residual heat cook the leaves for 3 minutes before serving."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
