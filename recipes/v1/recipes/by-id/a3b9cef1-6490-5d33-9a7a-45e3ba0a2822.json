  "name": "Breaded Pork Loin",
  "recipe_type": null,
  "brief_description": "This is a recipe for Breaded Pork Loin",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle pork chops with salt and pepper."
    },
    {
      "position": 2,
      "text": "Whisk egg and milk together in a shallow bowl."
    },
    {
      "position": 3,
      "text": "Dip each loin in the egg mixture then dredge in bread crumbs."
    },
    {
      "position": 4,
      "text": "Heat oil in a heavy skillet."
    },
    {
      "position": 5,
      "text": "Fry in the hot oil for about 6 minutes on each side or until color turns golden brown."
    },
    {
      "position": 6,
      "text": "Serve hot with atchara. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 12,
