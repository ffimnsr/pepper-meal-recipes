  "id": "c7b45635-f5d5-5dc1-bda5-b163cd6269fe",
  "slug": "sinigang-sa-miso",
  "name": "Sinigang sa Miso",
  "recipe_type": "soup",
  "brief_description": "A Filipino fish sour soup enhanced with miso paste.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the fish. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat oil in a pot. Fry each side of the fish for 1 1/2 minutes. Remove the fish from the pot and set it aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil, add onion and half of the tomato, and miso. Saute for 2 minutes."
    },
    {
      "position": 4,
      "text": "Put the fish back into the pot and then pour water. Let it boil."
    },
    {
      "position": 5,
      "text": "Cover and cook using low to medium heat setting for 10 minutes,"
    },
    {
      "position": 6,
      "text": "Add Maggi Magic Sinigang sa Sampaloc. Stir. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add long green pepper, string beans, and okra. Stir. Cover and cook for 5 to 7 minutes."
    },
    {
      "position": 8,
      "text": "Add fish sauce and ground black pepper. Stir."
    },
    {
      "position": 9,
      "text": "Put the kangkong leaves into the pot. Cover the pot and turn the heat off. Let it stay for 5 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "hard",
