  "id": "938eb24d-3b32-5990-af28-64cd4badf61c",
  "slug": "ham-and-cheese-quiche-recipe",
  "name": "Ham and Cheese Quiche Recipe",
  "recipe_type": null,
  "brief_description": "To me, Ham and Cheese Quiche make a great brunch. This is something that I like to have when I have something going on for lunch while I am pre-occupied with other chores early in the morning.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 350F."
    },
    {
      "position": 2,
      "text": "Arrange the pastry dough on a round baking dish.Blind bake for 12 to 15 minutes."
    },
    {
      "position": 3,
      "text": "Meanwhile, combine the beaten egg, salt, pepper, milk, and cheese. Mix well."
    },
    {
      "position": 4,
      "text": "Add the cubed ham to the egg mixture and stir."
    },
    {
      "position": 5,
      "text": "Remove the baking dish from the oven. Pour the entire mixture in the baking dish."
    },
    {
      "position": 6,
      "text": "Place it back in the oven. Bake for 35 to 40 minutes at 350F."
    },
    {
      "position": 7,
      "text": "Remove from the oven."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
