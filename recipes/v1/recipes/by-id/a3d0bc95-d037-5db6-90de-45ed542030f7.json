  "id": "a3d0bc95-d037-5db6-90de-45ed542030f7",
  "slug": "how-to-make-latik",
  "name": "Latik Recipe",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for latik",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a saucepan and pour-in the coconut milk."
    },
    {
      "position": 2,
      "text": "Bring the coconut milk to a boil."
    },
    {
      "position": 3,
      "text": "Continuously stir until most of the liquid evaporate. This will take about 12 to 15 minutes per cup of coconut milk."
    },
    {
      "position": 4,
      "text": "When the texture turns gelatinous, lower the heat and continue stirring. Oils should be separating from the milk at this stage."
    },
    {
      "position": 5,
      "text": "Continue stirring until brownish residues are formed. Turn off the heat and place the latik in a container. You can use this right away to top your favorite rice cake or place it in the fridge for a week or so."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 2,
