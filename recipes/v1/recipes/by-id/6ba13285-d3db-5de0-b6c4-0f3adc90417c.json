  "id": "6ba13285-d3db-5de0-b6c4-0f3adc90417c",
  "slug": "chop-suey-recipe",
  "name": "Chicken Chop Suey Recipe",
  "recipe_type": "main",
  "brief_description": "A vibrant medley of shrimp, chicken liver, gizzard, quail eggs, and colorful vegetables tossed in a light savory sauce. This Chicken Chop Suey Recipe is a Filipino favorite that delivers freshness, texture, and flavor in every serving.",
  "cuisine": "Chinese Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 1 quart of water in a pot. Add carrot and blanch for 30 seconds. Add snow peas, young corn, red bell pepper, and cauliflower. Cook for 1 minute. Add cabbage and cook for another minute. Transfer vegetables to an ice water bath for 2 minutes. Drain and set aside."
    },
    {
      "position": 2,
      "text": "Blanch shrimp in the same boiling water until orange. Remove and set aside."
    },
    {
      "position": 3,
      "text": "Boil chicken gizzard in water until tender. Drain and set aside."
    },
    {
      "position": 4,
      "text": "Heat cooking oil in a wok. Saut\u00e9 garlic until light brown, then add onion and cook until soft."
    },
    {
      "position": 5,
      "text": "Add chicken liver and saut\u00e9 for 3 minutes until lightly browned."
    },
    {
      "position": 6,
      "text": "Add boiled chicken gizzard and oyster sauce. Toss in the blanched vegetables and season with Maggi Magic Sarap. Stir and cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Add quail eggs, shrimp, and button mushrooms. Cook for 2 minutes while stirring gently."
    },
    {
      "position": 8,
      "text": "Combine cornstarch with 3 tablespoons of water. Pour the mixture into the wok and cook until the sauce thickens and coats the vegetables evenly."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve warm with steamed rice. Share and enjoy."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 20,
  "rest_time_minutes": null,
  "difficulty": "medium",
