  "id": "8b1aa51f-c20b-514f-bccf-ec0736af08d8",
  "slug": "cheesy-baked-macaroni-recipe",
  "name": "Cheesy Baked Macaroni",
  "recipe_type": "main",
  "brief_description": "This cheesy baked macaroni features tender elbow pasta layered with a savory tomato meat sauce, creamy white sauce, and melted cheddar cheese. Baked until golden and bubbly, it is the ultimate Filipino-style comfort dish for family gatherings and everyday meals.",
  "cuisine": "American Filipino Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the macaroni according to package instructions. Drain and set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pot over medium heat. Saut\u00e9 the garlic, onion, and bell peppers for 3 to 5 minutes or until softened."
    },
    {
      "position": 3,
      "text": "Add the ground beef and cook until it turns brown, breaking it apart as it cooks."
    },
    {
      "position": 4,
      "text": "Add the beef cube bouillon and stir until dissolved."
    },
    {
      "position": 5,
      "text": "Pour in the tomato sauce. Stir well and bring the mixture to a boil."
    },
    {
      "position": 6,
      "text": "Season with salt and ground black pepper. Continue cooking for 5 minutes. Remove from heat and set aside."
    },
    {
      "position": 7,
      "text": "Melt the butter in a separate pot over medium-low heat."
    },
    {
      "position": 8,
      "text": "Add the all-purpose flour and stir until the flour absorbs the butter and forms lumps."
    },
    {
      "position": 9,
      "text": "Pour in the fresh milk while stirring continuously. Keep stirring until the flour is completely dissolved and the sauce thickens. Use a wire whisk for a smoother texture."
    },
    {
      "position": 10,
      "text": "Add the quick melt cheese. Continue stirring until the cheese fully melts and blends into the sauce. Turn the heat off."
    },
    {
      "position": 11,
      "text": "Place the cooked macaroni in a large mixing bowl. Pour the tomato meat sauce over the pasta and mix well. Add a few tablespoons of white sauce and some shredded cheddar cheese, then toss everything together."
    },
    {
      "position": 12,
      "text": "Transfer the macaroni mixture to a baking pan. Spread the remaining white sauce evenly over the top, making sure to cover the entire surface."
    },
    {
      "position": 13,
      "text": "Preheat the oven to 375\u00b0F. Bake for 15 to 18 minutes or until the top turns golden brown."
    },
    {
      "position": 14,
      "text": "Remove from the oven and let it rest for a few minutes before serving."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 15,
