  "id": "cda2b892-ae98-5fb9-8c2b-8c650a5c99e4",
  "slug": "how-to-steam-broccoli",
  "name": "Steamed Broccoli with Toasted Garlic and Lemon",
  "recipe_type": "drink",
  "brief_description": "A light and healthy side dish of tender steamed broccoli tossed with toasted garlic and fresh lemon juice. It is simple to put together and pairs well with grilled, fried, or braised main dishes for a balanced meal.",
  "cuisine": "American Filipino Mediterranean",
  "instructions": [
    {
      "position": 1,
      "text": "Wash the broccoli well and cut it into bite size florets."
    },
    {
      "position": 2,
      "text": "Pour the water into a pot and bring it to a boil."
    },
    {
      "position": 3,
      "text": "Arrange the broccoli in a steamer basket and place it over the boiling water."
    },
    {
      "position": 4,
      "text": "Cover the pot and steam the broccoli for 4 to 6 minutes, or until tender but still bright green."
    },
    {
      "position": 5,
      "text": "Transfer the steamed broccoli to a bowl. Add the toasted garlic."
    },
    {
      "position": 6,
      "text": "Squeeze fresh lemon juice over the broccoli. Season with salt and ground black pepper. Toss gently until well coated."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve warm as a side with your preferred main dish for the day. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 6,
  "preparation_time_minutes": 5,
