  "id": "62255660-f4b1-5c7a-a773-1304d83d2a44",
  "slug": "air-fryer-tilapia",
  "name": "Air Fryer Tilapia",
  "recipe_type": "main",
  "brief_description": "Air Fryer Tilapia is a fast and easy way to cook seasoned tilapia fillets until flaky and lightly crisp. A simple spice rub of paprika, garlic powder, and onion powder coats the fish, and the air fryer does the rest in under 10 minutes. Serve with steamed rice and a squeeze of fresh lemon.",
  "cuisine": "American Filipino Mediterranean seafood",
  "instructions": [
    {
      "position": 1,
      "text": "Pat the tilapia fillets dry on both sides using paper towels. This helps the seasoning stick and gives the fish a better texture."
    },
    {
      "position": 2,
      "text": "Combine the paprika, garlic powder, onion powder, salt, and ground black pepper in a small bowl. Mix well."
    },
    {
      "position": 3,
      "text": "Brush both sides of the tilapia fillets with olive oil. Rub the seasoning mixture evenly over the fish, covering all surfaces."
    },
    {
      "position": 4,
      "text": "Preheat the air fryer to 400\u00b0F for 2 minutes."
    },
    {
      "position": 5,
      "text": "Arrange the tilapia fillets in the air fryer basket in a single layer with space between each piece. Avoid overlapping so the fillets cook evenly."
    },
    {
      "position": 6,
      "text": "Cook for 7 to 10 minutes, or until the fish flakes easily with a fork and the internal temperature reaches 145\u00b0F."
    },
    {
      "position": 7,
      "text": "Transfer the fillets to a serving plate and squeeze fresh lemon juice on top."
    },
    {
      "position": 8,
      "text": "Serve with steamed rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
