  "id": "849e74e1-b631-5714-91fd-86c947506014",
  "slug": "grilled-liver-bistek-steak",
  "name": "Grilled Liver Bistek",
  "recipe_type": null,
  "brief_description": "This is a liver steak with sauce recipe called Grilled Liver Bistek.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Grill the liver for 4 minutes per side. Remove from the grill and then slice into strips."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the garlic and onion"
    },
    {
      "position": 4,
      "text": "Once the onion gets soft, add the grilled liver slices. Stir and cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add salt, pepper, soy sauce, and water. Stir and let boil."
    },
    {
      "position": 6,
      "text": "Add sugar. Set heat to medium and continue to cook until the sauce reduces to half."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve with warm rice."
    },
    {
      "position": 8,
      "text": "Share and Enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
