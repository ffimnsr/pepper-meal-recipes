  "id": "ee59f192-eac4-56b2-8e32-6eb65059f937",
  "slug": "chicken-a-la-king-recipe",
  "name": "Chicken a la King Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Chicken a la King",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan and melt-in 1/4 cup butter."
    },
    {
      "position": 2,
      "text": "Put-in mushrooms. Cook for 3 to 4 minutes."
    },
    {
      "position": 3,
      "text": "Put-in chicken, salt, ground black pepper, and sherry. Cook for 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Meanwhile, heat a sauce pan and melt the remaining 1/4 cup butter."
    },
    {
      "position": 5,
      "text": "Add flour and stir until the mixture forms. Pour-in chicken broth and stir until the butter and flour mixture dissolve. Let boil."
    },
    {
      "position": 6,
      "text": "Transfer the chicken broth mixture to the pan where the chicken is cooking."
    },
    {
      "position": 7,
      "text": "Pour-in the heavy cream. Add thyme, pimento, parsley, and green peas.Let boil and cook until the sauce thickens."
    },
    {
      "position": 8,
      "text": "Arrange puff pastry on a serving plate and top with chicken a la king."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
