  "slug": "healthy-vegetable-dis-ginisang-upo-recipe",
  "name": "Ginisang Upo Recipe",
  "recipe_type": null,
  "brief_description": "Ginisang Upo is sauteed white squash with tomatoes and ground pork. This recipe is for beginners who want to cook healthy dishes.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the pan and pour the cooking oil"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic, onions, and tomatoes"
    },
    {
      "position": 3,
      "text": "Put-in the ground black pepper and ground pork then simmer for 3 to 5 minutes"
    },
    {
      "position": 4,
      "text": "Add the Upo (White Squash), cover the pan, and simmer for 6 minutes"
    },
    {
      "position": 5,
      "text": "Add salt to taste"
    },
    {
      "position": 6,
      "text": "Serve hot. Enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
