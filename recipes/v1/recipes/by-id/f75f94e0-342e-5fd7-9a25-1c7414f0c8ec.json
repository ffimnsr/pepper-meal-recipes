{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "f75f94e0-342e-5fd7-9a25-1c7414f0c8ec",
  "slug": "pork-tenderloin-salpicao",
  "name": "Pork Tenderloin Salpicao",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pork Tenderloin Salpicao.",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the pork tenderloin into cubes. Set aside."
    },
    {
      "position": 2,
      "text": "Combine olive oil, salt, and ground black pepper. Stir and then add the crushed garlic. Mix well."
    },
    {
      "position": 3,
      "text": "Put the cubed pork in a bowl and pour the olive oil mixture, but strain the garlic using a fork or spoon (we will cook the garlic separately). Fold the pork and make sure that all are coated with olive oil. Let it stay for 20 to 30 minutes. This will let the pork absorb the oil along with the flavors infused in it."
    },
    {
      "position": 4,
      "text": "Heat a pan. Once hot, add the garlic with the remaining oil. Cook until it turns brown. You may add up to 1 teaspoon of oil if needed (do this only if you think that more oil is needed to cook the garlic). Transfer the browned garlic in a bowl."
    },
    {
      "position": 5,
      "text": "Continue to heat the pan with the remaining oil. Add the oil-marinated pork (including the oil). Stir-fry (in high heat) until the pork turns brown."
    },
    {
      "position": 6,
      "text": "Add half of the browned garlic. Stir. Add the Worcestershire sauce and oyster sauce. Continue to cook in high heat until the sauce completely evaporates."
    },
    {
      "position": 7,
      "text": "Add the butter. Continue to cook until it melts."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Top with remaining garlic."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
