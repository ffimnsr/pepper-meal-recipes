  "id": "e77702ee-f2b1-57e3-b87a-bf2244a75983",
  "slug": "pancit-canton-recipe",
  "name": "Pancit Canton",
  "recipe_type": "main",
  "brief_description": "Pancit Canton is a Filipino stir fried noodle dish with pork, shrimp, Chinese sausage, and fresh vegetables tossed in savory soy and oyster sauce.",
  "cuisine": "Asian Chinese Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place 2 cups of ice and 3 cups water in a large bowl. Set aside."
    },
    {
      "position": 2,
      "text": "Boil 6 cups of water in a cooking pot."
    },
    {
      "position": 3,
      "text": "Once the water starts to boil, blanch the snap peas, carrots, and cabbage for 35 to 50 seconds. Quickly remove the vegetables and immerse in bowl with ice cold water. Drain the water after 2 minutes and set aside."
    },
    {
      "position": 4,
      "text": "Heat a large wok or cooking pot and pour in the cooking oil."
    },
    {
      "position": 5,
      "text": "Saut\u00e9 the onion and garlic."
    },
    {
      "position": 6,
      "text": "Add the pork and sausage slices and continue to cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add soy sauce and oyster sauce. Stir."
    },
    {
      "position": 8,
      "text": "Pour in chicken broth and water. Add salt and pepper. Let boil. Continue to cook for 5 to 10 minutes."
    },
    {
      "position": 9,
      "text": "Add the shrimp and parsley. Cook for 3 minutes. Add more water if needed."
    },
    {
      "position": 10,
      "text": "Add the flour noodles. Gently toss until the noodles absorb the liquid."
    },
    {
      "position": 11,
      "text": "Add the blanched vegetables. Toss and cook for 1 to 2 minutes."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
