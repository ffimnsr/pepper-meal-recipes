{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "71d927a1-e85d-5a7a-a2e1-d3d63a236e03",
  "slug": "banana-cream-pie-recipe",
  "name": "How to Make Banana Cream Pie",
  "recipe_type": "dessert",
  "brief_description": "Banana Cream Pie is a type of pie filled with a rich filling that is usually made from milk, cornstarch or flour, and eggs. The main ingredient, banana, is usually placed at the center layer between the filling.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the crust by combining the graham cracker crumbs, 6 tablespoons butter, and 1/4 cup sugar in a mixing bowl then mix."
    },
    {
      "position": 2,
      "text": "Arrange the mixture in a 9 inch pie or cake pan. Gently Press the mixture to make it more compact."
    },
    {
      "position": 3,
      "text": "Refrigerate for at least 1 hour."
    },
    {
      "position": 4,
      "text": "Make the filling by heating a saucepan. Put-in 3/4 cup sugar, salt, cornstarch, and milk. Continuously stir until the mixture thickens and reaches boiling point."
    },
    {
      "position": 5,
      "text": "Meanwhile, place the egg yolks in another mixing bowl and beat. Get 1/2 cup of the milk mixture from the sauce pan (do not turn off the heat yet) then mix with the beaten egg yolks."
    },
    {
      "position": 6,
      "text": "Stir-in egg yolk mixture on the saucepan and continue cooking in low heat for 2 to 3 minutes while Stirring continuously."
    },
    {
      "position": 7,
      "text": "Turn off the heat then put-in 2 tablespoons butter and vanilla extract then stir."
    },
    {
      "position": 8,
      "text": "Transfer the mixture on a bowl then refrigerate for 1 to 1 1/2 hours."
    },
    {
      "position": 9,
      "text": "Scoop half of the filling and arrange on the pie or cake pan with graham cracker crust."
    },
    {
      "position": 10,
      "text": "Arrange the sliced bananas on top of the mixture."
    },
    {
      "position": 11,
      "text": "Pour the remaining filling over the sliced bananas."
    },
    {
      "position": 12,
      "text": "Prepare the topping by combining the heavy whipping cream and 1/2 teaspoon vanilla extract. Beat using an electric mixer until soft peaks form."
    },
    {
      "position": 13,
      "text": "Spread the topping over the last layer of filling."
    },
    {
      "position": 14,
      "text": "Garnish with chocolate curls (optional)."
    },
    {
      "position": 15,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
