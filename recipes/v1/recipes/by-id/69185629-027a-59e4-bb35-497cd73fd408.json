  "id": "69185629-027a-59e4-bb35-497cd73fd408",
  "slug": "pineapple-upside-down-cake",
  "name": "Pineapple Upside Down Cake",
  "recipe_type": "dessert",
  "brief_description": "Pineapple Upside Down Cake",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "Place butter in a cake pan and melt by placing in the oven."
    },
    {
      "position": 3,
      "text": "Remove the pan from the oven, and then sprinkle some brown sugar."
    },
    {
      "position": 4,
      "text": "Arrange the sliced pineapples over the sugar.This will look better if you place some maraschino cherries."
    },
    {
      "position": 5,
      "text": "Combine all the remaining ingredients in a mixing bowl. Mix using an electric mixer until all the ingredients are well distributed."
    },
    {
      "position": 6,
      "text": "Pour the batter (mixed ingredients) in the cake pan."
    },
    {
      "position": 7,
      "text": "Bake for 45 to 50 minutes or until it passes the toothpick test."
    },
    {
      "position": 8,
      "text": "Remove from the oven, and then transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve while still warm. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
