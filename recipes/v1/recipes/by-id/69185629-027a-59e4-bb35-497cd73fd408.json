  "id": "69185629-027a-59e4-bb35-497cd73fd408",
  "slug": "pineapple-upside-down-cake",
  "name": "Pineapple Upside-Down Cake",
  "recipe_type": "dessert",
  "brief_description": "A classic American dessert with caramelized pineapple and cherries atop a moist vanilla cake, served upside-down.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350 degrees Fahrenheit (175 degrees Celsius)."
    },
    {
      "position": 2,
      "text": "Place the butter in a cake pan and melt it in the oven."
    },
    {
      "position": 3,
      "text": "Remove the pan from the oven and sprinkle the brown sugar evenly over the melted butter."
    },
    {
      "position": 4,
      "text": "Arrange the pineapple slices over the sugar. Place a maraschino cherry in the center of each pineapple ring, if desired."
    },
    {
      "position": 5,
      "text": "Combine the flour, white sugar, shortening, baking powder, milk, egg, and salt in a mixing bowl. Beat with an electric mixer until well combined."
    },
    {
      "position": 6,
      "text": "Pour the batter evenly over the pineapple layer in the cake pan."
    },
    {
      "position": 7,
      "text": "Bake for 45 to 50 minutes, or until a toothpick inserted into the center of the cake comes out clean."
    },
    {
      "position": 8,
      "text": "Remove from the oven and let cool for 5 minutes. Run a knife around the edge of the pan to loosen, then invert the cake onto a serving plate."
    },
    {
      "position": 9,
      "text": "Serve while still warm. Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 15,
  "rest_time_minutes": 5,
