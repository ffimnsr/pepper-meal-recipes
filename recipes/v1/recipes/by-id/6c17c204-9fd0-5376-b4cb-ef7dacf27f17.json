  "id": "6c17c204-9fd0-5376-b4cb-ef7dacf27f17",
  "slug": "sinantomas",
  "name": "Sinantomas",
  "recipe_type": "dessert",
  "brief_description": "Braised pork ribs with sweet potato.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the ribs by removing the membrane and slicing it into serving pieces."
    },
    {
      "position": 2,
      "text": "Combine the marinade ingredients along with the ribs in a big bowl. Start with the ground black pepper, fish sauce, soy sauce, and pineapple juice. Mix well. Marinate for at least 3 hours. Note: the longer the better."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan. Fry the sweet potato until it turns light brown. Remove and set aside."
    },
    {
      "position": 4,
      "text": "Using the remaining oil, pan-fry ribs for 3 minutes per side. Remove from the pan. Set aside."
    },
    {
      "position": 5,
      "text": "Saute onion using remaining oil. Add garlic and tomato. Cook until onion softens."
    },
    {
      "position": 6,
      "text": "Pour-in remaining rib marinade ingredients. Let it boil."
    },
    {
      "position": 7,
      "text": "Add ribs back into the bowl. Pour water. Let boil."
    },
    {
      "position": 8,
      "text": "Add banana ketchup. Stir and cover the pan. Continue cooking in low heat for 1 to 1 \u00bd hours or until the meat gets tender."
    },
    {
      "position": 9,
      "text": "Add the sweet potato back in the pan. Cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve with warm rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 180,
