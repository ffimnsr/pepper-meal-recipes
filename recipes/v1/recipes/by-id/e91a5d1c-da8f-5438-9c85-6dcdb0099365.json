  "id": "e91a5d1c-da8f-5438-9c85-6dcdb0099365",
  "slug": "beef-batchoy-with-liver-and-bung",
  "name": "Beef Batchoy with Liver and Bung",
  "recipe_type": "soup",
  "brief_description": "Beef shank and tendon simmered until tender with fresh egg noodles, scallions, toasted garlic, and chicharon in a piping hot broth.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Sliced the pork bung into serving pieces. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a large cooking pot."
    },
    {
      "position": 3,
      "text": "Saute the garlic, onion and celery until the onion gets soft."
    },
    {
      "position": 4,
      "text": "Add the ground black pepper. Stir and cook for 30 seconds."
    },
    {
      "position": 5,
      "text": "Put the beef tendon and shank in the cooking pot. Stir and cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Add the pork bung and pour-in water. Let boil. Cover and simmer for 2 to 3 hours."
    },
    {
      "position": 7,
      "text": "Increase the heat to medium. Bring back to a boil. Add the sliced liver and continue to cook for 10 to 15 minutes."
    },
    {
      "position": 8,
      "text": "Pour-in the fish sauce. Stir. Add more water if needed."
    },
    {
      "position": 9,
      "text": "Dip the fresh miki noodles in boiling water for 1 minutes. Remove the noodles and drain the water by placing the noodles in a colander, wire mesh, or strainer."
    },
    {
      "position": 10,
      "text": "Arrange the noodles in large individual bowls. Add the meats from the cooking pot and pour the piping hot soup. Top with toasted garlic, scallions, and chicharon."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 180,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "expert",
