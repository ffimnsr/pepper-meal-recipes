  "id": "d238f210-6c64-5457-9c10-824bd364bc1a",
  "slug": "one-pot-spaghetti",
  "name": "One Pot Spaghetti",
  "recipe_type": "main",
  "brief_description": "Spaghetti with mushroom and bell peppers",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Pour 4 quarts of water on a cooking pot. Let it boil and then add 1 teaspoon salt and spaghetti. Continue cooking for 11 minutes. Drain the water and set the spaghetti aside."
    },
    {
      "position": 2,
      "text": "Heat the same cooking pot. Add the ground beef. Cook until it browns."
    },
    {
      "position": 3,
      "text": "Add onion, garlic, mushroom, and bell pepper. Saute for 3 to 5 minutes."
    },
    {
      "position": 4,
      "text": "Drain the oil out and then add the marinara sauce and 1 1/2 cups water. Let it boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Beef Cube. Cover the pot and then adjust the heat to the lowest setting. Continue cooking for 20 minutes. Note: stir the mixture every 5 minutes and add more water as needed."
    },
    {
      "position": 6,
      "text": "Put the cooked spaghetti back into the pot. Toss until it gets coated by the sauce."
    },
    {
      "position": 7,
      "text": "Season with salt and ground black pepper and then add the cream cheese. Toss."
    },
    {
      "position": 8,
      "text": "Top with grated cheddar cheese. Serve warm with garlic bread. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
