  "id": "b062707e-bad9-5bf2-86a8-d23ed00aa2e8",
  "slug": "sweet-potato-pie-recipe",
  "name": "Sweet Potato Pie Recipe",
  "recipe_type": "dessert",
  "brief_description": "This Sweet Potato Pie Recipe is very easy to follow. It has all the necessary ingredients that falls within the budget. Try this recipe today.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a large cooking pot and pour-in water. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Put-in sweet potatoes then simmer for 45 minutes in medium heat."
    },
    {
      "position": 3,
      "text": "Turn-off heat and remove the sweet potatoes. Let cool."
    },
    {
      "position": 4,
      "text": "Run cold water on the potatoes while gently peeling the skins off. This can easily be done using your fingers."
    },
    {
      "position": 5,
      "text": "Mash the sweet potatoes using a fork, a masher, or a pastry mixer."
    },
    {
      "position": 6,
      "text": "Combine the mashed sweet potato and butter then mix well. You may use an electric mixer to make things easier."
    },
    {
      "position": 7,
      "text": "Put-in milk, eggs, nutmeg, cinnamon, vanilla, and sugar then mix until the texture becomes smooth."
    },
    {
      "position": 8,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 9,
      "text": "Arrange the mixture on the pie crust."
    },
    {
      "position": 10,
      "text": "Bake for 45 to 55 minutes or until it passes the toothpick test."
    },
    {
      "position": 11,
      "text": "Remove from the oven and let cool."
    },
    {
      "position": 12,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
