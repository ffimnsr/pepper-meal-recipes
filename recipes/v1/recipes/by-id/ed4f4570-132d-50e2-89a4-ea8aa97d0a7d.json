  "id": "ed4f4570-132d-50e2-89a4-ea8aa97d0a7d",
  "slug": "bagoong-rice-recipe",
  "name": "Bagoong Rice Recipe",
  "recipe_type": null,
  "brief_description": "Bagoong Rice is a type of fried rice dish that makes use of shrimp paste or bagoong.This is a quick and easy version that all can enjoy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a frying pan."
    },
    {
      "position": 2,
      "text": "Sear the sliced pork belly by putting them directly in the hot pan and cooking them until oil comes out. This should take about 2 to 5 minutes."
    },
    {
      "position": 3,
      "text": "Add 1 tablespoon of bagoong guisado and then stir. Cook for a minute and then remove from the pan and set aside."
    },
    {
      "position": 4,
      "text": "Pour the oil in the same frying pan."
    },
    {
      "position": 5,
      "text": "When the oil becomes hot, put-in the garlic and then cook for 15 seconds."
    },
    {
      "position": 6,
      "text": "Add 2 tablespoons of shrimp paste and then cook for 30 seconds in medium heat."
    },
    {
      "position": 7,
      "text": "Put-in the rice. Gently mix while cooking until all the ingredients are distributed properly. Cook the rice for 10 minutes while gently scraping the bottom of the pan once in a while."
    },
    {
      "position": 8,
      "text": "Transfer the rice to a serving bowl. Top with the cooked pork belly, chopped green mango, and chopped scallions."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
