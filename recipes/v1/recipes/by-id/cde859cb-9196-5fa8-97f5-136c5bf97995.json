  "id": "cde859cb-9196-5fa8-97f5-136c5bf97995",
  "slug": "cooking-lechon-kawali-fried-pork-filipino-recipe",
  "name": "Lechon Kawali",
  "recipe_type": "main",
  "brief_description": "Crispy, flavorful Filipino deep fried pork belly.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine pork belly, water, whole peppercorn and dried bay leaves in a wide cooking pot. Cover and let boil."
    },
    {
      "position": 2,
      "text": "Adjust the heat to a simmer. Continue cooking for 1 \u00bd to 2 hours."
    },
    {
      "position": 3,
      "text": "Remove the pork from the cooking pot. Place it on a plate and let it cool down."
    },
    {
      "position": 4,
      "text": "Rub Maggi Magic Sarap all over the pork belly."
    },
    {
      "position": 5,
      "text": "Soak it under the sun until the skin completely dries."
    },
    {
      "position": 6,
      "text": "Heat the oil in a wok. Once the oil gets hot, carefully deep fry the pork belly until the outer part becomes golden brown and crispy."
    },
    {
      "position": 7,
      "text": "Remove from the wok and put it over a wire rack. Let it cool down."
    },
    {
      "position": 8,
      "text": "Slice into serving pieces. Serve with lechon sauce. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 120,
  "rest_time_minutes": null,
