  "id": "6dfa778b-f28b-541c-89b9-6940c040147d",
  "slug": "chicharon-bulaklak-with-panlasang-pinoy-vinegar",
  "name": "Chicharon Bulaklak with Spicy Vinegar",
  "recipe_type": null,
  "brief_description": "This is a recipe for crispy chicharon bulaklak with homemade spicy Filipino vinegar.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the chicharon bulaklak by boiling water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the water starts to boil, add the pork masentry (bulaklak) and lemongrass. Cover and boil in medium heat for 1 hour."
    },
    {
      "position": 3,
      "text": "While the masentry is cooking, prepare the spicy vinegar. Start by adding the Thai chili pepper, garlic, whole pepperorn, and ginger in a food processor. Mince."
    },
    {
      "position": 4,
      "text": "Transfer to a large bowl and then add the unrefined coconut vinegar and sukang paombong. Add salt to taste. Stir. Tranfer to a container. Set aside. Note: serve this later with the crispy chicharon."
    },
    {
      "position": 5,
      "text": "Remove the boiled masentry from the pot. Let it cool down. Rub salt all over."
    },
    {
      "position": 6,
      "text": "Heat oil in a deep fryer or a deep coking pot. Once the reaches 330F, deep fry the bulaklak for 15 minutes. Let it rest for 5 minutes (take out from the oil)."
    },
    {
      "position": 7,
      "text": "Deep fry for the second time for 3 to 5 minutes or until crispy and golden brown. Arrange on a serving plate. Serve with Spicy vinegar."
    },
    {
      "position": 8,
      "text": "Serve! Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 130,
  "preparation_time_minutes": 10,
