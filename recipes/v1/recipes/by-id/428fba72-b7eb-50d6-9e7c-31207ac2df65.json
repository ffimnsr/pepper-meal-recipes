  "id": "428fba72-b7eb-50d6-9e7c-31207ac2df65",
  "slug": "vegetable-omelet-recipe",
  "name": "Vegetable Omelet Recipe",
  "recipe_type": "breakfast",
  "brief_description": "How about some Vegetable Omelet for breakfast? You can easily prepare this delicious omelet on your own by following the steps below.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt butter in Teflon coated (oven safe) frying pan"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the bell peppers and mushroom for 1 minute."
    },
    {
      "position": 3,
      "text": "Add salt and then stir."
    },
    {
      "position": 4,
      "text": "Pour-in the eggs and then cook in low to medium heat for 3 to 4 minutes."
    },
    {
      "position": 5,
      "text": "Preheat oven to broil."
    },
    {
      "position": 6,
      "text": "Turn- off the stove top and then transfer the Oven safe frying pan in the oven. Cook for 2 minutes or until the top part is done"
    },
    {
      "position": 7,
      "text": "Remove the pan from the oven (don\u2019t forget to wear oven gloves). Let the omelet slide from the pan to the serving plate while folding the omelet as it slides halfway down."
    },
    {
      "position": 8,
      "text": "Serve with bread. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 6,
  "preparation_time_minutes": 3,
  "rest_time_minutes": null,
