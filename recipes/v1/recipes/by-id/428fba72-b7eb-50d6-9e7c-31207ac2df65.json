  "id": "428fba72-b7eb-50d6-9e7c-31207ac2df65",
  "slug": "vegetable-omelet-recipe",
  "name": "Vegetable Omelet",
  "recipe_type": "breakfast",
  "brief_description": "A fluffy vegetable omelet loaded with bell peppers and mushrooms, finished under the broiler for a perfectly set top.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt the butter in a Teflon-coated (oven-safe) frying pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the bell peppers and mushrooms for 1 minute."
    },
    {
      "position": 3,
      "text": "Add the salt and stir."
    },
    {
      "position": 4,
      "text": "Pour in the eggs and cook over low to medium heat for 3 to 4 minutes."
    },
    {
      "position": 5,
      "text": "Preheat the oven to broil."
    },
    {
      "position": 6,
      "text": "Turn off the stovetop and transfer the oven-safe frying pan to the oven. Cook for 2 minutes or until the top is set."
    },
    {
      "position": 7,
      "text": "Remove the pan from the oven (wear oven gloves). Let the omelet slide from the pan onto the serving plate, folding it as it slides halfway down."
    },
    {
      "position": 8,
      "text": "Serve with bread. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 6,
  "preparation_time_minutes": 3,
