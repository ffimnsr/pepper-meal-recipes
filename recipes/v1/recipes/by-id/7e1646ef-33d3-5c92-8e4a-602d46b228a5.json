  "id": "7e1646ef-33d3-5c92-8e4a-602d46b228a5",
  "slug": "pork-empanada-recipe",
  "name": "Pork Empanada Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pork Empanada Recipe",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the pork filling by heating oil in a cooking pot. Add ground pork and cook until light brown."
    },
    {
      "position": 2,
      "text": "Add the chopped onions. Stir and continue to cook until the onion becomes soft."
    },
    {
      "position": 3,
      "text": "Add raisins, Worcestershire sauce, and beef broth. Cover the pot, adjust the heat to medium, cook for 10 to 12 minutes."
    },
    {
      "position": 4,
      "text": "Add peas, carrots, and potato. Cover and cook for 5 to 8 minutes Note: Add more beef broth or water, if needed"
    },
    {
      "position": 5,
      "text": "Put the brown sugar into the pot and season with salt and ground black pepper. Stir and cook for 1 minute. Set aside."
    },
    {
      "position": 6,
      "text": "Preheat oven to 400F."
    },
    {
      "position": 7,
      "text": "Meanwhile, prepare the dough using a food processor. Put flour in a food processor and then add salt. Pulse until both ingredients are blended."
    },
    {
      "position": 8,
      "text": "Slice the butter into small pieces. Add into the food processor. Continue to pulse until the butter blends well with the flour mixture."
    },
    {
      "position": 9,
      "text": "Add egg and gradually pour the milk 2 to 3 tablespoons at a time, while pulsing. Continue to process the mixture until all the ingredients are well blended."
    },
    {
      "position": 10,
      "text": "Transfer the dough into a flat surface. Mold a large sphere out of it. Separate in half, and then create a disk shaped figure on each piece of dough. Chill the dough for at least 20 minutes."
    },
    {
      "position": 11,
      "text": "Flatten one piece of dough on a flat surface using a rolling pin. Note: Watch video below for more information."
    },
    {
      "position": 12,
      "text": "Cut a part of the flatten dough using a circular mold, or anything with a circular tip such as a bowl. Remove the circular dough and set aside."
    },
    {
      "position": 13,
      "text": "Assemble the pork empanada by placing 1 to 2 tablespoons of the pork filling in the center of the circular dough.Secure it by folding both sides of the dough towards each other. Use your thumb and index finger to pinch the sides for it to cling to each other. Secure it even more by pressing the tip of a fork on the sides of the empanada."
    },
    {
      "position": 14,
      "text": "Arrange the empanadas on a baking tray lined with parchment paper. Bake for 15 minutes and then remove from the oven."
    },
    {
      "position": 15,
      "text": "Prepare the egg wash by combining egg white and milk in a bowl. Beat the mixture until blended. Brush the egg wash all over the empanadas."
    },
    {
      "position": 16,
      "text": "Put the pork empanada back into the oven. Continue to bake for 5 to 7 minutes or until it turns medium brown."
    },
    {
      "position": 17,
      "text": "Remove from the oven. Let it cool down."
    },
    {
      "position": 18,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
