  "id": "e6f3958f-74ad-5438-8681-e150f7f6b635",
  "slug": "filipino-food-chicken-stew-ginataang-manok-recipe",
  "name": "Ginataang Manok Recipe",
  "recipe_type": null,
  "brief_description": "Ginataang Manok is translated as chicken stewed in coconut milk. This is a simple Filipino Recipe wherein chicken is saut\u00e9ed in garlic, onion, and ginger",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking pot and pour-in the cooking oil."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic, onion, and ginger."
    },
    {
      "position": 3,
      "text": "Add the chicken and cook until the color of the outer part turns light brown."
    },
    {
      "position": 4,
      "text": "Pour-in the coconut milk while stirring and bring to a boil."
    },
    {
      "position": 5,
      "text": "Sprinkle some paprika then simmer for 30 minutes or until the chicken is tender and the coconut milk becomes thick."
    },
    {
      "position": 6,
      "text": "Add the long green chili and Thai chili then simmer for 5 minutes"
    },
    {
      "position": 7,
      "text": "Add the green papaya then simmer for 5 to 8 minutes."
    },
    {
      "position": 8,
      "text": "Put-in the spinach, salt, and pepper then simmer for 3 minutes."
    },
    {
      "position": 9,
      "text": "Turn-off the heat then transfer the cooked chicken to a serving plate"
    },
    {
      "position": 10,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
