{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "e487a9b1-7b4d-5e9f-bd0a-34844f442178",
  "slug": "pesang-isda-with-ginisang-miso",
  "name": "Pesang Isda with Ginisang Miso",
  "recipe_type": "soup",
  "brief_description": "Fish in ginger broth, bok choy, and Napa cabbage served with saut\u00e9ed yellow miso and crumbled tofu.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare Ginisang Miso by heating oil in a pan. Add onion. Saute for 20 seconds."
    },
    {
      "position": 2,
      "text": "Add garlic. Continue cooking for 10 seconds. Put the tomato in the pan and then saute until both tomato and onion softens."
    },
    {
      "position": 3,
      "text": "Add crumbled tofu. Stir and cook until all ingredients are well blended."
    },
    {
      "position": 4,
      "text": "Put the Miso in the pan. Saute for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add soy sauce, ground black pepper, and water. Stir. Cook for 1 minute. Transfer to a serving bowl. Set aside."
    },
    {
      "position": 6,
      "text": "Start making Pesang Isda by frying the fish. Heat oil in a wok. Fry one side of the fish until it turns golden brown in color. Turn it over and do the same on the opposite side. Remove from the pan and place on a clean plate. Set aside."
    },
    {
      "position": 7,
      "text": "On a clean pan, heat oil. Saute onion and ginger. Cook until the layers of the onion separate. Add garlic. Continue cooking for 30 seconds."
    },
    {
      "position": 8,
      "text": "Pour rice washing and add whole peppercorn. Boil for 2 minutes."
    },
    {
      "position": 9,
      "text": "Add fried fish. Cook one side for 3 minutes. Turn it over and boil the opposite side for 5 minutes."
    },
    {
      "position": 10,
      "text": "Season with fish sauce and add remaining vegetables. Continue cooking for 2 minutes."
    },
    {
      "position": 11,
      "text": "Serve with Ginisang Miso. Share and enjoy!"
    }
  ],
  "servings": 4,
