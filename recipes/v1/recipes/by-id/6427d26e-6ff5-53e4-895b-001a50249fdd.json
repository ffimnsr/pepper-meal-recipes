  "slug": "spicy-calderetang-kambing-with-peanut-butter-goat-meat-caldereta",
  "name": "Spicy Calderetang Kambing with Peanut Butter (Goat Meat Caldereta)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Spicy Calderetang Kambing with Peanut Butter (Goat Meat Caldereta)",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Saute garlic, onion, and chilies for 3 minutes."
    },
    {
      "position": 3,
      "text": "Add goat meat. Saute until light brown."
    },
    {
      "position": 4,
      "text": "Add tomato paste and pour tomato sauce. Stir."
    },
    {
      "position": 5,
      "text": "Pour beef broth. Let boil. Cover and cook between low to medium heat for 90 minutes or until tender."
    },
    {
      "position": 6,
      "text": "Add peanut butter. Stir to ensure that all ingredients are well blended."
    },
    {
      "position": 7,
      "text": "Add salt and ground black pepper."
    },
    {
      "position": 8,
      "text": "Stir-in green peas and bell peppers. Cover and cook for 8 to 10 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 120,
