  "id": "11f5a9da-acab-5a98-85ba-6f8e1083db3a",
  "slug": "buttermilk-pancakes",
  "name": "Buttermilk Pancakes",
  "recipe_type": "dessert",
  "brief_description": "It is undeniable that Buttermilk Pancakes makes breakfast more enjoyable. Whether you top it with whipped butter or whipped cream",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the dry ingredients in a mixing bowl starting with the flour, salt, baking soda, sugar, and baking powder. Mix well using a wire whisk."
    },
    {
      "position": 2,
      "text": "On another clean bowl, combine the eggs, buttermilk, milk, and melted butter. Stir."
    },
    {
      "position": 3,
      "text": "Pour-in the liquid mixture to the bowl with the mixture of dry ingredients. Gently whisk until all the ingredients are incorporated."
    },
    {
      "position": 4,
      "text": "Heat a pan and then lightly spray some cooking oil."
    },
    {
      "position": 5,
      "text": "When the pan becomes hot, scoop about half a cup of mixture and then pour-in the pan. Cook for about 1 to 2 minutes. Flip the pancake and then cook the other side for the same time."
    },
    {
      "position": 6,
      "text": "Transfer to individual plates and then top with a scoop of whipped butter and some pancake syrup."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 2,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
