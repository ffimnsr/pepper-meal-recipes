  "id": "742414a6-6a6f-5860-bfc4-3fc999fea396",
  "slug": "almondigas-misua-patola-recipe",
  "name": "Almondigas Recipe",
  "recipe_type": "soup",
  "brief_description": "Almondigas or Albondigas is a Meatball Soup Recipe. The Filipino version is also called meatball soup with misua and patola.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a large mixing bowl, combine the ground pork, half of the onion, raw egg, salt, ground black pepper, and flour. Mix thoroughly until all the ingredients are well incorporated. Set aside."
    },
    {
      "position": 2,
      "text": "Heat a cooking pot and pour-in oil."
    },
    {
      "position": 3,
      "text": "When the oil is hot enough, saut\u00e9 the garlic and remaining onions."
    },
    {
      "position": 4,
      "text": "Add the beef cube and fish sauce and cook for a minute."
    },
    {
      "position": 5,
      "text": "Pour-in water and let boil."
    },
    {
      "position": 6,
      "text": "Scoop about a tablespoon of the meat mixture and form it into a ball shape figure then drop in the boiling one after the other. Cook for 10 minutes."
    },
    {
      "position": 7,
      "text": "Add the patola (loofah) and cook for 2 to 3 minutes."
    },
    {
      "position": 8,
      "text": "Put-in the misua and cook for 1 to 2 minutes while gently stirring."
    },
    {
      "position": 9,
      "text": "Turn off heat and transfer to a serving bowl."
    },
    {
      "position": 10,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
