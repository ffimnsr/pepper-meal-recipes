  "id": "6ed178ba-c79f-53bf-acbe-292ee3f17d27",
  "slug": "beef-pares-sa-kanto",
  "name": "Beef Pares Kanto Style",
  "recipe_type": "main",
  "brief_description": "Meat, stew and rice\u2013 these are three common and basic elements of your classic Filipino savory dish. And there is good reason for this mix of ingredients. The meat adds your much-needed protein for a sense of balance in the meal. Not to mention, it adds great texture and flavor to your dish. Stew sinks\u2026",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Make the beef pares by heating oil in a cooking pot. Add beef fat. Saute for 2 minutes."
    },
    {
      "position": 2,
      "text": "Add onion, garlic, and ginger. Saute until the onion gets tender."
    },
    {
      "position": 3,
      "text": "Add beef. Cook until color turns medium brown (this usually takes 5 minutes)."
    },
    {
      "position": 4,
      "text": "Pour-in water. Let boil."
    },
    {
      "position": 5,
      "text": "Add star anise and Knorr Beef Cube. Cover the pot and adjust the heat to low. Cook for 2 to 2 1/2 hours or until beef gets very tender."
    },
    {
      "position": 6,
      "text": "Season with soy sauce, onion powder, ground black pepper, brown sugar, and salt. Stir."
    },
    {
      "position": 7,
      "text": "Make the garlic fried rice by heating oil in a pan. Add crushed garlic. Saute until garlic turns golden brown. Add leftover rice. Stir until all ingredients are well blended. Season with salt. Stir and cook for 3 to 5 minutes. Set aside."
    },
    {
      "position": 8,
      "text": "Arrange beef pares in a bowl and top with chopped green onions."
    },
    {
      "position": 9,
      "text": "Arrange garlic fried rice in another bowl and top with chopped green onions too."
    },
    {
      "position": 10,
      "text": "Serve hot! Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 180,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "expert",
