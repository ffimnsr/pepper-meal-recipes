  "id": "30bdf125-56ea-593e-ac13-b7110ea233d1",
  "slug": "crispy-dinakdakan-recipe",
  "name": "Crispy Dinakdakan",
  "recipe_type": "appetizer",
  "brief_description": "Deep fried pork belly, pig ears, and liver with onion and chili with rich and creamy dressing.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Tenderize the pork belly and pig ears. Do this by boiling water in a cooking pot. Add whole peppercorn, dried bay leaves, and garlic. Add pig ears and pork belly into the pot. Cover and boil between low to medium heat for 45 to 60 minutes. Drain the liquid, set aside."
    },
    {
      "position": 2,
      "text": "Prepare the liver by rubbing with salt. Heat 2 tablespoons oil in a pan. Cook the liver by pan-frying until brown. Set aside."
    },
    {
      "position": 3,
      "text": "Heat 3 cups cooking oil in a deep fryer or deep cooking pot. Rub salt all over the boiled pig ears and belly."
    },
    {
      "position": 4,
      "text": "Deep-fry the ears for 10 minutes. Remove from the fryer and let it rest for 5 minutes. Fry again for another 10 minutes. Set aside."
    },
    {
      "position": 5,
      "text": "Deep-fry pork belly for 8 minutes. Remove from the fryer and let it rest for 5 minutes. Deep-fry again for 5 minutes or until crispy. Set aside."
    },
    {
      "position": 6,
      "text": "Prepare the dressing by combining all dressing ingredients in a bowl. Stir until smooth."
    },
    {
      "position": 7,
      "text": "Chop the crispy ears and belly into bite-size pieces. Place in a large bowl and then add the fried liver. Toss. Add onion, green onion, and chili pepper. Mix until well blended."
    },
    {
      "position": 8,
      "text": "Pour half of the dressing into the bowl. Toss."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
