  "id": "f58032f7-45fc-59fe-8a41-a32ae68f5a49",
  "slug": "crispy-five-spice-spare-ribs",
  "name": "Crispy Five Spice Spare Ribs",
  "recipe_type": null,
  "brief_description": "Chopped spare ribs coated with five spice powder and garlic powder and fried until crispy",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine ribs, five spice powder, salt, garlic powder, sherry, ground black pepper, and cornstarch. Mix well and marinate for at least 3 hours."
    },
    {
      "position": 2,
      "text": "Heat a deep fryer or cooking pot and pour-in cooking oil."
    },
    {
      "position": 3,
      "text": "Divide the marinated ribs into two batches."
    },
    {
      "position": 4,
      "text": "When the oil turns hot, deep fry the first batch of marinated ribs for about 8 to 12 minutes."
    },
    {
      "position": 5,
      "text": "Remove the first batch of ribs from the fryer and transfer to a plate. Meanwhile, deep fry the second batch for a good 8 to 12 minutes."
    },
    {
      "position": 6,
      "text": "Remove the second batch of ribs from the fryer and transfer to a plate. Deep fry the first batch of ribs for the second time for another 10 minutes or until the texture becomes crispy."
    },
    {
      "position": 7,
      "text": "Remove the first batch of ribs from the fryer and transfer to a serving plate lined with paper towels (this will absorb excess oil)."
    },
    {
      "position": 8,
      "text": "Put-the second batch of ribs in the fryer and fry for 10 minutes or until crispy."
    },
    {
      "position": 9,
      "text": "Remove the second batch from the fryer and transfer to the serving plate with the first batch of ribs."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
