  "id": "9e57466e-ddb9-560a-9f22-6fd85d8effb6",
  "slug": "easy-egg-salad",
  "name": "Easy Egg Salad Recipe",
  "recipe_type": "salad",
  "brief_description": "Easy Egg Salad is a quick and simple egg salad recipe that you will surely like. It makes use of basic ingredients that are easy to find",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Remove the shell from the eggs and chop the eggs into small pieces. Place the chopped eggs in a large bowl. Set aside."
    },
    {
      "position": 2,
      "text": "Meanwhile, combine mayonnaise, Dijon mustard, celery, green onion, dill relish, sugar, salt and pepper in another bowl. Stir to mix."
    },
    {
      "position": 3,
      "text": "Pour the mixture to the large bowl with the chopped boiled eggs. Toss until all the ingredients are well incorporated."
    },
    {
      "position": 4,
      "text": "Cover the bowl and refrigerate to chill for at least 1 hour."
    },
    {
      "position": 5,
      "text": "Serve as a salad or top over a slice of bread."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 10,
