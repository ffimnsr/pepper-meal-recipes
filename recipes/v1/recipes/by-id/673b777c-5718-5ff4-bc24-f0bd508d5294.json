  "id": "673b777c-5718-5ff4-bc24-f0bd508d5294",
  "slug": "chicken-feet-adobo",
  "name": "Chicken Feet Adobo",
  "recipe_type": null,
  "brief_description": "This Chicken Feet Adobo Recipe is simple yet produces a delicious product. Try this recipe today and enjoy!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking pot and pour-in 16 tablespoons of cooking oil."
    },
    {
      "position": 2,
      "text": "Fry the chicken feet until color turns light brown. Set aside."
    },
    {
      "position": 3,
      "text": "On a clean pot, heat 2 tablespoons of cooking oil."
    },
    {
      "position": 4,
      "text": "Saute garlic and dried chili."
    },
    {
      "position": 5,
      "text": "Put-in the fried chicken feet, soy sauce, and water. Let boil."
    },
    {
      "position": 6,
      "text": "Add the dried bay leaves, whole peppercorn, oyster sauce, and sugar. Stir and simmer until chicken feet becomes tender.Note: add water as necessary."
    },
    {
      "position": 7,
      "text": "Add vinegar and stir. Cook for 5 minutes more. Taste and add salt as needed."
    },
    {
      "position": 8,
      "text": "Turn-off heat, and then transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
