  "id": "d0dd164c-3d82-56f7-828d-0d24cccf2e98",
  "slug": "best-dessert-new-york-style-cheesecake-cherry-pie-filling-recipe",
  "name": "New York Style Cheesecake",
  "recipe_type": "dessert",
  "brief_description": "New York Style Cheesecake is a type of dessert made from sweetened cream cheese, sour cream, and eggs.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Beat the cream cheese in a mixing bowl using an electric mixer for about 2 to 3 minutes"
    },
    {
      "position": 2,
      "text": "Whisk-in the granulated sugar and continue beating until everything is properly distributed."
    },
    {
      "position": 3,
      "text": "Add the flour and vanilla essence(or extract) then mix again for about 1 minute."
    },
    {
      "position": 4,
      "text": "Put-in the sour cream and continue mixing for another minute."
    },
    {
      "position": 5,
      "text": "Gradually add the eggs one at a time while mixing. Continue mixing until all the ingredients are well distributed."
    },
    {
      "position": 6,
      "text": "Pour the mixture over the graham pie crust."
    },
    {
      "position": 7,
      "text": "Preheat oven at 325 degrees Fahrenheit then bake for 30 to 35 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven then allow to cool down"
    },
    {
      "position": 9,
      "text": "Place the cherry pie filling on top of the cheesecake and spread evenly."
    },
    {
      "position": 10,
      "text": "Refrigerate for 30 minutes to an hour."
    },
    {
      "position": 11,
      "text": "Serve. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
