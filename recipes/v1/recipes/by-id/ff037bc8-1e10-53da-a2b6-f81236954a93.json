  "slug": "chicken-corn-and-malunggay-soup-recipe",
  "name": "Corn and Malunggay Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "This Corn and Malunggay Soup Recipe is nutricious and delicious. It can make you feel warm during cold days.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in olive oil."
    },
    {
      "position": 2,
      "text": "When the oil becomes hot, saute the garlic and onions."
    },
    {
      "position": 3,
      "text": "Put-in the shredded corn and stir."
    },
    {
      "position": 4,
      "text": "Pour-in chicken broth and let boil. Simmer for 8 to 10 minutes."
    },
    {
      "position": 5,
      "text": "Add salt and ground black pepper then cook for 2 minutes more."
    },
    {
      "position": 6,
      "text": "Put-in the malunggay leaves. Stir and simmer for 2 minutes more."
    },
    {
      "position": 7,
      "text": "Turn-off heat and transfer to a serving bowl."
    },
    {
      "position": 8,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
