  "id": "3affc6e9-e28c-513e-a91d-f89a93f4ee87",
  "slug": "special-chicken-embutido-recipe-filipino-chicken-meatloaf",
  "name": "Special Chicken Embutido Recipe (Filipino Chicken Meatloaf)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Special Chicken Embutido Recipe (Filipino Chicken Meatloaf)",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a mixing bowl, crush the chicken using a fork."
    },
    {
      "position": 2,
      "text": "Crack the eggs. Beat until the chicken cube dilutes in the beaten egg."
    },
    {
      "position": 3,
      "text": "Add the bell peppers, onion, raisins, sweet relish, and cheese. Fold to mix the ingredients."
    },
    {
      "position": 4,
      "text": "Add the ground chicken, salt, ground black pepper, and vegetable oil. Continue to fold until all the ingredients are well blended."
    },
    {
      "position": 5,
      "text": "Wrap the mixture in aluminum foil. Scoop a cup of mixture and arrange it in a sheet of aluminum foil. Place some wedged hard-boiled eggs in the middles and then roll the foil to shape like a cylinder. Secure both sides by twirling the ends of the foil until the mixture inside is compact."
    },
    {
      "position": 6,
      "text": "Boil water in a steamer or pot."
    },
    {
      "position": 7,
      "text": "Arrange the wrapped chicken embutido in a steamer."
    },
    {
      "position": 8,
      "text": "Cover and steam for 1 hour."
    },
    {
      "position": 9,
      "text": "Let the chicken embutido cool down."
    },
    {
      "position": 10,
      "text": "Place in the refrigerator for 3 hours."
    },
    {
      "position": 11,
      "text": "Slice and arrange in a serving plate. Serve cold."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 10,
  "cooking_time_minutes": 60,
