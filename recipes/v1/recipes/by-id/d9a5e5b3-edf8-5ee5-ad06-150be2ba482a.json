  "slug": "asadong-baboy-recipe",
  "name": "Asadong Baboy",
  "recipe_type": null,
  "brief_description": "This is a recipe for Asadong Baboy.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Add pork. Pour soy sauce, anisado wine, and beef broth into the pot. Let boil. Cover and continue to cook in low to medium heat for 30 to 35 minutes or until the pork becomes tender. Note: 2 pieces of star anise can be used if anisado wine is not available."
    },
    {
      "position": 4,
      "text": "Add brown sugar. Stir."
    },
    {
      "position": 5,
      "text": "Season with salt and ground black pepper"
    },
    {
      "position": 6,
      "text": "Pour cornstarch and water mixture into the pot. Stir. Continue to cook until desired consistency is achieved."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
