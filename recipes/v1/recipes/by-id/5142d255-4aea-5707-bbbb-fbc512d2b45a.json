  "id": "5142d255-4aea-5707-bbbb-fbc512d2b45a",
  "slug": "recipe-for-barbecue-chicken-marinade",
  "name": "Barbecue Chicken Marinade",
  "recipe_type": null,
  "brief_description": "A savory-sweet marinade for chicken barbecue made with soy sauce, lemon, and lemon lime soda.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine soy sauce, juice of 1 lemon, salt, red chili flakes, ground black pepper, and garlic powder. Stir until well mixed."
    },
    {
      "position": 2,
      "text": "Pour in the lemon lime soda. Stir."
    },
    {
      "position": 3,
      "text": "Use immediately to marinate chicken barbecue, or refrigerate for up to one day. Stir again before using."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 5,
