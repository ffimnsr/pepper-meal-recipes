  "slug": "recipe-for-barbecue-chicken-marinade",
  "name": "Recipe for Barbecue Chicken Marinade",
  "recipe_type": null,
  "brief_description": "Make delicious chicken barbecue by using this Recipe for Barbecue Chicken Marinade. It really works wonders!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, Combine soy sauce, juice of 1 lemon, salt, red chili flakes, ground black pepper, and garlic"
    },
    {
      "position": 2,
      "text": "powder. Stir and mix well."
    },
    {
      "position": 3,
      "text": "Pour-in the lemon lime soda. Stir."
    },
    {
      "position": 4,
      "text": "You can use this to marinate chicken barbecue right on the spot, or you can place this inside the fridge for a day. Make sure to stir again before using."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 1,
