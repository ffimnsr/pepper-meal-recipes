  "id": "979c0009-5ea7-5d0c-a892-1e33e22c3dcb",
  "slug": "honey-balsamic-glazed-mahi-mahi",
  "name": "Honey and Balsamic Glazed Mahi-mahi",
  "recipe_type": null,
  "brief_description": "Honey and Balsamic Glazed Mahi mahi is a healthy and delicious choice for lunch. This will even be better if paired with brown rice and steamed asparagus.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the mustard powder, salt, and ground black pepper in a bowl. Mix well and set aside."
    },
    {
      "position": 2,
      "text": "Microwave the honey for 15 to 20 seconds and then mix with balsamic vinegar. Stir to mix."
    },
    {
      "position": 3,
      "text": "Rub the salt, pepper, and mustard mixture all over each mahi mahi fillet."
    },
    {
      "position": 4,
      "text": "Brush the top with the honey and balsamic vinegar mixture."
    },
    {
      "position": 5,
      "text": "Heat the grill and then grill each side of the fish in medium heat for 5 to 6 minutes while basting with the honey mixture."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve with brown rice and steamed asparagus."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
