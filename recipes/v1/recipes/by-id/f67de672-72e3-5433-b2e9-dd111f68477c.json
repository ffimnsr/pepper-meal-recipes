  "id": "f67de672-72e3-5433-b2e9-dd111f68477c",
  "slug": "tinolang-isda",
  "name": "Tinolang Isda",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Tinolang Isda using Tuna Jaw or Panga ng Tuna.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a soup pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add ginger, tomato, and onion. Let the water reboil"
    },
    {
      "position": 3,
      "text": "Add-in the lemongrass. Cover and boil for 5 to 8 minutes."
    },
    {
      "position": 4,
      "text": "Gently slide-in the Tuna. Cover and cook for 12 to 15 minutes."
    },
    {
      "position": 5,
      "text": "Add the fish cube and then stir. Cover and continue to cook between low to medium heat for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the hot pepper leaves, scallions, long green pepper, and fish sauce. Stir and cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
