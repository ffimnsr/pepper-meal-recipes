  "id": "f85d533c-5ca1-5a91-94c7-7302f1b0c327",
  "slug": "scallop-chop-suey-recipe",
  "name": "Scallop Chop Suey Recipe",
  "recipe_type": null,
  "brief_description": "Scallop Chop Suey is another variation of the popular chop suey recipe. Instead of using the traditional meats, I used scallops.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and onion"
    },
    {
      "position": 3,
      "text": "Put-in the scallops. Cook each side for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add the carrot and cauliflower. Cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the snow peas, cabbage, and bell pepper. Cook for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in broth. Let boil."
    },
    {
      "position": 7,
      "text": "Add the quail eggs."
    },
    {
      "position": 8,
      "text": "Pour-in cornstarch diluted in water. Stir."
    },
    {
      "position": 9,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
