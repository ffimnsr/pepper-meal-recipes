  "id": "6c512db8-3db6-50c9-b2db-dbbc54724b00",
  "slug": "sizzling-liempo-sisig-recipe-knr_kls",
  "name": "Sizzling Liempo Sisig",
  "recipe_type": null,
  "brief_description": "This is a recipe for Sizzling Pork Belly Sisig",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add pork belly. Cover and continue to boil in medium heat for 25 minutes."
    },
    {
      "position": 3,
      "text": "Discard water and let the liempo cool down."
    },
    {
      "position": 4,
      "text": "Grill the pork for 4 to 5 minutes per side. Remove from the grill and slice into cubes."
    },
    {
      "position": 5,
      "text": "Mince the onions using a food processor. Set aside."
    },
    {
      "position": 6,
      "text": "Place the grilled pork belly on the same food processor. Mince."
    },
    {
      "position": 7,
      "text": "Heat oil on a cooking pot."
    },
    {
      "position": 8,
      "text": "Pan-fry the chicken liver for 3 to 5 minutes per side."
    },
    {
      "position": 9,
      "text": "Remove chicken liver from the pot. Place in the food processor and mince."
    },
    {
      "position": 10,
      "text": "Saute onion using the remaining oil in the pot until it becomes soft."
    },
    {
      "position": 11,
      "text": "Add minced pork. Saute for 3 minutes."
    },
    {
      "position": 12,
      "text": "Put the chicken liver. Mix until well blended. Continue to cook for 5 to 7 minutes."
    },
    {
      "position": 13,
      "text": "Pour Knorr Liquid Seasoning. Stir."
    },
    {
      "position": 14,
      "text": "Add ground black pepper, garlic powder, and chili pepper. Mix until all ingredients are well blended. Cook for 2 to 3 minutes."
    },
    {
      "position": 15,
      "text": "Add Lady's Choice Mayonnaise. Mix until all ingredients are well blended. Continue to cook in high heat for 3 minutes. Set aside."
    },
    {
      "position": 16,
      "text": "Heat a metal plate (also known as sizzling plate)"
    },
    {
      "position": 17,
      "text": "Run the butter over the plate until it melts."
    },
    {
      "position": 18,
      "text": "Transfer the cooked liempo sisig on the sizzling plate."
    },
    {
      "position": 19,
      "text": "Serve with lemon or calamansi. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 45,
