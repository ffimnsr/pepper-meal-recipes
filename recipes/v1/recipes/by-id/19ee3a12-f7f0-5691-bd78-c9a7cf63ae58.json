  "id": "19ee3a12-f7f0-5691-bd78-c9a7cf63ae58",
  "slug": "lumpiang-hubad-recipe-knr-pc",
  "name": "Lumpiang Hubad Recipe",
  "recipe_type": "dessert",
  "brief_description": "Vegetable saute with pork topped with sweet brown peanut sauce. This is a great dish to have anytime of the day.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saute onion and garlic until onion becomes soft."
    },
    {
      "position": 2,
      "text": "Add pork. Cook until brown."
    },
    {
      "position": 3,
      "text": "Pour 1 \u00bd up to 2 cups of water. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Pork Cube. Stir. Cover the pot and cook between low to medium heat until the liquid evaporates and the pork tenderizes."
    },
    {
      "position": 5,
      "text": "Add parsley, carrot, kamote, and \u00bd cup water. Cover the cooking pot. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Put the long green beans and cabbage into the pot. Toss. Cover the pot and cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 8,
      "text": "Add singkamas. Toss. Arrange on a serving plate. Set aside."
    },
    {
      "position": 9,
      "text": "Prepare the sauce by combining cornstarch with 3 tablespoons water. Stir until the cornstarch dilutes. Set aside."
    },
    {
      "position": 10,
      "text": "Pour 1 \u00bd cups water into a saucepan. Let boil."
    },
    {
      "position": 11,
      "text": "Add soy sauce and garlic. Cook for 2 minutes."
    },
    {
      "position": 12,
      "text": "Add dark brown sugar. Stir."
    },
    {
      "position": 13,
      "text": "Pour the cornstarch diluted in water. Stir. Continue to cook while stirring until the desired consistency is achieved."
    },
    {
      "position": 14,
      "text": "Pour the sauce over lumpiang hubad. Top with crushed peanuts."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 22,
  "preparation_time_minutes": 8,
  "rest_time_minutes": null,
