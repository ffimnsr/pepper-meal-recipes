  "id": "e3c0113c-7c71-5eb8-b704-78810e2a8915",
  "slug": "bacon-wrapped-shrimp-recipe",
  "name": "Bacon Wrapped Shrimp",
  "recipe_type": "appetizer",
  "brief_description": "Bacon Wrapped Shrimp is an easy shrimp appetizer recipe that tastes really good. The process involves marinating the shrimp",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Squeeze the lemon and place the juice in a large bowl."
    },
    {
      "position": 2,
      "text": "Add the salt, pepper, and garlic powder. Stir."
    },
    {
      "position": 3,
      "text": "Put the shrimp in the bowl. Toss and then marinate for 30 minutes."
    },
    {
      "position": 4,
      "text": "Meanwhile, cook the bacon strips in a griddle or pan until it is halfway done. Make sure that the bacon is not crisp and can still be bent without breaking. Set aside."
    },
    {
      "position": 5,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 6,
      "text": "Cut the bacon in half (crosswise). Wrap the shrimp with the bacon and secure by inserting a toothpick."
    },
    {
      "position": 7,
      "text": "Arrange the bacon wrapped shrimp in a baking tray. Brush with the remaining marinade to keep the moisture in."
    },
    {
      "position": 8,
      "text": "Bake for 10 to 12 minutes. Do not over bake the shrimp."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve with your favorite sauce."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 30,
