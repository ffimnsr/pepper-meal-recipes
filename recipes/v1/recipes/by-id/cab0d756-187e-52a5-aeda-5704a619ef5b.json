  "id": "cab0d756-187e-52a5-aeda-5704a619ef5b",
  "slug": "sizzling-tofu-recipe",
  "name": "Sizzling Tofu",
  "recipe_type": null,
  "brief_description": "This is a delicious recipe for Sizzling Tofu",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the sauce by combining all the sauce ingredients. Mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a pot."
    },
    {
      "position": 3,
      "text": "Once the oil gets hot (around 350F), deep fry the cubed tofu until it turns light brown. Remove from the pot and place in a plate with paper towel. Set aside"
    },
    {
      "position": 4,
      "text": "Scoop 3 tablespoons cooking oil from the pot where the tofu was fried. Heat it in a separate clean pot."
    },
    {
      "position": 5,
      "text": "Saute onion and bell peppers."
    },
    {
      "position": 6,
      "text": "Add the fried tofu. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Pour half of the sauce mixture into the pot. Stir and continue to cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Heat a sizzling plate on the stovetop. Melt butter into the plate. Transfer cooked tofu on the metal plate and pour the remaining sauce. Toss and cook for 1 minute."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
