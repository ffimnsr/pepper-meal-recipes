  "id": "0cc3752e-940a-5db6-979b-38f94eed9b64",
  "slug": "binagoongang-talong",
  "name": "Binagoongang Talong Recipe",
  "recipe_type": "salad",
  "brief_description": "Eggplant cooked in shrimp paste with chillies.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Fry eggplant for 1 \u00bd minute per side. Remove from the pan. Set aside."
    },
    {
      "position": 2,
      "text": "Using remaining oil, saut\u00e9 garlic until it turns light brown. Add onion and tomato. Continue saut\u00e9ing until the onion softens."
    },
    {
      "position": 3,
      "text": "Add pork and chili pepper. Cook until the pork turns light brown."
    },
    {
      "position": 4,
      "text": "Add bagoong alamang. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour water and vinegar into the pot. Let boil. Continue cooking for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Add fried eggplant. Stir and cook for 1 \u00bd minutes."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and sugar."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
