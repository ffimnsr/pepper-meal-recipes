  "id": "9e635a98-fa98-58ab-9ac9-96f5690c24b3",
  "slug": "ginisang-tuna-recipe-canned-albacore-tuna-sauteed-with-onions",
  "name": "Ginisang Tuna (Canned Albacore Tuna Sauteed with Onions)",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for tuna in can. Solid White Albacore Tuna was used for this recipe. The result is a delicious fresh tasting tuna that can be eaten with salad, bread, or rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Open the canned tuna and discard water."
    },
    {
      "position": 2,
      "text": "Heat the oil in a pan. Once the oil gets hot, saute the onion for 1 minute."
    },
    {
      "position": 3,
      "text": "Add the Albacore tuna. Continue to saute for 2 to 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour the chicken broth in the pan. Stir. Cover and cook in medium heat for 3 to 5 minutes or until it almost evaporates. You can add more broth if needed."
    },
    {
      "position": 5,
      "text": "Add parsley, salt, and ground black pepper. Squeeze the lime over the tuna. Stir."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
