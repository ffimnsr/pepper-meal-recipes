  "id": "3655ee0b-dd27-5b67-96b5-d54aeb286dd8",
  "slug": "nilagang-baka-recipe",
  "name": "Nilagang Baka Recipe",
  "recipe_type": "soup",
  "brief_description": "You probably wouldn\u2019t expect Nilagang Baka to be a delicious balance of flavors. Though simple to cook, this beef soup is really good.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the water and beef broth in a large cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the onion, star anise, and celery. Reduce the heat in medium. Cover the pot and continue to boil for 20 minutes."
    },
    {
      "position": 3,
      "text": "Remove the onion, star anise, and celery from the boiling liquid using a skimmer or a strainer. You can discard these ingredients."
    },
    {
      "position": 4,
      "text": "Add the beef. Simmer for 60 to 90 minutes or until the beef becomes tender. You can add more water if necessary."
    },
    {
      "position": 5,
      "text": "Put-in the saba banana and potatoes. Cook for 10 minutes."
    },
    {
      "position": 6,
      "text": "Add the bok choy and cabbage. Sprinkle salt and pepper. Stir."
    },
    {
      "position": 7,
      "text": "Cover and turn the heat off. Let the pot stay with cover-on for 2 to 5 minutes to cook the vegetables."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 72,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
