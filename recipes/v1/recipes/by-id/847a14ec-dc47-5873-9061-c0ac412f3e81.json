  "slug": "turkey-and-cranberry-sandwich-with-cream-cheese",
  "name": "Turkey and Cranberry Sandwich with Cream Cheese",
  "recipe_type": null,
  "brief_description": "Making Turkey and Cranberry Sandwich with Cream Cheese is a quick and easy idea to consume your leftover turkey and cranberry sauce.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Toast the wholegrain bread slices."
    },
    {
      "position": 2,
      "text": "Spread the cream cheese on the side of 1 sliced bread."
    },
    {
      "position": 3,
      "text": "Arrange the sliced turkey bread on top and then spread the cranberry sauce over the turkey."
    },
    {
      "position": 4,
      "text": "Top with the second slice of bread. Serve with apple cranberry juice. Share and enjoy!"
    }
  ],
