  "id": "e23188a1-b463-5da4-ad95-07efa597d2fa",
  "slug": "sour-cream-noodle-bake",
  "name": "Sour Cream Noodle Bake",
  "recipe_type": null,
  "brief_description": "Sour Cream Noodle Bake is a rich baked noodle dish perfect for lunch or dinner. This recipe makes use of 3 different cheeses",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the noodle according to package instructions. Drain. Set aside."
    },
    {
      "position": 2,
      "text": "Melt the butter in a pan."
    },
    {
      "position": 3,
      "text": "Add the ground beef and cook until brown."
    },
    {
      "position": 4,
      "text": "Put-in garlic salt. Stir and cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in tomato sauce. Let boil and simmer until the sauce reduces to half. Set aside."
    },
    {
      "position": 6,
      "text": "Preheat oven to 350 Fahrenheit."
    },
    {
      "position": 7,
      "text": "Combine the cooked noodles, ricotta cheese, Parmesan cheese, sour cream, and scallions. Gently toss to mix."
    },
    {
      "position": 8,
      "text": "Arrange the noodle mixture at the bottom of a baking pan. Top with a layer of the cooked ground beef. Arrange the shredded sharp cheddar cheese on top."
    },
    {
      "position": 9,
      "text": "Bake for 20 minutes."
    },
    {
      "position": 10,
      "text": "Remove from the oven. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
