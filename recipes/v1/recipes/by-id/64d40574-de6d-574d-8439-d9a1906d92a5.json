  "id": "64d40574-de6d-574d-8439-d9a1906d92a5",
  "slug": "how-to-make-spiced-vinegar-sinamak",
  "name": "How to Make Sinamak",
  "recipe_type": null,
  "brief_description": "This is a recipe for Sinamak or Spicy Vinegar",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine whole peppercorn, ginger, garlic, onion, and chili in a clean container (usually an empty bottle of liquor). Shake well to distribute the ingredients."
    },
    {
      "position": 2,
      "text": "Fill the bottle with the vinegar of your choice then tightly cover the bottle."
    },
    {
      "position": 3,
      "text": "Shake the bottle lightly and store in a safe place for at least 3 days. The longer the storage time, the spicier the vinegar will become."
    },
    {
      "position": 4,
      "text": "Serve as condiment for fried and grilled foods"
    }
  ],
  "servings": 10,
  "cooking_time_minutes": 1,
