  "id": "dd1912b9-e647-58e9-ac08-08af85b731fa",
  "slug": "crispy-fried-chicken-with-mushroom-gravy",
  "name": "Crispy Fried Chicken with Mushroom Gravy",
  "recipe_type": "main",
  "brief_description": "And so I made a guide in creating the delicious classic. Keep reading to find out more about my Crispy Fried Chicken Recipe",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Coat the chicken all over with Knorr Liquid Seasoning. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, make the mushroom gravy. Melt butter in a pot. Add all-purpose flour. Stir while cooking until lumps form and the mixture turns medium brown in color."
    },
    {
      "position": 3,
      "text": "Combine Knorr Cream of Mushroom with 1 \u00bd cups of water. Mix well and pour into the pot. Stir and let this simmer for a few minutes. Continue stirring until the consistency of the mixture smoothens. Set this aside while keeping it warm."
    },
    {
      "position": 4,
      "text": "Heat the oil in a deep pan."
    },
    {
      "position": 5,
      "text": "Combine all the breading ingredients in a bowl and mix it well."
    },
    {
      "position": 6,
      "text": "Dredge the chicken into the breading, dip in beaten egg, and roll it back into the breading making sure that the entire piece is well coated."
    },
    {
      "position": 7,
      "text": "Start frying the chicken until both sides are brown and crisp (and the internal temperature reads at least 165F)."
    },
    {
      "position": 8,
      "text": "Arrange on a serving plate. Serve with mushroom gravy. Share and enjoy!"
    }
  ],
  "servings": null,
