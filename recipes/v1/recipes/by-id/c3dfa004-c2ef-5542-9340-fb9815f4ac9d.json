  "id": "c3dfa004-c2ef-5542-9340-fb9815f4ac9d",
  "slug": "adobong-kambing-recipe",
  "name": "Adobong Kambing Recipe",
  "recipe_type": null,
  "brief_description": "Adobong Kambing is a goat dish wherein goat meat is tenderized and cooked using the popular Filipino Adobo style.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour 3 cups of water in a cooking pot and put-in ginger, onion, and salt. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the goat meat and simmer until the meat is tender."
    },
    {
      "position": 3,
      "text": "Turn off the heat, drain the water, and separate the meat from other ingredients. Set aside."
    },
    {
      "position": 4,
      "text": "Pour-in cooking oil in a wok or a frying pan then apply heat."
    },
    {
      "position": 5,
      "text": "When the oil is hot enough, put-in the garlic and fry until the color turns light brown."
    },
    {
      "position": 6,
      "text": "Add the goat meat and pan fry until the outer part turns light brown."
    },
    {
      "position": 7,
      "text": "Add soy sauce, 1 cup water, crushed peppercorns, and dried bay leaves then simmer for 10 minutes."
    },
    {
      "position": 8,
      "text": "Add vinegar and let boil. Simmer for 5 to 7 minutes."
    },
    {
      "position": 9,
      "text": "Put-in the dried chilies (if desired) and simmer until the sauce becomes thick."
    },
    {
      "position": 10,
      "text": "Turn off the heat and transfer to a serving plate."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
