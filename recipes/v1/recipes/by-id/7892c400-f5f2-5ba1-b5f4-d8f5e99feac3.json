  "id": "7892c400-f5f2-5ba1-b5f4-d8f5e99feac3",
  "slug": "beef-short-rib-sinigang-na-may-pakwan",
  "name": "Beef Short Rib Sinigang Na May Pakwan",
  "recipe_type": null,
  "brief_description": "This is a recipe for Beef Short Rib Sinigang Na May Pakwan",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a pot or pressure cooker. Let boil."
    },
    {
      "position": 2,
      "text": "Add tomato and onion. Continue to boil for 5 minutes."
    },
    {
      "position": 3,
      "text": "Put the beef short rib in the pressure cooker. Cover. Pressure cook for 30 minutes."
    },
    {
      "position": 4,
      "text": "Remove the cover of the pressure cooker. Add the watermelon. Continue to boil for 10 to 12 minutes."
    },
    {
      "position": 5,
      "text": "Add the Knorr Sinigang na may Gabi Recipe Mix. Stir. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add the snake beans. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add ground black pepper and fish sauce. Stir."
    },
    {
      "position": 8,
      "text": "Put the kangkong leaves and stalk into the pot. Cover. Let it stay for 5 to 8 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
