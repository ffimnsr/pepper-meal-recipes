{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "cd9bda71-621e-5178-93ac-7d8cc255ea73",
  "slug": "pinoy-style-baked-macaroni-with-white-sauce",
  "name": "Pinoy Style Baked Macaroni with White Sauce",
  "recipe_type": "dessert",
  "brief_description": "Baked macaroni with sweet meat sauce topped with creamy mornay sauce.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the macaroni by cooking according to package instructions. Drain the liquid and set the macaroni aside."
    },
    {
      "position": 2,
      "text": "Make the meat sauce. Heat oil in a pan. Saut\u00e9 onion and garlic. Once onion softens, saut\u00e9 ground beef and ground pork until it browns. Add hotdog and bell peppers. Cook for 1 minute."
    },
    {
      "position": 3,
      "text": "Add Knorr Beef cube. Stir and then pour tomato sauce and water. Cover the pot and boil for 20 to 25 minutes using low to medium heat. Note: add more water if needed. Season with sugar, salt, and ground black pepper. Set aside."
    },
    {
      "position": 4,
      "text": "Make the white sauce by melting butter in a saucepan. Add all-purpose flour. Stir and cook for 1 minute. Gradually pour milk while stirring. Add half of the cheese. Stir and continue cooking until the sauce thickens."
    },
    {
      "position": 5,
      "text": "Combine macaroni and meat sauce in a bowl. Add the remaining cheese. Toss."
    },
    {
      "position": 6,
      "text": "Preheat oven to 350F. Transfer the macaroni with meat sauce in a baking pan. Pour white sauce on top and then spread evenly."
    },
    {
      "position": 7,
      "text": "Bake for 15 to 20 minutes."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
