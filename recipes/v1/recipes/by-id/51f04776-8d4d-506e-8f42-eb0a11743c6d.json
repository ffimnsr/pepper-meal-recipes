{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "51f04776-8d4d-506e-8f42-eb0a11743c6d",
  "slug": "bagbagis-crispy-pork-intestine",
  "name": "Crispy Bagbagis (Crispy Deep Fried Pork Intestine)",
  "recipe_type": "appetizer",
  "brief_description": "A Filipino appetizer of crispy deep-fried pork intestines, also known as bagbagis.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Clean the intestines well with running water."
    },
    {
      "position": 2,
      "text": "Boil water in a large pot."
    },
    {
      "position": 3,
      "text": "Once the water starts to boil, add the intestines and boil for 15 minutes. Discard the water. Pour a fresh batch of water into the pot, return the intestines, and boil for 15 to 20 minutes. Discard the water once more."
    },
    {
      "position": 4,
      "text": "Pour the third batch of water into the pot and bring to a boil. Add 3 tablespoons of rock salt, bay leaves, and peppercorns. Continue to boil over low to medium heat for 1 hour. Remove the intestines and let cool."
    },
    {
      "position": 5,
      "text": "Cut the intestines crosswise into small pieces. Rub the remaining salt all over them and let sit for 5 minutes."
    },
    {
      "position": 6,
      "text": "Heat the oil in a large pot. Once the oil is hot, deep-fry the intestines until golden and crispy."
    },
    {
      "position": 7,
      "text": "Remove the crispy intestines from the pot and arrange on a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with spicy vinegar. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 105,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
