{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "0e86ba24-ee65-5063-b486-b17fac50308b",
  "slug": "seared-shrimp-macaroni-salad-with-roasted-bell-pepper",
  "name": "Shrimp Macaroni Salad with Roasted Bell Pepper",
  "recipe_type": "salad",
  "brief_description": "Rich and creamy macaroni salad with seared shrimp and roasted bell peppers. This delicious salad makes a good side for crispy fried chicken or grilled pork belly.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the elbow macaroni based on package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Roast the bell peppers on the stovetop. Arrange the sliced peppers on the burner grate and directly roast with fire until the pepper softens. Wash with running water while scraping burns on the outer layer. Chop and set aside."
    },
    {
      "position": 3,
      "text": "Heat a teaspoon of oil in a pan or cooking pot. Sear the fresh shrimp for 2 to 3 minutes or until it turns orangey. Remove from the pan. Chop into pieces. Set aside."
    },
    {
      "position": 4,
      "text": "Prepare the dressing by arranging a cup of Lady\u2019s Choice Mayonnaise in a large bowl. Add all the salad dressing ingredients. Stir until blended. Set aside."
    },
    {
      "position": 5,
      "text": "Assemble the shrimp macaroni salad by combining macaroni, seared shrimp, celery, and roasted bell peppers in a large bowl. Toss until all ingredients are well distributed. Pour salad dressing into the bowl. Fold until well blended."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
