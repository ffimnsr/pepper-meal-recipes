  "id": "30895034-04a1-557e-99cb-c1043a9a7fb0",
  "slug": "chocolate-crinkle-cookies-recipe",
  "name": "Chocolate Crinkle Cookies",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for&nbsp;Chocolate Crinkle Cookies",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Melt Chocolate chip using a double boiler or chocolate melter."
    },
    {
      "position": 2,
      "text": "Combine flour, salt, and baking powder in a large bowl. Mix well. Set aside."
    },
    {
      "position": 3,
      "text": "Combine sugar and cocoa powder in a mixing bowl. Mix alltogether until well distributed.Continue mixing while adding oil, vanilla extract, melted chocolate chips, and eggs. Note: Using a stand mixer with paddle attachment is ideal for this task."
    },
    {
      "position": 4,
      "text": "Gradually add the flour mixture while mixing. Continue the process until all the ingredients are well distributed. Cover the mixing bowl and refrigerate for at least 4 hours."
    },
    {
      "position": 5,
      "text": "Preheat oven to 350F. Scoop a tablespoon of chocolate mixture and shape it into a ball using your hands. Roll it over the powdered sugar until completely coated. Arrange in a baking tray lined with parchment paper. Perform this step until the chocolate mixture is completely consumed."
    },
    {
      "position": 6,
      "text": "Bake for 13 minutes."
    },
    {
      "position": 7,
      "text": "Remove from the oven and let it cool for 10 minutes."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 7,
  "cooking_time_minutes": 13,
  "preparation_time_minutes": 15,
