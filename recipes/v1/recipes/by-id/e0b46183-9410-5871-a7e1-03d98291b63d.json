  "slug": "pakbet",
  "name": "Pakbet Ilocano Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pakbet Ilocano",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "In a large pan, place water let boil"
    },
    {
      "position": 2,
      "text": "Put in the anchovy sauce and wait for the mixture to boil once more"
    },
    {
      "position": 3,
      "text": "Add-in the vegetables starting with the sweet potato then put-in the okra, bitter melon, eggplant, string beans, tomato, and onion and simmer for 15 minutes"
    },
    {
      "position": 4,
      "text": "Add the bagnet or lechon kawali (cooking procedure available in the recipe section) and simmer for 5 minutes"
    },
    {
      "position": 5,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
