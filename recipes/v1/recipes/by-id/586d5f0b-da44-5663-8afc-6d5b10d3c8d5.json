  "id": "586d5f0b-da44-5663-8afc-6d5b10d3c8d5",
  "slug": "pork-adobo-with-potato-recipe",
  "name": "Pork Adobo with Potato Recipe",
  "recipe_type": null,
  "brief_description": "Pork Adobo with Potato Recipe is another variation of the famous Pork Adobo. This easy to follow recipe incorporates potatoes to the basic adobo recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic for 30 seconds"
    },
    {
      "position": 3,
      "text": "Add the pork and whole peppercorn. Cook for 3 to 4 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in soy sauce and water."
    },
    {
      "position": 5,
      "text": "Add the bay leaves and let boil. Simmer (covered) for about 40 to 60 minutes. Note: Add water if needed"
    },
    {
      "position": 6,
      "text": "Put-in the vinegar and allow re-boiling."
    },
    {
      "position": 7,
      "text": "Add the potatoes. Simmer for 10 to 12 minutes."
    },
    {
      "position": 8,
      "text": "Add salt"
    },
    {
      "position": 9,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
