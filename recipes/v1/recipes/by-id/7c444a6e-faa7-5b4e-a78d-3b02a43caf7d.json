  "id": "7c444a6e-faa7-5b4e-a78d-3b02a43caf7d",
  "slug": "ginataang-yellow-fin-tuna",
  "name": "Ginataang Yellow Fin Tuna",
  "recipe_type": null,
  "brief_description": "Ginataang Yellow Fin Tuna is another version of fish cooked in coconut cream. I am using yellow fin tuna fillet this time.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Add ginger and continue to cook until the onion gets soft."
    },
    {
      "position": 4,
      "text": "Pour-in coconut cream. Stir and let boil."
    },
    {
      "position": 5,
      "text": "Add the ground black pepper and fish sauce. Stir and cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Put the fried yellow fin tuna fillet in the pan. Scoop some coconut cream on top while cooking. Cover and cook in low to medium heat for 12 minutes."
    },
    {
      "position": 7,
      "text": "Add the ampalaya leaves. Stir cover and cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Add red pepper flakes or fresh siling labuyo."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
