  "slug": "ginataang-salmon-sa-gata-recipe-salmon-in-coconut-milk_knr_mm",
  "name": "Ginataang Salmon (Salmon in Coconut Milk)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginataang Salmon",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and onion once the oil gets hot. Continue to cook until the onion becomes soft."
    },
    {
      "position": 3,
      "text": "In a bowl, combine Knorr Ginataang Gulay Recipe mix and water. Stir until well blended. Pour the mixture into the cooking pot. Let boil."
    },
    {
      "position": 4,
      "text": "Add salmon fillet one-by-one along with the long green pepper and chili pepper. Cover the pot and then cook in medium heat for 5 to 8 minutes."
    },
    {
      "position": 5,
      "text": "Add spinach. Stir. Season with ground black pepper. You may add salt, if preferred."
    },
    {
      "position": 6,
      "text": "Cover the pot and cook for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
