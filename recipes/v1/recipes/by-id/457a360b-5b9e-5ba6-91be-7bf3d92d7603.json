  "id": "457a360b-5b9e-5ba6-91be-7bf3d92d7603",
  "slug": "ginisang-monggo-with-dilis",
  "name": "Ginisang Monggo with Dilis",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginisang Monggo with Dilis.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil on a pot."
    },
    {
      "position": 2,
      "text": "Saute garlic, onion and tomato."
    },
    {
      "position": 3,
      "text": "Once the onion gets soft, add the dried dilis. Stir and cook for a minute."
    },
    {
      "position": 4,
      "text": "Add the soaked mung beans. Saute for1 to 2 mimutes."
    },
    {
      "position": 5,
      "text": "Pour-in water. Let boil. Cook in low heat until the mung beans gets soft and mushy. Note: you can add more water if needed."
    },
    {
      "position": 6,
      "text": "Sprinkle some ground black pepper and then add fish sauce. Stir."
    },
    {
      "position": 7,
      "text": "Add the spinach. Cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 5,
