  "id": "01232ecd-b148-5df0-8344-4cc87fb41be8",
  "slug": "filipino-vegetable-food-eggplant-omelet-tortang-talong-recipe",
  "name": "Tortang Talong Recipe",
  "recipe_type": "main",
  "brief_description": "Tortang Talong is a classic Filipino eggplant omelet made by dipping grilled and flattened eggplant in beaten eggs before frying until golden and crispy. Traditionally served with steamed rice and banana ketchup, this simple yet satisfying dish is perfect for breakfast, lunch, or dinner.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Grill the eggplants over an open flame or on a grill until the skins are charred black and the flesh is soft, about 5-7 minutes per side."
    },
    {
      "position": 2,
      "text": "Let the eggplants cool until safe to handle, then carefully peel off the charred skin while keeping the stems intact. Set aside on a plate."
    },
    {
      "position": 3,
      "text": "Crack the eggs into a shallow bowl."
    },
    {
      "position": 4,
      "text": "Season with salt and beat until the yolks and whites are well combined and slightly frothy."
    },
    {
      "position": 5,
      "text": "Place the peeled eggplant on a flat surface. Gently flatten the flesh with the back of a fork to create a fan-like shape, keeping the stem attached."
    },
    {
      "position": 6,
      "text": "Dip the flattened eggplant into the beaten egg mixture, ensuring both sides are well-coated."
    },
    {
      "position": 7,
      "text": "Heat a frying pan over medium heat and pour in the cooking oil."
    },
    {
      "position": 8,
      "text": "Carefully place the coated eggplant into the pan. Fry for 3 to 4 minutes per side until golden brown and crispy. Make sure both sides are cooked through. Serve hot with steamed rice and ketchup."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
