  "slug": "filipino-vegetable-food-eggplant-omelet-tortang-talong-recipe",
  "name": "Tortang Talong Recipe",
  "recipe_type": "salad",
  "brief_description": "Tortang Talong or Eggplant Omelet is a simple yet satisfying recipe. It is eaten with steamed rice and ketchup.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Grill the eggplant until the color of skin turns almost black"
    },
    {
      "position": 2,
      "text": "Let the eggplant cool for a while then peel off the skin. Set aside."
    },
    {
      "position": 3,
      "text": "Crack the eggs and place in a bowl"
    },
    {
      "position": 4,
      "text": "Add salt and beat"
    },
    {
      "position": 5,
      "text": "Place the eggplant on a flat surface and flatten using a fork."
    },
    {
      "position": 6,
      "text": "Dip the flattened eggplant in the beaten egg mixture"
    },
    {
      "position": 7,
      "text": "Heat the pan and pour the cooking oil"
    },
    {
      "position": 8,
      "text": "Fry the eggplant (that was dipped in the beaten mixture). Makes sure that both sides are cooked. Frying time will take you about 3 to 4 minutes per side on medium heat."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
