  "id": "83038db5-b71d-576d-91b8-6743787843e0",
  "slug": "fried-galunggong-with-salted-egg-and-tomato-salad",
  "name": "Fried Galunggong with Salted Egg and Tomato Salad",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for Fried Galunggong with Salted Egg and Tomato Salad",
  "cuisine": "Filipink",
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the fish including the cavity. Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, prepare the salted egg and tomato salad by combining all of its ingredients in a bowl, including the fish sauce. Gently toss. Set aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a frying pan."
    },
    {
      "position": 4,
      "text": "Once the oil gets hot, put the fish one after the other. Be extra careful during this step as the oil will splatter. Fry until one side of the fish gets brown and crispy. You will know that the fish is ready when the crackling sound from the pan mellows down. Note:If you have a splatter screen, this is the best time to use it."
    },
    {
      "position": 5,
      "text": "Turn the fish over and do the same step to the opposite side. Remove the fish from the pan. Let the oil drip."
    },
    {
      "position": 6,
      "text": "Arrange in a serving plate with salted egg and tomato salad."
    },
    {
      "position": 7,
      "text": "Serve with spicy vinegar."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
