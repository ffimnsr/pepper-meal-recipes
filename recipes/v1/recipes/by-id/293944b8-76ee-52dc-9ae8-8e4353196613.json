  "id": "293944b8-76ee-52dc-9ae8-8e4353196613",
  "slug": "kilawin-kinilaw-na-dulong-recipe",
  "name": "Kinilaw na Dulong",
  "recipe_type": null,
  "brief_description": "Kinilaw na dulong is a fish dish that makes use of silverfish which are locally known as \u201cDulong\u201d. This is a type of Ceviche wherein fishes or seafood are soaked in a citrus marinade.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine silverfish, salt, and ground black pepper then gently mix until everything is well incorporated."
    },
    {
      "position": 2,
      "text": "Add minced ginger and minced bird\u2019s eye chili then continue mixing until everything is distributed."
    },
    {
      "position": 3,
      "text": "Squeeze-in lemon (or calamansi) and gently stir the mixture to distribute the juice."
    },
    {
      "position": 4,
      "text": "Refrigerate for at least 30 minutes. At this stage, the citric acid in lemon or calamansi will gently cook the fish."
    },
    {
      "position": 5,
      "text": "Transfer to a serving bowl and serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
