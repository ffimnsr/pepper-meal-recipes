  "id": "16e132da-922f-5b16-8e38-e2daee2078c6",
  "slug": "basic-teriyaki-sauce-recipe",
  "name": "Basic Teriyaki Sauce",
  "recipe_type": null,
  "brief_description": "You can use this basic Teriyaki sauce to make delicious Teriyaki dishes and sauces. This recipe is so quick to prepare. You can make one in 10 minutes.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a saucepan."
    },
    {
      "position": 2,
      "text": "Pour-in the soy sauce, water, and rice wine. Stir."
    },
    {
      "position": 3,
      "text": "Gradually add the white and brown sugars. Stir."
    },
    {
      "position": 4,
      "text": "Add the garlic and ginger. Stir and then cook until the liquid starts boiling."
    },
    {
      "position": 5,
      "text": "Turn the heat off. Stir to dissolve the sugar."
    },
    {
      "position": 6,
      "text": "Let the mixture pass through a strainer to trap the garlic and ginger."
    },
    {
      "position": 7,
      "text": "Let cool. Serve as a sauce or use as an ingredient to cook your favorite teriyaki dish."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 5,
