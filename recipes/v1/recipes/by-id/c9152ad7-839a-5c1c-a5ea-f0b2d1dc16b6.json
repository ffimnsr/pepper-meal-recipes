  "id": "c9152ad7-839a-5c1c-a5ea-f0b2d1dc16b6",
  "slug": "easy-macaroni-salad",
  "name": "Easy Macaroni Salad",
  "recipe_type": "salad",
  "brief_description": "Easy Macaroni Salad is a quick and simple macaroni salad recipe that makes use of elbow macaroni, mayonnaise, sour cream, and some veggies and spices",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the cooked macaroni, mayonnaise, and sour cream. Mix well."
    },
    {
      "position": 2,
      "text": "Add the onion, sweet relish, celery and parsley. Fold to mix the ingredients."
    },
    {
      "position": 3,
      "text": "Put-in the mustard powder, ground black pepper, sugar, and salt. Continue to fold until all the ingredients are well incorporated."
    },
    {
      "position": 4,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 10,
