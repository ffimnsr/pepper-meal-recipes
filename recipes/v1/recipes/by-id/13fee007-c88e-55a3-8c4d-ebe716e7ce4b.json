  "id": "13fee007-c88e-55a3-8c4d-ebe716e7ce4b",
  "slug": "ensaladang-filipino-recipe",
  "name": "Ensaladang Filipino",
  "recipe_type": "salad",
  "brief_description": "Ensaladang Filipino is a type of salad composed of eggplant, onion, and tomato. It has a simple vinaigrette dressing and is sometimes served with shrimp paste. Ensaladang Filipino is also known as ensaladang talong.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat-up the grill. Grill the eggplant, onion, and tomato. The onion and tomato should only be grilled for 3 minutes per side, while the eggplant should be grilled longer until the inner part is fully cooked and soft. This should take around 10 to 12 minutes per side or more."
    },
    {
      "position": 2,
      "text": "Once the eggplant, tomato, and onion are done, peel the skin from the eggplant and slice. Slice the tomato and onion, as well. Arrange in a serving plate."
    },
    {
      "position": 3,
      "text": "Combine vinegar, sugar, salt, and ground black pepper in a bowl. Stir. Make sure that the salt and sugar dissolves completely. Pour over the tomato, eggplant, and onion."
    },
    {
      "position": 4,
      "text": "Serve with shrimp paste on the side."
    },
    {
      "position": 5,
      "text": "Share and enjoy"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
