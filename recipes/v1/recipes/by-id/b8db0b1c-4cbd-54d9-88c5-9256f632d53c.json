  "id": "b8db0b1c-4cbd-54d9-88c5-9256f632d53c",
  "slug": "crispy-tenga-recipe-crispy-pig-ears",
  "name": "Crispy Tenga Recipe (Crispy Pig Ears)",
  "recipe_type": "appetizer",
  "brief_description": "This is a recipe for crispy tenga or cripsy pork ears.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine 5 cups water and pig ears in a pot. Let boil. Cover and boil in medium heat for 20 minutes. Discard the water."
    },
    {
      "position": 2,
      "text": "Pour a new batch of water to the pot where the ears are. Add garlic, bay leaves, whole peppercorn, and 1 teaspoon salt. Stir and let boil."
    },
    {
      "position": 3,
      "text": "Pour the soy sauce and vinegar on the pot. Let the liquid boil again. Cover and continue to boil in medium heat for 60 minutes or until tender."
    },
    {
      "position": 4,
      "text": "Remove the ear from the pot. Let it cool down and then slice into small pieces."
    },
    {
      "position": 5,
      "text": "Rub remaining 1 teaspoon salt all over the ears."
    },
    {
      "position": 6,
      "text": "Heat the oil in a deep fryer or deep cooking pot. Once the oil gets hot enough, deep-fry the pig ears until the texture becomes crispy."
    },
    {
      "position": 7,
      "text": "Remove from the deep fryer and let the excess oil drip."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with spicy vinegar."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
