  "id": "a9ecda8a-388d-590b-bfac-53d998d173d5",
  "slug": "how-to-cook-minestrone",
  "name": "Minestrone Soup",
  "recipe_type": "appetizer",
  "brief_description": "A thick and filling Italian vegetable soup made with kidney beans, shell pasta, and fresh spinach in a tomato broth with a splash of red wine. This minestrone is ready in about 30 minutes and works well as a weeknight dinner or a make-ahead meal.",
  "cuisine": "Italian Mediterranean",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a large cooking pot over medium heat and pour in the olive oil."
    },
    {
      "position": 2,
      "text": "Add the garlic, onion, celery, and zucchini. Saut\u00e9 for about 3 to 4 minutes, or until the vegetables soften and release their aroma."
    },
    {
      "position": 3,
      "text": "Pour in the vegetable broth and diced tomatoes. Let the mixture come to a boil."
    },
    {
      "position": 4,
      "text": "Add the red wine, salt, and ground black pepper. Stir and allow the soup to simmer briefly."
    },
    {
      "position": 5,
      "text": "Put in the kidney beans, green beans, carrots, parsley, oregano, basil, and thyme. Lower the heat and let the soup simmer for 15 minutes so the flavors blend well."
    },
    {
      "position": 6,
      "text": "Add the cooked small shell pasta and fresh spinach. Continue simmering for 5 to 7 minutes, just until the spinach wilts."
    },
    {
      "position": 7,
      "text": "Turn off the heat and transfer the soup to a serving bowl. Serve warm with bread sticks."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
