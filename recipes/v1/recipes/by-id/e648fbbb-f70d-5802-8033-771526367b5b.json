  "id": "e648fbbb-f70d-5802-8033-771526367b5b",
  "slug": "creamy-pininyahang-manok",
  "name": "Creamy Pininyahang Manok",
  "recipe_type": "main",
  "brief_description": "Creamy Pininyahang Manok is tender chicken cooked with pineapple and vegetables in a rich, creamy sauce. This comforting Filipino dish is best served with rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Fry the potatoes and carrots until they start to brown. Remove and set aside."
    },
    {
      "position": 2,
      "text": "Reduce the oil to 3 tablespoons. Saut\u00e9 garlic, onion, and tomato until softened."
    },
    {
      "position": 3,
      "text": "Add the chicken. Cook until it turns light brown."
    },
    {
      "position": 4,
      "text": "Pour in the pineapple juice from the canned pineapple along with the pineapple chunks. Cover and simmer for 30 minutes. Add water if needed."
    },
    {
      "position": 5,
      "text": "Add the bell peppers, fried potatoes, and carrots. Simmer for 3 minutes."
    },
    {
      "position": 6,
      "text": "Season with fish sauce and ground black pepper. Pour in the Carnation Everyday Creamer. Stir and simmer for 2 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
