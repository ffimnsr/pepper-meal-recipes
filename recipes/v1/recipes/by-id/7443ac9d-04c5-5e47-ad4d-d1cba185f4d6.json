  "id": "7443ac9d-04c5-5e47-ad4d-d1cba185f4d6",
  "slug": "ginataang-mackerel-spinach",
  "name": "Ginataang Mackerel",
  "recipe_type": "main",
  "brief_description": "Canned Mackerel fish cooked in coconut milk with spinach. This simple dish is tasty. It is also quick and easy to make.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute onion, garlic, and ginger until garlic browns and onion softens."
    },
    {
      "position": 3,
      "text": "Pour coconut milk into the cooking pot. Add chili pepper.Stir. Cover the pot and cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Add mackerel. Pour water and vinegar into the pot. Let boil. Stir and cover the pot. Cook for 5 to 7 minutes."
    },
    {
      "position": 5,
      "text": "Season with fish sauce and ground black pepper."
    },
    {
      "position": 6,
      "text": "Add spinach. Cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 3,
