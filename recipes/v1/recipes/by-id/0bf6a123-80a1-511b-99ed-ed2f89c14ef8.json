  "id": "0bf6a123-80a1-511b-99ed-ed2f89c14ef8",
  "slug": "sweet-and-sour-tofu-recipe",
  "name": "Sweet and Sour Tofu",
  "recipe_type": "main",
  "brief_description": "This is a recipe for tokwa with sweet and sour sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a deep cooking pot."
    },
    {
      "position": 2,
      "text": "Deep fry the tofu. When the color turns light to medium brown, remove and set aside."
    },
    {
      "position": 3,
      "text": "Meanwhile, heat a pan and then pour in a tablespoon of cooking oil (use remaining oil from fried tofu)"
    },
    {
      "position": 4,
      "text": "When the oil becomes hot, put-in the garlic and cook for 20 seconds."
    },
    {
      "position": 5,
      "text": "Add the pineapple chunks, onion, green and red bell peppers. Stir and cook for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Combine sugar, soy sauce, vinegar, water, and ketchup in a bowl. Mix well."
    },
    {
      "position": 7,
      "text": "Pour-in mixture to the pan where the vegetables are cooking. Stir and let boil."
    },
    {
      "position": 8,
      "text": "Pour-in the cornstarch diluted in water. Stir until the sauce thickens."
    },
    {
      "position": 9,
      "text": "Add the deep fried tofu. Stir."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
