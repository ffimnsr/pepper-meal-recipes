  "id": "2976e5be-39eb-5d88-8399-7cff1e46246c",
  "slug": "how-to-cook-rice",
  "name": "How to Cook Rice",
  "recipe_type": "side",
  "brief_description": "How to cook rice comes down to the right water ratio for your rice type, a good rinse, and a 10 minute rest. This recipe uses long grain white rice such as jasmine, Sinandomeng, or Dinorado. Other rice types use different ratios and cook times. See the notes for the full table.",
  "cuisine": "Asian Chinese Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rice Cooker Method: Rinse the rice under cold water until the water runs clear."
    },
    {
      "position": 2,
      "text": "Place the rinsed rice in the rice cooker pot."
    },
    {
      "position": 3,
      "text": "Add 1 1/2 to 1 3/4 cups water and salt. Stir gently to combine."
    },
    {
      "position": 4,
      "text": "Close the lid and cook according to manufacturer instructions (standard white rice setting)."
    },
    {
      "position": 5,
      "text": "When cooking is complete, let the rice rest for 10 minutes before serving."
    },
    {
      "position": 6,
      "text": "Stovetop Method: Rinse the rice under cold water until the water runs clear."
    },
    {
      "position": 7,
      "text": "Combine the rinsed rice, water, and salt in a heavy-bottomed saucepan."
    },
    {
      "position": 8,
      "text": "Bring to a boil over high heat."
    },
    {
      "position": 9,
      "text": "Reduce heat to low, cover tightly, and simmer for 15 minutes without lifting the lid."
    },
    {
      "position": 10,
      "text": "Remove from heat and let rest, covered, for 10 minutes."
    },
    {
      "position": 11,
      "text": "Fluff with a fork before serving."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
