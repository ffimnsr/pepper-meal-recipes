  "id": "87a978e6-8753-5030-979c-009679056b66",
  "slug": "bok-choy-in-garlic-sauce-recipe",
  "name": "Bok Choy in Garlic Sauce",
  "recipe_type": null,
  "brief_description": "Here is another healthy vegetarian recipe dedicated to our vegan readers, Bok Choy in Garlic sauce. Before anything else, I would like to apologize for not being able to respond to your comments and emails in a timely manner.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine soy sauce, water, garlic, ginger, oyster sauce, sugar and mix well. Set aside."
    },
    {
      "position": 2,
      "text": "Heat a wok or frying pan then put-in the cooking oil."
    },
    {
      "position": 3,
      "text": "When the cooking oil is hot enough, pour-in the sesame oil."
    },
    {
      "position": 4,
      "text": "Stir fry the bok choy. Put the stalks first and stir fry for about 2 minutes then add the leaves and stir fry for 2 to 4 minutes."
    },
    {
      "position": 5,
      "text": "Turn off the heat and transfer the cooked bok choy in a serving plate."
    },
    {
      "position": 6,
      "text": "Heat the same wok or frying pan then pour-in the sauce mixture. Cook for about 2 minutes or until the sauce thickens."
    },
    {
      "position": 7,
      "text": "Turn off heat then top the sauce over the Bok Choy."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
