  "name": "Basil Pesto",
  "recipe_type": "condiment",
  "brief_description": "Basil Pesto is a fresh tasting sauce made from fresh basil leaves, pine nuts, garlic, olive oil, and cheese. This sauce is best for pasta",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the ingredients in a food processor. Cover and secure."
    },
    {
      "position": 2,
      "text": "Process the ingredients until a thick paste is formed."
    },
    {
      "position": 3,
      "text": "Transfer to a bowl."
    },
    {
      "position": 4,
      "text": "Serve as a sauce on your favorite pasta or chicken dishes."
    }
