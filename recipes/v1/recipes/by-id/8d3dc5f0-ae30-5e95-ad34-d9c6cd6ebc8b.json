  "id": "8d3dc5f0-ae30-5e95-ad34-d9c6cd6ebc8b",
  "slug": "dulong-fishcake",
  "name": "Dulong Fishcake",
  "recipe_type": "dessert",
  "brief_description": "This is a Fishcake recipe using dulong.&nbsp;",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine fish, 1/ 2 cup bread crumbs, egg, salt, pepper, mustard, garlic, mayonnaise, and lemon juice. Mix well."
    },
    {
      "position": 2,
      "text": "Scoop the mixture and shape into individual patties. Dredge in remaining 1/4 cup breadcrumbs. Set Aside."
    },
    {
      "position": 3,
      "text": "Melt butter in a pan. Pour-in olive oil."
    },
    {
      "position": 4,
      "text": "Pan-fry the fish patties in medium heat for about 5 to 6 minutes per side."
    },
    {
      "position": 5,
      "text": "Remove from the pan. Arrange in a serving plate."
    },
    {
      "position": 6,
      "text": "Serve with chips or salad and top with ranch dressing. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
