  "slug": "ginataang-gulay-with-pork-and-shrimp",
  "name": "Ginataang Gulay with Pork and Shrimp",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginataang Gulay with Pork and Shrimp.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the onion until it gets soft."
    },
    {
      "position": 3,
      "text": "Add the pork. Saut\u00e9 until light brown"
    },
    {
      "position": 4,
      "text": "Pour the water in the pot. Let boil."
    },
    {
      "position": 5,
      "text": "Stir-in the Gintaang Gulay mix. Continue to stir until it completely dissolves in water."
    },
    {
      "position": 6,
      "text": "Cover and cook in low heat for 8 to10 minutes. Note: you can add more water if needed."
    },
    {
      "position": 7,
      "text": "Add the squash. Stir. Cover and cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Put the snake beans in the pot. Stir and continue to cook for 5 to 7 minutes."
    },
    {
      "position": 9,
      "text": "Add the shrimp and ground black pepper. Cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 11,
      "text": "Serve! Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 28,
  "preparation_time_minutes": 5,
