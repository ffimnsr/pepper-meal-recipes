  "id": "6484ce70-8fc9-59d7-86ea-5ef99d741bd6",
  "slug": "bistek-silog",
  "name": "Bistek Silog",
  "recipe_type": null,
  "brief_description": "This is a recipe for a tasty Filipino Combo Meal known as Bistek Silog. It is a name that describes bistek tagalog, sinangag (garlic fried rice), at itlog (and fried egg).",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook bistek tagalog by following the recipe provided on the link above. Set aside."
    },
    {
      "position": 2,
      "text": "Prepare the garlic fried rice (also known as sinangag na kanin). Use the link in the ingredients section to be directed to the recipe for sinangag."
    },
    {
      "position": 3,
      "text": "Arrange a cup of sinangag in a plate and add a serving of bistek tagalog. Put 2 fried eggs on the side. Do this step 2 more times until a total of 3 bistek silog plates are prepared."
    },
    {
      "position": 4,
      "text": "Serve with your favorite condiment (mine is ketchup for the egg). Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
