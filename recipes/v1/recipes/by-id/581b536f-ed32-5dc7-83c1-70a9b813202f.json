  "id": "581b536f-ed32-5dc7-83c1-70a9b813202f",
  "slug": "sinigang-na-bangus-belly-sa-miso",
  "name": "Sinigang na Bangus Belly sa Miso",
  "recipe_type": "soup",
  "brief_description": "Boneless milkfish belly soup in sour broth",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Bring to a boil."
    },
    {
      "position": 2,
      "text": "Add tomato and onion. Cover and boil for 5 minutes."
    },
    {
      "position": 3,
      "text": "Stir-in Miso paste and cover the pot. Cook for another 3 to 5 minutes"
    },
    {
      "position": 4,
      "text": "Carefully add the bangus belly. Cook for 5 to 7 minutes in low to medium heat."
    },
    {
      "position": 5,
      "text": "Add the Daikon, okra, and green peppers. Cover and Cook for 5 to 8 minutes."
    },
    {
      "position": 6,
      "text": "Pour the contents of the sinigang mix package in the cooking pot. Stir. Add fish sauce."
    },
    {
      "position": 7,
      "text": "Add the mustard greens. Cover the cooking pot and continue to cook for 4 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
