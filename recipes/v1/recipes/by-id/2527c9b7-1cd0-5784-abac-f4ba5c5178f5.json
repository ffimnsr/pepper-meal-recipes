  "id": "2527c9b7-1cd0-5784-abac-f4ba5c5178f5",
  "slug": "crispy-pata-dinakdakan",
  "name": "Crispy Pata Dinakdakan",
  "recipe_type": "appetizer",
  "brief_description": "Chopped crispy pork hock tossed in onion and pepper with a creamy tangy glaze",
  "cuisine": "Filipino Ilocano",
  "instructions": [
    {
      "position": 1,
      "text": "Tenderize the pork hock by combining all the pork hock boiling ingredients in a cooking pot. Cover and boil between low to medium heat setting for 80 minutes. Drain the liquid and let the pork cool down to room temperature. Debone the pork hock using a sharp knife. Set aside (note: You may discard the bones.)."
    },
    {
      "position": 2,
      "text": "Rub 2 teaspoons of salt all over the skin of the pork."
    },
    {
      "position": 3,
      "text": "Prepare the dressing by combining all the dressing ingredients in a bowl. Stir until smooth."
    },
    {
      "position": 4,
      "text": "Rub 1 teaspoon salt all over the liver. Heat the cooking oil in a pan. Fry both sides of the liver until it browns. Remove from the pan and slice into serving pieces. Set aside."
    },
    {
      "position": 5,
      "text": "Heat oil in a deep cooking pot. Fry the pata until golden brown and crispy. Remove from the pot and let it cool down."
    },
    {
      "position": 6,
      "text": "Chop the crispy pata into bite-size pieces. Put it in a large mixing bowl, add the fried liver, and add the dressing, onion, green onion, and chili peppers. Toss until well blended."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
