  "id": "e8b8c145-0d1c-529e-879f-7ba3f13535f1",
  "slug": "kusido-recipe",
  "name": "Kusido Recipe",
  "recipe_type": "soup",
  "brief_description": "Light Filipino fish soup made with fresh fish, tomatoes, ginger, and leafy greens",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water in a cooking pot. Let it boil."
    },
    {
      "position": 2,
      "text": "Add tomatoes, onion, ginger, and long green peppers. Simmer for 3 mimutes."
    },
    {
      "position": 3,
      "text": "Add the tilapia. Continue to simmer for 7 to 10 minutes."
    },
    {
      "position": 4,
      "text": "Pour the calamansi juice. Stir."
    },
    {
      "position": 5,
      "text": "Season with salt."
    },
    {
      "position": 6,
      "text": "Add the sweet potato leaves. Continue cooking for 1 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
