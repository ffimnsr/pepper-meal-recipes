  "id": "85ad5988-bf4b-5d48-b11d-cb9ced8ac3a3",
  "slug": "spicy-asian-food-chili-crab-dish-recipe",
  "name": "Chili Crab",
  "recipe_type": "dessert",
  "brief_description": "This Chili Crab Recipe depicts one of the best ways to cook crab. It is sweet, spicy, tasty, and delicous!",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour the cooking oil"
    },
    {
      "position": 2,
      "text": "Saute the garlic, ginger, and crushed red pepper"
    },
    {
      "position": 3,
      "text": "Add the crab and cook for 3 to 4 minutes"
    },
    {
      "position": 4,
      "text": "Put-in the hoisin sauce, tomato ketchup, sweet chili sauce, fish sauce,and sesame oil then mix with the other ingredients"
    },
    {
      "position": 5,
      "text": "Pour-in the water and bring to a boil then simmer for 10 to 15 minutes or until the sauce gets thick"
    },
    {
      "position": 6,
      "text": "Garnish with green onions on top"
    },
    {
      "position": 7,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
