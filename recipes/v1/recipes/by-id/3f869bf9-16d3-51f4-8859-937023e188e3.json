  "id": "3f869bf9-16d3-51f4-8859-937023e188e3",
  "slug": "adobong-sitaw-with-tofu",
  "name": "Adobong Sitaw with Tofu",
  "recipe_type": null,
  "brief_description": "Adobong Sitaw with Tofu is another version of Adobong Sitaw, this time it is cooked with fried extra firm tofu. Adobong Sitaw is a Filipino vegetable dish",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Slice the fried tofu into squares. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 3,
      "text": "Saute garlic and onion until the onion is soft."
    },
    {
      "position": 4,
      "text": "Put-in the sliced tofu. Add soy sauce and water. Let boil."
    },
    {
      "position": 5,
      "text": "Pour-in the vinegar. Let it reboil."
    },
    {
      "position": 6,
      "text": "Add the string beans. Stir and cover. Simmer for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
