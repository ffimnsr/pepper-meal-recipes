  "id": "6223339c-7e8e-5a28-983e-d7026cc92160",
  "slug": "shrimp-and-chicken-pancit-canton",
  "name": "Shrimp and Chicken Pancit Canton",
  "recipe_type": null,
  "brief_description": "This is a recipe for Shrimp and Chicken Pancit Canton",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, pan-fry the shrimp for 40 seconds per side. Remove from the pot. Set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil (you can add more oil if needed), saut\u00e9 garlic and onion."
    },
    {
      "position": 4,
      "text": "Add the Chinese sausage and shredded chicken. Saute for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour the soy sauce into the pot along with the beef broth. Stir. Let boil. Cover and continue to cook in medium heat for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add parsley, snow peas, carrot, and cabbage. Cover and cook for 8 minutes."
    },
    {
      "position": 7,
      "text": "Put the ground black pepper into the pot. Stir."
    },
    {
      "position": 8,
      "text": "Add the pancit canton (flour noodles). Cover and cook until the noodles starts to get softer. Note: there is no need to stir the noodles after adding. Covering the pot traps the steam, which the noodles absorb. This makes it softer, eventually."
    },
    {
      "position": 9,
      "text": "Gently toss noodles. Add pan-fried shrimp. Cover the pot and continue to cook in medium heat for 3 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve with lime or calamansi."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 15,
