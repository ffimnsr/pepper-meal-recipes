{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "fb2a5cb6-f2a5-5be4-8638-628bf69f2e12",
  "slug": "eggplant-and-sardine-omelet-tortang-talong-with-sardinas",
  "name": "Eggplant and Sardine Omelet",
  "recipe_type": "main",
  "brief_description": "Filipino Eggplant omelet topped with saut\u00e9ed sardines. This budget-friendly recipe goes best with rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the sardine topping by heating oil in a pan. Saut\u00e9 garlic, onion, and tomato until the last 2 ingredients softens. Add the canned sardines and a quarter of the sauce from the can. Cook for 2 minutes. Season with salt and ground black pepper. Squeeze a piece of calamansi or a quarter lemon and add some chopped green onions. Stir. Remove from the pan. Set aside."
    },
    {
      "position": 2,
      "text": "Crack the eggs into bowl. Whisk until smooth and well-blended. Set aside."
    },
    {
      "position": 3,
      "text": "Prepare the eggplant by grilling until it softens. Make sure to flip it once in a while until steam comes out from the cracks of the skin. Remove from the grill. Let It cool down. Peel the skin off."
    },
    {
      "position": 4,
      "text": "Lay a piece of eggplant on a plate. Using a fork, flatten the eggplant by sliding the fork downwards."
    },
    {
      "position": 5,
      "text": "Heat remaining oil in a clean pan."
    },
    {
      "position": 6,
      "text": "While the oil is heating-up, dip a piece of eggplant into the whisked/beaten eggs. Lay it flat on the pan. Scoop a portion of the saut\u00e9ed sardines and place over the eggplant. Top with chopped green onions. Pour some beaten egg over the toppings. Continue cooking until the bottom turns golden brown."
    },
    {
      "position": 7,
      "text": "Gently flip the eggplant. Continue cooking until the bottom part is completely cooked. Remove from the pan and arrange on a serving plate. Make sure that the part with sardines is facing upwards."
    },
    {
      "position": 8,
      "text": "Serve with rice or your favorite side dish. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
