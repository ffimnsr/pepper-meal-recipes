  "id": "4d0737f0-9d72-5f0a-a7d3-8a4cc951dfd8",
  "slug": "kakaibang-tokwat-baboy",
  "name": "Kakaibang Tokwat Baboy",
  "recipe_type": "appetizer",
  "brief_description": "Grilled pork belly and air fried tofu in spicy vinegar sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Steam the pork belly for 45 minutes. Let it cool down."
    },
    {
      "position": 2,
      "text": "Combine calamansi juice and soy sauce. Stir."
    },
    {
      "position": 3,
      "text": "Place the pork belly in a resealable bag and then pour the soy sauce mixture. Marinate for 1 hour."
    },
    {
      "position": 4,
      "text": "Slice the tofu into smaller pieces. Rub oil all over each piece. Air fry for 17 minutes at 400F. Let it cool down and then slice into cubes."
    },
    {
      "position": 5,
      "text": "Grill the pork belly until fully cooked. Let it cool down and then slice into serving pieces."
    },
    {
      "position": 6,
      "text": "Make the sauce by combining all the sauce ingredients in a large bowl. Mix well."
    },
    {
      "position": 7,
      "text": "Add fried tofu and grilled pork belly. Toss until well blended."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve as an appetizer or main dish. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
