  "id": "899d59fc-fc7a-503a-8858-8d4eca83b4f7",
  "slug": "friday-chicken-noodle-soup",
  "name": "Chicken Noodle Soup",
  "recipe_type": "soup",
  "brief_description": "Chicken noodle soup with tender shredded chicken, saut\u00e9ed vegetables, and wide egg noodles in a savory broth seasoned with thyme and bay leaf.",
  "cuisine": "American Comfort Food traditional",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the chicken breasts and chicken broth in a large pot. Bring to a boil, then lower the heat and simmer for about 20 minutes or until the chicken is fully cooked. Remove the chicken and shred it using two forks. Set the chicken aside and keep the broth in the pot."
    },
    {
      "position": 2,
      "text": "Melt the butter in a separate pan over medium heat, then add the olive oil. Saut\u00e9 the onion for 1 minute, then add the celery and cook for 2 minutes. Add the garlic and cook for 30 seconds, followed by the carrot. Continue cooking for 2 more minutes. Transfer the saut\u00e9ed vegetables to the boiling broth."
    },
    {
      "position": 3,
      "text": "Add the dried thyme and bay leaf. Continue to simmer for about 10 minutes until the vegetables are tender and the flavors blend well."
    },
    {
      "position": 4,
      "text": "Add the egg noodles and cook until tender, about 8 minutes. Stir occasionally to prevent sticking. Return the shredded chicken to the pot and remove the bay leaf."
    },
    {
      "position": 5,
      "text": "Season with salt and ground black pepper. Toss to combine."
    },
    {
      "position": 6,
      "text": "Stir in the chopped parsley. Transfer to a serving bowl. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
