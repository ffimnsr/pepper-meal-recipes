  "id": "fa4cd3f7-e0e0-5dfa-9c53-2c15073801c1",
  "slug": "binagoongang-talong-with-lechon-kawali",
  "name": "Binagoongan Bagnet with Talong",
  "recipe_type": "main",
  "brief_description": "Crispy pork belly and eggplant cooked in shrimp sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic, onion, and tomato."
    },
    {
      "position": 3,
      "text": "Once tomato and onion softens, add the bagoong (shrimp paste). Stir."
    },
    {
      "position": 4,
      "text": "Pour-in water and vinegar. Let boil."
    },
    {
      "position": 5,
      "text": "Add the sliced eggplants, chili pepper, and half of the bagnet. Cover and cook in low to medium heat until the sauce reduces to half."
    },
    {
      "position": 6,
      "text": "Season with ground black pepper and sugar."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Add remaining bagnet."
    },
    {
      "position": 8,
      "text": "Serve warm with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
