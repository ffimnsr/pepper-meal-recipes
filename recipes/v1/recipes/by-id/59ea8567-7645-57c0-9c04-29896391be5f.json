  "schema_version": 1,
  "id": "59ea8567-7645-57c0-9c04-29896391be5f",
  "slug": "rosemary-garlic-pork-tenderloin",
  "name": "Pork Tenderloin with Rosemary and Garlic",
  "recipe_type": "main",
  "brief_description": "This roasted pork tenderloin is brined for juiciness, then rubbed with fresh rosemary, garlic, and olive oil before searing and baking. The result is tender, flavorful meat with a golden crust. Serve with mashed potatoes, roasted vegetables, or steamed rice.",
  "cuisine": "American Filipino Italian Mediterranean",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the salt, brown sugar, and 1 cup of water in a bowl. Microwave for 3 minutes, then stir until fully dissolved. Let it cool."
    },
    {
      "position": 2,
      "text": "Pour the remaining 3 cups of water into a large bowl or container. Add the cooled salt and sugar mixture along with the ice cubes. Stir gently."
    },
    {
      "position": 3,
      "text": "Add the pork tenderloin to the brine. Let it brine for 90 minutes. Remove it from the brine afterward and set aside. There is no need to rinse it."
    },
    {
      "position": 4,
      "text": "Place all the rub ingredients in a food processor. Process until the mixture becomes fine. You can also use a mortar and pestle."
    },
    {
      "position": 5,
      "text": "Rub the mixture all over the pork tenderloin. Let it sit for at least 1 hour. Overnight is even better."
    },
    {
      "position": 6,
      "text": "Preheat the oven to 400\u00b0F."
    },
    {
      "position": 7,
      "text": "Heat a pan and sear the pork tenderloin until all sides turn medium brown."
    },
    {
      "position": 8,
      "text": "Bake for 20 to 25 minutes or until the internal temperature reaches at least 145\u00b0F."
    },
    {
      "position": 9,
      "text": "Let the meat rest for 10 minutes, then slice."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 15,
  "rest_time_minutes": 120,
  "difficulty": "hard",
