  "slug": "nilagang-baka-with-kalabasa-filipino-boiled-beef-soup",
  "name": "Nilagang Baka with Kalabasa \u2013 Filipino boiled beef Soup",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Nilagang Baka with Kalabasa \u2013 Filipino boiled beef Soup",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water and beef broth into a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add beef slices, onion, and whole peppercorn. Cover the pot and continue to boil between low to medium heat for 1 \u00bd to 2 hours, or until the beef becomes tender. Note: add more water if needed."
    },
    {
      "position": 3,
      "text": "Add butternut squash or kalabasa. Cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Add long greens beans. Cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add bok choy and season with fish sauce. Continue to cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve with rice."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 10,
