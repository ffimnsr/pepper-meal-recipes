  "id": "5f5777bc-08b9-52e1-ab04-1da0a0bd7551",
  "slug": "malapot-na-pininyahang-manok",
  "name": "Malapot na Pininyahang Manok",
  "recipe_type": "main",
  "brief_description": "Pineapple chicken stew with thick sauce.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Pan-fry the chicken pieces until the sides turns light brown in color. Remove from the chicken and set aside."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 onion and garlic using the remaining oil."
    },
    {
      "position": 3,
      "text": "Add the chicken back in once the onion softens."
    },
    {
      "position": 4,
      "text": "Pour soy sauce and stir while deglazing the chicken residue stuck on the pan."
    },
    {
      "position": 5,
      "text": "Add pineapple chunks and water. Let boil."
    },
    {
      "position": 6,
      "text": "Put-in the Knorr Chicken Cube. Cover the pan. Adjust the heat between low to medium settings. Cook the chicken for 25 minutes."
    },
    {
      "position": 7,
      "text": "Add liver spread and carrot. Cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Add bell peppers. Season with salt and ground black pepper."
    },
    {
      "position": 9,
      "text": "Combine cornstarch with 3 tablespoons of water. Mix well and then pour into the pan. Stir until the sauce reaches your desired thickness."
    },
    {
      "position": 10,
      "text": "Add sugar. Cook for a minute."
    },
    {
      "position": 11,
      "text": "Transfer to a serving plate. Serve warm with rice."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
