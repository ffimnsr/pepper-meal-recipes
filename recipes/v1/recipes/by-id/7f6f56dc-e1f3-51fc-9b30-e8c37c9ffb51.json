  "id": "7f6f56dc-e1f3-51fc-9b30-e8c37c9ffb51",
  "slug": "chocolate-graham-cupcake-recipe",
  "name": "Chocolate Graham Cupcake",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Chocolate Graham Cupcake",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine 1 1/8 cup sugar, flour, cocoa powder, baking powder, salt, and baking soda in a mixing bowl. Mix well using a balloon whisk. Set aside."
    },
    {
      "position": 2,
      "text": "In another bowl, combine eggs, milk, vegetable oil, and vanilla extract then mix using a stand or hand mixer."
    },
    {
      "position": 3,
      "text": "Gradually add the flour mixture while mixing. Continue mixing for about a minute."
    },
    {
      "position": 4,
      "text": "Pour-in hot water then mix until everything is well incorporated. Set aside."
    },
    {
      "position": 5,
      "text": "Preheat oven to 350 degrees Fahrenheit."
    },
    {
      "position": 6,
      "text": "Line the cupcake pan with muffin cups then pour-in the batter."
    },
    {
      "position": 7,
      "text": "Bake for 18 to 22 minutes."
    },
    {
      "position": 8,
      "text": "Remove from the oven and place in a wire rack to cool."
    },
    {
      "position": 9,
      "text": "Sprinkle graham crackers on the cupcakes."
    },
    {
      "position": 10,
      "text": "Make the frosting. Pour water in saucepan then turn-on heat. Allow the water to reach the point where it is near boiling.Place a glass or metal bowl over the saucepan then combine sugar, cream of tartar, and egg whites. Whisk continuously for 4 to 5 minutes. Turn off heat.Remove the bowl from the saucepan then whisk the mixture using an electric or stand mixer until stiff peaks form (about 6 minutes in high speed).Add vanilla extract then mix for 30 seconds."
    },
    {
      "position": 11,
      "text": "Place the frosting in a piping bag then pipe over the cupcake."
    },
    {
      "position": 12,
      "text": "Transfer to a cupcake rack or serving plate then serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
