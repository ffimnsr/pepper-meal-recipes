{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "00e21886-27b8-5ef8-9a9a-1133c8958c62",
  "slug": "lechon-belly-roll",
  "name": "Lechon Belly Roll",
  "recipe_type": "main",
  "brief_description": "Roasted pork belly lechon Cebu style.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Rub 5 tablespoons Knorr SavorRich on the meat part of the pork. Spread evenly. Turn the pork over and rub the remaining SavorRich and soy sauce on the skin of the pork. Let it marinate for 30 minutes."
    },
    {
      "position": 2,
      "text": "Preheat oven to 350\u00b0F."
    },
    {
      "position": 3,
      "text": "Chop the scallions, onion, and garlic. Crush the lemongrass and slice into pieces. Place all the garlic and onion over the belly. Add scallions and lemongrass. Roll the belly and secure by tying kitchen twine."
    },
    {
      "position": 4,
      "text": "Rub oil all over the belly roll. Pour 4 cups of water in a roasting pan and put remaining scallions and lemongrass. Arrange a roasting rack over the pan and place the rolled belly on the rack. Roast for 1 hour."
    },
    {
      "position": 5,
      "text": "Prepare the basting sauce by combining 2 tablespoons soy sauce and \u00bc cup oil. Mix well. Brush all over the pork."
    },
    {
      "position": 6,
      "text": "Increase the oven temperature to 360\u00b0F. Continue to roast for another hour. Note: add more water to the pan if needed."
    },
    {
      "position": 7,
      "text": "Increase the oven temperature to 370\u00b0F. Brush with basting sauce. Roast for 1 hour more."
    },
    {
      "position": 8,
      "text": "Increase heat to 400\u00b0F. Continue to roast until the skin gets very crispy. Remove from the oven and let the pork belly cool down."
    },
    {
      "position": 9,
      "text": "Make the dipping sauce by combining all the sauce ingredients (vinegar, soy sauce, red onion, garlic, sugar, peppercorn, and Thai chili). Microwave for 30 seconds."
    },
    {
      "position": 10,
      "text": "Remove the twine from the belly roll and chop into serving pieces. Serve with spicy vinegar dip."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 225,
  "preparation_time_minutes": 30,
