  "id": "382c51a3-7ca3-5e47-b041-ab166bf03b3a",
  "slug": "deep-fried-siomai-wonton-recipe",
  "name": "Deep Fried Siomai",
  "recipe_type": null,
  "brief_description": "This is a recipe for Deep Fried Siomai.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine all the ingredients except for the wanton wrapper and oil."
    },
    {
      "position": 2,
      "text": "Mix the ingredients thoroughly. Use a stand mixer, if possible."
    },
    {
      "position": 3,
      "text": "Wrap the mixture in wonton wrapper (see video for procedure). Set aside."
    },
    {
      "position": 4,
      "text": "Heat a cooking pot and pour-in cooking oil."
    },
    {
      "position": 5,
      "text": "Deep fry the wrapped wontons in medium heat for 5 to 7 minutes or until the color of the wrapper turns golden brown."
    },
    {
      "position": 6,
      "text": "Remove from the cooking pot and transfer to a plate lined with paper towels."
    },
    {
      "position": 7,
      "text": "Serve with chili, Asian Dipping Sauce, and rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
