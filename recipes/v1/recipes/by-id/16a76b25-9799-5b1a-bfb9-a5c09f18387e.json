  "id": "16a76b25-9799-5b1a-bfb9-a5c09f18387e",
  "slug": "crispy-spam-steak-recipe",
  "name": "Crispy Spam Steak Recipe",
  "recipe_type": "breakfast",
  "brief_description": "I eat my crispy spam steak with Filipino pandesal, and there are times when I eat it with sinangag with banana ketchup and fried egg.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Remove the Spam luncheon meat from the can and slice into serving pieces."
    },
    {
      "position": 2,
      "text": "Meanwhile, heat the cooking oil in a deep frying pan."
    },
    {
      "position": 3,
      "text": "Combine the garlic powder and egg. Beat until both ingredients are well incorporated. Set aside."
    },
    {
      "position": 4,
      "text": "Combine flour and cornstarch. Mix well and set aside."
    },
    {
      "position": 5,
      "text": "Dip each sliced Spam in the beaten egg then dredge in flour. Do this step twice to make the coat thicker."
    },
    {
      "position": 6,
      "text": "Fry the Spam coated with flour and cornstarch 3 to 4 slices at a time. The number of slices to cook at a given time will depend on the size of your pan: the wider the pan, the more slices you can cook at the same time. Cook one side in medium heat until the color turns medium brown and the texture becomes crispy. Turn the Spam slice over to cook the other side."
    },
    {
      "position": 7,
      "text": "Remove the Crispy fried Spam steaks from then pan. Place in a plate lined with paper towel."
    },
    {
      "position": 8,
      "text": "Serve with ketchup. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
