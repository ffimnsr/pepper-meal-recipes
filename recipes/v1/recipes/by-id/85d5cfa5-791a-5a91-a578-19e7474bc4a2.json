  "id": "85d5cfa5-791a-5a91-a578-19e7474bc4a2",
  "slug": "pork-pata-humba-ham-hock-filipino-recipe",
  "name": "Pork Pata Humba Recipe",
  "recipe_type": "drink",
  "brief_description": "This is a recipe for Pork Pata Humba or Braised ham hock in soy sauce and pineapple juice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add the ham hock (pata). Scoop out the scums that will eventually float. Cover and boil in medium heat for 40 to 60 minutes. You can add more water if needed."
    },
    {
      "position": 3,
      "text": "Remove the pata from the cooking pot and set it aside. Discard the water."
    },
    {
      "position": 4,
      "text": "Pour oil into a clean cooking pot."
    },
    {
      "position": 5,
      "text": "Once the oil gets hot, saute garlic and onion."
    },
    {
      "position": 6,
      "text": "Add the boiled pata. Stir and cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Pour the soy sauce and pineapple juice into the pot. Let boil."
    },
    {
      "position": 8,
      "text": "Add the pork cube. Stir."
    },
    {
      "position": 9,
      "text": "Add the dried bay leaves, cracked peppercorns, dried banana blossoms, and salted black beans (tausi). Stir. Cover and continue to cook between low to medium heat until the liquid reduces to half."
    },
    {
      "position": 10,
      "text": "Add the vinegar. Stir and then add the dark brown sugar. Continue to cook for 5 minutes."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl or plate. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
