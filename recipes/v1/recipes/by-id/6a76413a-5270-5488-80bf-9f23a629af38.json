  "id": "6a76413a-5270-5488-80bf-9f23a629af38",
  "slug": "lechon-paksiw-recipe",
  "name": "Lechon Paksiw",
  "recipe_type": null,
  "brief_description": "Leftover roasted pork simmered in a tangy sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saute the garlic until it starts to brown."
    },
    {
      "position": 2,
      "text": "Add the onion. Saut\u00e9 until it softens."
    },
    {
      "position": 3,
      "text": "Put the leftover lechon into the pot. Cook for 1 minute. Note: you can use either roasted pork or lechon kawali."
    },
    {
      "position": 4,
      "text": "Pour vinegar and water. Let it boil."
    },
    {
      "position": 5,
      "text": "Add garlic and onion powder, dried bay leaves, and whole peppercorn. Cover the pot and then simmer for 15 minutes."
    },
    {
      "position": 6,
      "text": "Pour the lechon sauce and add the sugar. Continue cooking for 5 minutes."
    },
    {
      "position": 7,
      "text": "Season with Maggi Magic Sarap. Stir."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with warm rice."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
