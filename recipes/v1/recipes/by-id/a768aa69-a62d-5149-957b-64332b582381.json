  "id": "a768aa69-a62d-5149-957b-64332b582381",
  "slug": "beef-papaitan-pinapaitang-baka",
  "name": "Beef Papaitan",
  "recipe_type": "appetizer",
  "brief_description": "Traditional Filipino bitter soup made from cow\u2019s innards. This is a special delicacy in the Northern part of the Philippines.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Wash beef tripe and small intestine. Boil with ginger and dried bay leaves for 45 minutes. Remove from the pot and let it cool down. Slice into bite-size pieces."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. Saut\u00e9 onion, garlic, and ginger until onion softens."
    },
    {
      "position": 3,
      "text": "Add beef heart and kidney. Saut\u00e9 until it turns light brown."
    },
    {
      "position": 4,
      "text": "Put the tripe and small intestines into the pot. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour water into the pot. Let is boil. Adjust heat to low. Continue boiling until beef heart and kidney tenderizes."
    },
    {
      "position": 6,
      "text": "Add beef liver and bile. Stir. Cook for 15 minutes in medium heat."
    },
    {
      "position": 7,
      "text": "Add Knorr Sinigang sa Sampaloc Recipe Mix."
    },
    {
      "position": 8,
      "text": "Put long green peppers into the pot and season with salt and ground black pepper. Stir. Cook for 2 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve hot."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 45,
  "rest_time_minutes": null,
  "difficulty": "expert",
