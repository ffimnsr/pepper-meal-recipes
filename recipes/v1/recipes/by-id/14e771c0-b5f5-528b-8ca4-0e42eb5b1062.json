  "id": "14e771c0-b5f5-528b-8ca4-0e42eb5b1062",
  "slug": "how-to-cook-beef-stroganoff",
  "name": "Beef Stroganoff",
  "recipe_type": "main",
  "brief_description": "With tender, juicy beef strips and a delightfully creamy sauce, beef stroganoff is one of the best comfort foods out there.",
  "cuisine": "Russian",
  "instructions": [
    {
      "position": 1,
      "text": "Make the roux by melting butter in a saucepan. Add flour and Knorr Beef Cubes. Continuously stir while cooking for 3 to 5 minutes. Pour water into the saucepan. Stir until all ingredients are well blended. Turn the heat off. Set roux aside."
    },
    {
      "position": 2,
      "text": "On a clean pan, heat oil. Saute onion and mushroom until the onion softens."
    },
    {
      "position": 3,
      "text": "Add beef. Saute for 3 minutes or until light brown."
    },
    {
      "position": 4,
      "text": "Pour-in roux. Stir. Continue cooking in medium heat for 3 minutes. Stir the mixture once in a while."
    },
    {
      "position": 5,
      "text": "Adjust heat to low. Add sour cream and season with salt and ground black pepper."
    },
    {
      "position": 6,
      "text": "Top over egg noodles. You can also have this with rice or pasta."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": null,
