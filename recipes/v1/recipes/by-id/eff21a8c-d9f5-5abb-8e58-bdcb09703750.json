  "id": "eff21a8c-d9f5-5abb-8e58-bdcb09703750",
  "slug": "filipino-food-max-style-fried-chicken-recipe",
  "name": "Max's style Fried Chicken",
  "recipe_type": null,
  "brief_description": "Learn how to cook this delicious Max Fried Chicken Recipe. This is a sure winner! Try this delicious today and let me know how you liked it.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a steamer, pour the water and bring to a boil."
    },
    {
      "position": 2,
      "text": "Add the dried bay leaves and chopped cilantro in the boiling water"
    },
    {
      "position": 3,
      "text": "Steam the chicken for 45 minutes"
    },
    {
      "position": 4,
      "text": "Remove the chicken from the steamer and allow the excess liquid to drip. Let the chicken cool down."
    },
    {
      "position": 5,
      "text": "Rub salt and pepper all over the chicken."
    },
    {
      "position": 6,
      "text": "In a deep-fryer or tall pot, pour the cooking oil and apply heat."
    },
    {
      "position": 7,
      "text": "When the cooking oil is hot enough, deep-fry the chicken for about 12 minutes. (If the chicken is not entirely immersed in oil, flip the chicken to fry the other side for another 12 minutes or until color turns golden brown)"
    },
    {
      "position": 8,
      "text": "Remove the chicken from the fryer and allow oil to drip."
    },
    {
      "position": 9,
      "text": "Serve hot with fried kamote (fried sweet potato). Share and Enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
