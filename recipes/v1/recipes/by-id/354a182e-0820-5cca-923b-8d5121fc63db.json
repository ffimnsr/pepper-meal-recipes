  "id": "354a182e-0820-5cca-923b-8d5121fc63db",
  "slug": "grilled-pork-chop-with-mango-salsa-recipe",
  "name": "Grilled Pork Chop with Mango Salsa",
  "recipe_type": "main",
  "brief_description": "Grilled pork chop with a delicious sweet salsa. Pair it with rice or grilled vegetables.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the mango salsa by combining all the salsa ingredients in a medium bowl. Gently mix and then refrigerate."
    },
    {
      "position": 2,
      "text": "Meanwhile, make the pork chop rub by combining the garlic powder, salt, and ground black pepper. Mix well."
    },
    {
      "position": 3,
      "text": "Apply the rub on the pork chop slices. Let it stand for 15 to 30 minutes."
    },
    {
      "position": 4,
      "text": "Grill each side of the pork in medium heat for about 6 to 8 minutes or until fully cooked in the outside. Makes sure not to over grill so that it won't get dry."
    },
    {
      "position": 5,
      "text": "Arrange in a serving plate with some Mango Salsa on the side."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 14,
  "preparation_time_minutes": 15,
