  "id": "6fe56209-363b-58b1-b81b-76552574fdfb",
  "slug": "pork-chao-fan",
  "name": "Pork Chao Fan Recipe",
  "recipe_type": "side",
  "brief_description": "Chinese Style Fried Rice",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a wok. Add beaten eggs. Fry until eggs are fully cooked. Remove eggs from the pan. Set aside."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 onion using remaining oil until it softens."
    },
    {
      "position": 3,
      "text": "Add ground pork. Cook while stirring until pork turns medium brown."
    },
    {
      "position": 4,
      "text": "Pour soy sauce, Sesame oil, and hoisin sauce into the wok. Stir."
    },
    {
      "position": 5,
      "text": "Add carrots and leftover rice. Stir-fry for 2 minutes. Toss until all ingredients are well distributed."
    },
    {
      "position": 6,
      "text": "Add green peas and green onions. Cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Add the chopped fried egg and then season with salt and ground white pepper."
    },
    {
      "position": 8,
      "text": "Serve warm. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 18,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
