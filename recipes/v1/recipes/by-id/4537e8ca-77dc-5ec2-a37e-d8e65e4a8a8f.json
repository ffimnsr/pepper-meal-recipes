  "id": "4537e8ca-77dc-5ec2-a37e-d8e65e4a8a8f",
  "slug": "fish-stew-paksiw-na-isda-sa-gata",
  "name": "Filipino Fish Stew (Paksiw na Isda sa Gata)",
  "recipe_type": null,
  "brief_description": "Fish steaks cooked in coconut milk and vinegar",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Rub the coarse sea salt on the fish steaks and set aside. (see notes below)"
    },
    {
      "position": 2,
      "text": "Heat \u00bc cup cooking oil. Fry the eggplants for 1 \u00bd minutes per side. Remove the eggplants from the pan. Set it aside."
    },
    {
      "position": 3,
      "text": "Pour the remaining cooking oil into the pan and then heat it up."
    },
    {
      "position": 4,
      "text": "Fry one side of the fish steaks until it browns. Do the same on the opposite side. Remove the fried fish. Set aside."
    },
    {
      "position": 5,
      "text": "Scoop out the oil in the pan until the amount gets close to around 3 tablespoons. Heat it up and then saut\u00e9 the onion for 1 minute."
    },
    {
      "position": 6,
      "text": "Add the garlic and ginger. Continue saut\u00e9ing for 1 \u00bd minutes."
    },
    {
      "position": 7,
      "text": "Arrange the fried fish steaks on the pan."
    },
    {
      "position": 8,
      "text": "Pour the coconut milk and then distribute the green and Thai chili peppers on the pan. Add ground black pepper. (see notes below)"
    },
    {
      "position": 9,
      "text": "Cover the pan. Let the mixture boil. Simmer for 4 minutes."
    },
    {
      "position": 10,
      "text": "Pour the vinegar. Cover the pan, let the mixture boil."
    },
    {
      "position": 11,
      "text": "Simmer until reduces close to half."
    },
    {
      "position": 12,
      "text": "Add the fried eggplants."
    },
    {
      "position": 13,
      "text": "Season with fish sauce and Maggi Magic Sarap."
    },
    {
      "position": 14,
      "text": "Transfer to a serving plate. Serve with rice."
    },
    {
      "position": 15,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
