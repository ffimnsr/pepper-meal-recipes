  "id": "f80d7c76-6a2b-55af-b751-c3f4cb086b1f",
  "slug": "misua-with-patola-and-meatballs",
  "name": "Misua with Patola and Meatballs",
  "recipe_type": "soup",
  "brief_description": "This is a Filipino recipe for a meatball soup with patola and thin flour noodles .",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 350F."
    },
    {
      "position": 2,
      "text": "Scoop a tablespoon of pork burger patty mixture and roll it on your hands until it turns into a ball shaped figure. Arrange the meatballs in a greased baking tray."
    },
    {
      "position": 3,
      "text": "Bake the meatballs in the oven for 25 minutes."
    },
    {
      "position": 4,
      "text": "Heat oil in a pot"
    },
    {
      "position": 5,
      "text": "Saut\u00e9 the garlic and onion"
    },
    {
      "position": 6,
      "text": "Once the onion starts to get soft, add the baked meatballs."
    },
    {
      "position": 7,
      "text": "Pour the chicken broth and water in the pot. Let boil. Set heat between low and medium, cover, and cook for 12 minutes."
    },
    {
      "position": 8,
      "text": "Add the patola. Continue to cook for 5 to 8 minutes."
    },
    {
      "position": 9,
      "text": "Add the misua and green onion. Stir and cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Sprinkle some salt and ground black pepper."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
