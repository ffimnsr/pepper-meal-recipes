{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "6391fb19-a051-5dda-ac7f-71ae8713b2d4",
  "slug": "lengua-kare-kare",
  "name": "Lengua Kare-Kare Recipe",
  "recipe_type": "main",
  "brief_description": "Tender ox tongue cooked in peanut and almond sauce and served with steamed bok choy, eggplant and string beans.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a pressure cooker. Add ox tongue. Pressure-cook for 45 minutes. Remove the tongue afterwards and let it cool down. Take the skin off the tongue and then slice into serving pieces. Set aside."
    },
    {
      "position": 2,
      "text": "Prepare the vegetables by steaming the eggplant and string beans for 10 minutes. Steam the bok choy for 5 minutes."
    },
    {
      "position": 3,
      "text": "Prepare the peanuts and almonds by roasting on a pan until the color starts to turn brown. Put the nuts in a food processor and blitz until the mixture turns into a paste-like consistency. Set aside."
    },
    {
      "position": 4,
      "text": "Heat annatto oil on a wok. Saut\u00e9 garlic and onion."
    },
    {
      "position": 5,
      "text": "Once the onion softens, add the sliced lengua. Saut\u00e9 for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour the beef broth into the wok. Cover and let boil. Continue boiling for 10 minutes in low heat setting."
    },
    {
      "position": 7,
      "text": "Add the peanut and almond paste. Stir until all ingredients are well blended. Continue cooking uncovered for 7 minutes. Season with salt."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl and add the steamed vegetables. Serve with shrimp paste (bagoong alamang)."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
