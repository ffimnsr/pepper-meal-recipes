  "slug": "how-to-cook-the-best-game-day-chili",
  "name": "Best Game Day Chili Recipe",
  "recipe_type": null,
  "brief_description": "The Best Game Day Chili Recipe is really one of the best recipes around. Get the details by checking this recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in olive oil."
    },
    {
      "position": 2,
      "text": "Put-in ground beef and chopped onion and cook for 7 to 10 minutes or until the ground beef turns medium brown."
    },
    {
      "position": 3,
      "text": "Put-in all the seasoning then stir."
    },
    {
      "position": 4,
      "text": "Add the tomato sauce, diced tomatoes, and kidney beans. Stir and cover. Simmer for 1 \u00bd hours."
    },
    {
      "position": 5,
      "text": "Turn-off heat then transfer to a serving bowl."
    },
    {
      "position": 6,
      "text": "Serve with grated cheese or your favorite side."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
