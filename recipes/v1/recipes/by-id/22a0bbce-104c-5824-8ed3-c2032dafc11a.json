  "slug": "pinoy-street-food-orange-egg-tokneneng-qwek-kwek-kwek-recipe",
  "name": "Kwek-Kwek",
  "recipe_type": null,
  "brief_description": "Kwek-kwek are deep-fried quail eggs coated in an orange annatto batter, a popular Filipino street food snack.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Place the cornstarch in a container and dredge the boiled quail eggs. Set aside."
    },
    {
      "position": 2,
      "text": "In a mixing bowl, combine flour, salt, and pepper, then mix thoroughly."
    },
    {
      "position": 3,
      "text": "Dilute the annatto powder in warm water, then pour into the mixing bowl with the other ingredients. Mix well."
    },
    {
      "position": 4,
      "text": "Place all the quail eggs in the mixing bowl and coat with the batter."
    },
    {
      "position": 5,
      "text": "Heat a pan and pour in the cooking oil."
    },
    {
      "position": 6,
      "text": "When the oil is hot enough, deep-fry the quail eggs by scooping them from the mixing bowl using a spoon. Make sure that each one is coated with batter."
    },
    {
      "position": 7,
      "text": "After a few minutes, remove the fried quail eggs from the pan and place on a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with vinegar or fish ball sauce while still crispy."
    },
    {
      "position": 9,
      "text": "Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 5,
