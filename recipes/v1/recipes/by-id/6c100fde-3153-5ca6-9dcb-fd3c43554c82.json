  "id": "6c100fde-3153-5ca6-9dcb-fd3c43554c82",
  "slug": "pancit-bihon-with-lechon-kawali",
  "name": "Pancit Bihon with Lechon Kawali",
  "recipe_type": "main",
  "brief_description": "Filipino pancit bihon topped with chopped crispy pork belly.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saute onion and garlic until the onion softens."
    },
    {
      "position": 2,
      "text": "Add pork belly and sausage. Saute for 3 minutes."
    },
    {
      "position": 3,
      "text": "Pour soy sauce and water. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Pork cube. Stir and cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Add bihon noodles. Cover the pot and then continue cooking until the noodles starts to soften."
    },
    {
      "position": 6,
      "text": "Add oyster sauce. Toss until all ingredients are well distributed."
    },
    {
      "position": 7,
      "text": "Put-in dried shrimp, cabbage, snap peas, carrot. Toss. Cook for 7 minutes."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper and soy sauce if needed."
    },
    {
      "position": 9,
      "text": "Arrange in a serving tray and top with chopped lechon kawali."
    },
    {
      "position": 10,
      "text": "Serve with sliced lime or calamansi. Share and enjoy!"
    }
  ],
  "servings": 12,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
