  "id": "a2aeadf3-5e33-5d66-808b-61ea777e0e35",
  "slug": "crispy-garlic-fried-chicken-wings",
  "name": "Crispy Garlic Fried Chicken Wings",
  "recipe_type": "appetizer",
  "brief_description": "Crispy chicken wing with ranch sauce",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the chicken with all the marinade ingredients. Mix well. Refrigerate for at least 1 hour."
    },
    {
      "position": 2,
      "text": "Meanwhile, make the white sauce by combining all the sauce ingredients in a bowl. Stir to mix everything together. Set aside."
    },
    {
      "position": 3,
      "text": "Add beaten egg. Distribute it all over the chicken pieces."
    },
    {
      "position": 4,
      "text": "Gradually add the cornstarch and all-purpose flour. Continue mixing until all the ingredients are well incorporated. Set aside."
    },
    {
      "position": 5,
      "text": "Heat 2 cups of cooking oil in a wok."
    },
    {
      "position": 6,
      "text": "Once the temperature reaches 350F, add the chicken wings one piece at a time. Adjust the heat to medium setting. Continue frying for 8 to 10 minutes or until the chicken turns golden brown. Remove from the wok and let the chicken cool down for 10 to 12 minutes."
    },
    {
      "position": 7,
      "text": "Put the fried chicken wings back into the wok and continue frying for 1 minute."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with white sauce on the side."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "medium",
