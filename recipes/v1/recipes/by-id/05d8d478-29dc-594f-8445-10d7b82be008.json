  "id": "05d8d478-29dc-594f-8445-10d7b82be008",
  "slug": "chicken-teriyaki-brown-rice-sunny-side-up-egg",
  "name": "Chicken Teriyaki, Brown Rice, and Sunny Side Up Egg Recipe",
  "recipe_type": "breakfast",
  "brief_description": "Chicken Teriyaki, Brown Rice, and Sunny Side Up Egg Recipe sounds like a good idea for lunch or breakfast \u2013 if you intend to eat something heavy",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the marinade by combining the soy sauce, brown sugar, Mirin (or cooking wine), water, and garlic powder. Stir until all the ingredients are properly distributed."
    },
    {
      "position": 2,
      "text": "Place the chicken breasts in a Ziploc bag or in a bowl. Mix-in the marinade. Seal the bag and put inside the refrigerator. Marinate for at least 1 hour (overnight is better)."
    },
    {
      "position": 3,
      "text": "Heat the grill. Grill the marinated chicken for 4 to 7 minutes per side or until the internal temperature reads 165F. You can flip the chicken twice while grilling each side for half the time per rotation to avoid one side from getting burnt."
    },
    {
      "position": 4,
      "text": "Arrange the cooked brown rice in a bowl. Put-in the grilled chicken teriyaki over the rice and top with sunny side up egg. Sprinkle some toasted sesame seeds on top of the chicken."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 60,
  "rest_time_minutes": null,
  "difficulty": "hard",
