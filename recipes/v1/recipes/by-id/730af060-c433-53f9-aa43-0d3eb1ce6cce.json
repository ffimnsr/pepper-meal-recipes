  "id": "730af060-c433-53f9-aa43-0d3eb1ce6cce",
  "slug": "pancit-chami",
  "name": "Pancit Chami Tamis Anghang Recipe",
  "recipe_type": "dessert",
  "brief_description": "Sweet and spicy fresh noodles tossed in pork and vegetables. This dish is popular in the province of Quezon in the Philippines.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat wok or pan. Sear pork fat until enough oil is extracted."
    },
    {
      "position": 2,
      "text": "Saute onion and garlic until the onion softens."
    },
    {
      "position": 3,
      "text": "Add pork, chicken, and liver. Saute until the outer parts turn light brown."
    },
    {
      "position": 4,
      "text": "Add soy sauce, oyster sauce, and water. Cover the wok. Let the liquid boil."
    },
    {
      "position": 5,
      "text": "Add crushed red pepper and brown sugar. Stir. Continue boiling for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add fresh noodles. Toss."
    },
    {
      "position": 7,
      "text": "Put the carrot and cabbage into the wok. Continue tossing until all ingredients are well blended. Cover and cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper and pour cornstarch slurry (2 teaspoons of cornstarch + 2 teaspoons of soy sauce + \u00bc cup water). Toss.Add boiled quail eggs. Transfer to a serving plate. Serve! Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 5,
