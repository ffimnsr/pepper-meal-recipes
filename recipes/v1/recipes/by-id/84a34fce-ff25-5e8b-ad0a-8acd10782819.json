  "id": "84a34fce-ff25-5e8b-ad0a-8acd10782819",
  "slug": "steamed-fish-with-scallions-and-ginger-recipe",
  "name": "Steamed Fish with Scallions and Ginger",
  "recipe_type": null,
  "brief_description": "This is a recipe for steamed fish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make a series of diagonal cut on both sides of the fish using a knife."
    },
    {
      "position": 2,
      "text": "Combine salt and sesame oil. Rub the mixture on the whole fish. Set aside"
    },
    {
      "position": 3,
      "text": "Combine soy sauce, ginger, scallions, and sherry."
    },
    {
      "position": 4,
      "text": "Arrange the fish in a heat proof plate. Pour the soy sauce mixture on top."
    },
    {
      "position": 5,
      "text": "Meanwhile, heat water on a base pan and then arrange the bamboo steamer on top of the pan."
    },
    {
      "position": 6,
      "text": "Place the plate with fish inside the bamboo steamer. Cover and then steam for 10 to 16 minutes."
    },
    {
      "position": 7,
      "text": "Heat the oil in a sauce pan."
    },
    {
      "position": 8,
      "text": "When the oil becomes hot, pour over the steamed fish"
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
