  "slug": "ginataang-lechon-kawali-with-kalabasa-and-long-green-beans",
  "name": "Ginataang Lechon Kawali with Kalabasa and Long Green Beans",
  "recipe_type": null,
  "brief_description": "This is a recipe for Ginataang Lechon Kawali",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot"
    },
    {
      "position": 2,
      "text": "Saut\u00e9 onion for 20 to 30 seconds"
    },
    {
      "position": 3,
      "text": "Add garlic. Continue to cook until the onion softens."
    },
    {
      "position": 4,
      "text": "Put the lechon kawali into the pot. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Combine Knorr Ginataang Gulay Recipe Mix with 1 \u00bd cups water. Stir. Pour the mixture into the cooking pot."
    },
    {
      "position": 6,
      "text": "Cover the pot. Continue to cook in medium heat for 45 minutes. Note: add more water if necessary."
    },
    {
      "position": 7,
      "text": "Add butternut squash or kalabasa. Cover the pot and cook for 5 minutes."
    },
    {
      "position": 8,
      "text": "Add long green beans. Cover the pot and continue to cook for 2 to 3 minutes."
    },
    {
      "position": 9,
      "text": "Season with ground black pepper and fish sauce"
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve!"
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
