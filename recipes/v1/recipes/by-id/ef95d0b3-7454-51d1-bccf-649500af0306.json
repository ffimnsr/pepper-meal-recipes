  "id": "ef95d0b3-7454-51d1-bccf-649500af0306",
  "slug": "ketogenic-bacon-and-egg-salad-recipe",
  "name": "Ketogenic Bacon and Egg Salad",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for Low Carb High Fat Ketogenic Bacon and Egg Salad",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot and then add eggs. Cover the pot and apply heat. Let the water boil rapidly."
    },
    {
      "position": 2,
      "text": "Turn the heat off. Let the eggs remain the the covered pot for 10 minutes."
    },
    {
      "position": 3,
      "text": "Discard the warm water from the pot and pour cold water into it. You can also add ice to quickly chill the egg. Remove the shell and slice into cubes. Set aside."
    },
    {
      "position": 4,
      "text": "Meanwhile, prepare the bacon by heating a pan. Cook each side of the bacon using medium heat for 3 minutes or until the bacon gets crispy. Chop the bacon and set aside."
    },
    {
      "position": 5,
      "text": "Combine Lady's Choice mayonnaise, Dijon mustard, salt, ground black pepper, and onion in a bowl. Mix well."
    },
    {
      "position": 6,
      "text": "Add sliced eggs, bacon, scallions, and cheese. Fold until well blended."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
