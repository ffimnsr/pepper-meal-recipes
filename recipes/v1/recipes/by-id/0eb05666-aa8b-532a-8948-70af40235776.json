  "id": "0eb05666-aa8b-532a-8948-70af40235776",
  "slug": "pork-giniling-with-oyster-sauce",
  "name": "Pork Giniling with Oyster Sauce",
  "recipe_type": "main",
  "brief_description": "Ground pork with oyster sauce and potato.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Once hot, pan-fry the diced potato until the exterior turns light brown in color. Remove the potatoes from the pan and set aside."
    },
    {
      "position": 2,
      "text": "Using the remaining oil, saut\u00e9 onion, garlic, and tomato."
    },
    {
      "position": 3,
      "text": "Add ground pork once the onion softens. Cook while stirring for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour the soy sauce into the pan and add water. Adjust the heat to low. Cook uncovered until the liquid reduces to half."
    },
    {
      "position": 5,
      "text": "Add oyster sauce and cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Put the fried potato back into the pan. Continue cooking for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl and serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
