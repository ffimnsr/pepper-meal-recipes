  "id": "d43039bb-fb64-5adf-b93b-fecf65e97d74",
  "slug": "chicken-arroz-caldo-recipe-glutinous-rice-porridge",
  "name": "Arroz Caldo Recipe",
  "recipe_type": "breakfast",
  "brief_description": "Filipino Chicken congee with boiled eggs",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat around 5 tablespoons of cooking oil in a wok. Add the garlic immediately. Slow fry it while occasionally stirring until golden brown. Remove the garlic from the wok. Set aside."
    },
    {
      "position": 2,
      "text": "Saute the onion in the remaining oil until it softens. Add ginger. Saute for 1 minute."
    },
    {
      "position": 3,
      "text": "Add the chicken and continue saut\u00e9ing until the color of the exterior turns light brown. Pour 2 tablespoons of fish sauce. Stir."
    },
    {
      "position": 4,
      "text": "Add the jasmine and sweet rice. Saute for 30 seconds,"
    },
    {
      "position": 5,
      "text": "Pour the water into the wok. Cover and let it boil."
    },
    {
      "position": 6,
      "text": "Add Maggi Magic Chicken Cube. Adjust the heat to the lowest setting. Simmer the chicken while occasionally stirring until the rice breaks down with a thick consistency. (note: this usually takes more than 35 minutes to achieve)."
    },
    {
      "position": 7,
      "text": "Add turmeric powder and safflower. Stir."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper and fish sauce as needed."
    },
    {
      "position": 9,
      "text": "Add the boiled eggs, toasted garlic, and chopped green onions."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl and top with more toasted garlic and chopped green onions. Serve with a condiment of calamansi and fish sauce."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
