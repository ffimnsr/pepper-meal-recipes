  "id": "1acb5223-cf25-5dd2-a071-760313067826",
  "slug": "pork-menudo-with-bell-peppers",
  "name": "Pork Menudo with Bell Pepper",
  "recipe_type": "main",
  "brief_description": "Pork Menudo with Bell Pepper is a colorful Filipino tomato stew with diced pork shoulder, liver, hotdogs, carrots, potatoes, and red and green bell peppers. The peppers go in near the end so they keep their color and a little snap. Serve hot with steamed white rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the pork and soy sauce in a bowl. Mix well and let the pork marinate for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan over medium-high heat. Fry the carrots and potatoes until they start to brown. Remove from the pan, drain, and set aside. Leave about 2 tablespoons of oil in the pan."
    },
    {
      "position": 3,
      "text": "Saute the hotdogs in the same pan for 1 to 1 1/2 minutes. Remove from the pan and set aside."
    },
    {
      "position": 4,
      "text": "Add 2 tablespoons of oil to the same pan. Saute half of the chopped onion until soft. Add the pork liver and cook until lightly browned. Remove from the pan and set aside."
    },
    {
      "position": 5,
      "text": "Pour 3 tablespoons of the used cooking oil into the pan. Saute the garlic until it starts to brown. Add the remaining onion and cook until soft."
    },
    {
      "position": 6,
      "text": "Add the marinated pork. Saute until the pork turns light to medium brown."
    },
    {
      "position": 7,
      "text": "Pour in the tomato sauce and water. Stir and let it boil."
    },
    {
      "position": 8,
      "text": "Add the bay leaves and beef powder. Cover the pan and simmer until the pork becomes tender."
    },
    {
      "position": 9,
      "text": "Return the hotdogs and pork liver to the pan. Cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Add the bell peppers, carrots, and potatoes. Toss to combine and cook for 1 minute."
    },
    {
      "position": 11,
      "text": "Add the sugar. Season with fish sauce and ground black pepper to taste. Transfer to a serving plate and serve with rice. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 20,
  "rest_time_minutes": 10,
