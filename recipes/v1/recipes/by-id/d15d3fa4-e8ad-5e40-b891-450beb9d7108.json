  "id": "d15d3fa4-e8ad-5e40-b891-450beb9d7108",
  "slug": "grilled-pinoy-pork-chop-recipe",
  "name": "Grilled Pinoy Pork Chop Recipe",
  "recipe_type": null,
  "brief_description": "Grilled Pinoy Pork Chop is a simple yet delicious pork chop recipe that anyone can make. This is best eaten with sliced green mango, tomato, and shrimp paste.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine oil, salt, pepper, garlic powder, and chili powder. Mix well until the powders are diluted in oil."
    },
    {
      "position": 2,
      "text": "Rub the oil mixture in each piece of pork chop."
    },
    {
      "position": 3,
      "text": "Place the pork chop in a covered container. Refrigerate for at least 3 hours for the flavors to be absorbed."
    },
    {
      "position": 4,
      "text": "Heat the grill. Using medium heat, grill each side of the pork chop for about 8 to 12 minutes depending on the thickness of the cut. Baste with remaining oil mixture."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve with sliced green mangoes, tomatoes, salted eggs, and shrimp paste."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 180,
