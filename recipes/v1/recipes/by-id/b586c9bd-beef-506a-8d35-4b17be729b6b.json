  "id": "b586c9bd-beef-506a-8d35-4b17be729b6b",
  "slug": "ginataang-manok-with-kalabasa-recipe",
  "name": "Ginataang Manok and Kalabasa",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Chicken and Butternut Squash in coconut Milk.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, pan fry the chicken for 2 minutes per side. Remove from the pot. Set aside."
    },
    {
      "position": 3,
      "text": "Saute onion and garlic using remaining oil until the onion softens.Put the chicken back into the pot."
    },
    {
      "position": 4,
      "text": "Make the gata mixture by combining Knorr Ginataang Gulay Mix and water. Stir until the powder completely dilutes. Pour the gata into the pot. Let boil. Cover and for 25 minutes using low to medium heat. Note: add more water if needed."
    },
    {
      "position": 5,
      "text": "Add kalabasa. Cover and cook for 7 to 8 minutes."
    },
    {
      "position": 6,
      "text": "Add malunggay leaves. Stir and cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Tranfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
