  "id": "da4df0e4-485e-5251-b363-707c3e97bb99",
  "slug": "chicken-igado",
  "name": "Chicken Igado Recipe",
  "recipe_type": "main",
  "brief_description": "Chicken liver and heart stewed in vinegar and soy sauce with bell pepper and green peas.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat 3 tablespoons of oil in a cooking pot. Pan-fry chicken liver for 2 minutes. Turn it over and fry the opposite side. Transfer the fried liver on a clean plate. Set aside. Note: There will be liquid coming out of the liver. Let it evaporate completely and continue frying until the liver turns light brown. Do the same step until the liver is completely cooked. Do not over fry it though to keep it from tasting bitter."
    },
    {
      "position": 2,
      "text": "Wipe the same pan with a clean paper towel to remove most of the liver residue. Heat remaining cooking oil. Saute garlic until it starts to brown. Add onion and continue saut\u00e9ing until it softens."
    },
    {
      "position": 3,
      "text": "Add chicken heart. Saute for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour soy sauce and vinegar into the pot. Cover the pot and let the mixture boil. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Add bay leaves and water. Cover the pot. Continue cooking using low to medium heat for 35 minutes. Note: add more water if needed."
    },
    {
      "position": 6,
      "text": "Put the fried liver into the pot. Stir. Cover and cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add carrot, bell pepper, and green peas. Cover and continue cooking for 2 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
