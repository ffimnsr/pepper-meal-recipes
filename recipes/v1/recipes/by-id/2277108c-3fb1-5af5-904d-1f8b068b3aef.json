  "id": "2277108c-3fb1-5af5-904d-1f8b068b3aef",
  "slug": "chicken-potato-salad",
  "name": "Chicken Potato Salad",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for chicken potato salad with carrots and peas.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil 4 cups water in a pot. Add the chicken. Boil for 15 minutes. Remove the chicken and let it cool down. Slice the chicken into small cubes. Set aside."
    },
    {
      "position": 2,
      "text": "Boil a clean batch of water in a clean pot. Add the carrot and continue to boil for 5 minutes. Drain the water and set the carrot aside. Do the same with the potato."
    },
    {
      "position": 3,
      "text": "Combine the diced chicken, carrot, and potato in a mixing bowl. Add garlic salt, pickle relish, Parmesan, and mayonnaise. Fold until all the ingredients are well blended. Add the frozen green peas. Continue to fold until well blended. Note: you can adjust the amount of garlic salt and Parmesan to tailor to your taste."
    },
    {
      "position": 4,
      "text": "Refrigerate for at least 3 hours."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
