  "id": "1b2e7d7c-36c8-5796-863f-dd6586af246c",
  "slug": "easy-pata-tim-ham-hock-recipe",
  "name": "Easy Pata Tim Recipe",
  "recipe_type": "main",
  "brief_description": "One of the most popular ways you can cook pata also happens to be one of the easiest. We\u2019re talking about Filipino-Chinese classic, pata tim!",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 5 cups of water. Add bay leaves and pata. Cook for 10 minutes. Drain the water and set the pata aside."
    },
    {
      "position": 2,
      "text": "Heat cooking oil and sesame oil and then saut\u00e9 onion and garlic."
    },
    {
      "position": 3,
      "text": "Once the onion softens, add the boiled pata. Saut\u00e9 for 1 minute."
    },
    {
      "position": 4,
      "text": "Add soy sauce and pour 3 cups of water into the cooking pot. Let it boil."
    },
    {
      "position": 5,
      "text": "Add Knorr Pork Cube and star anise. Pressure-cook for 20 minutes"
    },
    {
      "position": 6,
      "text": "Add sugar, Shitake mushroom and carrot. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add the bok choy. Continue cooking for 1 minute."
    },
    {
      "position": 8,
      "text": "Combine cornstarch and 1/4 cup water. Stir and pour the mixture into the cooking pot. Continue cooking until the sauce thickens."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper as needed."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
