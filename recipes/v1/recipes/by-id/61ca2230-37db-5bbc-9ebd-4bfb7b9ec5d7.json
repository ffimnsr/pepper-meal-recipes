  "id": "61ca2230-37db-5bbc-9ebd-4bfb7b9ec5d7",
  "slug": "braised-collard-greens",
  "name": "Braised Collard Greens",
  "recipe_type": "side",
  "brief_description": "Slow-braised collard greens simmered with smoky bacon, sweet molasses, and tangy vinegar until meltingly tender. A classic Southern side dish that balances savory, sweet, and acidic flavors perfectly.",
  "cuisine": "southern-american",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a wide casserole."
    },
    {
      "position": 2,
      "text": "When the oil is hot, add the bacon. Cook for 1 minute."
    },
    {
      "position": 3,
      "text": "Put-in the garlic and onion. Continue to cook until the onion becomes soft."
    },
    {
      "position": 4,
      "text": "Pour-in the chicken broth and water. Let boil."
    },
    {
      "position": 5,
      "text": "Add the molasses, vinegar, salt, and ground black pepper. Stir."
    },
    {
      "position": 6,
      "text": "Gradually add the collard greens while pushing down with a spoon. Cover and simmer for 80 minutes or until the greens are tender. Make sure to stir every 15 minutes. Note: add water as necessary."
    },
    {
      "position": 7,
      "text": "Remove the cover to let the excess liquid evaporate."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 80,
  "preparation_time_minutes": 5,
