  "id": "aa31fd1e-5f25-5576-b04f-8fee2ada7c56",
  "slug": "chili-ginger-chicken",
  "name": "Chili Ginger Chicken",
  "recipe_type": "main",
  "brief_description": "Breaded chicken sauteed in ginger with chili glaze",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt and pepper on the sliced chicken. Toss until the seasonings are well distributed."
    },
    {
      "position": 2,
      "text": "Bread the chicken. Start by combining flour and cornstarch in a bowl. Mix well. Dredge the chicken in the flour mixture and then dip it in the beaten egg. Dredge it again into the flour mixture. Arrange on a clean plate."
    },
    {
      "position": 3,
      "text": "Combine all the sauce ingredients in a bowl. Mix until the texture smoothens. Set aside."
    },
    {
      "position": 4,
      "text": "Heat the oil in a wok. Fry the breaded chicken until it turns golden brown. Set aside."
    },
    {
      "position": 5,
      "text": "Heat 3 tablespoons of cooking oil in a clean wok. Saut\u00e9 ginger and garlic for 30 seconds."
    },
    {
      "position": 6,
      "text": "Add green beans, chili pepper, and bell pepper. Saut\u00e9 for 1 minute."
    },
    {
      "position": 7,
      "text": "Put the breaded chicken into the wok. Toss."
    },
    {
      "position": 8,
      "text": "Pour the sauce. Stir and continue to cook until it thickens."
    },
    {
      "position": 9,
      "text": "Transfer the chicken in a serving plate. Serve with rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
