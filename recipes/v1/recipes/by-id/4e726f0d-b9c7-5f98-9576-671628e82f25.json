  "id": "4e726f0d-b9c7-5f98-9576-671628e82f25",
  "slug": "original-buffalo-chicken-wings",
  "name": "Original Buffalo Wings",
  "recipe_type": "appetizer",
  "brief_description": "Air Fried chicken wings coated with Buffalo sauce and served with ranch dressing, carrots, and celery.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Divide the wings into 3 parts. Separate the drumette from the wingette. Cut off the wingtip and set aside. Note: we&#39;ll only be using the big parts."
    },
    {
      "position": 2,
      "text": "Pat the wings dry with paper towel and arrange inside an air fryer. Air fry one side for 12 minutes at 350F. Do the same with the opposite side."
    },
    {
      "position": 3,
      "text": "Make the sauce by melting butter in a microwave oven. Add the hot sauce and stir until well blended."
    },
    {
      "position": 4,
      "text": "Soak chicken wings in the sauce. Make sure that each piece is fully coated."
    },
    {
      "position": 5,
      "text": "Serve with ranch dressing, carrots, and celery. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 29,
