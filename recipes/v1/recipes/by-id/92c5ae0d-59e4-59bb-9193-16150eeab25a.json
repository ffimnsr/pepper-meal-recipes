  "id": "92c5ae0d-59e4-59bb-9193-16150eeab25a",
  "slug": "sinigang-na-salmon-sa-miso",
  "name": "Sinigang na Salmon sa Miso",
  "recipe_type": null,
  "brief_description": "This is a recipe for Fish Sinigang using salmon head.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add onion and tomato. Let the water- re-boil."
    },
    {
      "position": 3,
      "text": "Put the salmon heads into the pot. Stir."
    },
    {
      "position": 4,
      "text": "Once the water starts to boil once more, add Knorr Sinigang na May Miso Recipe Mix. Stir."
    },
    {
      "position": 5,
      "text": "Add the long green peppers. Cover and then cook in medium heat for 12 minutes."
    },
    {
      "position": 6,
      "text": "Add okra, ground black pepper, and fish sauce. Stir. cover and cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Add the mustard leaves. Cover and cook for 3 to 5 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
