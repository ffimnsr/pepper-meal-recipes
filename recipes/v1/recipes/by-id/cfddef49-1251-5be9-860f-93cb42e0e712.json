  "id": "cfddef49-1251-5be9-860f-93cb42e0e712",
  "slug": "basic-cedar-plank-salmon-recipe",
  "name": "Cedar Plank Salmon",
  "recipe_type": null,
  "brief_description": "On another note, this Basic Cedar Plank Salmon Recipe is simple and very easy to prepare. I am using wild caught salmon for this since it has less mercury compared to farm raised salmon. Cedar plank is also needed for this recipe. The plank helps the salmon dish taste better and have a more appetizing aroma.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine salt, pepper, garlic and onion powder in a bowl. Mix well."
    },
    {
      "position": 2,
      "text": "Pour the oil in the bowl and mix with the spices."
    },
    {
      "position": 3,
      "text": "Rub the oil mixture all over the salmon fillet. Let it stay for 15 minutes."
    },
    {
      "position": 4,
      "text": "Heat-up the grill."
    },
    {
      "position": 5,
      "text": "Meanwhile, place the salmon on the cedar plank."
    },
    {
      "position": 6,
      "text": "Arrange the cedar plank with salmon on top of the grill. Cover the grill and continue to grill the salmon for 15 to 20 minutes, or until the salmon gets flaky."
    },
    {
      "position": 7,
      "text": "Remove the salmon from the grill. Arrange in a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with lemon or calamansi."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
