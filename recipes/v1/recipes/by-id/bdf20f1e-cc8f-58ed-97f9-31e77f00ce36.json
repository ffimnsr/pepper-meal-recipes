  "id": "bdf20f1e-cc8f-58ed-97f9-31e77f00ce36",
  "slug": "vegetarian-pancit-sotanghon-recipe",
  "name": "Vegetarian Pancit Sotanghon",
  "recipe_type": null,
  "brief_description": "The ingredients of Vegetarian Pancit Canton are comprised of vegetables plus the vermicelli noodles, which is made from grains.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Soak the noodles in a bowl of water until it becomes soft, but not soggy. Drain the water and set the noodles aside."
    },
    {
      "position": 2,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the garlic, onion, and celery"
    },
    {
      "position": 4,
      "text": "Once the onion becomes soft, pour-in the vegetable broth and annatto water. Let boil."
    },
    {
      "position": 5,
      "text": "Add the cabbage, carrot, and parsley. cover and cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Put the noodles in the cooking pot. Toss until all the ingredients are well incorporated."
    },
    {
      "position": 7,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 8,
      "text": "Serve with lemon wedges or calamansi."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
