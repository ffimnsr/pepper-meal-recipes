  "id": "bc1dad42-bb3d-5a18-803a-0560b96d1e23",
  "slug": "the-only-filipino-spaghetti-recipe-that-i-trust-for-the-holidays",
  "name": "The Only Filipino Spaghetti Recipe That I Trust for the Holidays",
  "recipe_type": "dessert",
  "brief_description": "Spaghetti with ham and hotdogs in a sweet blend of tomato sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add a teaspoon of salt. Put the spaghetti noodles in the pot. Cook according to package instructions. Drain the water and set the spaghetti aside."
    },
    {
      "position": 2,
      "text": "Make the sauce by heating oil in a cooking pot. Saut\u00e9 garlic and onion until the onion softens."
    },
    {
      "position": 3,
      "text": "Add the ground pork. Cook it while stirring until it turns light brown in color."
    },
    {
      "position": 4,
      "text": "Add the ham and hotdogs. Saut\u00e9 for 2 minutes."
    },
    {
      "position": 5,
      "text": "Put the bell peppers into the pot. Continue cooking for 1 minute."
    },
    {
      "position": 6,
      "text": "Pour the spaghetti sauce. Add 1 cup water. Stir and let boil."
    },
    {
      "position": 7,
      "text": "Add Knorr pork cube. Cover the pot and reduce the heat to a simmer. Cook for 30 minutes while stirring every 6 minutes or so."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper. You can add some grated cheese if preferred."
    },
    {
      "position": 9,
      "text": "Arrange spaghetti on a serving plate. Top with spaghetti sauce and shredded cheese."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
