{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "35ac3a88-69a7-50cd-94f0-3faa5c52306c",
  "slug": "crispy-lechon-belly-with-bacon",
  "name": "Crispy Lechon Belly with Bacon",
  "recipe_type": "main",
  "brief_description": "Seasoned pork belly slab stuffed with bacon and green onions",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Poke the skin of the pork. I use a meat tenderizing tool for this."
    },
    {
      "position": 2,
      "text": "Combine all the seasoning ingredients. Mix well. Set aside."
    },
    {
      "position": 3,
      "text": "Season the inside part of the pork belly with Knorr Liquid Seasoning. Spread the seasoning mixture by sprinkling over the meat part of the pork. Rub to make sure that it gets distributed evenly."
    },
    {
      "position": 4,
      "text": "Arrange the bacon strips over the seasoned side of the belly and top with lemongrass and spring onions. Roll the belly and secure using a kitchen twine."
    },
    {
      "position": 5,
      "text": "Brush vinegar all over the skin part of the belly and sprinkle salt."
    },
    {
      "position": 6,
      "text": "Arrange in an air fryer or turbo broiler. Cook at 325F for 90 minutes."
    },
    {
      "position": 7,
      "text": "Dab the oil from the skin and adjust the temperature of the broiler to 400F. Continue broiling until the skin becomes crispy."
    },
    {
      "position": 8,
      "text": "Serve with lechon sauce or spiced vinegar"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
