  "id": "c3a8f506-f87d-55b6-805b-1ca4722ad835",
  "slug": "egg-sandwich-spread-recipe",
  "name": "Egg Sandwich Spread Recipe",
  "recipe_type": null,
  "brief_description": "This Egg Sandwich Spread recipe is quick and easy to prepare. Once you have all the ingredients ready, all you need is to mash the eggs and add all the ingredients together.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Place the eggs in a bowl. Mash using a fork."
    },
    {
      "position": 2,
      "text": "Add mayonnaise, sugar, mustard powder, onion powder, salt, and pepper. Fold until all the ingredients are well blended."
    },
    {
      "position": 3,
      "text": "Add the sweet pickle relish. Fold once more until the pickles blends with the other ingredients."
    },
    {
      "position": 4,
      "text": "Transfer in a container. Refrigerate for 1 hour, or you can use it immediately. Spread over your favorite slice of bread."
    },
    {
      "position": 5,
      "text": "Share. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 10,
