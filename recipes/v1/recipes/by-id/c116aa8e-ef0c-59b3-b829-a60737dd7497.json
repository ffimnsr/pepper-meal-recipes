  "id": "c116aa8e-ef0c-59b3-b829-a60737dd7497",
  "slug": "sinigang-na-isda-sa-kamias",
  "name": "Sinigang na Isda sa Kamias (Fish Sinigang)",
  "recipe_type": "soup",
  "brief_description": "Sinigang na Isda sa Kamias or fish sinigang s a type of Filipino sour soup. It makes use of fish, tomato, mustard greens, long green peppers, and onion.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil the water in a large cooking pot."
    },
    {
      "position": 2,
      "text": "Once the water starts to boil, add the tomatoes, kamias, and onion. Cover and let boil for 8 minutes."
    },
    {
      "position": 3,
      "text": "Add the fish (any type) and long green peppers. Cover and cook in medium heat for 10 to 12 minutes."
    },
    {
      "position": 4,
      "text": "Add the mustard greens, salt, and pepper. Stir."
    },
    {
      "position": 5,
      "text": "Turn the heat off. Cover and let the residual heat cook the leaves for 5 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 7,
      "text": "Serve with white rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
