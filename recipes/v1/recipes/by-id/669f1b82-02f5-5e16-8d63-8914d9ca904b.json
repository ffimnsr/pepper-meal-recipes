  "id": "669f1b82-02f5-5e16-8d63-8914d9ca904b",
  "slug": "laing-fried-rice",
  "name": "Laing Fried Rice",
  "recipe_type": "side",
  "brief_description": "This is a quick fried rice recipe that makes use of laing. These are taro leaves that were cooked in coconut milk.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine salt and rice in a bowl. Gently mix until well blended."
    },
    {
      "position": 2,
      "text": "Heat the oil in a wide pan."
    },
    {
      "position": 3,
      "text": "Add the garlic once the oil gets hot. Cook until light brown."
    },
    {
      "position": 4,
      "text": "Put the laing in the pan. Stir and cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add the rice. Continue to cook for 5 to 8 minutes. Stir fry the rice until it blends well with the rest of the ingredients."
    },
    {
      "position": 6,
      "text": "Add the toasted anchovies. Stir and cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Top with red chili."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
