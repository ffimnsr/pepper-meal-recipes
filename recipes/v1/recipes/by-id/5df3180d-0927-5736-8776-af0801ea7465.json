  "id": "5df3180d-0927-5736-8776-af0801ea7465",
  "slug": "how-to-cook-crispy-fried-smelt",
  "name": "Crispy Fried Smelt",
  "recipe_type": null,
  "brief_description": "This is a recipe for Crispy Fried Smelt",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and garlic powder all over the smelts. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Combine flour and cornstarch in a bowl. Mix well."
    },
    {
      "position": 3,
      "text": "Heat oil in a pan or cooking pot."
    },
    {
      "position": 4,
      "text": "Dredge the smelts in flour and cornstarch mixture."
    },
    {
      "position": 5,
      "text": "Fry in medium heat for 3 to 5 minutes or until it turns crispy."
    },
    {
      "position": 6,
      "text": "Remove from the pan and arrange in a plate lined with paper towel."
    },
    {
      "position": 7,
      "text": "Serve immediately. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 8,
