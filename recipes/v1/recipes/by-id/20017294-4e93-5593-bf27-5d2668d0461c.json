  "slug": "filipino-food-pork-adobo-recipe",
  "name": "Pork Adobo Recipe",
  "recipe_type": "main",
  "brief_description": "Basic Filipino Prok Adobo with Soy Sauce, Vinegar, and Garlic. This delicious dish is perfect when served over newly cooked white rice.&nbsp;&nbsp;",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the pork belly, soy sauce, and garlic then marinade for at least 1 hour"
    },
    {
      "position": 2,
      "text": "Heat the pot and put-in the marinated pork belly then cook for a few minutes"
    },
    {
      "position": 3,
      "text": "Pour remaining marinade including garlic."
    },
    {
      "position": 4,
      "text": "Add water, whole pepper corn, and dried bay leaves then bring to a boil. Simmer for 40 minutes to 1 hour"
    },
    {
      "position": 5,
      "text": "Put-in the vinegar and simmer for 12 to 15 minutes"
    },
    {
      "position": 6,
      "text": "Add salt to taste"
    },
    {
      "position": 7,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
