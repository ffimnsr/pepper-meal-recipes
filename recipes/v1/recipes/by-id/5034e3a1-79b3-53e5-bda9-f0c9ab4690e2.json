  "id": "5034e3a1-79b3-53e5-bda9-f0c9ab4690e2",
  "slug": "pork-chop-bicol-express",
  "name": "Pork Chop Bicol Express",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Pork Chop Bicol Express",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, pan fry each pork chop for 1 minute per side. Remove from the pan and then set aside."
    },
    {
      "position": 3,
      "text": "Using the remaining oil, saut\u00e9 garlic and onion until the onion becomes soft."
    },
    {
      "position": 4,
      "text": "Pour the coconut cream in the pan. Let boil."
    },
    {
      "position": 5,
      "text": "Add the chili and green pepper. Stir."
    },
    {
      "position": 6,
      "text": "Gently add the pan-fried pork chop back in the pan. Pour the water and let the liquid boil. Cover and cook in low heat for 40 minutes or until the pork chop becomes tender."
    },
    {
      "position": 7,
      "text": "Add the shrimp paste. Stir. Cover and cook until the sauce reduces and becomes thick."
    },
    {
      "position": 8,
      "text": "Sprinkle some salt and ground black pepper, if needed."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Top with chopped chives or scallions. Serve with rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
