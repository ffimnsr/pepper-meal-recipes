  "id": "11925d4d-eb9b-5794-9563-c525e1b6a3bc",
  "slug": "sausage-liver-and-pork-stew",
  "name": "Sausage, Liver, and Pork Stew",
  "recipe_type": null,
  "brief_description": "Sausage, Liver, and Pork Stew is perfect for all occasions; it can also be served during regular days when you feel like preparing something nice and special. This dish is similar to pork menudo and can be enjoyed anytime of the day.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, brown the pork."
    },
    {
      "position": 3,
      "text": "Add the onion and garlic. Saute until the onion gets soft."
    },
    {
      "position": 4,
      "text": "Stir-in the sausage. Cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the pig liver. Cook for 3 to 4 minutes."
    },
    {
      "position": 6,
      "text": "Add the tomato paste. Stir. Pour-in the beef broth. Let boil. Cover and simmer until the pork is tender (around 40 to 60 minutes). You can add more beef broth if needed."
    },
    {
      "position": 7,
      "text": "Add the potato, green peas, carrots, and ref bell pepper. Stir and cook for 10 to 12 minutes."
    },
    {
      "position": 8,
      "text": "Add salt and pepper to taste. Cook for 2 minutes more."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl.Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
