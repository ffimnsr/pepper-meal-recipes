  "id": "61a5c400-5977-5479-80c7-d771409841ce",
  "slug": "filipino-paksiw-recipe",
  "name": "Bangus Filipino Paksiw Recipe",
  "recipe_type": null,
  "brief_description": "Milkfish cooked in a tangy base with some vegetables",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan and sear the pork fat until enough oil gets extracted."
    },
    {
      "position": 2,
      "text": "Turn off the heat. Arrange the garlic, ginger, onion, and whole peppercorns."
    },
    {
      "position": 3,
      "text": "Top with the milkfish slices, long green peppers, eggplant, and bitter melon."
    },
    {
      "position": 4,
      "text": "Pour the vinegar. Turn the heat on. Cover the pot, and let it boil. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add water. Let the liquid re-boil. Simmer for 15 minutes."
    },
    {
      "position": 6,
      "text": "Season with fish sauce."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve with rice."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
