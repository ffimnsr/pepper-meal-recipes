  "id": "fd6b2f50-983e-5621-8645-714d37466fbc",
  "slug": "macaroni-salad-easy-recipe",
  "name": "Macaroni Salad",
  "recipe_type": "salad",
  "brief_description": "Simple chicken macaroni salad for beginners",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the macaroni based on the package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Boil the chicken breast for 15 minutes. Let it cool down and the shred it into pieces."
    },
    {
      "position": 3,
      "text": "Combine cooked macaroni, shredded chicken, Lady\u2019s Choice Mayonnaise, and all other ingredients in a large bowl. Toss until well blended."
    },
    {
      "position": 4,
      "text": "Season with salt. Refrigerate for at least 2 hours before serving."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy!"
    }
  ],
