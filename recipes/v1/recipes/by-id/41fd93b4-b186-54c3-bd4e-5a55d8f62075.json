  "id": "41fd93b4-b186-54c3-bd4e-5a55d8f62075",
  "slug": "calderetang-baboy-recipe",
  "name": "Calderetang Baboy Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Calderetang Baboy or Pork Kaldereta.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Once the oil becomes hot, pan-fry the carrots and potato until the outer part turns light brown. This should take around 2 to 3 minutes. Set aside."
    },
    {
      "position": 2,
      "text": "Remove excess oil from the pan. Saute onion, garlic, and tomato. Continue to cook until the onion and tomato becomes soft."
    },
    {
      "position": 3,
      "text": "Add the pork belly slices into the pan. Cook until the pork turns light brown."
    },
    {
      "position": 4,
      "text": "Pour tomato sauce into the pan. Stir."
    },
    {
      "position": 5,
      "text": "Add water. Let boil. Cover and cook in low heat for 45 to 60 minutes."
    },
    {
      "position": 6,
      "text": "Add liver spread. Stir until well blended."
    },
    {
      "position": 7,
      "text": "Put the bell peppers into the pan. Stir. Continue to cook in medium heat until the sauce reduces to half."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 9,
      "text": "Add the pan-fried carrot and potato. Stir and cook for 3 to 4 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
