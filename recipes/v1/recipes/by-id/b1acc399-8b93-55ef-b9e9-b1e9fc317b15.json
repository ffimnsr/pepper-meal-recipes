  "id": "b1acc399-8b93-55ef-b9e9-b1e9fc317b15",
  "slug": "ginataang-talong-with-malunggay-and-tofu",
  "name": "Ginataang Talong with Malunggay and Tofu",
  "recipe_type": "salad",
  "brief_description": "Eggplants cooked in coconut milk with tofu as a source of protein and moringa leaves for extra nutrition. This is a healthy eggplant recipe indeed.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saute garlic and onion until the later softens."
    },
    {
      "position": 2,
      "text": "Prepare the coconut milk by combining water and Knorr Ginataang Gulay Recipe Mix. Stir until the mixture gets well blended."
    },
    {
      "position": 3,
      "text": "Pour coconut milk into the pan. Cover and let it boil."
    },
    {
      "position": 4,
      "text": "Add eggplant. Cover the pan and cook for 8 minutes."
    },
    {
      "position": 5,
      "text": "Add air fried tofu. Stir and cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add malunggay leaves. Stir and continue cooking for 1 minute."
    },
    {
      "position": 7,
      "text": "Season with ground black pepper and salt as needed."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
