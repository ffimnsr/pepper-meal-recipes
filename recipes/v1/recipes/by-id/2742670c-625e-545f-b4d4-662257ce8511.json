  "id": "2742670c-625e-545f-b4d4-662257ce8511",
  "slug": "ham-katsu",
  "name": "Ham Katsu",
  "recipe_type": "main",
  "brief_description": "Tonkatsu made from ham steak with homemade tonkatsu sauce",
  "cuisine": "Japanese",
  "instructions": [
    {
      "position": 1,
      "text": "Heat cooking oil in a pan over medium heat."
    },
    {
      "position": 2,
      "text": "Dredge a slice of CDO Holiday Ham in flour, then dip it in beaten egg. Ensure all sides are completely coated before dredging into breadcrumbs, pressing gently so they adhere better."
    },
    {
      "position": 3,
      "text": "Deep-fry the ham katsu until the bottom turns golden brown, then flip and fry the other side until crispy. Remove from the pan and let cool on a wire rack."
    },
    {
      "position": 4,
      "text": "Meanwhile, make the sauce by combining all the tonkatsu sauce ingredients in a small bowl. Mix well."
    },
    {
      "position": 5,
      "text": "Arrange the ham katsu on a serving plate. Serve with homemade tonkatsu sauce. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
