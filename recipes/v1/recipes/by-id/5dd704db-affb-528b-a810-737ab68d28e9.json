  "id": "5dd704db-affb-528b-a810-737ab68d28e9",
  "slug": "pork-dumpling-knr-kls",
  "name": "Pork Dumpling",
  "recipe_type": "appetizer",
  "brief_description": "Easy steamed pork dumpling with a savory filling composed of ground pork, chives, and cabbage, and seasonings. This dim sum dish is perfect to make any day you please.",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Mash the cabbage. Add salt. Continue to mash until salt is well distributed. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Combine ground pork, shrimp, ginger, and chives in bowl. Mix well."
    },
    {
      "position": 3,
      "text": "Add cabbage, ground white pepper, cooking wine, Sesame oil, and Knorr liquid seasoning. Continue to mix until all ingredients are well blended."
    },
    {
      "position": 4,
      "text": "Scoop 1 \u00bd teaspoon of pork mixture and place it in the middle of the Gyoza wrapper. Secure the filling by symmetrically folding the wrapper and pressing the edges. You may also press using the tip of a fork."
    },
    {
      "position": 5,
      "text": "Arrange the pork dumplings on a steamer lined with cabbage leaves. Cover and steam for 10 minutes."
    },
    {
      "position": 6,
      "text": "Serve with dipping sauce. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
