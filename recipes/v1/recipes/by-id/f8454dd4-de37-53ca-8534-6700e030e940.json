  "slug": "pulled-pork-sandwich-recipe",
  "name": "Pulled Pork Sandwich Recipe",
  "recipe_type": null,
  "brief_description": "If you adore pulled pork then this simple Pulled Pork Sandwich Recipe is for you. This is a quick pulled pork sandwich idea that you can use if you have pulled pork around.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the pulled pork by following the recipe provided using the link above. Make sure to only do a quarter of the recipe to produce 1 lb. of pulled pork."
    },
    {
      "position": 2,
      "text": "Place the bread slices in an oven toaster. Toast."
    },
    {
      "position": 3,
      "text": "Spread chipotle mayonnaise on each side of 2 bread slices."
    },
    {
      "position": 4,
      "text": "Arrange the Pulled Pork over one side of the bread with chipotle mayo. Put the other slice of bread on top of the pulled pork.Make sure that the side with chipotle mayonnaise is facing down this time."
    },
    {
      "position": 5,
      "text": "Serve. Share and enjoy with homemade potato chips."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
