  "id": "af91ef40-9495-5f99-a830-74d0c4888f2f",
  "slug": "puchero-bulalo-recipe-beef-shank-stew",
  "name": "Puchero Bulalo",
  "recipe_type": null,
  "brief_description": "This is a recipe for Puchero Bulalo",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot or pressure cooker. Once hot, sear one side of the beef shank for 2 minutes. Turn it over to sear the other side for another 2 minutes.Remove the beef shank and set aside."
    },
    {
      "position": 2,
      "text": "Pour oil into the pressure cooker. Saute onion, garlic, and tomato."
    },
    {
      "position": 3,
      "text": "Add Chinese sausage or chorizo de bilbao. Saute for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add the seared bulalo back into the pressure cooker."
    },
    {
      "position": 5,
      "text": "Pour tomato sauce and beef broth. Let boil. Cover the pressure cooker and pressure cook for 20 to 30 minutes."
    },
    {
      "position": 6,
      "text": "Let the pressure out of the pressure cooker and then remove the cover."
    },
    {
      "position": 7,
      "text": "Add the saba banana, garbanzos, and potato. Continue to cook for 5 to 8 minutes."
    },
    {
      "position": 8,
      "text": "Add long green beans, bok choy, and cabbage. Stir. Cook for 3 to 5 minutes."
    },
    {
      "position": 9,
      "text": "Add fish sauce and ground black pepper. Stir."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve!"
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
