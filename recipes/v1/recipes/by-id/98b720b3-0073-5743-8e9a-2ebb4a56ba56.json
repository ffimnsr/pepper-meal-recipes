  "id": "98b720b3-0073-5743-8e9a-2ebb4a56ba56",
  "slug": "chicken-liver-and-gizzard-stew-with-quail-eggs-and-snap-peas",
  "name": "Chicken Liver and Gizzard Stew with Quail Eggs and Snap Peas",
  "recipe_type": "main",
  "brief_description": "Stewed chicken liver and gizzard with quail eggs.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine 2 cups water and quail eggs in a cooking pot. Let the water boil. Once the water starts to boil, adjust heat to medium. Boil eggs for 3 minutes. Discard water. Let the eggs cool down and then peel-off the shell. Set the eggs aside."
    },
    {
      "position": 2,
      "text": "Boil 4 cups water in a pot. Add the gizzards. Continue to boil for 40 to 60 minutes or until the gizzards are tender. Discard the water. Set gizzards aside."
    },
    {
      "position": 3,
      "text": "Combine liver and oyster sauce. Mix well. Add cornstarch and then gently mix until all ingredients are well distributed."
    },
    {
      "position": 4,
      "text": "Heat \u00bc cup oil in a pan. Add the liver. Pan-fry each side for 1 minute. Remove from the pan. Set aside."
    },
    {
      "position": 5,
      "text": "Heat 3 tablespoons oil in a pan. Once the oil gets hot, saute onion and garlic."
    },
    {
      "position": 6,
      "text": "Add the boiled chicken gizzard once the onion softens. Stir-fry for 1 minute."
    },
    {
      "position": 7,
      "text": "Pour soy sauce, vinegar, and \u00be cup water into the pan. Cover and cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Add the chicken liver. Stir. Cover the pan and continue to cook for 5 to 8 minutes. Note: add more water if needed."
    },
    {
      "position": 9,
      "text": "Put the snap peas and bell pepper into the pan. Cook for 2 minutes."
    },
    {
      "position": 10,
      "text": "Add sugar and then season with ground black pepper and salt."
    },
    {
      "position": 11,
      "text": "Put the boiled eggs into the pan. Stir."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Serve with warm white rice."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
