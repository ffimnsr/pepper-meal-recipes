  "id": "c830281a-1b4e-5e83-8793-b3aee1732911",
  "slug": "chicken-binagoongan-recipe",
  "name": "Chicken Binagoongan",
  "recipe_type": "main",
  "brief_description": "Easy Filipino chicken stew cooked with shrimp paste.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saut\u00e9 onion for 25 seconds."
    },
    {
      "position": 2,
      "text": "Add the garlic. Saut\u00e9 for 30 seconds."
    },
    {
      "position": 3,
      "text": "Add tomato. Continue cooking until the tomato softens."
    },
    {
      "position": 4,
      "text": "Put the chicken into the pan. Saut\u00e9 until the color of the outer part turns medium brown."
    },
    {
      "position": 5,
      "text": "Add bagoong alamang (shrimp paste). Cook for 1 minute."
    },
    {
      "position": 6,
      "text": "Pour vinegar into the pan. Let the liquid boil."
    },
    {
      "position": 7,
      "text": "Pour water into the pan. Cover and then let it boil. Boil for 5 minutes."
    },
    {
      "position": 8,
      "text": "Add winged beans (sigarilyas). Cover and then cook between low to medium heat for 30 minutes."
    },
    {
      "position": 9,
      "text": "Season with sugar and add more shrimp paste if needed."
    },
    {
      "position": 10,
      "text": "Add chili and long green pepper. Cook for 3 minutes."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl. Serve with warm rice."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
