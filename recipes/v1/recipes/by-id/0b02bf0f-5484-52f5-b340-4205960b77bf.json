  "id": "0b02bf0f-5484-52f5-b340-4205960b77bf",
  "slug": "baked-spaghetti",
  "name": "Baked Spaghetti",
  "recipe_type": "main",
  "brief_description": "Creamy and spaghetti baked with mozzarella.",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Cook spaghetti based on package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Make the sauce by browning the ground beef in a pan until beef fat gets rendered. Separate the oil from the meat using a sieve or colander. Note: leave around 2 tablespoons of oil for sauteing."
    },
    {
      "position": 3,
      "text": "Heat remaining oil in the pan and then saute garlic and onion."
    },
    {
      "position": 4,
      "text": "Add the ground beef back into the pan and saute for 3 minutes."
    },
    {
      "position": 5,
      "text": "Pour diced tomato and tomato sauce into the pan. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add Italian seasoning and Knorr Beef Cube. Stir and cover the pan. Adjust heat to low setting and continue cooking for 25 minutes. Note: add water if needed. Season with salt and ground black pepper."
    },
    {
      "position": 7,
      "text": "Combine spaghetti and sauce. Toss until all ingredients are well distributed. Arrange the mixture on a baking pan and top with mozzarella. Bake at 350F for 30 minutes."
    },
    {
      "position": 8,
      "text": "Serve with buttered toast or garlic bread."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": null,
  "preparation_time_minutes": 10,
