  "slug": "burong-mustasa-pickled-flat-mustard-greens",
  "name": "Burong Mustasa (Pickled Flat Mustard Greens)",
  "recipe_type": null,
  "brief_description": "This is a recipe for Burong Mustasa (Pickled Flat Mustard Greens)",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Wash the flat mustard leaves and pat dry. Soak under the sun for 1 hour or until wilted."
    },
    {
      "position": 2,
      "text": "Meanwhile, prepare the rice water by combining rice and water in a pot. Cover and cook the rice in medium heat until soft."
    },
    {
      "position": 3,
      "text": "Combine salt and mustard leaves in a bowl. Gently mash the mixture. Arrange in a resealable jar."
    },
    {
      "position": 4,
      "text": "Place a mesh strainer over the jar. Pour the rice water from the pot. Note: the soft rice should be filtered by the mesh. We only need the water for this process."
    },
    {
      "position": 5,
      "text": "Cover the jar. Let it stay in room temperature for 4 to 6 days."
    },
    {
      "position": 6,
      "text": "Serve as an appetizer or use an ingredient to cook fish, egg, and other dishes. You can stock it in cooler temperature (50 to 55F) for the flavor to develop further."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 60,
