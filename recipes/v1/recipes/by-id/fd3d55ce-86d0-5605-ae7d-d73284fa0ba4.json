  "id": "fd3d55ce-86d0-5605-ae7d-d73284fa0ba4",
  "slug": "microwave-brownie-in-a-bowl",
  "name": "Microwave Brownie in a Bowl",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Microwave Brownie",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the dry ingredients in a bowl. Start with the flour, cocoa, sugar, and salt. Mix well using a spoon."
    },
    {
      "position": 2,
      "text": "Add the butter, water, and vanilla extract. Continue to mix until all the ingredients are well incorporated."
    },
    {
      "position": 3,
      "text": "Compress the mixture by sliding a spoon on top of it. The top portion should be flat."
    },
    {
      "position": 4,
      "text": "Microwave for 90 to 100 seconds."
    },
    {
      "position": 5,
      "text": "Remove from the microwave and let it cool down."
    },
    {
      "position": 6,
      "text": "Enjoy with scoop of vanilla ice cream."
    }
  ],
  "servings": 1,
  "cooking_time_minutes": 2,
