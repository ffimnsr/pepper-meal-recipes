  "id": "046cebbb-54db-5464-86c7-f0d7fe69843b",
  "slug": "daing-na-bangus-fried-milkfish-marinated-in-vinegar",
  "name": "Daing na Bangus Recipe",
  "recipe_type": null,
  "brief_description": "Daing na bangus is a fried milkfish dish wherein the fish is marinated in a vinegar mixture and then fried until brown and crispy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine vinegar, pepper, salt, garlic, and cayenne pepper powder in a bowl. Stir to mix the ingredients. Set aside."
    },
    {
      "position": 2,
      "text": "Butterfly the bangus (slice from the top) and the place it inside a large re-sealable plastic bag."
    },
    {
      "position": 3,
      "text": "Pour the vinegar mixture in the bag and then let all the air out. Seal the bag and refrigerate overnight."
    },
    {
      "position": 4,
      "text": "Remove the fish from the bag and let the liquid drip."
    },
    {
      "position": 5,
      "text": "Heat the cooking oil in a pan. Once the oil gets hot, fry the fish in medium heat until one side gets crisp. Turn it over and repeat the process on the other side."
    },
    {
      "position": 6,
      "text": "Remove from the pan and place in a serving plate. Serve with bowl of spicy vinegar."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 60,
