  "id": "73696ccc-feeb-5bbf-a286-56c9c9a2a21b",
  "slug": "easy-chicken-tinola-recipe",
  "name": "Easy Chicken Tinola Recipe",
  "recipe_type": "soup",
  "brief_description": "Tinola is a Filipino Chicken Soup Dish. This easy chicken tinola recipe is composed of chicken and vegetables along with a good amount of ginger.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "When the oil becomes hot, saut\u00e9 the ginger, garlic and onion"
    },
    {
      "position": 3,
      "text": "Once the onion is soft, put-in the chopped chicken. Cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in the chicken broth. Let boil and then simmer for 20 to 25 minutes."
    },
    {
      "position": 5,
      "text": "Add the chayote wedges. Cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Put-in the hot pepper and/or malunggay leaves."
    },
    {
      "position": 7,
      "text": "Add the ground black pepper and fish sauce. Stir."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 9,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
