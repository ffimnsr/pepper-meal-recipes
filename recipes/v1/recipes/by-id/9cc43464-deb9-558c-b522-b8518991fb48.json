  "slug": "ginataang-galunggong-recipe",
  "name": "Ginataang Galunggong Recipe",
  "recipe_type": null,
  "brief_description": "Ginataang Galunggong refers to round scad cooked in coconut milk. This is a tasty and rich Filipino fish dish that is great to pair with rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour the coconut milk in a wide cooking pot. Let it boil."
    },
    {
      "position": 2,
      "text": "Add the garlic, ginger, onion, fish sauce, and ground black pepper. Stir. Cover and cook for 5 minutes."
    },
    {
      "position": 3,
      "text": "Arrange the fish in the cooking pot along with the Serrano pepper. Cover and then continue cooking in medium heat for 30 minutes."
    },
    {
      "position": 4,
      "text": "Remove the cover. Let the sauce reduce to about 1/2 to 3/4 cups."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve with warm rice."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
