  "id": "559cbae0-a4b6-5d47-8e5a-d889b782dc9c",
  "slug": "pepper-crusted-filet-mignon",
  "name": "Pepper Crusted Filet Mignon",
  "recipe_type": null,
  "brief_description": "Pepper Crusted Filet Mignon. Make your own filet mignon the easy way by following this recipe step by step.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt on all sides of the steak, then rub with cracked pepper."
    },
    {
      "position": 2,
      "text": "Heat a pan over medium-high heat, then pour in 2 tablespoons of olive oil (add more if needed)."
    },
    {
      "position": 3,
      "text": "When the oil is hot, pan-fry the steak for 3 minutes per side. Note: If the cut is thick, sear the sides as well."
    },
    {
      "position": 4,
      "text": "Preheat the oven to 350 degrees Fahrenheit."
    },
    {
      "position": 5,
      "text": "Bake the pan-fried steak for 6 to 8 minutes."
    },
    {
      "position": 6,
      "text": "Transfer the steak to a plate and set aside."
    },
    {
      "position": 7,
      "text": "In the same pan used for the steaks, add 1 tablespoon of olive oil (omit if there is enough oil remaining)."
    },
    {
      "position": 8,
      "text": "Heat the pan and add the onions. Cook for 2 to 3 minutes, until softened."
    },
    {
      "position": 9,
      "text": "Pour in the red wine and simmer until reduced by half."
    },
    {
      "position": 10,
      "text": "Return the steak to the pan and cook for 30 seconds per side."
    },
    {
      "position": 11,
      "text": "Turn off the heat, then transfer the steak to a serving plate."
    },
    {
      "position": 12,
      "text": "Pour the red wine sauce over the steak."
    },
    {
      "position": 13,
      "text": "Serve with blanched asparagus and mashed potatoes."
    },
    {
      "position": 14,
      "text": "Serve immediately and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
