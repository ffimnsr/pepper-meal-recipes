  "id": "321a08e2-64dc-555b-8e1e-40d9a01aee10",
  "slug": "cheesy-chicken-afritada-recipe",
  "name": "Cheesy Chicken Afritada Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Cheesy Chicken Afritada",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot"
    },
    {
      "position": 2,
      "text": "Pan-fry the chicken for 1 to 2 minutes per side. Remove from the pot and transfer to a clean plate. Set aside."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 onion on the remaining oil for 20 seconds"
    },
    {
      "position": 4,
      "text": "Add garlic. Continue to saut\u00e9 until the onion softens."
    },
    {
      "position": 5,
      "text": "Put the pan-fried chicken back into the cooking pot. Saute for 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour tomato sauce into the pot and add chicken broth. Let boil."
    },
    {
      "position": 7,
      "text": "Cover and continue to cook using medium heat for 40 to 45 minutes."
    },
    {
      "position": 8,
      "text": "Add potato and carrot. Stir. Cook for 5 to 7 minutes."
    },
    {
      "position": 9,
      "text": "Add bell pepper. Cook for 3 minutes."
    },
    {
      "position": 10,
      "text": "Season with salt and ground black pepper"
    },
    {
      "position": 11,
      "text": "Add cheese. Stir and cook for 1 minute."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 13,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
