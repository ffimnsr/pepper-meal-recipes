  "id": "769eff49-d2af-598f-bc76-16c19d7ccd3c",
  "slug": "skinless-longganisa-recipe",
  "name": "Skinless Longganisa",
  "recipe_type": "dessert",
  "brief_description": "This is a basic recipe for Filipino sweet and garlicky skinless longganisa.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Peel the skin off the garlic cloves. Crush thoroughly using mortar and pestle. Mince the crushed garlic. Set aside."
    },
    {
      "position": 2,
      "text": "In a large mixing bowl, combine ground pork along with all of the ingredients. Mix well."
    },
    {
      "position": 3,
      "text": "Cover the bowl. Refrigerate for 2 hours."
    },
    {
      "position": 4,
      "text": "Shape the longganisa by laying a sheet of wax paper on a flat surface. Scoop around 3 tablespoons of mixture and put over the wax paper. Fold the wax paper from top to down until the mixture covered. Hold the edge of the paper with your fingers and then slide the card towards the mixture. Push a bit more until a sausage shape is formed. Do this step until the entire mixture is consumed."
    },
    {
      "position": 5,
      "text": "Cook the longganisa by combining 1 cup water and 4 tablespoons of cooking oil in a pan."
    },
    {
      "position": 6,
      "text": "Add the longganisa and then turn the heat on. Let the liquid boil, and then adjust to the lowest heat setting. Continue boiling until the water completely evaporates."
    },
    {
      "position": 7,
      "text": "Fry both sides of the longganisa in the remaining oil until it turns brown."
    },
    {
      "position": 8,
      "text": "Remove from the pan and arrange on a serving plate. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 26,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 15,
