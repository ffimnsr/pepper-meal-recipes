  "id": "a00c486f-681e-5053-bd29-82d4b5c6f1b0",
  "slug": "chicken-afritada-recipe",
  "name": "Chicken Afritada Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Filipino Afritadang Manok.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot. Saute onion and garlic until the onion softens."
    },
    {
      "position": 2,
      "text": "Add chicken. Cook for 30 seconds. Turn it over and cook the other side for another 30 seconds."
    },
    {
      "position": 3,
      "text": "Pour tomato sauce and chicken broth. Cover. Let boil."
    },
    {
      "position": 4,
      "text": "Add dried bay leaves. Cover the cooking pot. Continue to cook in medium heat for 30 minutes."
    },
    {
      "position": 5,
      "text": "Add hotdogs and carrot. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add potato. Cover the pot and cook for 8 minutes."
    },
    {
      "position": 7,
      "text": "Add green peas. Cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper"
    },
    {
      "position": 9,
      "text": "Serve!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
