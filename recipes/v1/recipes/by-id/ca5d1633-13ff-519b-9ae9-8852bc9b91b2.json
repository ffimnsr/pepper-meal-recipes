  "id": "ca5d1633-13ff-519b-9ae9-8852bc9b91b2",
  "slug": "tinolang-tahong",
  "name": "Tinolang Tahong Recipe",
  "recipe_type": "soup",
  "brief_description": "Fresh mussels in ginger broth with long green pepper and hot pepper leaves.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour-in cooking oil."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Add ginger and mussels, and then cook for a minute."
    },
    {
      "position": 4,
      "text": "Pour-in water. let boil. Cook for&nbsp;5 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the spinach or hot pepper leaves. Cook for 3 minutes."
    },
    {
      "position": 6,
      "text": "Add salt (or fish sauce) and pepper. Stir."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl.&nbsp;Serve. Share and enjoy."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
