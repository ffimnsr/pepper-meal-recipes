  "id": "2402da82-085f-504f-bcc8-1b77ee184bb6",
  "slug": "kare-kare-recipe",
  "name": "Kare Kare",
  "recipe_type": "main",
  "brief_description": "A traditional Filipino oxtail and peanut stew with vegetables, served with shrimp paste",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a large pot, bring the water to a boil"
    },
    {
      "position": 2,
      "text": "Put in the oxtail followed by the onions and simmer for 2.5 to 3 hrs or until tender (35 minutes if using a pressure cooker)"
    },
    {
      "position": 3,
      "text": "Once the meat is tender, add the ground peanuts, peanut butter, and coloring (water from the annatto seed mixture) and simmer for 5 to 7 minutes"
    },
    {
      "position": 4,
      "text": "Add the toasted ground rice and simmer for 5 minutes"
    },
    {
      "position": 5,
      "text": "On a separate pan, saute the garlic then add the banana flower, eggplant, and string beans and cook for 5 minutes"
    },
    {
      "position": 6,
      "text": "Transfer the cooked vegetables to the large pot (where the rest of the ingredients are)"
    },
    {
      "position": 7,
      "text": "Add salt and pepper to taste"
    },
    {
      "position": 8,
      "text": "Serve hot with shrimp paste. Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 150,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "expert",
