  "id": "38f11279-66a4-508d-a6be-f7ba54655905",
  "slug": "gotong-batangas-recipe",
  "name": "Gotong Batangas Recipe",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for Gotong Batangas (beef innards soup)",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a large cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add all the beef innards. Cover and cook in medium heat for 30 minutes."
    },
    {
      "position": 3,
      "text": "Discard the water. Pour rice washing into the pot. Let boil."
    },
    {
      "position": 4,
      "text": "Add salt, crushed peppercorn, garlic powder, onion, chili, and annatto water. Stir."
    },
    {
      "position": 5,
      "text": "Add beef bouillon. Cover and cook in low heat for 4 hours."
    },
    {
      "position": 6,
      "text": "Remove the innards from the cooking pot. Slice into serving pieces."
    },
    {
      "position": 7,
      "text": "Arrange in a bowl. Pour hot broth in the bowl and top with chopped green onions and chili."
    },
    {
      "position": 8,
      "text": "Serve with a dipping sauce composed of chopped onion, soy sauce, calamansi, and chili."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 240,
  "preparation_time_minutes": 10,
