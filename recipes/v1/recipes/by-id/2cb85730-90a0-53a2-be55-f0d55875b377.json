  "id": "2cb85730-90a0-53a2-be55-f0d55875b377",
  "slug": "pork-monggo-chicharon-malunggay-recipe",
  "name": "Pork Monggo Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pork Monggo or stewed mung beans with pork",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute garlic, onion, and tomato."
    },
    {
      "position": 3,
      "text": "Add the pork. Cook until the color of the pork turns light brown."
    },
    {
      "position": 4,
      "text": "Pour water into the pot. Let boil"
    },
    {
      "position": 5,
      "text": "Add the pork cube. Stir."
    },
    {
      "position": 6,
      "text": "Add the mung beans. Cover and adjust the heat between low to medium. Continue to cook until the mung beans becomes tender. Add more water, if necessary."
    },
    {
      "position": 7,
      "text": "Put the malunggay leaves and spinach in the cooking pot. Stir and cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Add ground black pepper and fish sauce. Cook for 2 to 3 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Top with chicharon."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
