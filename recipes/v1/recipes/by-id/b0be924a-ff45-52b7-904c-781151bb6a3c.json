  "id": "b0be924a-ff45-52b7-904c-781151bb6a3c",
  "slug": "easy-callos-recipe",
  "name": "Easy Callos Recipe",
  "recipe_type": "side",
  "brief_description": "Beef Tripe tastes great when cooked properly and mixed with the right ingredients. This Easy Callos Recipe is a good example aside from Kare-kare.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the oil gets hot, saute the onion. Add the whole peppercorn and continue to cook until the onions get soft."
    },
    {
      "position": 3,
      "text": "Add the cooked tripe. Saute for 2 to 3 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the chinese sausage. Stir and cook for 2 minute."
    },
    {
      "position": 5,
      "text": "Pour-in the tomato sauce. Add the beef broth. Stir. Let boil. cover and simmer for 30 minutes."
    },
    {
      "position": 6,
      "text": "Add the pork and beans. Stir. Cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Put-in the sweet peppers. Cook for 4 to 6 minutes."
    },
    {
      "position": 8,
      "text": "Add the garlic powder and salt to taste. Stir."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Top with chopped green onions."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
