  "id": "cf4ad511-d2f7-5783-baa0-b015b5950c0b",
  "slug": "beef-tinola-recipe",
  "name": "Beef Tinola Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Filipino Beef Tinola",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pressure cooker."
    },
    {
      "position": 2,
      "text": "Once the oil becomes hot, saute garlic and onion for 30 seconds."
    },
    {
      "position": 3,
      "text": "Add ginger. Continue to cook until onion gets soft."
    },
    {
      "position": 4,
      "text": "Put the beef chuck into the pressure cooker. Cook until brown."
    },
    {
      "position": 5,
      "text": "Pour beef broth and water. Let boil."
    },
    {
      "position": 6,
      "text": "Cover the pressure cooker and then pressure cook for 40 minutes."
    },
    {
      "position": 7,
      "text": "Safely remove the cover and then add green papaya and long green chili peppers. Cook for 8 to 10 minutes."
    },
    {
      "position": 8,
      "text": "Season with ground black pepper and fish sauce. Stir."
    },
    {
      "position": 9,
      "text": "Turn the heat off. Add spinach (or malunggay leaves). Let the residual het cook the leafy greens for 3 minutes."
    },
    {
      "position": 10,
      "text": "Transfer to a serving bowl. Serve hot."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
