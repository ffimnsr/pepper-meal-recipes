  "id": "65e558d2-4fc5-571f-93eb-38eada60bdf3",
  "slug": "fried-battered-fish-whiting",
  "name": "Fried Whiting Fish Recipe",
  "recipe_type": "main",
  "brief_description": "Fried whiting fish is a fried fish fillet recipe that requires the fish to be dipped in a simple batter before being deep fried.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the batter by combining the flour, garlic powder, milk, water, salt, and ground black pepper in a bowl. Whisk until well incorporated."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a deep pan or cooking pot."
    },
    {
      "position": 3,
      "text": "Dip the fish fillets in the batter. Make sure that the entire fillet is coated."
    },
    {
      "position": 4,
      "text": "Deep fry in medium heat until the color turns golden brown (about 5 to 7 minutes)."
    },
    {
      "position": 5,
      "text": "Remove the fish from the fryer. Transfer to a serving plate."
    },
    {
      "position": 6,
      "text": "Serve with Braised Collard Greens."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 7,
  "preparation_time_minutes": 10,
