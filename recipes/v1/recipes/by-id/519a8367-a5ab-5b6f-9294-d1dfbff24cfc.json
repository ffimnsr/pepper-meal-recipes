  "id": "519a8367-a5ab-5b6f-9294-d1dfbff24cfc",
  "slug": "classic-tinolang-manok-recipe",
  "name": "Classic Tinolang Manok Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Classic Tinolang Manok. It is also known as Filipino Chicken Tinola",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic, onion, and ginger. Add the ground black pepper."
    },
    {
      "position": 3,
      "text": "When the onion starts to get soft, add the chicken. Cook for 5 minutes or until it turns light brown."
    },
    {
      "position": 4,
      "text": "Pour the water. Let boil. Cover and then set the heat to low. Boil for 40 minutes."
    },
    {
      "position": 5,
      "text": "Scoop and discard the scums and oil on the soup."
    },
    {
      "position": 6,
      "text": "Add the Knorr chicken cube and chayote or papaya. Stir. Cover and cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Put the malunggay and hot pepper leaves in the pot and pour the fish sauce in. Continue to cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
