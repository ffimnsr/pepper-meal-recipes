  "id": "147f382d-7658-5568-b852-33dd1dbac324",
  "slug": "salted-egg-chicken",
  "name": "Salted Egg Chicken",
  "recipe_type": "main",
  "brief_description": "Crispy fried chicken tossed in a rich and creamy salted egg glaze with butter, curry leaves, and chilies.",
  "cuisine": "Malaysian Singaporean",
  "instructions": [
    {
      "position": 1,
      "text": "Place chicken in a bowl. Add Maggi Magic Sarap, then coat with beaten egg. Dredge in cornstarch and flour until well covered."
    },
    {
      "position": 2,
      "text": "Heat oil in a deep pan over medium high heat. Fry chicken in batches until golden and crispy, about 4\u20135 minutes per batch. Drain excess oil on paper towels."
    },
    {
      "position": 3,
      "text": "In a clean pan, melt butter over low heat. Add garlic and saut\u00e9 until lightly golden and fragrant."
    },
    {
      "position": 4,
      "text": "Add sliced chilies and curry leaves. Cook for 30 seconds until fragrant."
    },
    {
      "position": 5,
      "text": "Add mashed salted egg yolks. Stir until bubbly and foamy. Pour in Carnation Everyday Creamer and stir until smooth and slightly thick."
    },
    {
      "position": 6,
      "text": "Season glaze with sugar and a pinch of salt. Toss in fried chicken and mix quickly until evenly coated. Transfer to a plate and serve hot with rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
