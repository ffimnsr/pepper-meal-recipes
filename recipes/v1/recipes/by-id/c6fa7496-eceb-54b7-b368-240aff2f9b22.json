  "id": "c6fa7496-eceb-54b7-b368-240aff2f9b22",
  "slug": "fettuccine-pasta-with-tomato-meat-sauce",
  "name": "Fettuccine Pasta with Tomato Meat Sauce",
  "recipe_type": null,
  "brief_description": "Fettuccine Pasta with Tomato Meat Sauce is a fresh tasting pasta recipe that you can enjoy anytime. Preparing this is real quick and easy.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the olive oil in a pan."
    },
    {
      "position": 2,
      "text": "Put the onion in and then cook for 3 minutes or until it becomes soft."
    },
    {
      "position": 3,
      "text": "Add the ground beef and pork. Stir and then cook until the meat turns brown."
    },
    {
      "position": 4,
      "text": "Pour the marinara sauce in. Stir. Bring to a boil."
    },
    {
      "position": 5,
      "text": "Add the Italian seasoning, salt, and pepper. Simmer for 10 to 15 minutes."
    },
    {
      "position": 6,
      "text": "Arrange the Fettuccine pasta in individual pasta bowls."
    },
    {
      "position": 7,
      "text": "Pour the tomato meat sauce on top. Sprinkle some cheddar or parmesan cheese."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 5,
