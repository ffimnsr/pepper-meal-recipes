  "slug": "spicy-sardinas-with-patola-and-miswa",
  "name": "Spicy Sardinas with Patola and Miswa",
  "recipe_type": null,
  "brief_description": "This is a recipe for Spicy Sardinas with Patola and Miswa",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Add onion. Saute until soft."
    },
    {
      "position": 3,
      "text": "Pour the sardines into the pot, including the sauce. Add chili peppers and garlic powder. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour water into the cooking pot. Stir. Let boil."
    },
    {
      "position": 5,
      "text": "Add miswa and patola. Continue to cook for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Season with patis and ground black pepper."
    },
    {
      "position": 7,
      "text": "Transfer to a bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
