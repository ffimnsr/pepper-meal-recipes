  "id": "f7aabda0-1384-501f-a34e-3a568e730532",
  "slug": "grilled-cheese-sandwich-and-homemade-chicken-tenders-recipe",
  "name": "Grilled Cheese Sandwich and Chicken Tenders",
  "recipe_type": "snack",
  "brief_description": "Easy grilled cheese sandwich and air fried chicken tenders.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the chicken by rubbing salt all over it. Let it stay for 5 minutes."
    },
    {
      "position": 2,
      "text": "Combine Lady\u2019s Choice Mayonnaise and Dijon mustard in a bowl. Mix well. Coat the chicken with the mixture."
    },
    {
      "position": 3,
      "text": "Dredge the chicken in Panko breadcrumbs. Arrange in a clean plate. Set it on the side for 15 minutes. Note: this will help the breadcrumbs stick better."
    },
    {
      "position": 4,
      "text": "Heat oil in a pan. Partially fry both sides of the chicken until the breading turns light brown."
    },
    {
      "position": 5,
      "text": "Transfer the chicken to an air fryer and air-fry for 15 to 18 minutes at 360F. Remove from the air fryer and set aside."
    },
    {
      "position": 6,
      "text": "Meanwhile make the grilled cheese sandwich by heating a non-stick pan. Spread Lady\u2019s Choice Mayonnaise on one side of each slice of bread. Put the bread with the Mayo side down into the pan. Top one side with cheese slices."
    },
    {
      "position": 7,
      "text": "Cover the cheese with the other bread slice, brown part facing up. Continue cooking using low to medium heat setting while flipping the bread until the cheese completely melts."
    },
    {
      "position": 8,
      "text": "Remove the grilled cheese from the pan. You can slice it if preferred. Serve right away with chicken tenders. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
