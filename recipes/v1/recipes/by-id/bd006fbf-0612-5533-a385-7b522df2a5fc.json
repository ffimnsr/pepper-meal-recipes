  "id": "bd006fbf-0612-5533-a385-7b522df2a5fc",
  "slug": "tocino-fried-rice-recipe",
  "name": "Tocino Fried Rice Recipe",
  "recipe_type": "side",
  "brief_description": "Easy fried rice with tocino, eggs, and vegetables",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat 3 tablespoons of cooking oil in a pan. Adjust your stove between low to medium heat setting. Fry both sides of our CDO Funtastyk Young Pork Tocino until it browns (note: no need to boil). Remove the tocino from the pan. Slice it into serving pieces. Set aside."
    },
    {
      "position": 2,
      "text": "Crack the eggs and beat. Heat the same pan and add the remaining 2 tablespoons of cooking oil. Fry the beaten egg until done. Put it on a clean plate and cut into small pieces. Set aside."
    },
    {
      "position": 3,
      "text": "Melt butter on the same pan. Add the tocino. Cook for 30 seconds."
    },
    {
      "position": 4,
      "text": "Add the leftover rice. Toss and continue cooking for 3 minutes."
    },
    {
      "position": 5,
      "text": "Season with soy sauce, salt, and ground black pepper. Toss until all ingredients are well blended."
    },
    {
      "position": 6,
      "text": "Add carrots and green peas. Continue cooking for 2 minutes."
    },
    {
      "position": 7,
      "text": "Put the eggs back into the pan. Toss and cook for 30 seconds."
    },
    {
      "position": 8,
      "text": "Transfer the tocino fried rice on a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
