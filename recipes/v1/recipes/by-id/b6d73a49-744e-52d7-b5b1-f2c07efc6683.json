  "id": "b6d73a49-744e-52d7-b5b1-f2c07efc6683",
  "slug": "buttermilk-cornbread",
  "name": "Buttermilk Cornbread",
  "recipe_type": null,
  "brief_description": "Buttermilk Cornbread is a type of cornbread that uses buttermilk as one of its ingredients. Cornbread, on the other hand, is generally defined as a type of quick bread that makes use of cornmeal. This recipe is quick and easy and its outcome is something that you will like.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 375F."
    },
    {
      "position": 2,
      "text": "Combine buttermilk and baking soda. Stir and set aside."
    },
    {
      "position": 3,
      "text": "Beat the eggs and then add the butter and buttermilk mixture while stirring."
    },
    {
      "position": 4,
      "text": "Gradually add-in sugar, salt, cornmeal, flour, and whole kernel corn. Continue mixing until all the ingredients are well incorporated."
    },
    {
      "position": 5,
      "text": "Bake for about 30 to 35 minutes."
    },
    {
      "position": 6,
      "text": "Let the temperature cool. Slice and serve."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 10,
