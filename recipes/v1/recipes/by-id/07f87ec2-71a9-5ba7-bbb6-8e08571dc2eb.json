  "id": "07f87ec2-71a9-5ba7-bbb6-8e08571dc2eb",
  "slug": "dinakdakan-recipe",
  "name": "Dinakdakan Recipe",
  "recipe_type": "appetizer",
  "brief_description": "A smoky, creamy Ilocano pork dish made from grilled pig parts",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour 6 to 8 cups water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Once the water starts to boil, you have the option to add dried bay leaves and whole peppercorn. Add-in the pig ears and face. Set the heat to low and continue to boil for 50 to 60 minutes."
    },
    {
      "position": 3,
      "text": "Discard the water and let the excess water drip. Rub a little bit of salt all over the boiled ears and face. Rub the ginger powder on the liver."
    },
    {
      "position": 4,
      "text": "Heat-up the grill. Grill the ears and face for 4 to 6 minutes per side or until it turns a bit crisp, but not burnt. Grill the liver for 5 to 8 minutes depending on the thickness."
    },
    {
      "position": 5,
      "text": "Remove the grilled pig parts from the grill. Let it cool down and start chopping into bite-size pieces."
    },
    {
      "position": 6,
      "text": "Meanwhile, combine mayonnaise and vinegar in mixing bowl. Stir."
    },
    {
      "position": 7,
      "text": "Add some ground black pepper. Continue to stir until the ingredients are well blended."
    },
    {
      "position": 8,
      "text": "Add the ginger, chili, onion, and garlic powder (optional). Toss."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
