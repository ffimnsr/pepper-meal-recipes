  "id": "98568af3-02a8-54c7-9c11-2c9c8c9b9c04",
  "slug": "easy-guacamole-recipe",
  "name": "Easy Guacamole Recipe",
  "recipe_type": null,
  "brief_description": "Preparing guacamole should be quick and hassle free. This Easy Guacamole Recipe will guide you on how to make fresh guacamole fast.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine avocados, salt, and lime juice. Coat the avocados with lime. Set aside."
    },
    {
      "position": 2,
      "text": "Put together the remaining ingredients in bowl and then shred using a food processor."
    },
    {
      "position": 3,
      "text": "Add the shredded ingredients with the avocado and then mash using a fork of potato masher. Mix well."
    },
    {
      "position": 4,
      "text": "Serve as a dip for tortilla chips or serve with burritos. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 1,
  "preparation_time_minutes": 12,
