  "id": "b21e871a-d7ec-572d-be84-8d8d9a1b53cb",
  "slug": "basic-chicken-afritada",
  "name": "Simple Chicken Afritada",
  "recipe_type": null,
  "brief_description": "This is a recipe for basic chicken afritada. It is the simplest recipe that still provide the traditional yummy taste of this dish.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pot."
    },
    {
      "position": 2,
      "text": "Saute the onion and garlic."
    },
    {
      "position": 3,
      "text": "Add the chicken slices. Continue to saute until the chicken gets light brown."
    },
    {
      "position": 4,
      "text": "Pour the chicken broth and add the tomato paste. Stir and let boil. Add the dried bay leaves and sugar. Cover the pot and adjust the heat to low. Cook for 35 minutes. Note: Add water or chicken broth if it starts to dry-up."
    },
    {
      "position": 5,
      "text": "Add the potato and carrot. Stir. cover and continue to cook in medium heat for 8 to 10 minutes."
    },
    {
      "position": 6,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 55,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
