  "id": "a1ca3e47-5c4e-5e24-928e-9f159b66ec85",
  "slug": "eggplant-with-ground-pork-in-oyster-sauce",
  "name": "Eggplant with Ground Pork in Oyster Sauce",
  "recipe_type": null,
  "brief_description": "Eggplant and ground pork stir-fry with bell pepper.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat 3 tablespoons of cooking oil in a pan. Fry both sides of the sliced eggplants until it softens. Transfer the eggplants on a clean plate. Set aside."
    },
    {
      "position": 2,
      "text": "Add the remaining cooking oil and sesame oil. Saute the onion, garlic, and ginger."
    },
    {
      "position": 3,
      "text": "Add the ground pork once the onion softens. Saute it until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Add soy sauce, oyster sauce, sugar, and water. Continue cooking until the liquid evaporates."
    },
    {
      "position": 5,
      "text": "Add the bell pepper and then put the eggplants back into the pan. Stir fry for 3 minutes."
    },
    {
      "position": 6,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 7,
      "text": "Serve hot over rice. Share and enjoy!"
    }
  ],
