  "id": "d936c34e-5b6e-5ec0-8d42-808c5808cd01",
  "slug": "chicken-alfredo-recipe",
  "name": "Chicken Alfredo",
  "recipe_type": null,
  "brief_description": "Fettuccine pasta with chicken in creamy white sauce.",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Cook fettuccine according to package instructions. Drain water and set aside."
    },
    {
      "position": 2,
      "text": "Season chicken with salt and pepper. Let it stay for 10 minutes."
    },
    {
      "position": 3,
      "text": "Melt 3 tablespoons butter in a pan. Add olive oil."
    },
    {
      "position": 4,
      "text": "Pan-fry chicken for 3 minutes per side. Remove chicken from the pan. Slice into serving pieces. Set aside."
    },
    {
      "position": 5,
      "text": "Melt the remaining butter in the pan. Pour heavy cream. Stir and let boil."
    },
    {
      "position": 6,
      "text": "Add Knorr Chicken Cube. Put the Parmesan cheese into the pan along with the chicken. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add fettucine. Toss. Add parsley and season with ground black pepper."
    },
    {
      "position": 8,
      "text": "Serve warm. Share and enjoy!"
    }
  ],
  "servings": null,
  "cooking_time_minutes": 30,
