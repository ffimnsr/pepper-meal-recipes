  "id": "b25a2903-4d9b-5f39-aae3-8fa99a73ae2c",
  "slug": "chili-garlic-oil-recipe",
  "name": "Chili Garlic Oil Recipe",
  "recipe_type": null,
  "brief_description": "This chili with garlic condiment will increase your appetite and make your meals more enjoyable.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Mince the chili peppers and garlic. Note: you can do it manually or use a food processor. It is also possible to use a blender. In case you decide to go with the latter, the oil should also be added."
    },
    {
      "position": 2,
      "text": "Pour the oil in a pan and then add the minced garlic and chili pepper. Adjust the heat to the lowest setting."
    },
    {
      "position": 3,
      "text": "Add star anise and bay leaves. Cook in a low temperature setting for 30 minutes."
    },
    {
      "position": 4,
      "text": "Remove the star anise and bay leaves. Add vinegar. Continue cooking until the chilies turn dark. Note: this usually takes around 10 minutes. Remember to always set the heat to the lowest setting all throughout the process."
    },
    {
      "position": 5,
      "text": "Turn the heat off. Add hoisin sauce, sugar, and salt. Stir until well blended. Let the chili garlic oil cool down to room temperature."
    },
    {
      "position": 6,
      "text": "Transfer the mixture in a mason jar. Serve as a condiment. Share and enjoy!"
    }
  ],
  "servings": 12,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
