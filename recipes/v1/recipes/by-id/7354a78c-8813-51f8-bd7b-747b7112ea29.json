  "id": "7354a78c-8813-51f8-bd7b-747b7112ea29",
  "slug": "vegetarian-pancit-canton-recipe",
  "name": "Vegetarian Pancit Canton",
  "recipe_type": "main",
  "brief_description": "Filipino pancit with all vegetable ingredients. This dish is both healthy and delicious.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine dried mushrooms and warm water in a bowl. Soak until mushroom softens. Slice mushrooms. Save aside the water for later."
    },
    {
      "position": 2,
      "text": "Heat 3 tablespoons of cooking oil in a pot. Stir-fry snap peas, cabbage, and carrot for 1 \u00bd minutes. Remove and set aside."
    },
    {
      "position": 3,
      "text": "On the same pot, add remaining oil. Saute onion, garlic, and celery until onion softens."
    },
    {
      "position": 4,
      "text": "Add mushrooms. Saute for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add oyster sauce and soy sauce. Pour water used to soak mushrooms. Let boil. Cover and cook in medium heat for 10 minutes."
    },
    {
      "position": 6,
      "text": "Add parsley. Stir."
    },
    {
      "position": 7,
      "text": "Add pancit canton. Cover and cook for 2 minutes. This will allow the noodles to absorb steam to make it softer."
    },
    {
      "position": 8,
      "text": "Toss the noodles. Cover the pot and continue to cook in low heat for 3 minutes."
    },
    {
      "position": 9,
      "text": "Add stir-fried vegetables. Toss."
    },
    {
      "position": 10,
      "text": "Season with ground black pepper. Toss and transfer to a serving plate."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "hard",
