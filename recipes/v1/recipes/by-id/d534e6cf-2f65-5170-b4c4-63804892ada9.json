  "id": "d534e6cf-2f65-5170-b4c4-63804892ada9",
  "slug": "spicy-tokwat-baboy-recipe",
  "name": "Spicy Tokwat Baboy Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Spicy Tokwat Baboy. It is a typoe of Filipino pulutan dish.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour 12 to 15 cups water in a cooking pot. Let boil. Add pig ears and continue to boil in medium heat for 15 minutes."
    },
    {
      "position": 2,
      "text": "Discard the water and let the pig ears cool down. Scrape thoroughly until all the hair and top skin are removed."
    },
    {
      "position": 3,
      "text": "Pour the same amount of water on the same cooking pot. (Note: make sure to throw-out the initial water used.). Let boil."
    },
    {
      "position": 4,
      "text": "Add cinnamon bark, lemongrass, and pig ears. Cover and continue to boil in medium heat for 1 hour or until the ears becomes tender. Note: add more water if needed."
    },
    {
      "position": 5,
      "text": "Meanwhile, heat oil on a pan. Fry one side of the tofu for 4 minutes. Turn it over and fry the opposite side for 4 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Remove from the pan and slice the tofu into cubes. Set aside."
    },
    {
      "position": 7,
      "text": "Remove the pig ears from the pot. Let cool. Slice into serving pieces and then combine with the sliced tofu."
    },
    {
      "position": 8,
      "text": "Prepare the spicy vinegar mixture by combining salt, sugar, vinegar, and soy sauce. Stir. Microwave for 15 seconds. Continue to stir until well blended. Add chili peppers, onion, and ground black pepper to the spicy vinegar mixture. Toss."
    },
    {
      "position": 9,
      "text": "Pour the vinegar mixture all over the tokwat baboy. Toss."
    },
    {
      "position": 10,
      "text": "Top with chopped onion leeks. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 75,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
