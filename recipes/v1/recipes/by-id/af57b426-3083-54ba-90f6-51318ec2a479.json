  "id": "af57b426-3083-54ba-90f6-51318ec2a479",
  "slug": "easy-kung-pao-shrimp-recipe-2",
  "name": "Easy Kung Pao Shrimp Recipe",
  "recipe_type": "main",
  "brief_description": "This Easy Kung Pao Shrimp Recipe is all about making your own homemade kung pao shrimp a little bit quicker. If you were able to see our previous recipe for kung pao shrimp (with video), you know that it demonstrates how to cook the dish from ground-up; this means also making your own kung pao sauce \u2014 which is really easy and delicious.",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan or wok then pour the cooking oil."
    },
    {
      "position": 2,
      "text": "Once the cooking oil gets hot, quickly saute the ginger and garlic. Do this fast to prevent the spices from getting burnt."
    },
    {
      "position": 3,
      "text": "Put-in the dried chili and peanuts. Stir fry for 1 minute."
    },
    {
      "position": 4,
      "text": "Add the onion and zucchini. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Put-in the bell peppers. Stir-fry for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the shrimp. Continue to stir-fry for 2 to 5 minutes. do not overcook the shrimp"
    },
    {
      "position": 7,
      "text": "Pour-in the kung pao sauce. Stir and cook for 1 minute."
    },
    {
      "position": 8,
      "text": "Add the scallions. Sprinkle salt and pepper, if needed. Try to taste your dish at this point to see if you will need to add salt and pepper."
    },
    {
      "position": 9,
      "text": "Stir and transfer to a serving plate."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
