  "id": "098670ad-51ab-5c9c-b083-b48e5cd99c9b",
  "slug": "pulutan-style-beef-caldereta",
  "name": "Filipino Beef Caldereta (Pulutan Style)",
  "recipe_type": "main",
  "brief_description": "Spicy Filipino beef stew with liver spread and peanut butter.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saute onion and garlic until onion softens"
    },
    {
      "position": 2,
      "text": "Add beef. Saute until the outer part turns light brown."
    },
    {
      "position": 3,
      "text": "Add soy sauce. Pour tomato sauce and water. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Beef Cube. Cover the pressure cooker. Cook for 30 minutes."
    },
    {
      "position": 5,
      "text": "Pan-fry carrot and potato until it browns. Set aside."
    },
    {
      "position": 6,
      "text": "Add chili pepper, liver spread and peanut butter. Stir."
    },
    {
      "position": 7,
      "text": "Add bell peppers, fried potato and carrot. Cover the pot. Continue cooking for 5 to 7 minutes."
    },
    {
      "position": 8,
      "text": "Season with salt and ground black pepper. Serve."
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
