  "id": "99adbd9f-bcdb-57a1-8a79-90266744639d",
  "slug": "sarciadong-pechay",
  "name": "Sarciadong Pechay",
  "recipe_type": "main",
  "brief_description": "Baby bok choy with eggs and tomatoes",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saut\u00e9 garlic, onion, and tomatoes."
    },
    {
      "position": 2,
      "text": "Add the pechay. Saut\u00e9 for 20 seconds and then pour water. Let it boil."
    },
    {
      "position": 3,
      "text": "Gently pour the beaten egg around the pan. Stir and continue cooking until the eggs start to solidify."
    },
    {
      "position": 4,
      "text": "Season with fish sauce and ground black pepper. Serve with rice."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 12,
