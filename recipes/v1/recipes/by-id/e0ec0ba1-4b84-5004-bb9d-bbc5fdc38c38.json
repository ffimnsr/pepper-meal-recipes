  "id": "e0ec0ba1-4b84-5004-bb9d-bbc5fdc38c38",
  "slug": "paksiw-na-baboy",
  "name": "Paksiw na Baboy",
  "recipe_type": null,
  "brief_description": "Paksiw na Baboy is a Filipino pork dish cooked in vinegar, soy sauce, garlic, and spices",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Sear the pork until it browns, and enough oil gets extracted."
    },
    {
      "position": 2,
      "text": "Add the garlic. Saut\u00e9 for 1 minute."
    },
    {
      "position": 3,
      "text": "Pour soy sauce and water. Let it boil."
    },
    {
      "position": 4,
      "text": "Add bay leaves and whole peppercorn. Cover the cooking pot. Adjust to a simmer and continue cooking for 30 minutes."
    },
    {
      "position": 5,
      "text": "Adjust the heat setting between low and medium. Add vinegar. Let it boil. Stir."
    },
    {
      "position": 6,
      "text": "Add the banana blossoms. Adjust the heat to the lowest setting. Continue to cook for 30 minutes."
    },
    {
      "position": 7,
      "text": "Add brown sugar and season with Maggi Magic Sarap."
    },
    {
      "position": 8,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 15,
