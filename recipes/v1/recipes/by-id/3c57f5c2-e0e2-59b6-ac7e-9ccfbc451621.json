  "id": "3c57f5c2-e0e2-59b6-ac7e-9ccfbc451621",
  "slug": "lengua-in-white-mushroom-sauce",
  "name": "Lengua in White Mushroom Sauce",
  "recipe_type": null,
  "brief_description": "This is a recipe for Lengua in White Mushroom Sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 6 cups of water in a pressure cooker. Add the ox tongue. Cover the cooker and pressure cook for 35 to 40 minutes or until tender."
    },
    {
      "position": 2,
      "text": "Remove from the pressure cooker. Let it cool down. Peel the outer layer off the tongue. Slice the ox tongue into thin pieces."
    },
    {
      "position": 3,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 4,
      "text": "Saute onion and garlic."
    },
    {
      "position": 5,
      "text": "Add the sliced ox tongue. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour the condensed cream of mushroom and beef broth in the pot. Stir. Let boil. Cover and simmer for 35 minutes."
    },
    {
      "position": 7,
      "text": "Add the sliced mushrooms and whipping cream. Continue to cook for 40 minutes in low heat or until the liquid reduces to half and the sauce starts to thicken."
    },
    {
      "position": 8,
      "text": "Add salt and ground black pepper to taste."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 20,
