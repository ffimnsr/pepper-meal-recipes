  "id": "8db4c8d7-49ef-5631-9a0a-7a01aee95af3",
  "slug": "mechadong-baka-recipe",
  "name": "Mechadong Baka Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Mechadong Baka",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange beef in a bowl. Pour soy sauce and squeeze half a lemon. Mix well. Marinate for 3 hours."
    },
    {
      "position": 2,
      "text": "Heat oil in a pressure cooker."
    },
    {
      "position": 3,
      "text": "Saute onion, garlic, and tomato."
    },
    {
      "position": 4,
      "text": "Once the onion and tomato are soft, add the marinated beef, including the marinade. Continue to cook until the beef browns."
    },
    {
      "position": 5,
      "text": "Pour tomato sauce and beef broth. Let boil."
    },
    {
      "position": 6,
      "text": "Add bay leaves. Pressure cook for 20 to 30 minutes."
    },
    {
      "position": 7,
      "text": "Add potato. Continue to cook uncovered in medium heat for 5 to 8 minutes."
    },
    {
      "position": 8,
      "text": "Add bell pepper. Cook for 8 minutes."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper.Stir."
    },
    {
      "position": 10,
      "text": "Transfer to serving bowl. Serve."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
