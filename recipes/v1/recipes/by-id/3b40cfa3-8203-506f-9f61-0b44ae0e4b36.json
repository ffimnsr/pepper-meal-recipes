  "id": "3b40cfa3-8203-506f-9f61-0b44ae0e4b36",
  "slug": "pancit-udon-recipe",
  "name": "Pancit Udon Recipe",
  "recipe_type": null,
  "brief_description": "Pancit Udon is my own version of Pancit using udon noodles. This Pancit Udon recipe is very easy to follow and it taste really good too.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the udon noodles by boiling the water in a deep cooking pot."
    },
    {
      "position": 2,
      "text": "Once the water starts to boil, put-in the udon noodles, boil for 10 to 12 minutes or until just about right and not soggy."
    },
    {
      "position": 3,
      "text": "Drain the water and place the noodles in a colander or strainer to let the excess water drip. Immediately transfer the noodles to a large bowl and pour-in the olive oil. Gently toss the noodles until covered in olive oil.Set aside. Note: this will prevent the noodles from sticking to each other."
    },
    {
      "position": 4,
      "text": "Meanwhile, heat cooking oil in a a large and wide wok or pan."
    },
    {
      "position": 5,
      "text": "Saute the onion and garlic."
    },
    {
      "position": 6,
      "text": "Add the pork once the onion turns soft. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add-in the squid balls. Cook for another 2 minutes."
    },
    {
      "position": 8,
      "text": "Put-in the carrots and cabbage. Continue to stir fry for 3 minutes."
    },
    {
      "position": 9,
      "text": "Slowly add the noodles in the pan."
    },
    {
      "position": 10,
      "text": "Pour-in the soy sauce and squeeze the lemon. Stir fry for 3 to 5 minutes."
    },
    {
      "position": 11,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 12,
      "text": "Transfer to a serving plate and top with chopped green onions."
    },
    {
      "position": 13,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
