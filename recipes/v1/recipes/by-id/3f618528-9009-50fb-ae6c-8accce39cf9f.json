  "id": "3f618528-9009-50fb-ae6c-8accce39cf9f",
  "slug": "carbonara-recipe-filipino-style-knr-bc",
  "name": "Carbonara Recipe Filipino Style",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pinoy Style Carbonara.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the bacon until crispy. Do this by placing each strip in a pan. Cook in medium heat for 2 minutes. Flip the bacon and cook the opposite side for another 2 minutes. Continue performing the same steps until each piece gets crispy. Set aside. Save the bacon grease."
    },
    {
      "position": 2,
      "text": "Cook the spaghetti by pouring water in a cooking pot. Let boil. Add salt and put the spaghetti into the pot. Cook for 12 minutes or until al dente. Remove the spaghetti. Set aside. Save \u00bc cup of water used to cook spaghetti."
    },
    {
      "position": 3,
      "text": "Prepare the carbonara sauce by heating 3 tablespoons of bacon grease. Saute onion and garlic."
    },
    {
      "position": 4,
      "text": "Once the onion softens, pour all-purpose cream into the pan. Stir. Add \u00bc cup water."
    },
    {
      "position": 5,
      "text": "Add Knorr Beef Cube. Stir until well blended."
    },
    {
      "position": 6,
      "text": "Put chopped bacon and nutmeg into the sauce. Stir."
    },
    {
      "position": 7,
      "text": "Add the cooked spaghetti. Toss until spaghetti gets totally coated with sauce."
    },
    {
      "position": 8,
      "text": "Add Parmesan cheese. Toss. Add more bacon."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve and enjoy!"
    }
  ],
  "servings": null,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
