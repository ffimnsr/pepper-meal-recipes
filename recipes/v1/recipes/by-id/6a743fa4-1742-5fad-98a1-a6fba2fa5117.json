  "id": "6a743fa4-1742-5fad-98a1-a6fba2fa5117",
  "slug": "christmas-lasagna-recipe-easy-knr-bc",
  "name": "Christmas Lasagna",
  "recipe_type": "main",
  "brief_description": "This is a recipe for holiday lasagna. It is rich, tasty, and delicious.",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the meat by heating olive oil in a pot. Add ground beef and ground Italian sausage. Cook until light brown."
    },
    {
      "position": 2,
      "text": "Add onion and garlic. Cook uncovered for 3 minutes."
    },
    {
      "position": 3,
      "text": "Pour-in diced tomato and water. Stir and let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Beef Cube. Stir, and add parsley, basil, and Italian seasoning. Cover and simmer for 40 minutes while stirring every 7 minutes."
    },
    {
      "position": 5,
      "text": "Add Tomato paste and season with sugar, salt, and ground black pepper. Set the meat sauce aside."
    },
    {
      "position": 6,
      "text": "Combine all the cheeses in a large bowl. Mix well."
    },
    {
      "position": 7,
      "text": "Preheat oven to 370F."
    },
    {
      "position": 8,
      "text": "Assemble the lasagna by pouring meat sauce on a baking pan. Make sure to evenly spread the sauce. Top with a layer of lasagna. Spread 1/3 of the cheese mixture over the lasagna and top with meat sauce. Arrange another layer of lasagna on top. Continue to do the same steps until all lasagna are consumed. Finally spread the cheese mixture on the topmost layer and add more Mozzarella cheese."
    },
    {
      "position": 9,
      "text": "Cover the baking pan with aluminum foil. Bake for 25 minutes. Remove the foil and continue to bake for 5 to 10 minutes."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 75,
  "preparation_time_minutes": 15,
