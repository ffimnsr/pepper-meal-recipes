  "slug": "ginataang-mais-filipino-dessert-recipe",
  "name": "Ginataang Mais Recipe",
  "recipe_type": "dessert",
  "brief_description": "Ginataang Mais is sweetened corn cooked in coconut milk. This Recipe is quick and easy to prepare and tastes delicous.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine coconut milk and glutinous rice in a cooking pot then turn on the heat. Let the coconut milk boil."
    },
    {
      "position": 2,
      "text": "Once the coconut milk is boiling, stir the mixture to prevent the glutinous rice from sticking. Set the heat to low and let the rice cook while stirring once in awhile. This will take approximately 12 to 15 minutes."
    },
    {
      "position": 3,
      "text": "Add the whole kernel corn and cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Put-in the sugar and stir thoroughly. Cook for 2 more minutes."
    },
    {
      "position": 5,
      "text": "Transfer to a serving bowl and serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
