  "id": "6236efce-f511-5f2c-a944-c3e3f03149ac",
  "slug": "chicken-gizzard-ginataan",
  "name": "Chicken Gizzard Ginataan",
  "recipe_type": "appetizer",
  "brief_description": "Chicken gizzards cooked in coconut milk",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour the water in a cooking pot. Let it boil."
    },
    {
      "position": 2,
      "text": "Add dried bay leaves and chicken gizzards. Reduce the heat to medium setting. Boil until the gizzard becomes tender (around 35 to 45 minutes). Remove the gizzards from the pot and set it aside."
    },
    {
      "position": 3,
      "text": "Heat the oil in a wok. Saut\u00e9 the garlic, ginger, and onion."
    },
    {
      "position": 4,
      "text": "Add the boiled gizzards once the onion softens. Saut\u00e9 for 2 minutes."
    },
    {
      "position": 5,
      "text": "Pour-in the coconut milk. Let it boil. Simmer until it reduces to half."
    },
    {
      "position": 6,
      "text": "Add the bell pepper. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Add the kangkong leaves. Season with fish sauce and ground black pepper."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
