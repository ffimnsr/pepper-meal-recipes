  "id": "cc319a04-7b9d-56da-b1a0-2d89b56694d8",
  "slug": "longganisa-pasta-recipe",
  "name": "Longganisa Pasta",
  "recipe_type": "dessert",
  "brief_description": "Penne pasta with sweet sausage",
  "cuisine": "Italian",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saut\u00e9 onion and garlic until the onion softens."
    },
    {
      "position": 2,
      "text": "Pour the tomato sauce into the pan. Let boil."
    },
    {
      "position": 3,
      "text": "Add Italian seasoning and red pepper flakes. Cover and continue cooking in low heat for 15 minutes."
    },
    {
      "position": 4,
      "text": "Thicken the sauce by adding tomato paste and then put the cooked penne pasta into the pan. Toss. Cook for 1 minute."
    },
    {
      "position": 5,
      "text": "Slice the longganisa into half and add these into the pan. Toss."
    },
    {
      "position": 6,
      "text": "Season with salt and ground black pepper. Add cheddar cheese."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve warm. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
