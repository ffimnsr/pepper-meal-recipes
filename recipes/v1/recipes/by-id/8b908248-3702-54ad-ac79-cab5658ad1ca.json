  "id": "8b908248-3702-54ad-ac79-cab5658ad1ca",
  "slug": "pumpkin-pie",
  "name": "Pumpkin Pie",
  "recipe_type": "dessert",
  "brief_description": "Pumpkin Pie is a type of dessert pie made from pumpkin. This delicious dessert is usually made between autumn to early winter when pumpkins are just about right to harvest.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 425 degrees Fahrenheit"
    },
    {
      "position": 2,
      "text": "Combine sugar, salt, ground cinnamon, and ground nutmeg in a bowl then mix well."
    },
    {
      "position": 3,
      "text": "Add the beaten eggs and continue mixing until all the ingredients are well distributed."
    },
    {
      "position": 4,
      "text": "Put-in the pumpkin and fold-in with the other ingredients."
    },
    {
      "position": 5,
      "text": "Gradually add the milk while mixing."
    },
    {
      "position": 6,
      "text": "Pour the mixture on the pastry dough (uncooked pie crust) and place inside the oven."
    },
    {
      "position": 7,
      "text": "Bake for 12 minutes then reduce the temperature to 350 degrees Fahrenheit. Bake for another 40 to 45 minutes or until it passes the toothpick test."
    },
    {
      "position": 8,
      "text": "Remove from the oven and let cool."
    },
    {
      "position": 9,
      "text": "Refrigerate for 2 hours."
    },
    {
      "position": 10,
      "text": "Serve, Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 45,
  "preparation_time_minutes": 10,
