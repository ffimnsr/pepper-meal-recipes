  "id": "874311c1-5df0-5964-9b2a-f005f41e8ed5",
  "slug": "oven-roasted-asparagus",
  "name": "Oven Roasted Asparagus",
  "recipe_type": "side",
  "brief_description": "Roasted seasoned asparagus with parmesan cheese",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Preheat the oven to 400 F."
    },
    {
      "position": 2,
      "text": "Arrange the asparagus in a baking tray. Drizzle with olive oil. Toss."
    },
    {
      "position": 3,
      "text": "Season with salt and ground black pepper. Add garlic and parmesan cheese. Gently toss until all the ingredients are well blended."
    },
    {
      "position": 4,
      "text": "Bake for 13 minutes."
    },
    {
      "position": 5,
      "text": "Remove from the oven and arrange on a serving plate. Top with more cheese if preferred."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 13,
  "preparation_time_minutes": 5,
