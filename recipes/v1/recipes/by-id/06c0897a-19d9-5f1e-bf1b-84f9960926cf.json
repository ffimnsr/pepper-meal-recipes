  "id": "06c0897a-19d9-5f1e-bf1b-84f9960926cf",
  "slug": "calamares-calamari-recipe",
  "name": "Calamares",
  "recipe_type": "appetizer",
  "brief_description": "Calamares or Calamari is a mouth watering breaded fried squid dish. Discover why this is one of the best appetizers around.",
  "cuisine": "filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine squid, salt, and ground black pepper then mix well. Let stand for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat a cooking pot then pour-in cooking oil."
    },
    {
      "position": 3,
      "text": "Dredge the squid in flour then dip in beaten egg and roll over breadcrumbs."
    },
    {
      "position": 4,
      "text": "When the oil is hot enough, deep-fry the squid until the color of the coating turns brown. Note: This should only take about 2 to 3 minutes in medium heat. Do not overcook the squid."
    },
    {
      "position": 5,
      "text": "Remove the fried squid from the cooking pot and transfer in a plate lined with paper towels."
    },
    {
      "position": 6,
      "text": "Serve with sinamak or Asian dipping sauce."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 3,
  "preparation_time_minutes": 10,
