{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "105037c3-9ca7-504d-bbc4-3ea001ffff5a",
  "slug": "inihaw-na-galunggong-with-ensaladang-talong",
  "name": "Inihaw na Galunggong with Ensaladang Talong",
  "recipe_type": "salad",
  "brief_description": "This is a recipe for grilled fish with eggplant salad",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the fish by rubbing salt all over (including the cavity). Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, prepare the eggplant salad (ensaladang talong) by poking all sides with a fork and heating it directly in open flame on your stove top. Rotate the eggplant after every minute to equally cook all sides. Note: It is normal for the skin of the eggplant to get burnt during this process. It will not affect the condition of the inside."
    },
    {
      "position": 3,
      "text": "Once the eggplant is completely cooked (all sides are dark and steam is coming out if it), let it cool down. Gently peel off the skin. Cut the stem and discard."
    },
    {
      "position": 4,
      "text": "Combine all ensaladang talong ingredients in a bowl. Mix well. Set aside."
    },
    {
      "position": 5,
      "text": "Heat the grill. Skewer each fish in bamboo skewers (bbq sticks). Brush oil all over the fish to prevent the skin from sticking on the grates. Grill each side for 4 to 5 minutes or until the fish is cooked thoroughly."
    },
    {
      "position": 6,
      "text": "Arrange the grilled galunggong in a plate along with the ensaladang talong. Serve with rice and spicy vinegar dip."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 1,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 15,
