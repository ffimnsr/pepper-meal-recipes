  "id": "1b8204ed-629f-50c2-9bb2-53cdb4fca76f",
  "slug": "filipino-food-sour-shrimp-soup-sinigang-na-hipon-recipe",
  "name": "Sinigang na Hipon",
  "recipe_type": "soup",
  "brief_description": "Shrimp and vegetable soup in sour broth.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add onion, tomato, and radish. Cover and continue to boil for 8 minutes."
    },
    {
      "position": 2,
      "text": "Add shrimp. Cook for 1 minute."
    },
    {
      "position": 3,
      "text": "Add Knorr Sinigang sa Sampaloc Recipe Mix. Stir until it dilutes completely. Cover and cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add long green pepper, snake beans, okra, and eggplant. Stir. Cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Put the kangkong stalks into the pot. Season with fish sauce and ground black pepper."
    },
    {
      "position": 6,
      "text": "Add kangkong leaves. Cook for 1 minute."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve warm with rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
