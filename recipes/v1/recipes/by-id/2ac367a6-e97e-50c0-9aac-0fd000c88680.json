  "id": "2ac367a6-e97e-50c0-9aac-0fd000c88680",
  "slug": "sizzling-tuna-sisig",
  "name": "Sizzling Tuna Sisig",
  "recipe_type": null,
  "brief_description": "This is a recipe for Sizzling Tuna Sisig.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrannge tuna cubes in a bowl. Pour Knorr liquid seasoning. Mix well. Let it stay for 10 minutes for the fish to absorb the flavor."
    },
    {
      "position": 2,
      "text": "Melt 2 tablespooons butter in a pan."
    },
    {
      "position": 3,
      "text": "Once the butter is completely melted, add the marinated tuna cubes. Cook until medium brown"
    },
    {
      "position": 4,
      "text": "Add onion. Saute for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add chopped long green pepper and Thai chili. ."
    },
    {
      "position": 6,
      "text": "Scoop the mayonnaise and add it into the pan. Stir until all ingredients are well blended. Cook for 3 to 5 minutes"
    },
    {
      "position": 7,
      "text": "Add salt, ground black pepper, and garlic powder. Stir and cook for 3 minutes."
    },
    {
      "position": 8,
      "text": "Heat a metal plate (also called sizzling plate) over a stovetop."
    },
    {
      "position": 9,
      "text": "Melt 1 tablespoon butter on the metal plate. Make sure that the entire area of the plate gets coated."
    },
    {
      "position": 10,
      "text": "Tranfer the cooked tuna sisig into the metal plate. Continue to cook while gently stirring for 1 to 2 minutes seconds."
    },
    {
      "position": 11,
      "text": "Top with crushed chicharon, chili and slices of lime or calamansi."
    },
    {
      "position": 12,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
