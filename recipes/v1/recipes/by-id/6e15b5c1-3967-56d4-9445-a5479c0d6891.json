  "id": "6e15b5c1-3967-56d4-9445-a5479c0d6891",
  "slug": "soup-number-5",
  "name": "Soup Number 5",
  "recipe_type": "soup",
  "brief_description": "An exotic soup composed of the bull's sex organs, this Filipino recipe is said to have aphrodisiac effects.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Boil 6 cups water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Put Ox bat and balls. Continue to boil for 15 to 20 minutes. Remove from the cooking pot and wash with running water. Discard the water."
    },
    {
      "position": 3,
      "text": "Pour 6 cups water in a cooking pot. Let boil. Add sibot herb mix and lemongrass. Cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Add bat and balls into the pot. Continue to cook for 3 to 4 hours or until tender. Note: you can use a pressure cooker to tenderize it quickly. Add water as needed."
    },
    {
      "position": 5,
      "text": "Remove the meat from the pot. Let it cool down and then slice into smaller pieces. Filter the liquid using a kitchen sieve to separate the solid ingredients. Set aside."
    },
    {
      "position": 6,
      "text": "Heat oil in a cooking pot. Saute garlic, onion, and ginger until garlic browns and onion softens."
    },
    {
      "position": 7,
      "text": "Add the sliced bat and balls and chopped Thai chili. Saute for 2 minutes."
    },
    {
      "position": 8,
      "text": "Pour the filtered liquid and add beef broth. Let boil. Cook for 20 minutes."
    },
    {
      "position": 9,
      "text": "Season with fish sauce and ground black pepper and add sugar. Cook for 5 minutes more."
    },
    {
      "position": 10,
      "text": "Make the soup thicker by pouring a mixture composed of cornstarch and water. Stir."
    },
    {
      "position": 11,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
