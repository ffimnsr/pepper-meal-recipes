  "id": "6a135de4-3bba-52a4-824f-755913b313e4",
  "slug": "mahi-mahi-paksiw-recipe",
  "name": "Mahi-Mahi Paksiw Recipe",
  "recipe_type": null,
  "brief_description": "Mahi-mahi paksiw is a dish wherein fish such as mahi-mahi (which is also known as dolphin fish \u2013 don\u2019t worry, this is not our friendly dolphin flipper) is cooked in vinegar with some spices.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the mahi-mahi fillet."
    },
    {
      "position": 2,
      "text": "Heat-up the grill then grill each side for 3 minutes."
    },
    {
      "position": 3,
      "text": "Meanwhile, combine water, vinegar, whole peppercorn, garlic, and sugar in a cooking pot. Let boil. Adjust the heat to low."
    },
    {
      "position": 4,
      "text": "Put-in the grilled mahi-mahi and long green chili then continue to cook (covered) for 12 to15 minutes. Add more water if needed."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
