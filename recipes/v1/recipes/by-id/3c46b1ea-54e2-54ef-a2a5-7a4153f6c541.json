  "id": "3c46b1ea-54e2-54ef-a2a5-7a4153f6c541",
  "slug": "buttered-garlic-shrimp",
  "name": "Garlic Butter Shrimp Recipe",
  "recipe_type": "main",
  "brief_description": "This is a recipe for Garlic Butter Shrimp",
  "cuisine": "Filipino Recipe",
  "instructions": [
    {
      "position": 1,
      "text": "Marinate the shrimp in lemon soda for about 10 minutes"
    },
    {
      "position": 2,
      "text": "Melt the butter in a pan."
    },
    {
      "position": 3,
      "text": "Add the garlic. Cook in low heat until the color turns light brown"
    },
    {
      "position": 4,
      "text": "Put-in the shrimp. Adjust heat to high. Stir-fry until shrimp turns orange."
    },
    {
      "position": 5,
      "text": "Season with ground black pepper, salt, and lemon juice. Stir."
    },
    {
      "position": 6,
      "text": "Add parsley. Cook for 30 seconds."
    },
    {
      "position": 7,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 10,
