  "id": "7c9ceeeb-0a20-51cc-a0c2-76bb2262e1b4",
  "slug": "hot-and-sour-soup",
  "name": "Hot and Sour Soup",
  "recipe_type": "appetizer",
  "brief_description": "Hot and Sour Soup is an oriental soup dish composed of meat and lots of vegetables. Chilies or chili sauce is responsible in making",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot then pour-in chicken broth and let boil."
    },
    {
      "position": 2,
      "text": "Put-in Shiitake mushroom, wood ear, and ginger then stir. Simmer for 10 minutes."
    },
    {
      "position": 3,
      "text": "Remove the ginger, put-in pork, tofu, carrots, and bamboo shoots. Simmer until pork is tender (about 20 minutes)."
    },
    {
      "position": 4,
      "text": "Add soy sauce, rice vinegar, and hot sauce then stir."
    },
    {
      "position": 5,
      "text": "Stir-in cornstarch diluted in water and egg. Stir thoroughly."
    },
    {
      "position": 6,
      "text": "Turn off heat, transfer to a serving bowl, and garnish with spring onions."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
