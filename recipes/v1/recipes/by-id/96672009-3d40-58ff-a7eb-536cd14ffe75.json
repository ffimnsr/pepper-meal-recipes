  "id": "96672009-3d40-58ff-a7eb-536cd14ffe75",
  "slug": "pinaupong-manok-sa-asin",
  "name": "Pinaupong Manok sa Asin",
  "recipe_type": null,
  "brief_description": "Pinaupong Manok sa Asin is a simple Filipino Steamed Chicken dish. This recipe makes use of coarse sea salt and pepper as seasonings.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub 3 tablespoons of salt and 1/2 teaspoon ground black pepper all over the chicken. Make sure that you also rub the seasonings in the chicken cavity for optimal flavor. Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Stuff the lemongrass and leeks inside the chicken."
    },
    {
      "position": 3,
      "text": "Arrange the remaining salt on the cooking pot by spreading it to cover space."
    },
    {
      "position": 4,
      "text": "Place the banana leaf on top of the salt."
    },
    {
      "position": 5,
      "text": "Place the chicken over the banana leaf. Note: I use a small can of tomato sauce to help the chicken securely sit. Simply insert the can in the cavity."
    },
    {
      "position": 6,
      "text": "Turn the heat on to medium and steam for 80 to 90 minutes."
    },
    {
      "position": 7,
      "text": "Remove the chicken from the cooking pot and transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve with a dipping sauce composed of fish sauce and lemon or calamansi."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 15,
