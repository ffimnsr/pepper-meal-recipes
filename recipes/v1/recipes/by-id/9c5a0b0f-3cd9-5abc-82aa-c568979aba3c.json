  "id": "9c5a0b0f-3cd9-5abc-82aa-c568979aba3c",
  "slug": "slow-cooked-pork-chop-shiitake-mushrooms",
  "name": "Slow Cooked Pork Chop with Shiitake Mushrooms",
  "recipe_type": null,
  "brief_description": "Slow Cooked Pork Chop with Shiitake Mushrooms is what I usually make when I am busy doing house chores because I can slow cook while working",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange onion at the bottom of the slow cooker."
    },
    {
      "position": 2,
      "text": "Layer the pork chops on top of the onion."
    },
    {
      "position": 3,
      "text": "Add the mushrooms, garlic powder, sugar, a pinch of salt and ground black pepper. Pour-in the beef consomme."
    },
    {
      "position": 4,
      "text": "Set your slow cooker to low and cook the pork chops for 7 hours."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 420,
