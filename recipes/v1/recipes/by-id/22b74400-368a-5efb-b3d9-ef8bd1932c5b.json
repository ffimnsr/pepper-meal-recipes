  "slug": "how-to-make-sweet-and-sour-sauce-recipe",
  "name": "Sweet and Sour Sauce Recipe",
  "recipe_type": "dessert",
  "brief_description": "A perfectly balanced sweet and tangy sauce",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the sugar, ketchup, vinegar, and soy sauce in a bowl."
    },
    {
      "position": 2,
      "text": "Mix the combined ingredients using a balloon whisk or fork."
    },
    {
      "position": 3,
      "text": "Heat a saucepan then pour-in the sugar-ketchup-vinegar-soy sauce mixture. Stir once in a while and bring to a boil."
    },
    {
      "position": 4,
      "text": "Pour-in the cornstarch diluted in water then continue stirring until the texture becomes thick."
    },
    {
      "position": 5,
      "text": "Turn of the heat and transfer the sweet and sour sauce to a sauce bowl then serve."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 15,
