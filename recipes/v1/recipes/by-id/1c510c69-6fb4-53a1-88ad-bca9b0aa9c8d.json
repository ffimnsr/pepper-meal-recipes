  "id": "1c510c69-6fb4-53a1-88ad-bca9b0aa9c8d",
  "slug": "crispy-adobo-flakes-recipe",
  "name": "Crispy Adobo Flakes Recipe",
  "recipe_type": "appetizer",
  "brief_description": "This Crispy Adobo Flakes Recipe is a simple yet delicious way to prepare pork adobo. It can be eaten as an appetizer and a main dish.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Shred the pork adobo slices along the grain."
    },
    {
      "position": 2,
      "text": "Mix the flaked pork with its sauce to absorb flavor. Let it sit for 10 minutes."
    },
    {
      "position": 3,
      "text": "Heat a frying pan and pour-in the olive oil."
    },
    {
      "position": 4,
      "text": "When the oil becomes hot, fry the shredded pork in medium heat until the texture becomes crisp."
    },
    {
      "position": 5,
      "text": "Turn-off heat then transfer the fried pork in a plate lined with paper towel. This will absorb the oil."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate then serve with sinamak (spiced vinegar)."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 10,
