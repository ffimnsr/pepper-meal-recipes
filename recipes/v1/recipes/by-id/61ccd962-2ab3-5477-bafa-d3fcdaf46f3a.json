{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "61ccd962-2ab3-5477-bafa-d3fcdaf46f3a",
  "slug": "pork-pata-in-monggo-with-sotanghon",
  "name": "Pork Pata in Monggo with Sotanghon",
  "recipe_type": null,
  "brief_description": "Vegetable dish with mung beans, glass noodles, and pork hocks",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil the pork hock in 4 cups of water for 10 minutes. Drain the water and then wash the pork to ensure that it is clean. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a cooking pot. Saute garlic, onion and tomatoes."
    },
    {
      "position": 3,
      "text": "Once the onion and tomato soften, add the mung beans. Saut\u00e9 for 30 seconds."
    },
    {
      "position": 4,
      "text": "Pour 4 cups of water into the pot. Add the pork hock. Let boil. Cover and simmer for 50 to 60 minutes or until the pork tenderizes. Occasionally stir every 10 minutes and add more water as necessary."
    },
    {
      "position": 5,
      "text": "Add the sotanghon noodles. Stir. Continue cooking in low heat for 3 to 5 minutes. The mung beans should be soft and somewhat creamy at this point."
    },
    {
      "position": 6,
      "text": "Add the beef powder and then season with fish sauce and ground black pepper. Stir."
    },
    {
      "position": 7,
      "text": "Add the spinach. Turn off the heat and then cover the pot for 1 minute."
    },
    {
      "position": 8,
      "text": "Gently stir until the spinach mixes with the other ingredients in the pot."
    },
    {
      "position": 9,
      "text": "Serve hot with rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 10,
