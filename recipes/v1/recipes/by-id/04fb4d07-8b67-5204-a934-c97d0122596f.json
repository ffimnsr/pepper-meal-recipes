  "id": "04fb4d07-8b67-5204-a934-c97d0122596f",
  "slug": "filipino-fish-steak-recipe",
  "name": "Filipino Fish Steak Recipe",
  "recipe_type": null,
  "brief_description": "Filipino Fish Steak is the Fish version of Bistek Tagalog, which is also known as Filipino Beef Steak. This dish is simple and easy to prepare. If you have been visiting this food blog for a while, you should be aware that I always speak of what I think is the truth \u2013 and this recipe is something that is easy and delicious.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Once the oil turns hot, fry the sliced milkfish belly until the color turns medium brown. Flip the fish to fry the other side."
    },
    {
      "position": 3,
      "text": "Remove the fish from the pan after frying. Discard most of the cooking oil from the pan leaving around 1 tablespoon of oil."
    },
    {
      "position": 4,
      "text": "On the same pan with little oil, cook the garlic until it turns light brown."
    },
    {
      "position": 5,
      "text": "Pour-in the soy sauce, water, and lemon juice. Stir."
    },
    {
      "position": 6,
      "text": "Add the fried fish. Cover and cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Add the onion, salt, and pepper. Stir. cover and cook for 2 to 5 minutes. You may add water if needed."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Top with chopped parsley."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
