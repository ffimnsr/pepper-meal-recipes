  "id": "32dce0bf-c5d0-58e9-86ec-d6aa93384a95",
  "slug": "sprite-pork-adobo-recipe",
  "name": "Sprite Pork Adobo Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Sprite Pork Adobo",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a large bowl, combine soy sauce and Sprite with the pork belly. Mix well. Cover the bowl and refrigerate. Let the pork marinate for at least 6 hours."
    },
    {
      "position": 2,
      "text": "Using a kitchen sieve, drain the marinade out of the bowl. Set it aside."
    },
    {
      "position": 3,
      "text": "Heat oil in a cooking pot"
    },
    {
      "position": 4,
      "text": "Once the oil becomes hot, saute garlic until light brown"
    },
    {
      "position": 5,
      "text": "Add onion. Continue to saute until soft"
    },
    {
      "position": 6,
      "text": "Add pork belly. Stir and cook until light brown"
    },
    {
      "position": 7,
      "text": "Pour the marinade (Sprite and soy sauce). Cover the pot and let boil."
    },
    {
      "position": 8,
      "text": "Add whole peppercorn and dried bay leaves. Cover the pot and continue to cook for 30 minutes in medium heat."
    },
    {
      "position": 9,
      "text": "Pour vinegar into the pot. Let the liquid re-boil. Stir. Cover and cook for 25 to 30 minutes. Note: add water if needed."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate. Serve with rice."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
