  "id": "c61eb1b9-cf7d-53b3-9ea0-fb0991135c8a",
  "slug": "stuffed-ampalaya",
  "name": "Stuffed Ampalaya",
  "recipe_type": null,
  "brief_description": "Stuffed Ampalaya is a vegetable and meat dish that is composed of bitter gourd (also called bitter melon) and ground pork. The word \"Ampalaya\" is the Filipino term for bitter gourd. If we do some translation, this dish can also be called stuffed bitter gourd or stuffed bitter melon.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Preheat oven to 375 degrees Fahrenheit."
    },
    {
      "position": 2,
      "text": "In a large bowl, combine ground pork, onion, carrots, bread, salt, pepper, garlic powder, paprika, and egg. Mix well.Set Aside."
    },
    {
      "position": 3,
      "text": "Stuff the mixture into the ampalaya slices."
    },
    {
      "position": 4,
      "text": "Grease a baking pan, and arrange the stuffed ampalaya."
    },
    {
      "position": 5,
      "text": "Place inside the oven, and bake for 22 to 26 minutes. Or until the meat is cooked."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
