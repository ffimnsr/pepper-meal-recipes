{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "016189f4-794b-50c2-9e60-4b3bd003a9fd",
  "slug": "tuna-sushi-roll",
  "name": "Tuna Sushi Roll",
  "recipe_type": null,
  "brief_description": "Tuna Sushi Roll is a type of Sushi made from shari (cooked rice with vinegar) and raw tuna. This is also known as Tekkamaki.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine mayonnaise, sesame oil, and chili paste in a bowl. Mix well and set aside."
    },
    {
      "position": 2,
      "text": "Combine vinegar with sushi rice, and mix well."
    },
    {
      "position": 3,
      "text": "Arrange a sheet of nori over a sushi roller. Scoop some sushi rice and press on the nori so that the rice will stick. Do this step until most of the toasted seaweed is evenly covered. See the California Roll video for more details."
    },
    {
      "position": 4,
      "text": "Flip the nori in such a way that the part with rice is facing down. Arrange the tuna slices and cucumber on top of the toasted seaweed."
    },
    {
      "position": 5,
      "text": "Spread a little wasabi paste over the tuna, and then start rolling with the help of a sushi roller. Note: try to push down a little as you roll the sushi to compress."
    },
    {
      "position": 6,
      "text": "Spread some dynamite sauce over the sushi and sprinkle some Panko breadcrumbs on top of the sauce."
    },
    {
      "position": 7,
      "text": "Slice the Sushi roll crosswise into 6 equal pieces."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with soy sauce and wasabe paste."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 12,
  "rest_time_minutes": null,
  "difficulty": "medium",
