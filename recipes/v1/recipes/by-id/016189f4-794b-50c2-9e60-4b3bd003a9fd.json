{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "016189f4-794b-50c2-9e60-4b3bd003a9fd",
  "slug": "tuna-sushi-roll",
  "name": "Tuna Sushi Roll",
  "recipe_type": "main",
  "brief_description": "Fresh tuna and cucumber rolled in vinegared sushi rice and nori, topped with spicy dynamite sauce and crispy panko breadcrumbs. This inside-out roll features a creamy, spicy finish with a satisfying crunch.",
  "cuisine": "Japanese",
  "instructions": [
    {
      "position": 1,
      "text": "Combine mayonnaise, sesame oil, and chili paste in a bowl. Mix well to make dynamite sauce and set aside."
    },
    {
      "position": 2,
      "text": "Combine vinegar with sushi rice, and mix well."
    },
    {
      "position": 3,
      "text": "Arrange a sheet of nori over a sushi mat. Scoop some sushi rice and spread evenly over the nori, pressing gently so the rice sticks. Leave a 1-inch border at the top."
    },
    {
      "position": 4,
      "text": "Flip the nori in such a way that the part with rice is facing down. Arrange the tuna slices and cucumber on top of the nori."
    },
    {
      "position": 5,
      "text": "Spread a little wasabi paste over the tuna, and then start rolling with the help of a sushi mat. Note: try to push down a little as you roll the sushi to compress."
    },
    {
      "position": 6,
      "text": "Spread the dynamite sauce over the sushi roll and sprinkle panko breadcrumbs on top of the sauce."
    },
    {
      "position": 7,
      "text": "Slice the sushi roll crosswise into 6 equal pieces."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve with soy sauce and wasabi paste."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 12,
  "rest_time_minutes": 10,
  "difficulty": "medium",
