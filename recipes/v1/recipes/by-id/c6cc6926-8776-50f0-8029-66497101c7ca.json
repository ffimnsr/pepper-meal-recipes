  "id": "c6cc6926-8776-50f0-8029-66497101c7ca",
  "slug": "dinaldalem-recipe-igado-liver-and-pork-adobo",
  "name": "Dinaldalem Recipe",
  "recipe_type": "side",
  "brief_description": "This is a recipe for dinaldalem, It is a version if igado, which can also be considered as pork and liver adobo with chickpeas and bell pepper.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat 3 tablespoons of oil in a wok or pan. Stir-fry the liver for 2 to 3 minutes. Add the garlic powder. Continue to cook until the liquid from the liver completely evaporates. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the remaining oil in a pot."
    },
    {
      "position": 3,
      "text": "Once hot, saut\u00e9 the garlic and onion until soft."
    },
    {
      "position": 4,
      "text": "Add the ground black pepper. Stir."
    },
    {
      "position": 5,
      "text": "Add the sliced pork shoulder. Cook until light to medium brown."
    },
    {
      "position": 6,
      "text": "Put the dried bay leaves in the pot. Cook while stirring for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Pour the soy sauce and water in the pot. Stir and let boil."
    },
    {
      "position": 8,
      "text": "Cover and cook in low heat for 30 to 45 minutes or until pork gets tender."
    },
    {
      "position": 9,
      "text": "Stir-in the liver"
    },
    {
      "position": 10,
      "text": "Pour the vinegar in the pot. Wait for the liquid to boil again. Stir."
    },
    {
      "position": 11,
      "text": "Add the garbanzos and red bell pepper. Stir and cover. Cook in medium heat for 5 minutes."
    },
    {
      "position": 12,
      "text": "Add salt and sugar. Stir."
    },
    {
      "position": 13,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 14,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
