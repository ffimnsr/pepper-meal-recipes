  "id": "8d14dcf4-5d82-582c-b27a-01002a0bde27",
  "slug": "chicken-pesto-pasta-recipe",
  "name": "Chicken Pesto Pasta",
  "recipe_type": null,
  "brief_description": "Chicken Pesto Pasta is a healthy and easy chicken pasta dish that you can cook for dinner. This dish makes use of Penne pasta along with basil pesto and grilled chicken.This recipe will guide you on how to make your own pesto anytime you want.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cook the penne pasta according to package instructions. Set aside"
    },
    {
      "position": 2,
      "text": "Flatten the chicken breast by gently pounding using a meat tenderizer. Rub salt and pepper on the chicken breast. Let it stay for 10 minutes."
    },
    {
      "position": 3,
      "text": "Grill each side of the chicken breasts for 5 to 7 minutes. Let the meat rest for 5 to 8 minutes and then slice into thick strips."
    },
    {
      "position": 4,
      "text": "Combine the cooked pasta, sliced chicken breast, pesto, sun-dried tomato, and Parmesan cheese in a large mixing bowl. Toss until all the ingredients are well incorporated."
    },
    {
      "position": 5,
      "text": "Transfer to individual plates."
    },
    {
      "position": 6,
      "text": "Serve with garlic bread. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
