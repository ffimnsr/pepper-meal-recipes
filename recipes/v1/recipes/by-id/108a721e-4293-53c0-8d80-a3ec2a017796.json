  "id": "108a721e-4293-53c0-8d80-a3ec2a017796",
  "slug": "filipino-omelet-recipe",
  "name": "Filipino Omelet",
  "recipe_type": "breakfast",
  "brief_description": "Beaten eggs seasoned with salt and pepper and cooked with onions and tomato. This is a delicious breakfast dish best paired with pandesal.",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Crack the eggs and then place in a medium bowl. Add the salt and pepper and then beat using a wire whisk or fork. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 3,
      "text": "Saute the onion and tomatoes for 2 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in the beaten egg mixture. Spread the mixture by tilting the pan sideways. Continue to cook in medium heat for 3 to 4 minutes."
    },
    {
      "position": 5,
      "text": "Flip the omelet with the aid of a wide spatula and then cook the other side for 3 minutes. Note: If you are having a hard time flipping the omelet, try to first place the egg on a wide plate (the cooked side should be facing down). Quickly flip the plate on top of the pan so that the omelet will slide to the pan with the uncooked side facing down."
    },
    {
      "position": 6,
      "text": "Turn off the heat and then transfer the omelet to a serving plate. Enjoy with pandesal or garlic rice. Serve with banana ketchup."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 5,
