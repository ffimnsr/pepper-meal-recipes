{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "7c2368b0-24e7-5bc5-8014-e81a12c06acf",
  "slug": "relyenong-talong-with-tuna",
  "name": "Relyenong Talong with Tuna",
  "recipe_type": "main",
  "brief_description": "Eggplant stuffed with tuna",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Slice the eggplants crosswise, half an inch thick. Create eggplant rings by cutting around the inside part of each sliced eggplant. Chop the part that has been cut-out and set it aside."
    },
    {
      "position": 2,
      "text": "Heat 3 tablespoons of cooking oil in a pan. Saut\u00e9 onion and garlic. Add tuna and chopped eggplant once the onion softens. Cook for 3 to 5 minutes. Season with Knorr Liquid Seasoning. Transfer to a mixing bowl and let it cool down."
    },
    {
      "position": 3,
      "text": "Beat the eggs and add it to the cooked mixture in the bowl. Also add half of the carrot, green onions, and bell peppers. Mix well."
    },
    {
      "position": 4,
      "text": "Heat the remaining oil. Fry one side of the eggplant rings for 1 minute."
    },
    {
      "position": 5,
      "text": "Turn the eggplant over to cook the opposite side. Sprinkle some minced carrot, bell pepper, and green onions in each ring. Top it with a scoop of tuna mixture. Gently spread the mixture within the ring. Set your stove to medium heat and continue cooking for 2 minutes."
    },
    {
      "position": 6,
      "text": "Top the mixture with minced carrot, bell pepper, and green onions. Turn it over and cook the other side for 2 to 3 minutes. Remove the relyenong talong from the pan and arrange it on a serving plate. Serve with banana ketchup. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
