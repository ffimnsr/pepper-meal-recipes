  "id": "1ebec984-cf18-558d-96a9-5613a8872566",
  "slug": "braised-pork-belly-with-potato-and-peppers",
  "name": "Braised Pork Belly with Potato and Peppers",
  "recipe_type": "main",
  "brief_description": "Braised pork belly with potatoes",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Sear the pork belly until brown and enough oil has been extracted. Remove it from the pan and set it aside."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the garlic and onion in the extracted pork fat until the onion softens."
    },
    {
      "position": 3,
      "text": "Add the pork belly back into the pan. Saute it for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour the soy sauce and oyster sauce. Stir and then add the water. Cover the pan. Let the mixture boil. Add the dried bay leaves, and then adjust the heat setting to a simmer. Continue simmering for 30 minutes."
    },
    {
      "position": 5,
      "text": "Add the white vinegar and sugar. Cover the pan and simmer until the pork tenderizes completely. Note: This can take from 30 to 45 minutes."
    },
    {
      "position": 6,
      "text": "Add the potatoes. Cook it for 6 minutes."
    },
    {
      "position": 7,
      "text": "Add the bell pepper and ground black pepper. Season with salt and ground black pepper. Cover and cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve warm. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": null,
  "preparation_time_minutes": null,
