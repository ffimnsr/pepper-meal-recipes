  "id": "9c391b97-0774-506a-b9b6-b9b0ac897fee",
  "slug": "shrimp-laing",
  "name": "Shrimp Laing Recipe",
  "recipe_type": "main",
  "brief_description": "Dried Taro leaves cooked in coconut milk with shrimp.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Clean the shrimp by cutting the antenna and deveining. Set aside."
    },
    {
      "position": 2,
      "text": "Sear pork fat in a cooking pot. Continue cooking until enough oil gets extracted from it."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 onion, garlic, and ginger using the oil from the pork."
    },
    {
      "position": 4,
      "text": "Once the onion tenderizes, pour coconut milk into the pot and let it boil."
    },
    {
      "position": 5,
      "text": "Add chili peppers, shrimp paste, and dried taro leaves. Cover and cook for 5 minutes."
    },
    {
      "position": 6,
      "text": "Push the leave to submerge in coconut milk. Continue boiling on a covered pot for 30 minutes."
    },
    {
      "position": 7,
      "text": "Stir the mixture and adjust the heat between low to medium. Cover and cook for 45 to 60 minutes or until the leaves get very soft."
    },
    {
      "position": 8,
      "text": "Season with ground pepper and add shrimp. Cook for 3 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve. Share and enjoy with warm rice."
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 80,
  "preparation_time_minutes": 10,
