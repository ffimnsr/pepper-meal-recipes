  "id": "f0b53233-f4b8-50e7-a143-3388ce0ebdfa",
  "slug": "broiled-lobster-tail-with-lemon-butter-sauce",
  "name": "Broiled Lobster Tail with Lemon Butter Sauce",
  "recipe_type": null,
  "brief_description": "This is a recipe for Broiled Lobster Tail with Lemon Butter Sauce",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Set the oven to broil."
    },
    {
      "position": 2,
      "text": "Open the lobster tail by cutting the top shell using a pair of scissors. Start from the topmost part (lengthwise)until it reaches the far end. Push the shell sideways to expose the meat. Manually pull the meat out to expose it."
    },
    {
      "position": 3,
      "text": "Combine salt and garlic powder. Sprinkle the mixture over the lobster meat. Rub it all over the lobster meat."
    },
    {
      "position": 4,
      "text": "Arrange the lobster in a baking tray. Broil for 8 to 10 minutes."
    },
    {
      "position": 5,
      "text": "Meanwhile, prepare the sauce by melting butter in a saucepan. Add lemon juice and whipping cream. Stir. Set aside."
    },
    {
      "position": 6,
      "text": "Remove the broiled lobster from the oven. Arrange in a serving plate. Top with lemon butter sauce."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 10,
