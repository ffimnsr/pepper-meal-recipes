  "id": "9bfd265d-84b9-54d2-9ef7-067931fe6730",
  "slug": "basic-pork-adobo-recipe",
  "name": "Basic Pork Adobo Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Basic Pork Adobo",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Add the garlic. Cook until it starts to turn light brown."
    },
    {
      "position": 3,
      "text": "Add the peppercorns and bay leaves. Continue to cook for 20 seconds so that its flavors get infused in the oil."
    },
    {
      "position": 4,
      "text": "Put the pork belly in the cooking pot. Stir and cook until it turns light brown. Note: check the garlic and make sure that it does not get burnt. Adjust heat if necessary."
    },
    {
      "position": 5,
      "text": "Pour the soy sauce and beef broth (or water). Let boil. Cover and cook in low heat for 40 minutes or until the pork gets tender. Add more beef broth or water if the liquid starts to dry quickly."
    },
    {
      "position": 6,
      "text": "Pour-in the vinegar. Let the liquid re-boil. Stir and cook for 8 minutes."
    },
    {
      "position": 7,
      "text": "Taste your pork adobo and decide to add salt if needed."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
