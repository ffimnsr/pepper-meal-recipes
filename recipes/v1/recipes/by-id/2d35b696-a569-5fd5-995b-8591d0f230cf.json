  "id": "2d35b696-a569-5fd5-995b-8591d0f230cf",
  "slug": "nilagang-litid-ng-baka",
  "name": "Nilagang Litid ng Baka",
  "recipe_type": "soup",
  "brief_description": "Nilagang Litid ng Baka or beef tendon soup is a Filipino soup dish composed of beef tendons, cabbage, and potato. This is a variation of nilaga",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour water and beef broth in a soup pot. Let boil"
    },
    {
      "position": 2,
      "text": "Add the whole peppercorn and onion. Boil for 5 minutes."
    },
    {
      "position": 3,
      "text": "Put the beef shoulder bones in the pot. Cover and then let the liquid return to a boil. Adjust the heat between low to medium. Cook for 60 to 120 minutes."
    },
    {
      "position": 4,
      "text": "Once the tendons are tender (this has a tendency to slip-off the bones), add the potato and cabbage. Cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Add the fish sauce. Adjust the taste by adding more if needed. Cook for 5 more minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve with a saucer of spicy fish sauce with lemon and a cup of rice on the side."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
