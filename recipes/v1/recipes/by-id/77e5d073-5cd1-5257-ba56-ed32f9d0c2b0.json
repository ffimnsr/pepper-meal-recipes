{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "77e5d073-5cd1-5257-ba56-ed32f9d0c2b0",
  "slug": "lechon-kawali",
  "name": "Lechon Kawali",
  "recipe_type": "appetizer",
  "brief_description": "Crispy deep fried pork belly with crackling skin and tender, juicy meat. The pork is boiled until fork tender, then fried until golden brown and crunchy. Serve with steamed rice and lechon sauce for a classic Filipino meal.",
  "cuisine": "Asian Filipino Southeast Asian",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water into a deep cooking pot and bring it to a boil."
    },
    {
      "position": 2,
      "text": "Add the pork belly, 1 tablespoon of salt, peppercorns, and bay leaves. Boil for 30 to 45 minutes or until the meat is fork tender."
    },
    {
      "position": 3,
      "text": "Remove the pork belly from the pot and let it cool down for a few minutes on a wire rack."
    },
    {
      "position": 4,
      "text": "Rub the remaining 1 tablespoon of salt evenly all over the pork belly, especially on the skin side. Let it air dry for at least 30 minutes."
    },
    {
      "position": 5,
      "text": "Heat oil in a deep cooking pot or wok until it reaches 350F (175C)."
    },
    {
      "position": 6,
      "text": "Carefully lower the pork belly into the hot oil. Fry for 7 to 10 minutes, turning occasionally to brown evenly. Be extra careful as the oil will splatter. Use a lid to partially cover the pot if needed, but do not cover completely."
    },
    {
      "position": 7,
      "text": "Remove the pork when the skin is golden brown and crispy all over. Place on a wire rack to drain excess oil."
    },
    {
      "position": 8,
      "text": "Let the pork rest for 5 minutes before slicing into serving pieces. Serve immediately with lechon sauce or spiced vinegar."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
