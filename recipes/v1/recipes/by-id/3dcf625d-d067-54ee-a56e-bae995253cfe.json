  "id": "3dcf625d-d067-54ee-a56e-bae995253cfe",
  "slug": "ginataang-sitaw-at-kalabasa",
  "name": "Ginataang Kalabasa at Sitaw with Crab",
  "recipe_type": "main",
  "brief_description": "Calabaza squash with string beans and crab cooked in coconut milk",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour cooking oil."
    },
    {
      "position": 2,
      "text": "Saute garlic and onion."
    },
    {
      "position": 3,
      "text": "Add fish sauce and coconut milk, and then let boil."
    },
    {
      "position": 4,
      "text": "Put-in the ground black pepper, and then cook for 10 minutes in medium heat until the liquid reduces."
    },
    {
      "position": 5,
      "text": "Put-in the crabs and stir. Cook for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Add the squash (kalabasa). Stir. Cover the pot and then continue cooking for 6 minutes. Note: you can add water if the liquid reduces quickly as expected."
    },
    {
      "position": 7,
      "text": "Add the string beans, stir, and then cook for 3 to 5 minutes or until the squash becomes soft enough."
    },
    {
      "position": 8,
      "text": "Turn the heat off and transfer to a serving plate."
    },
    {
      "position": 9,
      "text": "Serve with hot steamed rice."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 8,
  "cooking_time_minutes": 40,
  "preparation_time_minutes": 15,
