  "id": "b6407f0f-ebed-50c9-a4e4-e28dd186d3a1",
  "slug": "easy-seared-scallops",
  "name": "Easy Seared Scallops",
  "recipe_type": "appetizer",
  "brief_description": "Easy Seared Scallops is a quick and relatively easy appetizer recipe. This can be enjoyed just as it is or by dipping in lemon butter sauce.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle salt and pepper on the scallops. Gently rub the seasoning and let it stay for 5 minutes."
    },
    {
      "position": 2,
      "text": "Melt the butter in a pan and then add the olive oil."
    },
    {
      "position": 3,
      "text": "When the butter and oil mixture becomes hot, sear each side of the scallops until both sides are golden to dark brown."
    },
    {
      "position": 4,
      "text": "Serve as an appetizer."
    },
    {
      "position": 5,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
