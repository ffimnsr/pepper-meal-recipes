  "id": "efc0d16e-9a42-5a39-9037-59620e0e7adc",
  "slug": "sarciadong-manok",
  "name": "Sarciadong Manok",
  "recipe_type": "main",
  "brief_description": "Chicken stewed with tomato and green peas and seasoned with fish sauce for that delicious Umami taste.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saute onion, garlic, and tomato."
    },
    {
      "position": 2,
      "text": "Once the onion and tomato soften, add chicken pieces. Continue to cook until the color turns light brown."
    },
    {
      "position": 3,
      "text": "Add tomato paste and chicken broth. Let boil."
    },
    {
      "position": 4,
      "text": "Put-in dried bay leaves and parsley. Cover and cook between low to medium heat for 35 to 40 minutes. Note: add more water or chicken broth if needed."
    },
    {
      "position": 5,
      "text": "Add green peas and season with fish sauce and ground black pepper."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve! Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
