  "id": "3ab52166-6d5b-5dfa-8121-562a659e7a53",
  "slug": "grilled-flank-steak-recipe",
  "name": "Grilled Flank Steak",
  "recipe_type": "side",
  "brief_description": "Tender and flavorful grilled flank steak marinated overnight for maximum taste. The marinade infuses the meat with savory goodness, while grilling creates a beautiful char on the outside and juicy interior. Serve with mashed potatoes, grilled corn, or white rice for a satisfying meal.",
  "cuisine": "American Barbecue Filipino Grill",
  "instructions": [
    {
      "position": 1,
      "text": "Season the flank steak with a little salt on both sides."
    },
    {
      "position": 2,
      "text": "Combine all the marinade ingredients in a bowl. Stir"
    },
    {
      "position": 3,
      "text": "Place the flank steak in a sturdy resealable freezer bag. Pour the flank steak marinade into the bag. Press out the air and seal the bag securely. Place inside the refrigerator and marinate overnight."
    },
    {
      "position": 4,
      "text": "Heat the grill to high. Grill the marinated flank steak for 6 to 7 minutes per side, depending on the thickness of the meat."
    },
    {
      "position": 5,
      "text": "Remove the steak from the grill and let it rest for 10 minutes before slicing."
    },
    {
      "position": 6,
      "text": "Slice the steak against the grain into your desired thickness. Serve with white rice, grilled corn, or grilled potatoes on the side."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 14,
  "preparation_time_minutes": 60,
  "rest_time_minutes": 480,
  "difficulty": "expert",
