  "id": "354df825-6b17-51bf-9031-449201ca1907",
  "slug": "beef-asado",
  "name": "Beef Asado",
  "recipe_type": "main",
  "brief_description": "Filipino piquant beef stew with potato and carrot.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine beef, crushed peppercorn, soy sauce, vinegar, dried bay leaves, lemon, and tomato sauce. Mix well. Marinate beef or at least 30 minutes."
    },
    {
      "position": 2,
      "text": "Put the marinated beef in a cooking pot along with remaining marinade. Add water. Let boil."
    },
    {
      "position": 3,
      "text": "Add Knorr Beef Cube. Stir. Cover the pot and cook for 40 minutes in low heat."
    },
    {
      "position": 4,
      "text": "Turn the beef over. Add tomato paste. Continue cooking until beef tenderizes. Set aside."
    },
    {
      "position": 5,
      "text": "Heat oil in pan. Fry the potato until it browns. Turn over and continue frying the opposite side. Remove from the pan and place on a clean plate. Do the same with the carrots."
    },
    {
      "position": 6,
      "text": "Save 3 tablespoons of cooking oil from the pan where the potato was fried. Saute onion and garlic until onion softens."
    },
    {
      "position": 7,
      "text": "Pour-in the sauce from the beef stew. Let boil. Add the beef. Cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Add butter and let it melt. Continue cooking until the sauce reduces to half."
    },
    {
      "position": 9,
      "text": "Remove the beef from the pan. Slice into serving pieces. Arrange on a serving plate with fried potato and carrot. Top with remaining sauce."
    },
    {
      "position": 10,
      "text": "Serve warm with rice. Share and enjoy!"
    }
  ],
  "servings": 5,
  "cooking_time_minutes": 90,
