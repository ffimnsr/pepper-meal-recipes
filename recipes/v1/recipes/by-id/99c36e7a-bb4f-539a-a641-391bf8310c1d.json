  "id": "99c36e7a-bb4f-539a-a641-391bf8310c1d",
  "slug": "pork-hamonado",
  "name": "Pork Hamonado",
  "recipe_type": "dessert",
  "brief_description": "Pork belly stewed in soy sauce and pineapple juice",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a cooking pot. Fry each side of the pork belly for 2 minutes."
    },
    {
      "position": 2,
      "text": "Pour-in the soy sauce, pineapple juice, and half of the pineapple chunks."
    },
    {
      "position": 3,
      "text": "Add the garlic and whole peppercorn. Cover and let it boil."
    },
    {
      "position": 4,
      "text": "Reduce the heat to a simmer. Continue cooking until the pork tenderizes. Note: This should take around 60 minutes. You can add water as needed."
    },
    {
      "position": 5,
      "text": "Add the remaining pineapple chunks and brown sugar. Season with salt as needed. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Serve warm with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
