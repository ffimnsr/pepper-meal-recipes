  "id": "a6e96fde-b0e4-5aff-9ed0-ff0e54af701e",
  "slug": "honey-garlic-barbeque-spare-ribs-recipe",
  "name": "Honey Garlic Spare Ribs",
  "recipe_type": "dessert",
  "brief_description": "Tender pork spare ribs baked in a sweet and savory honey garlic glaze made with hoisin sauce, oyster sauce, and soy sauce. The ribs marinate for at least three hours, then bake at 350\u00b0F until caramelized and glossy. Serve them over garlic fried rice for a satisfying meal.",
  "cuisine": "American Asian Chinese Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine the honey, hoisin sauce, oyster sauce, soy sauce, and pounded garlic in a bowl. Stir until well blended."
    },
    {
      "position": 2,
      "text": "Place the spare ribs in a large bowl and pour the sauce mixture over them. Coat the ribs evenly, then cover and marinate in the refrigerator for at least 3 hours."
    },
    {
      "position": 3,
      "text": "Preheat the oven to 350 degrees Fahrenheit."
    },
    {
      "position": 4,
      "text": "Arrange the marinated ribs on a baking tray. Bake for 35 minutes, basting with a little olive oil halfway through if the surface looks dry."
    },
    {
      "position": 5,
      "text": "Remove the ribs from the oven and transfer to a serving plate. Serve with garlic fried rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
