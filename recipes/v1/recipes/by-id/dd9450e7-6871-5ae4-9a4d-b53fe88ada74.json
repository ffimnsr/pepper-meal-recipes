  "id": "dd9450e7-6871-5ae4-9a4d-b53fe88ada74",
  "slug": "pork-siomai-recipe",
  "name": "Pork Siomai",
  "recipe_type": "appetizer",
  "brief_description": "Steamed homemade pork shumai.",
  "cuisine": "Chinese Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Combine ground pork and minced shrimp in a bowl. Gradually mix together."
    },
    {
      "position": 2,
      "text": "Add jicama, carrot, onion, scallion, egg, ground black pepper, and sesame oil. Continue to mix until all the ingredients are well blended."
    },
    {
      "position": 3,
      "text": "Add Knorr SavorRich Pork Liquid Seasoning. Mix well."
    },
    {
      "position": 4,
      "text": "Scoop 1 1/2 tablespoons of the pork mixture and wrap in wonton wrapper (see video below for guidance). Perform this step until the mixture is fully consumed."
    },
    {
      "position": 5,
      "text": "Arrange in a steamer and then steam for 15 to 20 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate. Serve with toyo and calamansi dipping sauce and some chili garlic paste."
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
