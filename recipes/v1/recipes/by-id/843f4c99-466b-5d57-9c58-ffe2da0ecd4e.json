  "id": "843f4c99-466b-5d57-9c58-ffe2da0ecd4e",
  "slug": "simple-lo-mein",
  "name": "Lo Mein",
  "recipe_type": "main",
  "brief_description": "This homemade lo mein is a quick stir fry of egg noodles, crisp vegetables, and a savory sauce made with soy sauce, oyster sauce, and chicken stock. Everything comes together in a wok in under 20 minutes.",
  "cuisine": "Chinese",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a wok over medium heat."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 the onion until it softens. Add the bell pepper, mushrooms, snow peas, and carrots. Stir fry for about 2 minutes, just until the vegetables are slightly tender but still crisp."
    },
    {
      "position": 3,
      "text": "Add the cooked egg noodles. Toss well and cook for 3 minutes."
    },
    {
      "position": 4,
      "text": "Pour in the soy sauce, chicken stock, and oyster sauce. Toss everything together and continue cooking for 3 to 5 minutes, allowing the noodles to absorb the sauce."
    },
    {
      "position": 5,
      "text": "Add the spinach, then season with salt and pepper. Toss again and cook for 1 to 3 minutes, just until the spinach wilts."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate and serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
