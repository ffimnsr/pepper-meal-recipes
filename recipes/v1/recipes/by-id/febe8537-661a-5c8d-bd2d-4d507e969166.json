  "id": "febe8537-661a-5c8d-bd2d-4d507e969166",
  "slug": "steamed-eggplant-and-okra-with-bagoong",
  "name": "Steamed Eggplant and Okra with Bagoong",
  "recipe_type": null,
  "brief_description": "This is a recipe for Steamed Eggplant and Okra with Bagoong",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a pot or steamer."
    },
    {
      "position": 2,
      "text": "Wash the okra and eggplants in running water. Pat it dry and then slice the eggplant in half lengthwise. Divide the halved eggplant into 3 pieces (a piece of eggplant will total to 6 slices). You can also slice the okra crosswise if desired."
    },
    {
      "position": 3,
      "text": "Arrange the eggplant and okra in a steamer. Steam for 15 minutes to 18 minutes"
    },
    {
      "position": 4,
      "text": "Remove from the steamer and arrange in a plate."
    },
    {
      "position": 5,
      "text": "Serve with bagoong."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 5,
