  "id": "4fb928f8-04fe-533d-9ecf-4ec40bce1929",
  "slug": "ginataang-monggo-with-tofu-and-malunggay",
  "name": "Ginataang Monggo with Tofu and Malunggay",
  "recipe_type": "main",
  "brief_description": "Mung bean stew with fried tofu and moringa leaves",
  "cuisine": "Fiipino",
  "instructions": [
    {
      "position": 1,
      "text": "Saute garlic, onion, and tomato."
    },
    {
      "position": 2,
      "text": "Add mung beans. Saute for 2 minutes."
    },
    {
      "position": 3,
      "text": "Pour water in the pot. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Pork Cube. Let boil. Continue cooking until the mung beans are mushy. Note: add more water as needed."
    },
    {
      "position": 5,
      "text": "Dilute Knorr Ginataang Gulay Mix in 1 \u00bd cups water. Mix well. Pour into the pot."
    },
    {
      "position": 6,
      "text": "Add fried tofu. Cook for 2 minutes."
    },
    {
      "position": 7,
      "text": "Put the malunggay leaves in the pot and then season with ground black pepper and salt."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
