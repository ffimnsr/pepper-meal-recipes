  "id": "aaa0834e-0a40-50e0-ba9c-a7c603b35b7a",
  "slug": "beef-pares-mami-noodles-recipe",
  "name": "Beef Pares Mami Noodles Recipe",
  "recipe_type": "soup",
  "brief_description": "This is a recipe for beef pares mami. It is a type of beef noodle soup that makes use of fresh miki noodles.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a pot. Add the beef neck bones. Let boil. Simmer for 2 hours."
    },
    {
      "position": 2,
      "text": "Add salt and ground black pepper to taste."
    },
    {
      "position": 3,
      "text": "Arrange the miki noodles in a cooking basket. Submerge in boiling broth for 10 minutes. Remove, drain, and the set aside."
    },
    {
      "position": 4,
      "text": "Arrange the cooked miki noodles along with a serving of beef pares in individual bowls. Top with chopped scallions, toasted garlic, and a piece of boiled egg, sliced in half."
    },
    {
      "position": 5,
      "text": "Pour a cup or two of hot beef stock in the bowl. Season with some fish sauce and ground black pepper."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 120,
  "preparation_time_minutes": 15,
