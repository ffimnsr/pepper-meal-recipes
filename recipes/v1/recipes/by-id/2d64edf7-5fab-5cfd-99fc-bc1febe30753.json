  "id": "2d64edf7-5fab-5cfd-99fc-bc1febe30753",
  "slug": "grilled-mussels-recipe",
  "name": "Grilled Mussels Recipe",
  "recipe_type": "appetizer",
  "brief_description": "This Grilled Mussels Recipe makes a perfect seafood appetizer for many reasons. To name a few, it is delicious, easy to prepare, and budget friendly.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Clean the mussels and boil in 2 cups of water for at least 2 to 5 minutes."
    },
    {
      "position": 2,
      "text": "Let the mussels cool. Drain and remove the beard. Set aside."
    },
    {
      "position": 3,
      "text": "Heat the olive oil in a pan."
    },
    {
      "position": 4,
      "text": "Saut\u00e9 the onion until soft"
    },
    {
      "position": 5,
      "text": "Add the garlic and continue to saut\u00e9 for 1 minute."
    },
    {
      "position": 6,
      "text": "Add the tomato and tomato paste. Saut\u00e9 for 1 minute. Transfer to a bowl and let cool."
    },
    {
      "position": 7,
      "text": "Meanwhile combine breadcrumbs, parsley, mint, and lemon juice. Mix well."
    },
    {
      "position": 8,
      "text": "Scoop the saut\u00e9ed onion, garlic, and tomato mixture and arrange on top of the mussels. Add the breadcrumbs mixture above."
    },
    {
      "position": 9,
      "text": "Heat the grill and grill the mussels for 5 to 7 minutes in medium heat."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 11,
      "text": "Serve as an appetizer."
    },
    {
      "position": 12,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 7,
  "preparation_time_minutes": 5,
