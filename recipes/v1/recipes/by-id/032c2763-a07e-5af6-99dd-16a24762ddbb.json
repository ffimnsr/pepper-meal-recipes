  "id": "032c2763-a07e-5af6-99dd-16a24762ddbb",
  "slug": "beef-in-oyster-sauce-recipe",
  "name": "Beef in Oyster Sauce",
  "recipe_type": null,
  "brief_description": "This simple and quick beef in oyster sauce recipe will definitely make you serve a decent meal in the table right before lunch or dinner time.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine beef, oyster sauce, soy sauce, salt, and ground black pepper. Mix and marinate for at least 30 minutes."
    },
    {
      "position": 2,
      "text": "Heat a wok and pour-in cooking oil."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 garlic, ginger, and chili."
    },
    {
      "position": 4,
      "text": "Stir-fry spinach then place in a serving plate and set aside."
    },
    {
      "position": 5,
      "text": "Using the same wok with remaining oil, stir-fry the marinated beef for 5 to 6 minutes or until the color turns brown."
    },
    {
      "position": 6,
      "text": "Arrange the beef on top of the spinach."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": 30,
