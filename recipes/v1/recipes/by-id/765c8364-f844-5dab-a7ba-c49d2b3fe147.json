  "id": "765c8364-f844-5dab-a7ba-c49d2b3fe147",
  "slug": "beef-kaldereta-sa-gata-with-peanut-butter",
  "name": "Beef Kaldereta sa Gata with Peanut Butter",
  "recipe_type": "main",
  "brief_description": "Beef stewed in tomato based sauce and coconut milk with potato, bell peppers, and peanut butter.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute onion, garlic, and tomato. Continue to saute until onion and tomato softens."
    },
    {
      "position": 3,
      "text": "Add beef. Cook until it turns light brown."
    },
    {
      "position": 4,
      "text": "Pour tomato sauce and beef broth. Let boil. Cover and cook in low heat until the sauce reduces to half."
    },
    {
      "position": 5,
      "text": "Pour coconut milk into the pot. Add Thai chili peppers. Cover and continue to boil until the beef gets tender."
    },
    {
      "position": 6,
      "text": "Add peanut butter. Stir."
    },
    {
      "position": 7,
      "text": "Add the potato.Cover and cook for 10 minutes."
    },
    {
      "position": 8,
      "text": "Put the bell peppers into the pot. Cover and cook for 12 minutes."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 10,
      "text": "Transfer to a serving plate and serve with warm white rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
