  "id": "bb1a7563-0179-5d95-8831-9a9a8a496890",
  "slug": "breakfast-t-bone-steak-with-fried-eggs-recipe",
  "name": "Breakfast T-Bone Steak with Fried Eggs",
  "recipe_type": "breakfast",
  "brief_description": "This is a recipe for Breakfast T-Bone Steak with Fried Eggs",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt all over the steak. Let it stay for 15 minutes."
    },
    {
      "position": 2,
      "text": "Melt butter in a pan. Add olive oil."
    },
    {
      "position": 3,
      "text": "Gently pound the garlic until it cracks and then put it into the pan. Do not remove the skin. Note: this will give the steak a garlicky taste."
    },
    {
      "position": 4,
      "text": "Put the T-bone steak into the pan. Cook for 4 to 5 minutes between low to medium heat."
    },
    {
      "position": 5,
      "text": "Turn the steak over to cook the opposite side. Continue to cook for 3 minutes. You can also scoop some butter using a spoon and pour it on top of the steak while frying."
    },
    {
      "position": 6,
      "text": "Arrange on a serving plate. Season with ground black pepper"
    },
    {
      "position": 7,
      "text": "Serve with fried eggs. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 8,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
