  "id": "3491aa7b-8ec2-5173-afb8-a7bc8c0edbd2",
  "slug": "shingaling-recipe",
  "name": "Shingaling Recipe",
  "recipe_type": "snack",
  "brief_description": "Shingaling is a popular snack in the Philippines. It is made from miki noodles. Here is a recipe from Rene Magdiwang. Enjoy!",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "In a bowl, combine garlic powder, chili powder, and beef powder. Mix them well."
    },
    {
      "position": 2,
      "text": "Rub the mixture on the miki noodles to the point that all sides are coated."
    },
    {
      "position": 3,
      "text": "Arrange the noodles in a wide tray. Do not let the noodles overlap each other."
    },
    {
      "position": 4,
      "text": "Let the noodles dry under direct sunlight for 1 day. Cover the noodles with a clean screen or cheese cloth to protect it from insects if you are drying them outside of your house."
    },
    {
      "position": 5,
      "text": "Heat the oil and deep fry the dried noodles until golden brown."
    },
    {
      "position": 6,
      "text": "Serve with vinegar!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 12,
  "preparation_time_minutes": null,
  "rest_time_minutes": null,
  "difficulty": "medium",
