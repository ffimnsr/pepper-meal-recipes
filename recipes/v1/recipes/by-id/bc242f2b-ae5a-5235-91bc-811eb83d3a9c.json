  "id": "bc242f2b-ae5a-5235-91bc-811eb83d3a9c",
  "slug": "ginisang-repolyo-with-chicken-knr-cc",
  "name": "Ginisang Repolyo with Chicken",
  "recipe_type": "main",
  "brief_description": "Sauteed cabbage with chicken, oyster sauce, and bell peppers. This easy vegetable recipe is healthy and delicious.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot."
    },
    {
      "position": 2,
      "text": "Saute onion and garlic. Once the onion gets soft, add chicken. Cook until color turns light brown."
    },
    {
      "position": 3,
      "text": "Pour \u00be cups water. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Chicken Cube. Cover the pot and continue to cook until the water evaporates."
    },
    {
      "position": 5,
      "text": "Put the oyster sauce and cabbage into the cooking pot. Stir. Saute for 1 minute."
    },
    {
      "position": 6,
      "text": "Add \u00bd cup water. Stir and cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Put the bell peppers into the pot. Season with salt and ground black pepper. Continue to cook for 2 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 5,
