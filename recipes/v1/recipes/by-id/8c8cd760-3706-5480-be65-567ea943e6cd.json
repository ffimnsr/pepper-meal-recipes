  "id": "8c8cd760-3706-5480-be65-567ea943e6cd",
  "slug": "barbecued-chicken-lettuce-wrap",
  "name": "Barbecued Chicken Lettuce Wrap",
  "recipe_type": "appetizer",
  "brief_description": "This chicken lettuce wrap recipe demonstrates how one of the most sought after appetizer dish in Asian restaurants is cooked. It is tasty and appetizing.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a wok."
    },
    {
      "position": 2,
      "text": "Put-in the chicken. Stir fry for 2 minutes."
    },
    {
      "position": 3,
      "text": "Add the ginger and garlic. Cook for 30 seconds."
    },
    {
      "position": 4,
      "text": "Put-in the chopped mushroom. Season with salt and pepper. Stir-fry for 1 to 2 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the chopped water chestnuts, bell pepper, and green onion. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add the orange juice and Hoisin sauce. Stir until all the ingredients are coated."
    },
    {
      "position": 7,
      "text": "Arrange the lettuce leaves in a plate. Scoop some mixture in each lettuce leaf."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
