  "slug": "salmon-steak-recipe",
  "name": "Salmon Steak Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Salmon Steak.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine olive oil and lemon juice. Stir."
    },
    {
      "position": 2,
      "text": "Arrange salmon in a wide plate then pour-in olive oil and lemon juice mixture. Marinate each side for about 5 to 7 minutes."
    },
    {
      "position": 3,
      "text": "Meanwhile, combine garlic powder, salt, and ground black pepper in a small bowl. Mix."
    },
    {
      "position": 4,
      "text": "Sprinkle the garlic powder mixture equally on the salmon."
    },
    {
      "position": 5,
      "text": "Heat a grill, and then grill each side of the salmon for 4 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Transfer to a serving plate and serve with garlic sesame spinach."
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
