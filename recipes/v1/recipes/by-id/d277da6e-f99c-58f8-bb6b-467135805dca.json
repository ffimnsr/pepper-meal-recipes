  "id": "d277da6e-f99c-58f8-bb6b-467135805dca",
  "slug": "pinangat-na-isda",
  "name": "Pinangat",
  "recipe_type": "soup",
  "brief_description": "Pinangat is a simple Filipino fish dish cooked with bilimbi, tomatoes, and whole peppercorns. The fish simmers gently in its own juices, creating a sour and savory broth that pairs perfectly with steamed rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the fish, bilimbi, and tomatoes alternately in a wide cooking pot."
    },
    {
      "position": 2,
      "text": "Sprinkle the salt and whole peppercorns over the fish, then pour in the water."
    },
    {
      "position": 3,
      "text": "Cover the pot and bring the liquid to a boil over medium heat."
    },
    {
      "position": 4,
      "text": "Reduce the heat to low once the liquid starts to boil. Continue cooking for 15 to 20 minutes or until the fish is fully cooked."
    },
    {
      "position": 5,
      "text": "Turn off the heat and carefully transfer the pinangat to a serving plate. Serve with steamed rice."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
