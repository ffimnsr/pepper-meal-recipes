  "id": "be016816-ec2f-58d1-bdfd-f6bb40e6350c",
  "slug": "sizzling-bulalo-recipe",
  "name": "Sizzling Bulalo Recipe",
  "recipe_type": null,
  "brief_description": "Sizzling bulalo is a beef shank recipe cooked in a fajita or sizzling plate and topped with beef gravy. It is eaten with rice and mixed veggies.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Make the mushroom gravy. Heat a cooking pot or sauce pan then add the 1 tablespoon butter and melt. Put-in the mushroom and saut\u00e9 for 3 minutes. Add the condensed cream of mushroom soup then stir. Pour 3/4 cup water; add 1/2 teaspoon salt and 1/2 teaspoon ground black pepper then stir. Simmer for 5 minutes or until the sauce thickens.Set aside."
    },
    {
      "position": 2,
      "text": "Arrange Beef Shank in a cooking pot then sprinkle 1 teaspoon salt."
    },
    {
      "position": 3,
      "text": "Pour 3 cups water and apply heat. Let boil and simmer until the beef is tender. Remove from the cooking pot and place in a clean plate. Note: add water as needed."
    },
    {
      "position": 4,
      "text": "Season both sides of the beef with 1/2 teaspoon salt, 1/2 teaspoon ground black pepper, and garlic powder. Set aside."
    },
    {
      "position": 5,
      "text": "Heat a pan then add 2 tablespoons butter. Let the butter melt."
    },
    {
      "position": 6,
      "text": "Pan-fry both sides of the beef for at least 2 minutes per side."
    },
    {
      "position": 7,
      "text": "Heat the sizzling plate (metal plate) then put-in 1 tablespoon butter and let melt."
    },
    {
      "position": 8,
      "text": "Arrange the pan fried beef on the sizzling plate, top with mushroom gravy, and place the corn on the side."
    },
    {
      "position": 9,
      "text": "Serve hot. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 90,
  "preparation_time_minutes": 10,
