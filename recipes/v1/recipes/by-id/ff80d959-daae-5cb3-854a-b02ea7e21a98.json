  "id": "ff80d959-daae-5cb3-854a-b02ea7e21a98",
  "slug": "garlic-pepper-beef-in-mushroom-gravy",
  "name": "Garlic Pepper Beef in Mushroom Gravy",
  "recipe_type": "main",
  "brief_description": "Tender beef sirloin stir-fried with garlic and black pepper, coated in a rich mushroom gravy, and served hot with rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a large skillet over medium heat and add the minced garlic. Cook until golden brown and crispy, about 2-3 minutes. Using a fine mesh strainer, separate the crispy garlic from the oil and set the garlic aside for garnish."
    },
    {
      "position": 2,
      "text": "Reduce the garlic oil to 2 tablespoons in the pan. Increase heat to medium-high and saut\u00e9 the sliced beef until it browns on all sides, about 4-5 minutes total."
    },
    {
      "position": 3,
      "text": "Pour in the soy sauce and oyster sauce, then season with salt, ground black pepper, and half of the toasted garlic. Stir to combine and cook for 1 minute. Remove beef from pan and set aside."
    },
    {
      "position": 4,
      "text": "In the same pan, melt the butter over medium heat. Add the flour and whisk continuously, cooking until the mixture turns golden brown, about 2-3 minutes."
    },
    {
      "position": 5,
      "text": "Gradually pour in the beef broth while whisking constantly to prevent lumps. Add the sliced mushrooms and bring to a simmer. Stir until the sauce thickens, about 3-4 minutes, then season with onion powder, garlic powder, salt, and ground black pepper."
    },
    {
      "position": 6,
      "text": "Add the cooked beef back to the pan and toss until well combined with the mushroom gravy. Cook for 2-3 minutes to heat through. Transfer to a serving plate, top with the remaining crispy garlic, and serve immediately."
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 15,
  "rest_time_minutes": null,
  "difficulty": "medium",
