  "id": "b76ff2cc-489c-526f-929d-4e377cc0b685",
  "slug": "easy-chicken-adobo-recipe-knr-cc",
  "name": "Easy Chicken Adobo",
  "recipe_type": "main",
  "brief_description": "Straightforward recipe for Filipino chicken adobo. This will give you a tasty and delicious adobo that you can enjoy eating with rice.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a cooking pot. Saute garlic and onion until the garlic turns light brown and the onion softens."
    },
    {
      "position": 2,
      "text": "Add chicken pieces. Cook until the chicken turns light brown."
    },
    {
      "position": 3,
      "text": "Pour water, soy sauce, and vinegar. Let boil."
    },
    {
      "position": 4,
      "text": "Add Knorr Chicken Cube, whole peppercorn, and dried bay leaves. Stir. Cover the pot and cook in medium heat for 15 minutes."
    },
    {
      "position": 5,
      "text": "Turn the chicken pieces over. Cover and continue to cook for another 15 minutes."
    },
    {
      "position": 6,
      "text": "Add dark brown sugar and season with salt."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
