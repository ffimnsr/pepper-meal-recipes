  "id": "28b9aa45-129c-5865-a89f-a75ff808d6c3",
  "slug": "ginisang-ampalaya-with-shrimp-sauteed-bitter-gourd",
  "name": "Ginisang Ampalaya with Shrimp (Sauteed Bitter Gourd)",
  "recipe_type": null,
  "brief_description": "Ginisang Ampalaya with Shrimp (or saut\u00e9ed bitter gourd) is a simple yet nutritious dish that you can prepare for lunch. This recipe involves bitter gourd (also called bitter melon), which is a type of vegetable that is known to have a lot of nutritional value.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine ampalaya and 1 tablespoon salt. Mix well. Let it stay for 15 minutes. Rinse with water."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 3,
      "text": "Once the oil gets hot, add the garlic. Saute until the color turns light brown."
    },
    {
      "position": 4,
      "text": "Add the onion and tomato. Sauce until the texture turns soft."
    },
    {
      "position": 5,
      "text": "Add the shrimp. Stir and cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Stir-in the ampalaya. Cook for 3 to 5 minutes. Add salt and pepper to taste."
    },
    {
      "position": 7,
      "text": "Make extra room in the pan by pushing the mixture on the side. Pour the beaten eggs in the pan. Continue to cook the eggs while trying to stir around."
    },
    {
      "position": 8,
      "text": "Mix the cooked egg with the rest of the ingredients. Cook for a minute."
    },
    {
      "position": 9,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 15,
