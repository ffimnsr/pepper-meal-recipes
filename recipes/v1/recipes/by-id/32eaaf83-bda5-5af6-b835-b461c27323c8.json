  "id": "32eaaf83-bda5-5af6-b835-b461c27323c8",
  "slug": "apple-pork-pot-roast",
  "name": "Apple Pork Pot Roast",
  "recipe_type": "side",
  "brief_description": "Apple Pork Pot Roast can be considered as a comfort food. It is delicious and full of flavor. This is best served for lunch or dinner along with bread and butter, mashed potatoes, or rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Rub salt and pepper all over the pork roast. Let is stay for 20 minutes."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a Dutch oven or oven safe cooking pot."
    },
    {
      "position": 3,
      "text": "Once the oil becomes hot, sear the pork until the color of all the sides turns light to medium brown."
    },
    {
      "position": 4,
      "text": "Pour-in apple juice and beef broth. Let boil."
    },
    {
      "position": 5,
      "text": "Meanwhile, preheat oven to 310 degrees Fahrenheit."
    },
    {
      "position": 6,
      "text": "Add the onion, chopped apples, thyme, and rosemary to the pork roast. Cover and cook for 5 minutes."
    },
    {
      "position": 7,
      "text": "Turn off the stove top heat. Place the dutch oven inside the conventional oven. Roast for 150 to 180 minutes."
    },
    {
      "position": 8,
      "text": "Remove the roast from the Dutch oven and arrange in a serving plate. Strain the remaining sauce and thicken by cooking it further until the liquid evaporates and the desired thickness is achieved. Add salt and pepper to taste."
    },
    {
      "position": 9,
      "text": "Pour the sauce over the pot roast."
    },
    {
      "position": 10,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 180,
  "preparation_time_minutes": 10,
