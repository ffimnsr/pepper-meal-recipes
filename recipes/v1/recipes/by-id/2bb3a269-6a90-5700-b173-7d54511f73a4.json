  "id": "2bb3a269-6a90-5700-b173-7d54511f73a4",
  "slug": "rib-eye-steak-with-potatoes-recipe",
  "name": "Rib Eye Steak with Grilled Potato",
  "recipe_type": null,
  "brief_description": "Rib Eye Steak with Grilled Potato is perfect for dinner along with a glass of red wine. Like any other steak dish, it is important to not overcook the steak",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the rub by combining salt, ground black pepper, garlic powder, and cayenne pepper. Mix well."
    },
    {
      "position": 2,
      "text": "Rub the mixture all over the rib eye steak. Let it stay for 10 minutes."
    },
    {
      "position": 3,
      "text": "Meanwhile place oil on a large bowl then sprinkle a little salt. Add-in the potatoes and coat with oil."
    },
    {
      "position": 4,
      "text": "Heat-up the grill."
    },
    {
      "position": 5,
      "text": "Grill the rib eye steak for 5 to 6 minutes per side."
    },
    {
      "position": 6,
      "text": "Grill the potatoes for 10 to 12 minutes."
    },
    {
      "position": 7,
      "text": "Let the steak rest for 10 minutes. Arrange the rib eye steak in a serving plate along with the potatoes."
    },
    {
      "position": 8,
      "text": "Serve with your favorite steak sauce. Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 24,
  "preparation_time_minutes": 5,
