  "id": "b24609c8-33b6-552f-935c-792a118806f2",
  "slug": "sauteed-shrimp-string-beans",
  "name": "Sauteed Shrimp with String Beans",
  "recipe_type": null,
  "brief_description": "Sauteed Shrimp with String Beans or Ginisang Hipon at Sitaw is a quick and easy shrimp with vegetable recipe that you can prepare for lunch. This goes well with steamed white rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the onion, tomato, and garlic."
    },
    {
      "position": 3,
      "text": "Sprinkle a dash of ground black pepper."
    },
    {
      "position": 4,
      "text": "Once the onion turns soft, put-in the shrimp and stir fry for 2 to 3 minutes."
    },
    {
      "position": 5,
      "text": "Add the string beans and soy sauce. Continue to stir fry for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 17,
