  "id": "53c343ea-3016-53ea-a7ec-f092b7f4abf2",
  "slug": "how-to-make-biko-with-latik",
  "name": "Biko with Latik",
  "recipe_type": "dessert",
  "brief_description": "Filipino rice cake made from glutinous rice and brown sugar topped with savory coconut milk residue.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare latik by boiling 2 cups coconut milk in a saucepan. Adjust heat to medium. Continue boiling while stirring until texture thickens. Lower the heat once oil becomes visible. Cook and stir constantly until the color of the residue turns golden brown (note: latik is the residue formed after boiling coconut milk). Separate the oil from the latik using a strainer or filter paper. Set aside."
    },
    {
      "position": 2,
      "text": "Start making the biko by combining glutinous rice and water in a rice cooker. Set the cooker to \u201ccook\u201d mode. Wait until the process is complete."
    },
    {
      "position": 3,
      "text": "Boil 4 cups coconut milk in a cooking pot for 7 minutes."
    },
    {
      "position": 4,
      "text": "Add brown sugar and salt. Stir."
    },
    {
      "position": 5,
      "text": "Add cooked rice. Stir until well blended. Continue cooking while stirring until rice absorbs the coconut milk mixture completely."
    },
    {
      "position": 6,
      "text": "Line banana leaves over a baking tray. Brush coconut oil over the leaves."
    },
    {
      "position": 7,
      "text": "Transfer biko into the tray once the consistency becomes thick and sticky (paste-like). Top with latik. Let it cool down for at least 15 minutes."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 5,
