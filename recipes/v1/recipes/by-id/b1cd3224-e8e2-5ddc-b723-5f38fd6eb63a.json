  "id": "b1cd3224-e8e2-5ddc-b723-5f38fd6eb63a",
  "slug": "cassava-suman-recipe",
  "name": "Cassava Suman",
  "recipe_type": "dessert",
  "brief_description": "Cassava Suman is a native Filipino rice cake (kakanin) that is comprised of grated cassava, brown sugar, and coconut cream.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the cassava and brown sugar in a large mixing bowl. Gently fold until the ingredients are well distributed."
    },
    {
      "position": 2,
      "text": "Add the coconut cream. Stir until all the ingredients are well incorporated."
    },
    {
      "position": 3,
      "text": "Scoop about 1/2 cup of mixture and arrange on one side of the banana leaf. Mold the mixture so that it appears to be cylindrical in shape, with the length of about 4 to 5 inches."
    },
    {
      "position": 4,
      "text": "Roll the banana leaf to wrap the mixture. Make sure that the leaf is not loose so that the mixture can use it as a mold. Secure the top and bottom part of the leaf by folding it inward in the same direction."
    },
    {
      "position": 5,
      "text": "Boil about 5 to 6 cups of water in a steamer."
    },
    {
      "position": 6,
      "text": "Arrange the wrapped cassava suman on the steamer and then steam for 30 to 35 minutes or until the texture becomes firm."
    },
    {
      "position": 7,
      "text": "Remove from the steamer and let the temperature cool down."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
