  "id": "38236d20-1ebb-5cdc-ab07-599cd555a368",
  "slug": "sauteed-bok-choy-shrimp",
  "name": "Sauteed Bok Choy with Shrimp",
  "recipe_type": "main",
  "brief_description": "Sauteed Bok Choy with Shrimp is a simple recipe that involves baby bok choy. This vegetable is somewhat similar to a vegetable known as pechay",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the garlic, onions, and tomato. Continue cooking until the onions soften."
    },
    {
      "position": 3,
      "text": "Put-in the shrimp. Stir. Cook for 1 minute."
    },
    {
      "position": 4,
      "text": "Pour-in chicken broth. Let boil."
    },
    {
      "position": 5,
      "text": "Add the bok choy. Stir. Cover and cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Season with salt and pepper. Continue cooking for 1 minute."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
