  "id": "169115a5-37c5-5d17-86c0-e016e99e039d",
  "slug": "chicken-afritada-sa-gata",
  "name": "Chicken Afritada sa Gata",
  "recipe_type": "main",
  "brief_description": "Filipino chicken stew recipe wherein chicken is stewed in tomato sauce and coconut milk.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat oil in a pan. Saute garlic and onion."
    },
    {
      "position": 2,
      "text": "Add the chicken. Saute until it turns light brown in color."
    },
    {
      "position": 3,
      "text": "Add tomato sauce, hotdogs, and water. Let it boil."
    },
    {
      "position": 4,
      "text": "Combine Knorrr Ginataang Gulay Recipe Mix with 2 cups water. Mix well and then pour it into the pan. Cover and cook for 45 minutes using low heat."
    },
    {
      "position": 5,
      "text": "Add Knorr Chicken Cube, potatoes, and carrots. Cook for 8 minutes."
    },
    {
      "position": 6,
      "text": "Add the green peas and bell peppers. Cook for 3 minutes."
    },
    {
      "position": 7,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 8,
      "text": "Serve with rice. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "medium",
