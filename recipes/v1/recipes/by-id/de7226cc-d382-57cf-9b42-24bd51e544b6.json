  "slug": "salmon-sinigang-recipe-knr_sg",
  "name": "Salmon Sinigang Recipe",
  "recipe_type": null,
  "brief_description": "This is a Recipe for Salmon Sinigang",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour water in a cooking pot. Let boil."
    },
    {
      "position": 2,
      "text": "Add tomato, onion, and Daikon radish. Cover and cook for 5 minutes."
    },
    {
      "position": 3,
      "text": "Add salmon fillet. Cook for 2 minutes."
    },
    {
      "position": 4,
      "text": "Add Knorr Sinigang na Isda mix. Stir."
    },
    {
      "position": 5,
      "text": "Put the long green peppers into the pot along with the okra,and snake beans. Cover the pot. Cook in medium heat for 2 minutes."
    },
    {
      "position": 6,
      "text": "Add kangkong stalks. Season with patis and ground black pepper. Cook for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Add kangkong leaves. Turn the heat off. Cover the pot and let it stay for 5 minutes."
    },
    {
      "position": 8,
      "text": "Transfer to a serving bowl. Serve!"
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
