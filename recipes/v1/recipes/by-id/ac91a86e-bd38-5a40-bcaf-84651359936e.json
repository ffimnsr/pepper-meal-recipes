  "id": "ac91a86e-bd38-5a40-bcaf-84651359936e",
  "slug": "braised-vegetables",
  "name": "Braised Vegetable Recipe",
  "recipe_type": null,
  "brief_description": "Braised Vegetables or wet-roasted vegetables is a vegetarian dish composed basically of mushrooms, bamboo shoots,young corn, snow peas, and carrots. This is a perfect dish for health conscious individuals and people who are on a diet.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Blanch the snow peas then set aside"
    },
    {
      "position": 2,
      "text": "In a pan, saut\u00e9 the garlic and onions"
    },
    {
      "position": 3,
      "text": "Add the ground black pepper then cook until the onions are soft"
    },
    {
      "position": 4,
      "text": "Put in the soy sauce and oyster sauce then mix slightly"
    },
    {
      "position": 5,
      "text": "Add the carrots then cook for 2 minutes"
    },
    {
      "position": 6,
      "text": "Put-in the young corn and bamboo shoots then simmer for 3 minutes"
    },
    {
      "position": 7,
      "text": "Add the mushrooms then simmer for 5 to 7 minutes"
    },
    {
      "position": 8,
      "text": "Add salt and brown sugar to taste"
    },
    {
      "position": 9,
      "text": "Put-in the blanched snow peas"
    },
    {
      "position": 10,
      "text": "Serve hot. Share and Enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 25,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
