  "id": "d04a4688-e746-511d-bc93-d383bcb51920",
  "slug": "saffron-rice-recipe",
  "name": "Saffron Rice Recipe",
  "recipe_type": "side",
  "brief_description": "Saffron Rice or yellow rice is a delicious rice dish that is flavorful and smells real nice. Saffron rice makes use of saffron threads, which is considered as one of the most expensive spices in the world. No wonder this saffron rice is amazing.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Clean the rice by washing placing it in a bowl with water. Discard the water."
    },
    {
      "position": 2,
      "text": "Put the rice on a cooking pot. Pour-in 3 1/2 cups water and add the butter, saffron, bell peppers and salt. Stir."
    },
    {
      "position": 3,
      "text": "Heat the cooking pot (covered) in a stove top. Let boil."
    },
    {
      "position": 4,
      "text": "Once the liquid starts to boil, adjust the heat to a simmer. Continue to simmer for 15 to 20 minutes or until the rice completely absorb the liquid. Try to gently stir the rice in the middle of the process to ensure that the ingredients are distributed evenly."
    },
    {
      "position": 5,
      "text": "Transfer to a serving bowl with your favorite main dish such as beef kebobs."
    },
    {
      "position": 6,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "medium",
