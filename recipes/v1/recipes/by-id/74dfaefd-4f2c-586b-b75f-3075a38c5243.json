  "id": "74dfaefd-4f2c-586b-b75f-3075a38c5243",
  "slug": "yummy-blueberry-pancake-recipe",
  "name": "Yummy Blueberry Pancake Recipe",
  "recipe_type": "dessert",
  "brief_description": "Blueberry pancake is perfect for breakfast alog with some pancake syrup. Get the details of this pancake recipe here.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Mix the dry ingredients (flour, salt, sugar, baking powder) in a bowl."
    },
    {
      "position": 2,
      "text": "Using another clean bowl, whisk in egg, oil, and milk."
    },
    {
      "position": 3,
      "text": "Add the egg mixture to the dry ingredients. Mix by folding."
    },
    {
      "position": 4,
      "text": "Fold the blueberries in the mix."
    },
    {
      "position": 5,
      "text": "Heat and lightly spray some oil on the pan."
    },
    {
      "position": 6,
      "text": "Scoop 1/4 cup of mixture and pour in the pan. Let it cook until bubbles comes on top. Turn the pancake over and cook for a few seconds."
    },
    {
      "position": 7,
      "text": "Serve with pancake syrup."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 5,
