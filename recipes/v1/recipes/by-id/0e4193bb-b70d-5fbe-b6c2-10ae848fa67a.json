  "id": "0e4193bb-b70d-5fbe-b6c2-10ae848fa67a",
  "slug": "adobong-labong-bamboo-shoot-recipe",
  "name": "Adobong Labong Recipe",
  "recipe_type": null,
  "brief_description": "Adobong Labong is a type of bamboo shoot dish cooked with pork and shrimps. This Adobong Labong Recipe will show you everything that you need to know. Bamboo Shoots are known as \u201cLabong\u201d in Filipino. These are soft and young edible bamboo sprouts that sprung on the ground.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Pour cooking oil in a wok then apply heat."
    },
    {
      "position": 2,
      "text": "Saut\u00e9 garlic and onions"
    },
    {
      "position": 3,
      "text": "Add pork then cook for 5 minutes."
    },
    {
      "position": 4,
      "text": "Pour-in pork or beef broth and let boil. Cover and simmer for 10 to15 minutes."
    },
    {
      "position": 5,
      "text": "Add shrimps, bamboo shoots, salt, and ground black pepper. Simmer for 5 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in vinegar and let boil. Simmer uncovered for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate then serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 10,
