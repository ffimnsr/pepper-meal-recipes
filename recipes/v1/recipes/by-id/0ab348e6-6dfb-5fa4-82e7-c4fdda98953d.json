  "id": "0ab348e6-6dfb-5fa4-82e7-c4fdda98953d",
  "slug": "simple-bibingkang-malagkit",
  "name": "Simple Bibingkang Malagkit",
  "recipe_type": "dessert",
  "brief_description": "Simple Bibingkang Malagkit is a Filipino sticky rice dessert dish made from glutinous rice, coconut milk, and sugar.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "In a rice cooker or cooking pot, combine water and rice. Cook until the rice fully absorb the water. Note that the rice is not yet fully cooked at this point."
    },
    {
      "position": 2,
      "text": "Transfer the rice on a baking tray."
    },
    {
      "position": 3,
      "text": "Preheat the oven to 350 F."
    },
    {
      "position": 4,
      "text": "Combine the coconut milk and cream, salt, sugar, and vanilla extract in a mixing bowl. Stir until all the ingredients are well blended."
    },
    {
      "position": 5,
      "text": "Pour the mixture on the baking tray with rice. Gently stir until all the ingredients are distributed."
    },
    {
      "position": 6,
      "text": "Bake for 40 to 60 minutes or until the top turns medium brown."
    },
    {
      "position": 7,
      "text": "Remove from the oven. Let it cool down for 30 to 50 minutes."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 6,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 15,
