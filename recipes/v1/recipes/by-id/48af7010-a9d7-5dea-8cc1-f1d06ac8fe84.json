  "id": "48af7010-a9d7-5dea-8cc1-f1d06ac8fe84",
  "slug": "paksiw-na-isda-recipe",
  "name": "Paksiw na Isda Recipe",
  "recipe_type": null,
  "brief_description": "This Paksiw na Isda Recipe is simply fish cooked in vinegar and garlic. This seafood dish is best eaten with steamed rice.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a pan and cooking pot then pour-in vinegar and water."
    },
    {
      "position": 2,
      "text": "Add salt and whole peppercorn then stir. Bring to a boil."
    },
    {
      "position": 3,
      "text": "Arrange the fish in the pan along with the ginger, garlic, onion, bitter gourd, and finger chili. Cover and simmer in low to medium heat for 12 to 15 minutes."
    },
    {
      "position": 4,
      "text": "Turn off the heat and transfer to a serving plate."
    },
    {
      "position": 5,
      "text": "Serve hot with steamed rice. Share and enjoy!"
    },
    {
      "position": 6,
      "text": "Note: You may substitute salt with 3/4 to 1 tablespoon fish sauce."
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 25,
