  "id": "c399f4b0-a33d-5723-b093-c07f878b1326",
  "slug": "bean-sprout-chicken",
  "name": "Bean Sprout Chicken",
  "recipe_type": null,
  "brief_description": "Bean Sprout Chicken is a quick and easy Asian chicken dish that goes well with a bowl of rice. This recipe is good and easy to follow",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the garlic, ginger, and onion."
    },
    {
      "position": 3,
      "text": "Add the sliced chicken breast. Cook for 5 minutes in medium heat."
    },
    {
      "position": 4,
      "text": "Add the soy sauce, cooking wine, and sesame oil. Stir. Cook for 2 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the mung bean sprouts. Cook for 3 to 5 minutes."
    },
    {
      "position": 6,
      "text": "Add the scallions, sugar, salt, and ground black pepper.Stir and continue to cook for 2 to 3 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Top with toasted sesame seeds."
    },
    {
      "position": 8,
      "text": "Serve.Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
