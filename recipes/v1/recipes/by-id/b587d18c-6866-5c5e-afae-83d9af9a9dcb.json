  "id": "b587d18c-6866-5c5e-afae-83d9af9a9dcb",
  "slug": "breakfast-burrito",
  "name": "Breakfast Burrito",
  "recipe_type": "breakfast",
  "brief_description": "Filipino breakfast burrito with tocino and all the fixins",
  "cuisine": "Filipino Mexican",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the tocino by heating 3 tablespoons of cooking oil in a pan. Adjust your stove between low to medium heat setting. Fry both sides of our CDO Funtastyk Young Pork Tocino until it browns (note: no need to boil). Remove the tocino from the pan. Slice it into serving pieces. Set aside"
    },
    {
      "position": 2,
      "text": "Make the scrambled eggs by combining eggs and fresh milk. Beat until the mixture smoothens. Heat a pan and melt the butter. Once the butter gets hot enough, pour the egg mixture and stir constantly while cooking. Once the texture becomes less runny, add 2 tablespoons of shredded cheddar cheese, and then stir. Transfer to a clean plate. Set aside."
    },
    {
      "position": 3,
      "text": "Prepare the rice by pouring vinegar over it. Mix well and set aside."
    },
    {
      "position": 4,
      "text": "Assemble the burrito. Start by spreading the rice over the tortilla. Top with lettuce, tomato, cheese, egg, and CDO Funtastyk Young Pork Tocino. Secure the contents by wrapping the flour tortilla. Arrange on a serving platter. Serve for breakfast. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 10,
