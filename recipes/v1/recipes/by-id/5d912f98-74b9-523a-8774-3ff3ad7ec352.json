  "id": "5d912f98-74b9-523a-8774-3ff3ad7ec352",
  "slug": "chicken-salad-wrap",
  "name": "Chicken Salad Wrap",
  "recipe_type": "salad",
  "brief_description": "Chicken Salad Wrap is simply chicken salad wrapped in tortilla. You can use either flour or corn tortilla for this recipe.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Combine the celery, chicken, salt, and pepper in a large mixing bowl."
    },
    {
      "position": 2,
      "text": "Put-in the lime juice and mayonnaise. Fold the mixture to mix all the ingredients."
    },
    {
      "position": 3,
      "text": "Arrange 2 leaf lettuces over the tortilla wrap."
    },
    {
      "position": 4,
      "text": "Scoop half of the chicken mixture on top of the lettuce. Fold the opposite sides of the tortilla and roll starting from the end of the unfolded side until the chicken salad is completely secured."
    },
    {
      "position": 5,
      "text": "Serve with chips."
    },
    {
      "position": 6,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 2,
  "cooking_time_minutes": 5,
  "preparation_time_minutes": 10,
