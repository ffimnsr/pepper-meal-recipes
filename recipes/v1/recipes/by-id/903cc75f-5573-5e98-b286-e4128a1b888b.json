  "id": "903cc75f-5573-5e98-b286-e4128a1b888b",
  "slug": "java-rice-with-pork-chop",
  "name": "Java Rice with Pork chop",
  "recipe_type": "main",
  "brief_description": "How to Make Easy Java Rice and Crispy Fried Pork Chop.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Prepare the pork chop by combining all brine ingredients in a large bowl. Mix well. Add pork chop in the brine solution and brine for 7 hours. Note: Cover the bowl and place it inside the refrigerator to avoid contamination."
    },
    {
      "position": 2,
      "text": "Make the Java rice by combining washed rice and water in a cooking pot. Let the mixture boil. Add Knorr Pork Cube. Stir until well blended. Cover the pot and adjust heat between low to medium. Continue cooking until rice is done. Remove the cover from the pot and let the rice cool down."
    },
    {
      "position": 3,
      "text": "Once the rice cools down completely, heat annatto oil on a pan and then add margarine. Saut\u00e9 garlic and onion until the latter softens."
    },
    {
      "position": 4,
      "text": "Add cooked rice. Stir-fry for 2 minutes."
    },
    {
      "position": 5,
      "text": "Add turmeric powder and season with sugar and salt as needed. Set aside."
    },
    {
      "position": 6,
      "text": "Start cooking the pork chop by heating oil on a clean pan."
    },
    {
      "position": 7,
      "text": "Combine flour, garlic powder, onion powder, and baking soda in a resealable bag. Seal and shake."
    },
    {
      "position": 8,
      "text": "Place a piece of brined pork chop in the bag and shake. Dip it in beaten egg and then put it back into the bag and shake until well coated."
    },
    {
      "position": 9,
      "text": "Fry one side in medium heat until it turns golden brown. Turn the pork over and do the same to the other side. Note: perform this step on all pork chops."
    },
    {
      "position": 10,
      "text": "Arrange a cup of Java rice with a piece of pork chop on a plate. Serve with papaya atchara. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
