  "slug": "tofu-and-green-bean-stir-fry-in-oyster-sauce-with-salted-black-beans",
  "name": "Tofu and Green Bean Stir Fry in Oyster Sauce with Salted Black Beans",
  "recipe_type": null,
  "brief_description": "This is a recipe for Tofu and Green Bean Stir Fry in Oyster Sauce with Salted Black Beans.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Cut the fried tofu into cubes. Set aside."
    },
    {
      "position": 2,
      "text": "Heat oil in a pan. When the oil gets hot, saute the onion until soft."
    },
    {
      "position": 3,
      "text": "Add the snake beans, peppers, and salted black beans. Stir-fry for 3 minutes."
    },
    {
      "position": 4,
      "text": "Add the tofu. Continue to stir fry for 1 minutes."
    },
    {
      "position": 5,
      "text": "Combine oyster sauce and chicken broth (or water) in a bowl. Mix well. Pour the mixture into the pan."
    },
    {
      "position": 6,
      "text": "Add ground black pepper and garlic powder. Cook for 3 to 5 minutes."
    },
    {
      "position": 7,
      "text": "Transfer to serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
