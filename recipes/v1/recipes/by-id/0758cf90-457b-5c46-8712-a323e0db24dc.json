  "id": "0758cf90-457b-5c46-8712-a323e0db24dc",
  "slug": "pata-paksiw-recipe",
  "name": "Pata Paksiw Recipe",
  "recipe_type": null,
  "brief_description": "This is a recipe for Pata Paksiw or Paksiw na Pata",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil 7 cups water in a cooking pot."
    },
    {
      "position": 2,
      "text": "Once the water starts to boil, put the pork hocks into the pot. Cover and then boil for 20 minutes."
    },
    {
      "position": 3,
      "text": "Remove the boiled pork hocks from the pot. Discard the water."
    },
    {
      "position": 4,
      "text": "Heat the oil in the same cooking pot and then saute the garlic and onion."
    },
    {
      "position": 5,
      "text": "Add the boiled pork hock back when the onion starts to get soft. Cook for 2 to 3 minutes."
    },
    {
      "position": 6,
      "text": "Pour-in soy sauce, Knorr liquid seasoning, and remaining 3 cups water . Add whole peppercorns and dried bay leaves. Let boil. Cover and cook the pork in low to medium heat until it gets tender (around 40 to 60 minutes). You can turn the pork hock over to cook the opposite side, if needed. Add more water if necessary."
    },
    {
      "position": 7,
      "text": "Pour the vinegar in the cooking pot. Let the liquid re-boil. Stir and then add the brown sugar and banana blossoms. Add salt of needed."
    },
    {
      "position": 8,
      "text": "Cover and cook for 8 minutes."
    },
    {
      "position": 9,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 10,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 70,
  "preparation_time_minutes": 20,
