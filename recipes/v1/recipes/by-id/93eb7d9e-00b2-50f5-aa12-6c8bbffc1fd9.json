  "id": "93eb7d9e-00b2-50f5-aa12-6c8bbffc1fd9",
  "slug": "popcorn-chicken-recipe",
  "name": "Popcorn Chicken",
  "recipe_type": null,
  "brief_description": "This is a recipe for Popcorn Chicken.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle the chicken with salt and pepper. Mix well and let stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Meanwhile, combine the all-purpose flour, garlic powder, and chili powder in a Ziploc bag. Shake to mix."
    },
    {
      "position": 3,
      "text": "Dip the chicken pieces in the beaten egg, and then put the first batch in the bag with the flour mixture. Shake well to coat."
    },
    {
      "position": 4,
      "text": "Heat the cooking oil in a deep cooking pan. When the oil becomes hot, put-in the flour coated chicken one-by-one. Continue frying in low to medium heat until the color turns light to golden brown."
    },
    {
      "position": 5,
      "text": "Remove chicken popcorn from the pan and place in a plate lined with paper towels."
    },
    {
      "position": 6,
      "text": "Serve with cornbread or cornbread muffin. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
