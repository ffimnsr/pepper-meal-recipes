  "id": "8bf7aa1f-fc4e-5748-94b3-586b35c37533",
  "slug": "halabos-na-hipon-with-butter",
  "name": "Halabos na Hipon with Butter",
  "recipe_type": "main",
  "brief_description": "Shrimp steamed in lemon lime soda and butter.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Heat pan and then add shrimp. Stir."
    },
    {
      "position": 2,
      "text": "Pour lemon lime soda. Let it boil while gently stirring shrimp once in a while. Continue cooking until the liquid reduces to half."
    },
    {
      "position": 3,
      "text": "Season with salt and add butter. Let the butter melt. Continue cooking for 1 to 2 minutes."
    },
    {
      "position": 4,
      "text": "Add parsley. Stir."
    },
    {
      "position": 5,
      "text": "Transfer to a serving plate. Serve warm"
    },
    {
      "position": 6,
      "text": "Share and enjoy."
    }
  ],
  "servings": 3,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 5,
