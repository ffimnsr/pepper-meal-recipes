  "slug": "ginataang-mais-at-malagkit-sweet-corn",
  "name": "Ginataang Mais at Malagkit (Sweet Corn and Glutinous Rice in Coconut Milk)",
  "recipe_type": "dessert",
  "brief_description": "This is a recipe for Sweet Corn and Glutinous Rice in Coconut Milk.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Pour coconut milk and coconut cream in a cooking pot. Let it boil."
    },
    {
      "position": 2,
      "text": "Once it starts to boil, add glutinous rice. Stir continously for 10 minutes."
    },
    {
      "position": 3,
      "text": "Add sugar. Stir."
    },
    {
      "position": 4,
      "text": "Add sweetcorn into the pot. Stir and continue to cook in low heat for 8 minutes. Note you can cook this longer to make the corn and rice softer."
    },
    {
      "position": 5,
      "text": "Add vanilla extract and salt. Stir."
    },
    {
      "position": 6,
      "text": "Transfer to a serving bowl. Serve"
    },
    {
      "position": 7,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
