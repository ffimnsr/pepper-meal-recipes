  "id": "f9c696de-1350-51d2-9076-059eae4bd62a",
  "slug": "papis-recipe",
  "name": "Papis Recipe",
  "recipe_type": null,
  "brief_description": "Papis is a simple beef stew dish that makes use of beef and a can of pork and beans. The beef is saut\u00e9ed with garlic and onions and simmered until tender",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the cooking oil in a deep cooking pot or Dutch oven."
    },
    {
      "position": 2,
      "text": "Saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "When the onion becomes soft, add the cubed beef."
    },
    {
      "position": 4,
      "text": "Brown the beef and then pour-in the beef broth or beef stock. Let it boil. Cover and simmer for 45 to 60 minutes. Add water, if needed."
    },
    {
      "position": 5,
      "text": "Put-in the pork and beans. Stir and cook in medium heat for 5 minutes."
    },
    {
      "position": 6,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 60,
  "preparation_time_minutes": 10,
