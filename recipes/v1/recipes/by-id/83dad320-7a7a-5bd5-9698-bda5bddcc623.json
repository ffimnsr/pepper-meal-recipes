  "id": "83dad320-7a7a-5bd5-9698-bda5bddcc623",
  "slug": "how-to-cook-bacon-wrapped-scallops-in-lemon-garlic-butter-sauce",
  "name": "Bacon wrapped Scallops in Lemon Garlic Butter Sauce",
  "recipe_type": "appetizer",
  "brief_description": "Bacon wrapped scallops makes a perfect appetizer, especially when you top it with tasty Lemon Garlic Butter Sauce. It makes a good appetizer for any meal.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Wrap each scallop with a strip of bacon then secure using a wooden toothpick."
    },
    {
      "position": 2,
      "text": "Heat a frying pan then put-in the butter and allow to melt."
    },
    {
      "position": 3,
      "text": "Fry the bacon-wrapped scallops for about 3 minutes per side."
    },
    {
      "position": 4,
      "text": "Pre-heat oven to 350 degrees Fahrenheit. Bake the fried bacon-wrapped scallops for 15 minutes."
    },
    {
      "position": 5,
      "text": "Heat the same pan where the scallops were fried. With the remaining butter, sprinkle the garlic powder and put-in the lemon juice. Cook for a minute then turn-off heat."
    },
    {
      "position": 6,
      "text": "Arrange the baked bacon-wrapped scallops in a serving plate then top with lemon garlic butter sauce."
    },
    {
      "position": 7,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 21,
  "preparation_time_minutes": 5,
