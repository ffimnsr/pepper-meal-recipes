  "id": "53002e39-bd75-50cf-8b36-1ab528a6664a",
  "slug": "tortilla-soup-recipe",
  "name": "Tortilla Soup Recipe",
  "recipe_type": "soup",
  "brief_description": "This flavorful Tortilla Soup Recipe is best for cold weather. Nothing is more comforting like having a hot and hearty soup for dinner.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat a cooking pot and pour-in oil."
    },
    {
      "position": 2,
      "text": "Put-in onion when the oil becomes hot. Cook until soft."
    },
    {
      "position": 3,
      "text": "Add garlic and jalapeno."
    },
    {
      "position": 4,
      "text": "Put-in tomatoes and cook for a minute."
    },
    {
      "position": 5,
      "text": "Add chicken broth and let boil.Simmer for 10 minutes."
    },
    {
      "position": 6,
      "text": "Put the shredded chicken and salt. Simmer for 12 minutes."
    },
    {
      "position": 7,
      "text": "Turn the heat off and transfer to a serving bowl."
    },
    {
      "position": 8,
      "text": "Add cilantro, tortilla strips, sliced avocado, and cheese."
    },
    {
      "position": 9,
      "text": "Serve with lime. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 8,
  "rest_time_minutes": null,
  "difficulty": "medium",
