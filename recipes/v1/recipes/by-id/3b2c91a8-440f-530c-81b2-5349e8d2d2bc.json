  "slug": "ginisang-kalabasa-at-sitaw-with-daing-recipe",
  "name": "Ginisang Kalabasa at Sitaw with Daing Recipe",
  "recipe_type": null,
  "brief_description": "Ginisang kalabasa at sitaw with daing is a Filipino vegetable saute dish that makes use of calabaza squash and string beans as ingredients.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Heat the oil in a pan."
    },
    {
      "position": 2,
      "text": "Saute the garlic and onion."
    },
    {
      "position": 3,
      "text": "Once the onion starts to get soft, add the dried fish. Stir."
    },
    {
      "position": 4,
      "text": "Put-in the calabaza squash. Continue to stir fry for 1 minute."
    },
    {
      "position": 5,
      "text": "Pour-in water and bring to a boil. Cover and cook for 5 to 6 minutes or until the water evaporates."
    },
    {
      "position": 6,
      "text": "Stir in the string beans.Cook for 2 minutes in medium heat."
    },
    {
      "position": 7,
      "text": "Add fish sauce and ground black pepper. Cook for 1 to 3 minutes more."
    },
    {
      "position": 8,
      "text": "Tranfer to a serving plate. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 10,
