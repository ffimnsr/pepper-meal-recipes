  "id": "b5e5c831-a5b7-5761-8a12-ce19f978135e",
  "slug": "pork-with-zucchini-in-oyster-sauce",
  "name": "Pork with Zucchini in Oyster Sauce",
  "recipe_type": null,
  "brief_description": "Pork with Zucchini in Oyster Sauce is a recipe that you can prepare for lunch during ordinary days. This dish is easy and simple. You will definitely like it.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Sprinkle some salt and pepper on the pork slices. Let stand for 10 minutes."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a pan."
    },
    {
      "position": 3,
      "text": "Dredge the pork slices in flour."
    },
    {
      "position": 4,
      "text": "Pan-Fry the pork for 1 minute per side."
    },
    {
      "position": 5,
      "text": "Add oyster sauce, soy sauce, and beef broth. Stir and then cook covered for 5 to 10 minutes (add water as necessary)."
    },
    {
      "position": 6,
      "text": "Put-in the zucchini, salt, and pepper. Stir, and then cook for 5 minutes until most of the liquid evaporates."
    },
    {
      "position": 7,
      "text": "Transfer to a serving plate."
    },
    {
      "position": 8,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 30,
  "preparation_time_minutes": 5,
