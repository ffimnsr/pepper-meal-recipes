  "id": "955c21fe-3f47-5bf4-beed-455e7b06a739",
  "slug": "chicharon-bulaklak-recipe",
  "name": "Chicharon Bulaklak Recipe",
  "recipe_type": "appetizer",
  "brief_description": "Chicharon Bulaklak or deep-fried ruffled fat is a popular Filipino appetizer. It is often consumed with alcoholic drinks and is best eaten when dipped in spicy vinegar.",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the ruffle fat, whole peppercorn, 2 tablespoons salt, and bay leaves in a cooking pot. Pour-in water. Let boil. Cover and then simmer for 1 hour."
    },
    {
      "position": 2,
      "text": "Turn the heat off. Remove the boiled ruffle fat from the pot and then let the water drip-off."
    },
    {
      "position": 3,
      "text": "Rub the remaining salt all over the ruffled fat. Set aside."
    },
    {
      "position": 4,
      "text": "Meanwhile, heat the cooking oil in a deep fryer or a deep cooking pot."
    },
    {
      "position": 5,
      "text": "When the oil gets hot, slowly add-in the ruffled fat. Deep fry in low to medium heat until the texture becomes crisp and the color turns medium brown."
    },
    {
      "position": 6,
      "text": "Remove from the deep fryer or cooking pot. Arrange in a plate lined with paper towels to absorb the oil."
    },
    {
      "position": 7,
      "text": "Serve with spiced vinegar."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 80,
  "preparation_time_minutes": 10,
