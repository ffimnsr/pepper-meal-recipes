  "id": "4794b25d-6d40-53c9-9982-6b83deae0248",
  "slug": "7up-fried-chicken",
  "name": "7Up Fried Chicken",
  "recipe_type": "main",
  "brief_description": "Crispy fried chicken marinated in lemon lime soda and spices, then double-dredged and deep-fried to golden perfection.",
  "cuisine": "American",
  "instructions": [
    {
      "position": 1,
      "text": "Combine chicken with marinade ingredients (lemon lime soda, onion powder, garlic powder, salt, and ground white pepper) in a large bowl. Mix well. Marinate for at least 3 hours. Drain the remaining marinade afterwards."
    },
    {
      "position": 2,
      "text": "Heat oil in a deep fryer or deep pot to 350\u00b0F (175\u00b0C)."
    },
    {
      "position": 3,
      "text": "Beat eggs in a bowl. Dredge chicken in flour, then dip in beaten egg. Double coat by dredging in flour again. Shake off excess flour. Repeat for all chicken pieces."
    },
    {
      "position": 4,
      "text": "Deep fry for a total of 15 minutes. Note: if using less oil, fry one side for 10 minutes, then flip and fry the other side for 5 to 8 minutes."
    },
    {
      "position": 5,
      "text": "Remove the chicken from the fryer and place over a wire rack to cool down. Transfer to a serving plate. Serve and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 15,
  "preparation_time_minutes": 60,
