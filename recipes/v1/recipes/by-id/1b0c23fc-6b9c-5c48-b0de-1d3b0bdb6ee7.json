{
  "$schema": "../../schemas/recipe.schema.json",
  "schema_version": 1,
  "id": "1b0c23fc-6b9c-5c48-b0de-1d3b0bdb6ee7",
  "slug": "fried-eggplant-crispy-fritters",
  "name": "Fried Eggplant (Crispy Fritters / Talong Okoy)",
  "recipe_type": "appetizer",
  "brief_description": "Crispy grated eggplant fritter with spicy vinegar dipping sauce",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Grate the eggplants and arrange in a bowl. Sprinkle 4 teaspoons of salt. Toss until the eggplants are evenly coated. Let it stay for 10 minutes."
    },
    {
      "position": 2,
      "text": "Add 2 cups of water into the bowl. Wash the eggplants to get rid of the salt. Grab the eggplants with your hand and squeeze until the water drains completely. You can also put this in a cheesecloth and wring it until the water drains out."
    },
    {
      "position": 3,
      "text": "Combine flour, cornstarch, and baking powder in a bowl. Mix well and then set aside."
    },
    {
      "position": 4,
      "text": "Beat the eggs in a large bowl. Add the eggplants, green onions, salt, and ground black pepper. Mix it well."
    },
    {
      "position": 5,
      "text": "Gradually add the flour and cornstarch mixture. Mix until all the ingredients are well blended."
    },
    {
      "position": 6,
      "text": "Heat 2 cups of oil in a small pan. Note: the oil must be deep enough for the mixture to float."
    },
    {
      "position": 7,
      "text": "Scoop around 3 tablespoons of the eggplant mixture into the pan with hot oil. Fry until both sides are brown and crispy. Drain the excess oil and arrange the eggplant fritters on a serving plate."
    },
    {
      "position": 8,
      "text": "Make the dipping sauce by combining vinegar, sugar, salt, ground black pepper, and soy sauce in a bowl. Microwave for 30 seconds and then stir until well blended. Add chili peppers, onion, garlic, and green onion. Serve with the eggplant fritters."
    },
    {
      "position": 9,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 10,
  "preparation_time_minutes": 30,
  "rest_time_minutes": null,
  "difficulty": "medium",
