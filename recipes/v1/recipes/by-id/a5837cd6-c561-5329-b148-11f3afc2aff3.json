  "id": "a5837cd6-c561-5329-b148-11f3afc2aff3",
  "slug": "sweet-chicken-spaghetti",
  "name": "Sweet Chicken Spaghetti",
  "recipe_type": "dessert",
  "brief_description": "Sweet Chicken Spaghetti is version of Filipino spaghetti that makes use of ground chicken, instead of pork. This makes me remember my childhood",
  "cuisine": null,
  "instructions": [
    {
      "position": 1,
      "text": "Arrange the spaghetti noodles in individual plates. Set aside."
    },
    {
      "position": 2,
      "text": "Heat the cooking oil in a deep cooking pot."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the onion"
    },
    {
      "position": 4,
      "text": "Add the ground chicken and then cook for 5 minutes."
    },
    {
      "position": 5,
      "text": "Put-in the hotdog slices and chicken cube. Sprinkle about 1/4 teaspoon of ground black pepper. Stir and then cook for another 3 minutes"
    },
    {
      "position": 6,
      "text": "Pour-in the tomato sauce and water. Stir. Let boil and then simmer for 35 to 45 minutes."
    },
    {
      "position": 7,
      "text": "Add the sugar and tomato paste. Stir and continue to cook until the texture of the sauce becomes thick."
    },
    {
      "position": 8,
      "text": "Add salt and pepper to taste."
    },
    {
      "position": 9,
      "text": "Pour a portion of the sauce over the arranged spaghetti noodles."
    },
    {
      "position": 10,
      "text": "Top with shredded cheese. Serve with toast."
    },
    {
      "position": 11,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 35,
  "preparation_time_minutes": 5,
  "rest_time_minutes": null,
  "difficulty": "hard",
