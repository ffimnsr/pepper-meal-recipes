  "id": "261b5ab4-cca6-55f7-ac53-e04ba2902de1",
  "slug": "easy-utan-bisaya-law-uy",
  "name": "Easy Utan Bisaya (Law-Uy)",
  "recipe_type": "main",
  "brief_description": "Boiled assorted vegetables.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Boil water in a cooking pot. Add lemongrass and ginger. Cook for 5 minutes."
    },
    {
      "position": 2,
      "text": "Add taro and squash. Cover and continue boiling for 5 to 7 minutes."
    },
    {
      "position": 3,
      "text": "Remove lemongrass from the pot. Add okra, string beans, and eggplant. Stir. Cover and continue cooking for 7 minutes."
    },
    {
      "position": 4,
      "text": "Add Knorr Shrimp Cube. Stir and cook for 3 minutes."
    },
    {
      "position": 5,
      "text": "Add spinach. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Season with salt and ground black pepper."
    },
    {
      "position": 7,
      "text": "Transfer to a serving bowl. Serve."
    },
    {
      "position": 8,
      "text": "Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 20,
  "preparation_time_minutes": 5,
