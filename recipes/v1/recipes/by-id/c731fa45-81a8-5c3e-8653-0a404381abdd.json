  "id": "c731fa45-81a8-5c3e-8653-0a404381abdd",
  "slug": "panlasang-pinoy-spaghetti",
  "name": "Panlasang Pinoy Spaghetti",
  "recipe_type": null,
  "brief_description": "This is a recipe for Panlasang Pinoy Spaghetti. This is my trusted Filipino spaghetti recipe.",
  "cuisine": "Filipino",
  "instructions": [
    {
      "position": 1,
      "text": "Cook the spaghetti according to package instructions. Set aside."
    },
    {
      "position": 2,
      "text": "Start to make the spaghetti sauce by heating the oil in a cooking pot."
    },
    {
      "position": 3,
      "text": "Saut\u00e9 the onion and garlic and continue to cook until the onion gets soft."
    },
    {
      "position": 4,
      "text": "Add the ground pork. Cook until the color turns light brown."
    },
    {
      "position": 5,
      "text": "Add the hotdog and potted meat. Cook for 2 minutes."
    },
    {
      "position": 6,
      "text": "Pour the tomato sauce and water. Stir and bring to a boil."
    },
    {
      "position": 7,
      "text": "Add Knorr beef cube. Cover and cook in low to medium heat for 30 minutes."
    },
    {
      "position": 8,
      "text": "Stir-in the banana ketchup and add the sugar. Cook for 5 to 8 minutes."
    },
    {
      "position": 9,
      "text": "Season with salt and ground black pepper"
    },
    {
      "position": 10,
      "text": "Arrange a serving of spaghetti in a plate. Top with a generous amount of spaghetti sauce. Sprinkle shredded cheddar cheese on top."
    },
    {
      "position": 11,
      "text": "Serve. Share and enjoy!"
    }
  ],
  "servings": 4,
  "cooking_time_minutes": 50,
  "preparation_time_minutes": 10,
  "rest_time_minutes": null,
  "difficulty": "hard",
